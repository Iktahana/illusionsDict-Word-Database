          "literary": [
            {
              "text": "壁には髭もじゃ爺の写真がかかっているだけだ。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギンネコ号の艇長といえば、かれがなじみの鴨艇長だとばかり思っていたのに、それが意外にも、別人の髭もじゃの老人だったので、もうすこしで「あッ」と叫ぶところだった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は髭もじゃの博士の横顔をしばらく見ていた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう、この髭もじゃか」と、ケレンコは目をみはって、「ところで衛兵長、お前は、三人のあやしい男を発見したとかいったが、あとの二人はどうしたのか」「はい、二人はその場で、鉄砲でうちたおしてあります。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご安心ください」「おお、そうか」　と、司令官はうなずき、クイクイの神様の方にむいて、「おい、髭もじゃ。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ、この髭もじゃ先生、おれの体から卵を、ぬきだしやがったぜ。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "技師は、ひげもじゃの大きな顎を持っていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひげもじゃの顎と、上唇をあつかましい笑いにほころばせながら。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の高い、ひげもじゃの、あまり見かけない顔だった。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひげもじゃらの、髪もぼさぼさの、山賊みたいな俺をうさん臭そうに見た洋品店の小僧に、「この近所の銭湯はどこだい。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、ゆっくりおよいでいるがいい」　てんじょうで、ひげもじゃのかおがのぞいています。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかれないかね」　てんじょうのあなから、ひげもじゃの二十めんそうがからかっているのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎らしいことには、ひげもじゃの方の潤ちゃんが、あっけに取られた黒衣婦人を嘲笑するように、お化けみたいに笑っている。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智の奥さん、とうとうおれは君を手に入れたぜ」　ハッピ姿のひげもじゃの男が、顔の上にのしかかるようにして、毒々しく呼びかけている。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
