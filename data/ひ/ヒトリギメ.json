[
  {
    "uuid": "a2d0277c-22d0-55eb-acc7-8f92c0eff5d5",
    "entry": "独り決め",
    "reading": {
      "primary": "ひとりぎめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
