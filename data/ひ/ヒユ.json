  {
    "uuid": "3fe9a3c8-7d53-5e81-afdf-7df26a367620",
    "entry": "莧",
    "reading": {
      "primary": "ひゆ",
      "alternatives": [
        "ひょう",
        "ヒユ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Joseph's-coat (Amaranthus tricolor)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔われのみみちにたゞしきと〕われのみみちにたゞしきと、　　ちちのいかりをあざわらひ、ははのなげきをさげすみて、　　さこそは得つるやまひゆゑ、こゑはむなしく息あへぎ、　　　春は来れども日に三たび、あせうちながしのたうてば、　　すがたばかりは録されし、下品ざんげのさまなせり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつし身のつひに果てなん極みまで　　添ひゆくいのち正眼には見よ第三五課　家庭　私は紅山茶花を見るといつも思うのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北から冷たい風が来て、ひゆうと鳴り、はんの木はほんたうに砕けた鉄の鏡のやうにかゞやき、かちんかちんと葉と葉がすれあつて音をたてたやうにさへおもはれ、すすきの穂までが鹿にまぢつて一しよにぐるぐるめぐつてゐるやうに見えました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "別当がこんどは、革鞭を二三べん、ひゆうぱちつ、ひゆう、ぱちつと鳴らしました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　別当がむちをひゆうぱちつとならしましたのでどんぐりどもは、やつとしづまりました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　別当が、むちをひゆうぱちつと鳴らしました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　別当が、むちをひゆうぱちつと鳴らし、どんぐりはみんなしづまりました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "別当も大よろこびで、五六ぺん、鞭をひゆうぱちつ、ひゆうぱちつ、ひゆうひゆうぱちつと鳴らしました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪童子はわらつて革むちを一つひゆうと鳴らしました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その裂くやうな吼えるやうな風の音の中から、「ひゆう、なにをぐづぐづしてゐるの。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゆうひゆうひゆう、ひゆひゆう、降らすんだよ、飛ばすんだよ、なにをぐづぐづしてゐるの。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゆう、ひゆう、向ふからさへわざと三人連れてきたぢやないか。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひゆう、ひゆう、さあしつかりやるんだよ。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひゆう、ひゆう、なまけちや承知しないよ。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゆう、ひゆう、ひゆう、ひゆうひゆう。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
