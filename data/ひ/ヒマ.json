    },
    "definitions": [
      {
        "index": 1,
        "gloss": "castor oil plant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少し熱があるから、すつかり下剤をかけた方がいいだらうといふので、蓖麻子油を飲むことにした。",
              "citation": {
                "source": "八月の霧島",
                "author": "吉田絃二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十グラムまでは大丈夫だと言つてＮ氏は五郎八茶碗になみなみと蓖麻子油を注いでくれた。",
              "citation": {
                "source": "八月の霧島",
                "author": "吉田絃二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書の綱が性慾のコマを廻す原始人の礼儀は外界物に目も呉れないで目前のものだけを見ることでしただがだが現代文明が筆を生みました筆は外界物です現代人は目前のものに対するにその筆を用ひました発明して出来たものが不可なかつたのですだが好いとも言へますから――僕は筆を折りませうか？",
              "citation": {
                "source": "迷つてゐます",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は弱いので、　悲しみに出遇ふごとに自分が支へきれずに、　生活を言葉に換へてしまひます。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人によつて色々異ることと思ひますが、私は詩に就いては自分に分るやうにだけは考へますが、それを人に分らせようとするや大変骨が折れます。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言で云へば、必竟偶然を排し詩を判然と人間の意識の手中に収めたいといふ精神と云ふことが出来るかと思ひますが、それが判然と実現出来れば、全く喜ばしいことであります。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年、「宮沢が死んだ」と聞いた時には、大変気の毒に思ひました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の我々の感性に近いもの、寧ろ民謡でさへある殉情詩が、此の殉情的な国で、今迄読まれなかつたなぞといふことは不思議だと、今度此の全集の第一巻が出た後では、諸君も必ずやさうお思ひになることと思ひます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔まひるつとめにまぎらひて〕宮沢賢治まひるつとめにまぎらひてきみがおもかげ来ぬひまはこころやすらひはたらきしそのことなにかねたましき新月きみがおももちをつきの梢にかゝぐれば凍れる泥をうちふみてさびしく恋ふるこゝろかな",
              "citation": {
                "source": "〔まひるつとめにまぎらひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私思ひますに、我が国人の素質は非常によく、開化の段階は猶低いのであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶は雪のふる都會の夜にしづかな建築の家根を這ひまはるさびしい青猫の影の影記憶は分身のやうなものだ。",
              "citation": {
                "source": "記憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またおひまの折には、おたよりを下さい。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の三、四年生の頃だつたと思ひます。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく恥かしく思ひました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五年、十年生きてゐてもらつて、私が多少でもいゝ仕事をして、お父さに喜んでもらひたかつた、とそればかり思ひます。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの一枚を、二円で買ひました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの画は、今も豊田様のお家に、あると思ひます。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいへ詩とは、かういふものだと、何とか云つて見たく思ひます。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「正ちやん、人が笑ひますよ、そんなことを言ふと。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ私の代りをやつてご覧なさいまし、とても目がまひますよ……」「黙れ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ貴兄が特異で在ることと、僕が論文を纏める才にひどく乏しい上に論文の大体の相手を持たないために随分変なものかも知れないが、単なる好意で書いたものでも単なる悪意で書いたものでもないのだから、　読んだら返事を願ひます。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お眠り、ねえおまへ病気ですよ、誰かセレナードを……男の方々はみんな寝ちまひました！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」が、冗談ぢやない、僕は僕が輝けるやうに生きてゐた。",
              "citation": {
                "source": "酒場にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかゞとりはからひませうか」と言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十二年六月十九日生れの宿命を、あなたもご存じの事と思ひます。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し休みたいと思ひます。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢應の鯉魚は、三井寺の興義といふ鯉の畫のうまい僧の、ひととせ大病にかかつて、その魂魄が金色の鯉となつて琵琶湖を心ゆくまで逍遙した、といふ話なのですが、私は之をよんで、魚になりたいと思ひました。",
              "citation": {
                "source": "魚服記に就て",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ君ともあらうものが、こんな投げやりな文章では仕樣がないと思ひましたので、「實に下手だ。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かまた本を送つてよこして下さい、と戰地から頼んで來ましたので、私は新宿へ行き、華麗な裸婦のたくさんある泰西の畫集を三册買ひました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
