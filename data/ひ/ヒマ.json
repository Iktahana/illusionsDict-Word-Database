[
  {
    "uuid": "06439cac-fcb8-52d0-8b83-f4192758f728",
    "entry": "蓖麻",
    "reading": {
      "primary": "ひま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
