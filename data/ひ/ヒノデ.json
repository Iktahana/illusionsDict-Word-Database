        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自然に対しても、近代人は近江八景や、二見ヶ浦の日の出のような、伝習に囚われた名所や風光で満足が出来ないのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月の炎天というのに、黒｜羅紗の外套を着る、毛糸の襟巻をする、革の手袋をはめる、かくして岩頭に金剛杖をブッ立て、日の出の大観を眺めていた。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上の日の出がどんなに美しかろうが、海鳥が飛ぼうが、鯨がはねようがそんな事はどうでもよい、一刻も早く目的地に上陸して動かぬ地盤が踏みたいと願う。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "×・30　二日の出立が四五日延期となる。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで日の入りがぼやけた朱色に見え、日の出が褪めた桃色に見えるが、兎に角その交代して繰り返されて行くことが分かる。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎には、すべてが、つい一昨日の出来事のようにまざまざと躍っている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みかかった雲は、東方からさしてくる赤い日の出に、薄紫色に染めぬかれて、ゆるやかに動いていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の出前学校は、　　稗と粟との野末にて、　　朝の黄雲に濯はれてあり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし俺もこの頃は考え方が少しちがって来た」「そうか」　堯はその日の出来事を折田に話した。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝、私は日の出を見に海辺に立っていたことがありました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　これはあなたにこの手紙を書こうと思い立った日の出来事です。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘が手に届かない位高かったのを見事に飛んだ……云々の二項で、当日の出来がゾッとするほどハッキリとわかった。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別に変った生活もしませんが、私達は日の出前に起床し、日が暮れて床に就き、明るいうちはせっせと働いて日を送っています。",
              "citation": {
                "source": "働く町",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一日の出来事はどういうものか私の中学時代の思い出の中に目立って抜き出た目標の一つになっている。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞の記事はその日その日の出来事をできるだけ迅速に報知する事をおもな目的としている。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず試みに「炭俵」上巻の初めにある芭蕉｜野坡の合奏を調べてみると、「むめが香にのっと日の出る山路かな」の発句にはじまって、「屏風の陰に見ゆる菓子盆」の揚げ句に終わる芭蕉のパートにはいったいにピッチの高いアクセントの強い句が目に立つ。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば七部集炭俵の中にある「雪の松おれ口みればなお寒し」「日の出るまえの赤き冬空」「下肴を一舟浜に打ち明けて」の三連などは色彩的にもかなりおもしろいものである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊更らにその輪廓の大きさと重々しさとを増した蝦夷富士は、鋼鐵のやうな空を立ち割つて日の出る方の空間にそゝり立つてゐる。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の出ずるも間も無い事であろう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかる時に期せずして、朝の人は日の出を望むであろう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初日の出、」　いいかけて急に膝を。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……抱妓が五人と分が二人、雛妓が二人、それと台所と婢の同勢、蜀山兀として阿房宮、富士の霞に日の出の勢、紅白粉が小溝に溢れて、羽目から友染がはみ出すばかり、芳町の前の住居が、手狭となって、ここに鏡台の月を移して、花の島田を纏めたものが。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、北守将軍ソンバーユー　ある日のちやうど日の出ごろ、ラユーの町の人たちは、はるかな北の野原の方で、鳥か何かがたくさん群れて、声をそろへて鳴くやうな、をかしな音を、ときどき聴いた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日の出づる邊、我故國では今頃は定めて、都大路の繁華なる處より、深山の奧の杣の伏屋に到るまで、家々戸々に日の丸の國旗を飜して、御國の榮を祝つて居る事であらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも波浪に揉まれて、此方に廻りし其艦尾には、赫々たる日輪に照されて「日の出」の三｜字が鮮かに讀まれた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍艦「日の出」の甲板では、後部艦橋のほとりより軍艦旗飜る船尾に到るまで、多くの乘組は、列を正して、我端艇の歸艦を迎へて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、此噂は早くも軍艦「日の出」の全體に傳つたが、誰れも其本分を忘れて「どれ、どんな男だ」などゝ、我等の側に飛んで來る樣な不規律な事は少しも無く。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "青や紫を使つてゐても、大智氏の場合には、その色彩を墨色と同様の扱ひをする、墨以外の色を、墨の扱ひのできる作家といふのは、日本の画壇にはさう沢山はゐないのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、貴方真人間に成損つたとお言ひのですな」「さうでございます」「さうすると、今は真人間ではないと謂ふ訳ですか」「勿論でございます」　直道は俯きて言はざりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は本当につらひのですけれど、これも自分のゆくべき道ならば仕方がないのです。",
              "citation": {
                "source": "書簡　山田邦子宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
