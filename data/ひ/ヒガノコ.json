    "definitions": [
      {
        "index": 1,
        "gloss": "cloth tie-dyed with a scarlet red dappled pattern",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その襟がたぶん緋鹿の子か何かであろう、恐ろしくぎざぎざした縮れた線で描かれている。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は緋鹿の子の帯揚が胸のところにこぼれているのを見つけだすと、慌てたように帯の間にたくしこんで、胸をかたく合せた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その緋鹿の子の扱帯が、白鷺に鮮血の流れるようです。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、帯は緞子の帯ならば、その滑らかな地質がその物の如く現われ、また緋鹿の子の帯上げならば、鹿の子に絞り染めた技巧がよく会得されるように精巧に試みました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "引き続き作に苦心したこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "至極江戸前女で、緋鹿の子の手柄をかけていいわたに結った、黒エリをかけた下町ッ子のチャキチャキだった。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋鹿の子の地に大きく牡丹を染め出した友禅の長襦袢に伊達巻き一本のおきえさんの姿は阿娜めいて昼間のおきえさんとは別人の観があった。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長吉はねずみちりめん無垢の上衣、緋ぢりめん無垢の下着、白の浜｜縮緬のゆまき、緋鹿の子のじゅばんを着ている。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "面長な下ぶくれな顔に黒い鬢を張って、おしどりに結って緋鹿の子の上を金紗でむすんでいた。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄八丈に黒繻子の襟、緋鹿の子の半襟、絞りばなしの鹿の子の帶。",
              "citation": {
                "source": "下町娘",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "折しも、通りすがった二人づれ――対の黄八丈を着て、黒繻子に緋鹿の子と麻の葉の帯、稽古帰りか、袱紗包を胸に抱くようにした娘たちが、朱骨の銀扇で、白い顔をかくすようにして行く、女形を、立ち止って見送ると、「まあ、何という役者でしょう？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾模様が付いて居ります、紅かけ花色、深川鼠、路考茶などが流行りまして、金緞子の帯を締め、若い芸者は縞繻子の間に緋鹿の子をたゝみ、畳み帯、挟み帯などと申して華やかなこしらえ、大勢並んで、次の間にお客様のおいでを待って居ります。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ娼妓たちでしょう、頭にかぶさる位の大きな島田髷に、花簪の長い房もゆらゆらと、広い紅繻子や緋鹿の子の衿をかけた派手な仕掛姿で、手拍子を打って、幾人も続いて長い廊下を往ったり来たりします。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――扱帶は私のでも間に合はないことはないでせう」　くる／＼と解いたお半の扱帶、同じ緋鹿の子絞りを、自分の手で土藏の窓からサツと、外へ投げかけました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "紅い扱帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "その編笠の紐の緋鹿の子の、くっきりと映えるような美しいのも居たというが、着物はすべて木綿に限ったもので、あの人達ほど木綿の着物をしゃんと着こなして居た者はないと、亡き母の言った言葉を覚えて居る。",
              "citation": {
                "source": "寺町",
                "author": "岩本素白",
                "note": "青空文庫"
              }
            },
            {
              "text": "――扱帯は私のでも間に合わないことはないでしょう」　くるくると解いたお半の扱帯、同じ緋鹿の子絞りを、自分の手で土蔵の窓からサッと、外へ投げかけました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "紅い扱帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋鹿の子を絞った長襦袢が少し崩れて、燃えるような紅の綸子の夜の物が、砕けた花片のように桜子の膝を埋めます。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第三夜　お化け若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤色の大振袖と、緋鹿の子の長襦袢と、精巧の袴と、紅綸子の夜の物と、何んという妖しい取り合せでしょう。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第三夜　お化け若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋鹿の子の結綿で足を縛られて、その上｜櫛を差し込んであるんだから、どんな烏だって飛びやしません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な悪戯をする人間もあったものじゃございませんか」　番太の爺が出したのは、燃えるような緋鹿の子の結綿と、鼈甲の櫛が一つ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "首を絞めた緋鹿の子の扱帶は、解いて床の側に置きましたが、心なくも苦痛に歪んだ小さい顏はむき出しのまゝ、髮の亂れも衣紋の崩れも、言ひやうもなく痛々しいのに、三輪の萬七はそれを直してもやらなかつたやうで、それはひどく冒涜的にさへ見えるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鍵の穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "髮形をすつかり堅氣の娘風にしたお靜の後姿――黄八｜丈の袷と緋鹿の子｜帶が、唐花屋の暖簾をくゞつて見えなくなつた時は、大日坂の下から遠く樣子を見て居た錢形の平次も、さすがに眼の前が眞つ暗になるやうな心持がしました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金色の處女",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪形をすっかり堅気の娘風にしたお静の後ろ姿――黄八丈の袷と緋鹿の子帯が、唐花屋の暖簾をくぐって見えなくなった時は、大日坂の下から遠く様子を見ていた銭形の平次も、さすがに眼の前が真っ暗になるような心持がしました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金色の処女",
                "note": "青空文庫"
              }
            },
            {
              "text": "額全体が余程古いものらしく、背景の泥絵具は所々はげ落ていたし、娘の緋鹿の子も、老人の天鵞絨も、見る影もなく色あせていたけれど、はげ落ち色あせたなりに、名状し難き毒々しさを保ち、ギラギラと、見る者の眼底に焼つく様な生気を持っていたことも、不思議と云えば不思議であった。",
              "citation": {
                "source": "押絵と旅する男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "からたちのいばらを透かして華やかな友禅ちりめんと緋鹿の子の帯揚が見えた。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
