        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからひと騒動、まあ、お聴きください」　死んだ女は日本橋材木｜町、俗に杉の森｜新道というところに住んでいるお半という者であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風にこぐらかって来ると、ひと騒動おこるは必定。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の伝六のひと騒動におどろいて舞い逃げたとみえて、意外なところに止まっていたのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼くなって卒倒したのですから、ここにまたひと騒動おこりました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと騒動始まりましたよ」「どうした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "如才なく護つてはあるだらうが、とにかくひと騒動だ。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祈りのあとで、ひと騒動もちあがった。",
              "citation": {
                "source": "身体検査",
                "author": "ソログーブ・フョードル",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが下妻の里とすれば、自分の姿を見つけられては、ひと騒動もち上るに相違ない。",
              "citation": {
                "source": "平馬と鶯",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、またひと騒動がはじまった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "筏の鎖をはずすのでまたひと騒動。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし泰造も多計代も、その崖の下に駅から走って来たハイヤを停めて、髪の赤い子供らに囲まれながら、ひと騒動して出入することについて、ちっともばつの悪さは感じないらしかった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多計代は、「やれ、やれ、相もかわらずひと騒動だ」と椅子にもたれこんだ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま一分もしたら、彼女はもうひと騒動もち上げかねない有様だった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら、俺もどこかカフェー・シャンタンの帰りで、しかも何か途中でひと騒動やったという様子をしているらしい。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国に持っていけばひと騒動だろう」「君はそれで稼げる。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはぜひともこの（単純そうな）男を城下へ伴れ戻して、ひと騒動おこして手柄をたてさせ、ついでにおれも仕官するという手だ。",
              "citation": {
                "source": "日日平安",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬廻りには「精明館」の門人が多いので、しぜん両者が対立するようなかたちになり、そのときもひと騒動起こりそうになった。",
              "citation": {
                "source": "四日のあやめ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
