[
  {
    "uuid": "d305e1f1-b8b4-571e-b5f3-2aa675cd830b",
    "entry": "火消し",
    "reading": {
      "primary": "ひけし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
