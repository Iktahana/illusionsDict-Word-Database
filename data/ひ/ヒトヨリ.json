[
  {
    "uuid": "b965843d-25f7-5db5-a59f-d3d573d7058c",
    "entry": "人より",
    "reading": {
      "primary": "ひとより",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
