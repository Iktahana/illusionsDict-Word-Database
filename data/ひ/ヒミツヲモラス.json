        "examples": {
          "standard": [
            {
              "text": "大切な顧客の情報を秘密を漏らすようなことは決してできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、口の軽い友人にうっかり秘密を漏らしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "もし私がその秘密を漏らすようなことがあれば、信用を失うだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "五人の中で悧巧な信太郎は、隙を見て土蔵を脱け出しましたが、村右衛門に脅かされた言葉が恐ろしくて秘密を漏らす間もないうち、鋳掛屋の権次に誘い出され、こんどはうんと権次に責められて土蔵の秘密を打ち明け、かえって権次に殺されたのでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "五つの命",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男なら決して伯爵の秘密を漏らすような事はありません」「どうか、その辺の事はよろしくやってもらい度い」「では直ぐ使をやりましょう」左の手の疑問「何んの用事だい」　使を出してから三時間目に、「足の勇」は伯爵家の応接間に入って参りました。",
              "citation": {
                "source": "死の予告",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかり重大な秘密を漏らすところだった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "女二人、流浪のみぎり、同情の気持ちが湧いたが、まだ秘密を漏らすほどにはなっていない。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
