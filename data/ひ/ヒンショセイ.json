[
  {
    "uuid": "3eb14c60-6183-5795-925c-1a5a33bdaf60",
    "entry": "貧書生",
    "reading": {
      "primary": "ひんしょせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
