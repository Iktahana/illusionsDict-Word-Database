        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "卒業の証書も生活の保証も命さへも要らないと云ってゐるこの若者の何と美しくしかも扱ひにくいことよ　扉がまたことことと鳴った。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も見舞ひにくる者もない、さうした日の午後など、私は病後のうら寂しい氣持で窓際の椅子に凭りながら、靜かな雨脚を眺め暮してゐるのであつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、これは兄として言ひにくいことだが、きつと恥かしい病氣にでもかかつて、やけくそになつたのだらう。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の池の鯉を、大小計つてねらひにくるが、仕かけさへすれば、すぐにかゝる。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　きのふまで五日のあひだ、毎日おなじ時刻に飴を買ひにくる女がある。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜もやはりそれで、無理に狩り出されて山の手から下町まで出かけて来たのであるが、あひにくに今日は昼間から陰つて底冷えがする。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あひにくに又降り出しました。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あひにく電車が些つとも来ないやうですね。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あひにくに風があるので、火の手は瞬くひまに拡がつて、もう何うすることも出来ない。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もの皆悲しく、憂ひにくづるる濱邊の心ら。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつたい此等の聴衆共は、音楽を味ひにやつてくるのか、音楽会の気分を味ひにくるのか。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに紙鳶は大きく扱ひにくかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その答は、いひにくかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とその人はいひにくさうに答へた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の原書をかひにくるのは猫中の材料だ。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟は、うすい下唇をちろちろ舐めながら、寢がへりもせず聞いてゐたが、けつこんするのか、と言ひにくさうにして尋ねた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頗る言ひにくい話であるが、彼とふたりで遊び歩いてゐると勘定はすべて彼が拂ふ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、Ｎ君は、言ひにくさうにして言ふのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「獨り者だから」と、云ひにくいのを、さりげなく見せながら、「口説くかも知れませんよ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分とはかの女がこちらをさして云ふので、お前とも呼びつけに出來ず、さうかと云つて、またあなたとは氣が引けていひにくいところから、さういひなして來たのだらう。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女の兒（外に子供はゐないのだから、言ひにくい島民名前などは持出さずに、唯、女の兒とだけ呼ぶことにしよう）が生れる前の十數年間、一人の赤ん坊も此の島に生れなかつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀ちやんだつて強い軍人のお面をかぶりたかつたには異ひなかつたでせうが、あひにくその時にはもう強いお面は一つも残つてゐなかつたのです。",
              "citation": {
                "source": "泣き笑ひ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それは、ちよつとこゝでは云ひにくい！",
              "citation": {
                "source": "鸚鵡の思ひ出",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故僕が強情を張るか、その理由はちよつと……云ひにくいこともないけれど、云つたつて仕様がないから、云はない。",
              "citation": {
                "source": "晩秋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あひにくそばにランプがありません。",
              "citation": {
                "source": "青い顔かけの勇士",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々絶えずとぶらひにく。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子を更に手拭ひにくるんで、俺は彼に手渡した。",
              "citation": {
                "source": "木枯の吹くころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（云ひにくさうに又あたまを掻く）御病氣中おせき立て申すのは餘りに心ないやうで、なんとも申兼ねる次第でござりますが……。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "春いくとせいつか忘れてゐた言葉あなたが拾つてもつてゐたいくねんまへの春だつた「青麥の青きをわけて、逢ひにくる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
