    },
    "definitions": [
      {
        "index": 1,
        "gloss": "irony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "特に月々の「文藝春秋」に出すアフォリズム風の文字（侏儒の言葉）は、機智のために機智を弄する弄筆者流の惡皮肉で、憎惡的にさへ不滿を感ぜずに居られなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその客が歸つたあとでは、けろりとして皮肉の舌を出すだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからして自分は、時にしばしば彼を「意地惡き皮肉の人」とも考へた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと甚だしくは、談話の後で舌を出す皮肉な惡漢――意地の惡い諷刺家――とさへ想像した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸途に別れる時、室生は例のずばずばした調子で、私に向つて次のやうな皮肉を言つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（しかも皮肉なことには、その催眠劑がまた彼を死に導いた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮肉や諷刺じゃないわけだ。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は何を云つたかよくは覚えてゐないが、兎も角新しき男に皮肉めいたことを喋舌つたことを覚えてゐる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところがその……僕には神剣なんかつて分り兼ねますのでね……」　彼の皮肉は従兄には皮肉だとも取れなかつたらしかつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち「侏儒の言葉」は、江戸ツ子的浮薄な皮肉とイロニイとで、人生を単に機智的に揶揄したもので、パスカルやニイチエのアフオリズムに見る如き、真の打ち込んだ人生熱情や生活体感が何処にもない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "百数十年も昔に作った蕪村の詩が、明治の新体詩より遥かに芸術的に高級で、かつ西欧詩に近くハイカラであったということは、日本の文化史上における一皮肉と言わねばならない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、カナダのタール教授が来て氷河に関する話をしたときなど、ペンクは色々とディスクシオンをしながら自分などにはよく分らぬ皮肉らしいことを云って相手を揶揄しながら一座を見渡してにやりとするという風であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私とても、言葉の上の皮肉や、自分の行李を放り込む腹癒せ位で、此事件の結末に満足や諦めを得ようとは思っていなかった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のことだけだって考え剰っている筈の若い年頃の男が、年寄の女に向って年齢のことを気遣うのなども、もう皮肉に気持ちがこずんで来た証拠だね」　柚木は洞察の鋭さに舌を巻きながら、正直に白状した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の感情はそっちのけに、養母が動揺するのを気味よしとする皮肉なところがあった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、英国人ぐらい文筆上で女性に対し諷刺や皮肉を弄し、反感を示している国民は少い。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　などと皮肉らしく云われても平気です。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「意気なお方につり合ぬ、野暮なやの字の屋敷者」という皮肉な嘲笑を甘んじて受けなければならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか皮肉な、今にも例の人を笑わせる顔をしそうなところがある。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう云った時にアインシュタインの顔が稲妻のようにちょっとひきつったので、何か皮肉が出るなと思っていると、果して「自然が脳味噌のない『性』を創造したという事も存外無いとは限らない」と云った。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄腸｜居士を父とし、天台道士を師とし、木堂翁に私淑していたかと思われる末広君には一面気鋒の鋭い点があり痛烈な皮肉もあった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときアインシュタインが「もし私が 〔be^te noire〕 だったらこんなことはあるまい」といって皮肉に笑ったそうである。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこの曲った標柱は天然自然の滑稽であり皮肉である。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあらを捜したり皮肉をいうばかりが批評でもあるまい。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなりの皮肉屋であったが、ときどき面白い観察の眼を人間一般の弱点の上に向けて一風変ったリマークをすることがあった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生君の告別演説には、自己に對する反省と苛責とがあり、それが外部に八當りして、多少皮肉な調子を帶びてゐた。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小學時代には、或る腕白小僧の友だちがゐて、よく子供らしい意地惡から、僕を皮肉にからかつたり惡口したりした。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業の証書も生活の保証も命さへも要らないと云ってゐるこの若者の何と美しくしかも扱ひにくいことよ　扉がまたことことと鳴った。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も見舞ひにくる者もない、さうした日の午後など、私は病後のうら寂しい氣持で窓際の椅子に凭りながら、靜かな雨脚を眺め暮してゐるのであつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、これは兄として言ひにくいことだが、きつと恥かしい病氣にでもかかつて、やけくそになつたのだらう。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
