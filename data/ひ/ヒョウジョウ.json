  {
    "uuid": "af3bb9a9-e0e3-5410-a507-41f01c924391",
    "entry": "氷上",
    "reading": {
      "primary": "ひょうじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "on (the) ice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四　馬が苦しげに氷上蹄鉄を打ちつけられた脚をふんばって丘を登ってきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒橇や、荷馬車や、徒歩の労働者が、きゅうに檻から放たれた家畜のように、自由に嬉々として、氷上を辷り、頻ぱんに対岸から対岸へ往き来した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、きしきしという軋りが聞えて、氷上蹄鉄を打ちつけられた馬が、氷を蹴る音がした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は、滑らないように下面に釘が突出している氷上蹄鉄で、凍った雪を蹴って進んだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷上月のたはむれ薫ゆるころ、　　氷は冴えてをちこちに、　さゞめきしげくなりにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛する兄弟よ、まことに師走におよび、爾は裸體にして氷上に匍匐し、手に金無垢の魚を抱きて慟哭するところの列傳孝子體である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪白の幌内川の氷上に、ただひとつ穿たれたばかりの黒い穴。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはすぐに見えなくなったが、再び左舷にあらわれて、氷上に投げた影のように、はっきりとそれを認めることが出来た。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は氷上に出て漁猟をする人々があり、夜は氷を截つて氷庫に運ぶ人々がある。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俯し目になつた視線が、氷上の人まで達する距離は可なりあるのであるが、氷上の人の槌を揮ふ手つきまで明瞭に見える。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水面を離れる石が氷上に置かれる頃は、もうからからに凍つてゐるからである。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早くから氷上に立つて、牢屋の中へ魚が納るまでには、短い冬の日が一ぱいに用ひられるのであつて、竹簀をあげて魚を魚籃の中へ捕り入れる頃は、日はもう湖の向ひの山へ傾いてゐるのである。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖面を吹く風は、障るものなき氷上を一押しに押して来る。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大凡周囲四里半の氷上にあつて、漁人の生活は、全く世の中との交渉を杜絶する。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "只日に一度、弁当を提げて漁場へ運んで来る妻女の姿が氷上に現れる。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬季には、この湖水も諏訪湖と同じく凍りついて、氷上を渡ることが出來る。",
              "citation": {
                "source": "霧の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝道尊重は確に支那人の一美點に相違ないが、ただ何事にも精神を後にして、形式を先にする支那人は、孝行といへば、裸體で氷上に臥して、親の病氣の平癒を神に祷るとか、昔の二十四孝の極端な手本を、その儘に眞似する者が尠くない。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、瓦斯の減量につれて浮揚性を失った船形棺は、拳銃を載せたまま湖底に横たわっている妻アビゲイルの死体の上に沈んでいったのですが、一方牧師の身体は、四肢が氷壁に支えられてそのまま氷上に残ってしまい、やがて雨中の水面には氷が張り詰められてゆきました。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍結した氷上はむしろ歩き易いであろう。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "六人の隊員は不要の物を氷上にすてゝ飛行機に乗り込みました。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その隊員一同は、氷上生活の間に絶えず海流や気象や氷塊の運動などを研究し、氷原の状態を詳しく調査して、発見する事柄が少くなかつたのです。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年の五月二十二日、飛行機で着水して氷上に生死の間をさまよつたのは、其処から五十哩ばかり西方の地点だつた。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙間から氷上を眺めると、やはり陸地のないことが確かめられた。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "北極の氷上に記念として置かれた三ヶ国の国旗、それを眺めて一同は感激の極みにあつた。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした場合には、吾々はもう飛行船を棄てゝ氷上を徒歩して、どこかの海岸までたどりつくより外に方法はない。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠が亡くなつてから、丹波氷上の田楽能の一座の部領に迎へられて、十年あまりをそこで過して居つたが、兄弟子の信吉法師が行方不明になつた頃呼び戻されて、久しぶりで住吉に帰つた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷上で娶つた妻も早く死んで、固より子もなかつた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠のお話では、氷上で育てた弟子のうちにも、さういふ風に、房主になりたい／＼言ひづめで、とゞのつまりが、蓮池へはまつて死んだ男があつたといふぜ。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ばかりや瓜生野座の命ぢやらうて、坂下や氷上の座から、幾度土べたに出額をすりつけて、頼んで来ても伝授さつしやらなんだ師匠が、われだけにや伝へられた揺拍子を持ち込みや、春日あたりでは大喜びで、一返に脇役者ぐらゐにや、とり立てゝくれるぢやろ。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて御城内におきましては、十八日からひろまにおより合いなされまして御ひょうじょうがござりましたが、くわしいことは存じませぬけれ共、亡君のおん跡目相続のこと、明地闕国の始末についての御だんごうらしゅうござりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
