[
  {
    "uuid": "1f63f009-97d1-53b5-af96-6145cb4950ed",
    "entry": "表情",
    "reading": {
      "primary": "ひょうじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "facial expression",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「全くだ」とＡも思ふ、「しかしま、お手柔らかに」と、表情以て友達甲斐を発揮する。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで思はず、Ａのカマに掛かり、ニツコリしたり、或は、急に不慣れな問題が跳出したので、表情が激変したりする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私が今歩いてゐる時に持してゐる私の表情は、悲しげなものであるかも知れない。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはむやみと生硬の漢語や、俗悪で不自然な言葉のアクセントや、中学生じみた幼稚な興奮や、およそさうした類の低能な感傷的表情を、むやみと鼓張した態度で一本調子に並べたてられて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の表情では、いけないか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦痛の叫びは、いよいよ世の嘲笑の声を大にするだけであろうから、男は、あらゆる表情と言葉を殺して、そうして、ただ、いも虫のように、もそもそしていた。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思わず口を滑らせたら、菊ちゃんは一瞬はっと表情をかえて妙にまじめな眼つきで私の顔を見つめたかと思うと、くるっと私に背をむけお盆で顔をかくすようにして店の奥へ駈けこんでいったものだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの不機嫌そうな表情を、円滑に、取り戻すことができたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱のように無表情であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕は馬場さんを信じています」「はあ、そうですか」私の精一ぱいの言葉を、なんの表情もなく聞き流して、「今度の雑誌のことだって、僕は徹頭徹尾、信じていません。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頭を屈めた際につむつた眼を、云ふことの出来ない表情で開くと、閉つた口をムニヤムニヤとさせた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一先づ拑子を引くと再び赤坊は此の世のものとしての苦しさうな表情となつて出来るだけ泣き喚き出した。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白い所では人は寧ろニガムシつぶしたやうな表情をする。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら技巧とは一々の場合に当つて作者自身の関心内にあることで、殊に芸術の場合には名辞以前の世界での作業であり、技巧論即ち論となるや名辞以後の世界に属する所から、技巧論といふものはせいぜい制作意向の抽象表情を捉へてそれの属性を述べること以上には本来出ることが出来ない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が這入つた時、教師達は誰も話をしてはゐなかつたが、それと知ると其処にゐた全部の者は一斉に、不馴れな人間に対する心意気のない、畏敬の表情を作つて差向けてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが外国人だから嫌な表情にみえないんだが、日本人だつたらどんなに嫌に見えるだらう。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして祖母の表情が余り露骨だから父もそれを知つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――我国の女がまことに無表情に出来てゐることを知つてゐる者のその誰でもが今彼女の夫に対してしたことは、まあ女優か何かにしか思へなかつたのである。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "この温泉の空気を代表する浴客は、主として都会の中産階級の人であるが、とりわけさうした人たちの若い夫人や娘たち――と言つても、大磯や鎌倉で見るやうな近代的な、中凹みで睫毛の長い表情をした娘たちではない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、この母と娘は氣が合つて、いつも何かと笑ひ騷ぎ、そのために、この家庭は、お旦那の苦蟲を噛みつぶしたやうな表情にもかかはらず、まづ明るい印象を人に與へる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ叫びも、狸の不意の訪問に驚き、かつは喜悦して、おのづから發せられた處女の無邪氣な聲の如くに思はれ、ぞくぞく嬉しく、また兎の眉をひそめた表情をも、これは自分の先日のボウボウ山の災難に、心を痛めてゐるのに違ひ無いと解し、「や、ありがたう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは少しも表情を變へず、默つて雀を見てゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手も火夫も、鋭い表情になって、機械に吸い込まれてしまった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "同乘の小學生を注意して見ると、勿論みんな違つた顏であるが、其れで居て妙にみんなよく似た共通の表情がある。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　警視長官は面白くもない昔の唄を町の唄うたいが義務で唄う表情を想像して笑いたくなったが我慢して穏かに断った。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長なす黒髪を項の中から分けて豊かに垂れ下げ、輪廓の正しい横顔は、無限なるものを想うのみ、邪なる想いなしといい放った皎潔な表情を保ちながら、しら雲の岫を出づる徐なる静けさで横に移って行く。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彼女は職業の場所に出て、好敵手が見つかると、はじめはちょっと呆けたような表情をしたあとから、いくらでも快活に喋舌り出す。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの窓にはたくさんの顔がみな一様な表情を浮べてゐた。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かな愚かな表情を、院長さんとその園芸家とどっちが頭がうごくだらうといった風の――えい糞考へても胸が悪くなる。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこの愉快な創造の数時間をめちゃめちゃに壊した窓のたくさんの顔をできるだけ強い表情でにらみまはした。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
