        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "引き取りながらも、医者は何といった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、黙って引き取りなせえ」　云いながら彼は中間の手に二朱の金をそっと握らせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と橋田氏は引き取り、「とにかく壮烈なものでしたよ。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たれか引き取り手がないものかナ。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三村家で二人を引き取り、不安なく暮らしている以上、その上の複雑な愛情とが憎悪とかいうようなむずかしい人情は、無駄だとさえ思えた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞおかまいなく、お引き取りを、と言うまでもなし……ついと尻を見せて、すたすたと廊下を行くのを、継児のような目つきで見ながら、抱き込むばかりに蓋を取ると、なるほど、二ぜんもり込みだけに汁がぽっちり、饂飩は白く乾いていた。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の文吉は康太郎の姉聟の金造に養子に貰われたから良いが、弟の順平は乳飲子で可哀相だとお婆が引き取り、ミルクで育てている。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "香以は闇に紛れて茶屋へ引き取り、きわには辞を尽して謝し、「金は店からすぐ届ける」と云い畢って四手に乗り、山城河岸へ急がせた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五年二月廿二日御当家｜御攻口にて、御幟を一番に入れ候時、銃丸左の股に中り、ようよう引き取り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉使いに向い、盛政は直ぐに引き取りたるかと訊いた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「すぐに、荷物をお引き取りください。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、お引き取り下さい！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中を呼びますから、お引き取りになって下さい。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、出来るだけ早く、この家からお引き取り下さい！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の文吉は康太郎の姉聟の金造に養子に貰われたから良いが、弟の順平は乳飲子で可哀相だとお婆が引き取り、ミルクで育てゝいる。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから今はどうかお引き取りを。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤をばわれ引き取りて世話すべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶太の翁ハノホは西班牙に旅せしころ、彼親達を識りつれば、孤兒を引き取りて養へりしに、故郷なる某の貴婦人あはれがりて迎へ歸り、音樂の師に就きて學ばしめき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "小塚氏はなお語を継ぎて、貴女は何にも御存知なき様子、しかし早晩御通知あらん、いずれ明日にも面会に出頭せん、衣類等は如何になりおるや、早速にも間に合うよう相成りおるや否やなど、種々厚き注意をなして、その日はそのまま引き取りたり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうわたくしは引き取りましてもよろしゅうございましょうか」と、信濃屋の番頭はおずおず訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "へへへへへ」　余程ひどく踏み倒したと見えて、番頭はその引き取り値段を云わなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の源吉はまだ子供でどうすることも出来ないので、日が暮れてから近所の人たちが死骸を引き取りにくる筈になっている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "四畳半には主人と女中との死骸がならべてあって、お葉の家からはまだ誰も引き取りに来ないとのことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがね、私はつまらない者ですけれど、殿様がおそばで使っていてくださいますからね、昔のいろいろな話を申し上げる中で、どうなさいましたろうと私が姫君のことをよく申すものですから、殿様が、ぜひ自分の所へ引き取りたく思う。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主｜予て予の気短きを知れば、給仕人が聞き違うた体に言い做し、皿を引き将て去らんとするを気の毒がり、浜口氏が自分引き取りて食べ試みると奇妙に旨いとて、予に半分くれた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の者の話によると、けさ早々に東京へ電報を打ったのであるから、今夜か、あるいはあしたの早朝には死体を引き取りに来るのであろうとのことであった。",
              "citation": {
                "source": "山椒魚",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れの女学生一人と、東京から引き取りに来た男三人と、宿の者も二人付き添って、町はずれの方へ無言でたどって行った。",
              "citation": {
                "source": "山椒魚",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君はその場でいきをひきとり、左官屋は牢へ行き、左官屋の十歳ほどの息子が、このあいだ駅の売店のまえで新聞を買って読んでいた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ふり返ると味方が、尚左岸に苦戦してひきとりかねている者が多いのを見て、さらば、援けえさすべしとて引き返す。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そういって、やさしい目でじっとみながら、ふかいため息をひとつつくと、それなり息をひきとりました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            }
          ]
        }
