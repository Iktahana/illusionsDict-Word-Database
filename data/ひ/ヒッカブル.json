          "literary": [
            {
              "text": "灯りを消して、更紗の懸蒲団を引っ被ると、蝦のように躯を曲げて、すぐさま寝入ってしまった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の外れに来て、急に小男は、着ているその半纏の裾をひったぐるようにして頭からひっかぶるのだった。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、フトンをひっかぶる気配、周囲の三四人が低く笑う。",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
