        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何しろ、優勝区には、増産奨励の酒が一升づつ出ることになつて村長の机の上に六本並んでゐるのだから、他の賞品になら寛容の美徳を現はす連中も、この縄綯ひリレーだけは、勝敗が明確でないといふことにした。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔漢が一升徳利を抱えて暴れているのもいい。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京から遥々見送って来た安兵衛という男が、宿屋で毎日朝から酒ばかり飲んでいて、酔って来ると箸で皿を叩きながら「ノムダイシ、一升五合」（南無大師遍照金剛）というのを繰返し繰返し唱えたことも想い出す。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の隅っこに淋しく残された鏡台、とり散らかされた化粧道具、（それが静かにダブッて）　鏡台の辺りに転がって居る一升徳利、もう一つコロコロ転がって来て二つコツンと衝突しました。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして傍にあった一升徳利を引き寄せると、重さでぶるぶる手を震わせながら茶椀の中へ注ぎ込んだ。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも一升買ってきた石油はすぐなくなった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "発育ざかりの私の二人の子供は、一日一升五合くらいの飯を平らげてまだなにかほしそうな顔をしているのだが、外米の入った飯になると、かわいそうなほど急に、いつもの半分くらいしか食わなくなって悄げこんだ。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山さんは、一升瓶を持參してゐたので、私は、北山さんのころぶ度に、ひやりとしました。",
              "citation": {
                "source": "黒石の人たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升ほど持って帰っても、じきにぺろっと失くなるのやそうで……」　峻が語を聴きながら豆を咬んでいると、裏口で音がして信子が帰って来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりで毎晩一升以上も呑むようでしたが、どちらも酒に強いので、座の乱れるようなことは、いちどもありませんでした。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯の仕度にとりかかっていたら、お隣りの奥さんがおいでになって、十二月の清酒の配給券が来ましたけど、隣組九軒で一升券六枚しか無い、どうしましょうという御相談であった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九本の一升瓶をずらりと一列に並べて、よくよく分量を見較べ、同じ高さずつ分け合うのである。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋一ぱいに、れいのかつぎの商売道具らしい石油かんやら、りんご箱やら、一升ビンやら、何だか風呂敷に包んだものやら、鳥かごのようなものやら、紙くずやら、ほとんど足の踏み場も無いくらいに、ぬらついて散らばっている。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんぐりを一升早くもってこい。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升にたりなかったら、めっきのどんぐりもまぜてこい。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょうど一升あります。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と……」「これは私の心意気じゃ……この首を熱燗十本で売りませう　　　　　　　　　　　損得無しの一升一生……」「アハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升｜徳利をぶらさげて先生、憚りながら地酒では御座らぬ、お露の酌で飲んでみさっせと縁先へ置いて去く老人もある。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升徳利をぶらさげて先生、憚りながら地酒では御座らぬ、お露の酌で飲んでみさっせと縁先へ置いて去く老人もある。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "五合や一升の酒に酔うようなおれ様か！",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二度目の月と醤油との会合ははなはだ解決困難であるが、前の巻の初めに、史邦の「帷子」の発句と芭蕉の脇「籾一升を稲のこぎ賃」との次に岱水が付けた「蓼の穂に醤のかびをかき分けて」を付けているところを見ると、岱水の頭には何かしら醤油のようなものと帷子との中間にまたがる観念群があるのではないかと疑わせる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に握り飯が大形の、切溜めという深く四角い塗った器につめてある傍に、濁酒のはいった素焼の一升瓶が添えてあった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前刻から、通口へ顏を出して、髯旦のうめ方が、まツ其の通り、小兒の一寸に水一升の割を覗いて、一驚を吃した三助、「然も然うず、然もござりませうぞや。",
              "citation": {
                "source": "錢湯",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「からすかんざゑもんは　くろいあたまをくうらりくらり、　とんびとうざゑもんは　あぶら一升でとうろりとろり、　そのくらやみはふくろふの　いさみにいさむものゝふが　みゝずをつかむときなるぞ　ねとりを襲ふときなるぞ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならこの校長さんは樽こ先生といふあだ名で一ぺんに一升ぐらゐは何でもなかったのです。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今日のお礼ですが、あなたは黄金のどんぐり一升と、塩鮭のあたまと、どつちをおすきですか。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんぐりを一升早くもつてこい。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升にたりなかつたら、めつきのどんぐりもまぜてこい。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちやうど一升あります。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
