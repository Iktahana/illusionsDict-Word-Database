        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして赤坊の唾液で濡れた拑子を指先で挟んで持つてゐながら、母親が子供を揺りながら泣いたり、その子の瞳を見入つて一言二言狂気のやうに云つたりするのを「そんなにして俺が何が出来るものか」と思つて立つてゐた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がよい加減なことを一言二言いうと、お増はいきなり僕の手をとって、も少しこっちへきてここへ腰を掛けなさいまアと言いつつ、藁を積んである所へ自分も腰をかけて僕にも掛けさせた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしＮ君が一言二言問答したら、それでよかったと見えてそのまま階段を上がって行った。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壇上の人が下りると、上壇に椅子へ腰かけた人、これが議長だそうであるが、この人が何か一言二言述べると、左の方の議員席からいきなり一人立上がって大きな声でわめき立てた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "及びもしないあんな男をいきなり一言二言はなしてそんなことを考えるなんてあることでない。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人らに一々アローと声をかけて、一言二言話していました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の哲学者が一言二言いったというだけで人間全体が別種の存在に変わって人間界の方則があべこべになるということは想像ができない。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "禮拜が終ると相島は楠に一言二言云つて直ぐ教會を出た。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武村兵曹は彼等の仲間でも羽振りよき男、何か一言二言いふと、勇ましき水兵の一團は、等しく帽を高く飛して、萬歳を叫んだ、彼等は其敬愛する櫻木大佐の知己たる吾等が、無事に此島に上陸したる事を祝して呉れるのであらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「別に、でも、一言二言皮肉みたいなことを云ったわ。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうと立停まって一言二言交すついでに、主税はふと心付いて、もしやこの頃、先生の事だの、お嬢さんの事を聞きに来たものはないか、と聞くと、月はじめにモオニングを着た、痘痕のある立派な旦那が。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにどうも挨拶といったところで、私なぞは結論が序論と一緒になってしまうので一言二言いえばいつもそれでおしまいになるのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "許宣は気が注いて船頭に一言二言別れの詞をかけ、楊柳の陰から走り出て湧金門を入って、ぎっしり簷を並べた民家の一方の簷下を歩いた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が行ってしまうとその駅員は、改札係と、居合わせた警官と三人で顔を見合わせて何か一言二言言ってにやにや笑っていた。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "許宣は気が注いて船頭に一言二言別れの詞をかけて、楊柳の陰から走り出て湧金門を入り、ぎっしり簷を並べた民家の一方の簷下を歩いた。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何か一言二言話しあって小屋の方に帰って行った。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな話をする事には、物慣れてゐる城持ちの貴婦人が、何か序開きに一言二言云つて置いて、傍に立つてゐた一人の耳に口を寄せて囁くと、その聞いた女が隣に伝へる。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄關の格子戸の開く音と、小聲に一言二言交へる音とが止んで、鳴皮の踏みしめる音がかすかに錯綜してゐるのも止むと、『お免下さい。",
              "citation": {
                "source": "女",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひは兵卒の頸筋元を駈※る、すると敵の首を取る夢やら、攻略やら、伏兵やら、西班牙の名劍やら、底拔の祝盃やら、途端に耳元で陣太鼓、飛上る、目を覺す、おびえ駭いて、一言二言祈をする、又就眠る。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一言二言で此身の生死が決るのぢや。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学士は娘に向つて、一言二言話してゐるうちに、例も女を蕩す折にするやうに、掌面の講釈を始めた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "会に一言二言夫となく問を掛けて見ても、三千代は寧ろ応じなかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴシップや世間の噂で、すでにそれらの医師だちにも興味的に知られているらしい葉子は、入院最初の一日の間に、執刀者のＫ――博士にも甘えられるだけの親しみを感じていたが、庸三と一言二言話しているうちに用意ができて、間もなく手術台のうえに載せられた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島は一言二言口を利いているうちに、それがつい二三日前に、ふっと引込まれて行くような射倖心が動いて、つい買って見る気になった或｜賭ものの中った報知であることが解った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島は一言二言口を利いているうちに、それがつい二三日前に、ふっと引込まれて行くような射倖心が動いて、つい買って見る気になった或賭ものの中った報知であることが解った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして弁士の演説に一言二言の批評を加える僕らを、その演説会の妨害か打ち毀しかに来たものと考え、警察官と主催者と聴衆とが一緒になって騒ぎ出す。",
              "citation": {
                "source": "新秩序の創造",
                "author": "――評論の評論",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えて置くから、まあ悠くり滞留するがよかろう」　スーラーブは、立ったまま、代として渡す羊について一言二言つけ加え、広間を去った。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸、父の一言二言で、その危険な峠は越した。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう表情は役所へ上司が監察にやって来る時、官吏連の顔によく現われるもので、どうやら最初の恐怖も消え去り、大体のところはお眼鏡にかなったとみえ、長官がしまいに軽口を叩いてニコニコしながら、何か一言二言いわれたりすると、ぐるりを取りまいている側近の役人連はそれに答えて二倍も笑う。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだに、ラップランドのおばあさんは、干ダラに、ひとことふたこと書いて、それをだいじに持っていくようにと、ゲルダに言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
