[
  {
    "uuid": "53f7b51e-1224-5c9e-9999-4ca576bc7217",
    "entry": "豹変",
    "reading": {
      "primary": "ひょうへん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
