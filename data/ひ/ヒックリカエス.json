[
  {
    "uuid": "d4240191-83e3-5210-baad-9e364eb93c9f",
    "entry": "ひっくり返す",
    "reading": {
      "primary": "ひっくりかえす",
      "alternatives": [
        "ひっくりがえす"
      ],
      "is_heteronym": false
    },
    "grammar": {
