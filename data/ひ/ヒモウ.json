    "definitions": [
      {
        "index": 1,
        "gloss": "hair coat (of an animal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
