    "definitions": [
      {
        "index": 1,
        "gloss": "phoenix (esp. fenghuang, the Chinese phoenix)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜食後、ストラヴンスキイの「火の鳥」を聽く。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「火の鳥」といふと、亡き小山内薫先生の事を思ひ浮べる。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱に溶けたその波を、火の鳥のように直線に飛んで、真面に銅像を射たのであった。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十四年に書いた私の「火の鳥」という未完の長編小説に、次のような一節がある。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世は影の鳥、火の鳥の飛び去る如く、われ高山に昇りて、その過ぐるを眺む……男はわれを害し、女はただ泣けども、われはその男女を愛す。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の鳥を聴く一　午前一時過ぎ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜鵑の鳴声が「ほんぞんかけたか」であらうと、また「ほんだうたてたか」であらうと、そんなことはどうだつていいが、忘れてはならないのは、この伝説のやうに彼を鳥の世界の金貸しだなどと信じ過して、火の鳥ともいふべき真紅な舌を持つたこの小鳥の啼声に、激越な燃ゆる魂の動きを聴き遁さないことである。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの鳥の囀りが安らかな木の枝の上で唱はれるのと打つて変つて、この火の鳥の絶叫は、大抵の場合高い森から森への真直な空の大道を直翔に翔ける途中で叫ばれるのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」比較的上流の婦人ばかりで作られていた『火の鳥』という雑誌に、「ビラ撒き」という詩を発表し、『女人芸術』に「お目見得」という小説を書いたりしていた窪川稲子は、良人にはげまされて一少女工を主人公とした小説をかき、中野重治がそれに「キャラメル工場から」と題をつけて、『プロレタリア芸術』にのせた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみも羊の肝の羹も昨日となれば異ならぬかな（草の夢）ただ一人柱に倚れば我家も御堂の如し春の黄昏　これは歌集大正七年出版の「火の鳥」にある作である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「火の鳥」は晶子歌に一時期を画するもので、即ちこれ以後の歌は作者のいふおだやかな人間になつて作つたもので、それ迄のものとは厳然と区別される。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵本ども病める枕を囲むとも母を見ぬ日は寂しからまし　人形は目開きてあれど病める子はたゆげに眠る白き病室仄かにも煙我より昇るとて君もの云ひに来給ひしかな　恋を卒業した作者が今度は心を溌まして、恋の明るい一面を美しく歌はうと試みたのが「火の鳥」以後の作者の態度である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ、神々しき初日の登場、燦爛たる火の鳥の舞。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の鳥四時から十一時頃まで。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏の首のようにおちくぼんだ襟足をあっけにとられてながめていると、ラヴェルの〈スペインの時〉とファリアの〈火の鳥〉をあっさり奏いて、ありがとうございましたとお辞儀をしてぽくぽく帰って行った。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "前回の通り、焔色の夜会服を着て、見るもいぶせきこの木賃宿の一室へ、さながらニジンスキイの「火の鳥」とでもいった花々しいようすで飛び込んで来た。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "譯者曰、著者は八境は佛教の八戒と同じく、三常の門は盆祭の火の鳥居と同じく、景日は大日にして、慈航は盆祭の舟、明宮は盆火の宮殿に均しく其間相關するものあるが如くに注せり。",
              "citation": {
                "source": "弘法大師と景教との關係",
                "author": "イー、エー、ゴルドン",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞踊組曲「火の鳥」は、ストラヴィンスキーの出世作でお伽噺の舞踊劇だ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいてゆくと、それは火の鳥となる。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の鳥のように、火を曳いて飛んでゆく無数の黒点が、どこへその火を移そうかと、煙の空を、翔けめぐっている。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空も、火の粉、火の鳥、火の蝶々。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田勢は、夜明けもまたず、それへ攀じ登って、銃口を並べ、また焔の枯れ柴や油布へ分銅をつけて、火の鳥のように、大手門の内へ投げこんだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の鳥の如く水を翔けて、敵船の巨体へ喰いついた小艇は、どうしても、離れなかった。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、火の鳥は、いつのまにか、ここらの郷武者の間に、卵を孵していた。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭や顔ばかりではない、尾の附け方だつて、胴片のつなぎ具合だつて、脚の釣合ひのとり方だつて、釣の掛け方は云ふまでもなく、塗料のあんばいだつて――一途に心が狂奔するばかりで、今はもう部分的に手を取つて見ようとすれば何も彼も滅茶滅茶で凡てが手の施しようもなかつた。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
