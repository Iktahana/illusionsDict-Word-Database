        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "※かなりその国生、　　かぎりなし天つ日嗣、　　いざ継がせ言依さすもの、　　勾玉とにほひ綴らせ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "※かなりその國生、　　かぎりなし天つ日嗣、　　いざ繼がせ言依さすもの、　　勾玉とにほひ綴らせ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "）天壤と窮みなき、天津日嗣、ここに　（讚へまつれ、いざや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "畏きや天つ日嗣、幾足日、幾千歳しろしめす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "天ツ日嗣は必ず皇緒を立てよ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その巻一の初めには、「謹みて按ずるに、神州は太陽の出づる所、元気の始まる所にして、天つ日嗣、世々、宸極を御し、終古｜易らず。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め旧幕に阿諛し、恐多くも廃帝之説を唱へ、万古一統の天日嗣を危うせんとす。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち全文を解りよくすれば、天地の棟梁即ち祖根、日根、祖日根は云ふもさらなり、天神人あるとあらゆるものの祖の唯一の神宮と云ふべき日本國に御座して、世界の五種の人類の棟梁にています天皇、即ち天津日嗣天日根天皇の系圖、及び寶骨像御神體の寶物たることを記した大切なる祕密の卷となる。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "めでたきかなや、日嗣の皇子、世の星なる、麗はし、良き姫めとらす。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄雄しくいます、日嗣の皇子、げに、人皆、とこしへ、たのまん御柱、ならびて在す、天つ少女、そのみなさけ、優しく、みけしき気高し。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊かる天日嗣の広き道　踏まで　狭き道ゆくな。",
              "citation": {
                "source": "橘曙覧",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士尊かる天日嗣の広き道　踏まで　狭き道ゆくな。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "真ごゝろも、正しき道によらで尽さば大綱と　天日嗣を先とりて、もろ／＼の目を編む国と知れ天皇に　身もたな知らず　真心をつくしまつるが、吾国道一・二・三はかうして導かねばならぬ蒙昧な武士の、まだ多かつたことを示してゐる。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時作る利のみむさぼる国に、正しかる日嗣のゆゑを　しめしたらなむ神国の神のをしへを　千よろづの国にほどこせ。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日嗣ぎの皇子が、日の皇子（天子様）におなりなされると、天子様としての仰せ言が下る。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "御誕生後、後代の日嗣御子がお定まりになつて、其中から次の代の主上がお定まりになつたのである。",
              "citation": {
                "source": "貴種誕生と産湯の信仰と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天つ日嗣は必ず皇緒を続げよ。",
              "citation": {
                "source": "道鏡皇胤論について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、代々の帝の御位に即かせ給うは、天の日を嗣ぐということにて、天津日嗣といい、また宮仕えし給う人を、雲の上人といい、都を天といい、四方の国、東国よりも、西国よりも、京へ上るといえり。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東征は日の神の加護によって遂げられたことになっているが、これは天上における皇祖としての日の神の皇都が「天つ日嗣」をうけられた皇孫によって地上のヒムカに遷され、それがまた神武天皇によってヤマトに遷されたことを、語ったものであり、皇祖を日の神とする思想によって作られたものである。",
              "citation": {
                "source": "建国の事情と万世一系の思想",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「王女がその縁者にして日嗣だからだ。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠けむりすめろぎの　天の日嗣と嗣ぎてくる　君の御代御代隠さはぬ　明き心をすべらべに　極めつくして仕へくる　いや継ぎ継ぎに見る人の　語りつぎてて聞く人の　鑑にせむをあたらしき　清きその名ぞおほろかに　心思ひてむな言も　祖の名断つな大伴の氏と名に負へる　ますらをの伴　まだ九月九日、重陽の宵である。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は神国であるから日嗣の御子は易ることがない、変るべからず、というのが論の骨子だが、“――神は人をやすくすることを本誓とす。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "にひ藁を繩になひつぎ。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとうちのなかでさんび歌をうたうのが聞こえて、花で飾られたひつぎが、中からはこび出されました。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その三人のうつくしいむすめをいれた三つのひつぎが、森のしげみから、すうっとあらわれてきて、湖のむこうへわたっていきました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼き日我が最も嬉しかりしは、今は世になき母方の祖母なる人、又は我が母人よりさまざまの昔話、物語のたぐひつぎつぎにせがみては、飽く事なく聞く時の心なりき。",
              "citation": {
                "source": "貝殼追放",
                "author": "「その春の頃」の序",
                "note": "青空文庫"
              }
            },
            {
              "text": "』夫の伊佐奈また言ひつぎぬ、『汝を見しその日のはじめ、迷ひ來し谷村の夜、この山にいかづち裂けぬ。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇では、ひつぎ又はあまつひつぎといふ――の、正邪を判断する為に、其を口に唱へさせながら、手を湯につけさせた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、ひつぎの・みこと言はれた方々である。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして遂に、一人のみこの・みこと――ひつぎの・みこは数人ある――が、摂政皇太子の義となつた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
