        "examples": {
          "standard": [
            {
              "text": "熟練の職人が、太い鉄棒をいとも簡単にひん曲げて装飾品を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ラグビー選手の力強いタックルで、ゴールの支柱がひん曲げられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これだけ硬いワイヤーをひん曲げるには、専用の工具が必要だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "画家がどのやうに林檎の形態を、ひんまげる自由をもつて描かうと、林檎からは苦情は来ないのであるそのことを良いことにして林檎の真実を離れて形態だけを変へるといふ態度は、少くとも自然物に対する芸術家の愛の態度ではない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "唇をひんまげるのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
