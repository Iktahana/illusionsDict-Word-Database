        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぎょっとして振りむくと、馬場の右脇にコバルト色の学生服を着た背のきわめてひくい若い男がひっそり立っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句を読むと、田舎の閑寂な空気や、夏の真昼の静寂さや、ひっそりとした田舎家の室内や、その部屋の窓から見晴しになってるところの、広茫たる一面の麦畑や、またその麦畑が、上風に吹かれて浪のように動いている有様やが、詩の縹渺するイメージの影で浮き出して来る。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚の花やゆかしき母屋の乾隅　土蔵などのある、暗くひっそりとした旧家であろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧家の奥深く、影のささないひっそりした部屋。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その卓の上に、鮮魚の冷たい鮓が、静かに、ひっそりと、沈黙して置いてあるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由に図書室へ出入りすることを許されたが図書室の中はいつ行ってみても誰もいないでひっそりしていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の宿屋というものを、思わせる「糸屋」と看板を出した旅籠屋には、椽側に紡車を置きっ放しにして、ひっそりかんとしている、馬車はここで停まった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "人通りのない町はひっそりしていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるひとときはひっそりとする巴里。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ少しも物音がなく、閑雅にひっそりと静まりかえって、深い眠りのような影を曳いてた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の特殊な美しさも、静かな夢のような閑寂さも、かえってひっそりと気味が悪く、何かの恐ろしい秘密の中で、暗号を交しているように感じられた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそりとした暗い町を今人間の形をした苦悶が火照って行き過ぎるのではないか。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "四辺はひっそりとして物音無し。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ひっそりとして物音無し。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の中はまたひっそりする。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一間の内はひっそりとしている。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「牛屋は、ボッコひっそりとしとるじゃないや。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇い一筋町がひっそりとしてしまった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人宿だけに亀屋の店の障子には燈火が明く射していたが、今宵は客もあまりないと見えて内もひっそりとして、おりおり雁頸の太そうな煙管で火鉢の縁をたたく音がするばかりである。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前屋は小半町しか距れていないので、すぐに行き着くと、紙屋の店は表の戸をおろしてひっそりしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋内はひっそりして、薄気味悪く、中にはなにも見えなかった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家を外から伺うと、人声一つせず、ひっそりと静まりかえっていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱山も今日はひっそりして鉄索もうごいていず青ぞらにうすくけむっていた。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそりとして返事もなく空さへもなんだかがらんとして見れば見るほど変なおそろしい気がするのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見わたすと、その檸檬の色彩はガチャガチャした色の階調をひっそりと紡錘形の身体の中へ吸収してしまって、カーンと冴えかえっていた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそりした昼の湯槽には若い衆が二人入っていました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪は小止なく、今は雨も交らず乾いた軽いのがさらさらと面を打ち、宵ながら門を鎖した敦賀の通はひっそりして一条二条｜縦横に、辻の角は広々と、白く積った中を、道の程八町ばかりで、とある軒下に辿り着いたのが名指の香取屋。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟の群が通り過ぎると、ひっそりする。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
