          "standard": [
            {
              "text": "彼は、人目もはばからず、道端で愛を叫び始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、人目もはばからず、公衆の面前で涙を流した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "二人は人目もはばからず、公園のベンチで熱いキスを交わした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ふるさとに見し世の友を恋ひわびてさへづることを誰か分くらん　こんなふうにはかながって暮らしていた数日ののちに、以前にもまして逢いがたい苦しさを切に感じる源氏は、人目もはばからずに大井へ出かけることにした。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "気づかれないように近づきながらすかしてみると、それとも知らぬげに用人黒川と、こってり塗った質屋の若後家が、人目もはばからずに喃々喋々と、はなはだよろしくない艶語にうつつをぬかしている姿が目にはいりましたので、認めるや同時です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の方を始め、おつきの者達も、人目もはばからず泣き叫んだ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            }
          ]
        }
