    "definitions": [
      {
        "index": 1,
        "gloss": "to be soaked in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芸術とは、自分自身の魂に浸ることいかに誠実にして深いかにあるのだ。",
              "citation": {
                "source": "詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光の下、ひとり深夜の裏町を通る人は、だれしも皆こうした詩情に浸るであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのめぐりを七人の天女は趾頭舞踊しつづけてゐるが、汚辱に浸る月の心になんの慰愛もあたへはしない。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃き浄めた朝の座敷で幽寂閑雅な気分に浸る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、私は古典に浸る人間には、どこかその中からロマンチックなものを求める本能があるのではあるまいかなど考えた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（いえ、）（いえじゃあござんせぬ、それ、それ、お法衣の袖が浸るではありませんか、）というと突然背後から帯に手をかけて、身悶をして縮むのを、邪慳らしくすっぱり脱いで取った。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、見世ものの踊を済まして、寝しなに町の湯へ入る時は、風呂の縁へ両手を掛けて、横に両脚でドブンと浸る。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇中の人物に自己を投射しあるいは主人公を自分に投入することによって、その劇中人物が実際の場合に経験するであろうところの緊張とそれに次いで来るように設計された弛緩とを如実に体験すると同等の効果を満喫して涙を流しはなをすする、と同時に泣くことの快感に浸るのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあとでは得態の知れない悔の気持に浸るのだ。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯槽に浸ると、びっくりするほど冷たかった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は稲毛の料亭にある宴会に呼ばれ、夜がふけてから、朋輩と車を連ねて、暗い野道を帰って来たこともあったが、波の音が夢心地の耳に通ったりして、酒の酔いが少しずつ消えて行く頭脳に、言い知らぬ侘しさが襲いかかり、死の幻想に浸るのだったが、そうした寂しさはこのごろの彼女の心に時々｜這い寄って来るのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈四郎はこの店に入浸るようになった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（否、）（否ぢやあござんせぬ、それ、それ、お法衣の袖に浸るではありませんか、）といふと突然背後から帯に手をかけて、身悶をして縮むのを、邪慳らしくすつぱり脱いで取つた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桔梗短くさき浸る、汀に寄らす天少女、玉松が枝に領巾解き掛け、湖水に、糸をさらし練る。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると実に恐ろしく――実に猛烈に――実にものすごく酒がどっと流れ出て大洪水となり、――部屋はこっちの壁から向うの壁まで一面に浸る――たくさんものを載せたテーブルはひっくり返る――架台は裏返しになる――ポンチの鉢は煖炉の中へ入ってゆく――淑女たちはヒステリーを起すという有様。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に、あれ程の大きな心配の前に動いてゐる私に――何の憂慮も起させず陽光に浸るが儘に夢心地に入らうとまでさせた、――その美しい光景は、想像にお任せいたすより他はありません。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はこれから何としても、あゝいふ世界に足を踏み入れるぞ、酒に酔つて、詩に浸るのだ。",
              "citation": {
                "source": "思ひ出した事（松竹座）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　Ｋはその朝の微白い空気の中にも、死ぬことの難くないことを感じたが、そこでは一層かれはさうした心持に浸ることが出来た。",
              "citation": {
                "source": "浴室",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからというもの葉子は忘我渾沌の歓喜に浸るためには、すべてを犠牲としても惜しまない心になっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生に深く浸るといふことは、経験を沢山に積むといふことは――更に言ひ換へて、人生を知識的に知るといふことは、それは決して創造的、燃焼的でないばかりでなく、むしろその反対に、その作者の心境を抽象的にして了ふといふことであつた。",
              "citation": {
                "source": "作者の言葉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "落着いた然も浸るばかりの悦びと感謝の心で、私はペンを執りました。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯槽には幾つかの列に厚板が並べてあり、人はとりどりにその板にしがみ附きながら隊長の立つ方向に面して息を殺して浸るのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の書生は今の青年がオペラやキネマへ入浸ると同様に盛んに寄席へ通ったもので、寄席芸人の物真似は書生の課外レスンの一つであった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、夫人を迎えて家庭の団欒の悦びに浸るようになってからは詩人の夢から覚めて頗る平穏堅実となったとのみ聞いていた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "才を呵して直ちに章をなす彼の文筆が、絵の具皿に浸ると同時に、たちまち堅くなって、穂先の運行がねっとり竦んでしまったのかと思うと、余は微笑を禁じ得ないのである。",
              "citation": {
                "source": "子規の画",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの中に浸る東京の上流婦人の中に、次第にサジスムス性のソレが殖えてゆくのは、男性のソレと同様止むを得ない事である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼びよせて、菓子など與ふれば、喜びて、片言交りに物よく言ひたるいとらうたし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても此浦は平家の一門果て給ひたる所なれば痛はしく存じ、毎夜此磯邊に出でて御經を讀み奉り候。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言はゞ我が良人をはづかしむるやうなれど、そも／＼御暇を賜はりて家に歸りし時、聟と定まりしは職工にて工場がよひする人と聞きし時、勿躰なき比較なれど我れは殿の御地位を思ひ合せて、天女が羽衣を失ひたる心地もしたりき。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『春色恋白浪』に「鼠色の御召縮緬に黄柄茶の糸を以て細く小さく碁盤格子を織｜出したる上着、……帯は古風な本国織に紺｜博多の独鈷なし媚茶の二本筋を織たるとを腹合せに縫ひたるを結び、……衣裳の袖口は上着下着ともに松葉色の様なる御納戸の繻子を付け仕立も念を入て申分なく」という描写がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
