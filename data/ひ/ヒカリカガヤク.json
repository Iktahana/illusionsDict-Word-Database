        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三千の兄弟たちが、あの光り輝く工場の中の部署についている三千の兄弟たち、あの工場以外のどの工場にも、労働者街にも溢れている、全プロレタリアの均しく背負っている苦痛なんだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄雲を透した日光が暫く此の靜かな村里を照らして、ダリアやコスモスが光り輝くやうに見えた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学校で教わったナショナルリーダーの「マッチ売りの娘」の幻覚のように、大きなクリスマストリーが、神秘的に光り輝く霧の中に高く浮かみ上がる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉桜のころで、光り輝く青葉の陰で、どうどうと落ちている滝は、十八歳の私には夢のようであった。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "到るところの生活が、光り輝く山河であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "賞品をもらうときシャツの袖がちらと出て、貝のボタンが三つも四つも、きらきら光り輝くように企てたのでした。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルト色に深く澄み渡つた南の空に、大粒の宝玉のやうに燦々と光り輝く十字星は、天空一ぱいに散乱する群星を圧してゐた。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人が現場へ着いた頃は夜も可成り更けてゐたが、澤山の島人達が寒さにもめげずに別莊のまはりに集つて、今は電燈の光り輝く窓窓に好奇の眼を注いでゐた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに光り輝く光線、風、草いきれ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、紙の入道雲が歩行く歩行く、光り輝く紙の雪山が。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "光り輝く数百の麦稈帽の反射は近い水面を、空気を、砂地をことに眩ゆく新にした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の上手から静謐な、光り輝く漣の上を影絵のように急速力で漕いで来る丸木舟も見えた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈍重な巨躯の逸りに逸った匍匐の醜態が今、一時にまた光り輝くばかりの黒褐の毛のなだれとなり、地響きとなり、奮いたつ香炎の放電体となる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の蝋燭が鼻の真向にしんみりと光り輝く、眼と眼とが凝とその底から吸ひ付くやうに差覗く……つくづくと陰影と霊魂と睨み会つたまま底の底から自愛と憐憫の心とが切々と滲み出る。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふ光り輝く青さだらう、海も空も。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という光り輝く青さだろう、海も空も。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "命といふものはほろびる日のあるものですが、詩の国はいつまでも光り輝くところのものであります、ですから、艶子にとつてはレオナさんは命よりも大切な光りでした。",
              "citation": {
                "source": "駒鳥の胸",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "利息の支払ひで望遠鏡は購ひ損つたが、この眼をこのまゝ眼鏡に擬しても、この頃の夕暮空のあれ位ひならば、きらきらと光り輝く有りさまが手にとるやうだ。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは光の中に光り輝く斑點であつた。",
              "citation": {
                "source": "日の光を浴びて",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻綾子のやうな薔薇の花、勝ち誇つた唇の結構な氣の廣さ、櫻綾子のやうな薔薇の花、光り輝くおまへの口は、わたしどもの肌の上、その迷景の赤い封印を押してくれる、僞善の花よ、無言の花よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "はて、ヂュリエットが居るゆゑに、其艶麗さで、此窖が光り輝く宴席とも見ゆるわい。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔も今も、今日も明日も、いや未来｜永劫に光り輝く、人生の一大燈明なのであります。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に「是れ大明呪なり」とは、明とは、光明の明ですから、この般若の真言こそ永遠に光り輝く、仏の神聖なることばだということです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも明かな、生々とした眼つきなので、その人の肉體が假令どう病み衰へても光を失ふことは考へられない、肉體が衰へれば衰へるほど眼だけは愈々光り輝くのではないか、と人に思はせるやうな眼が稀にはあるものである。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "テイアは光り輝く太陽ヘリオスと太陰セレネを生みぬ、また曙の神エオスも。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "広場のはずれにこれもまた、光り輝く服装をした巡査が立っている。",
              "citation": {
                "source": "ワルシャワのメーデー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖には、早打ちを仕掛けた打上げ船が、ゆたりゆたりと、光り輝く海面に漾い、早くも夏に貪婪な河童共の頭が、見えつ隠れつ、その船のあたりに泳ぎ寄っていた。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爛爛と光り輝く眼で、今にも飛びかかって来そうな底知れぬ黒さだった。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し我が僧侶の努力により、衰へ切つた支那佛教界に、新しい生命を與へ、佛日再び中華の空に光り輝くことになつたらば、それこそ宗祖に對する何よりの大供養と信ずるのである。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔つき合せては、恥かしく、というより、何も彼にもが、しろがね色に光り輝く、この雰囲気のなかでは、喋るよりも黙って、あなたと、海をみているほうが、愉しかった。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
