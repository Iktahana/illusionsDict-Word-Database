    "definitions": [
      {
        "index": 1,
        "gloss": "to redeem debts (e.g. of a geisha)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
