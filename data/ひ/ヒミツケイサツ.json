        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ペテルスブルグの秘密警察の代理者ガポン僧正は、プチロフ工場の四人の労働者の解雇を契機として起ったストライキ、拡大して行く労働者運動の波を、自己の指導下におこうとして、歴史的大芝居を打とうとした。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツァーの秘密警察は手を廻してゴーリキイについての醜聞を流布させ、その計画を妨害した。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論同時に秘密警察署へも報告をいたしまして、私立探偵事務所二箇所へ知らせましたそうで。",
              "citation": {
                "source": "襟",
                "author": "オシップ・ディモフ　Ossip Dymoff",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に秘密警察署の手で、今朝から誰があの川筋を通ったということを探りました。",
              "citation": {
                "source": "襟",
                "author": "オシップ・ディモフ　Ossip Dymoff",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密警察署の方は官吏でございますから、報酬は取りませんが、私立探偵事務所の方がございますので。",
              "citation": {
                "source": "襟",
                "author": "オシップ・ディモフ　Ossip Dymoff",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密警察署はあっても、外の用をしている。",
              "citation": {
                "source": "襟",
                "author": "オシップ・ディモフ　Ossip Dymoff",
                "note": "青空文庫"
              }
            },
            {
              "text": "工部局の活動、秘密警察の協力、素人探偵の競演――などと、物すごいウルランド氏捜索の手がつくされたが、ウルランド氏の消息は更にわからなかった。",
              "citation": {
                "source": "見えざる敵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、秘密警察隊の司令官ハヤブサじゃないか。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、直に秘密警察隊を動員してキンギン国の大使ゴールド女史をはじめ、向うの要人の身辺を警戒しろ」「はい。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに、別のスイッチが入れられ、秘密警察隊の司令官ハヤブサに、ゴールド大使の身辺調査の命令が与えられた。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもわからん」　部屋の一隅には、秘密警察隊の司令官ハヤブサが、身の置きどころもないような極り悪そうな顔で、頭を下げていた。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前こそ、ぼんくら中の大ぼんくらだ」「は、はい」　秘密警察隊の司令官ハヤブサは、ますます顔面を蒼白にして、おそれ入るばかりであった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのトマト姫のことが、とつぜん秘密警察隊の司令官ハヤブサの口から出てきたので、大総督の愕きは大きかった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲー・ペー・ウー、ゲシュタポ、中国の藍衣社、ＣＣ団などの秘密警察組織を、憲兵隊に代行させようという意図なので、本来の防諜機関としての任務のほかに、国家主義でない個人の活動と思想を抑圧する。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる平家直属の秘密警察とも言えるこの一隊の正体は、十四、五の少年部隊である。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行こうが追跡され、秘密警察が調べます。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
