        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "侍二人付き添って甲の侍が君江に、Ｔ「雲霧主膳様からのお迎えで御座る」　ヘッと長七と君江顔見合せた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さいときから苦労をして来たというだけに、人付合いも悪くない。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、令夫人付きのメイドか。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は妙な癖のある男で、人付き合いを避け、外出も滅多にしません。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからと言おうか案の定、人付き合いがあまりうまく行かない。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の量も増え、いよいよ人付き合いを避けます。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、与力には同心が四、五人ぐらいずつ付いている、同心の下には岡っ引が二、三人付いている、その岡っ引の下には又四、五人の手先が付いているという順序で、岡っ引も少し好い顔になると、一人で七、八人｜乃至十人ぐらいの手先を使っていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れの女学生一人と、東京から引き取りに来た男三人と、宿の者も二人付き添って、町はずれの方へ無言でたどって行った。",
              "citation": {
                "source": "山椒魚",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて十騎二十騎、あとには徒の者も七八十人付き添って、あき草の中を泳いで通った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、女が何か外出する用事はないかと訊いたので、ちょっとあると答えると、しばらくして一頭の駿馬に、水干装束をした下人が二、三人付いてやって来た。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の里人付記〔『日本』明治三十二年四月二十三日〕",
              "citation": {
                "source": "曙覧の歌",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "中宮付き、夫人付き、姫君付きの盛装した女房のすわっているのが数も知れぬほどに見えた。",
              "citation": {
                "source": "源氏物語",
                "author": "梅が枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は御所からもたらされて灌仏が六条院でもあることになっていたが、導師の来るのが遅くなって、日が暮れてから各夫人付きの童女たちが見物のために南の町へ送られてきて、それぞれ変わった布施が夫人たちから出されたりした。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人たちは若いころに院の御愛人であったが、須磨へおいでになった留守中から夫人付きになっていて、皆女王を愛していた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になって楽人たちの退散していく時に紫の夫人付きの家職の長が下役たちを従えて出て、纏頭品の箱から一つずつ出して皆へ頒った。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房たちの車は夫人付きの者のが五台、女御のが五台、明石夫人に属したのが三台で、それぞれに違った派手な味のある飾りと服装が人目に立った。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本人ぎらいの名がたつと、誰一人付きあったというものがない。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その流罪囚護送の事は、「源平盛衰記」文覚上人流罪の条に、伊豆の国へ流罪の由にて……院より庁の下部二人付られたり。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "光子は知名の政治家｜某の家に雇われ、夫人付の小間使となったが、主人に欺かれて身重になった。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五十年来寄席通ひをつづけ、今でも京都では唯一の寄席である新京極の富貴亭の定連株になつてゐる私は、いまだにさういつた芸人付き合ひが止められないので、義理にも黒足袋よりほかはく気にならない。",
              "citation": {
                "source": "黒足袋",
                "author": "吉井勇",
                "note": "青空文庫"
              }
            },
            {
              "text": "疳が強くて、人付きが惡くて、父親にまであまり可愛がられてはゐなかつた、人さらひの狙ふやうな玉ぢやない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "神隱し",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は月待ちの人混みに浮かれて、自分の家へ歸らなかつたが、今朝はあの騷ぎで、親類から寺を廻り、今歸つて來たところだ」　金六に引合せられたのは、成程お國がヒヨツトコの國から來た男といふだけあつて醜男ではあるが、何んとなく人付きの良い、道樂者らしい肌合ひの男でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "月待ち",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分さん方度々御苦勞樣で」　店に迎へてくれたのは、人付きの良い手代の春之助でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "罠に落ちた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "新六は無愛想で人付きは惡いが、ありや飛んだ良い男さ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "心中崩れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "劍術の富山七之助は、グツと若くて二十七歳、これは骨張つた青白い顏と、ギラギラ光る三白眼だけでも相當なもので、長身無口の青年、少し一國で氣短かで、人付きのよく無い男ですが、腕の方はまことに確かで、江戸の山の手の道場荒しで、一時は相當の惡名も馳せた男です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "萬兩分限",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主で内々は高利の金も廻して居ると言はれる五十男、脂ぎつて光澤の良い頭、大きく胡坐をかいた鼻、顎が張つて、背が低くて、あまり感じの良い男ではありませんが、如才がなくて、人付きがよくて、金儲けには拔目が無ささうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "處女神聖",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓といっても巣鴨一番の金持だから、倅の房松は一生長い着物を着て暮せるわけだが、この男は口無調法で人付合いが嫌いで、親父の重兵衛にねだって少しばかりの畑を自由にさして貰い、そこに大根や芋や草花などを作って、毎日真っ黒になって働いている変り者ですよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "茶碗割り",
                "note": "青空文庫"
              }
            },
            {
              "text": "手代の徳松は男が良くて人付きがいいから、少しは遊ぶだろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "権八の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹のお鳥は、もと見世物小屋にもいたことがあり、一度は亭主も持ったそうですが、喧嘩別れをして姉のところへ転げ込んだほどで愛嬌もあり人付きは滅法良い方ですが、何かしら評判のよくないところがありました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "彦徳の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥様ッ、旦那様が、タ、大変で御座います」　扉を押し開いて飛び込んだのは、主人付の女中、「何うしたの、旦那様が何うかなすったのかえ？",
              "citation": {
                "source": "悪魔の顔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
