[
  {
    "uuid": "f3bf804d-9560-5d12-ab59-1c81339a5007",
    "entry": "肥料",
    "reading": {
      "primary": "ひりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
