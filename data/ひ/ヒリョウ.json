      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "manure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新宿の數多いビルヂングは、何かの張子細工のやうに見えるし、アスハルトの街路の上を無限に續く肥料車が行列して居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆に彼等の爲すべきことは、子供の夢を涵養し、そのフアンタスチツクのドリームランドに、豐潤な肥料を注ぐことでなければならない。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から畑に入るゝ肥料なるべし異様のかおり鼻を突きて静岡にて求めし弁当開ける人の胸悪くせしも可笑しかりける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をとめてよく見ると、半開きの白ばらの花のかげ――肥料をやりたての根本の赤土の上に生れたばかりの小さいひきがえるがよちよちしている。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農業に関する知識は相当にあって、人工肥料の問題にも興味があり、この点では却って旧弊な執事等より進取的であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窒素肥料の硫酸アンモニアもまた石炭から採ることが出来るという話である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんなところから郷土的な「肥料盜人」のやうなものが生れた。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンナ・ニコロ接吻したまま、　――ヨシユキ、ロマンチシズムとヒロイックなスラビナの時代はまだロシア人は香のいい肥料があったのです。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拭には、どっかの村の肥料問屋のシルシが染めこまれてある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にとって、トルストイが肥料だった。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、トルストイは、あまりに豊富すぎる肥料で、かえってあぶないようだ。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに慾張って、肥料を吸収しすぎた麦は、実らないさきに、青いまゝ倒れて、腐ってしまう。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのように、トルストイという肥料から、あまり慾張ってそれを吸収しすぎると、こっちが、肥料負けがしてあぶない。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻からげをして、帯には肥料問屋のシルシを染めこんだ手拭をばさげて居る。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "製鉄所も、化学工場も、肥料会社も――そして、そこに働いている労働者が――戦争のために使われる。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "化学工場からは、毒瓦斯を、肥料工場からは――肥料会社は、肥料を高い値で百姓に売りつけるが、必要に応じて、そこから火薬が出来るようになっている。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は肥料だのすっかり僕が考えてきっと去年の埋め合せを付ける。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから仕事の予定も肥料の入れようも見当がつかないのだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして肥料だのすっかり考えてやる。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも肥料の入れようやなんかまるでちがうんだから。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくが肥料を教えた喜作のだってそれだけなら何でもない。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、あれぐらい手入をしてあれぐらい肥料を考えてやってそれでこんなになるのならもう村はどこももっとよくなる見込はないのだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西袋も今はその辺に肥料会社などの建物が見えるようになり、川の流れのさまも土地の様子も大に変化したが、その頃はあたりに何があるでもない江戸がたの一曲湾なのであった。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "土の性質、肥料や水の供給、それから光線や温度の関係で同じ種から貴族と平民が生まれるのであった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本には昔からずいぶんいろいろな危険思想が海外から幾度となく輸入されたが、それが抑圧に抗しながらやっと土着するころにはいつのまにかすっかり消化され日本化されてしまって結局はみんな大日本を肥やす肥料になっていた。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもこれらのおとぎ話を、尻の曲がったごうなの殻にでも詰め込んで丸のみにさせられていたのであったら、とうの昔に体外に排泄されてどこかよその畑の肥料にでもなっていたことであろうと思う。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから土地に肥料を施す如く、人は色々な文句を作ってこれ等の情を肥かうのだ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
