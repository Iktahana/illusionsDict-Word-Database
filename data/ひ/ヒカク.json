[
  {
    "uuid": "1bbd0646-e973-5f23-a77f-1d09518d6b15",
    "entry": "比較",
    "reading": {
      "primary": "ひかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
