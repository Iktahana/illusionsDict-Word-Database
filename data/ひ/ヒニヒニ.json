[
  {
    "uuid": "4eceb34e-847b-5268-a318-57c00749453a",
    "entry": "日に日に",
    "reading": {
      "primary": "ひにひに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
