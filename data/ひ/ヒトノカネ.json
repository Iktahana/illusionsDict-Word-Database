    "definitions": [
      {
        "index": 1,
        "gloss": "other people's money",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は心におもつた、昔、一緒に遊んだことのある、一人の金髮をした少女のことを。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿舎からは、工人の金属的な、激昂した声が、やかましく事務所の方へもれて行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい皆聞かっし、初手はな、支那人の金満が流丸を啖って路傍に僵れていたのを、中隊長様が可愛想だってえんで、お手当をなすってよ、此奴にその家まで送らしておやんなすったのがはじまりだ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の金銭に其方が関係する権利はあるまい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ある夜、花井｜母子は夜逃げしてしまい、どうやら主人の金で株をして穴をあけたためだと、あとで分った。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では隨分大きい仲買所でも仕拂を多少づつ遲れさす、即ちそれ丈人の金を融通しておくのである。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい皆聞かつし、初手はな、支那人の金満が流丸を啖つて路傍に僵れてゐたのを、中隊長様が可愛想だつてえんで、お手当をなすつてよ、此奴にその家まで送らしてお遣んなすつたのがはじまりだ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも一千人の金剛力者は、この機械の中に暴れて居る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　イワンは、それは私のしたことではありません、私はゆうべ一しよに茶を飲んでからあとは、ずつとあの人の顔を見なかつたのです、私はじぶんのお金を八千ルーブルもつてゐる以外に、人の金なぞはもつてゐません、と、ちかつてかう言ひました。",
              "citation": {
                "source": "ざんげ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御奉行さまの前ですがあのときほど、盗みが面白かったことはございません」　越前は、苦笑していたが、「長吉よく物を考えて見よ、その老人が生命を失おうとしたのは、その老人の金を盗んだ盗人の故ではないか。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちも、人の金を盗むことで、その人の生命を奪っていることもあるのだぞ。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "万年筆屋が銭湯へ呶鳴り込んで来たが、安二郎は、「あんた、人の金ただ借りれると思たはりまんのか」と頭にのせた手拭をとってもう一つ小さく畳むと、また頭の上にのせた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他人の金を遣うのも、やはりよくないことなのだ」　そこで黄英が言った。",
              "citation": {
                "source": "黄英",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷章は要人の金を出すからという妥協に耳をかさないで、府庁に訴えた。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは地の下の小人の金のようなものだ。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉公人として主人の金をぬすみ出すのは罪が深い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして其の本人の金之助は殆ど生きている心持はなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の商人に聞いてみると、金を持っている人には商売はできない、金のないものが人の金を使うて事業をするのであると申します。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何為添れんのですか」「はい、実は私は、恥を申しませんければ解りませんが、主人の金を大分｜遣ひ込みましたので御座います」「はあ、御主人｜持ですか」「さやうで御座います。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいい加減の拵え事をして主人の金を掠めようなどという、そんなさもしい怖ろしい心は微塵も持っていない。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら落ちぶれていても、奉公の妹をそそのかして主人の金を盗み取るほどの人間と見積もられたのは甚だ心外である。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどアメリカ人の金銭に対して露骨なのと一般だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政の大地震や明暦の大火の後にも、放逸な仮宅生活や、諸職人の金廻りのよかった関係から、淫風蕩々たるものがあったことは史実の証明するところである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺初めて聞いて吃驚したんだけれどもな、今までの日本のどの戦争でも、本当は――底の底を割ってみれば、みんな二人か三人の金持の（そのかわり大金持の）指図で、動機だけは色々にこじつけて起したもんだとよ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だから※は他人の金を右から左へ持って行っただけで、三分にして年三割六分、全く無償で二割六分（二割六分！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るからに画家らしい二人の男は川口亜太郎とその友人の金剛蜻治、女は亜太郎の妻｜不二、やがて三人が岳陰荘の玄関に着くと、あらかじめ報のあったものと見えて山荘に留守居する年老いた夫婦の者が一行を迎え入れた。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして貯金が一千万円ぐらいになったら、ここへすごい常設館をたてて、大魔術とサーカスと透明猫と、三つをよびものにして、ここへ遊びに来る人の金をみんなさらってしまうんだ」　六さんは、えらい鼻息であった。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持の貧乏人となるか、貧乏人の金持となるか、結局、問題はその人の心構えの如何です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　婆さんのおはぐろや女の人の金歯は虫か何かのやうに見えるからたまらないのです。",
              "citation": {
                "source": "かげろふ断章",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
