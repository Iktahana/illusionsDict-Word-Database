          "literary": [
            {
              "text": "さあ分配金をくれてやるから、どこへでも行って遊んで来い」　手下どもを追いやってから、自分も重い財布を握り、いつもの癖の一人遊び、ブラリと吉原へやって来た。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は僕の前につゝ立つたまゝ、一人遊びをのぞきこまれた子供がやるやうに、そのどこを見てゐるかわからないやうな斜視の眼で、警戒するやうに僕をぢつと見返してゐた。",
              "citation": {
                "source": "南方",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして堀と私とが話をしていても何も言わずに、邪魔をしないで一人遊びするように、娘なぞと遊んでいた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ友達が一人遊びにやって来て、大将何を考え込んでいるのだと言う。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬいぐるみで一人遊びする子どもにとって、そのぬいぐるみがどれだけ大事で心強いものなのかが、わかります。",
              "citation": {
                "source": "ぼくら　ふたり",
                "author": "US TWO",
                "note": "青空文庫"
              }
            }
          ]
        }
