        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｔ「てっきり彼奴」　と独り言、Ｔ「朝ッぱらから一稼ぎしてやがるかも知れ無えぞ」　其辺で鉄五郎クルッと踵を反して走り去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと一稼ぎしなきゃあ、今日のおまんまに有り付けねえ」　国太郎はそう言ったが、自分の冗談が幇間の気持ちの上にどんなに響くかちょっと顔を後へ向けて魯八の顔を見る。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵を上げた見世物の、じゃ、じゃん、じゃんも、音を潜めただからね――橋をこっちへ、はい、あばよと、……ははは、――晩景から、また一稼ぎ、みっちりと稼げるだが、今日の飲代にさえありつけば、この上の欲はねえ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "村出身の予備後備の軍人の年金の話で、いま一戦争あつて引出されると俺もこれでまた一稼ぎ出来るがなア、何しろ斯う不漁ぢア仕様がねえと図太い声を出したのを見るともう五十歳に近い大男であつた。",
              "citation": {
                "source": "岬の端",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂は蜂で、正午前後のぽかぽかと暖かい頃を見計らつて、「もう一稼ぎだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし熊坂｜長範が山で一稼ぎする積りで夜が更けて高野へ登つた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "長範の腕は盗みをするだけに寸も長かつたし、納骨には打つて附の代物であつたが、山でもまだ一稼ぎしなければならぬので、一寸｜出し惜みをした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは何もこの家を目当に、うろついていたのではないのですが、ちょうどそこへ来合わせたのを幸い、一稼ぎする気を起しました。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜に行って、一稼ぎするつもりである。",
              "citation": {
                "source": "どぶろく幻想",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "富子の母親にはお金持の旦那があつて金に不自由がないから、娘を芸者に一稼ぎなどゝいふ考へはなく、然るべき男と結婚させてと大いに高い望みをかけてゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "必要のノミシロ以上は決して仕事をしなかったが、人が困っているのを見ると、一稼ぎして、人にくれてやることは時々あった。",
              "citation": {
                "source": "死と影",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　エンゼルは娘をだまして一稼ぎするには妙を得ていた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "吸いつけ煙草に離れともない在郷の衆、客を呼ぶ牛太の声、赤絹に火のついたような女たちのさんざめき、お引けまでに一稼ぎと自暴に三の糸を引っかいて通る新内の流し、そのなかを三人は左右大小の青楼へ気を配りながら、雁のように跡を踏んで縫って行った。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたというんだね」「いや、どうもこうもありゃしねえ、お蘭さん、お前はこいつを持って一足先に行きな、おいらあまた一稼ぎだ」　がんりきは、こう言ってお蘭どのの、らんじゅくした面をまじまじと見つめると、「いやな人だね、なんて目つきをするんだよ」　お蘭どのが、手をあげてぶつ真似をしました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二家の争うは、徒らに、越後の上杉をよろこばすのみではないか）　と、占領範囲の悉くを、既成事実として認めさせ、一稼ぎの後は、恬として、澄まし込んでいる迅さの如きは、蟇が蚊を呑んで嘯いているような横着さである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "四ツ谷で今またふたりも似通った手口の死骸が見つかったというからにゃ、おそらく四、五人の仲間があってひとかせぎしてやろうと、おたげえ手をつなぎながら荒仕事やっているにちげえあるめえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとかせぎしような」　突然鋭く言いすてると、不意にすっくと立ち上がったものでしたから、こちこちになっていた伝六は、はじめて毒気が抜けたようにお株を取りもどして、すっかり生地のままの伝六となりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "草花の香でしょうか、あ、雲雀が鳴いてますよ」　「さあ、お鮓をいただいてお腹ができたから、もうひとかせぎして来ましょうか、ねエ女中さん」と姥の幾は宿の女を促し立てて、また蕨採りにかかりぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "草花の香でしょうか、あ、雲雀が鳴いてますよ」「さあ、お鮓をいただいてお腹ができたから、もうひとかせぎして来ましょうか、ねエ女中さん」と姥の幾は宿の女を促し立てて、また蕨採りにかかりぬ。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車でも來たら、しかれる前にハロウとか何とかいつて、乘せてつてもらつて、ついでにあわよくば、ひとかせぎやらかそうという口だろう。",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
