        "examples": {
          "standard": [
            {
              "text": "彼女はピアノから絵画まで、あらゆる百芸に秀でている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の家には、世界中から集められた百芸の品々が飾られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "父は多趣味で、まさに百芸の達人といった感じだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "芸術は百芸の長である。",
              "citation": {
                "source": "芸術上の心得",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、若い連中の眼には百芸百能の驚異的な人間に見えたにちがいないのである。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "一芸に秀づるものは必ず百芸に通ず。",
              "citation": {
                "source": "小説作法",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、日ごろのゲジゲジも迂路鼠も青草蛇も、案外、天真｜爛漫なもので、飲む、踊る、唄うなど、百芸の歓を尽して飽くるを知らない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
