[
  {
    "uuid": "aa310ddf-aed0-59e2-99a2-1c85e9149723",
    "entry": "ヒレ",
    "reading": {
      "primary": "ヒレ",
      "alternatives": [
        "フィレ",
        "フィレー"
      ],
      "is_heteronym": false
    },
    "grammar": {
