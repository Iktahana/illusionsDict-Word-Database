[
  {
    "uuid": "dd76b883-eb05-5251-9278-ad6fbf64a314",
    "entry": "氷面",
    "reading": {
      "primary": "ひょうめん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
