        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「それじゃあれがストーンだ」というと、「驚くべき推理の力だな」と冷やかす。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷やかすなってこと……アタマは生きてる中使っとくもんだ。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は直江津の艀船の腑甲斐なさを、冷やかす意味において、水火夫全体へ向かって、当番を除いたほかの者は、ボートと伝馬とをおろして、練習していいという、本船初まって以来の計画と壮挙とが発表された。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集長がまた皮肉な男で、人を冷やかすことをなんとも思わぬ。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に癪にさわる、三十七の己を冷やかす気が知れぬと思った。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時に近頃はサディとドルガンのお揃いの所をよく見掛けるね」　スパイダーは探偵の冷やかすのを耳に入れまいとした。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林田は警察できいたそうだ」「何だ君、君は自分の情緒をあの男にしやべつたんだな」　藤枝はこういうとニヤリと冷やかすように私を見た。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるで気絶したようなんね」　と、冷やかすと、怒りながらまけてくれた。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、風呂敷包みになつてるなンて変ね」　ゆき子が冷やかすやうに、鏡から離れていつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も私を冷やかすかのように……。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「な、あんまり、冷やかすもんでねえ。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石川の荻原の下宿で夜を更かして、帰ってくるのを、荻原が送ると言うので、江戸川までくると、夜更けて、花の陰に店を出している、大道易者がいたのを、冷やかす気で、見て貰うと、易者は何と思ったのか、荻原の顔を見て、「あなたには女難がある」と言った。",
              "citation": {
                "source": "北国の人",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がついて見ると、いつの間にか二人の前には五六人の、支那人の子供たちが立ちはだかっていて冷やかすように彼等を見上げているのである。",
              "citation": {
                "source": "あいびき",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冷やかすんじゃない。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中達はびつこ、びつこと冷やかすのだが、なるほど冷やかしてみたくなるのだ。",
              "citation": {
                "source": "木々の精、谷の精",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "羞しがつてらつしやいますこと」　と、お妙が修吉を冷やかすのだつた。",
              "citation": {
                "source": "木々の精、谷の精",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷やかすだけならいゝが、多少は小言めく。",
              "citation": {
                "source": "妻の日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の顔の四五桂のつづきを読んでるわけじゃアあるまいね」　と冷やかすと、意外にも、木戸は真顔でそれに答えて、「えゝ。",
              "citation": {
                "source": "桂馬の幻想",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人にも余り話しかけず、昨日のやうに芝居もどきで歩き廻りもせず、下の六畳に腕を組んで坐つてゐたが、時々噛んで吐き棄てるやうに人々の会話へ皮肉な冗談をまぜつ返してみたり、冷やかすやうに「ふん」と言つて肩を聳やかし乍らソッポを向いたりして、自分は会話の中へ溶けやうとしなかつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴作はさういふ心のまとまりのない廻転に正直に身をまかせ、暫く沈黙に耽つてゐたが、「ほんとに君はあの女に気がないのかな」　と、紅庵を冷やかすやうに笑つて言つた。",
              "citation": {
                "source": "雨宮紅庵",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "多寡をくくつて冷やかすといふほど露骨なものではないにしても、肉体の交渉をおよそなんでもないことのやうに言ひ強めた心理の底には、逆に肉体の交渉が紅庵にとつては最大の関心事であつたことを示すところのものがあると解釈しても不当のやうには見えなかつた。",
              "citation": {
                "source": "雨宮紅庵",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "端のものがそういって、あとから幾度も冷やかすのである。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見は自分にそういう性癖があるのを知り抜いていて、時には余りに冷やかすぎると思って悔むことさえある。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくだよ、こう答えるのは長島萃で、冷やかすようにニヤニヤあとは無言、あいつは何を考えていたのだろう。",
              "citation": {
                "source": "青い絨毯",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがあんた」と他巳吉は、卓一を冷やかすやうな笑ひを浮かべて喋りだすのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は冷やかすであらう。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも俺は、と他巳吉は澄江の顔を眼前に描きながら、冷やかすやうな笑ひを浮かべて呟いた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひやかすやうに云ふんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひやかすように云うんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひやかすように言うんだ」「おまえに悪口を言うの」「うん、けれどもカムパネルラなんか決して言わない。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
