    "definitions": [
      {
        "index": 1,
        "gloss": "fluttering to the ground (of a leaf or petal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
