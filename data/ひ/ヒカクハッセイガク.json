          "standard": [
            {
              "text": "比較発生学は、異なる生物の胚の発生過程を比較し、進化の証拠を探る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は魚類と両生類の発生段階における類似性について比較発生学的な研究を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "比較発生学の知見は、種間の進化的な関係を理解する上で不可欠である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二　比較解剖学、比較発生学、動物化石学、動物分布学等の事実に基づいて考へれば、人類は決して初めより今日の通りの人類として、存在して居た訳ではなく、或る時代まで溯れば、猿類と共同の先祖に達することは、最早疑ふことの出来ぬ確な事実である。",
              "citation": {
                "source": "固形の論理",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較解剖学とか比較発生学とか、すべて比較という字を冠らせた学科はみなこの見方によって研究を進めているのである。",
              "citation": {
                "source": "生物学的の見方",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
