        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みみずくの、ひとり笑いや秋の暮。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、ひとり笑い崩れた。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作も思わず釣りこまれてひとり笑いしていると、細目にあいてる戸の間から白い女の顔がすっと出た。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由を知らない女房らは口々に、「なぜひとり笑いをしていらっしゃるの」　と言った。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はいたずら者らしくひとり笑いをしながら立て膝をしてみたが、それには自分ながら気がひけたので、右足を左の腿の上に積み乗せるようにしてその足先をとんびにしてすわってみた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍子は「婦系図」の、やはり湯島天神境内の場面を思い出し、自分の書生っぽ姿を思い合わせ、ひとり笑いを浮べた。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一体誰だい」「ふふふふ」　とカビ博士はひとり笑いをしてから、「おどろいてはいけない、君の妻君だよ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎十郎は橋のたもとに突っ立って、ひと波に揉まれながら、ジッとその様子を眺めていたが、ふっとひとり笑いすると、「なるほど、あれが源次郎さまか。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "野伏大名",
                "note": "青空文庫"
              }
            },
            {
              "text": "お高は、それがおかしいようにくすくす笑って、それから、その、ひとり笑いに気がついて急にまじめな顔をつくって、雑賀屋の寮の門をくぐった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり笑いたいような気持で眺めて通ってゆくうちに連想がひろがって、伸子はチョルト・ポヴェリ（悪魔にさらわれろ！",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と、すぎさった手術に向って心の内で陽気にルガーチ（罵り）しながら、ひとり笑いで唇をゆるめた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いつの間にかかくれんぼでもしているように、われ知らず緊張していた自分に、声を立てないひとり笑いをした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸思い出してひとり笑いつつ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさあやまったのに損をしてしまった、と思って全く可笑しくひとり笑いました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これじゃわたしもいやなわけだと、ひとり笑いいたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（思い出してひとり笑いいたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風なブランカのひとり笑いに交ってカッコーは盛に鳴いて居り、咲がおみやさんの遺品わけをして話している声がきこえます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らず天空の爛々たる星を仰いで、ひとり笑いに笑っている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の好きなおかずの時は、にっこりとひとり笑いをして予供みたいに喰べています。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、体が弱いと風をひきやすいから、まず体を丈夫にすることだ」　それからしばらくして、高橋さんは帰って行きましたが、一太郎君は、「やっぱり高橋さんはえらいや、だから、僕、高橋さんが大好きさ」と、つぶやきながら、にこにこと、ひとり笑いをするのでした。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では一つ、いたずらを初めるかな」　私はニヤニヤひとり笑いを洩しながら、客が少いので見つけられる心配もなく、例の道具立てに取かかるのでした。",
              "citation": {
                "source": "湖畔亭事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
