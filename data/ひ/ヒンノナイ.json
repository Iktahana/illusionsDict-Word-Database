    "definitions": [
      {
        "index": 1,
        "gloss": "vulgar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　女中あがりらしいその少女は、品のない口調でそう叫んで、私の傍の椅子にべったり坐った。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "携帯品のない場合には、その土地の羊羹か煎餅のたぐいを買って贈る。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、頸筋をさすつたり兩手をもみ合せたりして、氣品のない話かたをした。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それにしても、蓮葉な表情、ごてごてした品のない身なり、變に肉感的な姿體には人妻らしい一種の落ち着いた感じは見えなかつた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏に大きな代表的作品のないのは惜しいが、自分は氏をその理由で責めたくない。",
              "citation": {
                "source": "小川芋銭",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀さんは背の低い、品のない、五十四、五の女で、良人に羽織を着せる時、丈一杯｜爪立てする様子を、お庄は後で思い出し笑いをしては、年増の仲働きに睨まれた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟のプロレタリア文学はその素晴らしい達成にもかかわらず、やはりこの国際的主題を扱ったいい作品のないことは関心の的となっている。",
              "citation": {
                "source": "プロレタリア文学における国際的主題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、お土産品を売るというんで自他ともに許しているはずのミカエル街ピルチの店に、売子と埃と好意と空気の他何ひとつ商品のないのに最後に感心。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、評者たちの言葉が一致したことは、本当に新しいという作品のないこと。",
              "citation": {
                "source": "今日の文学の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚生活に入って五年の間、一つもまとまった作品のないことを苦痛に感じ、不安に感じはじめていた作者は、一九二三年の夏には本気ですこし長いものをかきたかった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第二巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "画品などというものは、捜し廻っても何処にもありはしません、下卑た品のない、薄ッぺらなけばけばした絵ばかり目につきます。",
              "citation": {
                "source": "帝展の美人画",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家ではこんな普通の衣服の色の取り合わせをしたりすることが長くなかったのですから、品のないものにしかでき上がらないでね、死んだ人が生きておればと、そんなことを思い出していますが、あなたにもそうしてお世話をなさいました方がいらっしゃるのですか。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "友禅菊という、葉や、咲きかたや色の今めかしい品のない花だが、芒のかげに一叢になっているのは、邪魔にもならないのでそのままにしてあるが、初元結にはとてもおよばない。",
              "citation": {
                "source": "紫式部",
                "author": "――忙しき目覚めに",
                "note": "青空文庫"
              }
            },
            {
              "text": "品のないモダン一家の典型。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "品のないことおびただし、ただ、極めて二流的に演技し、科白が面白いので皆よろこんで笑う。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間即ち「俗」といふことになりますが、これは、もともと「出家」したものに対して世間の普通の人を「俗人」と云つたのを、転じて「凡庸」の意に用ひ、更に、卑しく品のないことを指すに至つたのです。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十がらみの見るからに品のない行商人らしい小男だ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "学用品のない子ども。",
              "citation": {
                "source": "石をしょわずに",
                "author": "――わかい女教師の自殺",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶わんの重い、厚手のは、まことに品のないものでございます。",
              "citation": {
                "source": "殿さまの茶わん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はただ気品のない画を掛けたものだと思ったばかりである。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "品のない冷たい人間ではないか。",
              "citation": {
                "source": "悩みのひととき",
                "author": "SCHWERE STUNDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗難品のない盗難だ。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんちくりんで、縹緻も悪く、品のないお石などが、狩野家の麒麟児とまでいわれる近恒を、すでに自分のものかなんぞのように触れまわす。",
              "citation": {
                "source": "おれの女房",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若さまは御身分が違うのですから、決してそのような品のないことをあそばしてはなりません」　かれらと身分が違うということは、日常すべての事が示していた。",
              "citation": {
                "source": "菊千代抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の様に色々な薬品のない時分の堕胎薬といえば、もうこれに極っていたものだ。",
              "citation": {
                "source": "毒草",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金色」サトウの荒尾が汗をかき熱演するほど安っぽく、品のないものになる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
