        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昭和六年の秋米国各大学における講演を頼まれて出張し、加州大学、スタンフォード大学、加州及びマサチュセッツのインスチチュート・オブ・テクノロジーその他で、講義、あるいは非公式談話をした。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしロンドンにお帰りになったのは、全く御同慶の至りに堪えません」「いや、君は僕の非公式の助力が要りそうだと思ってさ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか彼とか、偉そうなこと、つよそうなこと、階級的そうなことを云っても、対手の女を見ると、その男の非公式な部分、書いてない部分が露出している。",
              "citation": {
                "source": "ゴルフ・パンツははいていまい",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民の公式儀礼は少なくとも非公式心理によって多少とも裏切られて見えたのが、上半期の事実であった。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この売春婦の非公式ふらんす帰化の心理には、いくぶんそこに、じぶんの行為によって自国の名誉を傷つけたくないという少しの愛国的作用も働いてることだろうし、それに、外国の女となると、べつの現象に対するように男の好奇心が沸き立つところをも、彼女らは経験によって捉えているのであろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "非公式にマンハッタン計画と呼ばれていたというＰＣプロジェクトで、ソフトウエアの調達を担当していたジャック・サムズにインタビューした際、同書の著者は、この問題に関するサムズの主張を聞き取った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の批評家の団体はマス君の議論を正理の擁護だと非公式に認め、フランセエズ座の名優某は匿名の下に「カイアエ君を揶揄した。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真班――非公式の旅行なのに、ベルリン停車場へ着いてみると、大変な騒ぎだから、アバス・ヌリ殿下は、どうして知れたんだろうと不思議に思っている。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に米国海軍あたりではわが艦政本部が非公式に発表した『最上』の設計図を見て、舌をまいて驚いているのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、非公式に出るものは、家あるじの側に侍る高級官女――巫女の資格を以て奉仕した――に口授せられたものが、其文句の受けてに其まゝ伝達せられたのである。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷巫女なる内外の命婦以上の高級官女が、臨時・非公式或は、至上個人としての相聞・感激の御｜口占に、代作或は添刪に与る風が、殊に著しくなつて来たらしい。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "賀正事の非公式になつたもので、兼ねて「斎の木の祝言」の元とも言ふべき宮廷の新年行事である。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "非公式でも、皇族の訪問は虔まねばならぬ事であつた。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷を大家――公――と言ふに対して、後宮の主の上に、後代非公式に生じたものとして、私部の字を、后の部民・領土の上に宛てた。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ看護人ほどの自由はないが、医師や事務員の引上げた後なら、同僚即ち看護人の理解によつて、非公式ではあるけれども外出できるし、縁日をぶらついてきたこともあつた。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "道・釈の教が、記録の指定する年代よりも遥か以前に、非公式に将来せられてゐたのと同様、暦法も亦、史の書き留めを超越してゐるものと見てよい。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "公式と非公式とでは違ふであらうが、内容にも屡あり得べきことではなかつた。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "非公式には多少の往來を交して居さうな人々の間にも、公式となると、こと／″＼しい形式を履まねばならぬことになつてゐた。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それは非公式にだ。",
              "citation": {
                "source": "死んだ魂",
                "author": "エマ・ゴオルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、（二）　昭和十四年八月企画院に「新聞雑誌用紙協議会」が非公式に設置され、そこで新規割当等が協議された。",
              "citation": {
                "source": "日本出版協会論",
                "author": "嶋中雄作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはわれわれがそう思い、また誰しもが疑問に感じる点である」（六月十五日、「ミュンヘン新報」）　その朝、山の城で非公式な告別式があった。",
              "citation": {
                "source": "泡沫の記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝、忠相は非公式に右近を審べて、伊勢の名家の出と知り、山田奉行当時の友人の息ではあり、且つ人違いで当の喬之助ではないので、お絃とともに許してやる。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "和泉屋からも、非公式に具申してきていたし、それよりも、木場の甚は、ふるくから深川の顔役で、公事やその他いっさいの口ききで、数寄屋橋ぎわの奉行所へは日参していたし、忠相も、しっかりした老人をみて、以前から半官式に深川一帯のことをまかせて、忠相と木場の甚とは、役目を離れて、ある意味では友人でもあった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟木　いや私のは権利と言うよりも、非公式な、ここの元の主人の手紙だとか何とか、遺言書ではないから、表面上の効力は無いだろう。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし事にも手紙は非公式の喚出状で、殊に差出人が有名な宮岡警部であったのは意外の喜びであった。",
              "citation": {
                "source": "黒猫十三",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迢空は堀辰雄に好意をもっていたし、好意は非公式の愛情をも潜めていたものらしい、堀もそれをうすうす知っていたから、おとろえた姿をこの人の眼に見せたくなかったのだろう。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度見せてほしいとごく非公式に申入れたが、だれか中間にけちをつけた人間がいたと見えて、私が、そのノートは沖縄について大事なもので、北海道には用がないといったことを、悪意で先方へ伝えて、先方がつむじを曲げてしまった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この所説の報道がそんなに間違っていなかった証拠は、之を反駁した陸軍の非公式声明（『東朝』四月二十八日付）に見られる。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが蔵相の所論が発表された時は、都下の主な新聞紙は揃って蔵相に拍手を送ったことを忘れてはならぬ（之に比べて陸軍の非公式声明が如何に弁解的であるかは、すでに蔽うことの出来ない感触だ）。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍当局は最後に、この第二回目の演説に対して非公式な声明を発して、若槻総裁を反駁した。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
