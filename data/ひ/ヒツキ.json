        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あたかも我々自身の運命が我々の裡でひつきりなしにより明らかであると同時により目には見えないものとなつてゆくやうに。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ上つた思ひつきだ。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから少し馬におくれたので急いで追ひつきました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "籬などに纏ひつきつ、風車のようなる形して咲き出でたる花の色白く大なるが程よく紫ばみたる、位高く見えて静に幽なるところある美はしきものなり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の空や通りはまるつきり白だか水色だか変にばさ／＼した雪の粉でいつぱい、風はひつきりなしに電線や枯れたポプラを鳴らし、鴉なども半分凍つたやうになつてふら／＼と空を流されて行きました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "杯盤の間に於ても暗闘と暗闘とがひつきりなしにつづく。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "寢られないほど、ひつきりなしに、けたゝましく鳴立てたのである。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金をかけて、茶座敷を営むより、此の思ひつき至つて妙、雅にして而して優である。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口の農具展覧会行だらう、自転車と自動車とがひつきりなしにやつてくる。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "この思ひつきは意表外であつた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が寂しさ苦しさのあまり、自分を救ふ何等かの手段を、衆生済度僧たる老師が持ち合せるであらうといふ一面功利的な思ひつきからでもあつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その負担をのがれる為めと、やゝもすれば身辺に近づいて来る画像の誘惑から遠ざかる為めと、もひとつ彼の思ひつきの為めに彼は翌年の春の初、寺のうしろの畑地の隅に居を移した。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓさんは、それを思ひつき、私に食べさせようとして連呼してゐるのだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数枝に、無理矢理、劇場から引つぱり出され、さうして数枝の悪意ない、ちよつとした巫山戯た思ひつきが、高須をここへ連れこんだ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧の処には矢張丈足らずの骸がある、遠くへ避けて草の中へ駆け抜けたが、今にもあとの半分が絡ひつきさうで耐らぬから気臆がして足が筋張ると、石に躓いて転んだ、其時膝節を痛めましたものと見える。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イドリスは、そのとッさに、気ちがひになるよりも、もつといゝことを思ひつきました。",
              "citation": {
                "source": "ダマスカスの賢者",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、私は思想家でも科學者でもないから、私のひよい／＼と浮かんで來る思ひつきや斷片的な考へが皆優れたものだつたらうなどといふのではない。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の中で私に慘殺された無數の思ひつき（それらは、高く風に飛ぶ無數の蒲公英の種子のやうに、闇の中に舞ひ散つて、再び歸つて來ない）の中には、さうした類のものだつて多少は交じつてゐたらうと考へるのは、自惚に過ぎるだらうか？",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、今浮かんだ思ひつきの大部分は消えてしまひ、頭を掠めた中の最もくだらない殘滓が紙の上に殘るだけなのだ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは思ひつきだ。",
              "citation": {
                "source": "エハガキの激賞文",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして家出した以上、自分はもう思ひ切り堕落するか、野たれ死にするか、二つのうちの一つだと思ひ、少年らしいこの極端な思ひつきにソハソハと揺れてゐるうちに、電車は梅田に着いた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、その想ひつきのしびれるやうな幸福感に暫らく揺られてゐた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と蹲りながら、手を挙げて、「唯今、思ひつきました。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は猶口を極めて小室の人柄を褒め、思遣り深い殿樣、下々の思ひつきのよいことまで言うて、かういふことになるのも全く神々の御計らひ眞に有難いことやと涙を拭いて悦んだも無理ならぬことである。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば天を仰いで可見の星の姿を写さうならば、それは直に空想の所産であつて、ひつきよう絶対の存在ではないか。",
              "citation": {
                "source": "水車小屋の日誌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "花火はひつきりなしにあげられた。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隠し場所の思ひつきのすぐれてゐることには、俺も彼女に敬意を表した。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "○男子一、（激しく）百姓になる、そいつは思ひつきだ。",
              "citation": {
                "source": "きのふは嵐けふは晴天",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
