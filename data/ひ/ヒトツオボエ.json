[
  {
    "uuid": "211959e8-8e79-5ca1-b5d5-8ff43fe1d822",
    "entry": "一つ覚え",
    "reading": {
      "primary": "ひとつおぼえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
