[
  {
    "uuid": "5a8a4cc1-9e93-57fd-819e-63131f383f59",
    "entry": "氷点",
    "reading": {
      "primary": "ひょうてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
