        "examples": {
          "standard": [
            {
              "text": "かつての東ドイツは、社会主義体制の下で独自の発展を遂げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ベルリンの壁崩壊後、東ドイツは西ドイツと統一され、一つのドイツとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は東ドイツ出身で、統一前の生活について興味深い話を聞かせてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ソヴェト式に自分たちの仕事を分担し組織する能力と習慣とをもった農村出身者たちは、東ドイツの村落へ行っても、その能力を発揮した。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この點に關しては、東ドイツに生まれたシュティフテル、シュワーベンに育ったメーリケと並び稱されている。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
