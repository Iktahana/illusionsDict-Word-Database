    "definitions": [
      {
        "index": 1,
        "gloss": "prostrating oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして毎年船をどっさり仕立てまして、その船底の乾くときもなく、棹や櫂の乾くまもなもないほどおうかがわせ申しまして、絶えず貢物を奉り天地が亡びますまで無久にお仕え申しあげます」と、平蜘蛛のようになっておちかいをいたしました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日どこへ往っても、誰の前でも、平蜘蛛のようになって這いつくばって通った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上機関大尉は、はっと体を縮めるなり、飛鳥のようにカンバスのうしろにとびこむと、そのかげに平蜘蛛のようにぴったりとはりついた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は木連格子のあいだからそれをそっと転がし込んで、自分は土のうえに平蜘蛛のように俯伏していた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の顔を見ると、平蜘蛛のように、お辞儀をしながら、そのくせ、額ごしに、冷たい目でじろじろ見ていたかと思うと、いいにくそうに、『旦那はん。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎はやはり旗を片手に、三匹の家来を従えたまま、平蜘蛛のようになった鬼の酋長へ厳かにこういい渡した。",
              "citation": {
                "source": "桃太郎",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "口をポカンと開いて、今にも涎の垂れそうな顔をしたが、両手をさし上げたまま床の上にベッタリと、平蜘蛛のようにヒレ伏してしまった。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕人が平蜘蛛のようになって謝っているがどうしても許さないのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の三人の少年たちは平蜘蛛のようにへたばった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十郎は平蜘蛛のように、ピッタリ地面へ身を伏せていた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に文治が、「これ一同静かにしろ」と睨み付けられてピタリと止って、平蜘蛛のようになって居ります。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "憮然として、なお燈下にうずくまる男を見下ろしていると、右の老爺は平蜘蛛のような形をしているのが、気のせいか、見ているうちに平べったくなって、畳にべったりくっついてしまっているように見えて、白雲も少し気味が悪いような気分にさえなりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "平蜘蛛のようにひれ伏してしまった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "御勘弁願います」　ひと片づけすんだのち圓太郎は、平蜘蛛のようになってあやまった。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナア、宗匠、後生じゃから、お願いじゃから――」　人に頭をさげられつづけて、生まれてからこの自分の頭をさげたことのない対馬守、ここを先途と、平蜘蛛のようにペコペコお辞儀をしている。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "御書院番衆はやれやれと寛ぎ出して、急にそこここに話声も起り、中断されていた喬之助いじめをまたはじめようとそっちのほうを見ると、もう皆頭を上げているのに、喬之助だけは、まだ平蜘蛛のように畳に手をついている。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "御書院番衆は、やれやれと寛ぎ出して、急にそこここに話声も起り、中断されていた喬之助いじめをまたはじめようとそっちのほうを見ると、もう皆頭を上げているのに、喬之助だけは、まだ平蜘蛛のように、畳に手をついている。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻布の馬場やしきだことの、高音とかいうおかみさんだことのと、めりはりの合わねえことばかりいっていたが、やっとあとでまちがいとわかってな、今度は、平蜘蛛のようなあやまりようよ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちっ、困ったなあ」腕組みをほどいた文次が、「この稼業ばかりは何からどう糸を引くかしれねえから、では、ちょっくら出張って――」　閑山は平蜘蛛のように額を畳にすりつけた。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで源右衛門は平蜘蛛のようになってこの福の女神を拝んだのだった。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "林は扉口で、「林謹直でございます」　と名乗りを上げ、平蜘蛛のようになってお声を待っていたが、およそ二分経っても何のお返事もない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女はちいさい声でつぶやいたとき、外では男が湿った板戸にぴったりと平蜘蛛のように忍びよったところであった。",
              "citation": {
                "source": "香爐を盗む",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎は、そこに飛びこむと、平蜘蛛のように畳に体を伏せて息を殺した。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を畳の上に平蜘蛛のようにして、耳を澄まして寝息を窺ったが、紙張の中に人ありやなしや。",
              "citation": {
                "source": "大菩薩峠",
                "author": "東海道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも俺たちは、せいぜい平蜘蛛のように平つくばって、神さまを念じながら、ただもう逆らわぬよう……それをやり過すより外に、手は無いのだが、往々｜角だらけの岩石をまきこんで来るから、当り所の悪かったが最後、片輪はおろか、根こそぎ持って行かれ兼ねない。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　金を見ると木賃の亭主は、平蜘蛛のように謝り入って、それからは手のひらを返すように、頼みもしない薪を持ってきたり、粥を煮ようの、薬はあるかのと、うるさいほど、親切の安売りをする。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなお、諄々と、「べつに、どういう心算でもなく、お堂の中に、女子の泣き声が聞えたので、不審に思って、覗いてみただけでござります」　と、言い訳して、平蜘蛛のように、詫び入るだけだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ……」　彼女はふるえ上がって、大地へ平蜘蛛のように手をついた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして追剥ぎをするほどな力や度胸がなくても、「黒旋風李逵」とさえいって脅かせば、みな金や持ち物をすてて逃げ出すので、つい面白半分にもご高名をつかって、母子二人の露命をつないでいたもので――と平蜘蛛のようにあやまりぬくのであった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大友君が、そうして、屋根の上に、ひらぐものように、すがりついたときには、自動車はもうはしりだしていたのです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
