    "definitions": [
      {
        "index": 1,
        "gloss": "vote",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五十年後のソヴェト社会では、重大事件がすべてラジオで投票決議されるということになっている。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に總理大臣桂伯と直接に和戰の票決を爲したる外務大臣小村男とは、唯だ此の一擧に由りて、遽かに古今無雙の英雄となりたるものゝ如し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に総理大臣桂伯と直接に和戦の票決を為したる外務大臣小村男とは、唯だ此の一挙に由りて、遽かに古今無双の英雄となりたるものゝ如し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
