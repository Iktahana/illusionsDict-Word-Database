    "definitions": [
      {
        "index": 1,
        "gloss": "brown-eared bulbul (Hypsipetes amaurotis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、自分はこの絵を見る度に静かな田舎の空気が画面から流れ出て、森の香は薫り、鵯の叫びを聞くような気がする。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中に一本大きな赤椿があって、鵯の渡る頃は、落ち散る花を笹の枝に貫いて戦遊びの陣屋を飾った。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の空にはごを仕掛けて鵯を捕った事もある。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山にはどんぐりも落ちれば、鵯の鳴く音に落ち葉が降る。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここに鼬の係蹄が仕掛けてあるよ」「あれが鵯を捉える羽子だ」そして、「茸を生やす木」などと島吉が指さすのを見ながら、これが東京とは思えなかった。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷店、休茶屋、赤福売る店、一膳めし、就中、鵯の鳴くように、けたたましく往来を呼ぶ、貝細工、寄木細工の小女どもも、昼から夜へ日脚の淀みに商売の逢魔ヶ｜時、一時鳴を鎮めると、出女の髪が黒く、白粉が白く成る。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "虹の目玉だ、やあ、八千年生延びろ、と逆落しの廂のはずれ、鵯越を遣ったがよ、生命がけの仕事と思え。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯爵は鴎の影がなくなつたのでまた安心して樺色の実に嘴を入れ出した小｜鵯に眼をやりながら言葉を続ける。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小｜鵯も飛んで行つて仕舞つた。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「撃ったら知れるだろうか、俺より他に、何人もいそうにないぞ、こんな山の中じゃ、鉄砲の音は聞えても、鶴を撃っておるやら、鵯を撃っておるやら、わからないだろう、そうじゃ」　丹治はその鶴を人に知れないようにそっと撃とうと思いだした。",
              "citation": {
                "source": "怪人の眼",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何処の巣にいて覚えたろう、鵯、駒鳥、あの辺にはよくいる頬白、何でも囀る……ほうほけきょ、ほけきょ、ほけきょ、明かに鶯の声を鳴いた。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵯越の逆落しと遣れ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥の羽に怯かされた、と一の谷に遁込んだが、緋の袴まじりに鵯越えを逆寄せに盛返す……となると、お才さんはまだ帰らなかった。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "目白を、鵯を、百舌きちを。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山内の時雨」の中の鵯やもみぢの歌「厨辺の霜」の中の油画のやうな三四首。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きとし生ける鵯や百舌、鶫のたぐひ、木々の枯葉に驚く声も、けけつちやう、ちやうちやう、きいりきいりと親まる。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこにか鵯は叫べど、風騒ぐけはひも聴かず。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉踏み踏みつつ行けば、いづく飛び鵯高音うつ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "近々と啼き翔る鵯、遠々とひびく浪の音。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉踏みつつ行けば、いづく飛び鵯高音うつ。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾く年の落ち葉木の実といっしょに鵯の鳴き声も軒ばに降らせた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鵯が南天燭の実、山雀が胡桃ですか、いっそ鶯が梅の蕾をこぼしたのなら知らない事――草稿持込で食っている人間が煮豆を転がす様子では、色恋の沙汰ではありません。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "虹の目玉だ、やあ、八千年｜生延びろ、と逆落しの廂はづれ、鵯越を遣つたがよ、生命がけの仕事と思へ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵯がけたたましく啼き立てる。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に其処に常住する鴉――これもこの大きな松の梢の茂みの中に見る時おもひの外の美しい姿となるものである、ことに雨にいゝ――季節によつて往来する山雀、四十雀、松雀、鵯、椋鳥、鶫、百舌鳥、鶯、眼白、頬白等を数ふるに過ぎぬ。",
              "citation": {
                "source": "沼津千本松原",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "林には、　　鵯のこゑさへうらがれて、野面には、　　千草の花もうれひあり。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の本棚には一冊の書物もなくなつて、鵯、山鳥、カケス、鶫、雉、鵙、雀、カハセミ等の標本が翼を並べた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鳥、鵯、雉等は柚太が打つて来るのだが、私は肉食を執ると動悸が激しくなるからと拒んで、自分のわけ前だけを標本に造つてゐた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もず」を見ても「ひよどり」を見ても「からす」と言います。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日一｜疋の子供のひよどりがその中に入れられました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
