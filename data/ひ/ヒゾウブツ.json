[
  {
    "uuid": "e6f44b44-6116-5552-995a-8912f8834d2d",
    "entry": "被造物",
    "reading": {
      "primary": "ひぞうぶつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
