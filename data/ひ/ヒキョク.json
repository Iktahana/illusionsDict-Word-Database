    "definitions": [
      {
        "index": 1,
        "gloss": "elegy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ギリシア軍のトロイアにむかひて船出せし港一一二―一一四【悲曲】『アエネイス』。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し異説あり二二―二四〔喜曲、悲曲〕註釋者曰く。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤壁圖に題す首陽の蕨手に握り汨羅の水にいざ釣らむやめよ離騷の一悲曲造化無盡の藏のうち我に飛仙の術はあり。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "シユレーゲルも悲曲の要素は熱意なりと論じられぬ。",
              "citation": {
                "source": "情熱",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日古藤庵の悲曲続出するや、読者｜孰れも何となく奇異の観をなすと覚ゆ、要するに古藤庵の情熱、自から従来の作者に異るところあればなるべし、悲曲としての価値は兎も角も、吾人は其の情熱を以て多く得難きものと認めざるを得ず。",
              "citation": {
                "source": "情熱",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒れかかって、仲間にささえられ、風の渡るたびに、奇妙な悲曲をかなでているのもある。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに、それの繰返しの儚いことか、愚かなことか、古典平家の全篇はその悲曲である。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外の女性たちと義仲との悲曲は、おおむね著者の創意によるものとあからさまにいっておく。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこそ、一門が都の落去も、福原の焼亡も、一ノ谷、屋島、壇ノ浦の末路も、あわれとも、優しいとも、人間宿業のかなしさとも、何かいい知れない悲曲の響きを、今でも人の胸へ打ってくるのではあるまいか。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
