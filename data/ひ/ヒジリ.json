[
  {
    "uuid": "74185aa9-158f-5b0b-8e8d-4872542c783b",
    "entry": "聖",
    "reading": {
      "primary": "ひじり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
