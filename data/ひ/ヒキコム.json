        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それも富沢が何かしっかりしたさういふことの研究でもしてゐてじぶんの考へに引き込むためにさう云ってゐるのか全く本音で云ってゐるのか、或は早くもあの恐ろしい海外の思想に染みてゐたのかどれかもわからなかった。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすいうすい真綿の毛のような繋縛がいつも絡みついてたいして堕落へ引き込むという懸念も無い代りに綺麗に吹き払おうと思えばなかなか除きにくい、これが自分の性情の運命である。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上へ上へとはしゃぎ出そうとする氏の都会的な陽性を、どうしても底へ引き込む陰性なものがある。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界市場では、結局足元を食い荒らされた互換勢力を引き込むリスクを承知でこの道を選んだ以上、日本ＩＢＭは気合いを込めた高付加価値マシンをぶつけてくるに違いない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがブックマンは、アプリケーションやプログラマーの開発経験など、ＰＣ上に築き上げられたさまざまな資産を引き込むことを狙ってあえてこの道を選んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの女中は兎もあれ、お朝には得心させて置かないと、照之助を引き込むのに都合が悪いと思ったからでございます。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は酔っぱらってしまって失礼だからもう引き込むよ」　と言い捨てて居間のほうへ行ってしまった。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局のところ、アメリカのソフトウエアを引き込む受け皿となりえたはずのＪＸは、ジュニアが惨敗を強いられる中で、せっかくの日英バイリンガルマシンとしての性格を生かせなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は君を擽つて河の中へ引き込むぞ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私も東京に行きたいんですが、どうも一度田舎に引き込むと駄目ですな。",
              "citation": {
                "source": "帰途",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑う時にはいつもいつも頭を左の肩の上にのせて、手の甲で口を押える様にして、ハッハッハッと絶れぎれに息を引き込む様に笑った。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵、まじめな一番がすむと、装束や持ち物も、稍、壊れた風で出て来て、前の舞を極めて早間にくり返し、世話式とでも謂つた風に舞ひ和らげ、おどけぶりを変へて、勿論、時間も早くきりあげて、引き込むのです。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きた烏賊か、蝦を餌として鈎につけ三十尋から六、七十尋の深い海底へ下してやると、三、四百匁から、六、七百匁の中鯛、一貫目から二貫目以上もある大鯛が、グイと引き込む。",
              "citation": {
                "source": "葵原夫人の鯛釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手が白い飛沫をあげて荒瀬になる肩の少し緩やかなところへ囮鮎を引き込むと、直ぐむずむずときた。",
              "citation": {
                "source": "弟子自慢",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "車を引き込むので土間は広いのですが、ただ二間のようですから、引子はどこへ寝かすのかと聞きましたら、「二階です」といいます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二間の竿に、二尺の道糸をつけ、落ち込みに餌を下げると、文句なしにグイと引き込む。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前には、いろいろの雑草の花が、はげしい日光を浴びながら咲いて、ちょうや、はちが飛び集まっているのがながめられましたけれど、ここだけは、まったく日が陰って、広い野を越えて吹いてくる風は、汗の引き込むほど涼しかったのでした。",
              "citation": {
                "source": "曠野",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌などを車で引き込むと、すぐ向うの方で、それが処理されている様子である。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "合圖がかゝると女は素早く窓を閉めて奧へ引き込む。",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその中へ、山小屋から電灯線を引き込むと、それで立派な低温の研究室が出来る。",
              "citation": {
                "source": "大雪山二題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女に見られた男は、誰でもただじろりやられただけで、ぞっと襟もとから恋風を引き込む。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽が出ると引き込むだけの差で、こう心に連続がなくなっては不思議なくらい自分で自分が当にならなくなる。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしにこっちが引き込むと、突然変なところへ強い力を見せた。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手は窓の框に引っ掛けて躰を支え、少し躰を浮かせるようにして左足を地袋の上へ引き込む。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミズムは容易に皮相化そうとするジャーナリズムを牽制して之を基本的な労作に向わしめ、ジャーナリズムは容易に停滞に陥ろうとするアカデミズムを刺戟して之を時代への関心に引き込むことが出来る筈である。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミーは容易に皮相化そうとするジャーナリズムを好意的に牽制して之を多少とも基本的な労作に向かわしめ、ジャーナリズムは又容易に停滞に陥ろうとするアカデミーを親和的に刺激して之を時代への関心に引き込む。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その取り込みはめんどうだが、浅いところのキスは引きが強く、二回、三回ぐらい、水ぎわから水底へ引き込む。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学の歴史も、作家そのものが文学思潮的に稚くて、わからず知らなかった時代（例えば明治初期）と、作家の努力が作品と現実が引き込む必然からどうよけようかという点に払われる時代とは大変な相異ですね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリストフを危険な親昵に引き込むのは、ユーディットのやり方一つだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことを「愛情の問題」において作者が念頭に置かない一般の情勢であったこと、それらが私たちの心をまじめな感想にひきこむのである。",
              "citation": {
                "source": "新しい一夫一婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
