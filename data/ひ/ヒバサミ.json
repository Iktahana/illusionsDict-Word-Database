        "examples": {
          "standard": [
            {
              "text": "燃えさかる暖炉から薪を動かすため、長い火ばさみを使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "キャンプファイヤーで、火ばさみを使って燃えカスを整理した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "囲炉裏端で、祖母が火ばさみで炭をくべている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "或は箒木、或は火ばさみに跨り、そしてマリバスは揚鍋の柄に乘つて出ていつた。",
              "citation": {
                "source": "サバトの門立",
                "author": "DEPART POUR LE SABBAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何も苦痛を与えてやろうとしたわけではないので、ほんの軽くとらえただけだったが、それでも男は、Ｋに二本の指ではなく、真っ赤な火ばさみでつかまれたように、悲鳴をあげた。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "すみのほうには、火ばさみと、木べらがあり、紡車は、腰かけの上にあがっています。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "火ばさみでたたきますと、そのうちの一つが下に落ちました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
