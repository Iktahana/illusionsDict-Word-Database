        "examples": {
          "standard": [
            {
              "text": "お祭りの夜、子供たちはみんな光る棒を持って楽しそうに踊っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コンサート会場で、ファンが色とりどりの光る棒を振っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "停電時に備えて、非常用持ち出し袋に光る棒を入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "近来電気の応用が盛んになるにつれて色々の事に炭を使う、白熱電灯の細い線も炭、アーク灯の中の光る棒も炭である、電話機の受話口の中の最も要用なものは炭でこしらえた丸薬のようなものである。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに光る棒が下方から伸びあがってくる。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
