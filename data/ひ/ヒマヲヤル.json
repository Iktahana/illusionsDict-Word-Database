    "definitions": [
      {
        "index": 1,
        "gloss": "to dismiss (an employee)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "亡者宿の主翁は一両の金と、女に暇をやる証拠の書類を小八に渡した。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし表向きに暇をやることはならぬ、兄の遺骨を郷里へ送る途中で仏寺に参詣し、または親戚のもとへ立ち寄ることは苦しからずというのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした乾児達の健気な働きと、自分に対する心持とを見た忠次は、その中の二三人を引き止めて他の多くに暇をやることが、どうしても気がすすまなかった。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れて居るだらうから、早く寝ろといふ代りに、彼等は、田舎から来て見物したからう、今晩だけ暇をやるから遊んで来いといふ風に言つて呉れた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十四日（金曜）晴　風強　きみを、明日にかけて暇をやる。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は好きだが――いいや、女だって、祇園の妓に暇をやるのに、紙屑をすてるようだった。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは明日にも店のものに、暇をやる事に決心をした。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に、親類のように親しくなる人が三人や四人は出来るよ」「勝見に暇をやることはいけなくって？",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが個展を前にひかえてこのいそがしいのに、はっきりした理由もなくおはるに暇をやるのは馬鹿げていた。",
              "citation": {
                "source": "入梅",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度芸者に出るか、そうでなければ以前からも大分金を使ったらしい洋服の若い奴が、俺の代りに這入込んで、俺のしたようにお千代を自由勝手にするに違いない、と思うと慶三はいくら腹が立っても、腹立ちまぎれに滅多に暇をやることは出来ない。",
              "citation": {
                "source": "夏すがた",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾に囲った今更になっては実のところ唯一人以前のお客が入込んだからとて、腹立まぎれに綺麗さっぱりと暇をやる勇気はない。",
              "citation": {
                "source": "夏すがた",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶三はその夜すごすごと家へ帰るが否や、お千代の許へ簡単に暇をやる旨を書き送った。",
              "citation": {
                "source": "夏すがた",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "重吉は種子が生きている時分に雇入れた小女に暇をやる。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、いけなかったときに、暇をやることにしてください。",
              "citation": {
                "source": "人の身の上",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "今すぐここで暇をやるから、どこへでも行っておしまい」「ははは。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "たつた十五ぢやお前の年の半分だ」「あつしが貰はうなんて言やしまん、――それから、番頭の幸七は思ふ仔細あつて、その儘暇をやる、――主人は素知らぬ顏をして居ても、番頭がうんと取込んで居ることを知つて居たんですね。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "權三は泣く",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も其方に暇をやるとは言はぬぞ」　丹之丞は驚きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "支配人の佐吉さんは六郎さんには一番の苦手ですが、これは奉公人ですから、いざとなれば暇をやる術もあります」　爺やは意氣込みました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "路地の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もその方に暇をやるとは言わぬぞ」　丹之丞は驚きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "支配人の佐吉さんは六郎さんには一番の苦手ですが、これは奉公人ですから、いざとなれば暇をやる術もあります」　爺やは意気込みました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "路地の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「序にもう一つ伺ひますが、下女のお崎を今日限り暇をやるといふのは本當でせうか」　平次は話題を變えて、さり氣なくお崎のことに觸れて行きます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "江戸の夜光石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして代りの女中が来ないので、この女に暇をやることができないでいるうちに、あの凶事が持ち上ってしまった。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は」「いつでも、暇をやるから、帰るがいい。",
              "citation": {
                "source": "野槌の百",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時でも暇をやると――日頃さう言つて居るくらゐだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "屠蘇の杯",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今夜わたしは長い旅に出るから、おまえたちみんな暇をやる。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "召使たち全部には朝八時まで一晩の休暇をやることにしたから、お前にもその休暇をやる」「ハイ！",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "時刻はおそくなったが、正月の暇をやるからと云って、子供の土産でも買ってゆくようにと、幾らかを紙に包んで渡した。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝川幸之進平友正　こちらから主君に暇をやるという意味、またあと書として、山陽道を上って立退くから追手を向けるなら相手をする、決して逃げも隠れもしないと書いてあった。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしい、暇をくれと申すなら暇をやる。",
              "citation": {
                "source": "蕗問答",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、王さまには、思いきってひまをやるだけの勇気もありませんでした。",
              "citation": {
                "source": "いさましい　ちびの仕立屋さん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
