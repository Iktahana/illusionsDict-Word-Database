[
  {
    "uuid": "87eb6d93-fb0e-5ead-a5d7-294c1fae6084",
    "entry": "悲鳴",
    "reading": {
      "primary": "ひめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
