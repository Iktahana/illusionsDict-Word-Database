  },
  {
    "uuid": "f8375a44-920f-5181-94b4-3f1bba744741",
    "entry": "非命",
    "reading": {
      "primary": "ひめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unnatural or untimely death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一瞬よ、――光よ、水脈よ、楽の音よ――酒のキユラソオ、接吻の非命の快楽、毒水の火のわななきよ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝死後、頼家、実朝が相次いで非命に斃れ、鎌倉幕府の命運｜将に傾むかんとするが如き情勢を示した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「非命」の論の立つ所以で、ここは又儒家と岐れる。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "在るが故に慶ぶべきか、亡きが故に悼むべきか、在る者は積憂の中に活き、亡き者は非命の下に殪る。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて劫初の昔より、かくて無数の歳月を、慈悲悔恨の弛無く、修羅の戦酣に、げにも非命と殺戮と、なじかは、さまで好もしき、噫、永遠のすまうどよ、噫、怨念のはらからよ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて劫初の昔より、かくて無數の歳月を、慈悲悔恨の弛無く、修羅の戰酣に、げにも非命と殺戮と、なじかは、さまで好もしき、噫、永遠のすまうどよ、噫、怨念のはらからよ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍事には關羽・張飛・趙雲があつたが、關羽や張飛は早く非命に斃れ、趙雲一人は生存したが、之も久しからずして世を辭し、その以後には名ある大將は殆ど存在せぬ。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし又強いて脱そうとすれば、如何なる政治的天才も忽ち非命に仆れる外はない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌三十五年六月二十一日午後、伊庭想太郎と云ふ剣客の為に星は市会議場に非命の最期を遂げた。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし又強いて脱さうとすれば、如何なる政治的天才も忽ち非命に仆れる外はない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の福島の夏祭りの夜に非命の最期をとげた植松菖助なぞは御関所番の重職ながらに膝をまげて、生前にはよく養父のところへ金子の調達を頼みに来たものだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して当時その苦衷を了せられずして、遂に非命に死す。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ非命の死にも、運不運によってさまざまなニュアンスがあることがわかる。",
              "citation": {
                "source": "淪落の皇女の覚書",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる非命薄運の人に対して、唯物論者のごとき霊魂の滅亡を説くも、なんらの効力なく、ただますます失望に失望を重ねしむるばかりであります。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで非命に斃れた、かの実朝公なども、今はこの樹に憑って、守護に当って居られる……。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　非命の死と罪悪――地の世界には、週期的に争闘が起るものであるが、霊的眼光を以てこれを考察すれば、畢竟それは善悪の霊と霊との争闘である。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に『非命の死と罪悪』の一節は、正に本章の圧巻で、再思三考に値する。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "即此説に從へばアイオラの祭は、父を慕ひて自殺したエリゴーネを慰め、併せて其父のイカリオスの非命に死した靈をも和めることになるが、乙の説によるとイカリオスを殺したのは餘人ならず其女エリゴーネで、彼女は其親殺しの罪を悔いて縊死したのだ。",
              "citation": {
                "source": "鞦韆考",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる土倉の中には命よりも金銭を惜む輩もあって、刃を執って一揆等と渡り合い、夫婦共に非命の最期を遂げたという話もある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北越雪譜初編巻之上　終北越雪譜初編　巻之中越後塩沢　　鈴木牧之　　編撰江戸　　　　京山人百樹　刪定○　雪頽人に災す　我住魚沼郡の内にて雪頽の為に非命の死をなしたる事、其村の人のはなしをこゝに記す。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆人かくて身を起し、水師の中に驅け走り、陣に火煙を吹き揚げて糧食ひとしく喫去り、やがて應護の神靈に衆人おのおの牲を上げ、　400非命の戰死、惡戰の苦惱の救ひ祈り請ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカイアの非命決定せらる。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて光輪めぐり行き天の眞中を過ぐる時、クロニーオーン黄金の＊秤取り出し其中に、駿馬を御するトロイアと黄銅鎧ふアカイアの　70運を――すべてに懸り來る死の運命を投じ入れ、秤の眞中手に取ればアカイア非命の運沈み、運傾きて慘憺と大地の上に垂れさがり、之に反してトロイアの運は高くも天のぼる。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚なるかな凶運を逃れて敵の舟よりし、風凄じきイーリオン都城をさして揚々と、戰車戰馬を引きかへす譽得べきに非りき、　115その事あるに先だちてヂュウカリオーンのすぐれし子、＊イドメニュウスの槍により彼は非命に斃れたり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユウケーノール（其父は豫言巧みの＊ポリュイドス、富みて勇あり、コリントス郷を住居となせるもの）非命を遂に逃れずと悟りて船に乘り來る、　665故は老いたるポリュイドス屡※彼に陳じ曰ふ、惡き病を身に受けて其邸中に身まかるか、若くはアカイア水軍のそばにトロイア軍勢に殺さるべしと。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかく陳ずる勇將を死の暗影は掩ひ去る、肢體はなれて彼の魂非命を嘆じ傷みつゝ、　855青春及び剛勇を捨て冥王のもとに飛ぶ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "息を引取る敵將にかくと叫びぬヘクトール、『パトロクロスよ、何故に我に非命を豫言する？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』脚神速のアキリュウス、慨然として答へ曰ふ、『＊非命に逝ける愛友を救はん事の叶はねば、願はく、ただちに我れ死せむ――友は故郷に遠ざかり、その逆運を防ぐべき我が救助なく斃されぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐれし勇士、父とする、われは神女の生むところ、しかも死滅と非命とは我にも遂に來らんず、　110そは曙か、黄昏か、はた日中か、われ知らず、あるもの我に手向ひて鋭槍飛ばしわれ討たむ、あるひは絃を離れ來る＊勁箭われの命絶たむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "單に幽靈が出るといふだけの話ならば、馬鹿とも臆病とも叱つても笑つても濟むが、問題が斯う面倒になつて兄が離縁の掛合ひめいた使に來るやうでは、小幡も眞面目になつてこの幽靈問題を取扱はなければならないことになつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
