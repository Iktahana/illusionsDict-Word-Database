    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shriek",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ううむ、ううむ、と大袈裟に唸りながら、めちや苦茶に鎌を振りまはして、時々、あいたたたた、などと聞えよがしの悲鳴を擧げ、ただもう自分がこのやうに苦心慘憺してゐるといふところを兎に見てもらひたげの樣子で、縱横無盡に荒れ狂ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが親愛なる而して甚だ純眞ならざる三十七歳の男性、狸君の悲鳴である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふくろの方では、水を飲ませといてから殴るのであるから、充分に思ひやりのある処置と信じてゐるのだらうが、殴られる子供の側になつて考へると、何のために、母親が自分を殴るのか、見当がつかないものだから、その抗議として、死にもの狂ひに、あらん限りの悲鳴を上げるのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その家の庭に咲き誇った夕顔をせせりに来る蛾の群が時々この芳紀｜二八の花嫁をからかいに来る、その度に花嫁がたまぎるような悲鳴を上げてこわがるので、息子思いの父親はその次の年から断然夕顔の裁培を中止したという実例があるくらいである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といふ恐ろしい女の悲鳴と、驚くべき異常の騷動とが、夏の白晝の物倦い情景を一變させた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時妾はふと、夜陰の無花果の木の下に潜む、黒衣の人間の険悪な顔を姿見に認めて、恐ろしい悲鳴をあげました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にナタリーの悲鳴が爆発して彼女の頬に紅色の液体がながれていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然レムブルグが悲鳴をあげて廊下に飛出す、米良はバルコニに駈け上ると暈れた空気に蒼白めた闘争に窶れた同志の死体が沈むのを見た。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女の顔が廃艦のような色にかわると、ポール商会に金属的な悲鳴が聞こえた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　午後五時すぎに田村英介氏の部屋の卓上電話が、ジャバの女の快楽のときの悲鳴に似たときのこえをあげる。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃を悪るくする者、下痢する者など方々で悲鳴をあげた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻を殴られた豚は悲鳴を上げ、野良を気狂いのように跳ねまわった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神經の興奮し切つてゐるお道は迚も安らかに眠られさうもなかつたが、なんにも知らない幼い娘はやがてすやすやと寢ついたかと思ふと、忽ち針で眼球でも突かれたやうにけたゝましい悲鳴をあげた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その悲鳴を聞きつけて、内から大勢が駈け出してみたが、薄暗い灯ともし頃で、そこらに物の影もみえなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は、悲鳴をあげ、罵った。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "于の悲鳴と、小山の噛みつける声がも一度した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮え湯をあびせられたような悲鳴が聞えて来た。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "通訳は、小屋のかげから、悲鳴や叫喚や、銃声がごったかえしに入りまじって聞えて来る方をおずおず見やった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くワイワイ騒いでる群集（五、六カット程で）カメラ近寄ってその人垣の中から悲鳴が聞える。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきほどの客のように抓って見たところで、ごく稀にしか悲鳴を発しないのである。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛まれるや否や、その下らない奴は、直ちに悲鳴をあげた。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲鳴は最も微かなところからはじまる。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような夜に沖で死んだ人々の魂が風に乗り波に漂うて来て悲鳴を上げるかと、さきの燐火の話を思い出し、しっかりと夜衣の袖の中に潜む。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "声が悲鳴に近くなり、真黒い顔が蒼黒くなってくる。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどなく、きゃんきゃん悲鳴を挙げて敗退した。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "グワンと、こぶしで頬を殴られ、田島は、ぎゃっという甚だ奇怪な悲鳴を挙げた。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キヌ子に殴られ、ぎゃっという奇妙な悲鳴を挙げても、田島は、しかし、そのキヌ子の怪力を逆に利用する術を発見した。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "單に幽靈が出るといふだけの話ならば、馬鹿とも臆病とも叱つても笑つても濟むが、問題が斯う面倒になつて兄が離縁の掛合ひめいた使に來るやうでは、小幡も眞面目になつてこの幽靈問題を取扱はなければならないことになつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か送ってきましたか」「ええ赤い魚の粕漬なんですがね」「じゃひめいちでしょう」　三四郎はつまらんものを送ったものだと思った。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし野々宮君はかのひめいちについていろいろな事を質問した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
