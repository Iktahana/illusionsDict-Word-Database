    "definitions": [
      {
        "index": 1,
        "gloss": "to turn over",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "屋上ではせんたく物を朝風に翻すおかみさんたちの群れもある。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰を陽に翻すのじゃ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は人の葬を送って墓穴に臨んだ時、遺族の少年男女の優しい手が、浄い赭土をぼろぼろと穴の中に翻すのを見て、地下の客がいかにも軟な暖な感を作すであろうと思ったことがある。",
              "citation": {
                "source": "鴎外漁史とは誰ぞ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに渺たる河内の一郷士正成が敢然立って義旗を翻すに至った動機には、実に純粋なものがあるのだ。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋏をあげて翻すと切られた葉のかたまりはバラバラに砕けて横に飛び散った。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、若い検事はもはや自分の意見を翻すわけにいかなかった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イル、カワリエル、セルヱンテ」又「チチスベオ」、今侍奉紳士と翻す。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐにきいきいと轆轤の軋る音、ざっざっと水を翻す音がする。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "口をあいて活動やどんちよう芝居を覯てゐる方が、何うも僕には、つまり端的で、おもしろかつたのだが、彼女の美しさを可成りに僕も認めてゐたゝめに、その不気嫌な顔に出遇ふのを怕れて、どうやら雑誌などを翻すようになつたのだ。",
              "citation": {
                "source": "「尾花」を読みて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空に乱れた戦闘機の群の木の葉と散り、鳶と舞ふては翼を翻す戦ひや、花々しい軍艦の進水式などを拝観すると、生涯の夢をさゝげて放浪の旅にさ迷った、かの即興詩人の作者の言葉などが、ゆくりなくも思ひ出されたりするのである。",
              "citation": {
                "source": "喧嘩咄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節をたとへて金樽緑酒とも云へるものならば、おそらく街々の角なみに「艦隊入港」の歓迎旗を翻す真夏の微風に、天地も陶然として凱歌を挙げるひとときに止めを刺すと申すべきであらう。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅の間隙でも生ずれば――そこに彼等は自由を望んで反旗を翻すことは火を見るよりも明かなことではありませんか。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "天空を飛翻する鳶の如く悠々と「大車輪」の業を見せて、するりと手を離したかと見ると、砂地に近いところで伸々とした宙返りを打つた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ろうと思っている葉子の下心をおぼろげながら見て取って、それを翻す事はできないとあきらめていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子がもし木村であったら、どうしておめおめ米国｜三界にい続けて、遠くから葉子の心を翻す手段を講ずるようなのんきなまねがして済ましていられよう。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代精神といふものは、大きなことをするものではあるが、根本から言つて見ると、大海の上に掀翻する波濤のやうなものである。",
              "citation": {
                "source": "現代と旋廻軸",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙を翻すまいと思つて我慢してゐるのに、その涙が頬の上を伝はつて流れた。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねがね、市九郎の強剛なる意志を知りぬいている周囲の人々は、彼の決心を翻すべき由もないのを知った。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前言を翻すのは男子の恥辱だと心得ている。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いかに困ればといって、素志を翻すわけには行かぬ。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "牙彫りを排し木彫りに固執したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「左う来りや、斯う逃げて――」　彼は潜航艇の真似などをして、飛鳥の如く駒を翻すので、私は唇を噛んで追跡にかゝつてゐるうちに、「さあ、何うだ、思ひ知つたか！",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢中で飛び出した私は月あかりを浴びてまつしぐらに駆け出した私の馬車の上で、白鳥が翼を翻す凄まじさでメイ子が打ち狂うてゐる光景を認めた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "高踏派の壮麗体を訳すに当りて、多く所謂七五調を基としたる詩形を用ゐ、象徴派の幽婉体を翻するに多少の変格を敢てしたるは、その各の原調に適合せしめむが為なり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、手に手に半月刀を翻す一団の荒武者が阿修羅の如く猛り立つて魚の腹を裂き、氷塊を詰め込み、見る間に魚の山をとり崩して行く鮮やかさなどは観る者に息もつかせない花々しさである。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　宮子は身を翻すように、ひらりと盆栽の棕櫚を廻っていくと、甲谷はまた山口の方へ向き返った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後二時の海辺の部屋の明るさ――外国雑誌の大きいページを翻す音と、弾機のジジジジほぐれる音が折々するだけであった。",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "運河の岸まで歩いて来ると、潮気のある風が海から吹いて来て、二人の着物の裾を翻す。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬から、腮から、耳の下を頸に掛けて、障ったら、指に軽い抗抵をなして窪みそうな、※色の肌の見えているのと、ペエジを翻す手の一つ一つの指の節に、抉ったような窪みの附いているのとの上を、純一の不安な目は往反している。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬川の鉄橋を渡り牛蒡や甘藍が青白い葉の裏をひるがえす畑の間の細い道を通りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをどう斯う云うのは恩恵深き自然に対して正しく叛旗をひるがえすものである。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
