    "definitions": [
      {
        "index": 1,
        "gloss": "cold (to the touch)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひと浴び冷やっこいところを浴びてきなよ」「ちぇッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、望みどおり殺してやるから、ちょっとこっちに首を出しなよ」　いいつつえり髪を捕えて、そこの縁側へひきずっていくやいなや、やにわにじゃあじゃあとくみたての冷やっこいところを、少年の首から頭へ浴びせかけましたものでしたから、まことに春先ののぼせ引き下げにはこれこそ天下一品の適薬です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきの手裏剣少年じゃねえが、少し逆上しているようだから、冷やっこいところを二、三杯見舞ってやろうか」「いいえ、けっこうです、けっこうです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "餉台は奥の間へ持って行かれたし、母が先生の傍へつききりなので彼は台所の畳の上で独人あてがわれた冷やっこい方の御飯をよそって食べ始めた。",
              "citation": {
                "source": "火",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷やっこい汗が額を流れた。",
              "citation": {
                "source": "反逆",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶器ってえな冷やっこい物ばかりじゃねえぞ、恋女房の肌みてえに、暖かいものの筈なんだ？",
              "citation": {
                "source": "増長天王",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎天に響く「氷やい氷」、蜜柑箱に仕入れた少々の氷を後生大事、「ところ天やてんや」と真鍮のお椀へ突いてくれる心天売り、これも声だけは冷やっこい。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、しばらくは茫然と眸をひらいて白痴のような口を開いていたが、何か、冷やっこいものが、額から顔へかけて、たらたらと流れているのに気づいて、「血……血だッ……」掌で、彼は顔をこすった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おらあ、そんな冷やっこい手に握られたくねえ、な、なぜ、ご一新となったならば、飛んで来て、手を握ってくれなかった。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水はまだ、雪解をもつかと思われるほど冷やっこい。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――李逵は竹籠を這い出し、そこらの冷やっこい岩肌を撫でまわした。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……たれだ……」　と万太郎は驚いて、目をふさがれた冷やっこい手へ、自分の手を重ねて軽く身をもがく。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまるで試験官のようなひやっこいはっきりした心地で女の心を見とおすように傍にひかえてひややかに笑って居る。",
              "citation": {
                "source": "砂丘",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひやっこい、かたいお手々だよ！",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エエひやっこいアイスクリン！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから明治三、四年までは、夏氷などいうものは滅多に飲まれない、町では「ひやっこい／＼」といって、水を売ったものです。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはズット昔からある水売りで、売子は白地の浴衣、水玉の藍模様かなんかで、十字の襷掛け、荷の軒には風鈴が吊ってあって、チリン／＼の間に「ひやっこい／＼」という威勢の好いのです。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは「ひやっこい／＼」の水売で、処々にあった水茶屋というのは別なもの、今の待合です。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花さんは、無頓着に生えぎわの汗を肩へかけた手拭でふきながら、「そりゃ吸わないわね、だって、のましてる乳でなけりゃ、ひやっこいもん、いやがるよウ」　ひろ子にはその夜のことが忘られなかった。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田沢さんの血はひやっこい。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひやっこい石の上につっぷして――私は或る芝居の舞台面の中に自分を加えて考えるほどセンチメンタルな感情になって居る。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事によらずやむを得ず習練させられて巧になったと云うものはまことにそれ自身にとってはかなしいひやっこい気持がするものである。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡山のステーションから吹雪に皮膚を荒されるのをこらえて淋しい一本道を車にゆられて行った時私は逃亡者の様なわびしいひやっこい気持になった。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいでもやっぱり涙をこぼすワ」　私の一方の何でもをひやっこい目で見て居る心がささやいた。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＨさんとＭさんと母さん」　私はなげつける様にどなって、ひやっこいたたみの上につっぷした。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてそんなひやっこい様子をして居るの、何か腹の立つ事があるの」「腹の立つ事なんか一つもありゃしない、うれしくってうれしくってしようがないんだから……」　彼の女は斯う云って又歌のつづきを云って居た。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お龍はかちほこった様に眉をかるく動かしてダラリと下げて居る男の両手を自分のひやっこい雌へびの肌ざわりの様な手の中に入れた。",
              "citation": {
                "source": "お女郎蜘蛛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しらんかおをして居る女のよこがおを見ながらソッとにぎりしめるとひやっこいするどい頭の髄まですき通す様な痛さがあたえられた。",
              "citation": {
                "source": "お女郎蜘蛛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見込んだ蛇は死んでも蛙をのむと云う事は昔からきまってる……」　女は前よりも一層ひやっこい眼色をして云った。",
              "citation": {
                "source": "お女郎蜘蛛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御龍のなめらかなひやっこいきめの間から段々自分の命を短くする毒気が立って居るらしく思われそのまっくらな森の様な気のする髪の中には蛇が沢山住んで居やしまいかと男は思った。",
              "citation": {
                "source": "お女郎蜘蛛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
