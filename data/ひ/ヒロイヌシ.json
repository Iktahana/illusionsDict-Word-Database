    "definitions": [
      {
        "index": 1,
        "gloss": "finder (of lost property)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
