[
  {
    "uuid": "233045ac-7426-568e-b899-444f7a7f33a6",
    "entry": "飛燕",
    "reading": {
      "primary": "ひえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
