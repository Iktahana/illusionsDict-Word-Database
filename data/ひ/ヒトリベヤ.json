        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "實際、俺は一人部屋にゐると君ちやんのことばかりを考へてゐる。",
              "citation": {
                "source": "書翰",
                "author": "大正十一年九月（推定）　小島勗宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さだ子さんだつて僕がそんな事をしないと信じているから、僕を一人部屋に残して行つたのでしよう」　検事といえども容赦はしない、出方によつてうんと云いこめてくれようというようすが見えた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "信子は素早く電灯を点け、かおると二人で廊下へ出ようとすると、蒲団を被って慄えていた蔦江は一人部屋に残されるのが恐ろしさに、歯を鳴らしながらその後に続いた。",
              "citation": {
                "source": "宝石の序曲",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから夕方近くになるまで一人部屋で書いて居ました。",
              "citation": {
                "source": "無題（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けげんな顔をしていたら運転手が私の方を振り返って「一人部屋が欲しいのか、相宿でもいいのか」と普通の英語に翻訳してくれた。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、小病室があいていて一人を希望すれば、伸子がそうしているように、室代を倍払うだけで一人部屋にもなった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、ケンシントンのホテルの五階に、寄宿舎の一人部屋のような狭い室をもっていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は大きくてきれいで、部屋は一人部屋だ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺は一度マイクを握ると離さない方だからなあ」　三人が楽しく歓談している一方、俊文は一人部屋の隅で『ヤングジャンプ』を黙々と読み耽っていた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って、一人部屋にとじこもり、気を静めていると、やがて、ボーイが来客を知らせた。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋は、地下一階の一号室、一人部屋、こゝは、はじめてなり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが留守のうちに一人部屋へ入ってふて寝をしていた奴がある。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
