    "definitions": [
      {
        "index": 1,
        "gloss": "barely miss (meeting someone, catching a train, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――爺さんは、当夜植木｜店のお薬師様の縁日に出た序に、孫が好きだ、と草餅の風呂敷包を首に背負って、病中ながらかねて抱主のお孝が好いた、雛芥子の早咲、念入に土鉢ながら育てたのを丁寧に両手に抱いて、来て、途中頭の上の火事に慌てながら、驚破や見舞、と駆込んで、台所口へ廻ったのが、赤熊と一足違い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵粮だって餡麺麭を捻込んで、石滝の奥へ、今の前橋を渡ったんだ、ちょうど一足違い位なもんだ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、六が砂まぶれの脚絆をすじりもじって、別荘の門を通ったのと、一足違いに、彼は庭下駄で、小石を綺麗に敷詰めた、間々に、濃いと薄いと、すぐって緋色なのが、やや曇って咲く、松葉牡丹の花を拾って、その別荘の表の木戸を街道へぶらりと出た。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に一足違いで、トムは既に樹根に倒れていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙と一足違いに、意外にも安二郎が迎えに来た。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙と一足違いに意外にも安二郎が迎えに来た。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足違いでしたよ」　という返事である。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母様も貴方の弟思いの御心持にスッカリ同情されましたが、一足違いで貴方を取逃がされたのを非常に残念がり、八方に部下を飛ばして貴方の行衛を探しておられると、両国橋の方向へ行かれる貴方を発見した者が、電話で知らせた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人「残念なことしやはりましたなァ、ほん一足違いだした」節子「その仏像を買った方のお名前御存知ですの？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足違いで密閉を免れたお品は、ホッとして無意識であたりを見廻わしたが、この時はじめて恐ろしい事態が呑みこめた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が飛出すと、一足違いに、ドッと梁が落ちて、金色の火の子が、パッと花火のように散った。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは幾重にも詫びるが、今朝は別して師匠の事が気に掛って何んだか一刻半刻を争うように思われたので……一足違いで師の臨終に逢えないような気がしたので、それで姉御の帰りをも待たず、飛出したような次第。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足違いだったよ」「会場へなんかまだ行くものか、昨日は風邪をひいて臥ていたし、今日は出掛ようとしているところへ、あいつが来たんで……」　柏の言葉が終らないうちに、けたたましく呼鈴が鳴った。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが恨みをいいたかった人は、一足違いで、死骸になってしまったらしいですよ。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「助けてやろうと我々二人、すぐに後を追っかけたが、一足違いで間に合わなかった」「嘘だ嘘だ！",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩息で頭髪を振り乱し、遠くを駈けて来たものらしく、はいると同時にべたりとなったのを見ると、あの、一足違いで、三味線堀の里好の家から逃げられてしまった人魚のお蔦だ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一足違いでねえ君、残念な事をしたよ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海で東亜同文書院の向かいの中華そば屋に雇われ、当時名声をはせた島貫兵太夫のチベット入りの一行に加わろうとし、一足違いで間に合わず、残念でならなかったこともあった。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は手探りで、まず地下室の鍵を開け、階段を降りかけると、下から低い声で、「一足違いでした。",
              "citation": {
                "source": "恐怖の幻兵団員",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の一足違いで三十分も新聞を読ませられる。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「好いお天気が続きますなあ」　と一足違いの爺さんは唯一つ残っていた椅子を占領していた。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張り一足違いだったけれど、此方は一世紀前から待っているような顔をしてやった。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、一足違いだったよ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ妻と妹とが一足違いに帰ってきた。",
              "citation": {
                "source": "秋風と母",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足違いで、僕が飛び込んだのです。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく一足違いだ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "屈強な若党のひとりが、それと一足違いに登って来て、いきなり、「この女め」　と、お袖を捉えて叩き伏せた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウウム、一足違いで惜しいことをいたした」「何しろうつつの病人ですから、何処へ連れて行かれようと、今じゃあお粂の意志のままで、御当人にも分らなかったでしょう」「してその行った先は？",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一足違いに前へ行く多市の影へ、何か、不意にキラリッと青光りの一｜閃！",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘは骨董商のチャンフーからいまでていった、船員風の男が、ひとあしちがいで、黄金メダルを買っていったということを聞くと、急いで、そのあとをつけていったんだ。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
