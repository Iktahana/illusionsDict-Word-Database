[
  {
    "uuid": "8384da32-5072-57db-b20f-2fdf50acaa38",
    "entry": "悲憤慷慨",
    "reading": {
      "primary": "ひふんこうがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
