    "definitions": [
      {
        "index": 1,
        "gloss": "sleeping alone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『ちょっと入らして頂戴な、蚊で堪らないから』と言いさま、やっと一人寝の蚊帳の中に入って来たのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……藤屋には私の声が聞かしたくない、叔父が一人寝てござるんだ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一つ家に一人寝て観る草に月（「愚を守る」初版本）",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "お滝はその年十三になる新一を奥の室へ寝かして、己は主翁の室となっている表座敷で一人寝ていたが、寝心地が好いのでぐっすり睡っていたところで、不思議な感触がするので吃驚して飛び起きた。",
              "citation": {
                "source": "狐の手帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜更けに、男が一人寝た部屋を、庭から覗込んで、窓を開けて、と言う婦はあるまい。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな形で女が一人寝ていた。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏の愛は月日とともに深くなっていくのであるが、最愛の夫人が一人京に残っていて、今の女の関係をいろいろに想像すれば恨めしい心が動くことであろうと思われる苦しさから、浜の館のほうで一人寝をする夜のほうが多かった。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その友人は自分の好みからわざわざ一人寝の携帯天幕を作らせて持って居る。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その夜、勝平は自分一人寝室に入ってからも、若い妻のすべてが、彼の眼にも、鼻にも、耳にもこびり付いて離れなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手にゐたときには、よくそんな事を思つて一人寝床の中で泣いてゐたりした事がいくどもあつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "清三は一円五十銭で、一人寝の綿｜蚊帳を買って来て、机をその中に入れて、ランプを台の上にのせて外に出して、その中で毎夜遅くまで書を読んだ。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その夜、勝平は自分一人寝室に入つてからも、若い妻のすべてが、彼の眼にも、鼻にも、耳にもこびり付いて離れなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は、あまり好い天気だから僕を途中まで送つておいでと命じたのに、吾家の宵張りの連中は誰一人寝言でさへも返答しないよ、僕は飯も喰はずに出かけて来たので途中で君の家に寄つてパンを一片とビールを一本と……」「鯵があつたらう、今朝の――」　鴎丸に寄つたのは事実だつたが、途中まで送つておいで！",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何アに、米さんは一人寝せときゃええさ、なア米さん、独人り寝てるわのう。",
              "citation": {
                "source": "火",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "品の好くて見栄えのしない法衣をまとった二人の若僧と、枯れた様な僧が一人寝台のすぐそばに居る。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがここに逃げることを相談している一団の次の部屋では、内膜炎で舞台半ばに倒れたままいまだに起き上れない波子が一人寝ているのだ。",
              "citation": {
                "source": "時間",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人寝の折、きんは真夜中に眼が覚めると、娘時代からの男の数を指でひそかに折り数えてみた。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前読んだ事のある伊勢物語風に、昔男ありけりと云う思い出をいっぱい心に溜めているせいか、きんは一人寝の寝床のなかで、うつらうつらと昔の男の事を考えるのは愉しみであった。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お座敷には赤んぼが一人寝かされたまま、だれもそばには居ませんでした。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃の夜長に一人寝てゐてつくづく考へて見ると、全く別世界にゐるやうな感が致します。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその時通り庭の土間を上つた所に立つて、汗を拭き／＼、何気なく奥の間の方へ眼をやつたが、手前の部屋との界の葭障子を透して、其処に女が一人寝てゐるのが見えた。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを斥けて、自分の欲する儘に振舞ふこと、例へば何処かの部屋の隅にでも一人寝るといふ様な我儘を言ふだけの親しみをそれらの人達に対して持つて居なかつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃寺の庭は広々とした芝生で、少年が一人寝転んで呆んやり空を見ていた。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人寝の折、きんは真夜中に眼が覚めると、娘時代からの男の数を指でひそかに折り数へてみた。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前読んだ事のある伊勢物語風に、昔男ありけりと云ふ思ひ出をいつぱい心に溜めてゐるせゐか、きんは一人寝の寝床のなかで、うつらうつらと昔の男の事を考へるのは愉しみであつた。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前も知らなければ、職業も判らないまゝで、別れるひとなのだと思ふにつけ、ゆき子は一人寝の、狭いベッドへ這入つてからも、その男の事が始終｜瞼を離れなかつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り寝はちちと啼くなる小鼠に家鳴りどよもし夜あけぬるかな　偶※君の留守に一人寝をする夜など、鼠が天井でちいちい鳴くのが、家鳴り鳴動するやうに耳を刺戟し、おちおち眠ることもならず、遂に夜が明けてしまふ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人寐て雁を聴くかな味わろき宵の食事の幾時の後　一人寝の所在なさに聴き耳を立てると雁の声が聴こえて来た。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が一人寝ているくらいのかさになった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（柳里恭「ひとりね」）　少し耳がいたい。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
