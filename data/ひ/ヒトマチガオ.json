    "definitions": [
      {
        "index": 1,
        "gloss": "looking like one is waiting for someone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
