    "definitions": [
      {
        "index": 1,
        "gloss": "irritability (of an organ, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
