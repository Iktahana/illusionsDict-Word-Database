    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to have a cramp",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒さで体が引きつれるように感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長時間同じ姿勢でいたので、首の筋肉が引きつれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あまりの痛みに、全身が引きつれるようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だが、右足に、深手を負って、少し、引きつれる小太郎は、右手へ、敵を受ける不利を考えて、じりっと、背を、川の方へ引いた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も一緒に笑いながら口のはたが変な工合に引きつれるような気がして私はなき笑をして居た。",
              "citation": {
                "source": "日記",
                "author": "一九一三年（大正二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらばわが手並のほど見せてくれんと、仲兼は五十余騎を引きつれると群がる敵陣の中へ割って入った。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この戦いにまぎれて高倉宮は奈良へ逃げられたにちがいない、今なら間に合う、と選りすぐった精兵四、五百騎を引きつれると馬に鞭をあて、鐙をけって疾駆した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた彼は自分の力をあまり過小視して、援兵を引きつれることが必要だと思った。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャン・ヴァルジャンは鞅をとらえて駄馬を引きつれるように、鞅縛りにした繩を取って、ジャヴェルを引き立て、自分のうしろに引き連れながら、居酒屋の外に出た。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スチームの通った汽車から降りた時、顔がひきつれるような気持でしたな。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
