        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は子供たちを動物園に引き連れて行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行中は、たくさんの荷物を引き連れて移動するのが大変だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "社長は秘書を引き連れて会議室に入ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アッハハハお帰りなされ」　いい捨て部下を引き連れると町の方へ引き上げて行った。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スチームの通った汽車から降りた時、顔がひきつれるような気持でしたな。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
