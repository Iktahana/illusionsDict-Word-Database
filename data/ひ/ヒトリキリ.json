    "definitions": [
      {
        "index": 1,
        "gloss": "all on one's own",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで、彼は不安さうに夢のなかに逃れようとし、園のなかに、まつ暗な園のなかに、一人きりで立つてゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして自分がずつと遠くに、一人きりでゐて、武裝してゐるのだとよいのに、と思つた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランゲナウ人は、ただ一人きり敵陣深く入り込んでしまつてゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、自分の部屋に一人きりでゐる時に、私は翌日貴方に言ふべき言葉を一生懸命に用意するのです。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そこから農民を扱って文学的に実を結んだのは佐左木俊郎一人きりであった。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、支那兵が一人きりなら、それを片づけるのは訳のない仕事だ。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが窓から　一人きり。",
              "citation": {
                "source": "お月さまを",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のおぬいの身の上として、天にも地にも頼むものは母一人きりなのだ、その母がおぬいをまったく見忘れている夢らしかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と　いひきかせて、仔牛を　一人きり　送つて　やりました。",
              "citation": {
                "source": "仔牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なくなった父の、としとってからの子ですから、父も、ずいぶん可愛がって、私も、大事な一人きりの子ですし、なんでもあの子の好きなようにさせて育てましたが、それが、あの子の為に、よくなかったようでした。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ文六ちゃんは、一人きりの子供で、甘えん坊でした。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、文六ちゃんは樽屋の清六さんの一人きりの大事な坊ちゃんで、甘えん坊だからです。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一番冒頭に書して、確かお辻と云ふ女、「アラ水沢さん嬉しいこと御一人きり。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえ、兄が一緒ですから……でも大雪の夜なぞは、町から道が絶えますと、こゝに私一人きりで、五日も六日も暮しますよ。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お寂しいでせうね、こんな處にお一人きり。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさん一人きりなんでしょうかしら。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、兄が一緒ですから……でも大雪の夜なぞは、町から道が絶えますと、ここに私一人きりで、五日も六日も暮しますよ。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんに万一のことがあると、わたしは天にも地にも、ほんとうに一人きりになってしまうのですから。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、私を一人きりにさせて下さい」　この最後の言葉は、まるで彼の上にのしかかっていた圧迫を、急に全くはねのけたかのように、激しい勢いで彼の口からとび出した。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　でも、おやゆび姫は行ってしまって野ネズミを一人きりにすれば、とっても悲しむにちがいない、とわかっていました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お寂しいでしょうね、こんな処にお一人きり。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「――処がその婦は一人きりで、薄いお納戸色の帯に、幽な裾模様が、すッと蘆の葉のように映りました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすぐぎょっとしてあたりを見回したが、われに返って自分｜一人きりなのに安堵して、いそいそと着物を着かえ始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんはいつも一人きり此處に居るのかと訊くと、夜は年中一人だが、晝になると女房と娘とが麓から登つて來るのだといひながら、ほんの隱居仕事に斯んな事をしてゐるが、馴れてしまへば結局この方が氣樂でいいと笑つてゐる。",
              "citation": {
                "source": "比叡山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都｜界隈から大阪奈良初瀬とりの汽船に乘り込んで漸く初めて一人きりの旅の身になつた樣な心安さを感じて、われ知らずほつかりとしてゐた所である。",
              "citation": {
                "source": "熊野奈智山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんはいつも一人きり此処にいるのか、ときくと、夜は年中一人だが、昼になると麓から女房と娘とが登って来る、と言いながら、ほんの隠居｜為事に斯んなことをして居るが馴れて見れば結局この方が気楽でいいと笑っている。",
              "citation": {
                "source": "青年僧と叡山の老爺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお客があるのに、自分を一人きりにするのは、どう考えてもひどいと思った。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気中は私が死んだ夢を見たりして、夜中に一人きりの広い家の中で、お念仏申していたなど云いますの。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……言葉をかえて申しますれば、あなた様と御一緒の運命に結びつけられる女と申しますのは、この世にたった私一人きりなのではないかしら……と、毎日毎日心の底の奥深いところで、おそれ迷いながら、今日まで生き永らえておりましたことで御座いました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、一人きりになって、静かに振返ってみると、川田はとにかく憂欝であった。",
              "citation": {
                "source": "舌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
