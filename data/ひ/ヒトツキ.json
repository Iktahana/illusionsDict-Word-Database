    "definitions": [
      {
        "index": 1,
        "gloss": "one month",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "陳述、私は明治四十年四月の末に生れ、その年十一月三日に郷里を母と母方の祖母と三人で立ち、四日乗船、六日大連着、そこで父に出迎へられ、（その父も今は亡き数、――安らかなれかし！",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮は、十一月の曇つた午後に、風が往来の砂塵を巻きあげてゐるやうなもんだと、僕の、心はともかく肉体は、左様に今はや観念してゐるやうな具合だ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "千九百十七年十一月九日郷里にて萩原朔太郎",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十月十一月太宰治　　　　　（上）　御坂で苦慮のこと　甲州御坂峠の頂上に在る茶店の二階を借りて、長篇小説すこしづつ書きすすめて、九月、十月、十一月、三つきめに、やつと、茶店のをばさん、娘さん、と世間話こだはらず語り合へるくらゐに、馴れた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん茶店の人たちも、あのお客は、ただ口が重いだけで、別段に惡だくみのある者でないといふことが判つた樣子で、お客さんのお嫁さんになるひと仕合せですね、世話が燒けなくて、とをばさんに冗談言はれて、私は苦笑して、やつと打ち解けて來たころには、はや十一月、峠の寒氣、堪へがたくなつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十一月も終り頃だつたが、私が女の新しき家の玄関に例のワレ物の包みを置いた時、新しき男は茶色のドテラを着て、極端に俯いて次の間で新聞を読んでゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「山繭」一九二六年十一月号）",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月ばかりの間に幾多の改革が行はれた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十四年の十一月に死んだ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仝年十一月、諸井三郎を訪ぬ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十一年一月著者郷愁の詩人｜与謝蕪村蕪村の俳句について君あしたに去りぬゆうべの心｜千々に何ぞ遥かなる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川沖觀艦式　　昭和四年一月、品川沖に觀艦式を見る。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年一月『ホトトギス』）",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治三十二年十一月『ホトトギス』）",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十二年一月『ホトトギス』）",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十年一月、渋柿）",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年一月『実験治療』）",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年一月『婦人公論』）（『蒸発皿』への追記）この記事が縁となって、重兵衛さんの次男の亀さんからの消息に接することが出来た。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年一月『アララギ』）",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年一月『ホトトギス』）",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治三十四年十一月）",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も急く旅でもなしいっそ人力で五十三次も面白かろうと、トウトウそれと極ってからかれこれ一月の果を車の上、両親の膝の上にかわるがわる載せられて面白いやら可笑しいやらの旅をした事がある。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ことし十一月入院することにきまつた。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説だつたら、また、言ひたいだけのことは言ひ切つて在るのだから、一月ぐらゐ、店頭で叫びつづけても、惡びれない覺悟もできてゐるが、どうも、朝顏有感は、一ヶ月、店頭で呟きつづける勇氣は無い。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜など、燭を秉って、湯殿へ通うと、空には露が一杯で、十一月頃の冷たさが、ひしひしと肌に迫る、そうして凸凹のないところは、ないくらいな山の中にも、梓川が、静かな平坦な大道路となって、森の中を幅びろくのしている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に一月元旦に降ったからとて、必ずしも初雪とはいわず、前年の九月や十月頃に降った方のを、かえって初雪と称する。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月三日の明治節の国民運動会の日である。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "：入力者注　主に外字の説明や、傍点の位置の指定（例）（大正十五年一月）-------------------------------------------------------　松戸与三はセメントあけをやっていた。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらあ、一月娑婆に居りあ、お前さんなんかが、十年暮してるよりか、もっと、世間に通じちまうんだからね。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつき経ち、ふたつき経って、そろそろ百日目がちかくなって来ても、私たちはだまって見ていなければいけません。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
