        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人には遠く離れた広間の真中に、しんとして寝ているような心持である。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "首里の名主といはれて居る謝源は大広間の上座にうちくつろいで座つて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間の四方の障子はスツカリ取り払はれ、大洋を拭ふて来る海風は無数の蝋燭の焔をユラユラさせながら気持ちよく皆の肌に入つて行くのであつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大広間の酔ぱらつて居る家来も流石に王のこの様子に気づいたのか急にヒツソリとなつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「密謀の集会」「大広間の評定」「道中の行列」これには大抵同じ土手や昭和国道がつかわれる。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）左衛門宅の大広間　なりひら小僧が中央に座している。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間になりひら悠々と坐している。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）左衛門宅大広間の次の室には　ふんぞり七兵衛の率いる捕方が合図如何と待ちかまえる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間では、　なりひらと対座した左衛門。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝元の広間で　左衛門となりひら小僧。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝広間　飯を食っているなりひら小僧。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝広間では　なりひらが悠々立ち上る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　此処のお殿様　近頃はやりの　仇討病患者――Ｓ＝城中広間　お殿様。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ　斯くて――Ｓ＝大広間　殿様の御座へ、殿様がお座りになる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれも贋ものの飛行機だったろうか――李鄭の後から僕は広間へついてあらわれると、僕は忽ち、無数の支那服の女に交ってチイク・ダンスを踊るタルタンの素足の踊姿を認めたんです。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大広間からは時々賑やかな朗らかな笑声が聞こえていた。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、何うぞ……」　廊下を二曲り、又半ばにして、椽続きの広間に、線香の煙の中に、白い壇が高く築かれて居た。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿はもと料理屋であったのを、改めて宿屋にしたそうで、二階の大広間と云うのは土地不相応に大きいものである。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階に客のない時は大広間の真中へ椅子を持出して、三十畳を一人で占領しながら海を見晴らす。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日の晩は雨でお流れになるかと思ったらみんな本館の大広間へ上がって夜ふけるまで踊り続けていた。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーリスがシャトーの玄関をはいってから、人けのない広間をうろつきまた駆け回る場面の伴奏も抑揚変化が割合によくできていて人を飽きさせない。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新噴水は大広間の床を大きく楕円形に掘り窪めて、その底に据えられてあった。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "村会議員の家は立派なもので五十畳の広間にはあかりがぞろっとともり正面には銀屏風が立ってそこに二人は座らされました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とてもその人数の入るような広間は、恐らくニュウファウンドランド全島にもなかったでしょう。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばけもの世界長は、もう大広間の正面に座って待っています。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夕日は言に色を添え、「鶏が銀に輝やいて、日の出の紅の漲るような、夜の雪の大広間、蒔絵の車がひとりでに廻るように、塗膳がずらりと並んで、細工場でも、運八美術閣だから立派なのよ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　一時、何となく陰々とした広間が、ぱッとまた明くなりますとね、鶏がくるりと目を覚まして、莞爾笑ったように見えたんですって。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――考えても――上り端には萌黄と赤と上草履をずらりと揃えて、廊下の奥の大広間には洋琴を備えつけた館と思え――彼奴が風体。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　幹事は陽気に軽く手を拍って、「そのお話を、是非一つ、会場の広間で願いましょう。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……広間が暗くなっていますね、……最う会をはじめました。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
