[
  {
    "uuid": "c87bc140-9c8d-5f0a-a332-9f1081d9a453",
    "entry": "人里離れた",
    "reading": {
      "primary": "ひとざとはなれた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
      ],
