    "definitions": [
      {
        "index": 1,
        "gloss": "waiting for one hundred years for the waters of the Yellow River to clear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、これまた私の観察によれば、わが国の風潮の悲しむべき一面であるが、これをいつまでも民間の努力にのみ委ねておくことは、百年河清を待つにひとしいことを先に私は宣言せざるを得ぬのである。",
              "citation": {
                "source": "演劇統制の重点",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのいづれにも半分づゝ賛成であるが、その目的を達するためには、これまで行はれてゐたやうな方法では百年河清をまつに等しいといふことを断言する。",
              "citation": {
                "source": "風俗の非道徳性",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "余輩はわが学の進歩を促すうえにおいて、百年河清を俟つの態度を採るべくあまりに短気である。",
              "citation": {
                "source": "遺物・遺蹟と歴史研究",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって無邪気・無智識の児童をまねて、百年河清を待つ訳には行かぬ。",
              "citation": {
                "source": "遺物・遺蹟と歴史研究",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "百年河清を待つには恐れ入りました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
