    "definitions": [
      {
        "index": 1,
        "gloss": "playing with fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "許嫁気取りの男への反撥心と、好奇心がさせた火遊びに過ぎない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この火遊び的な娘にも、それ相応の恋があるのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、雨後の冷気が、ムラ気と火遊びを鎮めるに充分だった――と。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「言葉」を弄ぶといふことは、一つの文化的遊戯には違ひないが、これは火遊びに類するもので、怪我をすることがある。",
              "citation": {
                "source": "言葉の魅力［第一稿］",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は叔母さんの家に戻り、ちょっとした恋愛火遊びめいたこともあったらしいが、それも立ち消え、彼女は加津美の女中になってしまった。",
              "citation": {
                "source": "孤独者の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが火遊びをしたのではあるまいかと考える、その底には、本人にも火遊びの要素があるのだ。",
              "citation": {
                "source": "無法者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと、ちょっとした火遊びみたいな軽い気持だったのが、次第に深みへはまり込んだのである。",
              "citation": {
                "source": "怒りの虫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "火遊びなのかまたは真剣なのか、あの二人の真意はわれわれにはよく分らない、という説があった。",
              "citation": {
                "source": "庶民生活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "条件が揃ってる安全な火遊びであった。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、火遊びといえるほどの積極的な意志もなく、自然の誘惑への無抵抗な陥没だった。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれは畢竟、愛情の問題ではなく、富裕な美しい未亡人の火遊びに過ぎなかったようだ。",
              "citation": {
                "source": "聖女人像",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "火遊びといふ言葉がある。",
              "citation": {
                "source": "木々の精、谷の精",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦前、鎌倉の浮気な女たちが火遊びに現をぬかした伝説の男の手は、心やすくも親しそうにも、そう、やすやすと握れるものではなかった。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ちのないことを確信して、火遊びができるといふのは、こいつは精神の鍛へられてゐる証拠ですからね……」「ほう……君は、何時の間にそんな精神を鍛へたんだ？",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "火遊びの遊びが過ぎて殺されたのさ」「――」「お袋を待たして見世物へ入つた定吉は、あの照手姫を見るとムラ／＼とお駒を思ひ出したのさ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人形の誘惑",
                "note": "青空文庫"
              }
            },
            {
              "text": "火遊びの遊びが過ぎて殺されたのさ」「…………」「お袋を待たして見世物へ入った定吉は、あの照手姫を見るとムラムラとお駒を思い出したのさ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人形の誘惑",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの巷にあれすさんでいる火遊びの嵐はどうだ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "セックスというものは、私はやっぱり一度、相めぐりあった、そして火遊びでなく、夫婦というような形において、この人生を歩み出したからには、等しく相手も同じようなですね、楽しみ、一つになり、明るく、法の恵みにあって、終わりを本当に老の後まで全うすることを、行者宿報設女犯というんじゃないかと思うんです。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が、佐治を相手にして火遊びをする女だとは思わないけれど、用心に若くはなし、敢てこの第一の理由を、あけすけにいって置く次第だ。",
              "citation": {
                "source": "偽悪病患者",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "異性が異性に対する好奇心は、危険な火遊びの第一歩だ。",
              "citation": {
                "source": "偽悪病患者",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀次郎は、疾くからここの仲間であり、若い命を、女、酒、ばくち、悪事の火遊びにすり減らしていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とばかり、都のうちにふみとどまって、都じゅうを馬糞と馬蠅の巷となし、大刀、長柄を横たえ歩き、何か、事件こそ起れと、物騒な放言や火遊びを持ち廻っている状だった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
