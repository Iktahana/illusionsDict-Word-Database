          "literary": [
            {
              "text": "また行燈に入れるものに「ひょうそく」というものを用いた。",
              "citation": {
                "source": "亡び行く江戸趣味",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "同居の妹がひょうそうかなにかできて働けないからである。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子が十六になる前の冬、川辺みさ子は指を、ひょうそうで痛めた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "激しい練習のために、ひょうそうになったのだそうだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽と歌にだけ様々な少女の気もちの表現を托していた伸子は、川辺みさ子がひょうそうで指をいためた間に、急速に小説にひかれて行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
