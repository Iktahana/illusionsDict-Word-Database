        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と見ると、ぬめりとした長い面が、およそ一尺ばかり、左右へ、いぶりを振って、ひゅっひゅっと水を捌いて、真横に私たちの方へ切って来る。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて加市君が、ひゅっといきをすいこんで、「ふえーん」とうまくなきだした。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍のほの白き日蓮上人、辻説法跡の塚が、ひゅっと私の視野に飛び込み、時われに利あらずという思いもつかぬ荒い言葉が、口をついて出て、おや？",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが不意に猟師は二人の背後に立ち上り、手に弓を取って満月の如く引きしぼり、光明の普賢菩薩に向って長い矢をひゅっと射た、すると矢は菩薩の胸に深く、羽根のところまでもつきささった。",
              "citation": {
                "source": "常識",
                "author": "COMMON SENSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思うと、四秒くらいでまたその色がひゅっと縮まって、もとの四つの島だけに戻り、それで映画が終るわけである。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つめたい風が汽車の窓からひゅっとはいってきました。",
              "citation": {
                "source": "母を尋ねて三千里",
                "author": "アミーチス",
                "note": "青空文庫"
              }
            },
            {
              "text": "」狩矢が、途端に二、三本、ひゅっと彼の耳のそばを唸って通った。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれも、弟かしら」　鞍の上から、伸び上がった時、耳のそばを、ひゅっと、へんな音が掠めた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ひゅっと鳴って伸びるとおもえばスッと引く。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真白い腕から、火の輪のような一閃が、玄蕃の横へひゅっと飛ぶ。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その片岡へ、無言のまま、ひゅっと長刀の薙ぎを伸ばして、源五が、あッと蒐り足を竦めたわずかな隙に、一学は、縁を躍って、ふたたび広庭の雪の中へ出ていた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの草むらから二筋三筋――ひゅっと、さなだ虫のような紐が、草を撫でて飛んで来たのである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゅっと、どこか天空で、弦を放たれた一矢の矢うなりがした。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに、悪来は、「来たかっ」　と、手に握っていた短剣の一本をひゅっと投げた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "孫策の顔へ、ひゅっと、一本の箭が立った。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
