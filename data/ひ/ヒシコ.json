    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese anchovy (Engraulis japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「生きながら直に打ちこむひしこ漬」「椋の実落ちる屋根くさるなり」なども全く同様な例である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理卓の上にはアンショア（ひしこの塩漬）の三枚におろしたのが昨日からオリーブ油に浸けられている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同ばんかた、わが言ひしことを、そくざにおいて、打ちけされけることあり。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌いかならむ年の日にかも毛の國の民の嘆きの止む時あらむひしこ漬足妣木の山を近みと。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝまでにひしこも來れ。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風の寒く吹くなべ竹籃にひしこ持ちて來とほき濱びゆ髪十月の末母の命によりて成田山にまうで毛綱を見て作れる歌并短歌母刀自の依しのまにま。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "フラア・マルチノがこの詞と、或る知人の戲に、アントニオはあやしき子なるかな、うみの母をば愛するやうなれど、外の女をばことごとく嫌ふと見ゆれば、あれをば、人となりて後僧にこそすべきなれ、といひしことあるとによりて、母上はわれに出家せしめむとおもひ給ひき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはその部屋をおとづれ、彼等と共に寺にて歌ひしことあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が惠によりてゆくりなき幸に逢ひしことよ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに戀せんなどとは、われ實に夢にだにおもひしことなし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その車の傍なる座をば、樂長にも許さず、吾友にも許さで、彼媼を伴ひしこそ、姫が心の清き證なれ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校にありしころ人の世途の難を説くを聞きては、或課題のむづかしき、或師匠の意地わるきなどに思ひ比べて、我も亦早く其味を知れりといひしことあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人々は謝肉祭の頃｜假粧して街頭を彷徨ひたりしが、こゝにさへ假粧して集ひしこそ可笑しけれ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "君既にをさなくして此都に居給ひきといへば、若しこゝの稚き子等と共に、「アラチエリ」の寺にて説教のまねし給ひしことあらずや。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時君は金の控鈕附きたる短き上衣を着たまひしこと今も忘れず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫は君が穉くて樂しき日を送り給ひしこそ羨ましけれといひて、憂をかくすやうなるさまなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は媼の詞につきて熟※おもふに、むかし母とマリウチアとに伴はれて、ネミ湖畔に花束作りし時、わが上を占ひしことあるは此媼なりしなるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を傷けて亡命せしこと、身を賊寨に托せしことより、怪しき媼の我を救ひしことまで、一も忌み避くることなかりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ逡巡して、否われは舞ふこと能はず、曾て舞ひしことなしと答ふれば、サンタ重ねて、家のあるじたる我身おん身に請はゞ奈何といふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど友は我を伴ひしことなく、我も亦獨り往かん心を生ずることなかりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしベルナルドオの我にいひしことあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "疇昔の日おん身が物思はしげに打沈みてのみ居給ひしとき、拙き身のそを慰め參らせばやとおもひしことあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランチエスカの君は我才を稱へ、我を呼びて詩人となし、醫師に我が拿破里の劇場に上りて、即興詩を歌ひしことを語り給ひしに、醫師驚きたる面持して、さてはかの謳者は此人なりしか、公衆の稱歎は尋常ならざりき、重ねて技を演じ給はゞ、世に名高き人ともなり給はんものをなどいへり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてある時端なく一の思想の浮び出づるに逢ひて、これと與に曾て聞ける歌、曾て聞ける韻語を憶ひ得給ひしことはあらずや。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃おん身の我を抱き給ひしこと、我が爲めに畫かきて賜はりしことをば、まだ忘れ侍らず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは姫に告げて、まことの海原は我脚底に又一の碧空を視る如しと云ひしに、姫は手を組み合せて、神の此世界を飾り給ひしことの極みなく奇しきをたゝへ給ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "颶風の勢少しく挫けたるとき、こゝに坐したる女子の、彼恢復せられたるエルザレム中の歌を歌ひ、耳を傾けて夫の聲のこれに應ずるや否やを覗ひしこと幾度ぞ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨見苦しき假住ひに御尋下され候時、我目を覆ひし面紗の忽ち落つるが如く、君の初より眞心もて我を愛し給ひしことを悟り候ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "只畜生と云ひ、外道と云ひしことだけは、度々明かに聞きしゆゑ忘れず。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふ着きたまひしことなれば、『ピナコテエク』、また美術会の画堂なども、まだ見玉はじ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
