    "definitions": [
      {
        "index": 1,
        "gloss": "using multiple simple paper masks to represent different emotions in a play (from the middle of the Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
