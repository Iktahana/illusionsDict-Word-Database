[
  {
    "uuid": "5c85e31f-64a7-5733-a846-462e068e7e57",
    "entry": "僻",
    "reading": {
      "primary": "ひが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接頭辞"
      ],
