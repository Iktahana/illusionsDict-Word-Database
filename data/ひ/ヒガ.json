      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "evil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "時には自分の珍しい是等の聴手は如何思ふことだらうと僻まれた、その訓辞の大体はかうだつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたいてい当選者は決まっているだろうと僻み根性を出して、傍観していたら、どうしたことか、私が最高点に当選していた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし少年の一点の僻みも屈託もない顔つきと行雲流水のような行動とは人々の心に何か気分を転換させ、生活に張気を起させる容易なものがあったらしい。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、第二期におけるごときハ行音は、遠僻の地の方言には今日でもまだ存している。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは無論作者に對する一｜種の僻見かも知れませんが、事實に於ては、私も氏の作品に強く心を惹かれ乍らも、どこかにまだ心持にぴつたり來ない點がないではありません。",
              "citation": {
                "source": "三作家に就ての感想",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、支那の僻陬の地の農民たちは、日清戦争があったことも、清が明に取ってかわったことも知らずに、しかし、軍隊の略奪には恐ろしく警戒して生きている、──こういうことは、支那の奥地に這入った者のよく見受けるところであるが、これも独歩は、将校のちょっとした上陸から発見して、それを伝えている。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の、大切な洋服を着た男は、糞に汚れた豚に僻易して二三歩あとすざりした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "憫むべし晩成先生、｜嚢中自有銭という身分ではないから、随分切詰めた懐でもって、物価の高くない地方、贅沢気味のない宿屋を渡りあるいて、また機会や因縁があれば、客を愛する豪家や心置ない山寺なぞをも手頼って、遂に福島県宮城県も出抜けて奥州の或｜辺僻の山中へ入ってしまった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋は早い奥州の或｜山間、何でも南部領とかで、大街道とは二日路も三日路も横へ折れ込んだ途方もない僻村の或寺を心ざして、その男は鶴の如くに※せた病躯を運んだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは僻見であり誤解である。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "緒論で断わってあるとおり、以上の所説は、特殊な歴史と環境とをもった一私人の一私見に過ぎないのであって、おそらく普遍性の少ない僻説であろうと思われる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういう僻説を少しも修飾することなしにそのままに記録するということが、かえって賢明なる本講座の読者にとってはまた特殊の興味があるかと思うので、なんら他を顧慮することなくして、年来の所見をきわめて露骨に、しかも無秩序に羅列したまでである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら、断片的な通俗科学的読み物は排斥すべきものだというような事を新聞紙上で論じた人が近ごろあったようであるが、あれは少し偏頗な僻論であると私には思われた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとどこかまたイギリスのノーザンバーランドへんの偏僻な片田舎の森や沼の間に生まれた夢物語であるような気もするのである。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はお店は休みだ、もう誰にも酒は売ってやらない、とひとりで僻んで、自転車に乗り、何処かへ行ってしまいました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり今日のお祭の騒ぎに、一人で僻んで反抗し、わざと汚いふだん着のままで、その薄暗い飲み屋で、酒をまずそうに飲んで居るのでありました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の間に於ける親子の關係に於ても、學校に於ける師弟の關係に於ても、社會生活に於ける成員としての關係に於ても、この僻見は容赦なく採用された。",
              "citation": {
                "source": "子供の世界",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人の僻見によつて、穢されない彼等の頭腦と感覺の中から、かつて發見されなかつたやうな幾多の思想や感情が湧き出るのに遭遇するだらう。",
              "citation": {
                "source": "子供の世界",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "學術に對する俗衆の僻見をこれほど見せつけられると、彼れは意地にも初一念を通さずには置けなかつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤児とある以上、多少、捻くれや僻みがあっても致し方はない。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は橋の傍のいかけ師の主人でもとは相当の家だったが、先代から微禄したのを私の家の勢力の為だと思い僻み、こんな悪苛めもするのである。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし少年の一点の僻みも屈托もない顔つきと行雲流水のような行動とは人々の心に何か気分を転換させ、生活に張気を起させる容易なものがあったらしい。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか思うたが、取次いだ小使どんが、やや暫時あって引返して、お目に掛ろう言わるる、通れ、とあって、廊下伝い方角を教わって、そしてそれから歩行き出したがね、――私は先年この岐阜県下ですわ、飛騨のある山家｜辺僻に勤務した事があって、深い谷陰、高い崖に煙草の密造をする奴を検べに行ったのじゃね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて、その岐阜県の僻土、辺鄙に居た頃じゃったね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれど、場所｜柄ゆえの僻耳で、今の時節に丑の刻参などは現にもない事と、聞き流しておったじゃが、何と先ず……この雌鬼を、夜叉を、眼前に見る事わい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "情無い、もう不具根性になったのか、僻も出て、我儘か知らぬが、くさくさするので飛んだことをした、悪く思わないでおくれ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山間の僻村、人皆｜淳朴で、休んだ大黒屋旅館も気持のいい家であった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山間の僻地の割には景気がいいらしい。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "亞尼に一人の息子があつて、極く放蕩無頼な男で、十｜幾年か前に家出をして、行衞不明になつたといふ事は兼て聞いて居りましたが、亞尼は、それをば常に口僻のやうに、斯う言つて居りました「私の忰は私の言ふ事を容かずに、十月の祟の日に家出をしたばかりに、海蛇に捕られてしまひました。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "海蛇に捕られたとは、眞に妙な事だと思つて居りましたが、それがよく隱語を使ふ伊太利人の僻で、其書面ではじめて分りましたよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
