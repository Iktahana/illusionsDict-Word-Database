        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いかなる犠牲を払っても、奴をひっ捕らえるのだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして牛丸君をひっとらえると、ちょっと用があるからきてくれ、生命には別条ないから心配いらない、しかしいうことをきかないと痛い目にあうぞ、といって、牛丸君を外へつれだしたという。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、ほそびきが、へんな動きかたをしたら、いきなりとびついて、ひっとらえるんだ。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明智さんがもう少し早く、このぬけ穴を発見してくれたら、塔をぬすみだした手下のやつも、ひっとらえることができたんだがなあ。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、三号バスをとりかこんで、あいつを、ひっとらえるんだッ！",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むろん、ひっとらえるのさ。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで、庭にいる刑事たちとも、うちあわせをして、あいつがやってきたら、ひっとらえる計画をたてます。",
              "citation": {
                "source": "夜光人間",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
