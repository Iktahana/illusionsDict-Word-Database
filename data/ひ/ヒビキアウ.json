        "examples": {
          "standard": [
            {
              "text": "オーケストラの各楽器が美しく響きあい、壮大な音楽を奏でた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "意見が響きあうことで、より良い解決策が生まれることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山彦のように、二つの声が空中で響きあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あ、あれは死んだ人たちの嘆きと僕たちの嘆きがひびきあうからだろうか。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "無恨の速度で憧れのように、祈りのように、静かに、素直に、無限のかなたで、ひびきあうため、結びつくため……。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
