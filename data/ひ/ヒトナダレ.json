        "examples": {
          "standard": [
            {
              "text": "ライブ会場では、興奮した観客の人雪崩（ひとなだれ）が発生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地震の際、避難しようとする人々の人雪崩（ひとなだれ）が起きた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「すごい人出だ！まるで人雪崩（ひとなだれ）みたいだ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "けさ、日比谷であたしが人雪崩の下敷になって、もう少しで押し殺されようとしたとき、あなたはあたしの上へ押し重なった人を、まるで狂気のようにはね除けて下すったんですってね。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「捕物だ」　兩國の橋へかけての眞晝の人雪崩。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "「捕物だ」　両国の橋へかけての真昼の人雪崩。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "夥しい提灯と燭台が、人雪崩と一緒に二十尺も下の水に落ちる有様は、まことに壮観と言ってもいい程だったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鬼の面",
                "note": "青空文庫"
              }
            }
          ]
        }
