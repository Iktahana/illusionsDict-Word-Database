    "definitions": [
      {
        "index": 1,
        "gloss": "mean",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然るに私の方では、何といふ卑劣な愚かしさだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとを平気でからかうのは、卑劣な心情の証拠だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今日の洋画家中唯一の浅井｜忠氏を除けばいずれも根性の卑劣な※の声を打消していった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "撲ぐられた男こそは生きる資格もない卑劣漢だ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして敵は平気で卑劣なことが出来る男だ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤毛は、卑劣である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘のうちでも卑劣な嘘だ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸はそれを聞いた時、木下藤吉郎の出世談と甲乙のないほど卑劣不愉快なものだと思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い所から下を見てあざわらふ、そんな卑劣な惡魔的な態度に安住すべきでない。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の不充實から來る倦怠を辛うじて逃げる卑劣な手段として、自分でも氣付かずに、何時の間にか我れから案じ出した苦肉の策が、所謂彼れの大望なるものではないか。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れ自身の他人に對する理解のなさ加減から考へると、他人の理解を期待すると云ふやうな事が卑劣極つた事に思はれた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時或人はかくばかり自然が美しく荘厳であるのにどうして人間はかくばかり醜く卑劣なのだと歎じ、そこに人類の救ひ得べからざる堕落を痛感するだらう。",
              "citation": {
                "source": "自然と人",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと眼に入つたのは、今、此船の責任を双肩に擔へる船長が、卑劣にも此時、舷燈の光朦朧たるほとりより、天に叫び、地に泣ける、幾百の乘組人をば此處に見捨てゝ、第三の端艇に乘移らんとする處。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』なんかと標題を置いて、君等の其時の擧動を賞讃するのを見るにつけても、實に斷膓の念に堪えなかつたです――何、あの卑劣なる船長等は如何したと問はるゝか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「血迷うな、誤解はどうでも構わないが、君は卑劣だよ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……使った金子に世の中が行詰って、自分で死ぬのは、間違いにしろ、勝手だが、死ぬのに一人死ねないで、未練にも相手の女を道づれにしようとして附絡うのは卑劣じゃあないか。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっと飲んで、うんと酔おうという、卑劣な癖が付いてるんだ、お察しものですぜ、ええ、親方。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、未練と、執着と、愚癡と、卑劣と、悪趣と、怨念と、もっと直截に申せば、狂乱があったのです。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまつさえ、乱暴とも狼藉とも申しようのない、未練と、執着と、愚癡と、卑劣と、悪趣と、怨念と、なおその上にほとんど狂乱だと申しました。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは今になってみると如何にも卑劣極まる考え方に違いないのだが、生れつき小心な上に病気のお蔭で一層卑屈になった根性で、どうにもならなかったのだ。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀木のように、虚栄のモダニティから、それを自称する者もあり、また自分のように、ただ非合法の匂いが気にいって、そこに坐り込んでいる者もあり、もしもこれらの実体が、マルキシズムの真の信奉者に見破られたら、堀木も自分も、烈火の如く怒られ、卑劣なる裏切者として、たちどころに追い払われた事でしょう。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女房の卑劣な亭主も、こう考えて来ると、あながち非難するにも及ばなくなったようであります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑劣漢の焼印を、自分で自分の額に押したのでした。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何物の卑劣にすら、何物の虚僞にすら、あへて高貴の寛容を示し得るやうな、一つの穩やかにして閑雅なる徳はないか。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝、毛蟲にも似たる卑劣漢。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは卑劣と思えるほど小器用で脇の下がこそばゆくなる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、卑劣です。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なんというはくじょうな、ひれつなやつらだ。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
