        "examples": {
          "standard": [
            {
              "text": "春先になると、庭の柊南天が小さな黄色い花を房状に咲かせ始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "柊南天の葉は冬になると赤く色づき、庭を鮮やかに彩ってくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "柊のようなトゲのある葉と南天のような実を持つことから、柊南天と名付けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その一つは藍、紫の実を垂らしたひいらぎなんてんの葉と茎とである。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
