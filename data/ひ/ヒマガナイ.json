[
  {
    "uuid": "82e82959-3b9a-5113-993b-5ed95ea65531",
    "entry": "暇がない",
    "reading": {
      "primary": "ひまがない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
