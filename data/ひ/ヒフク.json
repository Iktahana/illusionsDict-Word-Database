        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何ぞ下女に言ひふくめて、猫を殺して來らざりしぞと。",
              "citation": {
                "source": "猫征伐",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでも猶あの人の頬は引締つて、丁度内側から吸ひふくべでもかけたやうに、肉がこけて見える。",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、庭の、森達の方を指差して、何か悪事を相談した芝居の悪者のやうに、手の先で秘密を云ひふくめた。",
              "citation": {
                "source": "競馬の日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "住民を殺すまいと思ふと、つい敵を射ち損ひますから……」「だから、かういふ部落で宣撫をする時は、日本軍が攻めて来ても、決して支那兵と一緒に逃げてはいかんと云ひふくめておきます。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方がないから玉川関にいひふくめて迎へに行つて貰ふ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "正雄はそこへ近づかないやうに云ひふくめられてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんの二の舞ひをしないやうに、くれぐれも、そなたに、言ひふくめておかうと思つて……」「その方には、たうとう、お会ひにならなかつたのね？",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭ではやつとそこまで自分に云ひふくめはしたものの、一方、それを裏切る種々雑多な感情がつぎつぎに彼の胸をしめつけ、それを追ひのけるための努力は、まつたく無駄でさへあるやうに思はれた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
