[
  {
    "uuid": "7febf137-ec76-5be2-8520-3c66872d3471",
    "entry": "一粒種",
    "reading": {
      "primary": "ひとつぶだね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
