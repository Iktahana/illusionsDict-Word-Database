        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冷奴に紫蘇の実、白瓜の香の物で、私と取膳の飯を上ると、帯を緊め直して、（もう一度そこいらを。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "優しさよ、松蔭の清水、柳の井、音に雫に聲ありて、旅人に露を分てば、細瀧の心太、忽ち酢に浮かれて、饂飩、蒟蒻を嘲ける時、冷奴豆腐の蓼はじめて涼しく、爪紅なる蟹の群、納涼の水を打つて出づ。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の衛生論から云うと余り感心しないものであろうが、かの冷奴なるものは夏の食い物の大関である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょせんは湯豆腐を冷たくしたものに過ぎないが、冬の湯豆腐よりも夏の冷奴の方が感じがいい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯豆腐から受取る温か味よりも、冷奴から受取る涼し味の方が遥かに多い。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "樋口一葉女史の「にごり江」のうちにも、源七の家の夏のゆう飯に、冷奴に紫蘇の香たかく盛り出すという件りが書いてあって、その場の情景が浮き出していたように記憶している。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷奴の平民的なるに対して、貴族的なるは鰻の蒲焼である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡瓜は漬け物のほかに、胡瓜｜揉みという夏向きの旨い調理法がむかしから工夫されていて、かの冷奴と共に夏季の食膳の上には欠くべからざる民衆的の食い物となっている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹のたたき、あいなめの煮物、船で作った絹｜漉しの冷奴、大根の風呂吹き。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャパニーズ・プレーン・スープ・ウィズ・オイル・アップ Japanese Plain Soup with Oil-Up.コールド・ビーン・カスタード Cold Bean Custard.『日本風の透明スープ』はお清汁……『豆の冷いカスタード』は冷奴。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――炊きたての飯に熱い汁をかけて食ううまさ、肌ぬぎの茶漬け、青じその香をきかした冷奴、さらに釜底の狐色に焦げたところへ塩をふった握り飯など、品も作法もなくうまかった。",
              "citation": {
                "source": "泥棒と若殿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜｜冷奴ヲ食ベ過ギタノガ悪カッタト見エテ夜半ヨリ苦シミ出シ二三度下痢スル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷奴、鯛さし、鴨ロースに、幕の内といふのだから相当食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝豆、冷奴、とんかつ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この仮説を敷衍すれば、熱い酒に冷たい豆腐のひややっこ、アイスクリームの直後のホットカフェーの賞美されるのもやはり一種の涼味の享楽だという事になる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
