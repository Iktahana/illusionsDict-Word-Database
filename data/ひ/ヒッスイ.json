    "definitions": [
      {
        "index": 1,
        "gloss": "inevitable decline (decay, collapse, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
