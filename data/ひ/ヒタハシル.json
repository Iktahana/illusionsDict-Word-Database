        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "精神は闇の曠野をひた走る。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "降り来る火の粉、渦巻く煙り、それを開いて異風天狗、武器蔵の方へひた走る。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　駕籠の一団はひた走る。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十三　ひた走るひた走る七福神組！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芹沢の里の方へひた走る！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、黙ったままひた走る。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおも、ひた走るひた走る。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お粥なと一口下さりませ」「こっちこそ助けて貰いたいよ」　振り切って松吉はひた走る。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の精神史の中では、絶対の拒否の中にも宇宙が育ち、現実を、生を、虚無と死へ還元したときに、生の最頂点を一線にひた走る自我の歴史が初まる。",
              "citation": {
                "source": "宿命の CANDIDE",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色のどんよりした朝、そして雷雨の雲に追いつこうと西へひた走る雲、霧を帯にした山やま、濡れそぼった樹々――何もかもが補祭には、ぶざまな不興顔をしているように見えた。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで取りに行きますので」それから背後を振り返ったが、「あ、いけない、とっ捕まりそうだ」　二人は懸命にひた走る。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて三人、ひた走る！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒になった四人の男女、ひた走るひた走る御器所の森へ！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　森を廻って町の方へ、四人懸命にひた走る！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出た所が上前津通り、それを西へひた走る。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お仙先に立ってひた走る。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　声を掛け合ってひた走る。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "☆没落の足どりで　ダンスホールの　階段を下りる☆外の光りに飢えて　冷蔵庫の　馬鈴薯の芽は枯れた☆もう一度咲かねば出られぬ　網窓の花☆綿ほこりで腐った胸に　レールは村へ――　ひた走る◆九月号『詩精神』第一巻第八号川柳「洪水」鶴　彬花つけた稲へ増水の閘門あけっ放すダム！",
              "citation": {
                "source": "鶴彬全川柳",
                "author": "鶴彬",
                "note": "青空文庫"
              }
            }
          ]
        }
