    "definitions": [
      {
        "index": 1,
        "gloss": "hundred thunderclaps",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
