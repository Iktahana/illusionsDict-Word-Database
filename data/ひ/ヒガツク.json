    "definitions": [
      {
        "index": 1,
        "gloss": "to catch fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "禽の、朗かに囀ずる声は、峰から峰へと火がつくようである。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひょっとしてあの時の痩我慢を破裂させているのかもしれない」そんなことを思って聞いていると、その火がつくような泣声が、なにか悲しいもののように峻には思えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さも貴女と御新造さんが烟に捲れて赤い舌で嘗められていなさるようで、私あ身体へ火がつくようだ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしないといけないわけがあるからかえてくださいましな」　といおうとしたけれども、火がつくばかりに駅夫がせき立てるので、葉子は黙ったまま青年とならんで小刻みな足どりで、たった一つだけあいている改札口へと急いだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その時、殿との間に深い爭ひが起つてゐて――それもいつものとは違つて、窕子が昔親しくした大學のひとりの書生の許から手紙がやつて來て、むかしの心に火がつくまでには到らなかつたけれども此方からかへしの歌などを贈つたことを殿に知られて、『何故それがわるいのです……。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の兒が泣いて泣いて何うしてもだまらないので、一度背中から下して、乳を含ませて見たりなどしたが、矢張りそりかえって火がつくように烈しく泣いた。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は火がつくようにまた便通を訴えた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷もつに火がつくので水をかける、そのあまりをかい出すもの、舟をこぐもの分業で命からがらにげ出したのだ。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火がつくと、直ぐまた宿を飛び出し、その北一條通りを右へ一町ばかり、巖本天聲の家を過ぎ、左りへ曲つて、道廳構内の白楊樹下を、今は、もう新らしい感じを起さないと考へながら通り拔け、それから北四條一丁目の氷峰の社へ行つて見た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはもちろん火がつくところから自然と連想を生じたのであろう。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを何んとかうまく優しく云へばいゝものをねえ、そおれや、あのおかみさんの方が火がつく程怒つてどなり散らしてゐるんですもの。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そう思う、と女の目に火がつくのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈火がつくや否や、彼はそろ／＼と振り向いて、見るのが怖いと思つてゐるその物を探した。",
              "citation": {
                "source": "醫師と旅行鞄の話",
                "author": "ロバート・ルイス・スティーヴンソン",
                "note": "青空文庫"
              }
            },
            {
              "text": "火縄式のライターは、炭火のように火がつくだけで、ろうそくのように焔が出ない。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "相反する妙なことを喋ったり行ったりする人物で、彼はオモムロにタバコをとりだして、湯気の中へ差込んだが、湯気から火がつくという話はきいた事がないね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "町ではチラチラ燈火がつく。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏にならない中は一向気が付かずにいたが、この頃の暑さにいずこの家も窓と云わず、勝手の戸口と云わず、いささかでも風の這入りそうな処は皆明けられるだけ明け放ってしまったので、夜になって燈火がつくと障子に映る島田の影位の事ではない。",
              "citation": {
                "source": "夏すがた",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ火がつくと、なかなかきえない。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに火がつくと、それこそたいへんだ。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、食堂に燈火がつく。",
              "citation": {
                "source": "顔",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチをする音がして、ランプに火がつくと、へやの中はちょうど春の晩のように、ほんのりと青くいろどられて、その光は、窓から、遠く海の方へ流れてゆきました。",
              "citation": {
                "source": "青いランプ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘ッ子を口説くにも、外交談判と同じように、時々、世間話などもして打ちとけたフリをしなければならないから、善鬼は懐中から蝋マッチという秘蔵の品物をとりだしてみせて、これはチャメロス大使からもらった舶来のポスポル（マッチのこと）であるが、日本のポスポルとちがって、どこでこすッても火がつく。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば水素中に空気がだんだん余計に雑ざって来ると、ある割合のところで火がつく。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前もって赤熱しておいたシャベルの上にドロップを１つ置くとすぐに火がつくが、炎を出して炭になることはなく、火がついてほんの半分ほと弱い炎をだして後に石のように硬い物質を残し、ロジンジ（菱形）の形はそのままであった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速水素を吹き出させて、その水素の噴流と空気とが巧い割合に混じていそうな所を狙って、変圧器だの百ボルトの交流だのの小さい火花をとばせてみると面白い程よく火がつくのであった。",
              "citation": {
                "source": "球皮事件",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まごまごするとお蔵に火がつく。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "咸臨丸受取",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば水素中に空気がだんだん余計に雑って来ると、或る割合のところで火がつく。",
              "citation": {
                "source": "寺田先生の追憶",
                "author": "――大学卒業前後の思い出――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひねくれるのは勝手だが、火元が近いから、お尻に火がつく。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "間……その閉ったドアの奥から、火がつくように敏子が泣き出した声が聞える。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかやるまいと思いますが、やれァ自分の身体に火がつくから」「まさか、やるまい。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
