    "definitions": [
      {
        "index": 1,
        "gloss": "to let oneself be persuaded (by)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大凧が充分に風をはらんで揚がる時は若者の二人や三人は引きずられるくらいの強い牽引力をもっている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう自分のとは分ちがたくなつてしまつてゐる、彼の苦惱に引きずられるがままになりながら。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言ったように四十四年に再び引きずられるように上京して、私の近所の下宿から学校へ通っていたが、翌年にそれでもどうにか卒業した。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は見舞客たちに見られないように、台所のほうから、こっそりはいって、離れの病室へ行きかけて、ふと「常居」の隣りの「小間」をのぞいて、そこに次兄がひとり坐っているのを見つけ、こわいものに引きずられるように、するすると傍へ行って坐った。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の男達も、無抵抗に引きずられるようにするするついて走り込んだ。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女も男の力に引きずられるようにして後から従いて往った。",
              "citation": {
                "source": "料理番と婢の姿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見て順作も引きずられるように跟いて往った。",
              "citation": {
                "source": "藍瓶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彭は引きずられるように老婆の後から随いて行った。",
              "citation": {
                "source": "荷花公主",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜陽はふらふらと起って侍女に引きずられるように紅い瓔瑜の処へ往った。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翁も引きずられるように跟いて往った。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本語がタコである」との批判を甘受し続ける代わり世界に添い続けたマックは、サードパーティとユーザーに引きずられる形ながら、ソフトウエアからの日本語処理の技術を積み重ねて世界に開いた確固たる日本の窓となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "音吉の手にかゝるとあんなに他易く上り付いたが、わたしが此度は音吉に代つて糸をとり、合図を待つて、音吉のやうにその場で糸をたぐらうとする態の巧者を真似ようとしても、凧は地を舐めて引きずられるばかりで、いつかな空へなどのしたこともなく、忽ち此方の両腕ばかりが櫂のやうにしびれるだけだつた。",
              "citation": {
                "source": "山峡の凧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はとにかく恐ろしい崕のきわまで来てしまった事を、そしてほとんど無反省で、本能に引きずられるようにして、その中に飛び込んだ事を思わないわけには行かなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく躊躇していたその子供は、やがて引きずられるように配達車の所までやって来た。",
              "citation": {
                "source": "卑怯者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　村川は、引きずられるような重くるしい心持で電話口に出た。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "心と心とが戦い、情と意とが争い、理想と欲望とがからみ合う間にも、体はある大きな力に引きずられるように先へ先へと進んだ。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズルズルズルズルと引きずられる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、それでは、わしもいっしょに行くから、ついて来い」　法信は引きずられるようにして和尚の部屋にはいった。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と半ば引きずられるようにして祭壇へ連れていかれ、気が付くと小声で教え込まれたことを呟き、訳の分からぬ事を誓わされたあげく、独身女性アイリーン・アドラーと独身男性ゴドフリィ・ノートンの結婚の立会人になってしまった。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかおかしいぞと思って二つの指で挟んでみて、おやおやと引きずられるままにそれをまさぐっていたかと思うと、「なあんだ！",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがゲーム用ＬＳＩが巻き起こしたブームに引きずられるように、しだいに雑誌の構成はテレビゲーム中心に移り、そのことがいっそう『Ｉ／Ｏ』の売れ行きを伸ばした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がなぜコンピューターに興味を持ち、引きずられるようにハードウエアとソフトウエアにのめり込んできたのか、竹松はこれまで考えたこともなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "で私は、来る日も来る日も、何か理由のわからぬ力に引きずられる心地で叔父の寺へばかりへばりついていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋の興味に甚だしく引きずられる小説や、筋の興味が殆んどない小説などは、こういう読み方をするのもよいかも知れない。",
              "citation": {
                "source": "ふざけた読書",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶像に引きずられることだ。",
              "citation": {
                "source": "偶像に就ての雑感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "引きずられるのが悪いのだ。",
              "citation": {
                "source": "偶像に就ての雑感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、どうぞ此方へ」　四人の芸妓がすらりと褄をとり、いい立姿を見せて階段をのぼるのに引きずられるように、はじめは入ることを渋っていたもの共も一斉に二階にあがった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は酔ってもいたが、何かしら引きずられる真剣なものを彼のうちに感じて、云われる通りに引廻されてしまったのであった。",
              "citation": {
                "source": "田舎者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの痛ましき生をまじまじ見守りながら、それでも引きずられるようにして生きてゆかねばならなかった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは引きずられるように日々を生きてゆくもいい。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
