[
  {
    "uuid": "85d03842-7a8d-52c9-86a6-e12a5b378dc7",
    "entry": "比類のない",
    "reading": {
      "primary": "ひるいのない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
