      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "luminous body (e.g. of a shooting star)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これに聯関して、やはり土佐で古老から聞いたことであるが、暴風の風力が最も劇烈な場合には空中を光り物が飛行する、それを「ひだつ（火竜？",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな現象があるいは光り物と誤認されることがないとも限らない。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も『土佐古今の地震』という書物に、著者｜寺石正路氏が明治三十二年の颱風の際に見た光り物の記載には「火事場の火粉の如きもの無数空気中を飛行するを見受けたりき」とあるからこれはまた別の現象かもしれない。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人玉を見たという人にその光り物の大きさを聞いてみても視角でいくらぐらいという人はきわめてまれである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はお前をはげしく追想する、お前は何時でも絶えることのない思慕の光り物だ。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなんだかチカチカ光り物が見えますわ。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが天野祐吉は怖ろしい光り物を見た。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃ太陽がお前の爲に、今宵マンチュアへの道案内に炬火持の役さしょとて、急に呼出した光り物ぢゃ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これミチミ、およしよ」「――しかし突然、僕はまっくらな絶望の闇のなかに、ほのかな光り物を見つけた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏から秋にかけて、江戸の空にはときどき大きい光り物が飛んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある物は大きい牛のような異形の光り物が宙を走るのを見たとさえ伝えられている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが突如音がして光り物が本堂に入って来た。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしてこわごわ起き上がってみますと、つい五六｜間先に大きな光り物がころげていました。",
              "citation": {
                "source": "雷のさずけもの",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とうなずいて、「すぐ頭の上の枝のところで、ぱっと光り物がしたと思うと、二人とも一緒に、同じ人の顔を見たのです。",
              "citation": {
                "source": "北国の人",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「は、ちょいと、光り物がしましただけで――」　と、雪之丞も、微笑を返した。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほほう、それで、そなたの前に、きらめいたという光り物のわけも、大方解ったようだ」　と、師匠は頷いて、「してその、門倉とかいうお方は、余程のお腕前かな？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなウジウジした様子を見るにつけて御龍は自分の体の中に心の中に住んで居る光り物を可愛がった。",
              "citation": {
                "source": "お女郎蜘蛛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、キラキラと光り物がした。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おッ」――キリキリと弦を引き、さながら満月の形にしたが「おッ」とばかりに声を洩らし、正次は光り物の主を見た。",
              "citation": {
                "source": "弓道中祖伝",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子　恐ろしい魔法の光り物……。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）その恐ろしい魔法の光り物がその人の眼だと気付いた時は、娘の体は音楽家の両手の中にありました。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子　（手を軽く拍ち）ほんにそう云えばその通り、たしかに其処で聞いたに違いない、魔法の光り物のようなあの人の瞳が、私の瞳を引きつけている間に、お歌いなされた歌に相違はない。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も日本紀では、これを単なる海原を照し来る光り物、即、外来魂として取り扱つてゐる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫色に光るてえのは」「ほらほら、あの爆撃のところから、ずっと右の方にいったところだよ」「ああっ、あれかい、あの光りだな」　船員たちが甲板でひしめきあっているのは、爆煙からほど遠くない海中の光り物だった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ああ、この光り物が、そうじゃないかしら……」　大隅は突然チカチカと息をしているような光芒を認めた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを廻して、焦点を合わせるのだ」　先生は、そののぞき眼鏡の奥に、何だか、ななめになった光り物をみとめた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その光り物はだんだんはっきりして来た。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、人間の死ぬる場合には、人間の実体なる魂が、かげなる肉身から根こそぎに脱出するから、其又かげなる光を発して去るもの、と見るより、魂の光り物を伴ふ場合にあつたりなかつたりする説明は出来ない。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "一際烈しきひかりものの中に、一たび、小屋の屋根に立顕れ、たちまち真暗に消ゆ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
