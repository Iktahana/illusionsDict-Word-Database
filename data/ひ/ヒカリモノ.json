[
  {
    "uuid": "f8db4968-dd2b-5954-be32-253a9cc956c8",
    "entry": "光り物",
    "reading": {
      "primary": "ひかりもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
