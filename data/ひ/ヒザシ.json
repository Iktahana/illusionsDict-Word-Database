        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頼りなげな午後の日差しが靜かに林の中に落ちてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧牛の群は既に影を潜めて、緑の草原の上には日差しが斜めになつてゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪もよいの空ではあるが、日差しに張りのある初春の或る朝であった。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我々はできるだけ早く階下に降りて、外の明るい朝の日差しを浴びた。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒れ地ではハリエニシダが一面花盛りで、春の明るい日差しを浴びて燦爛と輝いている。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かくも日差しが強くては、何も期待できない。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍碧の海をへだてて長く突出した緑色の岬の端には、眼の醒めるような一群の白堊館が、折からの日差しに明々と映えあがる。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "斑な禿山の上には、何に驚いたのか鴉の群が、折からの日差しの中に慌だしく舞い上り、そしてその岬の彼方の沖合には、深谷氏の片足をもぎ取った奴であろう、丈余に亙る暗灰色の大｜鱶が、時々濡れた背中を鋭く光らしながら、凄じい飛沫を蹴立てて疾走していた。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色な日差しがわびしげに四辺にただようて、骨ばかりになった、木の影は、黒い線の様になって羽目にうつって居る。",
              "citation": {
                "source": "霜柱",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に秋の中頃の黄色っぽい日差しで四方には何の声もしない。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三が寝起きしている離れの前には、愛らしい百日草が咲き盛っていたが、夏らしい日差しの底にどこか薄い陰影があって、少しでも外気と体の温度との均衡が取れなくなると、彼は咳をした。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かい羽虫が軒端に簇がっていて、物憂げな十時ごろの日差しであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日差しの暖かい静かな町へ、二人は時々散歩に出かけたが、庸三に寄り添って歩いている葉子はとかく神経的な感傷に陥いりがちで、鈍感な彼に何かを暗示するような謎の言葉をかけることもあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時出航、　自分から出した手紙の抜粋、三月一日付、　今日のように春らしい日差しに成って暖で、雨が降ってやんで、水たまりに日が写って居ると法悦に近いような喜びに胸を打れます。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○弱い、疲れた日差しが、細かい木の枝や葉のもつれをチラチラと壁の上に印して居る。",
              "citation": {
                "source": "結婚問題に就て考慮する迄",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六畳の縁に向いた部屋に暫く机を置いて居た泰子は、春の日差しが暖く強く成るにつれて、眩しさを感じて仕方が無く成った。",
              "citation": {
                "source": "われらの家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭石が、コンベンショナルな日本の庭らしい趣で据えられ、手洗台の石の下には、白と黒とぶちの大きな猫が、斜な日差しを受けて、踞って居る。",
              "citation": {
                "source": "又、家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや午後の日差しがうっすら淋しく大道にかげり、空風があちらこちらに埃を吹き上げている。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきりした日差しに苔の上に木の影が踊って私の手でもチラッと見える鼻柱でも我ながらじいっと見つめるほどうす赤い、奇麗な色に輝いて居る。",
              "citation": {
                "source": "秋風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピッタリと頭の地ついた少ない髪を小さくまるめた青い顔の女が、体ばっかり着ぶくれて黄色な日差しの中でマジマジと物を見つめて居る様子を考えて見ると我ながらうんざりする。",
              "citation": {
                "source": "秋毛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が大嫌いで、どんな土砂降りでもまだ雨の方が好いと云って居る程の私なので今日の鎮まった柔かな日差しがそよりともしずに流れて居るのがどの位嬉しいか知れなかったのです。",
              "citation": {
                "source": "小さい子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の国｜筑紫の女王｜白蓮と、誇らかな名をよばれ、いまは、府下中野の町の、細い小路のかたわらに、低い垣根と、粗雑な建具とをもった小屋に暮している※子さんの室は、日差しは晴やかな家だが、垣の菊は霜にいたんで。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "層雲が彼方此方に漂って、はげしい日差しが凋んだ月見草に暑苦しくよどんで居る。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がひとりでにさめると、あったかい日差しが、しめた戸の節間からさして、庭でにわとりが鳴いて居る。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにく時計を枕元に置かず、日差しの見当で仕度をする。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄な日差しのむずかゆい様な日に午後から来たＨは、両親とも留守だったんで千世子と二人で洋館に居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二階の、日差しの悪い室で、すやすや眠ってる赤ん坊の顔を、小野君は大きな絵具箱を開いて、描き初めました……。",
              "citation": {
                "source": "肉体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁木は雷雨と雷鳴を待ちこがれましたが、それらしいものは一向に来ず、強い日差しに、焼け跡の菜園の作物は萎れがちでした。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五郎」は夕刻から宵にかけて相当に客があるので、それを避けてか、或は他にわけがあってか、秦や波多野は、多くはまだ日差しの明るいうちにやって来て、楽しげに川蟹をつついた。",
              "citation": {
                "source": "非情の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ乾き切らない湿気と鈍い日差しが皆の心も体も懶るくさせて、天気に感じ易い私は非常に不調和な気分になって居た。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
