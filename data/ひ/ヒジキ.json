[
  {
    "uuid": "78986af3-de30-519a-bb87-03063a8a9ef2",
    "entry": "鹿尾菜",
    "reading": {
      "primary": "ひじき",
      "alternatives": [
        "ヒジキ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hijiki (dark edible seaweed usu. sold in dried black strips; Hizikia fusiformis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ソレ直ぐに鹿尾菜の代が浮いて出ようというものさ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昆布鹿尾菜のゆるやかに搖れつゝあるも、喫驚と恐怖のさまを表明せり。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも切昆布と鹿尾菜と油揚と豆腐との外は百姓の手で作つたものばかりで料理された。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鹿尾菜と煮染の総菜じゃ、碌な智慧も出めえ――」　姉さんまで小父さんの成田屋｜張にかぶれて、そんなことを言うように成った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿尾菜藻を交へた飯が、凶事に用ゐられたので、必しも此時になくとも、訓註を施した時代にはあつた事が訣る。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿尾菜と喪葬との関係は、更に深いものがある。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此歌、恋人同士の間で、鹿尾菜を贈るに添へたのだと言ふことになつてゐる。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿尾菜藻を御飯の中に交へたものらしい。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、すつかり変形してしまつた歌の起源を説明すると、伊勢物語の様に、恋人同志の間で鹿尾菜を贈るのに添へたのだ、と言ふことになつて来るのです。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安朝の生活と言ふものは、貧弱な生活ですから、鹿尾菜みたいな物を、恋人同志がやりとりしたのですから恐しいですが、だけども、それだけの事実を知つてみると言ふと、この歌はもとは伊勢物語の伝への通りのものではない、と言ふ事が訣る。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかお前が書いたんぢやあるまいな」「これでも、あつしの字よりは少し筋が良い」「字のことになると、自慢がないから、八も可愛らしいよ、――それにしても、こいつは鹿尾菜をバラ撒いたやうぢやないか、お前讀んで見な」　半紙一枚へ、馬糞墨で書いた、下手な字が一パイ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蹄の跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "朋輩女郎の話で無ければ『二｜食に鹿尾菜』といつたやうな所謂苦界の勤めの悲しい囘想談である。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかめ、あらめ、ひじきなど、磯の香も芬とした。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お八ツ時分になると、甘党の松島は卓上電話で紅谷から生菓子を取り寄せ、玉露を煎れて呑んでいたが、晩餐には姐さんのためにてんやものの料理が決まって二三品食卓に並び、楽しい食事が始まるのだったが、彼自身は口がきわめて質素で、ひじきや煮豆で済ますのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋色に塗った低めの長い食卓には、鉢から移された前菜の、生海胆、琵琶湖産の源五郎鮒の卵巣、日向産の生椎茸の油煮、熊の掌の煮付に添えたひじき、鴨のロース、仙台産の味噌で包んだ京の人蔘、など、これらが織部の小皿に並んでいる。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひじきわけの女と言ふのは、歴代ひじき別なる称号によつて聖職に事へる名族が、伊勢にあつた事を意味する。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天武天皇崩御の条には、「青飯」の字をひじきおものと日本紀に訓註を施してゐる。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもひと言ひ、ひじきと言ひ、此だけ条件を備へて居て、其処に久しい年月の文学に与へる所の※爛作用を考へれば、さうした変化と、原形に対する推測は許されるものと思ふ。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひじきものには、袖をしつゝも」と言ふ歌が、伊勢物語の始めの方にあります。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひじきもの」は敷物の事を言つたので、今で言へばねこぶくと言つたものです。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に考へて見ると、ひじきものと言ふことにも意味があります。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひじきと言ふことは、日本でははつきりと葬式の言葉です。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬式の御飯にひじきおものと言ふものを入れる。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、青飯と書いて、ひじきおものと日本紀に訓註が書いてある。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひじきを喰べるだけではなんにも意味がありませんけれども、宮廷に関係のある御葬式の時には、ひじきわけの女と言ふものが出て来る。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで慌てゝ、ひじきわけを捜したところが、ひじきわけが円目の王と言ふ人の妻になつてゐた。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、昔の人はひじきと言ふことで、かう言ふ様に直に聯想する。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、伊勢の国のひじきわけの女と言ふ者が出て来て、宮廷の葬式の時の鎮魂を行つたのです。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしますとこの「思ひあらば」と言ふ事と、「ひじきものには」と言ふ事は接続してゐます。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、その間に「思ひあらば、云々云々、ひじきもの」と言ふ言葉があつたが、だん／＼伝へてゐる中に、有意識或は無意識に解釈して行つて、その時分の人の頭に合ふやうな、一種の合理化が行はれて、そこで発達が止つた。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
