  {
    "uuid": "bbaeed5d-5dfd-5c7a-8c16-675b8b995f1d",
    "entry": "飛信",
    "reading": {
      "primary": "ひしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "urgent letter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "又飛信越の界に、飛騨山脈と稱する連山あり。",
              "citation": {
                "source": "一萬尺の山嶽",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷲羽ヶ岳が黒部川の水源であることは、古い地誌にも記されているが、其位置を飛信越の三国界に在るものとして書いたり図したりしてあるのは、その方が正しいのか否か、資料が得られないので判断の下しようがない。",
              "citation": {
                "source": "黒部峡谷",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにたまたま十月の二十一日、東都神田にてＭＴＬが主催された「非常時下の救癩問題座談会」を終えて帰えりし朝風荘の書斎に、内田守君の飛信をうけ、小川女史が光田園長救癩四十年の記念にと捧げる、此書に序文を筆にする事も奇しき因縁である。",
              "citation": {
                "source": "小島の春",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母の妹の子にあたる三善康信やら、その他の京都にある縁者から、次々と、飛信が来た。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北近江の聯盟国、小谷の浅井久政、長政父子から、一鞭の飛信があって、「――織田の大軍が、続々北上して来る。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら食ひしん坊でも、その實は黄色くならなくつては。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
