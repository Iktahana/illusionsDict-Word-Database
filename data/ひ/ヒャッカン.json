    "definitions": [
      {
        "index": 1,
        "gloss": "all the officials",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "百官司職皆これに從ふ中に、王積薪と云ふもの當時碁の名手なり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百官　此日　知る何れの処ぞ、唯有り　羣烏の　早晩に朝する。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "八、群臣百官は早く朝廷に上り、遅く退け。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "また八省百官の制を設け、地方に於ける国造、県主の世襲を禁じ、新たに国司郡司を命じ、期限的に交替させることにした。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また別の日に伺候いたしまして」　還幸の鳳輦をはなやかに百官の囲繞して行く光景が、物の響きに想像される時にも、太后は過去の御自身の態度の非を悔いておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏の盛んな権勢に助けられて、中宮は百官の全い尊敬を得ておいでになる形である。",
              "citation": {
                "source": "源氏物語",
                "author": "胡蝶",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化の末に金澤瀬兵衞と云ふものが長崎｜奉行を勤めてゐたが、此人は叙爵の時｜越後守となるべきを、菓子商の稱を避けて百官名を受け、大藏少輔にせられたと、大郷信齋の道聽塗説に見えてゐる。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五胡時代に後燕の昭文帝の皇后の喪禮を行うた時、百官が宮廷に會同して哀を擧げた。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "百官達は意外の處分に恐惶して、次の式日からは、皆懷中に唐辛一包づつ用意して置き、哭する場合には、唐辛を含んで強いて泪を出して處分を免れたといふ。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "天樞の正面には、武后の親筆で大周萬國頌徳天樞の八字を刻し、その周圍には、この計畫に贊成した百官及び四夷諸酋長の名を刻した。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "隋の煬帝が叛臣の斛斯政を捕へて之を誅戮し、その肉を烹て、百官をして之を食せしめた。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "百官の或る者は、成るべく多量にその肉を飽食して、煬帝の歡心を買つたといふ（『資治通鑑』隋紀六、大業十年の條）。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢時代に諸州に孝經師を置いた（『後漢書』百官志四）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "崔發の事情憐むべきものがあるので、百官が交る交るその放免を嘆願したが、敬宗は頑として聽かぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "長安の皇宮は都城の北部に南面して建てられ、後部が内裏で前部が百官の集ふ役所である、その眞中が朱雀通りで朱雀門が南面してある、この朱雀の西の側に社稷がある、この朱雀通りの左が左京、右が右京になります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "又京都は二条の城及び内裏へも火を放ち、勿体至極もないことながら、帝の遷幸を乞い奉れば公卿百官は草の如くに必ず伏し靡くに相違ござらぬ……」　こう云って説いて行く中に私はふっとこんな事を心の隅で思いました。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ関白と申す者は、百官を總べ、万機を行ない、天下を関り白する者、太政大臣の上に坐し、一ノ上とも、一ノ人とも、一ノ所とも申し上ぐる御身分、百｜姓の模範たるべきお方であるはずだ。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏々の誄・百官の誄など奏したのも、或期間、魂の生死に弁別がなかつた為だ――にも共通の慣用句であつたらしい「現御神大八洲国所知食大倭根子天皇云々」と言ふ讃詞は、天子の神聖な資格を示す語として、賀正事から、此に対して発達したと思はれる詔旨（公式令）の上にも、転用せられて行つた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――鎮火祭「……親王たち・王たち・臣たち・百官人たち・天の下の公民に至るまでに、平らけく斎ひ給へと、神官天津祝詞の太祝詞事を以ちてたゝへ、辞をへまつらくと申す。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときの詔に「現御神と大八島国｜所知天皇が大命らまと詔りたまふ大命を集侍れる皇子等王臣百官人等天下公民｜諸聞食さへと詔る」（下略）と。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、自分の家の職業を申し、天寿を祝福して、百官を代表するのである。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　賢人百官を總べ、政權一途に歸し、一｜格の國體定制無ければ、縱令人材を登用し、言路を開き、衆説を容るゝ共、取捨方向無く、事業雜駁にして成功有べからず。",
              "citation": {
                "source": "遺訓",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "當此時朝廷百官遊蕩驕奢。",
              "citation": {
                "source": "遺篇",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "文武百官を初め、國政に參與するを許されて、我等の推した選良の士も、洩れなくこのゆかしき盛儀に陪し、親く大詔を蒙つたのである。",
              "citation": {
                "source": "賢所御神樂の儀",
                "author": "羽田亨",
                "note": "青空文庫"
              }
            },
            {
              "text": "百官不和、難以言治。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "百官和せずば、以て治を言ひ難し。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついては、越前宰相以下｜建白の趣旨に基づき、広く百官諸藩の公議により、古今の得失と万国交際のありさまとを折衷せられ、今般外国公使の入京参朝を仰せ付けられた次第である、と告げてある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "和紙四つ折百八十六丁、五号活字二段組でぎっしりつまっているのが、内閣総理大臣兼内務大臣陸軍中将従二位勲一等伯爵｜山県有朋を筆頭とし、監獄｜石川島分署看守副長十等野口正義を末尾とするところの、当年の大日本帝国文武百官の一覧簿をなしているのだからみものである。",
              "citation": {
                "source": "武鑑譜",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　百官戦慄して言なし矣であった。",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ那家が勝敗するかを看よ」　皇帝はじめ文武百官は、すっかり顔色を変えてしまった。",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
