    "definitions": [
      {
        "index": 1,
        "gloss": "close (e.g. of business)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じ畑の中を何遍も往復して居るのを少し離れた畑で働いて居た農夫が怪しんで居るやうで少し氣が引けた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまたこの場合に、台所から一車もの食料品を持込むのはかなり気の引けることであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野に雲の海があるとき、霞棚引けるとき、それ等を敷莚にして、幽婉な寝姿が影となって望まれる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつちか引けば、引いた方が切られるのである。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座あたりの堂々としたカフエーには、どうしてもきまりが惡く、氣が引けて這入れないのださうである。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ミサコはいまさらのように善良な夫を見つめていたが、「あなた、ナナコはまだ学校を引けないわね。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして五時頃、会社が引ける時分になると、急に起きて、髪を直し、顔や耳を石鹸で洗いたてて化粧をした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が学校が引けると小舟に乗りこんでやって行って、「マイラセ」という小籠に一っぱいか半ばい位いの鰯を貰って来るのだ。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばあさんは村を歩くのに、引けめを感じておず／＼していた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、工場が引けて帰る幹太郎を待ちかねていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、償勤兵となったことを、恥ずかしがりもしなければ、引けめに感じもしなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供なりに僕は、自分の家に、一枚の山も、一段歩の畠も持っていないのを、引け目に感じた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は縫物屋が引けて帰ったお品に云いつけた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚き火の傍へ行って、殊更らしく訊ねかえすと、他の労働者達に笑われるので気が引けた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……りんと引け、　　　りんと引けかし。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだとするとおれがあんな大学生とでも引け目なしにぱりぱり談した。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト少しドギマギして、顫えていはしまいかと自分でも気が引けるような弱い返辞をしながら、慌てて衣を着けて支度をした。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし不幸にして科学が進歩するとともに科学というものの真価が誤解され、買いかぶられた結果として、化け物に対する世人の興味が不正当に希薄になった、今どき本気になって化け物の研究でも始めようという人はかなり気が引けるであろうと思う時代の形勢である。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬喩を引けば浦島太郎が竜宮の一年はこの世界の十年に当たるというような空想や、五十年の人生を刹那に縮めて嘗め尽くすというような言葉の意味を、つまり「このエントロピーの時計で測った時の経過と普通の時計と比べて一年と十年また五十年と一瞬とに当たる」と説明すればよいかもしれぬ。",
              "citation": {
                "source": "時の観念とエントロピーならびにプロバビリティ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音が頭の頂上まで突き抜けるように響き渡って、何よりもまず気が引けるのである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ畑の中をなんべんも往復しているのを少し離れた畑で働いていた農夫が怪しんでいるようで少し気が引けた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "適当な楽譜を得るためにはじめには銀座へんの大きな楽器店へ捜しに行ったが、そういう商店はなんとなくお役所のように気位が高いというのか横風だというのか、ともかくも自分には気が引けるようで不愉快であったから、おしまいには横浜のドーリングとかいう商会へ手紙で聞き合わしたり注文したりする事にしていた。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の日など泥まみれの足を手ぬぐいでごしごしふいて上がるのはいいが絹の座ぶとんにすわらされるのに気が引けた記憶がある。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一人で飲んでいちゃ気が引けるとおっしゃられるとね」　と落着いた調子でいいながら奥さんは躇らいもせず手を出すのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔軟性はあるが押せども引けども壊れない自然の原則のようなものが形から感ぜられる。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "惨たらしゅう殺したる、蛇の鎌首ばかり、飛失せたらむ心地しつ立っても居ても落着かねば、いざうれ後を追懸けて、草を分けて探し出し、引摺って帰らんとお録に後を頼み置き、勝手口より出でんとして、押せども、引けども戸は開かず。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手口と覚しき処に行きて、もしやと引けども同じく開かず。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と車夫の吉造、不意に飛込んで、婦人の髻鷲掴みにしてぐいと引けば、顔をしかめて、「あ痛、つつつつつ」と拳に手を懸け、「無体な、何をするんだねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けて、引け過ぎに歸る時も、醉つて、乘込む時も。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋宮沢賢治草穂のかなた雲ひくきポプラの群にかこまれて鐘塔白き秋の館かしこにひとの四年居てあるとき清くわらひけるそのこといとゞくるほしき",
              "citation": {
                "source": "恋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
