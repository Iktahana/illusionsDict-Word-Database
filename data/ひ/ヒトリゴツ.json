        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「不思議だな、俺も変つたわい」　宗右衛門は腹の中で独り言つた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼は独り言つた。",
              "citation": {
                "source": "爪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と独り言つやいなや、しつかりと私と私の妻の手を順に握つた後に、猛然と、その一段高い道路に駆けあがつた。",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などゝ独り言つてゐた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、大胆不敵な、この女装の剣者は、独り言つ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼は又｜独り言つた。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
