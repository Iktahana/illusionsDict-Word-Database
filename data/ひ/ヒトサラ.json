        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとえ、一皿二フランの肉の料理でも、十分に食欲と味覚は満足させてくれる。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一皿の水を化して大海とするのである。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして煮肴一皿だけを取りよせて、熱燗を何本となく続けのみにした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「巴里のアンショア」の最初の一皿は、ほんの端だけ老翁に味われあとはゴミ桶へ捨てられた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一皿と家鴨の股の肉にサラダをあしらった一皿を組ましたものが、この店の名物「家鴨のブレッセ」である。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一皿さしあげませう。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木川子と吾輩二人で一皿を平らぐ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその日、晩飯を食わせられる時、道具屋が、めじの刺身を一臠箸で挟んで、鼻のさきへぶらさげて、東京じゃ、これが一皿、じゃあない、一臠、若干金につく。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一皿十円も二十円もする果物の皿をずらりと卓に並べるのが毎晩のことで、何をする男かと、あやしまぬものはなかったのである。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、いらん」　食堂だと思ったが、夜はカフェに変るのだろうか、いや、朝っぱらからもうカフェじみているわいと思いながら、小沢はぶっ切ら棒に断ったが、ふと思い出して、「――それより、にぎりを持って来てくれ」　十五円のライスカレー一皿では、腹が一杯にならなかったのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のもの海のもの、どんな御馳走があっても、最後の点睛はおいしい漬物の一皿でなければならない。",
              "citation": {
                "source": "漬物の味〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩にはお菜がないので、小さい筍を抜いて煮て食べた、一皿に盛るだけしかなかつたが、ダシもなかつたが、それでも十分うまかつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食（ちくわ一皿、ぢやがいも一皿、沢庵漬）うるかをよばれた。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "われもわれもと、その一皿二円の鯛の塩焼を注文する。",
              "citation": {
                "source": "禁酒の心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと全く見え透いた愚かなお世辞を言いながら、負けじ劣らじと他のお客も、その一皿二円のあやしげな煮込みを注文する。",
              "citation": {
                "source": "禁酒の心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウイリイは犬からよく言われて来たので、一ばんはじめの一皿だけたべて、あとのお皿へはちっとも手をつけませんでした。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "余も鰯を一皿註文したら鰯が八匹あつた。",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "餠のわづか一皿でも、其土地の非常な好い記念となる。",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "消化力の旺盛になつて居る旅中には、今飯を喰つたとて、面白い名物であつたら、一皿位では胃に障るやうなことはない。",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨休めするケニ』　私はその五円札を一枚持って飛出いて、近所の酒屋から土瓶に二杯、酒を買うて、木賃宿から味噌を一皿貰うて来ました。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀夫はその牡蠣船では牡蠣料理以外に西洋料理も出来ると聞いてゐたので、西洋料理の一皿か二皿かを取つてビールを飲んでも好いと思つた。",
              "citation": {
                "source": "牡蠣船",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋料理を一皿二皿喫つてビールを一本飲む位なら三四円もあれば良いだらう、と、彼は友達と西洋料理に行つた時の割前を考へ出してゐた。",
              "citation": {
                "source": "牡蠣船",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら、」　この間も料理一皿とナマ一杯で帰つて行つたこの方は、あまり飲んだり食べたりする方ではないらしい。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二合罎が一本に、おでんが一皿……」　学生の一人がかう云つて先生の方を見て笑つた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "値をきくと、指を一本出したので、煙草の五円に較べれば一皿一円のカレーライスは廉いと思い、十円札を出すと、しかし釣は呉れず、黒いジャケツを着たひどい訛の大男が洋食皿の上へ普通の五倍も大きなスプーンを下向きに載せて、その上へ白い飯を盛り、カレー汁を掛けるのだった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラックの天婦羅屋へはいって一皿五円の天婦羅を食べ、金を払おうとすると掏られていた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おてつだいさんの　とこに　いって、　ひとさら　おかゆを　つくってって　いってね、　それから　ダッシュを　おうちに　よんできて　いったの。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷に黄な粉をかけたるは江戸の目には見も慣ず可笑ければ、京水と相目して笑をしのびつゝ、是は価をとらすべし、今ひとさらづゝ豆の粉をかけざるをとて、両掛に用意したる沙糖をかけたる削氷に、歯もうくばかり暑をわすれたるは珍しき事いはんかたなし。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子が五つ六つの頃、よく支那人のひとさらいの話でおどかされたことがあった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けらお　ひとさらいのあんなあなだ！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
