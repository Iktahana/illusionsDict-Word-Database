          "literary": [
            {
              "text": "漫画芸術のために、彼等、一肌脱ぐのは当然だ。",
              "citation": {
                "source": "喧嘩上手",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞ皆様もお困りでしょう、ケチな野郎ではございますが、私がちょっと仲裁役、一肌脱ぐことに致しましょう、と云いたいんだがどう致しまして、すっぱだかになって踊ってみせます。",
              "citation": {
                "source": "二人町奴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然、この女優のために一肌脱ぐけど、とてもマーボー嬢に対するほどじゃない。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはひどく面白そうだから、僕も一肌脱ぐよ。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大谷さんは、奥さんが見込を力説したから一肌脱ぐことになっていた。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一肌脱ぐとなれば、若子さんに活動して貰う。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋の兄さんが一肌脱ぐ」「頼むよ」「その人から直接佳子さんを動かして貰う」「しかし親友か知ら？",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがたのために、ひとはだぬぐつもりでいるのです。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
