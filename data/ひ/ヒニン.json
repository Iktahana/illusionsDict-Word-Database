  },
  {
    "uuid": "9fa6d4ff-3119-57e3-9af0-f13c8164f9b9",
    "entry": "非人",
    "reading": {
      "primary": "ひにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "group comprising the lowest rank of Japan's Edo-period caste system (incl. ex-convicts and vagrants)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのがつしりした鉄のやうな腕は、すべての不健全なもの、非人倫的なもの、神秘的なもの、病感的なもの（もちろんその中には私の詩にみるやうな哲学も含んで居る）及び人生の幸福に有害なる一切の感情を弾きとばすことに熱して居る。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより郷里の事情も知らぬではないがあまりに薄情だと思って一時はひどく憤慨し人非人のように罵ってもみた。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のいわゆる漫画の対象材料となるものはほとんどすべて人間あるいは人間化されたる非人間である。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の文壇では、詩人や歌人が全く圈外に放逐され、一種の文壇的非人間として輕視されてゐる有樣だが、當時は尚「詩」の勢力が甚だ強く、牧水氏や白秋氏の名聲は、文壇全體の上に廣く輝やいて居たのである。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「非人に迄、身を落し　さだめて辛いであろう」　とハラハラと落涙して、Ｔ「其の方の至孝　天に通ぜぬ　道理が無い」　と乞食の手を掴んで、Ｔ「仇討本懐の日を　祈り申すぞ」　と老臣に金子を包ませて、　それを乞食に与え、Ｔ「些少乍ら　余の志じゃ」　乞食はまるで、鳩が豆鉄砲を喰った形。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう職務に立つときの彼女の姿態に針一｜突きの間違いもなく手間の極致を尽して彫り出した象牙細工のような非人情的な完成が見られた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、あれだけ農民、農村を知りながら、かくまで農民が非人間的な生活に突き落され、さまざまな悲劇喜劇が展開する、そのよってくる真の根拠がどこにあるかを突きつめて究明し、摘発することが出来ないのは、反都市文学のらち内から少しも出なかった農民文学会の系統を引いた作家的立場に原因していると思う。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの癖で、不愉快な場面を非人情に見る、――そうすると反対におもしろく見えて来る――その気持がものになりかけて来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが現代物理的科学にみなぎりわたっている非人間的自然観の根元である。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光覚に関する問題は生理学の領分に譲って物理学では非人間的な電磁波を考えるのみである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のように非人間的に徹底したように見える物理学でもまだ徹底しない分子を捜せばいくらでも残っている。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば力という観念でも非人間的傾向を徹底させる立場から言えばなんらの具体的のものではなく、ただ「物質に加速度が生じた」という事を、これに「力が働いた」という言葉で象徴的に言いかえるに過ぎないが、普通この言葉が用いられる場合には何かそこに具体的な「力」というものがあるように了解されている。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしどこまでも非人間的な態度で行けば物理学の書籍からこのような言葉を除去しなければならぬはずであるが、実際は平気でこれを使用している、この一事でも非人間主義の物理学が人間の便宜のために膝を屈している事はわかるだろう。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "境界面を示さない人間は不可視人間であり、それは結局、非人間であり無人間であるとも言われるかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお島どんがなあ……御存じかも知れんが、当寺の本堂の……ホラ……あすこの裏手に住んでおりまする非人の処へイツモ立寄って行きましたそうで……これは寺男の話で御座いまするが……」「ハハア。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの非人の歌｜詠みの赤猪口兵衛の処へ……」「ホオ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの非人を御存じで……」「知っておるにも何も、私とは極く心安い仲で……ヘヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅多に見えませんがなあ、お島どんは……それでも御座るとアノ非人を相手に長い事話し込んで御座ったという話で……」「イヤ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……も……もしやあの……非人が下手人では……」　良助は返事をしなかった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑紫野を見晴らす大根畠と墓原の間の小径の行止まりに、万延寺の本堂と背中合わせにして一軒の非人｜小舎がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも非人小舎とは言うものの、その小径の左右に、何処かの火事の焼跡から拾って来たらしい大きな焼木杭が二本、洒落た門構えの恰好に立っているのが、その奥のガラクタ小舎とは不釣合いな奇抜なものに見える。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程……われわれ非人風情には寄っても付けぬ初耳の話じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "非人同然の私が、お目付様のような大層な御身分の御方にお眼にかかる事が出来れば、それだけでも肩身が広うなりまする。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "よんどころない時は非人も致します。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも非人同様の姿ながら恐れ気もないその態度と、プンプンする熟柿臭い異臭が、いかにも不快な感じを与えたらしい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "非人同然の人間から遠廻しに役目柄を皮肉ったような事を言われながら、それでも道理には相違ないので文句が言えなかった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に踞まった目明の良助も同様に、炭俵の上の酒脹れになった非人の横顔を凝視めた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生から粗末な物ばかりを喰べる習慣で、割当てようのない奢った副食物は故意と子供にも遣らずに非人の私に下さる。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "非人風情の賢明ぶりを感心すると同時に、冷笑してみたくなったらしい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首のおしまひにんの字がついたらお困りになりませう？",
              "citation": {
                "source": "たんざくの客",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            }
          ]
        }
