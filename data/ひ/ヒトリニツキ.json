        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日は石を一人につき九百貫ずつ運んで来い。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズは一人につき一シリングを渡していった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、初頼という方が、持って来た下すった香奠が、将校方から十五円、兵士一同から二十円……これは皆さんが各々の気心で下すったもので、兵士方は上官から御内意があって、一人につき二銭から三銭のがなれど、人数にすれば二十と云う金高になるといった訳で。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "代表一人につき百万円（一ドル三六〇円のわり）の旅費は、作家のふところからは払いきれなかった。",
              "citation": {
                "source": "再武装するのはなにか",
                "author": "――ＭＲＡについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅客一人につき三十キロ以上の手荷物は許されなかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "多きは七十両、少なきは十五両乃至二十両、平均一人につき二十五両に過ぎず。",
              "citation": {
                "source": "京都学校の記",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聞き及びますと――」　益満は、膝の上に両手を張って、肩を怒らせながら、八郎太から七瀬を見廻して「当家秘伝の調伏法にて、人命を縮める節は、その行者、修法者は一人につき、二年ずつ己の命をちぢめると、聞いております。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "家督といっても以前なら、家禄があるのだが、この頃は最う士族一般が平均禄で、前にもいった、一家につき廿俵と家族一人につき一人半扶持とを先代の如くもらうのみである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみみたいな人ばっかりだったら、何にも出来ゃしないじゃないか　○パン一人につき一フントだけ買える由。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も死亡一人につき一万｜弗の割で出してもいいが……」「弗は下がっているから、一万弗といっても大した金じゃないね。",
              "citation": {
                "source": "不沈軍艦の見本",
                "author": "――金博士シリーズ・10――",
                "note": "青空文庫"
              }
            },
            {
              "text": "神前へのお初穂料として金百｜疋、道中の路用として一人につき一｜分二｜朱ずつ、百六十軒の村じゅうのものが十九文ずつ出し合ってそれを分担した。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "人足一人につき荷物七貫目である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "享保以来、宿村の庄屋一人につき玄米五石をあてがわれたが、それも前年度（明治五年）までで打ち切りとした。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "代金は誰がきめたものか、いずこも宿賃二、三百円を除いて、女の収入は客一人につき普通は三百円から五百円、一泊は千円以上だと云う。",
              "citation": {
                "source": "吾妻橋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "代金は誰がきめたものか、いづこも宿賃二三｜百円を除いて、女の収入は客一人につき普通は三｜百円から五｜百円、一｜泊は千円以上だと云ふ。",
              "citation": {
                "source": "吾妻橋",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしご承諾ねがえるなら、船賃として、一人につき金貨で二万｜法前払いするといった。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを國民の頭割りにして見ますと、一人につき平均五反五畝五歩に當ります。",
              "citation": {
                "source": "森林と樹木と動物",
                "author": "本多靜六",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄太郎は、露骨に、冷笑かすような口調を帯びて、「一人につき三つだけ、何でも願いごとをかなえて下さる。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "悲願百両",
                "note": "青空文庫"
              }
            },
            {
              "text": "正丁一人につき年十日の労働を課するのである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、これをサンチアゴ人口四十万に配当するときは、一人につき五ペソ（わが二円）ずつの割合となり、人口十人につき一人半は救助を受くる割合となるべし。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまずこの条々についても少し実際的に言って見ると、　子供手当及び老人手当は現在のところ一人につき四円ずつを出すことにしている。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私は、ピット氏が、その貧民法案の中に、労働者が三人以上も子供を有てばその一人につき一週一シリングを与えるという条項を作った点で、何らかの不正な意図を有っているとは、決して思わない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人一人につき二人、ひどいのは三四人健康人がついている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○今年の餅は一人につき一キロの由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの人数が、みんな一ヵ月世帯主三〇〇円、家族数一人につき一〇〇円ずつの預金をどこからか下げて、あらゆる三倍ずつの生計費をまかなって暮し、花見をして、上機嫌で平和の春がうたえるものだと、かりそめにも思うものは無い。",
              "citation": {
                "source": "現実の必要",
                "author": "――総選挙に際して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学の大仕事をやった揚句、私は各人に三円、女房一人につき二円、子供一人につき一円ずつをやることが出来ることを算出した。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、米一日一人につき一合の事。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「米は一人につき一日一合という御禁令だ、ええか。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして娘が結婚すると、ひとりにつき年収二五〇ポンドずつ受け取れるようになってある。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "手荷物規則ひとりにつき三十｜封度まで無代三十｜封度以上は、一封度に三｜片のわりで申し受けます。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
