[
  {
    "uuid": "72a8b2de-d5d7-586e-a094-20e397af2529",
    "entry": "日増し",
    "reading": {
      "primary": "ひまし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
