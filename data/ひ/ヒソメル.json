[
  {
    "uuid": "f73395a6-1382-51ae-886d-d87951e84878",
    "entry": "潜める",
    "reading": {
      "primary": "ひそめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
