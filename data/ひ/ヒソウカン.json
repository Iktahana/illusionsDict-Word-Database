    "definitions": [
      {
        "index": 1,
        "gloss": "feeling of tragic heroism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
