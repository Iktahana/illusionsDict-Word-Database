        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "天明六、丙午年は、不思議に元日も丙午で此の年、皆虧の蝕があつた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十九年（丙午）　一九〇六○一月四日、福地桜痴居士死す、六十六歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日、丙午、御持仏堂に於て、聖徳太子の御影を供養せらる、真智房法橋隆宣導師たり、此事日来の御願と云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿七日、丙午、晴、将軍家御不例の後、始めて鶴岳八幡宮に詣で給ふ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六日、丙午、天霽、申剋、将軍家前大膳大夫広元朝臣の亭に入御、是去る二日、御所焼失せるに依るなり、御台所、又南御堂より其所に入御、尼御台所、本所に渡御。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日、丙午、霽、今日御所に於て和歌御会有り、相州、修理亮、東平太重胤等其座に候する所なり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三日、丙午、関東の諸御領の乃貢の事、来秋より三分の二を免ぜらる可し、仮令ば毎年一所づつ、次第に巡儀たる可きの由、仰出さると云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九日、丙午、陰、地震矣。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日、丙午、快霽、尼御台所御上洛。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、実は貴子は丙午だから、ことし四十一歳である。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "奧さんは突然緘默を破つて、「なんにしろ丙午なのだから」と、獨言のやうに云つた。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体この星の人は……」年を聞いて丙午だと知ると、八卦見はもう立板に水を流すお喋りで、何もかも悪い運勢だった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十九年丙午十二月鏡花小史一　鳥差が通る。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配なのさ、こうやってお前、私がおもりをしている方はね、妙に火に祟られていなさるのさ、いえね、丙午の年でも何でもおあんなさりやしないけれど、私が心でそう思うの、二度までも焼け出されておいでなさるんだからね、」「どこで、へい？",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に午年ならば仔細はないが、弘化三年は丙午であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時代の習慣として、丙午の年に生まれた女は男を食い殺すという伝説が一般に信じられていたので、この年に生まれた女の子は実に不幸であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの母は取り上げ婆さんを職業にしていて、現にお元の生まれるのを取り上げた関係上、丙午の秘密をよく知っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "その無心を肯かなければ、かの丙午の秘密をお元の夫や姑に訴えると嚇した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "丙午の問題だけならともかくも、彼にはそれよりも重大な松茸の問題があるので、一生懸命に逃げまわった末に、とうとう不忍の池の底へ自分の命を投げ込んでしまったのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでわたくしは、あんな奴に滅茶滅茶にされた身体でございますから、どうなってもかまいませんけれど、丙午のことが世間に知れまして、もしも御離縁にでもなりますようですと、おかみさんもきっと生きてはおいでになるまいと存じますから」「よし、判った」と、半七は大きくうなずいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "光嶽林明大姉、同人妻、京水母、宇野氏、天明六丙午、三十六歳。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "天明六年丙午八月廿日誕、文政二年己卯八月初四日逝、游竜彦次郎俊良、行年三十四歳。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明の万暦丙午に至つて李時珍の本草綱目が成つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘化二年乙巳とすべきか、弘化三年丙午とすべきかに惑ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "姑く丙午を正しいとする。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」試に榛軒の年歯を以てこれに配するに、其十六、二十五、三十四、四十三、五十二、六十一は文政己卯、戊子、天保丁酉、弘化丙午となる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此丙午の歳には伊沢氏に事の記すべきものが無い。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自靖康丙午歳（西暦一一二六）。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は今年二十三、丙午の歳だった。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、あとで十六の娘はひのえうまだときいて、妙な心持がしてしかたがなかった。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
