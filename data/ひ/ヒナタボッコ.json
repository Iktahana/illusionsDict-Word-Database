    "definitions": [
      {
        "index": 1,
        "gloss": "basking in the sun",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "多分七、八歳くらいの自分と五、六歳くらいの丑尾さんとが門前のたたきの斜面で日向ぼっこをしていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が十二月二十五日の午前に帰って見ると、庭一面に籾を干してあって、母は前の縁側に蒲団を敷いて日向ぼっこをしていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半分、裸のかしわが、クックッと逃げる情景　支那の老婆が日向ぼっこして、麦わら細工を縫み乍ら兵隊の行軍を見ている。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと手伝えよ、そんなに日向ぼっこばかりしとらんで。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇が日向ぼっこをしたり、蜥蜴やヤモリがふいにとび出して来る。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでも、醤油屋へ行きたくなくなって、彼は、十時頃まで日向ぼっこをしていた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側で日向ぼっこをしている二匹のねこがどうかすると全く同じ挙動をすると同じかもしれない。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、あの、いま頬っぺたを掻いて、むくむく濡れた毛からいきりをたてて日向ぼっこをしている、憎らしいッたらない。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇しあだ浪いとまなみ、がらがらと石を捲いて、空ざまに駈け上る、崖の小家の正面に、胡坐を総六とも名づけつびょう、造りつけた親仁のように、どっかりと臀を据え、山から射す日に日向ぼっこ、海に向うて朝から晩、暮れると、浪枕、やあ、ころりとせ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先王さまが、お庭の此の腰掛にお坐りになって日向ぼっこをなされていると、急に御様子がお悪くなり、あたしたちの駈けつけた時には、もう悲しいお姿になって居られました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百匹もの猿は、青空の下でのどかに日向ぼっこして遊んでいた。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、陽の赤い、その時梟ヶ嶽は、猫が日向ぼっこをしたような形で、例の、草鞋も脚絆も擽ってえ。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いい若けえ者が酒屋の御用じゃああるめえし、犬っころを相手に日向ぼっこは面白くねえぜ」　半七の顔をみて、徳次という船頭は笑いながら挨拶した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちと母上と私とは海岸の砂丘に行って日向ぼっこをして楽しく二三時間を過ごすまでになった。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分田の向うの藁堆の陰で、日向ぼっこをしているのだろうと思って、その方へ行ってみますと、果して祖父の声がきこえてくるのです。",
              "citation": {
                "source": "勝負事",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かまきり　秋草のなかにどかりと腰をおろして、両足を前へ投げ出したまま日向ぼっこをしていると、かさこそと草の葉を伝って、私の膝の上に這いのぼって来るものがある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春から夏へかけて、多くの草木が太陽の「青春」と「情熱」とに飽酔しようとして、てんでに大きな、底の深い花の盃を高く持ち上げている頃には、彼は心静かに日向ぼっこをして、微笑を続けているばかしだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、慶一のひざを枕にしながら、柱に足をかけて、目をつぶっている高志までが、どうでもいい、という表情で、日向ぼっこしてる猫みたいに、満足そうな顔をしているのが、慶一には腑に落ちない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "○亀は馬鹿さ、嘘だと思ふのなら芝公園の池で日向ぼっこしてゐるから見て来給へ。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾が乳首へ苦艾を塗って鳩小舍の壁際で日向ぼっこりをして……殿樣と貴下はマンチュアにござらしゃりました……いや、まだ／＼耄きゃしませぬ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の流人たちは、海を見下ろす砂丘の上で、日向ぼっこをしていた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに彼等は秋の日の日向ぼっこということもあるらしい。",
              "citation": {
                "source": "黒猫",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "揺椅子で日向ぼっこをしていた彼は、「有難う、有難う」と云いながら、彼女の片手を執って敲いた。",
              "citation": {
                "source": "或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大判の頁、一枚ときめ、椽側で日向ぼっこをしながらちょうど時候にすればいま時分、とつとつと書きつめるのである。",
              "citation": {
                "source": "入学試験前後",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい脱線して飛んだ気焔になってしまったが、ちょっと籐椅子の上で寝ころんで、日向ぼっこをしながら一ぷくして、また初めの呑気至極な思い出すままだらりだらりと書いて行く与太的雑録に帰ろう。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、僕等の監房はちょうど真南向きに窓がついているので、日さえ照れば正午前二、三時間余りの間は、背を円くして日向ぼっこの快をとることができる。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　堀保子宛・明治四十三年二月二十四日　僕等の室の窓の南向きなこと、およびそれがために毎日二時間ばかり日向ぼっこができることなどは、いつか話したように思う。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして日向ぼっこをしながら仕事をしていると、何だか黒いものが天井から落ちて来る。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "若宮もとうとうこの日向ぼっこ連にはいったのか。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしは初夏以来雨ばかり降り続く妙な気候なので、内外にいる日向ぼっこ連の健康がはなはだ気づかわれる。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
