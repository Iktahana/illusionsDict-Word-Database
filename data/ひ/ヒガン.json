[
  {
    "uuid": "c5c98629-1b09-5335-bae6-406480b741bb",
    "entry": "彼岸",
    "reading": {
      "primary": "ひがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
