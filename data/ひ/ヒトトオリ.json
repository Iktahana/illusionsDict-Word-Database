  {
    "uuid": "a558aacd-ddc2-506a-a1d5-cd08fc2466e1",
    "entry": "一通り",
    "reading": {
      "primary": "ひととおり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
