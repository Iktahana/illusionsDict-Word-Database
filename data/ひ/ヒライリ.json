    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese traditional architectural structure, where the building has its main entrance on the side which runs parallel to the roof's ridge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
