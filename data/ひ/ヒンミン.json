[
  {
    "uuid": "fbf1ea43-7c7a-5035-93ae-6e91da6fd913",
    "entry": "貧民",
    "reading": {
      "primary": "ひんみん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
