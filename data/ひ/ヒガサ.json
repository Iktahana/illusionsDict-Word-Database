    "definitions": [
      {
        "index": 1,
        "gloss": "parasol (esp. one carried in the hand)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
