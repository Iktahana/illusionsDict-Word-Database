        "examples": {
          "standard": [
            {
              "text": "暖炉の奥にある火格子を掃除して灰を取り除かないと、火の回りが悪くなってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職人は真っ赤に焼けた鉄棒を叩き、古い洋館に似合う頑丈な火格子を作り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蒸気機関車の窯の中で、火格子の隙間から落ちる燃えカスの熱気が足元を焦がす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "外れた二本目の火格子を修繕するためで、しばらく容疑者と一緒にいたが、呼ばれたため途中で退室。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ホームズは立ち上がって、煙草の吸い殻を火格子に投げ入れて、「僕は実にのろまだった、ワトソン。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "広いものものしい煖炉の火格子は取りはずしてあり、薪がよく燃えるようにしてあった。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁煖炉の火格子の上に、冷えきった昨日の灰がうず高くなっている。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その眼も、依然として夢みるやうに爐の火格子を見守つてゐた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スケッチを一枚ずつゆっくり火格子に置いた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒が火格子にありますから、読まれたに違いありません」　確かにベリントン大佐の手書き封筒が火格子に乗っていた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草の吸い殻を火格子に投げた時、扉のベルが鳴った。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
