      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "countryside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まだ子供が出来ない頃、この新婚の若夫婦は、山陰道の辺鄙な島々を旅し歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "都鄙両方に往来する人は両方を少しずつ知っている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の歌天井に　朱きいろいで　　戸の隙を　洩れ入る光、鄙びたる　軍楽の憶ひ　　手にてなす　なにごともなし。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "原に草、鄙唄うたひ山に樹々、老いてつましき心ばせ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "町ともつかず村ともつかない鄙びた家並がある。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより惹いて、「鄙びたこと」「垢抜のしていないこと」を意味するようになってきた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな辺鄙な山の中に、こんな立派な大都会が存在しようとは、容易に信じられないほどであった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ見たうちで、アメリカの川船を舞台としたロマンスの場面中に、船の荷倉に折り重なって豚のように寝ているニグロの群れを映じてそれにものうげに悲しい鄙歌を歌わせるのがあった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは明治まで存し、今でも辺鄙には密に存するかも知れぬが、営業的なものである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして世におのずから骨董の好きな人があるので、骨董を売買するいわゆる骨董屋を生じ、骨董の目ききをする人、即ち鑑定家も出来、大は博物館、美術館から、小は古郵便券、マッチの貼紙の蒐集家まで、骨董畠が世界各国｜都鄙到るところに開かれて存在しているようになっている。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合に、突然にどこからか現われて来て新生面を打開するような対象が、往々それまではほとんど物理学の圏外か、少なくも辺鄙な片すみにあって存在を忘れられていたような場合であることもあえて珍しくはないのである。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの現象の多くのものは、現在の物理的科学の領域では、その中でのきわめて辺鄙な片田舎の一隅に押しやられて、ほとんど顧みる人もないような種類のものであるが、それだけにまた、将来どうして重要な研究題目とならないとも限らないという可能性を伏蔵しているものである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その麦畑の畦に、ところどころに鄙びた基督の磔刑の石像が立っていまして、それに士地の農夫達の手作りの花環などが供えられてあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて、その岐阜県の僻土、辺鄙に居た頃じゃったね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体昔の大名の別邸を取払った幾分の造作が残ったのに、件の洋風の室数を建て増したもので、桃色の窓懸を半ば絞った玄関｜傍の応接所から、金々として綺羅びやかな飾附の、呼鈴、巻莨入、灰皿、額縁などが洩れて見える――あたかもその前にわざと鄙めいた誂で。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなん當時の國色、大將軍梁冀が妻、孫壽夫人一流の媚態より出でて、天下に洽く、狹土邊鄙に及びたる也。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鄙はさて都はもとより、衣輕く戀は重く、褄淺く、袖輝き風薫つて、緑の中の涼傘の影、水にうつくしき翡翠の色かな。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鄙唄を、いゝ聲で――大正十年七月",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ、次の最初の停車場へ着いた時、――下りるものはなかった――私の居た側の、出入り口の窓へ、五ツ六ツ、土地のものらしい鄙めいた男女の顔が押累って室を覗いた。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜚※ほど又なく野鄙なるものはあらじ。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　だだっ広い玄関の座敷にちょっとした椅子場があり、均平をそこでしばらく待たせることにして、鄙びた菓子とお茶を持って来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し辺鄙だけれど、その代りのんびりしたもんだ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭も茶室もまだこの異趣の材料を使いこなせないところがあって、鄙俗の調子を帯びていた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それが縁付くとなると、草莽の中に鄙び、多産に疲れ、ただどこそこのお婆さんの名に於ていつの間にか生を消して行く。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "視た眼も舌の味ひも、あつさりと品のよい、みやびやかで、どこか鄙びた珍らしい雜煮の椀を手にとりあげた。",
              "citation": {
                "source": "雜煮",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣一枚の胸をハダケて、恐らく我々が来るまで、彼は頭をカカへてゐたに違ひなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まあこのおしまひの手合なんぞは、云つてることに何の意味もないにしてからがチヨイト頭を捻ること言換れば位置にお構ひなしに移動の万能範囲を拡げることが、いとも優秀なことのやうに思はれることは現時の流行感冒である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてなが魂もいやにがき、深淵ぞ　さうに違ひない、海を見てると溜息が出る。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが短歌より出て来たものだとしても、既に短歌と訣別して、新しい領土に立つてゐることも恐らく間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論かういふことは、一々の短歌作品、一々の俳句作品に就いてそつくりそのまま当箝まることではないけれども、夫々の様式を規範的に観た場合そのやうに言ふことは先づ間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
