[
  {
    "uuid": "d8ef2635-ae10-5a44-8183-3e3170d4b9e8",
    "entry": "鄙",
    "reading": {
      "primary": "ひな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
