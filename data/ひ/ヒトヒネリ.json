        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのころの郷里には「切りもぐさ」などはなかったらしく、紙袋に入れたもぐさの塊から一ひねりずつひねり取っては付けるから下手をやると大小ならびにひねり方の剛柔の異同がはなはだしく、すえられるほうは見当がつかなくて迷惑である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生め、一ひねりだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだって、こんな、修治みたいなのは一ひねりですよ。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてとうとう信濃の諏訪湖のそばで追いつめて、いきなり、一ひねりにひねり殺そうとしますと、建御名方神はぶるぶるふるえながら、「もういよいよおそれいりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "照明の變化と共に舞臺の感じがまるで一變するやうに、世界は、ほんのスヰッチの一ひねりで、さういふ幸福な（？",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）世界ともなり得るし、又同じ一ひねりで、荒冷たる救ひのないものともなる。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一ひねりだぞ」　と睨む空威張。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を云うとき何か、一ひねりしてみないと気のすまない性格だろうか、このような言葉は初対面の折になど、云わなくてもよい、いやがらせであると思って、気持がわるくなりかけたが、ここが路子の注意だと思い、「はあ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ前川夫人が少し難物、一ひねりも二ひねりもありそうな人物。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前川は、小太郎や祥子の相手をさせられているだけに、「グウ、キョキ、パッよろしい、君なんか一ひねり……」と、自信を以て始めたが、アッサリ美和子に負けてしまった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼より、三倍も肥つてゐるとさへ思はれる清親にかゝつては、一ひねりにされるだらうと覚悟はしたが、思つたより強かつた自分を、彼は別人のやうに感じた。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その老匠は眉をひそめて口髭を一ひねりした。",
              "citation": {
                "source": "『この心の誇り』",
                "author": "――パール・バック著――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもただの爺さんというのではなくて、一ひねりもふたひねりをもして人生に生き経た年よりで「怒濤」では、我から示す老いさらぼいを、表面はうっすりつめたい一つの顫える虚無のように周囲から際立たせている年寄が描かれている。",
              "citation": {
                "source": "作品の主人公と心理の翳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、なおそれより私たちの心にひっかかって来るのは、やはり、今日作家が自分たちの小説の主人公にこういう風な一ひねりした老人をもって来る、その心理だと思う。",
              "citation": {
                "source": "作品の主人公と心理の翳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "形象的にひろがりながら、文学の精神の表情は、何ものかに対して辞を低うするのが常識であるかのようになっているとすればその間の心理は一ひねり二ひねりしたものともならざるを得ない。",
              "citation": {
                "source": "作品の主人公と心理の翳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この答は予て期する所で、一ひねりひねつて句法を片輪に置いてあるために、余はどうしても俳句として採ることが出来ぬと思ふやうな句をいつでも碧梧桐が採るといふ事を知つて居る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればその日の糧を猟らうにも、鹿熊なんどのたぐひをとりひしぐは、指の先の一ひねりぢや。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに乗った上で、わしはわしの都合により、あの強力動力装置を組立ててそれを動かし、ちょっと一ひねりやっても、あのような汽船としては快速の部に入る速力を出せるのじゃ。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓如き一ひねりだと弾丸の前へとびだして大敗北を喫した。",
              "citation": {
                "source": "鉄砲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄吉は一刀両断、水もたまらず、首はとび甚だ意地の悪いもので地べたへ落ちてもぐりこんでしまへばいゝのにフワリフワリと宙に浮いて壁につき当り唐紙にはぢかれ柱の角で鼻をこすつてシカメッ面を一ひねり五へん六ぺん旋回する。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "新劇の役者が日常の生活感情をすなほに出す上に役の複雑な性格とか、特殊な思想とかを出さうとする努力があつて、そのために人間といふものをたえず一ひねりしてみせようとしてゐる。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふふん、こんなロケットなら一ひねりで片附くわ」　怪人丸木は、箱の中に映っているロケットを睨んでいる。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たち三人を、やっつけるなんて、それこそ一ひねりでいいのだ」　丸木も、なかなか負けていない。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽く一ひねりに五千の尾張兵をひねり殺して信秀の落ち目の元をつくったのは道三だ。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、覇気マンマンの升田は、従来の戦績もあって、木村をのんでいるから、軽く一ひねりと考えて、殆ど悪条件を気にかけていなかった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄吉は一刀両断、水もたまらず、首はとび甚だ意地の悪いもので地べたへ落ちてもぐりこんでしまえばいいのにフワリフワリと宙に浮いて壁につき当り唐紙にはじかれ柱の角で鼻をこすってシカメッ面を一ひねり五へん六ぺん旋回する。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アネサの道筋に男が立話をしたり立小便でもしていると、襟首に片手をかけて一ひねりする。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そこの道をあけてくれと頼んで退いてもらうよりも、襟首に手をかけて一ひねりして道のジャマ物を取払う方がカンタンであるから、時間も言葉も節約しているアネサの気持が分らないことはない。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、おのれ、ぶれい千万」　覚心坊はジュズをあげて、大蛇の頭をハタとたたきましたが、大蛇はからだを一ひねり、壇上にはいあがると、覚心坊のからだを、下から上へキリキリと巻きあげ、坊主頭の上に、臼のごときかま首をのせて、カッと火焔をはきかけるのでした。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "口では、まるで一ひねりに捻り潰してくれそうな勢で彼女を罵ることだけは我劣らじと罵る。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
