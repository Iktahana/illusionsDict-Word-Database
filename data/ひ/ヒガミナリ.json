        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "快晴の空から突然ゴロゴロと日雷が響き、洗濯物を取り込むべきか迷った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「雲一つないのに雷なんて」と、日雷の音に近所の人たちも驚いて空を見上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日雷は夏の午後の、どこか不思議で不気味な静けさを破って鳴り響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "作品第三番　　　　九月二日雷(1)　精神の圧迫されることは肉体の笞撻されるよりも苦しみを私はよく感ずるだが、私は屈服の奴隷ではない若し異郷に客死せねば或ひは旅嚢を背負つてどこへも渡つて行かれるならば行動の自由によつて種種の太鼓を敲く、その太鼓の音に数知れず群衆の吶喊を昂揚させる。",
              "citation": {
                "source": "小熊秀雄全集-13",
                "author": "詩集（12）その他の詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日雷雨の中をパリーへ帰る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日雷雨起こり、三日清風来たる。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月三十日雷火のため炎上。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
