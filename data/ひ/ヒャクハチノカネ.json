          "literary": [
            {
              "text": "話したりカードを遊んだりして居る最中に、遠くの方で、百八の鐘が鳴り始めた。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "百八の鐘を誰もききつけなかった。",
              "citation": {
                "source": "鏡餅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が平気で笑いさわいで居る中に、一人心でしんみりと、寒夜に響く百八の鐘をきいた。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽にして百八の鐘を聴く。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
