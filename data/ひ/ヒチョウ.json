[
  {
    "uuid": "8ae87ca7-4a5f-5fda-aca0-85f2ac3f8190",
    "entry": "飛鳥",
    "reading": {
      "primary": "ひちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
