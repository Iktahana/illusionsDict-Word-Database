    "definitions": [
      {
        "index": 1,
        "gloss": "just past noon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昼過ぎから猛烈な吹雪が襲って来たので、捲上の人夫や、捨場の人夫や、バラス取り、砂揚げの連中は「五分」で上ってしまった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう昼過ぎた午後の太陽の光に照らされた過去を眺めている、そして人並に愧じたり悔やんだり惜しんだりしている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎ、昭青年は姫に生飯を持って行って食べさせたあと、二人は川へ向いた苫を少し掻き分けて、対岸の景色を眺めていました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はとうとう朝飯もたべず、昼過ぎまで畑のあたりをうろついてしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎに上野へ出掛けたが、美術館前の通りは自動車で言葉通りに閉塞されていた。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の末でございました、ある日朝から六蔵の姿が見えません、昼過ぎになっても帰りません、ついに日暮れになっても帰って来ませんから田口の家では非常に心配し、ことに母親は居ても立ってもいられん様子です。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　簑虫　八月のある日、空は鼠色に曇って雨気を帯びた風の涼しい昼過ぎであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みにある日曜の昼過ぎから家族四人連れで奥多摩の入口の辺までという予定で出かけた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリじゅうのせんたく女の中でいちばん美しいのを女皇に選挙して盛んな行列をやるというのでしたから、昼過ぎに近所の大通りまで出て見ました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさ起こった事件を昼過ぎまでにできるだけ正確に詳細に報告しようという注文もここから出て来る。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎに、遠くない近所に火事があったがそれもまもなく消えた。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎに力三は裏の豊平川に神棚のものを洗ひに出された。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内ぢやお昼過ぎに出たつきりなもんですからどうしたんだらうと云つて心配してゐましたつてさ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎに、宰八が来て、その話。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夏父親がやって来た時、彼は東京へ出るたびに、罐詰を土産に親類か何ぞのように錦糸堀の家へ上がりこみ、朝からお昼過ぎまで居座る罐詰屋のことを、そんなふうに怒っていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "連中は午後に出発し、一晩遊んで翌日昼過ぎに帰って来たのだったが、土地のその日の小新聞に、倉持の結婚式の記事が、大々的に出ていることを、銀子は晩方になるまで少しもしらなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと引っ係りのあった、芳町の芸者屋の主人が、看板借りの年増を一人つれて、新潮楼で銀子を揚げ見したのは、銀子が桂庵へ手紙を出してから、四日目の昼過ぎであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフィリヤの親爺のご機嫌をそこねたくないばかりに、それはいい考えだなんてお追従を言って、ホレーショーにも賛成を強要し、三人で朗読の稽古をはじめたのは、きょうの昼過ぎだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは今立っている小川の縁の道の赤土が、昼過ぎの陽に照され、にちゃにちゃして茜色の雲を踏んで立っているような気持のするのに、眼の前一面に実のり倒れた金色の稲田を見渡して跼蹐んだ気持は何もかも何処かへ持って行かれました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶子、おまえはきょう昼過ぎわたしの庵へ出て、わたしから突然乱暴なわたしの決心を聞き、「まあ恐ろしい」と言った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「課長がいま社に残っているといいんだがなあ、昼過ぎに帰っちまったわねえ」　明子は現在加奈江の腫れた左の頬を一目、課長に見せて置きたかった。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お昼過ぎに母親と傘をさして済した顔でお湯に行った。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎから前方に陸が見えだし五時ごろにいよいよゲノアに着いた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎに行って見ると、刈られた葉はすっかりかわき上がって、青白い干し草になって散らばっていた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ではお昼過ぎに、ふたりで伺います。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎても雨はやまない。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「御厄介になる代りに、裏の薪を割らしてください」というて旅籠屋の亭主の承諾を得て、昼過ぎかかって夜まで薪を挽き、これを割り、たいていこのくらいで旅籠賃に足ると思うくらいまで働きまして、そうして後に泊まったということであります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度一｜学期の試験が済んでその採点も終りあとは三十一日に成績を発表して通信簿を渡すだけ、私のほうから云えばまあそうです、農場の仕事だってその日の午前で麦の運搬も終り、まあ一段落というそのひるすぎでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔打身の床をいできたり〕打身の床をいできたり、　　　箱の火鉢にうちゐれば、人なき店のひるすぎを、　　　雪げの川の音すなり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "副業雨降りしぶくひるすぎを、　　青きさゝげの籠とりて、巨利を獲るてふ副業の、　　　銀毛兎に餌すなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
