        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二、三日中に、文芸春秋社から「新ハムレット」が出る筈です。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年九月十五日中原中也高橋新吉様",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "高原地方や山麓の焼土に多く生棲していて、特に夏の日中に飛翔する小虫を捉えた着眼点にある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち読者は、羽蟻という言葉によって、そうした高原地方の、夏の日中の印象を与えられてしまうのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また出ますと云うたら宿は何処かと聞いたから一両日中に谷中の禅寺へ籠る事を話して暇を告げて門へ出た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日中に、文藝春秋社から「新ハムレツト」が出る筈です。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼日中、そんな危険な事が出来ますか。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば明日中某々地方に降雨あるべしというがごとし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、「民やはあのまた薬を持ってきて、それから縫掛けの袷を今日中に仕上げてしまいなさい……。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「六月十七日の午後に医者がきて、もう一日二日の処だから、親類などに知らせるならば今日中にも知らせるがよいと言いますから、それではとて取敢ずあなたのお母さんに告げると十八日の朝飛んできました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つの因子というのは、季節季節でその地方一帯を支配している地方的季節風と名づくべきもので、これは一日中恒同なものと考える。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　三三九頁を見ると、　フェレチ王国の人々は朝起きた時に一番先に眼に触れたものを、その一日中崇拝するという事が書いてある。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日中の通話の回数が驚くなかれ千六百九十四万とある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり日中だけの営業で、日が暮れたら店を片付けて住居に帰る）　三次の奴が境内の茶店に腰をかけて嫌に嬉し相にしている。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日中公園に坐りこんでゐるとき、彼等はどんなことを考へてゐるのか知ら？",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "……二　妻クララに一九〇二年九月十一日、巴里トゥリエ街十一番地　……私は一日中、ムウドンの庭の中の、靜かな場所に坐つてゐました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや左手の眼の前に落ちかかる日輪は爛れたような日中のごみを風に吹き払われ、ただ肉桃色の盆のように空虚に丸い。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日中隊は、早朝から、烏が渦巻いている空の下へ出かけて行った。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日のまだ登らないうち立野を立って、かねての願いで、阿蘇山の白煙を目がけて霜を踏み桟橋を渡り、路を間違えたりしてようやく日中時分に絶頂近くまで登り、噴火口に達したのは一時過ぎでもあッただろうか。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "札幌から出て来た友人は、上京した第一日中は東京が異常に立派に美しく見えるという。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日中の暑い盛りにはやはり暑いには相違ない。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日中にどれだけの人間が殺したり、殺されたりしたか、数が知れまい。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不愉快な記憶は、一日中、とれなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではもう日中だからみんなは立ってやすみ、食事をしてよろしい。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことがなくてさえ昼頃まで夢をたくさん見ながら寝ている自分には、見た夢と現実とが時どき分明しなくなる悪く疲れた午後の日中があった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "溪からは高く、一日中日のあたつてゐる畑だ。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声はよく透り、一日中変わってゆく渓あいの日射しのなかでよく響いた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通り筋の毛糸雑貨屋の主人はこの間まで店へ据えた毛糸の織機で一日中毛糸を織っていたが、急に死んでしまって、家族がすぐ店を畳んで国へ帰ってしまったそのあとはじきカフエーになってしまった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気候は、と言うと、ほかほかが通り越した、これで赫と日が当ると、日中は早じりじりと来そうな頃が、近山曇りに薄りと雲が懸って、真綿を日光に干すような、ふっくりと軽い暖かさ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い屋根は、森閑として日中薄暗い中に、ほのぼのと見える材木から又ぱらぱらと、ぱらぱらと、其処ともなく、鋸の屑が溢れて落ちるのを、思わず耳を澄まして聞いた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
