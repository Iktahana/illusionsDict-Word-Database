        "examples": {
          "standard": [
            {
              "text": "彼は、勝利のためならどんな卑怯な手を使っても構わないと考えているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ビジネスの世界でも、卑怯な手を使うと、長期的には信用を失うことになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スポーツマンシップに反して、卑怯な手を使う選手は、厳しく罰せられるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "どんな卑怯な手を使うかわからねえ――　ジーッと、みつめていると、雪之丞の方は門弟一人を斬って落して、息もはずまさず、次ぎのかかりを待っている。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            }
          ]
        }
