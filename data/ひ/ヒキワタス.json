    "definitions": [
      {
        "index": 1,
        "gloss": "to deliver",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "引き渡すから早速出て来い。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし来なかったら早速警察へ貴様らを引き渡すぞ。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通りやらないものは鳥の国へ引き渡す。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの人の手で、下役たちに引き渡すよりは、私が、それを為そう。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれを引き渡すなら引渡せ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいい加減なことをして、おふくろのお金を呼んで引き渡すと、お金はそれを自分の奉公さきへ連れ込んで養生させることにしました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直にいえばよし、さもなければお前を引き摺って行って、役人衆に引き渡すからそう思え。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "悔悟している教重を寺社方へ引き渡すのも可哀そうだと思って、兼松は寺の役僧や開帳の世話人らに内分の計らいを云い聞かせると、彼等も異議なく承知した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たって役人に引き渡すとあれば、手前これにて切腹いたす」　こうなると、半七もなんだか可哀そうにもなって来て、いつまでも彼等を窘めていられなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原で心中を仕損じた者は、日本橋へ三日｜晒した上で非人の手下へ引き渡すと定めても、それは何のおどしにもならなかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はめいめい警察の手をとおして両親に引き渡すと言っているからもう引き渡しはすんだろうね？",
              "citation": {
                "source": "少年探偵　呉田博士と与一",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "罰として賃銀棒引き、函館へ帰ったら、警察に引き渡す。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえに夫のないということは、証文面にも書いてあるではないか」　女は密夫を作って、それを先夫と詐るのであろうと、耿は一途に信じているので、彼女をその夫に引き渡すことを堅く拒んだ。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからすぐに銭翁の家をたずねて、かのむすめを引き渡すと、翁はおどろき喜んで、かねて触れ出した通りに李を婿にしました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "剪燈新話",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く行かねえと、引き摺って行って、橋番に引き渡すぜ」　女は黙ってすすり泣きをしているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋番へ引き渡すなんて云ったのは俺が悪い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても江戸城表玄関に立ちはだかって、天下を即刻拙者に引き渡すべしと呶鳴ったなぞは、権現さま以来ただの一度もない椿事ですから、その噂は自然に洩れて、忽ちぱっと世間に広がりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は是から先、君と交渉があれば、三千代を引き渡す時丈だと思つてるんだから」　代助は電流に感じた如く椅子の上で飛び上がつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうして歌原未亡人の死体を家人に引き渡すとすぐに、病室の取片付け方を看護婦に命じて、新聞記者が来ても留守だと答えるように頼んでから、コッソリと裏廊下伝いにこの室に来て、貴方の寝台のまわりを手探りで探したのです。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妹ごまさしくお引き渡す間、その女人こちらへお譲りくだされい」　三人の武士のその一人が、ツカツカと前に進み出ながら、慇懃の言葉でこういった。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこれから先、君と交渉があれば、三千代を引き渡す時だけだと思ってるんだから」　代助は電流に感じた如く椅子の上で飛び上がった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "奪われた不覚を棚へあげて、かくも、我らを非議するとは、卑怯にして手前勝手、引き渡すことまかりならぬ！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ほんとの夫婦になるつもりで、拙者と洞へ参る気でなくば、拙者そなたをたを」はママ］紀州藩士へ、ここで用捨なく引き渡す」「…………」　無言ではあったが心の中で、菊女は考えざるを得なかった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明暦義党の正木右馬介の死骸、親戚の者に引き渡す」　と、その同心が物々しく云った。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は加州から浪士一同へ酒肴を贈られ、降蔵らまでそのもてなしがあった上で、加州の家老｜永原甚七郎が来ての言葉に、これまでだんだん周旋したいつもりで種々尽力したが、なにぶんにも行き届かず、公辺へ引き渡すことになったからその断わりに罷り出たのであると。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の部屋にこもり、例の店座敷のわきで、本陣、問屋、庄屋の三役を勤めて来た公用の記録の中から、伝馬所へ引き渡すべきものを選みにかかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙者組み止めお引き渡す。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ問題はリヽーを素直に引き渡すかどうかと云ふことであつたが、それとても、福子の嫉妬心を煽り立てたら大丈夫うまく行くつもりでゐた。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ問題はリリーを素直に引き渡すかどうかと云うことであったが、それとても、福子の嫉妬心を煽り立てたら大丈夫うまく行くつもりでいた。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐずぐずしていると、警察にひきわたすぞっ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
