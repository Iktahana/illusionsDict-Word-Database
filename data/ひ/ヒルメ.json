    "definitions": [
      {
        "index": 1,
        "gloss": "Amaterasu Ōmikami (sun goddess)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "院長先生のお供をして、これからみんなでひるめしたべに出ませうよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてじっさいオツベルは、そいつで上手に腹をへらし、ひるめしどきには、六寸ぐらいのビフテキだの、雑巾ほどあるオムレツの、ほくほくしたのをたべるのだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤衣の童子が、そうして山に着いたのは、ちょうどひるめしごろだった。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち三人はひるめしどきを樂しみにしてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は発着所の近くの薄暗い宿屋へ這入つて、「大急ぎでひるめしを食べたいのですが。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるめしには未だ間があるので横浜のニューグランドまでドライヴしようじやないかと、令嬢達が云い出した。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大歌所のひるめの歌さひのくま　檜隈川に駒とめて、しばし水かへ。",
              "citation": {
                "source": "鶏鳴と神楽と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書中に、みぬま・みづは・みるめ・みぬめ・みつま・ひぬま・ひるめ等の形式変化と共に、内容も亦移つて居る事を述べた。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天上の忌服殿に奉仕するわかひるめに対するおほひるめのあったことは、最高の巫女でも、手ずから神の御服を織ったことを示すのだ。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の天子が日の神・御祖・ひるめの頃から、いつも血族的にはにゝぎの命と同格のすめみまであり、信仰的には忍穂耳命同様日の御子であつた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の最古い神名語尾むちはうちであらう（おほなむち・おほひるめむち・ほむちわけなど）。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひこはひるめの生んだ日の子であり、天子の日のみ子と区別したのである。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天照大神は、日の神ではなく、おほひるめむちの神であつた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此神には、おほひるめの神・わかひるめの神と二種あつて、前者は御一方、後者は沢山あつた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すさのをの命が、斑馬の皮を斎服殿に投げ込まれた時に、気絶したのは、わかひるめの神であつた（日本紀一書）。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるめと言ふのは、日の妻即、日の神の妻・后と言ふことである。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるめのるは、のである。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ひるめは、疑ひもなく、日の神の后の意であらう。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、みるみるうちに、ひつじさんのかほのいろがかはって、「いたづらあひるめ、もうゆるさないぞ。",
              "citation": {
                "source": "ひつじさんと　あひるさん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山の通りの小さい支那飯やで、二品一円のひるめしを売っているので、めずらしくたべてみる。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり立上って、神棚に蝋燭をつけて、その前に蹲った「天照る神ひるめの神……」それだけきり俺には聞き取れなかったが、非常に長たらしい訳の分らないことを、声には出さずに口の中で唱えだした。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "感冒をひいたかも知れない、しまったな……という気持でむっくり起き上ってみると、驚いたことには、灯明をあかあかとともした神棚の前で、お久がくぐまり込んで、「天照る神ひるめの神……」を初めている。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お久はいつのまにか神棚の前に坐り込んで「天照る神ひるめの神……」を初めていた。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天照る神も、ひるめの神も、何もかもあるものか。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天上の忌服殿に奉仕するわかひるめに対するおほひるめのあつた事は、最高の巫女でも、手づから神の御服を織つたことを示すのだ。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
