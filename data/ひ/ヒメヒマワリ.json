        "examples": {
          "standard": [
            {
              "text": "花壇の隅に、小ぶりながらも鮮やかな黄色い花を咲かせる姫向日葵が植えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "園芸店で、珍しい姫向日葵の種を見つけ、自宅で育ててみることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この小さくて可愛いお花、何ていう名前？」と聞かれ、「姫向日葵っていうんだ。普通のひまわりよりずっと小さいよ」と答えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "暴風洗濯物を入れたまま大きな盥が庭を流れ、地が俄かに二三｜尺も低くなつたやうに姫向日葵の鬱金の花の尖だけが見え、ごむ手毬がついと縁の下から出て、潜水服を著たお伽噺の怪物の顧眄をしながら腐つた紅いダリアの花に取り縋る。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一門の扉の飾りが向日葵、一歩中へ入ると、庭の花壇は向日葵と姫向日葵だらけ。",
              "citation": {
                "source": "向日葵の眼",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧｜濃し姫向日葵のそよぎをり投げ棄てしマツチの火らし霧濃し火虫さへ燈下親しむべくなりぬ八月十六日　句謡会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
