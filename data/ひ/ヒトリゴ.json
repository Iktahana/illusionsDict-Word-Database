        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）農家のひとり子で、生れて口をきくと、（椿ばけ――ばたり。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おじさんは、うんざりしたように顔をしかめたが、僕は平気で、「その鶴田君だがね、母ひとり子ひとりなんだ。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の由緒ある大きな寺のひとり子に生れ幼くして父を失った。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり子ですからしかたないのです。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "親ひとり子ひとりでこの山奥に年じゅう暮らしているのであるから、寂しいのには馴れている。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銀もそれを深く咎めようとはしなかったが、親ひとり子ひとりの家庭であるから、せがれの帰らない夜はなんとなく寂しい。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり子とめでし少女を。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、自分は田舎のひとり子でいわばなんの苦しみもなくのんきに育てられたほうである。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がひとり子ども三人、夫婦をあわせて六人の家族、妻君というのは、同業者のむすめで花前の恋女房であった。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ親ひとり子ひとりの尾張屋で、その跡取り娘をうしなった喜左衛門のかなしみはひと通りでない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前があんまり心配するから、そんな夢を見たのだろうとか、夢は逆夢だとか云って、まあいい加減になだめているのだが、親ひとり子ひとりの伜にもしもの事があったら、あたしも生きちゃあいられないとか云って、おっかさんは泣いて騒いでいる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお冬の家は親ひとり子ひとりで、その親は拘引されている。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "親ひとり子ひとりでほかには力になってくれる身寄りもないと、彼女は訴えるように言った。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "のらくら者でしたが、老い先かけて楽しみにしておったひとり子でござりますもの。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "播磨　親ひとり子一人ぢや、いつそ此の屋敷内へ引取つてはどうぢやな。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隣りに親ひとり子ひとりの家があって、その父が今度病死したので、せがれは棺を買いに出る時、又その隣りの家に声をかけて行った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銀もそれを深くとがめようとはしなかったが、親ひとり子ひとりの家庭であるから、せがれの帰らない夜はなんとなく寂しい。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分にもこの通りの手狹といひ、親ひとり子ひとりの無人でござりますので、一向にお世話も行きとゞきませぬ。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光は合掌し祈るような敬虔な心で、ひとり子平一郎の成長を見まもらずにいられなかった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親がひとり子の遠い旅を思う心情は一とおりでないのだが、天の群鶴にその保護を頼むというのは、今ならば文学的の技巧を直ぐ聯想するし、実際また詩的に表現しているのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは、ひとり子の隆夫少年に昔から甘くもあったが、また隆夫少年ひとりをたよりに、さびしく暮して行かねばならない気の毒な婦人でもあった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銀と、弁信と、二個の生命が、ともかくも無事でここへ現われて来たのが夢でない以上は、つづいて、もう二つの最愛の後妻と、生みの男のひとり子とが、そのあとに続いて来てもよかりそうなものではないか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大王ペンドラゴンのひとり子、金髪の少年スノーバアド（雪鳥）は或る夕がた繁つた山を出はづれた丘に出て西北に限りなくひろがる海を見てゐた。",
              "citation": {
                "source": "北極星",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、親ひとり子ひとりですもの！",
              "citation": {
                "source": "嫁入り支度",
                "author": "ПРИДАНОЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "母ひとり子ひとりというとおり、いま、こうたんかをきったお兼というお婆さんは、この屑竹の母親なのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある僧が道元に問うて言った――自分には老母があって、ひとり子である自分に扶持せられている。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのひとり子をこの世に送り、彼を死よりよみがえらせて明らかな証を我々に示したこの大いなる神を信じないか。",
              "citation": {
                "source": "『偶像再興』序言",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仔細というのは……」　又右衛門の連れあいは、四年ほど前に時疫で死に、いまは親ひとり子ひとりの家内。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "日高川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして馬場のひとりごととは千里万里もかけはなれた、つまらぬ感傷にとりつかれていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩きながら、ひとりごとのようにして呟くのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
