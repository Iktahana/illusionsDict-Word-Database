    "definitions": [
      {
        "index": 1,
        "gloss": "red or gold circle representing the Sun",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとへば西洋の惡魔が、日本では鬼や天狗の類となるし、昔の童話に出る武者修業の豪傑が、今日の新しい童話では、飛行機に乘つて機關銃を撃つたりするところの、科學的武裝をした日の丸太郎の類に變るのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（日の丸太郎やヘナチヨコ鐵砲。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の首まきへ私がいつか教えてやった日の丸を真似てこしらえた小さな日章旗と独逸の旗を二本しかけて返して上げた。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　無数の小さい日の丸の旗を持って、出迎えている、人々の中から一人の女が、ふいに一等卒の柿本の前にとび出した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻想的なといへば幻想的な、子供だましのポンチ繪には、土瓶が鉢卷をして泳いでゐたり、日の丸の扇で踊つてゐたりするのがあるが、ブーブー唸つて走つてゐる自働車などを見れば吹き出したくなる位だ。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まじめであると同時に at home といったような心持ちであるが、しかしそこには自分の頭にある「日曜日の丸善」というものが生ずる幻影はなくてむしろ常住な職業的の興味があるばかりである。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に日の丸の旗のあるのが妙に目に立って見えた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぎさに破れた絵日傘が打ち寄せられ、歓楽の跡、日の丸の提灯も捨てられ、かんざし、紙屑、レコオドの破片、牛乳の空瓶、海は薄赤く濁って、どたりどたりと浪打っていた。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺繍は日の丸の旗であつたのだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の丸の刺繍は簡單であるから、闇のなかで手さぐりしながらでもできるのだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろんぼは、きつと刺繍した日の丸の旗をくれるにちがひない。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺繍は日の丸の旗であったのだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の丸の刺繍は簡単であるから、闇のなかで手さぐりしながらでもできるのだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろんぼは、きっと刺繍した日の丸の旗をくれるにちがいない。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどきは誘われるまま、常連の学生たちと、日の丸行進曲を口笛で吹きつれて坂道の上まで歩き出てみる。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の丸の旗を立って大船一｜艘、海産物積んで、乗出いて、一花咲かせる目的でな、小舟町へ商会を開いた当座、比羅代りの附合で、客を呼ぶわ、呼ばれもしたので、一座に河岸の人が多かったでな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と問ふと少年は元氣よく『あ、私は日本が大好きなんですよ、日本へ皈りたくつてなりませんの、でねえ、毎日／＼日の丸の旗を立てゝ、街で戰爭事をしますの、爾してねえ、日の丸の旗は強いのですよ、何時でも勝つてばつかり居ますの。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、海岸邊の日の丸の旗を押倒して、獅子だの、鷲印の旗なんか立てた處で無益／＼。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日の出づる邊、我故國では今頃は定めて、都大路の繁華なる處より、深山の奧の杣の伏屋に到るまで、家々戸々に日の丸の國旗を飜して、御國の榮を祝つて居る事であらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大佐の家は隙間もなく日の丸の國旗に取卷かれて、其正面には、見事な緑門も出來た。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の処女会の人々がにぎやかに神社の境内を洒掃してゐる、辻々には演習兵歓迎の日の丸がへんぽんとひるがへつてゐる、これもまたわるくない風景だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山家に高くかゝげてある出征の日の丸、ぶらりと糸瓜。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の上に、大きい日の丸の旗が出来ました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "應援團長といふのがあつて、わざと汚い恰好で日の丸の扇子などを持ち、校庭の隅の小高い岡にのぼつて演説をすれば、生徒たちはその團長の姿を、むさい、むさい、と言つて喜ぶのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の丸の小さい旗がほしいって睦子が言うんだけれどもね、ひやりとしたよ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会の日の丸の燈籠である。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭湯日の丸湯と理髪店朝日軒の間の、せまくるしい路地を突き当ったところの空地を、凵の字に囲んで、七軒長屋があり、河童路地という。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の丸湯の煙突は年中つまっていて、たちまち洗濯物が黒くなってしまうのだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅宇しかえ屋の女房は名古屋生れの大声で、ある時、亭主を叱った声が表通りまできこえ、通り掛った巡査があやしんで路地の中まで覗きに来たというくらい故、煙突の苦情は日の丸湯の番台へ筒ぬけだが、日の丸湯の主人はきかぬ振りした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
