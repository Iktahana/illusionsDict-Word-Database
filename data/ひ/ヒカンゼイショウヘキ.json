          "standard": [
            {
              "text": "複雑な輸入手続きや独自の規格設定が、実質的な非関税障壁となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自由貿易を促進するためには、関税の撤廃だけでなく非関税障壁の解消も不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "相手国は、環境基準を厳格化することで新たな非関税障壁を設けてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "通産省と文部省の作ったコンピュータ教育開発センター（ＣＥＣ）のお墨付きを得てＢＴＲＯＮが教育用コンピューターに指定されながら、「それは一種の非関税障壁じゃないの」とのアメリカのクレームを前後して指定取消となったときには、開いた口がふさがらずに医者に駆け込む始末となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
