    "definitions": [
      {
        "index": 1,
        "gloss": "waiting area",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "弁護人控所は人いきれのする程、混雑して居た。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "大審院の控所はなかなかの混雑である。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　程もあらせず、……廊下を急いで、もっとも授業中の遠慮、静に教員控所の板戸の前へ敷居越に髯面……というが頤頬などに貯えたわけではない。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて言う通り静にしているように、と言聞かしておいて、精々落着いて、まず、あの児をこの控所へ連れ出して来たんだ。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこそと天にも昇る心地にて、控所に伴われ行きしに、典獄署長ら居並びて、謹んで大赦文を読み聞かされたり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正義会には、私は度々入り度いと思つてゐたのでしたが、その部員が控所にビラを貼つたり、教室に演説に来るところを見ると、多くは如何にもその会員らしい硬骨漢ばかりで、柔弱さうな自分の様子を知つてゐる私は決心がつき兼ねたものでした。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲田は煙管の掃除をし乍ら、生徒控所の彼方の一學年の教室から聞えて來るオルガンの音を聞いて居た。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、廣い控所を横ぎつて職員室に來る福富の足音が聞えた。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――亭乎とした体を真直にして玄関から上つて行くと、早出の生徒は、毎朝、控所の彼方此方から駆けて来て、敬しく渠を迎へる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は千早先生の時間だといふ時は、鐘が鳴つて控所に生徒の列んだ時、その高等科の生徒の顔色で分ります。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分とも経たぬうちに、今度は秋野がその鐘索を引いて、先づ控所へ出て行つた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "控所には、級が新しくなつて列ぶべき場所の解らなくなつた生徒が、ワヤワヤと騒いでゐた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲田は煙管の掃除をし乍ら、生徒控所の彼方の一学年の教室から聞えて来るオルガンの音を聞いて居た。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、広い控所を横ぎつて職員室に来る福富の足音が聞えた。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――亭乎とした體を眞直にして玄關から上つて行くと、早出の生徒は、毎朝、控所の彼方此方から驅けて來て、恭しく渠を迎へる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は千早先生の時間だといふ時は、鐘が鳴つて控所に生徒が列んだ時、その高等科の生徒の顏色で分ります。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分とも經たぬうちに、今度は秋野がその鐘索を引いて、先づ控所へ出て行つた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "控所には、級が新しくなつて列ぶべき場所の解らなくなつた生徒が、ワヤ／＼と騷いでゐた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘンリー……｜Ｓ・Ｃ・Ｂ……」　控所に引きあげた「Ｗ」の選手の間でも、さつきからの観衆の声援から聞き覚えた弘雄の仇名が、さかんに口にのぼつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきは四五人だつたが、いつの間にか待つてゐる人がごたごたして、其処の狭い控所は煙草の煙りで濛々としてゐた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "控所へ来ても他の職員と話しをする気にならん。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑等が先に立って、前に控所であった室の隣の広間をさして、廊下を返って往く。",
              "citation": {
                "source": "余興",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同小南の控所に往って、橋詰が口を開いた。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当分の間は百五十人の新入生に限り、朝毎をかしいぐらゐ早目に登校して、西側の控所に集まつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは入学式の日のことであるが、消魂しいベルが鳴ると三人の先生が大勢の父兄たちを案内して控所へ来、手に持つた名簿を開けていち／＼姓名を呼んで、百五十人を三組に分けた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年前まではこの中学の校舎は兵営だつたため、控所の煉瓦敷は兵士の靴の鋲や銃の床尾鈑やでさん／″＼破壊されてゐた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が経つにつれ、授業の間の十分の休憩時間には、私は控所の横側の庭のクローウヴァーの上に坐つて両脚を投げ出した。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴様は低能ぢやい、脳味噌がないや、なんぼ便所で勉強したかつて……」　学年始めの式の朝登校すると、控所で一と塊になつて誰かれの成績を批評し合つてゐた中の一人が、私を弥次ると即座に、一同はわつと声を揃へて笑つた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは区役所の控所とも、授産場とも、葬儀場ともいえる。",
              "citation": {
                "source": "源泉小学校",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の控所は、東京監獄の大玄関の取りつきの右側で、三間ばかりの奥行をもつたそのたゝきの土間にそふてゐる細長い室であつた。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
