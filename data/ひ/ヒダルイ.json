    "definitions": [
      {
        "index": 1,
        "gloss": "hungry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ミレエは腹が減つて饑いと言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、いつも饑いくらいでよしといたほうがいいんだよ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の眼をいぶかるように、ひだるい山の上の空を眺めることがあった。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "空がひだるいのではなかった、どうにもならぬ飢餓の日々がつづいていたのだ。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼跡の塵堆に僕の眼はくらくらし、ひだるい膝は前につんのめりそうだった。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "息をするのもひだるいような、このふらふらの空間は、ここもたしかに宇宙のなかなのだろうか。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の眼は突張って僕の唇は乾いている、息をするのもひだるいような、このふらふらの空間は……。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひだるい長い路を歩きつづけた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "息をするのもひだるいような、このふらふらの空間に……。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山を眺めて歩いていると、嘗ての、ひだるい、悲しい怒りに似た感情がかえりみられた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤の向は川でその辺まで行くと、この渓流のながめは、ちよつと山の温泉へでも行つたやうな気持をいだかせるのだつたが、ひだるい私は滅多に出歩かなかつた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの路の景色は、いまもまざまざと眼の前に浮かび、あそこを歩いた時のひだるい気持も、まだ消え失せてはゐない。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひだるい足どりで歩いて歩いて行つた路は、まだはるか私の行手にある。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふ訳で、こんな、こんな、ひだるい目にあはねばならないのかしら……食べものに絡まる老婆の哀唱は連綿として尽きないのだつた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼跡の塵堆に僕の眼はくらくらし、ひだるい膝は前にずんのめりさうだつた。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "息をするのもひだるいやうな、このふらふらの空間は、ここもたしかに宇宙のなかなのだらうか。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の眼は突張つて僕の唇は乾いてゐる、息をするのもひだるいやうな、このふらふらの空間は……。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "真暗な長いひだるい悲しい夜の路を歩きとほした。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "息をするのもひだるいやうな、このふらふらの空間……。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山を眺めて歩いてゐると、嘗ての、ひだるい、悲しい、怒りに似た感情がかへりみられた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの靴は僕が上京する時、広島の廃墟の露店で求めたものなのだが、総ゴム底のくらくらする、だぶだぶの靴は、僕のひだるい躯を一そうふらふらさす。",
              "citation": {
                "source": "魔のひととき",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ出したやうに、疲れたゞの、かひだるいだのと制※迦が独語をいふ外には、対話はおろか、一つのことばも反響を起さなかつた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "久太夫は腕組みをしたまま呆然と縁石の傍に佇んでいたが、涙をためた大きな眼で駒三郎のほうへ振返ると、「おれは腹を切るが、ひだるい腹では斬りにくかろう。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども二十銭なり三十銭なりの「ゲ」を貰うことが出来るとさっそくラサ府まで一里半あるところを、ひだるい腹をかかえて麦焦しを買いに行くです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもひだるい腹を抱えて居るところで尊いラマに逢いに行くと、ラマというのは大抵皆金満家ですから昼｜御膳などはなかなか立派なもので、前には乾肉の山が出来て居る位。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "不味い物でも腹一ぱい喰わんで、いつでもひだるい腹を抱えつつ金を溜めて高利貸をして居る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
