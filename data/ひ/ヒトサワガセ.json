[
  {
    "uuid": "9af82254-90bc-564e-94ef-01562133120e",
    "entry": "人騒がせ",
    "reading": {
      "primary": "ひとさわがせ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
