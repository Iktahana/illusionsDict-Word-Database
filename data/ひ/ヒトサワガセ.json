    },
    "definitions": [
      {
        "index": 1,
        "gloss": "person that annoys or causes trouble",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いや、まったく人騒がせの小判だ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新券のインフレになる」「結局金融措置というのは人騒がせだな」「生産が伴わねば、どんな手を打っても同じだ。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に飛んでもない人騒がせをしたことを、非常に恐縮しているらしい彼のおとなしい態度が諸人の感情をやわらげた。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋの町から乗った人もあり、Ｆの町で降りた人もあったが、いずれも平穏無事で、なんの人騒がせをも仕出来さずに終ったので、わたしはひそかに失望しながら車外をぼんやり眺めていると、Ｆの駅の改札口をぬけて、十四、五人の乗客がつづいて出て来た。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは長い間、島に暮らしていて、海や空を毎日ながめていたので、自然に一種の天気予報をおぼえたのだということですが、それはほんとうか、それとも人騒がせのまぐれあたりか、確かなことは判りません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟光は源氏が人騒がせに居所を不明にして、一日を犠牲にするまで熱心になりうる相手の女は、それに価する者であるらしいと想像をして、当然自己のものになしうるはずの人を主君にゆずった自分は広量なものだと嫉妬に似た心で自嘲もし、羨望もしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはただ今考えついたことではなかったのですが、昨年の悲しみがありました時、すぐにそういたしましては人騒がせにもなりますし、それでまた私自身も取り乱しなどしてはと思いまして」　例の命婦がお言葉を伝えたのである。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「およっちゃんは人騒がせに何を言ったんだろう。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人騒がせでも何でも構わない。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫が何のために遁世者の兼好をたずねたのか、それは確かには判らなかったが、大方は和歌の添削を乞いに行ったか、但しは昔物語の講釈でも聴きに行ったか、いずれにしても沙汰なしに出てゆくのは人騒がせであるというような蔭口もきこえたが、ともかくもかれが無事で帰って来ることが確かめられて、どの人の胸も軽くなった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所がらといい、場合といい、深いたくらみがあって、わざわざかように人騒がせいたしたやもあいわからんぞ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "じらさずに、すっぱり吐きなせえよ」「お恥ずかしいことでござりまするが、じつは、一生一度と契り誓いました情人に、金ゆえ寝返りされましたため、思い込んだが身の因果、小判で男の心をもう一度昔に返すことができますものならと、とんだ人騒がせをしたのでござります……」「なにッ、恋が身を焼いたとがですとな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだって、こんな人騒がせやったんだ」「面目ございませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって、火事でもねえのに、そんな人騒がせのことを叫んだら、のされちまいますぜ」「八丁堀の右門様がどなれとお命じになってるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにもあっしが人騒がせをやった当人なんですが、当人でありながらさっぱり見当がつかねえんですよ」「控えろッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなくなったり、消えたり、人騒がせをやりやがるから、むっつりの右門様もちょっと眼を踏みはずしたんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫も殺さぬようなお美しい顔をしておいでなすって、あんまり人騒がせをするもんじゃござんせんよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "人騒がせのあの血をまいたのは、いかにもてまえでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば、いつかは人の口の端にも伝わり、あそこは幽霊屋敷じゃ、血が降るそうじゃとうわさもたちましょうし、たてば養子に来てもない道理、来てがなければやがては実のせがれの三之助も跡を継がれる道理と、親心からついあのような人騒がせをしたのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とんだお人騒がせをつかまつり、恐縮いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、もうなにもかもあいわかったから、そなたの秘密をこのうえ聞こうとはいわぬが、そのかわり爾今けっしてさきほどのような人騒がせのまねはせぬと誓約するか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしゃまた、あんまりだんなが人騒がせなことをきまじめな顔でおっしゃいましたからね、ほんとうに松平のお殿さまをお連れ申そうと思いましたぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "べらぼうめ、なんて人騒がせなまねしやがるんでしょうね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暑いさなかを人騒がせするのにもほどがあらあ、おれが出かけるにもあたるめえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃあの女は何の必要があって、あんな人騒がせな出鱈目を創作して、吾々に恥を掻かせたんでしょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でえ、人騒がせをしやがつて、そんなことでお終ひか、戯談ぢやない。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらないことを言って、夜なかに人騒がせをしちゃあ困るよ。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "洒落や冗談にそんな人騒がせをするような人でないこともふだんから判っているので、父も不思議そうに聴いていましたが、ともかくも念のために見届けようと言って起ちあがりました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
