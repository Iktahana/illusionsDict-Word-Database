    "definitions": [
      {
        "index": 1,
        "gloss": "Ring of Fire (circum-Pacific volcanic belt)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして世界の可死を論じるために水や空気や火の輪廻を引用して種々の地文学的の問題に触れている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミランダは馬の背に乱舞しつつ火の輪を潜る。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロレ　　灰色目の旦が顰縮面の夜に對うて笑めば、光明の縞が東方の雲を彩り、剥げかゝる暗は、日の神の火の輪の前に、さながら醉人のやうに蹣跚く。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と燐寸を擦って、そこで彼は、その火の輪のむこうから僕の顔に驚いた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物に頼んで自分の身体を馬の上に縛らしておいて、自由自在に乗りこなす上に、七尺もあるハードルを飛び越したり、火の輪を潜り抜けたりする中に綺麗に縄を脱けてしまうんです。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この程度がこんなに面白いほど、燈台の火の輪が小さいというわけである。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "首たちは、燈火の輪の中に、一列に、密着して並んでいた。",
              "citation": {
                "source": "鸚鵡蔵代首伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の輪をくぐるのがアイツだよ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは又布地の厚い天幕をくぐって場内へはいったときに、れいの緋羅紗の服でかっきりからだを固めた騎馬の女が、くるくる、火の輪をめぐらし、鞭の音が花火のように輝き音がしていた。",
              "citation": {
                "source": "ヒッポドロム",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹は火の輪を抜ける物凄い芸当、これも油断のならぬ奴で、ある日使い手の頭へ咬みつき二カ所歯を立てて血がほとばしったが、気丈な男ですぐに繃帯したままその日は押し通した。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、燃えている石炭を速く回転させれば、火の輪のイメージを感覚に生じさせ、その回転のあいだに時間の間隔が少しもあるとは思われない。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、総身の毛穴からもえたつ熱気は、焔となって、いまにも、そうほうの切先から火の輪をえがきそうに見える……。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "真白い腕から、火の輪のような一閃が、玄蕃の横へひゅっと飛ぶ。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏林、赤壁の両岸とも、岩も焼け、林も焼け、陣所陣所の建物から、糧倉、柵門、馬小屋にいたるまで、眼に映るかぎりは焔々たる火の輪をつないでいた。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月分新小説に、凡兆が、（涼しさや朝草門に荷ひ込む）趣の、やさしき御催しこれあり、小生にも一鎌｜仕れとのおほせ、ゐなかずまひのわれらにはふさはしき御申しつけ、心得申して候。",
              "citation": {
                "source": "逗子より",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、実は斯く／＼と遠い二十幾年も前の真実を打ち明けて、たとへ一時はけしきを損じようともそれを過ぎれば恐らくお互ひのわだかまりがとけて朗にならう。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは戦ふ時である、戦嫌ひのわたしさへ今日此頃は気が昂る。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざなぎの命の鎮りますひのわかみや（日少宮）は、実在の近江の地から、逆に天上の地を捏ちあげたので、書紀頃の幼稚な神学者の合理癖の手が見える様である。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひのわかみやが、天上へ宮移しのあつたのも、同じく其頃の事と思ふ外はない。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も其いざなみすら、いつか、大空のひのわかみこに遷されて居る。",
              "citation": {
                "source": "万葉びとの生活",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手伝ひのわりあての仕方なども委員会で定める。",
              "citation": {
                "source": "一つの試案",
                "author": "――「列」解消のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たひのわき腹一寸四方」というのもこの手である。",
              "citation": {
                "source": "西園寺公の食道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
