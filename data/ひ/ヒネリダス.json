        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "苦しい家計の中から、子供の修学旅行の費用をどうにか捻り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "多忙なスケジュールを調整し、1日だけ家族旅行のための時間を捻り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "貯金を崩して、ずっと欲しかったヴィンテージのギターを買うための現金を捻り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
