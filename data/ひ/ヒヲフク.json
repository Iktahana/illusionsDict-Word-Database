[
  {
    "uuid": "36851cdd-dcb3-54c9-ae9c-2664c0057493",
    "entry": "火を噴く",
    "reading": {
      "primary": "ひをふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-カ行"
      ],
      "ctype": null,
