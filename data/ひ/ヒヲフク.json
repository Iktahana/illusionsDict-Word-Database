    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to burst into flames",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その鬱積がいまここに火を噴くのだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮鳴を、わたしは、草木と火を噴く山の地動を聴いた。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ白根の山、一たび轟烈爆然火を噴くに當りてや、泥土熱し逸散する所、所在に此慘を現ずるなり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実の生活ではふたたび開かれることのなくなった彼の口が、魯仲連の舌端を借りてはじめて烈々と火を噴くのである。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志よ俺たちへの土産はマクニドゴルスク第二溶鉱炉の火のやうな労働者の意志がどんなに燃えてゐるか敵に対する憤りの激しさを火を噴くうなりのはげしさをはつきりときいてきてくれ。",
              "citation": {
                "source": "小熊秀雄全集",
                "author": "―３―",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを頭の上に差し上げて、「……コレ外道サレッ……」　と大喝しながら投げ出したと思ったが、その時遅く彼の時早く、シューシューと火を噴く黒い爆弾がおやじの手から三尺ばかりも離れたと見るうちに、眼も眩むような黄色い閃光がサッと流れた。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を噴くかと思われた恋敵同士の会見が、意外にも穏かに進行していったので、一座は思わずホッと安心の吐息をした。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けて三時間ほどして風は止んだが、濃みどりの海は、震える山々が火を噴く時に酔ったもののように揺れ止まぬ雪ふかい連山に似て、揺れやまなかった。",
              "citation": {
                "source": "剣のうた",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古振りまで、がらり違ってきて、竹刀の先が火を噴くような激しさ、荒さ。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱗で囲んだ、火を噴く口を、5680竜奴、おこってぱくつかせおる。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "）一寸坊どもがパンの神様をそろそろと5920火を噴く穴の傍へ連れて行きますね。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字からいへば火を噴くとなるけれども、これは燃える火を指すのではない。",
              "citation": {
                "source": "火山の話",
                "author": "今村明恒",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を噴く山としては、この上の焼ヶ岳なんぞも日本の国では、どこへ出しても引けは取らない山ですが、阿蘇とは規模において比較になりませんなあ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "では火を噴く山が近辺にあるのでございますね。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を噴く山から天に舞い上る大蛇のような煙。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば、すでにいつか離反の火を噴く危険を孕んでいる三木城なのだ。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を噴く山と、密林と、一鍬のあともない湖沼や草原と、怪鳥と野獸と、そして文化なく人倫なく原始民のわづかな數がその中に爬蟲類のやうな棲息を營んでゐたに過ぎない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山もまた、いつ火を噴くか知れない性質をもっている。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年前だ、あの頃、正中ノ変と呼ばれた物騒な火を噴く山が、またぞろ、都のまン中で鳴り初めたのさ」「するとまた、宮中ですかい、騒動の因は」「そうよ、天皇さまの御謀反だってえ騒ぎだ。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくに山陽道でも備前、備中の郷士には、いつ火を噴くかしれないような活火山が厳存している。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち、火を噴く活火山のように寄手の上へ降りそそぐ。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ所、べつな所で、また火を噴くおそれはある。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや世界の鳴動も、社会の鳴動もするが、火を噴くまでは、みんなたかをくくっているものだろうか。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりか、一同は悲しさうにうつむいていもばかりを幾日間といふもの食べ続けて、猛烈な胸ヤケに襲はれ、谷川の水をガブ／＼と飲んでは胸をさすり、また腹痛を起す者さへ出来て、終ひには、あんな提言をした私に向つてのろひをふくむ眼を示す者さへ現れたのであつた。",
              "citation": {
                "source": "ビルヂングと月",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、はじめと少し計画を変へたもんだから、あなたをとんだ目に遭はせてしまつて……」　隊長は笑ひをふくんで私を顧みた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくのうちの　おにがはらの　くちへ　はなびを　しかけて　五じから　三十ぷんおきに　ひをふくやうに　します。",
              "citation": {
                "source": "にらめつくらの鬼瓦",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に後ろを振り返つた彼女の視線と、強ひて笑ひをふくんだ安里の視線とが、ぱつたり合つた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、多少、ばつの悪さうな笑ひをふくんだ声で、おれの肩へつかまつて来た。",
              "citation": {
                "source": "放浪者",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは硫黄のやうな匂ひをふくんだもののやうに、火のあかりを受けて、しかも平和に亂れない深い嗜眠のなかにあつた。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "淺吉は嗤ひをふくんだ變なまがつた顏の姿勢を、まともに直しかかり、その睨みぐあひはお咲にはどこに淺吉がこんなちがつた顏付を持つてゐたかとうたがはれるくらゐコワイものがあふれてゐた。",
              "citation": {
                "source": "命",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
