          "literary": [
            {
              "text": "三　まつりの語原今までのところでは、まつりの語原が、あまり説き散されて、よしあしの見さかひもつきかねる程になつてゐる。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まア待ちねえ」と辰つアんは受けて、いが栗頭をぬつと周三の方へ突き出し、「お前さんといふ男が喰つついてるんで、おかみが文句をいやがるんだよ、ひもつきには懲々してるといやがるんだ。",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからひもつきは大嫌ひさ！",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "飾りひもつきの肩章がある、ぴっちりした軍服だ。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            }
          ]
        }
