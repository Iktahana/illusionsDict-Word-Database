[
  {
    "uuid": "da1da56d-7088-529b-bc2b-d86bfed31364",
    "entry": "縹渺",
    "reading": {
      "primary": "ひょうびょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
