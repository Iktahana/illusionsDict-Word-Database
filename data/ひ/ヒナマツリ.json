        "examples": {
          "standard": [
            {
              "text": "初節句を迎える娘のために、祖父母が贈ってくれた立派な七段飾りをリビングに飾ってひな祭りをお祝いした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ひな祭りの日の夕食は、色鮮やかなちらし寿司と、縁起物の蛤のお吸い物を家族全員で囲むのが我が家の定番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼稚園のひな祭り会で、子供たちが一生懸命に練習した「うれしいひなまつり」を歌う姿を見て、成長を実感して涙が出そうになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかもそれが、またよりによって三月の三日、すなわちおひな祭りの当日なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は、ひな祭りの人形に於ても言へるのだ。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから学芸会だの、おひな祭りなどには、講堂の舞台上で活躍をした。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
