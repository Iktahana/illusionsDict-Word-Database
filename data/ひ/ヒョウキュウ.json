    "definitions": [
      {
        "index": 1,
        "gloss": "ice hummock",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして、氷丘のまわりを走って、いかにも僕を待っているかのように立っている、その頂きへまっすぐに登って、その上から見おろしたが、かの白い形をしたものはなんであったか、一向にわからない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡すかぎり白皚皚、まれに見る氷の裂け目か、氷丘の黒い影のほかには、一点のさえぎるものなき一大氷原である。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しげな氷丘と、奇妙な頂端を持って動かない一大氷原が、吾人の周囲につらなるのみである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "低温科学者が簡単に氷丘と称しているこの丘も、シベリアの原住民たちには、神秘の的であったらしい。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水源と氷丘との調査をしているからすぐこいというのである。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
