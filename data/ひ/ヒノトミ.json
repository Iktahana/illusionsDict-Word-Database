    "definitions": [
      {
        "index": 1,
        "gloss": "Fire Snake (54th term of the sexagenary cycle, e.g. 1917, 1977, 2037)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
