          "literary": [
            {
              "text": "それも忽ちひと舐めだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人でひと舐めふた舐めしたと思ったらそれでおしまい。",
              "citation": {
                "source": "ユモレスク",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛は舌を出して、ぺろりとひとなめやりました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ひとなめ牛若が息穴をなめたとたんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯をわかして、竹の皮についたひとなめの味噌を湯にといて飲む。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた元のおゆみさん、胸にエプロンをかけながら、二階の窓をあけに行くと、ほんのひとなめの、薄い富士山が見える。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フハンは主人のほおをひとなめしてから、身を転じてバケツの水をしたたかに飲み、それから主人をさそうもののごとく、顔を見あげた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "火は、その絹のハンカチーフみたいなものを、ひとなめにして焼きつくそうとしている。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつは、昨夜この銀座は焼夷弾の雨をうけて、たちまち紅蓮の焔でひとなめになめられてしまって、この有様であった。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時、寮のどこかに起こった怪火は、折りから暁の風になぶられて、みるみるうちに、数奇をこらした建物をひとなめ……。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころから風勢が強くなり、そのまま神田をひとなめにして日本橋まで焼け、一方は東に延びて、堀江町、小網町、葺屋町の両芝居から、馬喰町、浜町、そこで飛火をして深川の熊井町、相川町、八幡宮の一の鳥居を焼き、仲町辺まで一帯を灰にした。",
              "citation": {
                "source": "ちいさこべ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
