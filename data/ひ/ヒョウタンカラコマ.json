    "definitions": [
      {
        "index": 1,
        "gloss": "something appearing from a place one wouldn't expect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
