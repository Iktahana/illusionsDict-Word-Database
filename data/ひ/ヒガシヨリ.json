        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浅夜に瀟洒な鉄線を組み立てている清洲橋を渡って、人形町の可愛らしい灯の中で青苦い香気のある冷し白玉を喰べ、東京でも東寄りの下町の小さい踊り場を一つ二つ廻って、貝原はあっさり小初の相手をして踊る。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の東寄りを流れる水流の両国橋辺りから上を隅田川と云い、それから下を大川と云っている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺では穏やかでない東寄りの南風が数日来、絶え間なしに吹いているところで、追手の風でも余程自信のある船頭でないと船を出せるものでないことが商売柄千六にはよくわかっていた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "風は東寄りの方向に吹きまわしてはいるが、依然ほんの微風である。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレイヴゼンドへ電報を打つと、先刻通過したとの知らせ、東寄りの風となれば、グッドウィン砂州も通過し今頃はワイト島の程近くに相違ない。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その平野の東寄りの奧に愛鷹山がある。",
              "citation": {
                "source": "樹木とその葉",
                "author": "駿河灣一帶の風光",
                "note": "青空文庫"
              }
            },
            {
              "text": "帳台の東寄りの所で身を横たえている人は前斎宮でおありになるらしい。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　私が台上へ達した時、ラ氏は既に東寄りの手すりへもたれかかって、遠く居留地の方を眺めやっていた。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは町のうしろ東寄りの處で今は桑畑となつてゐる。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅間社の花崗岩の大鳥居の立っている長谷通も、安東寄りの片側はおおむね無事である。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵らは同じ木曾路でもずっと東寄りの宿場の中に来ていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして朝早くから日暮れに近いころまでかかって、東寄りの峠村中の田、塩沢、岩田、それから大戸あたりの稲作を調べに回った。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "また文政九年十二月には、東寄りの方にも本村に接して出村を設け、天保十四年十一月には、天部領小稲荷の地を年二十一石の年貢で天部村から租借し、建家の承諾を得てここにも発展した。",
              "citation": {
                "source": "特殊部落の人口増殖",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶頂は鋸岳といわれている通り岩の痩尾根で、最高所に二、三の石像と其北の少し低い一坪｜許りの平地に三角標石を存するのみであるが、東寄りに五、六町下ると木造のお宮が二つある。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこれは本来ならばバスも通う道路であって、親鸞が稲田から鹿島行方に往返のたび越えたのは東寄りの山路であるそうな。",
              "citation": {
                "source": "加波山",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "国境はそれよりも更に東寄りで、東北に向った切明の跡は密生した若木に閉され、殆んど足の踏み入れようもない。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東寄りに少し木立があるが西から南は開けている。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東寄りの方には矮小な黒檜白檜の一叢が沙漠の沃地を見るが如くに碁布しているけれども、其他は茫々たる草原で、五、六寸から一尺あまりに延びた禾本科や莎草科の植物が吹き募る東南の風に靡いている。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東寄りの岩壁の間の急峻な空谷を草に攫りながら背向きにドッと辷り下りる。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで頂上の東寄りの岩の原が尽きた辺から、矮い偃松の中を下り始めたが路らしいものはない。",
              "citation": {
                "source": "思い出す儘に",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学研究のよろこび　この固い決心のもとにマリーは遠くパリに赴き、姉に遇った上で、東寄りのある町に屋根裏の一室を借り、そこで極度に切りつめた生活を始めました。",
              "citation": {
                "source": "キュリー夫人",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は西の方の築地に佇み、一人は東寄りの角の築地のかげに立っていた。",
              "citation": {
                "source": "姫たちばな",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お一人様は東寄りに、べつのお一人様は西寄りの築地のかげにまいっていられます。",
              "citation": {
                "source": "姫たちばな",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "東寄りの武者窓から雪の手伝った暁の光が射し込んで、屍体の足の下に、その爪先きとほとんどすれすれに、宇治と荷札を貼った茶の空箱が置かれてあるのが、浮かぶように藤吉の眼に入った。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宇治の茶箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "前記のＢ家はそこから四五間東寄りにあって、小栗の住宅に最も近かったのである。",
              "citation": {
                "source": "日本に於けるクリップン事件",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかしらないけど、ゴッタに持ちこんで、汗をかきかき商売をしているわ」「あたしが聞いたところでは、そのへんのところが、ちょっとちがうようなんですけど……西ドイツだなんて言ってるけど、ドイツもずうっと東寄りの、ソヴエットに近いほうに籍があるんだって。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "方向は大槌より南少しく東寄り、釜石沖の方向。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の見送りには、生徒たちは一人も歩廊に入らず、駅から東寄りの線路の柵外に整列して見送る慣例になっていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央部分よりやや東寄りに、エフィニゲウス家の宏大な塋域があり、先程より詳しく申し上げました中尉の墓所は、この塋域中に設けられました。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおかげで、魚が真北からやや東寄りに針路を変えたことが分かった。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
