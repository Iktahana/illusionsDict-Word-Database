        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俺だって一晩中立ち通したかねえからな」「冗談云うない。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩中くらいはかかって燃えそうに見えた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいぼれは一晩中こごんで肝臓を庇っていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま民子が泣きやんでしまえば何のこともなく済んだであろうが、民子はとうとう一晩中泣きとおしたので翌朝は眼を赤くして居た。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子はゆうべ一晩中泣きとおした。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに母に叱られたか……一晩中泣きとおした……なるほどなどと思うと、再び熱い涙が漲り出してとめどがない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一晩中坐つたまま、書いてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは英介氏のむかし馴染みの女友だちがたずねてやってきて、英介氏を郊外の酒場へさそったり、彼女たちのアパルトマンでポーカーを一晩中やったり、英介氏にタキシードを着せてテッフィン（レストラン）に連れだしたりしたからだ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私よりは冷い、親爺に一晩中、くっ付いていた。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして樺の木は一晩中よみ続けました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも昔寄宿舎で浜口雄幸、溝淵進馬、大原貞馬という三人の土佐人と同室だか隣室だかに居たことがある、そのときこの三人が途方もない大きな声で一晩中議論ばかりしてうるさくて困ったというのである。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢も見た事の無え己れにゃ、一晩中ぽかんと眼球をむいて居る苦しみったら無えや。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したら、一晩中だもの。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは僕の前にまっ黒な崖があってねえ、そこから一晩中ころころかさかさ石かけや火山灰のかたまったのやが崩れて落ちて来るんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて気の利かない、間抜けた人だろうと、一晩中眉をひそめていた。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――こんないやな男に……」　一晩中自由にされていたかと思うと、殺してもなおあきたりないくらい、小郷が憎くなって来た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩一晩中君勇につきまとったんですね。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その夜のうちに、どう口説いたか母親を説き伏せ、一晩中掛って荷物をまとめた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になれば、また雨戸が閉って、あの重く濁った空気を一晩中吸わねばならぬのかと思うと、痩せた胸のあたりがなんとなく心細い。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "智子は、一晩中泣き明かして眠らずにいた。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけて、葛飾が一晩中家を明けていたことや、取乱した服装や、そんなことは何れも夫婦喧嘩のせいだとは云うものの、同時にもっと悪い事実を裏書きしていないとも限らない。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩中よんでいられるような長い手紙をかこうと思ったのだ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原の牝狼が、白けた冬の月の下で飢に悩みながら一晩中｜凍てた土の上を歩き廻る辛さを語ることもある。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原の牝狼が、白けた冬の月の下で飢に惱みながら一晩中｜凍てた土の上を歩き廻る辛さを語ることもある。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、その声は山の怪異の呼びかける声で、万一それに応じでもすると、一晩中応答しなくてはならぬが、そんなに長く声の続くものでない。",
              "citation": {
                "source": "死んでいた狒狒",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは君にこのようにお叩頭をしてから、何でも奢るよ」　次の夜が来たときわたしは秋雄を避けてさめ／″＼と一晩中泣いた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套の貝ボタンのような雹が野も畑も一せいに叩きつけるさ中を我関せずえんと言うふうに酒宴と踊りが始まりました、娘達の元気な笑声に私はあきれてしまいました、一晩中踊り抜くというのです。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち栄養不良に陥ったが、おまけに雨期になると、早朝から濡れ鼠のまま十時間働いてくたくたに疲れたからだで、着がえもせず死んだようになって丸竹の寝台に横たわり、一晩中蚊に食われているという状態ゆえ、脚気で斃れる者が絶えなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「京ちゃん、明日あたいと踊ってくれ、明日だけは誰とも踊らずに、一晩中あたい一人と踊ってくれ――と言うんだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ツグミも窓の格子の所にとまって、ひとばんじゅう、一生けんめい、おもしろい歌をうたって、気をおとさないようにとはげましてくれました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
