    "definitions": [
      {
        "index": 1,
        "gloss": "back of a stone monument",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "劉夢沢は長崎崇福寺の墓に山陽の撰んだ碑陰の記がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "碑陰に書したものは黒川敬之である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "碑陰にまつくろな土瓶つゝこむ清水かなの一句を刻す。",
              "citation": {
                "source": "礫川記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、碑の正面は光圀の「嗚呼忠臣楠子之墓」の八文字でよいとしても碑陰の文がないのはさびしいといって、この事を老公に献言したのも介三郎であった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "年暮の十日ごろ、碑陰の文は彫りあがった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
