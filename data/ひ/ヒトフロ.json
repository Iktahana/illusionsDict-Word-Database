        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じ鋳掛屋がもしも一風呂浴びてここを通りかかったのだったら、同じ絃歌の音は却って彼の唱歌を誘い出したかもしれない。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者もそこで一風呂あびて室に帰ってつめたいお茶をこくりとのみそれから椽側へ出てあまり栄えもせぬおがせが滝を拝見に出ると、これはまた、さっきの大天狗殿がやはり椅子にすはってシガーをくゆらして滝を見てござったのである。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷笑を浮べ乍ら、Ｔ「いいお湯が沸いてるよ」Ｔ「一風呂浴びてお帰りよ色男」　伊吉口惜し涙。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が、Ｔ「いいお湯が沸いてますよ」Ｔ「一風呂浴びて帰ったら何うですお二人」　　　　　　　　　　　　　　　　　　（Ｆ・Ｏ）８８＝（Ｆ・Ｉ）街道　右門と伝六とおふみと伊吉、江戸へ帰ります。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が、Ｔ「いいお湯が沸いてますよ」Ｔ「一風呂浴びて帰ったら何うですお二人」（Ｆ・Ｏ）88＝（Ｆ・Ｉ）街道　右門と伝六とおふみと伊吉、江戸へ帰ります。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだね、ここは」　良人は浴室で一風呂浴びて来た血色のいい肌へ浴衣に丹前を重ねたものを不器用に着て縁に立ちました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速一風呂浴びて渓流を耳にしながら杯を傾け、寝に付く前四人して浴場へ志ざす。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "……上方のお客が宵寐が覚めて、退屈さにもう一風呂と、お出かけなさる障子際へ、すらすらと廊下を通って、大島屋のお桂様が。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女中部屋でいたせばようございますのに、床も枕も一杯になって寝ているものでございますから、つい、一風呂頂きましたあとを、お客様のお使いになります処を拝借をいたしまして、よる夜中だと申すのに。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わっしゃったで、一風呂敷と夜具包みを引背負って出向いたがよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も朝から一日｜奔走いたので、すっかり憊れてしまって、晩方｜一風呂入ったところが、暑くて寝られんから、ぶらぶら納涼に出掛けて、ここで月を観ていたうちに、いい心地になって睡こんでしまった」「おや、そう。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」　目を見合せ、「可いわ、」　とはたと畳に落して、「私も一風呂入って来ましょう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、お艶様、その御婦人でございますが、日のうち一風呂お浴びになりますと、（鎮守様のお宮は、）と聞いて、お参詣なさいました。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕餉が少し晩くなつて濟んだ、女房は一風呂入らうと云ふ、糸七は寐る前にと、その間をふらりと宿を出た、奧の院の道へ向つたが、「まづ、御一名――今晩は。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、一風呂キヤ／＼と浴び、手拭を絞つたまゝ、からりと晴れた天氣の好さに、川の岸を坦々とさかのぼつて、來日ヶ峰の方に旭に向つて、晴々しく漫歩き出した。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵寐をするにも余り早い、一風呂浴びた後……を、ぶらりと二人連で山路へ出て見たのが、丁ど……狐の穴には灯は点かぬが、猿の店には燈の点く時分、何となく薄ら寒い、其処等の霞も、遠山の雪の影が射すやうで、夕餉の煙が物寂しう谷へ落る。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、お茶、煙草盆、御挨拶は略しまして、やがて持って来た浴衣に着換えて、一風呂浴びて戻る。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうせママのことだから、途中で一風呂浴びてということになるんじゃない……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕餉が少し晩くなって済んだ、女房は一風呂入ろうと云う、糸七は寐る前にと、その間をふらりと宿を出売、奥の院の道へ向ったが、「まず、御一名――今晩は。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "「草鞋をおぬぎになるより、さきへ一風呂。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに一風呂浴びて、お膳で一銚子という、旅では肝心な処ですがね、少々御無理を願いたい事があるんです。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一風呂の浴みに二人は今日の疲れをいやし、二階の表に立って、別天地の幽邃に対した、温良な青年清秀な佳人、今は決してあわれなかわいそうな二人ではない。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は急いで一風呂這入ってくる。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一風呂浴びて好い心持で私が戻つて来てゐると、すぐつゞいてあとから出て来たＢは、「先生方、湯にも入らずにすぐ寝て了つたらしいですね。",
              "citation": {
                "source": "アカシヤの花",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、何うだい、今のうちに皆なで一風呂浴びようぢやないか。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一風呂はいって、汗を流して来るころには、午飯の支度がもうできていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "剰さへ湯加減程よき一風呂に我が身体も亦車上の労れを忘れた。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、きょう両国の小屋が閉ねたのは何刻ごろだ」「御法通り酉刻（六時）そこそこでございました」「それから、お前は真っ直ぐに帰ったのか」「ヘエ、真っ直ぐに帰って、ひとふろ浴びて、一本つけさせたところへ、親分方のおいでで」　五郎八はそういって、薄寒そうに浴衣のえりをかき合せるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
