        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "遠くの大きな銀行ビルディングの屋上に若い男が二人、昼休みと見えてブラブラしている。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると三四人の友達と一緒に僕の側に来ていたジムが、「僕は昼休みの前にちゃんと絵具箱を調べておいたんだよ。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして昼休みが済んだら二つ失くなっていたんだよ。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花尾八幡宮の社殿で昼休み二時間。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼休みの時間に、僕は教室にひとり残って、小山内薫の「芝居入門」を読んでいたら、本科の鬚もじゃの学生が、のっそり教室へはいって来て、「芹川は居らんか！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は幾人かの仲間と一緒に、昼休みの時間に裏山の凹地へ行って、こっそりと煙草をのむ稽古をした。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日ばかり経った日の昼休みに、二人の五年生が三造を無理に裏山につれて行った。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度昼休みの時間なので、大学生や高等学校の生徒や、その他の学生達の列が、通り一杯に溢れていた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまはお昼休みだから、かまわないんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお昼休みの時間をねらって来たんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛭社長は尻尾の装置をもつて、事務能率上の画期的創案なりとして非常な自慢であつた、或る日蛭氏は社長室から何心なく、会社の屋上に眼をやつた、丁度昼休みの時間で、沢山の社員が明るい日光を浴びて街をみおろしながら嬉々としてゐるのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼休みの時間に機械体操につかまつて、もう少しで出来かゝつてゐる「中振り」を一所懸命に練習してゐるところへ組長が来て、「君はこゝに居たのか、さつきから随分探したぜ。",
              "citation": {
                "source": "悦べる木の葉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」先生の用事と云ふと、それに昼休みに呼ばれるといふのは、大概叱られることに定つてゐる……と、一郎は思つたから、可成り厭な気持がして、服に着いた砂をはらひながら、もう一度「ほんとに僕なのか？",
              "citation": {
                "source": "悦べる木の葉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "カギは、おれがもってるから、雨の日に昼休みのたまり場にでもしよう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十九日の昼休み、慶一、高志、ワラ、というＫＷＴＳトリオと、柾生、山崎の五人は、校舎の前庭の日本庭園にある、紫陽花に囲まれた東屋で、丸太のベンチに寝ころがったり、ベンチに足をのせ、背板に腰掛けたり、てんでんばらばらのかっこうで、ビートルズの話をしていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは長田の縄張りで、慶一が昼休みにここへくるのはめずらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志はさっきから、昼休みの歌声喫茶化を、あれこれ批判している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼休みに女工たちは、男工の話し込んでいる所をウロ／＼した。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼休みには、森本と重な仲間が四人同じ所に坐って、もう一度綿密に考えを練った。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と須山にきくと、彼は、自分の方にはまだハッキリと現われていないが、と一寸考えてから最近昼休みなどに盛んに戦争のことなどについてしゃべり廻って歩いている男がいると云った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "僚友会の清川や熱田は、今度の戦争は結局は大資本家が新しい搾取を植民地で行うための戦争であると云って、昼休みに在郷軍人や青年団の職工などゝ議論をした。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼休みの様子をみていると、青年団の「満洲王国」の話は、何んだか夢のような、それは信じていゝのかどうか、若しも本当だとすればいゝがという程度だったが、清川たちの話には臨時工などが賛成だった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　倉田工業の屋上は、新築中の第三工場で、昼休みになると皆はそこへ上って行って、はじめて陽の光りを身体一杯にうけて寝そべったり、話し込んだり、ふざけ廻ったり、バレー・ボールをやったりした。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼休みの時に、彼は語った。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山野と今日昼休みに遊んでたのだらう。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼休みの際などは、誰先立つとなく運動場に一蛇のポロテージ行進が始つて居た。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺は昼休みの時間などに塾の生徒のよく遊びに来るところだ。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトでは働く婦人の健康の特にこの点を注意して、新しく制定された工場の規定では、これまで一時間あった昼休みの外に午前と午後、或る時間内（約五分か十分と覚えている）機械を休止させ、就業中窓をしめているところでは窓をあけ、皆そろって深呼吸と簡単な全身の体操をすることになった。",
              "citation": {
                "source": "昨今の話題を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生や友達の個人的な思い出は抜き、次に印象深いのは、お昼休み前後の光景である。",
              "citation": {
                "source": "思い出すかずかず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　そういう昼休みの時、校舎の、多分北裏にあった、狭い、荒れた花壇は自分にとって忘られないものであった。",
              "citation": {
                "source": "思い出すかずかず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
