[
  {
    "uuid": "63ea6867-097a-52a2-aa57-229a6110f580",
    "entry": "曾",
    "reading": {
      "primary": "ひい",
      "alternatives": [
        "ひ",
        "そう"
      ],
      "is_heteronym": false
    },
    "grammar": {
