    "definitions": [
      {
        "index": 1,
        "gloss": "people",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実際彼の妻のように、良人に対して忠実な奉仕をする女性は、普通の西洋婦人の中にはほとんどなく、これほどまた男が殿様扱いにされる家庭生活も、西洋では考え及ばないことであるから、ヘルンの手紙をよんだ外国人たちが、いかにその日本の友人を羨望したかが想像される。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人の多數の友人たちは、種々の異つた見解から、夫々の意見を語るだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの點から、自分は彼を室生君や佐藤春夫君――その人たちは疑ひもなく詩人である。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に芥川君は、小穴隆一君や堀辰雄君等の、大勢の若い人たちと一緒であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿の或る居酒屋で、商人たちの話を聞いて悲しくなつた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いてゐる人たちも、一樣に皆黒いトンビを着て、田舍者の煤ぼけた樣子をして居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども観衆の大半は、ひょっとしたら、やっぱり侘びしい人たちばかりなのではあるまいか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に外国からやって来た素見の客（たとえば、松岡とか大島とかいう人たち）に対しては、まるでもう処女の如くはにかみ、顔を真赤にしたという話を聞きました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの海岸の城下まちにも、大砲の音が、おどろおどろ聞えて来て、まちの人たちも、生きたそらが無かったのでございましょうが、私は、そんなこととは知らず、ただもう妹のことで一ぱいで、半気違いの有様だったので、何か不吉な地獄の太鼓のような気がして、ながいこと草原で、顔もあげずに泣きつづけて居りました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人たちは私を呼ぶのに佐野次郎左衛門、もしくは佐野次郎という昔のひとの名でもってした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん茶店の人たちも、あのお客は、ただ口が重いだけで、別段に惡だくみのある者でないといふことが判つた樣子で、お客さんのお嫁さんになるひと仕合せですね、世話が燒けなくて、とをばさんに冗談言はれて、私は苦笑して、やつと打ち解けて來たころには、はや十一月、峠の寒氣、堪へがたくなつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこの世の中の人たちは、そんなに容易に敬服などするものでない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、旅行者にとってはのんきそうに見えながらも、帝都の人たちはすべて懸命の努力で生きているのだという事を、この北京の客に説明してやろうかしらと、ふと思った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしから私の家に出入している人たちに、こっそり聞いて廻ったこともある。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人たちは、大いに笑った。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この程度の「キリスト伝」が、外国の知識人たちに尊敬を以て読まれているんなら、一般の聖書知識の水準も、たかが知れていると思った。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし日本の人に、キリストの精神を教えてくれたのは、欧米の人たちであるが、今では、別段彼等から教えてもらう必要も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳壇のいわゆる俳人たちは、彼らの宗匠的主観に偏して、常に俳句を形態上のレトリックでのみ皮相な手法的技巧観で鑑賞するため、句が詩情している本質のポエジイと、その背後にある主観の貫ぬく哲学とを、ややもすれば閑却無視することになるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして単に、近代の抒情詩や美術しか知らない若い人たちでも、こうした蕪村の俳句だけは、思うに容易に理解することができるだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規一派の俳人たちは、詩からすべての主観とヴィジョンを排斥し、自然をその「あるがままの印象」で、単に平面的にスケッチすることを能事とする、いわゆる「写生主義」を唱えたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正岡子規以来、多くの俳人や歌人たちは伝統的に写生主義を信奉しているけれども、芭蕉や蕪村の作品には、単純な写生主義の句が極めて尠く、名句の中には殆んどない事実を、深く反省して見るべきである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの訳を読んだ人たちは、案外原作のつまらないのに失望して不平を言つた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にボードレエルの訳を通じて、ポオの詩を読んでる人たちは、実にはボードレエルの詩を読んでるので、ポオを読んではないのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白樺派の人たちは、トルストイとドストイェフスキイとを竝立させて、文學の二大神樣のやうに崇拜して居た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の讀み方によるドストイェフスキイは、心理上でポオと共通し、思想上でニイチェ、ショーペンハウエルと類縁するところの作家であつたが、友人たちの見たドストイェフスキイは、やはり白樺派の人と同じく、人道主義的に見たそれであつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に詩人たちは、昔に於ても今に於ても、西洋でも東洋でも、常に同じ一つの主題を有する。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この温泉の空気を代表する浴客は、主として都会の中産階級の人であるが、とりわけさうした人たちの若い夫人や娘たち――と言つても、大磯や鎌倉で見るやうな近代的な、中凹みで睫毛の長い表情をした娘たちではない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人たちの伊香保に対する批評は概して可もなく不可もなしといふ所であらう。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう人たちであったかそれはもう覚えていない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆踊りのまだ行なわれている所があればそこにはどこかに奈良朝以前の民族の血が若い人たちのからだに流れているような気がしてしかたがない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
