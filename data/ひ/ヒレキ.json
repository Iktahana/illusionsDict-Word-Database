    "definitions": [
      {
        "index": 1,
        "gloss": "expressing one's opinion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで自分は、諄々として前からの考へを披瀝した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが次の瞬間に湧き上つた気持を直接その看護婦に披瀝した。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神が息子夫妻から衷情を披瀝したらしい言葉を聴いたのは、この姉娘に対する非難めく口振りを通してだけだった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが此等のことについては、他日また別の機會で詳論し、大に君に對する僕の反對意見を披瀝しよう。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評とは云ふものの私は小説家であつて自分の思つたことを最も平凡に披瀝するに過ぎない。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから頼うだお方の手土産を披瀝されたが、そのうちにどこかの干柿があった。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家が自分を築き上げる上にホイットマンから受けた所を、秩序も研究もなく雑然と披瀝しているのに過ぎないのです。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二課　誰でも持つたから頭は考えて分別し、胸は感情を披瀝する。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教によって真心を披瀝し合っているからであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つには生命の前に誠を披瀝して懺悔することである。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてをかしなことには少女の顏は前に默つて西原氏を見惚れてゐたときも、これほど纒綿とした情緒を披瀝するときにも、筋一すぢ表現を換へない。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「諸君、祭司長は、只今既に、無言を以て百千万言を披瀝した。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下はその時の決心を披瀝した言葉である。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふやうに、人に屈せず、人を信ぜぬ彼であつたが、前の養母にも一度｜衷心感謝を披瀝したといふのは、享和元年彼は六十八歳になつたが、この年齢は大阪の歌島稲荷社の神が彼に与へた寿命の尽きる歳であつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、僕ひとり、誠実を披瀝して、僕の希望を述べなければならぬ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ互いに食通振りを披瀝したが、結局、パイナップルの鑵詰の汁にまさるものはないという事になった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家に於いても、ただ二念なく大君の御鴻恩に感泣し、ひたすら忠義の赤誠を披瀝し奉らん純真無垢のお心から、このやうなお歌をお作りになつたので、なんの御他意も無かつたものと私どもには信ぜられるのでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方たづね来し花京君の主唱にて、一燈光あざやかなる下、字を結び、興を探りて、互に吟腸を披瀝しぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから楽堂君が持って生まれた快弁熱語を以て滔々と法政騒動の真相を披瀝すると、黙々として聞いていた翁は、やがて膝の前に拡げられた法政騒動渦中の諸教授の連名に眼を落した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋本左内は、攘夷令降勅の件には関係なかつたので微罪になると思はれてゐたが、彼は、堂々と裁判官に所信を披瀝して退かなかつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この両藩を代表するに足る、西郷と木戸が、腹心を披瀝しあつて、討幕の役割を分担することを決めたのだ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の折に触れて提供する、特異な人物の思想や行動に対して、多少の興味を持ってくれる読者諸君におことわりしなければならないが、私がこれほどの大事件に対して持っていた知識を、早速読者諸君に披瀝しなかったことを、非難しないようにお願いする。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもまた物凄い長文で、全部を此処で朗読する予猶はありませんから、それはまたの機会に披瀝することにして、今日はその雄弁と奇想に満ちた彼自らが云ふところのパロオデイア（詩――比喩の歌？",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは私達が、この二ヶ月ばかりの間で読んだ書物のうちで、私達にこよなき亢奮の夢を誘つたところの数々の著書に就いての感想を披瀝したいのが私の希ひであつたのである。",
              "citation": {
                "source": "三田に来て",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の仕事といふのは官邸の下級吏員から日本の風俗や習慣に就いて質問を享けた場合に、それに就いて知る範囲の常識を披瀝し、また随時彼等にイロハを教授することでありました。",
              "citation": {
                "source": "私の万年筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "断じて披瀝を怕れる自尊心ではない。",
              "citation": {
                "source": "嘆きの谷で拾つた懐疑の花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れを贖う者が後必ず地の上に立たんとのヨブの大信仰の披瀝に対して、天はヨブの罪を顕わし地は興りてヨブを攻めんという（明かにヨブとはいわず、しかし勿論ヨブを意味するのである）。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女等に取り入る一つの手段として、何か一つ自分も相当の知識を披瀝したいものだ――私は、無暗とあせつたが、凡てが夢になるより他になかつた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五六年も前から……」　次郎は、袋の中から絵葉書などを取り出して僅かな見聞を披瀝した。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきの「ハムレツトだつてドンキホーテだつて……」などゝ云つて余の頭の鈍さを披瀝したところで仕方があるまい。",
              "citation": {
                "source": "余の倅に就いて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
