          "standard": [
            {
              "text": "公民権運動では、マーティン・ルーサー・キング・ジュニアが非暴力抵抗を提唱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "非暴力抵抗は、不正義な権力に対抗するための倫理的な手段として用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学生たちは、政府の政策に反対し、座り込みによる非暴力抵抗を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あの、あちらは、キリスト教国なんでしょうから、この――人見　しかし、と同時に、片倉君は、ガンジイなどの影響を非常に受けていて、――つまり、暴力否定、それから、その暴力に対する非暴力抵抗ですか――むしろ、実際的には、キリスト教よりもそちらの方が強いんじゃありませんかねえ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
