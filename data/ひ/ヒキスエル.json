        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（この時、甚吉たち三人の兄弟、あわただしく駆けてくる）甚吉　（甚兵衛に、飛びついて引き据える）この阿呆め！",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は真紀子の手首を持って引き据えるように椅子へ腰を降ろさせると、「やめなさいよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（起ち上る）女　　（いきなり、男の手をつかまへて、そばへ引き据える）駄目！",
              "citation": {
                "source": "恋愛恐怖病（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬之助に繩打って、引き据えるか。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妙の胸ぐら取ってそこに引き据えると同時に、紙のように白い咽喉首に切尖を擬した。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "褐の直垂に頭巾姿の土佐房を大庭に引き据えると、義経は笑いながらいった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風雲」の作者が曲折ある実践によって身につけた階級人としての鍛錬と高まりとは、こんにち竹造を一篇のプロレタリア小説の主人公として自身の前にひきすえるところまで到達した。",
              "citation": {
                "source": "文学における古いもの・新しいもの",
                "author": "――「風雲」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これや清麿の偽物じゃ」「どういたしまして、決して、そんな」「おのれ、まだいうか」　いきなり、百の襟がみをつかんで、畳へひきすえると、うしろの襖へ、「延作、延作」　と、どなった。",
              "citation": {
                "source": "野槌の百",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉行所の門に入って、白洲にひきすえると、夜は明けていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「連れて参りました」　肩から投げ出すように、その弱々しい人夫を、藤吉郎のまえにひきすえると、男は、「おゆるし下さいまし。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
