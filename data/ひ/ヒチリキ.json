[
  {
    "uuid": "9de5258d-71aa-5489-8c60-9dd89672436c",
    "entry": "篳篥",
    "reading": {
      "primary": "ひちりき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
