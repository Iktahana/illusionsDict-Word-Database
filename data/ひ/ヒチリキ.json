    "definitions": [
      {
        "index": 1,
        "gloss": "small double-reed wind instrument used in gagaku (made of bamboo, with 7 holes on top and 2 below)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "物に滲み入るような簫の音、空へ舞い上がるような篳篥の音、訴えるような横笛の音が、互いに入り乱れ追い駆け合いながら、ゆるやかな水の流れ、静かな雲の歩みのようにつづいて行く。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁々坊は熊手をあつかい、巫女は手綱を捌きつつ――大空に、笙、篳篥、幽なる楽。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "声もなき悲願の通夜のすすりなき薄らの闇に深みゆく、あはれ、法悦、いつしかに篳篥あかる谷のそら、ほのめき顫ふ月魄のうれひ沁みつつ夢青む忘我の原の靄の色。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮をあげての簫篳篥、浦安の舞。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形使　笙篳篥が、紋着袴だ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか篳篥などは、いずれあとから擬えたものであろうが、築山、池をかけて皆揃っている。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも篳篥を吹く役にあたる随身がそれを吹き、またわざわざ笙の笛を持ち込んで来た風流好きもあった。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "左大臣の子息たちも、平生の楽器のほかの大篳篥、尺八などの、大きいものから太い声をたてる物も混ぜて、大がかりの合奏の稽古をしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴の音も、笙篳篥の音も、そうかと思うと太鼓の音がどろどろどんどんと伝わりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛の教　　　　　アンリ・ドゥ・レニエいづれは「夜」に入る人のをさな心も青春も、今はた過ぎしけふの日や、従容として、ひとりきく、「冬篳篥」にさきだちて、「秋」に響かふ「夏笛」を。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛の教いづれは「夜」に入る人のをさな心も青春も、今はた過ぎしけふの日や、從容として、ひとりきく、「冬篳篥」にさきだちて、「秋」に響かふ「夏笛」を。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "笙や篳篥の音が始まった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言ひ付けて、漸く氣が付いたやうに袴、羽織を脱ぎ棄て、襟垢の付いた平常の白衣を引ツ掛け、白い帶をグル／＼卷きにして、コロリと横になると、手枕をして、「チヤンヤリホイロ……」なぞと、輕く疊を叩きつゝ、手拍子を取つて、篳篥の樂譜をやり出した。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜燈、旗、天蓋、笙、篳篥、女たちは白無垢、男は編笠をかぶって――清楚な寝棺は一代の麗人か聖人の遺骸をおさめたように、みずみずしい白絹におおわれ、白蓮の花が四方の角を飾って、青い簾が白房で半ば捲上げられ、それを幾町が間か肩にかつぎあげずに静々と柳橋から蔵前通りへと練り歩かれた。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "範実などと云ふ男は、篳篥こそちつとは吹けるだらうが、好色の話となつた日には、――まあ、あいつはあいつとして置け。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すいつちよすいつちよよ、すいつちよよ、初秋の小さき篳篥を吹くすいつちよよ、その声に青き蚊帳は更に青し。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主要な楽器は琴で、之に笛・篳篥が伴つてゐる。",
              "citation": {
                "source": "神楽記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず篳篥の音がした。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初秋の小き篳篥を吹くすいつちよよ。",
              "citation": {
                "source": "そぞろごと",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓、笙、篳篥、琴、琵琶なんぞを擁したり、あるいは何ものをも持たぬ手を膝に組んだ白衣の男女が、両辺に居流れて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に相圖に應じて篳篥の音が加はると見る間に、殿上深く垂れさせられた御簾は、内より二人の茜袍の手に、靜かに捲き上げられる。",
              "citation": {
                "source": "賢所御神樂の儀",
                "author": "羽田亨",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし露伴先生がそれよりもさらに愛敬されたのは寅彦の学問であって、「君に篳篥、笳の談をし、君から音波と物質分子位置の変化との関係をきく」ような静かな清談を楽しみとされたようである。",
              "citation": {
                "source": "露伴先生と科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "簫篳篥に合せてホウホケキヨ――」「止さねえか、馬鹿々々しい」「その梅屋敷の隣に、近頃紫御殿といふのが出來ましたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "からくり屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "で始めにはチベット流の音楽、ちょうど日本の簫篳篥及び太鼓のようなもので行列を整えて参ります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらはまあよい方の仕事で、なお大きな笛や笙篳篥を吹いたり太鼓を打ったり、あるいは供養物を拵えたりするのも、やはり壮士坊主の一分の仕事になって居るのです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ先に笙篳篥、太鼓、大笛、足取りを揃え、その次に金香炉、それは十二、三から十五に至るまでの、チベット人としては最もうるわしい子供ばかりを選り集めて立派な法衣を着せ、五色のシナ縮緬で飾りを付け、其子に例の香炉を持たして香を焚かせて居る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その間には太鼓、笙篳篥、インド琴あるいはチベット琴、笛などいろいろ楽器類及び宝物を持って行くのです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "その詰めたり何かする間にも、笙篳篥のごとき笛を吹き太鼓を打ち、誠に殊勝なる経文を唱えてなかなかありがたく見えて居ります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "山茶花の花びらを舌にのせて息をひけば篳篥ににた音がする。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「笛と蚯蚓と簫ひちりきだよ」小娘はサチ子を見ると改めて顔をしかめて呟いたが、空の袂をふりながらほかの卓子へ移動した。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
