[
  {
    "uuid": "b832932a-cc28-588a-b0b1-0df8a6e3ce83",
    "entry": "必殺",
    "reading": {
      "primary": "ひっさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bringing certain death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "響け猪木の「ダーッ」コール低価格ＳＰＡＲＣ攻勢の彼方にサンの新必殺技の予兆を見る　バクダッドの空に、アントニオ猪木が吼えている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "必殺ワザなんだよ……」「いいから、おやめなさい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか、高志があわてるような、必殺のカードを見つけなければだめだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえに、そんなことが、できるもんか」　必殺のカードでもなんでもなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か十六七の少年を英雄的な情熱に駆り立てて、いわゆる必殺の戦闘をさせた惨虐さは世界を驚かした。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "李林甫の半夜高堂に黙思するや、明日必殺ありしと云ふが如き、豈此間の消息を洩すものにあらずや。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、普通の修業では、到り得ない、必殺の業も、得ているようだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、貴様の、必死必殺の気組の底には、ただ喧嘩慣れた、無頼漢には、応わしからぬ、剣気が蔵されているような気がする。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――現世の栄華を、いのちよりも、魂よりも貴く思う人達から、まず、一ばん大切なものを奪い取って、零落の淵に沈ませ、恥辱をあたえ、さんざんに苦しみ悩ませてから、必殺の刃で、一思いに一命を絶ってやってこそほんとうの復讐なのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それだけ、殺気が充実して、すべての面上、必殺の凄味があふれる。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等の十本あまりの剣には、必死、必殺の剣気がみなぎってはいない。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣道に於ても形式主義の柳生流が全盛となり、勝負第一主義、必勝必殺主義の宮本武蔵の剣法は葬り去られる。",
              "citation": {
                "source": "鉄砲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "信助夫人との間には三間ほどの距離があるのに、目をとぢて、右のアッパーカット、左のフック、左右のストレート、なにぶんフットワークを忘れてゐるから勢ひ余つて前によろめき、よろけたハズミに向きが変つて、全然方角の違ふ虚空に向つて、必死必殺のアッパーカットやフックやストレートを間断なく繰りだしてゐる。",
              "citation": {
                "source": "朴水の婚礼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分では一撃必殺のきびしい桂のつもりであるが、あべこべに自分の命とりになりかねない懸念もあった。",
              "citation": {
                "source": "桂馬の幻想",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、一撃必殺を狙う剣法が農民の手で伝えられても、必ずしも怪しむには当らない。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "一撃必殺を狙う怖るべき実用剣を平和な日々の心からの友としているだけなのだ。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一見、変なヘッピリ腰で、いかにも、野良の百姓がクワやスキの片手間に会得したような風変りなものに見えるから、ヘッピリ腰の百姓剣法などと他流に笑われ易かったらしいが、実はアベコベで、これぐらい真剣勝負だけ考えて、必殺を狙った剣法は珍しい。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その必殺に凝った激しい狙いが、逆にヘッピリ腰の百姓剣法に見えるだけなのだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "息をこらし、眼は血走り、手を握ってギュッと拳をヒザに押しつけ、必死必殺、殺気がこもっているよ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、必殺の気魄がこもり、その一撃のきまるところ、結果は歴々として、あまりの怖しさに身の毛がよだつようであった。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "アネサの必殺の気魄に応じて、静々と現れたミコサマであったが、響きに応ずる自然の構え、一瞬にして応戦の気魄は移っている。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミコサマは充分用意しないうちに、アネサの必殺の気魄に応じて、その瞬間の姿勢のまま一瞬同じ気魄だけ移して構えに変ったから、見た目にはアネサのように充分の構えが出来ているようではないけれども、それがたしかに、構えであるということは分った。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、必殺の闘志は、それぐらいで、失われやしない。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀作さんは、胸をはり、いきを入れて、一｜発必殺の信念をこらしました。",
              "citation": {
                "source": "しらかばの木",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜひとも巷談師の目に必殺の文字をたたきこんでやろうという闘魂歴々たるものがある。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "長文の手紙の作者は必殺の文字に自信があるから、悠々敬称をつけてくれる。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "突きも蹴りも必殺の急所のみ狙うから試合ができない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十三　幻の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる巧妙な術が流行しなかったのはフシギだが、カラテも杖もあまりにも実用的で、必殺の術であるのが、悟道化した武道界に容れられなかったのかも知れない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十三　幻の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「必殺の」と言ひ直してもいいかもしれない。",
              "citation": {
                "source": "三島由紀夫",
                "author": "ナルシシスムの運命",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――そして今や三島由紀夫は、その必殺の「兇器」が、もはや美學的な或る觀念としてではなく、具體的な或る重量と或る鋭さをもつた現實の武器として、したがつて十分な使用價値と目的性とを以て、自分の掌に握りしめられてゐることを發見したのだ。",
              "citation": {
                "source": "三島由紀夫",
                "author": "ナルシシスムの運命",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
