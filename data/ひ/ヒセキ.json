  {
    "uuid": "386f674f-135f-569f-b7c5-3a5fb79e3db3",
    "entry": "ひ石",
    "reading": {
      "primary": "ひせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gangue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "影の如き人ありて、椎を揮ひ石をたゝむが如し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦令ひ石油の火の中も、盥の水の底までも、死なば共にと盟ふたる、恋し雄に先立たれ、何がこの世の快楽ぞ。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「幸ひ石川樣が融通して下すつて研屋の身上を建て直したやうなわけでございます」「どれほどの融通だ」「三千五百兩ほどでございます」「少し大きいな」　いかに公儀御用達でも、三千五百兩は大金です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は米をしよひ石油罐をぶらさげて、此れから又暫く山に入つてゐるのだと云ふ。",
              "citation": {
                "source": "黒岩山を探る",
                "author": "沼井鐵太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
