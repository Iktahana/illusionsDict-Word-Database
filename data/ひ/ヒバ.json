    "definitions": [
      {
        "index": 1,
        "gloss": "dried leaves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「干葉のゆで汁悪くさし」「掃けば跡から檀ちるなり」「じじめきの中でより出するり頬赤」の三句には感官的に共通な連想があるのみならず、空間的排列様式の類似から来る連想がある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "干葉や豆府の滓を売りやしまいし、面桶提げて残飯屋へ行くが可い、馬鹿め。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "門番の癖に生意気な、干葉を売らぬもよく出来た。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "干葉の縄が切れて干葉が散らばってる。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかに江戸以来の干葉湯というのもあった。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は何れも夏の青みを失つて――種類がちがふのかも知れないが――出来のわるい干葉のやうな色をしてゐた。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場で十三時間の労働をしている大衆にとって、また、山ゴボーの干葉を辛うじて食べて娘を女郎に売りつつある窮乏農民にとって、この「紋章」は今日何のかかわりがあるであろうか。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は真黒な干葉と松花のような黄いろい御飯を持ち出した。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いい匂いの干葉だね。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "色彩剥落し畫布半破れたれど珍しければ奉納者の名を見るに、「干葉縣下長柄郡□□□□大字五井、片岡□□米國サンフランシスコ在留せんまつ」とあり。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛の巣、大根の干葉、蜜柑の皮、汚れた折板、空瓶。",
              "citation": {
                "source": "夢幻泡影",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あい、牛蒡の干葉と黒焼の生姜――。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「干葉と生姜の黒焼。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六右衛門という百姓の女房が背戸で菜飯にする干葉を洗っていた。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女郎屋の印象は、私の故郷上州で唄ふ盆踊りの歌「鈴木主水といふ侍は、女房子供のあるその中で、今日も明日もと女郎買ひばかり。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い青空に、濃い白雲がギラギラ光つて、おもひばかりが一杯で、私には、なにが何やら分らない。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、ひばりも、あまり美しい鳥ではありませんが、よだかよりは、ずっと上だと思っていましたので、夕方など、よだかにあうと、さもさもいやそうに、しんねりと目をつぶりながら、首をそっ方へ向けるのでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とジョバンニは高く叫び返しましたがもうザネリは向ふのひばの植った家の中へはいってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまが又かっと明るくなり、二人はむしろに座ってひばりもゐないのに、「ひばり焼げこ、ひばりこんぶりこ、」なんて出鱈目なひばりの歌を歌ってゐました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "からす麦かもわが播けば、　　　ひばりはそらにくるほしく、ひかりのそこにもそもそと、　　上着は肩をやぶるらし。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁眠微けき霜のかけらもて、　　　西風ひばに鳴りくれば、街の燈の黄のひとつ、　　　　ふるへて弱く落ちんとす。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の田のなかにはきっとひばりの巣が三つ四つある。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひばりは降りるときはわざと巣からはなれて降りるから飛びあがるとこを見なければ巣のありかはわからない。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "午后はうちのひば垣をはさんだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに堆肥小屋の裏の二きれの雲は立派に光っていますし、それにちかくの空ではひばりがまるで砂糖水のようにふるえて、すきとおった空気いっぱいやっているのです。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とジョバンニは高く叫び返しましたがもうザネリは向うのひばの植った家の中へはいっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はもりもりかひばをたべてそのたてがみは茶色でばさばさしその眼は大きくて眼の中にはさまざまのをかしな器械が見えて大へんに気の毒に思はれました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんにゃ、ホースケ、蜂でない　そんなら、トースケ、ひばりだか？",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんにゃ、トースケ、ひばりでない。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪のないとき、ねていると、　西風ゴスケがゆすぶるぞ　ホースケ蜂が巣を食うぞ　トースケひばりが糞ひるぞ。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
