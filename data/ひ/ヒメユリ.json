    "definitions": [
      {
        "index": 1,
        "gloss": "morning star lily (Lilium concolor)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
