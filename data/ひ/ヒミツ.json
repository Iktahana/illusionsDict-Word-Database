[
  {
    "uuid": "5230ea43-8978-5a0e-b08c-2d723a26a0df",
    "entry": "秘密",
    "reading": {
      "primary": "ひみつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
