        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軍需成金共が跋扈してゐて、一人静かに書を読まうとか、傷ついた心身を休めようとか、さういふやうなものは問題ではないのだ。",
              "citation": {
                "source": "赤蛙",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、彼等は一人一人静かに舷梯を陸りて行ったが、最後の一人が汽艇に納まったのを合図に、憲兵達はソレッとばかり一斉に跳びかかって、彼等に手｜梏をはめてしまった。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車に乗って来た子供の太股の白さに日光が射していて、微風に蔓草の揺れる間を、切れるようなズボンの折目の正しい紳士が一人静かに歩いて来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱に倚つて一人静観しうる春の夕となつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の清い、石川河の磧に近く庵室をしつらえさせて、昔物語の姫君のように、下げ髪に几帳を立て、そこに冥想し、読書するという富家の女は、石の上露子とも石河の夕千鳥とも名乗って、一人静かに箏を掻きならす上手の名があった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ紅毛人の婆さんが一人静かに戸をあけて女に近より、一封の手紙を出しながら、「読んで見ろ」と云う手真似をする。",
              "citation": {
                "source": "誘惑",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こういう時には、一人静かに酒を飲むがよい。",
              "citation": {
                "source": "聖女人像",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番ビリにおった選手だけが難をまぬがれ、そこからゴールまではたった百米だし、目の前に全部倒れてしまったのをチャンと見届けていらッしゃるから、あせらず、あわてず、一人静々とゴールインあそばす。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人静かにいる時、彼女は、この生活がいつまで続くかという恐怖の塊りであった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――伸子は、夫のいない時、一人静かに家を出て行くつもりなのであった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから一人静かに働き得るのだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに闇の夜更けなど、一人静かに湯に沈んでいると、瀬音は時に、おびやかすような高調子を出す。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうかえってきましたね――と慰められたり憐まれたりしながら、ひとりしずかに自然を観じ人事を観じている。",
              "citation": {
                "source": "故郷〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そのころから圓朝はこの小糸の家の二階で、ひとりしずかに新作噺の構想を凝らすようになった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "その客はほかに誰もよばず、河の見える四帖半でひとりしずかに盃を嘗めていた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きていてひとりでいてぽつんとしていて考える……………………はかなさが身にしみてきていっそ、と……………………苦しみも、佗しみも、悲しみも……ああ、ひとりしずかにいることの佗しさ修治さん！",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
