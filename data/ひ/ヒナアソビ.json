    "definitions": [
      {
        "index": 1,
        "gloss": "playing with dolls displayed on the Girl's Festival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
