        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　ウヘーとその男、平謝り。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時はひどく腹を立てても、結局、娘想いの父は、若い学者の家には、平謝りに謝って、結婚を思い切って貰った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三好様が法螺を吹かれたゆえ、佐助様は逃げておしまいになられました」　三好はかえす言葉もなく、平謝りに謝りながら、楓と連れ立って佐助もとめての旅を続けねばならぬ羽目になったとは、まるで嘘から出た真じゃと、身から出た錆をやがて嘆いた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "万力も幾たびか頭を下げて平謝りにあやまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "『この歌はレコードにもあります、革命歌などと大それた、神かけて嘘は―』歌ひ終ると平謝りにあやまるのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見た松平家の家来たちは、てんでに言葉をつくして平謝りに謝りました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "諄くもいう通り、甚く温順い女で、少し粗匆でもすると顔の色を変えて平謝りに謝まった。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "平謝り２・16（夕）　東京神田の駿河台に大きな病院を持つてゐる広川｜和一氏といふ医学博士がある。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　広川氏が平謝りに謝るのを見て、夫人は漸と気色を直した。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからちっとも不思議には思わないで、そのかわり、ただ平謝りにあやまって行った。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりあなたは撲り殺されたいのですか」　僕はもう平謝りに謝るより他はなかつた。",
              "citation": {
                "source": "飢ゑ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とフランス語で平謝りに謝罪した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、この浪人の唇から漏れた、河原者という一言がぐっと胸にこたえたので、平謝りに謝るのもいまいましかったが、虫を押えて、一歩進み出た。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "客に怒鳴られ、平謝りに詫びてゐる幾を見、少しの落度もないやうにと忙しく走り廻つてゐる幾を見すると、軍治は自分が卑しめられてゐると感じた。",
              "citation": {
                "source": "鳥羽家の子供",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さんに云いつけます」　この言葉で私はすっかりまいってしまい、平謝りに謝った。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月不足で加に乳が無かったもんですから、満二月とはその児も生きていなかったそうですよ――しかし、旦那も正直な人サ――それは気分が優いなんて――自分が悪かったと思うと、私の前へ手を突いて平謝りに謝る。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ取って押えられて平謝りに謝った。",
              "citation": {
                "source": "屍体異変",
                "author": "森於菟",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と八五郎は、宵に申し上げた一萬兩の金を守護して居ただけのことで惡氣があつてやつたわけぢやございません」　平次は平謝りに謝つてをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "幽靈の手紙",
                "note": "青空文庫"
              }
            },
            {
              "text": "彦太は、平謝りに謝った。",
              "citation": {
                "source": "脚",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の「わたしは騙されて吉川家へ来た」という口走りにも、そのときの感情で、多少、母にも云い過ぎがあるかもしれなかったが、しかしそのつど、ヤブ井チク庵の吉益老夫婦は、母をなだめたり、母に詫びたり、ただもう平謝りが常だった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、無理に引っ立てて、玄関へ駈け出ると、媒人は、平謝りに、謝っていた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこの試合は試合というほどな勝負にもならず、船頭は得物とする櫂を相手にとられて、その頭を打砕かれそうになると、平謝りに手をついて謝った。",
              "citation": {
                "source": "剣の四君子",
                "author": "小野忠明",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯々申しわけない」　の一点張りで、時政は、平謝りに謝り通して来たものだった。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからお前の股肱になって働くから」　と誓って、平謝りに弟へ謝って、事件は落着したものだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その者の首を刎ねて、陣中に高札し、足下の冤をそそぐから、胸をなでてくれ給え」　平謝りに謝って、袁術は自分の命惜しさに、前に自分へ向って、兵糧止めを進言した隊中の部将を呼びつけ、理由も告げず縛らせて、「この男です。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもすみません」　と、助教授のからだを抱えるようにして、ひらあやまりにあやまった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十郎は別室で虎にひらあやまり、勘当の弟を見てやらなければならないので訪ねることのできなかった事情を説明して、「五郎がここへ居候ときまれば安心だから、五郎を置いてく代りに、お前をつれて曾我へ帰るが、どうだ。",
              "citation": {
                "source": "曾我の暴れん坊",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "くすり屋の主人も、これにはこまったとみえて、ひらあやまりにあやまり、酒を五しょうに、にわとりとさかななどをお礼としてだしました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁を焚いても、煙は出ますさかいにちっと辛抱してもらわな困ります」　責任者が平身低頭ひらあやまりにあやまるものだから、菊子嬢の一行もすぐ引上げた。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
