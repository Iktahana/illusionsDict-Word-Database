    "definitions": [
      {
        "index": 1,
        "gloss": "outward sign",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ロダンさんは希望に輝いて妾の肉体に表徴される内部的な動きを描き出したのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛮地では人煙が稀薄であり、聚落の上に煙の立つのは民の竈の賑わえる表徴である。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、日本海海岸には目立たなくて太平洋岸に顕著な潮汐の現象を表徴する記事もある。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は歸らざるか　　この「胡弓」は戀を表徴してゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちニイチェの比喩で言えば、美術はまさに智慧の女神アポロによって表徴されてる、端麗静観の芸術である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍より先は刀剣で剣の巻など名刀の威徳を述べて、これさえあれば天下治まるように言いおり、また弓矢を武威の表徴のごとく言った。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "上古の人が遺した石製の斧や槌は雷斧、雷槌など欧亜通称して、神が用いた武器と心得、神の表徴とした。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、自分の云う感覚と云う概念、即ち新感覚派の感覚的表徴とは、一言で云うと自然の外相を剥奪し、物自体に躍り込む主観の直感的触発物を云う。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学上に用いられた感覚なる概念も、要するにその感覚の感覚的表徴と変えられた意味を簡略しての感覚である。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "感覚とは純粋客観から触発された感性的認識の質料の表徴であった。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "官能表徴は感覚表徴の一属性であってより最も感性的な感覚表徴の一部である。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "このため官能表徴と感覚表徴との明確な範疇綱目を限定することは最も困難なことではあるが、しかし、少くとも清少納言の感覚は、あれは感覚ではなく官能が静冷で鮮烈であったのだ。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "新感覚的表徴は少くとも悟性によりて内的直感の象徴化されたものでなければならぬ。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち形式的仮象から受け得た内的直感の感性的認識表徴で、官能的表徴は少くとも純粋客観からのみ触発された経験的外的直感のより端的な認識表徴であらねばならぬ。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って官能的表徴は外的直感が客観に対する関係に於て、より感性的に感覚的表徴より先行し直接的に認識され直感される。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "此のため官能的表徴は感覚的表徴よりもより直截で鮮明な印象を実感さす。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、実は感覚的表徴のそれのごとく象徴せられた複合的綜合的統一体なる表徴能力を所有することは不可能なことである。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の故官能表徴は表象能力として直接的であるそれだけ単純で、感覚的表徴能力のそれのようには独立的な全体を持たず、より複雑な進化能力を要求するわけには行かぬ。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "感覚的表徴は悟性によりて主観的制約を受けるが故に混濁的清澄を持つほど貴い。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、官能的表徴は客観によりて主観的制約を受けるが故に清澄性故の直接清澄を持つほど貴重である。",
              "citation": {
                "source": "新感覚論",
                "author": "感覚活動と感覚的作物に対する非難への逆説",
                "note": "青空文庫"
              }
            }
          ]
        }
