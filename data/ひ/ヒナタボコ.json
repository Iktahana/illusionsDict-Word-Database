        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その湿めらへる声の中覇王樹の蔭に蹲みて日向ぼこせる洋館の病児の如く泣くもあり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかわびしき日向ぼこ物の穂などもはかなさよ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたたかにうち黄ばむ写真屋の古きならびは、半盲目の病児らの日向ぼこをば見るごとく、掲げたる鈍き写真のうちにくはせ者の女役者の顔のみ白く、罎ならぶ※のそば、露台にダアリヤの花ただひとつ赤けれども、なべてみな色もなし、入口の静かなる空椅子のうへに、みよりなき黒猫ぞひとりまた背を高めたる。",
              "citation": {
                "source": "浅草哀歌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹んで慮かるに神の御恵洽かりし太古創造の時代には人間無為にして家業といふ七むづかしきものもなければ稼ぐといふ世話もなく面白おかしく喰て寝て日向ぼこりしてゐられたものゝ如し。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "超絶哲学者の猫が、軒端で日向ぼこりをしながら、どんな思索にふけっていようと、また新聞記者の雀が、路次裏で見た小さな出来事をどんなに大げさに吹聴していようと、彼はそんなことには一向頓着しない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "足下は、街中で咳をして足下の飼犬の日向ぼこりを驚かしたと言うて、或男と鬪爭をした。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生氏は毎日日向ぼこりをして、もつと病人の多い国はないものかなどと考へてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄太君、腹いつぱい食べて、裏で野糞を垂れて、日向ぼこしてうつらうつら、全澄太発揮！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心平静、落ちついて、日向ぼこしつゝ読書。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "日向ぼこしながら読書、これやこの極楽々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪ぎみの働らくいやな日向ぼこ　　　みどり滝見人に水魔狂ひおつ影見しか　　　静廼熱の目に太りぼやけぬ鉢金魚　　　和香女人憎む我目けはしき秋鏡　　　※女等病的神経、憎み憤り、幻影を奔放に言い現する事は、昔の女流俳人には絶無といってよい位である。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると花壇に五六本の白牡丹が今を盛りと咲いていた，その花の下に飼猫の「コロ」が朝日を一杯背中に受けて、つくねんとうずくまッていた「日向ぼこりをしているのか、居睡りをしているのか？",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは誰も誰も日向ぼこりがしたいのだ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪見酒を楽しめない身にも日向ぼこりはできる。",
              "citation": {
                "source": "われらが四季感",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽を礼讃してぞ日向ぼこ倫敦の濃霧の話日向ぼこ伊太利の太陽の唄日向ぼこ一月十一日　友次郎と共に鎌倉駅にて電車を待つ間偶成。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白眼に互に日向ぼこりかな十二月十二日　夜。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまよへる風はあれども日向ぼこ美しく耕しありぬ冬菜畑冬日濃しなべて生きとし生けるもの十二月二十七日　鎌倉俳句会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を見る目細く日向ぼこりかな十二月十二日　横浜キリスト教青年会俳句会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や身を干｜海士の日向ぼこ　　　　朱拙　岩の上か、砂浜か、場所はわからぬ。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の歳時記では「日向ぼこ」は冬と定められているが、必ずしもそう限定するには及ぶまい。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体を乾かしながらの「日向ぼこ」には、冬よりも春の方が適切であろう。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の蠅――年寄りには、障子の桟で　日向ぼこが一等。",
              "citation": {
                "source": "独楽",
                "author": "高祖保",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
