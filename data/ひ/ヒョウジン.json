[
  {
    "uuid": "28bef517-7493-5d00-b179-8c7c19c78af6",
    "entry": "氷人",
    "reading": {
      "primary": "ひょうじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "go-between (in marriage)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "字義をもって論ずると月下氷人でない、竈下炭焼であるが、身躾よく、カラアが白く、磨込んだ顔がてらてらと光る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳にしゃがみながら、七八人ほど泊っていた氷人足は三月なかばに帰ってしまったこと、スキー、スケートは四月始めで終ったこと、躑躅の季節には半月ほど早いこと、つまり今はちょうど山が一番暇な時であることを説明して行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月下の氷人とならむかと云へば、赤らめたる顏を袖にうづむ。",
              "citation": {
                "source": "月の隅田川",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宅氏の家はこの島の神官職を勤むる十数代にわたり、当主其部翁は友人伊勢崎君の為に月下氷人に当るのだそうだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今宵の月下氷人を勤めている杉野｜子爵だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雄は芳子の師として、この恋の証人として一面｜月下氷人の役目を余儀なくさせられたのであった。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今宵の月下氷人を勤めてゐる杉野子爵だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今からお嫁入りの仕度とは殊勝な、どうだね、前川さん、この私の月下氷人じゃァ、ハハハハ、気に入らんというのかな。",
              "citation": {
                "source": "罠を跳び越える女",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月老氷人のなかだちで。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして海底大陸とわが人類との間をむすぶ月下氷人のような役割さええんじていたのだ。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり全身しもやけになった氷人間になっちまうよ。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "月下氷人という役がどんなに難かしいものか、第一課でうんと手を焼いてみるがいいや。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親は頗る喜んで早速この由を先方へ通ずる、そこで、かたの如く月下氷人を入れて、芽出度く三々九度も終ったというわけだ。",
              "citation": {
                "source": "二面の箏",
                "author": "鈴木鼓村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテその結婚の月下氷人は風ダ、それでこんなのを風媒植物と称える。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはその、月下氷人でネ、これからさきは知らんですよ――」　それで深水が笑うと、彼女も一緒にわらった。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白いのはこの日の「月下氷人」格の府知事大久保一翁で、この人はかねて大の刀剣通の、その蒐集する刀の蔵い場に頭を悩めたあげく、束にして四斗樽に刀身を何本も差して、そのぎっしり日本刀のささった樽が、又、橡の下に家中一杯だったという人である。",
              "citation": {
                "source": "ハイカラ考",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "この説を肯定するために先づ知つて置かなければならないのは、井伏は太宰夫妻の月下氷人だといふ一事である。",
              "citation": {
                "source": "井伏鱒二は悪人なるの説",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の記憶に誤りがないならば、それもただ形式的な所謂頼まれ仲人よりはもつと本式の月下氷人であつたやうにおぼえてゐる。",
              "citation": {
                "source": "井伏鱒二は悪人なるの説",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にはそれらの大きな四角い氷の一つが氷人夫の橇から村の道にすべりおちて大きなエメラルドのように一週間もそこに横たわり、通る人々をおもしろがらせた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "合せものゝ離れものと信じているような通り一片の月下氷人でない。",
              "citation": {
                "source": "髪の毛",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子といっても山楽は本当の子ではない、養子であったのだ、しかもその養子の氷人が、やっぱり天下第一の秀吉の直接の口利きであっただけに、養子ではあったが、不肖の子ではなかった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この俺が今日は二組の恋人の月下氷人を勤めた訳だからね」　明智はそういって、心から愉快そうに笑うのでした。",
              "citation": {
                "source": "黒手組",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "島崎さん、いつかの機会には、私を、月下氷人だと言ったくせに、今夜は、人違いなの。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
