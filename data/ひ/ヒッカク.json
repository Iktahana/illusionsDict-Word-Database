[
  {
    "uuid": "d19a0409-754d-55d2-998d-3ce66da77ec0",
    "entry": "引っかく",
    "reading": {
      "primary": "ひっかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to scratch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すなわち、かみつく、引っかく、振り飛ばすというのである。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドカーン」というかな文字で現わされるような爆音の中に、もっと鋭い、どぎつい、「ガー」とか「ギャー」とかいったような、たとえばシャヴェルで敷居の面を引っかくようなそういう感じの音がまじっていた。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラス板の上を釘で引っかくと、骨のずいまで身ぶるいがくるという者もある。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり飛びついて首を羽がいじめにして頭でも足でもかみつきあと足で引っかくのである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々小鳥のようなピーピーという泣き声を出しながらも負けずにかみつき引っかくのである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物置きの戸をはげしく引っかく音がすると思っていると、突然高い無双窓に三毛の姿が現われた。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八っちゃんはむせて、苦しがって、両手で胸の所を引っかくようにした。",
              "citation": {
                "source": "碁石を呑んだ八っちゃん",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう疲れも、暗さも、顔を引っかく小枝のとげも、すっかり忘れてしまうでしょう。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は、ブリキを引っかくような音が耳についてしようがないからなんとかしてくれ、と書いてよこしました。",
              "citation": {
                "source": "キャラコさん",
                "author": "月光曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリキを引っかくような音！",
              "citation": {
                "source": "キャラコさん",
                "author": "月光曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "石切り場にねむろうとして失敗して、それからあとの始末を一とおり話しかけて、やっと五分たつかたたないうちに、園に向かっているドアを引っかく音が聞こえた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとかべをがりがり引っかく音が聞こえた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っかく音が続いた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "両眼が、次第に大きく、まるで飛び出しでもするかのようになっている）……雨が……（ガクガクと立ちあがりかけて、出しぬけに、ほとんど人間の声とは思われない叫び声をあげながら、両手で空気を引っかく）ギ、ギ、ギ、ギャーッ！",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屠りはしないが、引っかくのだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎には五本の爪があっても、俺を引っかくことはできねえんだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらをひっかく鉄の箒め！",
              "citation": {
                "source": "春と修羅　第二集",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある宵の即景名月や糸瓜の腹の片光り（昭和二年十一月、渋柿）　　　　　　　＊　子猫がふざけているときに、子供や妻などが、そいつの口さきに指をもって行くと、きっと噛みつく、ひっかく。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを受け取ったとき、高い（８）うなり声が聞え、つづいて扉をがりがりひっかく音がした。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "投げ出していた足を折りまげて尻を浮かして、両手をひっかく形にして、黙ったままでかかって来たから、僕はすきをねらってもう一度八っちゃんの団子鼻の所をひっかいてやった。",
              "citation": {
                "source": "碁石を呑んだ八っちゃん",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも、何かばりばりとひっかくような音がありましたのでな――」「なにッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "カマがおりてきて坊主と富農の頸をひっかく。",
              "citation": {
                "source": "インターナショナルとともに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡くなったのは、そこの家の長女の配偶で、広島で遭難し歩いて此処まで戻って来たのだが、床に就いてから火傷の皮を無意識にひっかくと、忽ち脳症をおこしたのだそうだ。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて大きなつめでひっかくような音がすると思うと、はじめ真っ黒な雲と思われていたものが急に恐ろしい化けものの形になって、大きなつめを恐れ多くも御所のお屋根の上でといでいるのだということがわかりました。",
              "citation": {
                "source": "鵺",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○パリのメトロ植民地の黒人女をうつ、ひっかく、女がおろされる。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　誰かに彼を紹介すると、彼は顔をそむけ、手を後ろから差し伸べ、だんだん縮こまり、脚をくねらせ、そして、壁をひっかく。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "椅子を爪でひっかく。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、　こりゃ　へにぺにサリーの　ストッキングだね　――　ほれ　にわで　ひっかくから、　かかとが　こんなに　すりきれてさ！",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　タムは　とっても　やんちゃで　やたらと　ひっかくのでした。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども　まわりの　りすたちは　そのうたを　きくと　たばになって　つまさきチミーに　とびかかり、　なぐる、　ひっかく、　きのみの　ふくろを　ひっくりかえす。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
