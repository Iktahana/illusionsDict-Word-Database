          "literary": [
            {
              "text": "ここのところをわが青海流では、死屍水かかずしてよく浮くといって、平泳ぎのこころだ」「それは、よくおとうさんがおっしゃる、あの渾沌未分の兄弟か何かなの」　小初は食後の小楊枝を使いながら父親を弥次った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平泳ぎ、背泳ぎ、両抜手、片抜手、競泳、立ち泳ぎ――等を悉く試みた。",
              "citation": {
                "source": "「或る日の運動」の続き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆるやかな平泳ぎで、沖を見渡したり、渚を顧みたりしながら、人魚のやうに呑気に游泳した。",
              "citation": {
                "source": "「或る日の運動」の続き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の足は、いつの間にか平泳ぎの型で水をかいていた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一はゆっくりと、平泳ぎで高志のほうに向かいかけたが、高志のほうは、軽く抜き手をきって、スタートラインにたどりつくと、水中でターンし、二コースのあたりを、なかば本気で泳ぎはじめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丈夫で御座います」　小虎は然う云いながら、傘を捨て、平泳ぎに掛った。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「案外、近いぞ」　富士男はゆっくりと、得意の平泳ぎをはじめた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方がないから僕はもう立っていることを諦めて平泳ぎをはじめた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なるほど、海水だな）　平泳ぎから立泳ぎになったり、また平泳ぎにかえったり、僕は二十分間ぐらい泳いだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なく僕は平泳ぎをしながら、顔だけは横に寝かして、辛うじて息をつくことが出来た。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いふんどしの子供たちは、犬かきや、蛙泳ぎや、平泳ぎを、唇が青くなつてガタ／＼ふるへるまで、練習します。",
              "citation": {
                "source": "プールと犬",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真赤な毛糸の帽子をかぶり、上品な顔立ちのまだ若い女は、笑うような顔でゆっくりと平泳ぎをしていた。",
              "citation": {
                "source": "はやい秋",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて浮かび上がってきた女はかなり沖まで進んでおり、平泳ぎでさらに先へ進もうとしている。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうち、僕は平泳ぎをしている。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "平泳ぎのままペースを上げていき、やがて抜き手へと変えていく。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "平泳ぎで縦に何往復かしてみることを、裕一は亜紀子に提案した。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の底を平泳ぎで進みながら、ふたりは手をつないでみた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
