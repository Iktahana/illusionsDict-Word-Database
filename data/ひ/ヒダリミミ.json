          "literary": [
            {
              "text": "されど、わが左耳聾せるが爲に、はつきりと答聲の起る處を知るに由なし。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "左耳下にこぶがあるからには、まさしくそれが泥斎にちがいない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "くたばれッ」と岡田の左耳から頬にかけ、力一杯、横なぐりした。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤紫に膨脹した左耳に毒々しい銀蠅が群がってたかりだした。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが左耳は、幾んど聾す。",
              "citation": {
                "source": "狹山紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾丸は、左耳下から這入っている。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか狡猾なまた向う見ずな、左耳の無いこの男が、広東でどういうことをしたかは、別な物語に属する。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の左耳と背中の傷も、かすかな傷あとをのこしていまはなおつています。",
              "citation": {
                "source": "いまだ癒えぬ傷あと",
                "author": "――放射線火傷で右手をうしなつた木挽きの妻と河原にうつ伏せて死んでいた幼女に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまったと思って左耳へ持って行くと果して止まっている。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左耳が聞えないブライアン・ウイルスンが、いとこのマイク・ラヴとアマチュア・バンドをつくり、ブライアンのふたりの弟、カールとデニスがそこに加わり、さらにアル・ジャーディーンが入った。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
