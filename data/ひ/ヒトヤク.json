[
  {
    "uuid": "899addde-adf1-5f99-b1c7-e5a198b4fee7",
    "entry": "一役",
    "reading": {
      "primary": "ひとやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
