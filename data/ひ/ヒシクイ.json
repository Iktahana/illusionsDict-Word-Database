        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　軸削機をがちゃ／＼ならして、木枠に軸木を並べている房鴻吉に、彼は、なでるように笑ってみせた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹を放つ者は鶴を獲たり鴻を獲たりして喜ぼうと思って郊外に出るのであるが、実は沼沢林藪の間を徐ろに行くその一歩一歩が何ともいえず楽しく喜ばしくて、歩※に喜びを味わっているのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "右には染谷の岬、左には野井の岬、沖には鴻島が朝晩に変った色彩を見せる。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちぎれかかった雨雲の尾は鴻島の上に垂れかかって、磯から登る潮霧と一つになる。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物と聞く切干大根の甘いにほひをなつかしんで、手製ののり卷、然も稚氣愛すべきことは、あの渦卷を頬張つたところは、飮友達は笑はば笑へ、なくなつた親どもには褒美に預からうといふ、しをらしさのおかげかして、鴻の臺を向うに見る、土手へ上ると、鳴く、鳴く、鳴くぞ、そこに、よしきり。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は我が蒙りたる黙示の鴻大なるによりて高ぶることの莫からんために肉体に一つの刺を与えらる。",
              "citation": {
                "source": "パウロの混乱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家に於いても、ただ二念なく大君の御鴻恩に感泣し、ひたすら忠義の赤誠を披瀝し奉らん純真無垢のお心から、このやうなお歌をお作りになつたので、なんの御他意も無かつたものと私どもには信ぜられるのでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "官｜之を悪みて賽児を捕えんとするに及び、賽児を奉ずる者｜董彦杲、劉俊、賓鴻等、敢然として起って戦い、益都、安州、るに、刀刃入る能わざりければ、已むを得ずして復獄に下し、械枷を体に被らせ、鉄鈕もて足を繋ぎ置きけるに、俄にして皆おのずから解脱し、竟に遯れ去って終るところを知らず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の道に押掛の客というも有るが、これが真個の押掛けで、もとより大鎧｜罩手臑当の出で立ちの、射向けの袖に風を切って、長やかなる陣刀の鐺あたり散らして、寄付の席に居流れたのは、鴻門の会に樊※が駈込んで、怒眼を円に張って項王を睨んだにも勝ったろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また遥か後になつて小網町に鴻の巣が出来「メエゾン、コオノス」と称して異国がつた。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鴻臺」といふ酒薦の銘が大形に向河岸の屋根を蔽うてゐる。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "原口の瀧、いはれあり、去ぬる八日大雨の暗夜、十｜時を過ぎて春鴻子來る、俥より出づるに、顏の色慘しく濡れ漬りて、路なる大瀧恐しかりきと。",
              "citation": {
                "source": "逗子だより",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして背を屈めて立った処は、鴻の鳥が寝ているとしか思われぬ。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "行でませや、おほらかに大御軍、まだ蒙し、遥けきは鴻荒に属へり。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "行でませや、おほらかに大御軍、まだ蒙し、遙けきは鴻荒に屬へり。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十五年五月屋根の風見子を奪ろ、子｜奪ろ、鴻の巣の※に硝子が光る。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根の風見子を奪ろ、子奪ろ、「鴻の巣」の窓に、硝子が光る。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴻の巣とは西洋料理屋の名です。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この父子の他、俳優にして香以の雨露に浴したものには、猶市川小団次、中村｜鴻蔵、市川米五郎、松本国五郎等がある。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "香以は河原崎権十郎、市川小団次の二人に引幕一張ずつを贈り、芸者おさんに扮した市川米五郎と桜川善孝に扮した中村鴻蔵との衣裳持物を寄附した。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "既掲、頭山、杉山の項にも述べた通り、筑前藩の志士は維新の鴻業後、筑前閥を作る事が出来なかった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の能楽師の如く流祖代々の鴻恩を忘れて、浅墓な自分の芸に慢心し、日常の修養を放漫にする。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御鴻恩は死んでも忘却致しませぬ」「どう致しまして。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろ／＼考へた末、芹澤が真先に立つて、八名の浪士がわざ／＼大坂まで行き、鴻池を脅して二百両借りて戻つた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "西郷隆盛が、「お互に数百年来の御鴻恩、私情に於ては忍び難きことに候へども、天下の大勢かくの如く、全く人力の及ばざるところと存じ候」　と、述懐してゐるのを見ても、当時の実情が分り、その局に当つた岩倉、大久保、西郷、木戸等の苦衷は察せらるべきである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "よき折から京方に対し、関東の武威をあらはすため、都鳥を射て、鴻の羽、鷹の羽の矢を胸さきに裏掻いて貫いたまゝを、故と、蜜柑箱と思ふが如何、即ち其の昔、権現様戦場お持出しの矢疵弾丸痕の残つた鎧櫃に納めて、槍を立てて使者を送らう。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴻の羽の矢を額に取つて、蒼い顔して、頂きながら、武士は震へて居た。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命を軽んずること鴻毛のごとく、約を重んずること鼎に似たり。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴻巣上尾あたりは、暑気に倦めるあまりの夢心地に過ぎて、熊谷という駅夫の声に驚き下りぬ。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "深谷に着きて汽車に打乗り、鴻巣にいたりて汽車を棄て、人力車を走らせて西吉見の百穴に人間の古をしのび、また引返して汽車に乗り、日なお高きに東京へ着き、我家のほとりに帰りつけば、秩父より流るる隅田川の水笑ましげに我が影を涵せり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
