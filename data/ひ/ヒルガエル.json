    "definitions": [
      {
        "index": 1,
        "gloss": "to flutter (in the wind)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "理由のない不安と憂鬱の雰囲気のようなものが菖蒲や牡丹の花弁から醸され、鯉幟の翻る青葉の空に流れたなびくような気がしたものである。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "躯低く、頭禿げて、式ばかりの髷に結いたる十筋右衛門は、略画の鴉の翻るに似たり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体に燃えるぬめりを水で扱き取ろうとして異様に翻り、翻り、翻る。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐに御歩行かと思うと、まだそれから両手へ手袋を嵌めたが、念入りに片手ずつ手首へぐっと扱いた時、襦袢の裏の紅いのがチラリと翻る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「左右へ傾く舷へ、流が蒼く搦み着いて、真白に颯と翻ると、乗った親仁も馴れたもので、小児を担いだまま仁王立。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中立旗が門の所に翻る。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その旗のをかしく風に翻るさま、衣の紐などの如く見えき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "父なる神は、古の畫工の作れる如く羽ある童に擔はれたるにはあらで、その肢體の上、その風に翻る衣裳の上に、許多の羽ある童を載せつゝ、水の上を天翔り給ふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る静かな夕暮時に、屋上の星条旗の翻る音がはた／＼と聞えるかのやうな長閑な芝生の隅で青年は故国の草葺の屋根からの便りを展いてゐました。",
              "citation": {
                "source": "私の万年筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもお揃の、藍色の勝った湯帷子の袖が翻る。",
              "citation": {
                "source": "杯",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍染の湯帷子の袖が翻る。",
              "citation": {
                "source": "杯",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀色の翼が陽をうけて翻ると、金色に光つて、上を下へと、さながら三羽の金翅鳥が戯れてゐるかのやうなきらびやかな長閑さに見えた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その銀色の翼が斜めの陽りをうけて翻ると、遠い熱帯国の空からでも飛んで来た一群の金翅鳥が美しい東の国の長閑なる風のかほる景色に見惚れて、きりきり舞ひをしてゐるかのやうに思はれるのであつた。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "旌旗の翻る処、彼の行動は天馬空を征くの趣があつた。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "近衛府の有名な芸人の舎人で、よく何かの時には源氏について来る男に今朝も「その駒」などを歌わせたが、源氏をはじめ高官などの脱いで与える衣服の数が多くてそこにもまた秋の野の錦の翻る趣があった。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の空に翻る旗差し物、鐘、太鼓、鳴り物の響き、鬨の声、矢叫びの音は、皆この一人当たり一円六十八銭弱の争奪戦のどよめきと見るべきである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の窓下にはクルマの翼に触れる水量を調節するための鎖がつないであり、第二の窓はクルマの軸に油を差す口であり、第三の窓は空に翻る翼の水の切り具合を研究するために技師が半身を乗り出して空を見あげる場所であつた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "翻る袂、乱れる裾、なびく白木綿そっくりだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いゝえ、若し納屋へ帰つてＨさんがゐたら、Ｈさんを誘つて来て貰ひたいと思つて……」「オーライ――」　私は、何か気分が颯爽と翻るのを覚えて返事するやいなや、すた／＼と歩き出してゐた。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に翻る鶴子の髪の毛が彼の頬を打つた。",
              "citation": {
                "source": "陽に酔つた風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏、共産少年少女の野営地を訪問すると、赤い旗が翻る愉快な日かげで、男の子女の子とりまぜの炊事当番が、ジャガ薯の皮むきをやっている光景によくぶつかる。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "峰から峰へとぶのに、弁天様の着物のように沢山の襞や色どりが翻るようなのだ。",
              "citation": {
                "source": "読者の感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワのメーデーは、あの賑やかさと、全市に翻る赤旗の有様だけでもほんとに見せたいようだが、次の日の五月二日は休みだ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十月」は、翻る赤旗とともに、すべてこういうプロレタリア、農民への重石をはねのけ、猛然と文盲撲滅をはじめた。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの村に赤旗が翻ると、もうそこには、村のクラブと文盲撲滅の学校が出来た。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "間断なき週間制によって、五日週間を働くようになった一般勤労者は、職場職場で、生産能率増進のウダールニクを組織し、家へかえる道々には、例えばモスクワ市立銀行の屋根に、赤く翻るプラカートを見た。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根に赤旗の翻る一軒の民家には村ソヴェトが組織されていた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワルシャワのメーデー」「スモーリヌイに翻る赤旗」そのほかは、かえって来てから一九三一年にかかれている。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第八巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菖蒲の節句は男の節句、矢車のカラカラと高笑いする空に真鯉、緋鯉、吹流しの翻るも勇ましく、神功皇后、武内大臣の立幟、中にも鍾馗の剣を提げて天の一方を望めるは如何にも男らしい。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "六祖｜慧能かつて二僧が風に翻る塔上の幡を見て対論するのを見た。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
