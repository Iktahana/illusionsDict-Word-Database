[
  {
    "uuid": "3de7c9f9-a48c-5869-94c1-466103dd760b",
    "entry": "翻る",
    "reading": {
      "primary": "ひるがえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
