    "definitions": [
      {
        "index": 1,
        "gloss": "council (consultatory, advisory)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
