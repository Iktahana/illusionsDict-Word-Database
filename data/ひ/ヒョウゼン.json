[
  {
    "uuid": "ccc27b48-bd03-5cba-85d1-b2af5c777fdc",
    "entry": "飄然",
    "reading": {
      "primary": "ひょうぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞-と",
