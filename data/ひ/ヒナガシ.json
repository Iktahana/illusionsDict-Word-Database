        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雛祭りのお供えとして、色鮮やかな菱餅や雛菓子を仏壇にも供えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "金平糖やゼリーが入った可愛らしい雛菓子は、子供たちに大人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "和菓子屋の店頭には、この時期ならではの繊細な細工の雛菓子が並ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　……包みもしないで――翠を透かして、松原の下り道は夕霧になお近いから――懐紙に乗せたまま、雛菓子のように片手に据えた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ去年あったような赤や白や黄や水色や茶や、五色のお砂糖の雛菓子のように飾り立てたお菓子屋は、さすがに今年は六月の時も今度も見当たりませんでした。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁語に巧を弄せんよりは、真率に言ひながしたるがよほど上品に相見え申候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁語に巧を弄せんよりは眞率に言ひながしたるが餘程上品に相見え申候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑ひながしてゐるのも樂なしぐさではない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
