[
  {
    "uuid": "48f58187-2766-55f1-b7ec-db3483aa4140",
    "entry": "秘蔵",
    "reading": {
      "primary": "ひぞう",
      "alternatives": [
        "ひそう"
      ],
      "is_heteronym": false
    },
    "grammar": {
