[
  {
    "uuid": "91de55ca-8e9a-52d8-9f5b-949cb6717d75",
    "entry": "披露目",
    "reading": {
      "primary": "ひろめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
