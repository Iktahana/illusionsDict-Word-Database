          "literary": [
            {
              "text": "それから水夫を二百人集めておもらいなさい。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、叔父さんにも相談したが、叔父さんは、いまはそんな人集めの出来る時代では無いと言っていた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「紐育生れの御婦人が一人して持つてらつしやる色々な美点は、故郷の女では三人四人集めなければ得られないからなんですよ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "莫愁湖の畔にもの寂びた堂があり、そこでは付近の子供を二、三十人集めて寺子屋のような学校がひらかれていた。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "美作守の御勘定奉行｜九津見吉左衞門を初め九里平馬、戸村九右衞門、秋元九兵衞其の他御城下に加賀から九谷焼を開店した九谷正助、菊橋九郎左衞門、年寄役村方で九の字の附いた人を合せて十八人集めまして、結構な御馳走を致し、善い道具ばかり出して、頻りに自慢を致します事で、実に名器ばかりゆえ、客は頻りに誉めます。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜひとも男を五百人、女を五百人集めてくれ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を出ると、「八、關口の子分衆と、下つ引を五六人集めて、あのお妾姉妹と、奉公人達の身許をすつかり洗つてくれ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "彦徳の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれだけありゃ宜いでしょう、親分」「何人集めた」「丁度十人です」「お前を勘定に入れると千十人か」「ヘエ？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "下つ引を五六人集めて、叶屋の奉公人の身許をみんな洗つてくれ」　平次もよく／＼手に餘つた樣子です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "佛敵",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を出ると、「八、関口の子分衆と、下っ引を五六人集めて、あのお妾姉妹と、奉公人達の身許をすっかり洗ってくれ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "彦徳の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "下つ引を六七人集めて、安宅の辨吉と小人の三次郎と、俵右門とを見張らせてくれ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "髷切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "下っ引を五六人集めて、叶屋の奉公人の身許をみんな洗ってくれ」　平次もよくよく手に余った様子です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "仏敵",
                "note": "青空文庫"
              }
            },
            {
              "text": "下っ引を六七人集めて、安宅の弁吉と小人の三次郎と、俵右門とを見張らせてくれ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "髷切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "その開拓時代に、彼等は恭順を示さない土人達を、百二三十人集めて斬殺し、その死体を例の沼地へ投込んだと云う。",
              "citation": {
                "source": "殺生谷の鬼火",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、男座頭を八人集めて土俵へのぼせ、それをおくら一人に取組ませるのだ、一方はめくらだからめくらさがしだが、狭い土俵の上で八人の男、十六本の手、足ともでは三十二本でやられるのだから、いくらめくらさがしだってたまらない、ついにおくらがつかまって手取り、足取り……それは見ていられたものじゃない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと役に立ちまさあ」　マーシは渋ったが、しぶしぶ人集めに行った。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よし、それじゃあ、なるべく大きい強そうな団員を六―七人集めよう。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
