      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to express sudden recognition and being impressed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」渠は思はず膝を打つて喜んだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、時にゃがらりと巫山戯出して、肩へつかまる、羽織の紐を引断る、膝を打つ、擽る。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "車内にはＷ町からＦ町へと客に伴れられて芝居を見物に行く田舎芸者が三人ほど乗つてゐたが、声高に笑つたり、戯談半分に客の膝を打つたりして顫りにわるくはしやぎ立てゝゐた。",
              "citation": {
                "source": "海をわたる",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉を味わって見ると、云うに云われぬ皮肉な意味が出て来て、思わず膝を打つようなところがある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリバー旅行記の小人国や大人国の言葉を参考にして、よしツ、そいつは一ト月のうちに俺が拵へるよ、先づ幾通りかの暗号を――」　と森が讚同すると、村井も膝を打つて、「俺は、この附近の地理を験べてから、俺達にとつてだけ所用な個所に古代アテナイの花の名前を引用した符号をつけよう。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐の襟巻がはやり出したときいた缶チヤンは、早速一儲けしようと膝を打つて、此処に養狐事業を計画いたしました。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴左衞　（膝を打つて。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　顔の見えないやうな仕掛けで誰とでも話が出来れば好いんだが――どうかするとそんな馬鹿気た想ひに走ることがあつた樽野は、悦んで膝を打つた。",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速、先生の許へ持つて行くと、篤と目を通して居られたが、忽ち礑と膝を打つて、これでいゝ、その儘でいゝ、生じつか直したりなんぞせぬ方がいゝ、とかう仰有る。",
              "citation": {
                "source": "余が言文一致の由來",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、急に身を起すと、ポン、と膝を打つた。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老婆もおどろいたと見えて、ちょっと矢代の膝を打つ手真似をしてから優しく口に手をあてた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それから、僕の仮説が出発しているのだよ」「成程」検事が思わず膝を打つと、「すると、催眠術かね？",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に作者が案を得た時膝を打つて喜んだらうと思ふのは、その稚兒が男だつたか女だつたか記憶が朧になつて、考へ迷ふところであらう。",
              "citation": {
                "source": "貝殼追放",
                "author": "泉鏡花先生と里見※さん",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは苦い顔をなさりながら、良秀の方をじろ／＼睨めつけていらしつたのが、思はず知らず膝を打つて、「出かし居つた」と仰有いました。",
              "citation": {
                "source": "地獄変",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは苦い顏をなさりながら、良秀の方をじろ／＼睨めつけていらしつたのが、思はず知らず膝を打つて、「出かし居つた」と仰有いました。",
              "citation": {
                "source": "地獄變",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速、先生の許へ持つて行くと、篤と目を通して居られたが、忽ち礑と膝を打つて、これでいい、その儘でいい、生じつか直したりなんぞせぬ方がいい、とかう仰有る。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん」と老人は思い出したように膝を打つ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや寧ろ、官吏や政治家のうちには、相当に膝を打つて感心したものもゐるのであらう。",
              "citation": {
                "source": "“現代風俗”に就いて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが『人道とは人情を盡すの道といふことです』といふと膝を打つて喜びました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがややあって、斜酣があるあると言って膝を打つのだ。",
              "citation": {
                "source": "採峰徘菌愚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういつて、膝を打つ。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己の生活を自然に發展せしめ行く間に、先人及び今人の經驗に逢着して「此處だな」と膝を打つ場合がある。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこの話とピクイック先生が、ある晴れた秋の朝、二階の窓から前の露路を眺めてはたと小膝を打つ場面とをくらべて見る。",
              "citation": {
                "source": "長崎留学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものの半日あまり、枯木寒巌といったていで、半眼をとじながら黙々然々としていたが、お調べも間もない辰刻になると、とつぜんカッと眼を見ひらいて、「〆たッ」　と、膝を打つ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　膝を打つて自分は立ち上つた。",
              "citation": {
                "source": "静かな歩み",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちついた心で四辺を見廻すにつれ、やがてどんな想像も及ばなかったほどの「善いもの」が、いかに自分を取りまいているか……それに初めて気がついて、膝を打つにちがいない。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おろしかたが荒かったので、その動作は膝を打つようにみえ、はたと音がした。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにその大前小前の宿禰が、手を擧げ膝を打つて舞い奏で、歌つて參ります。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の束で膝を打つ姿に、身にまとう祖母めいたひたむきな雰囲気に見とれていた。",
              "citation": {
                "source": "象を撃つ",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
