        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女はどんなに高級なレストランでも、物怖じせず品良く振る舞うことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "淡いピンク色の着物を品良く着こなした彼女は、パーティー会場で一際目を引いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「贈り物をするなら、派手すぎず品良くまとまった包装を選びたいね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "御殿女中上りの老婢に粧装られる二人の厚化粧に似合つて高々と結ひ上げた黒髪の光や、秀でた眉の艶が今日は一点の紅をも施さない面立ちを一層品良く引きしめてゐる。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼がそこへ来た途端に、彼女は品良く身を起すと、一ぱいになった水甕を重そうに片手に下げたまま、ちらりと彼の顔へ眼をやった、そうしていつになく、人懐しげに口元へ微笑を浮べて見せた。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "身なりはかなり上等なもので、濃い青地の中に、細い赤が品良く縞に這入つた背広をきちんと着て、帽子は脱いで背後に組んだ手にぶら提げてゐた。",
              "citation": {
                "source": "青年",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "品良くお願いするわ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
