[
  {
    "uuid": "bfda2046-046d-5f6b-bc74-d332a43b90e0",
    "entry": "干乾し",
    "reading": {
      "primary": "ひぼし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "starvation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "てめえの裏切りが、何人の人間を干乾しにするか、よく考えて見ろ！",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんでてめえらは、干乾しになってしまうところだったんだ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その干乾しになってしまうのを、いったいだれが助けてやったと思ってんだ？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行きたくなくたって、行かなければこっちが干乾しになるじゃないですか？",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「百姓という百姓をみんな干乾しにしちまやあがった悪党でがさあ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩を書いていたところで、一生うだつがあがらないし、第一飢えて干乾しになるより仕方がない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて一家が干乾しは眼の前。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の親爺を乾鰮のように干乾しにして殺した大盗人！",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "この俺までを干乾しにしようとするのかい！",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「化物だから干乾しにもなるまい。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あたしゃ隣家のものなんだが、いつからともなしにこんな空屋へ、あんな狂人が舞い込んで来て、行きなといっても行かないので、かかりあいになるなア厭だけれど、さりとてうっちゃって置けもせず、干乾しにしちゃア可哀そうだと、お飯だけはお斎のつもりで、三度三度供えてやってるのさ」「まあまあそれはご奇特な。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "干乾しにしようって云うのだからな」「都会から入り込んだ薬草採り、今山から行かれてみろ、村方一円火の消えたように、ひっそり閑と寂れてしまう。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ農民の立場に立つて考へたら、あの水源地を二つともとられるつていふことは、立派にわれわれが干乾しになるつていふことだべ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし一人でゐれば、子供は干乾しにしないですむのよ」　この意味は、彼には呑み込めなかつた。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一口にダンサアと言っても色々で、中にゃ立派な人も居るでしようけど――そんな事してたんじゃ一家五人たちまち干乾し。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ものの閑人ぞ、敢て彼を干乾しにはせんとする。",
              "citation": {
                "source": "時の流れ",
                "author": "鈴木大拙",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもを背負って、台所なんぞしやがって、不景気な」「だって、この子を、干乾しにするわけにもゆくまい」　久助は、背なかで泣きぬくお燕をあやしながら、箸や茶碗を洗っていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、麓をぐるりと取巻かれて持久戦と出られたら、たちまち干乾しに見舞われる」「いまは捨てるときでしょう」宋江の説である。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この上はただ濠を深め、柵をかため、長囲を期して、敵を干乾しにするよりほかには」　と、帷幕の智嚢も、前線の部将も、いまは挙って、それにだけ一致していた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この兼好さん、干乾しになっちゃう」「こないだの話の続きをしておくれよ。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのうちにたった一つ、中がからになって、ひぼしになっているひょうたんがありました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "男ども密にいふなり「いひぼしてもてる」とや。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日、六兵衞はひぼしにして、腹をきれいに干して、いっぺん狐汁でもしてみんなで食おうじゃないか。",
              "citation": {
                "source": "狐物語",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひぼしにならなかつたと云ふだけね……」　富岡は釘をさしこまれた気がして黙つて、ゆき子の顔を見た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして置けば、貴様たちは、一月とたたない中に、ひぼしになって死んでしまうぞ。",
              "citation": {
                "source": "犬と笛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままでいれば、ひぼしになるか、病気になるかして、白骨と化してしまうであろう。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのわけは、お前がいなければわしは、地底戦車の中で、腹ぺこの揚句、ひぼしになって死んでしまったことだろう。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とインディアンは門を出ながらいった、「おれたちをひぼしにするつもりか？",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「委員がまだ置かれない前、あの人一人きりで監督してゐました頃には、私たちをひぼしにいたしました。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな奴等あ、一日も早く放り出してしまわないと、フー公、今にお前達ぁひぼしになるよ。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
