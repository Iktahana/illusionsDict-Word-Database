        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隙を窺つて紳士は二足、三足、たぢろぐよと見る間に身を返して一目散、人垣の間を別けて行衞も知れず。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人垣は急に崩れて、大風に偃す野草の如く、芳の通路を拓けども、何分多人數であるから、幾重にも犇犇と垣あり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次も心配して居ると、人垣掻き分け役人が現れた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くワイワイ騒いでる群集（五、六カット程で）カメラ近寄ってその人垣の中から悲鳴が聞える。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時――　人垣が崩れて侍が一人フラフラにされて逃げて来る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人垣の背後で死体を覗き込んで居た一人の船頭がある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那どんも一緒に……」　口々にそう言う人垣を押しわけて四十恰好の婀娜っぽい女房が入って来た。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "往來の人は自動車のまはりに人垣を作つた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は一倍群ったが、向側が崖沿の石垣で、用水の流が急激に走るから、推されて蹈はずす憂があるので、群集は残らず井菊屋の片側に人垣を築いたため、背後の方の片袖の姿斜めな夫人の目には、山から星まじりに、祭屋台が、人の波に乗って、赤く、光って流れた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "按摩の頭は、提灯とともに、人垣の群集の背後についた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野行を待つ右側も、品川の左側も、二重三重に人垣を造って、線路の上まで押覆さる。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女の気持からは、その男は垢っぽい感触を持ってるので、なるべく一人垣を隔てた向うへどうしても置きたかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝の市の見物は、これよりして早や宗右衛門町の両側に、人垣を築いて見送ったのである。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近きわたりの子供二人垣のもとにいよりて物もいはずしてありけり。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで得々と弁じ立てていた当の老人は、顔色を失い、意味も無く子路の前に頭を下げてから人垣の背後に身を隠した。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "互いに後になり先になり、人垣を押しわけ押しわけ伸び上り伸び上りするうちに、先を払う鉄棒の響。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭奢待の芳香、四隣を払うて、水を打ったような人垣の間を、しずりもずりと来かかる折から、よろよろと前にのめり出た銀之丞、千六の二人の姿に眼を止めた満月は、思わずハッと立佇まった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見返りもせずに、裲襠の背中をクルリと見せながら、シャナリシャナリと人垣の間を遠ざかって行った。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ようやくその人垣の背後まで辿り着いたとき、吾平爺はそのいちばん後ろに立っている一人の学生を掴まえて訊いた。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ……」　爺はそう呟いて、その人垣を打ち破って通り抜けようとした。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人垣は交差点の角に空を覆うて建った大百貨店の前から、幾重にもなって街上へ氾濫しているのであった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと言って罵られても言葉を返さずに、人垣の薄れていくところを目がけては車を曳き進めた。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地から醤油、味噌、麦、大豆なんか積んで、船の入る日にゃ、男も女も浪打際へ人垣の黒だかり。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中間は苦々しそうにその人垣を追いくずしている間に、二人の問答はだんだん進行して行った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "競馬場の埒の周囲は人垣で埋った。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が、突然地面の上に現われ出た瓶の山と乳の海とに眼を見張った瞬間に、道の向こう側の人垣を作ってわめき合っていた子供たちの群れは、一人残らず飛び上がらんばかりに驚いて、配達車の方を振り向いていた。",
              "citation": {
                "source": "卑怯者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜店｜商人のまわりには用もない通行人がたちどまって、そこここに人垣をつくっており、夜店などには眼もくれない連中が、両側の人垣の間を、ひっきりなしに次から次へと往き来していた。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも奥には、よほどえらいひとがきている。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも奥には、よほどえらいひとがきてゐる。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなら、ひとがきっと生きている王八（女房をとられた男）と笑うだろう」「王八」ちょっとふくれた春桃は、しかしやはりおだやかに云った。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
