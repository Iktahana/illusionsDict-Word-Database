[
  {
    "uuid": "2f94eb32-31cb-5386-b6de-f644fb06fcf7",
    "entry": "贔屓目",
    "reading": {
      "primary": "ひいきめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
