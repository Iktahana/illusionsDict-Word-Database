  {
    "uuid": "b6859ff6-9e25-558a-9cbc-4ca11d90dcf8",
    "entry": "一飲み",
    "reading": {
      "primary": "ひとのみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
