        "index": 1,
        "gloss": "hour of the Sheep (around 2pm, 1-3pm, or 2-4pm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
