    "definitions": [
      {
        "index": 1,
        "gloss": "a bit of contrivance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
