    "definitions": [
      {
        "index": 1,
        "gloss": "long day (esp. of spring)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ春の日永の殿上の欄にもたれて花散る庭でも眺めているような陶然とした心持になった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日永、半日たつてゐた青いお目々は牡丹をみつめ黝いお鼻は匂ひにぬれて。",
              "citation": {
                "source": "仔牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（いや、えゝと　蜜を吸ふのが日永の仕事　蜂の雀と申します）（おもしろいわ　それ何よ？",
              "citation": {
                "source": "春と修羅　第二集",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日永に生欠伸で鼻の下を伸している、四辻の飴屋の前に、押競饅頭で集った。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二回　魔の日魔の刻送別會――老女｜亞尼――ウルピノ山の聖人――十月の祟の日――黄金と眞珠――月夜の出港　それから談話にはまた一段の花が咲いて、日永の五｜月の空もいつか夕陽が斜に射すやうにあつたので、私は一先づ暇乞せんと折を見て『いづれ今夜弦月丸にて――。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "日永の頃ゆえ、まだ暮かかるまでもないが、やがて五時も過ぎた。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはは……いい質問だ」　紳士はその新聞の死亡広告欄を指して、「ここに、蜂谷重吉の死亡広告が出ているでしょう」「ええ」「元衆議院議員蜂谷重吉昨七月卅一日永眠仕候。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「元衆議院議員蜂谷重吉七月卅一日永眠仕候」　という死亡広告の広告主が自分自身だと昂然として言う男！",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "下　苦労は知らず勉強の徳　汽車もある世に、さりとては修業する身の痛ましや、菅笠は街道の埃に赤うなって肌着に風呂場の虱を避け得ず、春の日永き畷に疲れては蝶うら／＼と飛ぶに翼｜羨ましく、秋の夜は淋しき床に寝覚めて、隣りの歯ぎしみに魂を驚かす。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "村々の蔀、柱、戸障子、勝手道具などが、日永に退屈して、のびを打ち、欠伸をする気勢かと思った。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆は、漆はや、あやかし、こは子らよ生物、かく言ひて一つ反し、二つ反し、たらりとよ、つるりとよ、爺は見てゐつ、春の日永を。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌月蒼き潯陽江の春浅しふなべり低め四つ手張りたるたださへや月の光は霧らふらし四つ手に跳ぬる水の江の魚口あけてぽちりと紅くそめにけり小さき木彫のいつくしき魚魚売り魚売りの爺が日永や、ふち広の菅の編笠、たよたよと担棒かつぎて、はらはらに片手まはして、前籠に魚かすくなき、後の籠魚か多かる。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌菅笠の爺が日永となりにけりになひの籠のうしろさがりに米と雁米つくと、杵は踏みゐつ。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌菅笠の爺が日永となりにけりになひの籠のうしろさがりに米と雁　支那の木彫人形　その三米つくと、杵は踏みゐつ。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも善い事ならいいが、ろくでもねえところなんだから、堪らねえ」　鴉と田螺　麗かな春の日永を、穴から這ひだした田螺がたんぼで晝寢をしてゐました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月七日に昏睡状態に陥り、八日永眠。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日永の淀川づたいを十何里が間。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も家へ退っていてくれ」　源氏が熱心に言うので、大輔の命婦は迷惑になりそうなのを恐れながら、御所も御用のひまな時であったから、春の日永に退出をした。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お仙は自分の夏衣の縫い直しにかかっていたが、日永の針仕事に彼女も倦んで来たらしい、針先も見えないようなだるい眼をして、うっとりと手を休めていた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日永の晝寢にもあきたるにや、遊女二三人、紐帶のしどけなき姿して樓前に草摘むも、山なればこそ。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ垂れ籠めて鬱陶しそうに春の日永を暮している。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも下屋敷に遊んでいて、夏の日永、秋の夜永に、狂訓亭主人の筆の綾をたどって、丹次郎や米八の恋に泣いたり笑ったりしている方が面白いというわけで、武芸を忘れてはならぬという殿様や奥様の教訓よりも、狂訓亭の狂訓の方が皆んなの身にしみ渡ってしまったのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、長閑、暖、麗、日永、朧は春季と定め、短夜、涼、熱は夏季と定め、冷、凄、朝寒、夜寒、坐寒、漸寒、肌寒、身に入、夜長は秋季と定め、寒、つめたしは冬季と定む。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の最長きは夏至前後なり、しかれども俳句にては日永を春とす。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく一定せし上は日永夜長は必ず春秋に用うべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるさとはすつかり葉桜のまぶしさ・やつと戻つてきてうちの水音・わらやしづくするうちにもどつてる・雑草、気永日永に寝てゐませう（病中）　四月三十日久しぶりにようねむれた、山頭火は其中庵でなければ落ちつけないのだ、こゝならば生死去来がおのづからにして生死去来だ、ありがたし、かたじけなし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々へ無事帰庵のハガキを書く、身心がぼーつとしてまとまらない、気永日永に養生する外ない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは広目屋の広告通る○○○○○といふ十二字ならば「春日かな」「日永かな」「柳かな」「桜かな」「暖き」「小春かな」などを置くなり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "時候は立春、暮春、余寒、暖、麗、長閑、日永の類をいふ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "――実は今日三田村さんからお話を聞きまして、とも角それでは御相談に上らうと存じまして……」云ひながら彼は扇子をパチリパチリさせてゐた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
