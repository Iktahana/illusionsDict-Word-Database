    "definitions": [
      {
        "index": 1,
        "gloss": "Hyūga (former province located in present-day Miyazaki Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大学を出て一年ばかり郷里の日向で何をするともなく暮してゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が屋根と屋根との間から落ちる、やつと自分の背幅程の日向に、自分のおかつぱの影を見付けた時に、小僧とお祖母さんの話声が聞え出してゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は早く起き、榊をあげて柏子を打ち、木の香の匂ふ縁側に、日向ぼつこでもしてみるとしたらどうであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分七、八歳くらいの自分と五、六歳くらいの丑尾さんとが門前のたたきの斜面で日向ぼっこをしていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は多分日向に赴く。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまれ今夏日向に赴く時は下車したい。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "今かう書いてゐると日向の方は忘れてしまひさうなくらゐ豊前長州には下りてみたい。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり鏡というものを見る機会のない私は、ある朝偶然｜縁側の日向に誰かがほうり出してあった手鏡を弄んでいるうちに、私の額の辺に銀色に光る数本の白髪を発見した。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く裾野には稻田の黄色い斑の縞模樣が擴がり、其の遙かな向うには名を知らぬ山脈が盛上がつて、其の山腹に刻まれた褶襞の影日向が深い色調で鮮かに畫き出されて居る。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のない日は縁側の日向へ出て来て、紙の折り鶴をいくつとなくこしらえてみたり、秘蔵の人形の着物を縫うてやったり、曇った寒い日は床の中で「黒髪」をひくくらいになった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの経験ではまだ具体的な案は得られないが、適当にやれば、従来なら日影でいじけてしまうような天才を日向へ出して発達させる事も出来ようというのである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が十二月二十五日の午前に帰って見ると、庭一面に籾を干してあって、母は前の縁側に蒲団を敷いて日向ぼっこをしていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "くぢら浪海岸にて孤独田舎の白つぽい道ばたで、つかれた馬のこころが、ひからびた日向の草をみつめてゐる、ななめに、しのしのとほそくもえる、ふるへるさびしい草をみつめる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎のさびしい日向に立つて、おまへはなにを視てゐるのか、ふるへる、わたしの孤独のたましひよ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半分、裸のかしわが、クックッと逃げる情景　支那の老婆が日向ぼっこして、麦わら細工を縫み乍ら兵隊の行軍を見ている。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ閉されてゐる公園の中に、そんな鼠色のなかに一きは目立つ鼠色で、彫像どもが日向ぼつこをしてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと手伝えよ、そんなに日向ぼっこばかりしとらんで。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くそ真面目にかげ日向なくやる者は馬鹿の骨頂である。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源叔父の独子幸助海に溺れて失せし同じ年の秋、一人の女乞食｜日向の方より迷いきて佐伯の町に足をとどめぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが寒い時候にはいつでも袖無しの道服を着て庭の日向の椅子に腰をかけていながら片手に長い杖を布切れで巻いたのを持って、そうしていつまでもじっとしたままで小半日ぐらいのあいだ坊主頭を日に照らしていた。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り向いてみると花壇の前の日向に妙な男が突っ立っていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇が日向ぼっこをしたり、蜥蜴やヤモリがふいにとび出して来る。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでも、醤油屋へ行きたくなくなって、彼は、十時頃まで日向ぼっこをしていた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖へ出てゆく漁船がその影の領分のなかから、日向のなかへ出て行くのをじっと待っているのも楽しみなものだ。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日向はわずかに低地を距てた、灰色の洋風の木造家屋に駐っていて、その時刻、それはなにか悲しげに、遠い地平へ落ちてゆく入日を眺めているかのように見えた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう日向とは思えないそこに、気のせいほどの影がまだ残っている。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "穉いときの古ぼけた写真のなかに、残っていた日向のような弱陽が物象を照らしていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日向へ寢轉べば、そこは常に岬の突角だつた。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "徑を歩いてゆく私の影はすくすくと立つた杉の柱を※折して來る、冬の日よりもまだ弱い日向のなかにあらはれ、木立のなかに消えたり、熊笹の上を這つたりした。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時どき彼らは日向や土の匂いのするようなそこの子を連れて来て家で遊ばせた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
