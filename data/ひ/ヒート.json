        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フエヲ　一ポン　モツテ　イエイエノ　トグチニ　タツテ、ヒロ　ヒロ　ヒート　カナシイ　オトヲ　フルハセ、一セン　二センヲ　モラツテ　タビヲ　シマシタ。",
              "citation": {
                "source": "カナヅチ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "間宮のやりかたのヒートロスチ〔狡猾さ〕よくわかった。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（故アル・ウイルスン、キャンド・ヒート）　黒人のブルース・アーティストが、ボクのブルースを認めてくれる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーバー・ヒートは一度もしたことがない。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンジンのオーバー・ヒートをまねくいっさいの原因が、どこにも見当たらない。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
