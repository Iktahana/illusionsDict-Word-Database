        "examples": {
          "standard": [
            {
              "text": "電車で座っている時、不用意に肘を張ると、隣の人に迷惑がかかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供が食事中に肘を張るので、注意をして座り直させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ちょっと、肘張らないでくれる？窮屈だよ。」「あ、ごめん、つい癖で…。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "to be obstinate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "頑固な彼は、一度決めたことは決して曲げず、常に肘を張っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供のわがままに、親は根負けしないよう、しっかり肘を張って対応する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「何度言っても聞かないな、あの子は。」「ええ、まったく。肘を張って、自分の意見を曲げないんだから。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
