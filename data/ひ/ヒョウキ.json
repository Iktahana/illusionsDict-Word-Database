              }
            },
            {
              "text": "「どうぞ、御ひいきに――」　ペコンと、ひょうきんな恰好で頭を下げたが、しかし、どこか赤井の顔は寂しそうだった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それゃ君、泥棒猫だからさ」と小倉がひょうきんに答えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいかわらずのひょうきん者だな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょうきん口をたたいている場合じゃねえんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あいかわらず、きさまはひょうきん者だな、敬四郎どのの様子が尋常でない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、今のあいつの様子で、事起こるとにらんだのですね」　ひょうきん者のおしゃべり屋ではありましたが、そこはやはり職業本能で、右門のそのひとことで、ぴりっと胸にこたえたものがあったのでしょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六ッ、どうやらまた忙しくなったようだぞ」「えッ、どこかに忍術使いでもいるんですか」「あいかわらずのひょうきん者だな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
