[
  {
    "uuid": "cb719ee8-3e7f-5df8-b99c-01135ad2f687",
    "entry": "人離れ",
    "reading": {
      "primary": "ひとばなれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
