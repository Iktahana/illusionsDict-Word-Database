        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上り初めると蝶ヶ岳が見える、この山もそれに続く熊村岳（宛字）も、谷から渦まき※る飛沫のような霧に、次第に包まれて来る、足許には白花石楠花や、白山一華の白いのが、うす明るく砂の上に映っている。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝙蝠傘の上などに落ちて凍った雨滴を見ると、それが傘の面に衝突して八方に砕け散った飛沫がそのままの形に氷になっている。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると小さい飛沫になって落ちる水は寒い空気に触れ、皆｜氷柱の形になって天井および中段の横木から垂れ遂には地上に達する。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風落ちたれど波なお高く沖は雷の轟くようなる音し磯打つ波砕けて飛沫雨のごとし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "終局の場面でも、人生の航路に波が高くて、舳部に砕ける潮の飛沫の中にすべての未来がフェードアウトする。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蛇と鰐との闘争も珍しい見ものであるが、なにぶんにも水の飛沫がはげしくて一度見せられたくらいでは詳細な闘争方法が識別できにくいのが残念である。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水には落下の性を姿に現したプリムノという仙女と、流暢の性を現したカンリロエという仙女と、清浄を現したアカステという仙女と、飛沫を現したプレキサウレという仙女とが巣付いている。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ水の一部分が時折り形を変えて泡になったり、飛沫になったりするだけです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の根岩角に手をかけ、足を踏みしめて、ようよう飛沫雨のごとき中に下り立ちて、巨巌の上へ登り、海内無双の大瀑布、華厳の雄姿を眺めた時には思わず快哉三呼。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "響は忽ち海上に當つて、天軸一時に碎け飛ぶが如く、一陣の潮風は波の飛沫と共に、サツと室内に吹付けた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "風上にいる者は雨の飛沫を受けるだけで我慢もなるが、風下にいる連中は渦巻く煙に咽び返って眼玉を真赤にし、クンクン狸のように鼻ばかり鳴らしている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "目前の敵を殪し得た忠一は、先ずほッと一息｜吐くと共に、俄に渇を覚えたので、顔に浴びたる血の飛沫を拭いもあえず、軒の外へひらりと駈け出して、吹溜りの雪を手一杯に掬って飲んだ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳には牛九郎老人の枕元に血飛沫がかかっているだけで、ほかに何の異状も認められないところを見ると、二人の寝息を窺った犯人は、大胆にも電燈を灯けるか何かして蚊帳の中に忍び入って、二人の中間に跼むか片膝を突くかしたまま、右と左に一気に兇行を遂げたものらしい。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏の足掻きの雪の飛沫から小さな虹が輪になって出滅する。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "床と云わず、四方の壁と云わず、あらゆる反物の布地の上に、染めと織りと繍いと箔と絵羽との模様が、揺れ漂い、濤のように飛沫を散らして逆巻き亘っている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "速力計の針が六十五｜哩と七十哩の間をちらちらすると、車全体が唸る生きものになって、広いアスファルトの道は面前に逆立ち、今まで眼にとまっていた榕樹の中の草葺きの家も、椰子林の中の足高の小屋も、樹を切り倒している馬来人の一群も、総て緑の奔流に取り込められ、その飛沫のように風が皮膚に痛い。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空間にあへなき支点を求めて覚束なくも微風に揺られてゐる掻きつき剰つた新蔓は、潮の飛沫のやうだ。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段又一段と落ちて来て、千の流になり万の流になり、飛沫を高く空中にあげている。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　先生は、力のかぎりめちゃくちゃに茶筌で掻きまわしたものらしく、三畳間は薄茶の飛沫だらけで、そうして、しくじってはそれを洗面器にぶちまけていたものらしく、三畳間のまん中に洗面器が置かれてあって、それには緑の薄茶が一ぱいたまっていた。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧見臺に立つて見ると、昨夜の幽味は少しも無くて瀧は明らかに見え、無數の岩燕が瀧飛沫の煙の中を、朝の日の光を負ひながら翼も輕げに快く入亂れて上下左右してゐる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し鵲の橋の上に立つてゐると瀧が近いので、瀧飛沫は冷やかに領に下ちて衣袂皆しめり、山風颯然として至つて、瀧のとゞろき、流の沸りと共に、人をして夏のいづこにあるかを忘れしむるところ、捨て難いものがある。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛沫を浴びて、歯を食いしばっている――。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、買ったばかりの白いシャツに、汚泥の飛沫をひっかけられたように。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝滞していた気分は飛沫を揚げて流れ始めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘋癲院の陰鬱に硝子は光り、草場には青き飛沫の茴香酒冷えたちわたる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋼鉄のにほひに噎び、絶えずまた直裸なる男の子真白に光り、ひとならび、力あふるる面して柵の上より躍り入る、水の飛沫や、白金に濡れてかがやく。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しさと滴るばかり激瀾の飛沫に濡れて、弥さらに匂ひ閃めく火のごとき少女のむれよ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆が廻る、廻るうちに、帆の側面が何か強い力で内にひかれる……、波が時時、思ひあまつて飛沫をあげる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "盥は光れり、独楽のごとく、一斉に、燦爛たるその飛沫。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "立處其の手足を炙るべく、炎々たる炭火を熾して、やがて、猛獸を拒ぐ用意の、山刀と斧を揮つて、あはや、其胸を開かむとなしたる處へ、神の御手の翼を擴げて、其膝、其手、其肩、其脛、狂ひまつはり、搦まつて、民子の膚を蔽うたのは、鳥ながらも心ありけむ、民子の雪車のあとを慕うて、大空を渡つて來た雁であつた。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
