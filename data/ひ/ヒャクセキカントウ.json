[
  {
    "uuid": "57f9cc20-6fa1-5f36-a48e-6642fd7b698a",
    "entry": "百尺竿頭",
    "reading": {
      "primary": "ひゃくせきかんとう",
      "alternatives": [
        "ひゃくしゃくかんとう"
      ],
      "is_heteronym": false
    },
    "grammar": {
