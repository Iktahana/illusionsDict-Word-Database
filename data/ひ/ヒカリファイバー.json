        "examples": {
          "standard": [
            {
              "text": "インターネット回線は、光ファイバーのおかげで非常に速くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医者は、胃の内視鏡検査で光ファイバーの技術を使っていると説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海底ケーブルの多くは、大量の情報を送るために光ファイバーでできている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "マルチメディアや光ファイバー・ネットワークによって、あすにも紙と活字の本がなくなるかもしれないといった危機意識の盛りあげ方は、ちょっと古いのではないか。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして究極的には、この電子的な読書空間は光ファイバー網を通じて世界中の電子図書館とむすばれることになるにちがいない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
