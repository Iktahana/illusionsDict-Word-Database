    "definitions": [
      {
        "index": 1,
        "gloss": "figure of a person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すべての恋する人々は、自分等以外に全く人影のない離れ小島の無人島で、心行くまで二人だけの生活をし、二人だけの会話をしたいと願うのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらの氷店へはいって休んだ時には、森の中にあふるる人影がちらついて、赤い灯や青い旗を吹く風も涼しく、妹婿がいつもの地味な浴衣をくつろげ姪にからかいながらラムネの玉を抜いていた姿がありあり浮ぶ。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてじっと蹲ったままで可愛い首を動かして自分のまわりをぐるぐる廻って行く不思議な人影を眺めているようである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今でも盆踊りというとその夜を思い出すが、不思議な錯覚から、その時踊っていた妖精のような人影の中に、死んだその人の影がいっしょに踊っていたのだというような気がしてしかたがない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏とはちがって人影も見えぬ和楽園の前に釣を垂れている中折帽の男がある。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の火事ならば大勢の人が集まっているであろうに、あたりには人影もなくただ野良犬が一匹そこいらにうろうろしていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "温室の白塗りがキラキラするようでその前に二三人ふところ手をして窓から中をのぞく人影が見えるばかり、噴水も出ていぬ。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんとした道路があるが通っている人影が見えない。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本劇場の前まで来て見ると、さすがに今日はいつもの日曜とちがって切符売場の前にはわずかに数人の人影が見えるだけであったので急に思い付いて入場した。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽は綿雲の下に蓋はれ、人影の散々としてゐる池の端の上空には、博覽會の輕氣球がさびしげに浮んで居た。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛籠の傍へ寄って人影なしと見て天狗の面を取って辻堂の縁に置く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間、しんとした室内の七人の人影は臥像のやうなお前を取り卷いて、ぢつと佇んだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の油のやうな水面は大きく波立つて、眞黒な人影が毆れた蝙蝠傘のやうに動いてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧舍のあたりには小さな人影が動いてゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小道が廣い眞直ぐな道に這入る處に灰色にくすんだ家があつて、人影が見えた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が進むにつれて人影が黒い点のようになってしまった、そのうち磯も山も島全体が霞のかなたに消えてしまった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『人影が見えたと思うと「宮地ゃよいところじゃ阿蘇山ふもと」という俗謡を長く引いてちょうど僕らが立っている橋の少し手前まで流して来たその俗謡の意と悲壮な声とがどんなに僕の情を動かしたろう。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮れて間もなきに問屋三軒皆な戸ざして人影絶え人声なし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもとはちがってその時は人影というものがほとんど見えなくて、ただ片隅のベンチに印半纏の男が一人ねそべっているだけであった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵のうちはその障子に人影が写り「デデンデン」という三味線の撥音と下手な嗚咽の歌が聞こえて来る。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのなかには依然として何の人影も立ってはいなかった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "４「今晩も来ている」と生島は崖下の部屋から崖路の闇のなかに浮かんだ人影を眺めてそう思った。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は幾晩もその人影を認めた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは俺の空想が立たせた人影だ。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引きあげられた漁船や、地引網を捲く轆轤などが白い砂に鮮かな影をおとしているほか、浜には何の人影もありませんでした。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は折りおりその人影を見返りました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、その人影――Ｋ君――は私と三四十歩も距っていたでしょうか、海を見るというのでもなく、全く私に背を向けて、砂浜を前に進んだり、後に退いたり、と思うと立ち留ったり、そんなことばかりしていたのです。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は海を見ては合間合間に、その人影に注意し出しました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてついには、その人影が一度もこちらを見返らず、全く私に背を向けて動作しているのを幸い、じっとそれを見続けはじめました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人影のなにか魅かれているような様子が私に感じたのです。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            }
          ]
        }
