    "definitions": [
      {
        "index": 1,
        "gloss": "dance performed by a single person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "静一人舞いたりとても、竜神｜示現あるべきか。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "静一人舞ひたりとても、竜神示現あるべきか。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "満場ただ伝六郎の一人舞台になってシインとしかけているところへ、縁側の障子の西日の前に一人の小女の影法師がチョコチョコと出て来て跪いた。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台面が寂しい上に、主人公が盲目でちっとも動きがなく、むやみに長台詞をならべているばかりであるから、いくら団十郎の一人舞台でも、その当時の観客は頗る悩まされたに相違ない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "各国の観衆の中で昨日までは黒人とドイツ人の一人舞台の観があった。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また話がはずみ、――と云つても、殆ど嘉助の一人舞臺で、その間に挾む駿介のどんなちよつとした言葉でもが、嘉助の熱烈な共鳴を受けるのだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然、見物より先に傾注し、活々とした反応を示すべき周囲が、冷やかに納り込んで、一人舞台の芸を種々な感情で観察でもしているように見えるのはどういうものだろう。",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ義雄さんの方から節ちゃんの食い扶持が行く訳ではなかろうし、台湾の伯母さんから見れば厄介者が一人舞込むようなものだからねえ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑つて見たり、怒つて見たりの一人舞台だ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "番町の邸では、時折家族で――子供衆たちの催しではあろうが――大仕掛けなお伽芝居が催されたり、藤間勘十郎のお浚いなどに令嬢の一人舞台で見せられる時もあった。",
              "citation": {
                "source": "大橋須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「無いのう」「方々には」　軽輩の、益満の一人舞台となって、上席の人々は、少し、反感を持っていたが、こういうことにかけては、益満の才智より外に、いつも、方法が無かった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はマダム丘子の殆んど一人舞台であった。",
              "citation": {
                "source": "※の囁き",
                "author": "――肺病の唄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "より江氏は後期雑詠時代に一人舞台で、活躍していられる故、のちにゆずり、ただ枯菊に尚愛憎や紅と黄と　　　より江秋風にやりし子猫のたよりきく　　　同の二句に氏のデリケートな性格、あくどい悩や執着のないさらりとした明るさを見る。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽で最目のつくものは、殆、人長ばかりが舞つてゐるやうに見えることですが、他の人々には各、それ／″＼の才があるので、その才を特殊なものにして来た結果、人長の一人舞といふ形を生じたのでせう。",
              "citation": {
                "source": "神楽（その二）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば一人舞台でも、さうであつた。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠屋さんかえ」　とお春はいそいそ立上り、「今すぐ行くぞえなあ」「今宵は若殿にお連衆があるそうで、一人舞の御用意をなされて来てとのことですからそのお積りに願います」　と潜戸を開けて使が言い添えるのです。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに気を得て続々と馬琴は諸作を発表したが、折しも京伝は転化期にあり、他に目星しい競争者もなく、文字通り彼の一人舞台であり、かつは名文家で精力絶倫、第一人者と成ったのは理の当然と云うべきであろう。",
              "citation": {
                "source": "戯作者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは選挙資格審査請求書提出期限の二日前のギリギリの日であり、現知事が今のところ一人舞台として無競争選挙かといわれているときのことであった。",
              "citation": {
                "source": "実践について",
                "author": "――馬になった話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面の馬見所の大屋根の上では、がんりきが一人舞台で、大勢を相手に立廻っていることは前の通りであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と一人舞い出しました。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人舞台の力演に終始する点も両者は太だ共通してゐるし、川田が昭和戦前人気高潮の虎造節を自家薬籠中のものとしたことゝ、小亀が当時の大御所たりし先代楽遊の節調を好んで口にしたところも亦太だ相似てゐる。",
              "citation": {
                "source": "異版　浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、自分が海外にある長い留守中、国内にエセックスを残しておけば、競争場は彼の一人舞台となる。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると神尾主膳は、先程はやや甲走っていた声がようやく落着いて、提灯を枷に使いながら、一人舞台のように主張をはじめてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、富樫が引込むと、「ついに泣かぬ弁慶も一期の涙ぞ殊勝なる」から「判官御手を取り給い」の順序になるべきはずのところを、判官を初め、四天王残らずの山伏と、強力が、ずんずん舞台を引込んでしまい、あとは弁慶一人舞台。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛原氏が一人舞台で、みんなを笑わせたり、謹聴させたりしている内に、食事は終った。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう終りに近いか、次は藤夜叉の一人舞で、唄は繰返しこう聞えた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、湊川の一戦は、結果的に、正成の一人舞台といえる観であった。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
