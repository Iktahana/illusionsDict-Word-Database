    "definitions": [
      {
        "index": 1,
        "gloss": "formal folding fan made of hinoki cypress",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分も縁側へ出て新しく水を入れた手水鉢で手洗い口すすいで霊前にぬかずき、わが名を申上げて拍手を打つと花瓶の檜扇の花びらが落ちて葡萄の上にとまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい風が吹いて来て榊のゆうがサラサラと鳴り、檜扇がまた散った。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十四日　檜扇の花を植う。",
              "citation": {
                "source": "草花日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて檜扇を授けらる。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお珊が聞返す、胸を薄く数を襲ねた、雪の深い襲ねの襟に、檜扇を取って挿していた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五番に、檜扇取って練る約束の、我がお珊の、市随一の曠の姿を見ようため、芸妓、幇間をずらりと並べて、宵からここに座を構えた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと心付いた状して、動悸を鎮めるげに、襟なる檜扇の端をしっかと圧えて、ト後を見て、襖にすらり靡いた、その下げ髪の丈を視めた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、頤を檜扇に、白小袖の底を透して、「これか、」　と投げたように言いながら、衝と、両手を中へ、袂を探って、肩をふらりと、なよなよとその唐織の袖を垂れたが、品を崩して、お手玉持つよ、と若々しい、仇気ない風があった。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（檜扇にてさしまねけば、蟹は縁の下へ這い寄る。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（玉虫は檜扇を持ちて起ちあがり、はじめはしずかに舞う。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（玉虫は舞いながら、檜扇をあげて与五郎を丁々と打つ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぎし屋島のたたかいに、風流を好む平家の殿ばらは、船に扇のまとを立てさせ、官女あまたある中にも、この玉虫が選みいだされ、船端に立って檜扇をかざし、敵をまねいて射よという。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような怖ろしい場所へ立ち寄るなどと思いも寄らぬことでござりまする」　檜扇に白いおもてをかくして立ち去ろうとする彼女を、泰親はかさねて呼び返した。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰親の祈祷がそれほどに怖ろしゅうござるか」　玉藻は檜扇で口を掩いながら軽く笑った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、檜扇を把り直してしずしずと祈祷の壇上にのぼって行った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るみるうちに、それが美しい上臈の姿になって、檜扇におもてをかくしながら涼しげな声でこう言った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わらわの申すことを用いねば命はないぞ、その期に及んで後悔おしやるなと、言うかと思うと、その檜扇の蔭から怖ろしい……人か幽霊か鬼か獣か判らぬような、世に悽愴い変化のおもてが……。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝太郎は夢心地で走り寄ろうとするのを、彼女は檜扇で払い退けるようにさえぎった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "射干は「ひおうぎ」「からすおうぎ」などいえる花草にして、ここは「照射して」の誤なるべし。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
