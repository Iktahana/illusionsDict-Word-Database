[
  {
    "uuid": "24a66333-8de2-5f66-a85a-924391044c67",
    "entry": "人いきれ",
    "reading": {
      "primary": "ひといきれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
