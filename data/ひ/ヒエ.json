    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chilliness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はさよならを云つて、冷えた靴を穿いた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、風は冷え、街はいつたいに雨の翌日のやうではじめて紹介される人同志はなじまない。",
              "citation": {
                "source": "秋の日曜",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで手足の指などは自分のからだの一部とは思われないように冷え凍えてこちこちしている代わりに頭の中などはいいかげんにあたたかいものがよい程度に充実しているような気がしている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時に氷が増してよく冷えると見えて、少し心が落付いたが、次第に昇る熱のために、纏まった意識の力は弱くなり、それにつれて恐ろしい熱病の幻像はもう眼の前に押寄せて来る。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "華々しいもの、潔いもの、勇壮なるもの、さう云つたものから、子供の家へ帰ると、ひつそりと沈んだ冷え冷えとしたものが、両親の体臭のやうに、家中を靄のやうに立ちこめてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはつまり比較的暖かい地上近くの空気が温気を含んだままで気流につれて上昇し、高層の気圧の低い処へ行くに従って膨脹して冷えて来る、ある処まで行くと雲と凝り雨になってしまう事もあるが、ごく寒い時にはこれが直ちに凍って小さい雪片となりこれが次第次第に大きく生長する。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水色絹の簾の縁がしつとりと濡れて居り、簾の生地の竹の手觸りの冷え／″＼しさに、目をとめて見れば、いつの程よりか外には時雨のやうに冷い細雨がしとしとと降つて居たのである。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は朝餉を食べ終ると冷えた身体を撫でさすりいささかの暖味に心を引立たして貰って、きょうの旅路の踏出しにかかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外が冷えて來たらしく窓は湯氣が凍りついて白くなりました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ふう、今朝ずゐぶん冷えるな。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内一の財産家といふに、家内は祖母と此子二人、萬の鍵に下腹冷えて留守は見渡しの總長屋、流石に錠前くだくもあらざりき、正太は先へあがりて風入りのよき塲處を見たてゝ、此處へ來ぬかと團扇の氣あつかひ、十三の子供にはませ過ぎてをかし。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分の正月の記憶で身に沁みた寒さに関するものは、着馴れぬ絹物の妙につめたい手ざわりと、穿きなれぬまちの高い袴に釣上げられた裾の冷え心地であった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス語の冬 hiver はラテンの hibernum であろうがこれを「冷える」と比べてみるのも一興である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は冷えたわが子を素肌に押し当て、聞き覚えのおぼつかなき人工呼吸を必死と試みた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一七―一八年の冬頃からどうも脚が冷えて困ると云ってこぼしていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月十三日『東京朝日新聞』）　　　　　　　　　三　　　　　　露　夜地上の草木土石が冷えて空気よりも冷たくなると、空気中の湿気が持ち切れなくなって露と結ぶ。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "良く晴れた夜には地面は赤裸で天体の寒さに曝されるようなものだから余計によく冷える。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また風があると地面の冷えようとするのを始終空気が撫でて行くから空気よりも著しく冷える間がない。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草木の葉や土、石、藁のようなものは冷えやすいから露も多くつくが、光った金属例えば金盥などは冷えにくいから露も付きにくい。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜地面に近い空気がだんだんに冷えて来るために水蒸気が細かい滴になって空中に浮游すればすなわち霧である。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気候は内地と余り変らないが、夜が冷える。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしていつ夜が彼のすぐそばに來たのだらう、急に冷えびえして來た。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　翌年の春（その春はもの悲しく、冷えびえと來た）、ピロヴァノ男爵の軍使がしづかにランゲナウに入つていつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "古びた唐草模樣の壁紙の處處はげかかつた四方の壁には、三色版の平凡な風景畫が一つ掛かつてゐるきりで、がらんとした、空氣の冷えきつた部屋の中には裝飾品らしい何物も見えなかつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それは女の身の上が餘に悲慘に過ぎてゐるためだつたらうか、それとも何か意識外の理由が働くためだつたらうか、女の話が進んで行くにつれて、私の心は初めの感動を喪つて、何故かだんだんに冷えて行くのであつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな火鉢に僅かばかり燃やされた木片で暖まる譯もないがらんとした部屋の中は、凍るやうな戸外の夜氣と共に冷え渡つて、寒さがひしひしと身に迫つて來た。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唇をやられた男は、冷えた練乳と、ゆるい七分粥を火でも呑むように、おず／＼口を動かさずに、食道へ流しこんでいた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イラ痒い瞼、ひえびえとする野面の風にひえびえとしたみすぼらしい顔の中から、この遠近を嘆賞するもないもんだなぞ、云つては呉れるな人々よ、自然の与件は、何時でも生理のまゝに享受してゐる者でこそあれ、希望を持つて生きてゐるとも云へるので、其の他はすべて、謂はば野心で生きてゐるのだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "檻の鉄棒ひえてゐた。",
              "citation": {
                "source": "熊",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "母さんお窓をしめましよう、風がひえひえいたします。",
              "citation": {
                "source": "沼の家",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
