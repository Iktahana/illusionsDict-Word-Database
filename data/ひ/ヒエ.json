[
  {
    "uuid": "83dd0b26-073f-5a99-a0f3-e9438be2aa82",
    "entry": "冷え",
    "reading": {
      "primary": "ひえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
