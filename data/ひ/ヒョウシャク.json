[
  {
    "uuid": "92e1b786-e393-5703-863e-9d543153c03f",
    "entry": "氷釈",
    "reading": {
      "primary": "ひょうしゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "melting like ice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかるに近ごろになって私はようやくこの疑問を全く氷釈し得たるがごとくに思う。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつを見ると疑問が一ペンに氷釈したよ。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、そもそも予が疑団いよいよ凝結して、氷釈するあたわざるゆえんなり。",
              "citation": {
                "source": "妖怪報告",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる絶対関内の風光なれば、宗教上、天啓顕示をまたざるべからざるも、今ここに論ずるところは、道理によりて説明するにあれば、いささか宗教学の理論に考えて、この疑団を氷釈せんと欲するなり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなはち意外の辺において意外の聯絡を発見し以て久しく結で解けざりし疑問を氷釈すること尠きにあらず。",
              "citation": {
                "source": "史論の流行",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その行先が疑問、それを突き留めさえすれば、金策の問題もおのずから氷釈するに違いありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
