    "definitions": [
      {
        "index": 1,
        "gloss": "free-standing house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十町ばかり一目に見渡す青田のたんぼの中を、まっすぐに通った県道、その取付きの一構え、わが生家の森の木間から変わりなき家倉の屋根が見えて心も落ちついた。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁葺きの家が何軒も立ち並んだ一構えが柞の林に囲まれて、それに夕日がかっとさしているところに通りかかった。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "螺旋状になった路のついたこの峰のすぐ下に、それもほかの僧坊と同じ小柴垣ではあるが、目だってきれいに廻らされていて、よい座敷風の建物と廊とが優美に組み立てられ、庭の作りようなどもきわめて凝った一構えがあった。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の煉瓦建てをそのまま改造したと思われる漆喰塗りの頑丈な、角地面の一構えに来て、煌々と明るい入り口の前に車夫が梶棒を降ろすと、そこにはもう二三人の女の人たちが走り出て待ち構えていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは元紅葉館の女中だった人がある豪商の妾になったについて、その豪商という人が建ててあてがった一構えだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　いかさま舟宿としては一流らしい構えで、数寄をこらしたへやべやは、いずれも忍ぶ恋路のための調度器具を備えながら、見るからに春意漂ういきな一構えでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "表にはご番士のひとりがちゃんと待ち構えていて、城中からほど遠からぬ数寄屋造りの一構えに案内してくれましたものでしたから、まだ虚無僧姿のままの伝六の喜ぶこと、喜ぶこと――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "お約束どおりの、舟板べいで見越しの松でもがあるかと思いのほかに、ただの町家で、それがまた、ついこのごろ建てたらしい新普請の、しかし人けは少ないらしい一構えでしたから、右門はややしばしなにごとかをうち案じていましたが、ふいっとまた伝六の目をぱちくりさせるような行動を開始いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏には顕官の来て泊る新築の一構えなどもあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "大木の常磐木へおもしろくかかった蔦紅葉の色さえも高雅さの現われのように見え、遠くからはすごくさえ思われる一構えがそれであるのを、中納言も船にながめて、自分がたいそうに前触れをしておいたことがかえって物思いを深くさせる結果を見ることになったかと歎かわしく思った。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "塙代与九郎宅の奥庭、落葉を一パイに沈めた泉水に近く、樫と赤松に囲まれた離れ座敷は、広島風の能古萱葺、網代の杉天井、真竹瓦の四方縁、茶室好みの水口を揃えて、青銅の釣燈籠、高取焼大手水鉢の配りなぞ、数寄者を驚かす凝った一構え……如何にも三百五十石の馬廻格には過ぎた風情であった。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひっそりとした一構えに、人の気はいもない様子を見届けて、麺麭と葡萄酒を盗み出して、口腹の慾を充分｜充たした上、村外れへ出ると、眠くなって、うとうとしている所へ、村の女が通りかかる。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六　中庭の奥にも一構えあり、構えの奥に内土蔵があったが、その前の闇に佇んで、十二神貝十郎は静まっていた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "板倉周防守様のお屋敷内の、お長屋の一構えが彼の住居で、その住居の一室に、松浦民弥はいたのである。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "周防守様のご本殿の、大奥の結構な一構えが、姉小路卿の住居であった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さみしさ凄さはこればかりでもなくて、曲りくねッたさも悪徒らしい古木の洞穴には梟があの怖らしい両眼で月を睨みながら宿鳥を引き裂いて生血をぽたぽた……　崖下にある一構えの第宅は郷士の住処と見え、よほど古びてはいるが、骨太く粧飾少く、夕顔の干物を衣物とした小柴垣がその周囲を取り巻いている。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "神奈川の七軒町へ来ると、大きな一構えの建築を見出して屋根の上をながめると、横文字で、No. 9 と記してあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、この貴公子に拉せられた兵馬は、宮川を前にした大きな一構えの中へ引張り込まれてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは中庭の突き当りの陰気な一構えの建物の中にある薄暗い一組の室であった。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸板の一団　ちょうどこの頃のことであるが、この林から一里ほど離れた地点に、だだっ広い前庭を持った一構えの農家が立ってい、家鶏の雛が十羽ばかり、親鶏の足の周囲を、欝金色の綿の珠が転がるかのように、めまぐるしく転がり廻っていた。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、小暗く木の茂った、一構えの社地が現われた。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて若葉に鎖ざされたように蓊欝した小高い一構えの下に細い路が開けた。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪壮な石門をくぐると表は泉栽で、昼なお暗いばかりに樹木が鬱蒼と生い繁り、ただ見てさえなんとなくものすごい陰惨な気が漂って、見るからよほど年数の経っているような一構えである。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "一構えの家の中でありながら二階と三階との間にこんな仕切りを拵える……拵えさせるようなことをする人達！",
              "citation": {
                "source": "一つの出来事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云う姉が現在住んでいる上本町の家と云うのは、これも純大阪式の、高い塀の門を潜ると櫺子格子の表つきの一構えがあって、玄関の土間から裏口まで通り庭が突き抜けてい、わずかに中前栽の鈍い明りがさしている昼も薄暗い室内に、つやつやと拭き込んだ栂の柱が底光りをしていようと云う、古風な作りであった。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家は、二階建ての一構えであった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……かわいそうに、蜘蛛太は、わたしのために、仕置小屋に抛りこまれて、これも、覚えのないことを、責め折檻されているそうでございます」炎の家族一　国府の丘の小高いところに、良い庭木や石をあつめて、戦いでもある折は、小さな砦ぐらいな役には立とうと思われる豪奢な一構えの屋敷がある。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの見るからに閑雅な門のある一構えが、灰屋どののお住居です」「…………」　武蔵はうなずきながらふと、左の袂の先を、袂の外から握っていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間の月の下に、物音もしない一構えの建物がある。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "西ノ柵の内に、一構えの屋敷が空いているはずだ。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
