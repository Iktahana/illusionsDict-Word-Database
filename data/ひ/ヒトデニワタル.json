        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それでも気紛れな株さえやらなかったら、新婚当時養家で建ててくれた邸宅まで人手に渡るようなことにもならなかったかも知れなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は伯父の遺して行つた借債の為に人手に渡る。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間の後には人手に渡るべき一枚の五円紙幣に電気アイロンをあてて見る気にはなれない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "清は十何年居たうちが人手に渡るのを大に残念がつたが、自分のものでないから、仕様がなかつた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "清は十何年居たうちが人手に渡るのを大いに残念がったが、自分のものでないから、仕様がなかった。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとにこにこしてたと思ふんだが……」「伯父さんには、大変な心配事がおありになるんだから……」「へえ、なんです、それや……」「もう云つてもいいだらうと思ふけど、この家は、おつつけ人手に渡るんですつて……」「すると、僕たちは……」「だからさ、それを考へておくれよ。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏人ばかりでね、工場が人手に渡るとその人達も追出されるさうで、直ぐ翌日から食つて行けなくならあ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ、こんどこそ家屋敷が人手に渡るという噂も、卒業のさしせまった富士子の動きをきめられなくしているのだろうと思うと、コトエと同様、あなたまかせの運命が彼女を待ちうけていそうであわれだった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イイエ、同じ人手に渡るにしましても、あなたがお求め下さいましたので、こんな仕合せはございません。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそいつが人手に渡ると、またぞろ、夜光の短刀、夜光の短刀と猫も杓子も騒ぎだすやつがふえて、こッちの詮議にぐあいが悪い。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな物が人手に渡ると一大事だ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
