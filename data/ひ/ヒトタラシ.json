[
  {
    "uuid": "65be3995-1948-5c73-89a4-97ad2f96143d",
    "entry": "人たらし",
    "reading": {
      "primary": "ひとたらし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "someone who is well-regarded",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幸に江湖の識者来つて、吾人に教へよ、吾人をして通津を言ふの人たらしむる勿れ。",
              "citation": {
                "source": "「平和」発行之辞",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してこの次に来る可き光栄ある第二次の革命が愈君を権威ある詩壇の真人たらしめる事を信ずる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、個人を個人たらしめる・最も普遍的な意味に於ての・功利主義が私には缺けてゐるやうだ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この見地からして二葉亭は無知なる腹掛股引の職人を紳士と見て交際し、白粉を塗った淪落の女を貴夫人同様に待遇し、渠らに恩恵を施しつつ道徳を説き、渠らを罪悪の淵から救うて真人たらしむべく種々の手段を講じた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさにそれは、日本人をして日本人たらしむるものは、日本人的なるものであるといふのと変りはない。",
              "citation": {
                "source": "文学の本質について（二）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "試に我｜志を言はんか、我をして医師たらしめば我は病理を研究して茫漠たる治療術の基礎を固めん、我をして工人たらしめば我は機械学を研究し大小百種の機械を発明して世に便益を与へん、我をして科学者たらしめば我は数学を窮めて我智識に満足を与へ、生物学を学んで我感情に満足を与へん。",
              "citation": {
                "source": "病牀譫語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで話はあとへ戻りますが、職長は何か西村に含むところがあるとみえて、先月末に二十人ほど工員が馘を切られたとき、わたしを煽動してストライキを起こす張本人たらしめ、社長を脅して一万円の金を強請り取り、それを工員に分配するようにしたらばどうだと勧めました。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤次郎が真面目であること、かたいこと、が彼をして犯罪人たらしめない、とは不幸にして云い得ない。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ナポレオン乃至レニンをして詩人たらしめば、不世出の小説家を生ずるは言を俟たず。",
              "citation": {
                "source": "小説作法十則",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭に於ては夫婦喧嘩をなし、一杯機嫌で打擲をなして憚らず、而してその子弟を聖人たらしめよとは矛盾の甚しきものである。",
              "citation": {
                "source": "教育の最大目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて大詩人を大詩人たらしめるものは、――少くとも後代に大詩人の名を与へしめるものは雑駁であることに帰着してゐる。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "『解放は女子をして最も真なる意味に於て人たらしめなければならない。",
              "citation": {
                "source": "「婦人解放の悲劇」自序",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の民心に浸潤するの結果は、人を誤って法の罪人たらしむるに至る可し。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子としても良人としても確かなかつ周到な思慮を欠いて甚だ煮え切らぬ態度を取っていたために、母の恥を世に曝し、妻を罪人たらしめ、自分自身を不幸に導くような悲惨な結果になってしまった。",
              "citation": {
                "source": "姑と嫁について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族制度を最も遅くまで守持するであろうと思われる農家が、かえって第一にその子女の大多数を他郷の人たらしめねばならない時代となっています。",
              "citation": {
                "source": "激動の中を行く",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……婦人が進んで家庭から離れようとする如き考えは決して健全なものと思われません」といわれた如きは、博士こそ余りに「単なる理由」の下に軽率なる断案を下されたもので、博士は我国の女工八十万の家庭事情が経済的と倫理的の両方面から、彼らを職業婦人たらしめねば置かないという重要な理由を看過しておられるのです。",
              "citation": {
                "source": "激動の中を行く",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は、その人物が狂人ならばあくまでも狂人たらしめ、賢者ならばあくまでも賢者たらしめんとする。",
              "citation": {
                "source": "小説の内容論",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "當面の暴行のみを理由として、直にツネは元右衞門の相續人たらしむるに勝へずと斷定するのは、失當といはねばならぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう文学論はさておき、文芸家自身をしてより多く青春人たらしめんがためにも、ここに青春の復活ということが唱道されるべきである。",
              "citation": {
                "source": "神話と青春との復活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が其は、善郎さんの小説の中にあったように、彼のうちにもある暗黒がこれに対して寛大な良人たらしめるのではないだろうか。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "満鉄本社の宇佐美君が特に予等の満蒙旅行のために、君を煩はして東道の主人たらしめられたのは、その用意の深いのに感謝される。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「本から現實へ」は後年の彼をして「藝術に依つて藝術を作り出す」作家の一人たらしめた。",
              "citation": {
                "source": "芥川龍之介論",
                "author": "――藝術家としての彼を論ず――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水戸の史家が彼を反臣伝中の一人たらしめしが如き、此間の心事を知らざるもの、吾人遂に其余りに近眼なるに失笑せざる能はざる也。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "贈答・問答の類も、歌垣の唱和から筋を引くもので、かけあひ特有のあげ足とり・はぐらかし・人たらし・情らしさなどが皆過分に含まれてゐる。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を扶助し、保護して、高名の人たらしめようとした中世以後にも残つた民俗の心理的基礎は、こんな処に窺はれるのである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や友人春水の子俊秀｜斯の如きを見て、彼は曰へり、千秋子あり之を教へて実才を為さしめず乃ち詞人たらしめんと欲する乎、宜しく先づ史を読んで古今の事を知らしむべし、而して史は綱目より始むべしと。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "権力とか毒薬とか刃物とかバクダンとか、すべて危険な物を持たせないことが、狂人を平和な隣人たらしめる唯一の方法なのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "麻薬・自殺・宗教",
                "note": "青空文庫"
              }
            },
            {
              "text": "解放は女子をして最も真なる意味に於て人たらしめなければならない、肯定と活動とを切に欲求する女性中のあらゆるものがその完全な発想を得なければならない。",
              "citation": {
                "source": "婦人解放の悲劇",
                "author": "エンマ・ゴルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等をして造詩家たらしむるも、詩人たらしめざるもの茲に存す。",
              "citation": {
                "source": "松島に於て芭蕉翁を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしロッチをして日本帝国の軍人たらしめんか風紀問題は忽ち彼をして軍職を去らしむるに終りしならん。",
              "citation": {
                "source": "矢立のちび筆",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
