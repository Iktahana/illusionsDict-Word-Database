    "definitions": [
      {
        "index": 1,
        "gloss": "to have a cramp",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "親爺は、薄暗い廊下で、脚が引きつるものゝようにひょくひょくした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろへまわした両手を背中で項に引きつるようにされていた囚人は、項からだけ繩をときほぐされた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃のぐあいが悪くて腹が引きつるようであった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、つぶりながらも時時引きつる瞼で、彼がまだ寢落ちてゐない事は確かだつた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議に思って其のまま立っていると体が引きつるようになって動けなくなった。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "度重なるうち、下腹が引きつるような痛みに驚いたが、お婆は脱腸の気だとは感付かなかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "癇のためにそう引きつるのだとは、跡でお袋みずからの説明であった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "度重なる内、下腹が引きつるような痛みに驚いたが、お婆は脱腸の気だとは感付かなかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その駒もすさめぬものと名に立てる汀の菖蒲今日や引きつる　とおおように夫人は言った。",
              "citation": {
                "source": "源氏物語",
                "author": "蛍",
                "note": "青空文庫"
              }
            },
            {
              "text": "――二度とは、出来ない）　小太郎は、汗を拭きながら、肩にかけた荷物の下の、汗にじめじめするのを、度々、掛けかえながら、少し、引きつる脚で、大津から、坂本への道を、急いでいた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "がその僅かな小さい追想に伴うほこりに似た感情は、腰から下腹部にあたって引きつるような疼痛を感じたときに根柢から破れてしまった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬の肉が引きつるのを押し切って言った。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々何処かの筋肉がびくびくと引きつる。",
              "citation": {
                "source": "蠱惑",
                "author": "――冬夜、瞑目して坐せるある青年の独白――",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みすすむにつれ、夫人の眼はきらきらして、美しい唇が引きつるやうに歪むのであつた。",
              "citation": {
                "source": "垂水",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹便り一「どうした、戸のすきにはさんできたか」　と源三郎は、例のかみそりのような蒼白い顔に、引きつるような笑いを見せて、折りから庭づたいに帰ってきた谷大八を、見迎えた。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しくやつれた白い顔が、クシャクシャと引きつるように真ん中へよったかと思うと、口がゆがみ、小鼻のあたりが盛り上がってきて、無数の皺の集まった両の眼から、押し出されるように涙の粒が……あとから後からと光って落ちて、青い筋の浮いている手の甲や、膝を包む友禅をしとどに濡らす。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「亭主の敵を討った私に、何が御用だい」　振り冠った乱髪の中から、激怒に引きつるお吉の顔が、朝の光を半面に浴びます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　次郎は、恥ずかしさと腹だたしさとで、顔中が引きつるような気持ちだった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは、美しくひらいた眉根が、引きつるように、よっていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体の左側はただ一本の長い不愉快に引きつる傷口のように思えたが、両側に並んでいる小さな脚で本格的なびっこを引かなければならなかった。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "引きつるような泣き声でみんな眼をさましてしまったらしい。",
              "citation": {
                "source": "十三夜",
                "author": "――マニラ籠城日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして引きつるような波が、たえまなくからだを貫いて走った。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手は口のあたりで組み合わされて、肩が引きつるようにふるえている。",
              "citation": {
                "source": "トリスタン",
                "author": "TRISTAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、頭が、あれで、どんなふうになるのかねえ、手や足がピキピキと引きつるようなカゲンになって、さ、三度四度とそれにかけられると、どんなシブトイ人間でも、そりゃもう、グナグナになってしまうんだ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方は、青い顏色のままの、引きつるような笑い方でした。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々から陽気な露骨なことを言いかけられて、少年の顔つきが無言のうちに引きつるのに、彼は居合わしたこともよくあった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも済まねえ」　咽喉が引きつるような気持で、まずこう言って米友が詫びました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしまた引きつるようなら、ロープの勢いで切り落としてやるところだが。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ひきつるような苦痛の皺があとに残ったので、びっくりして男の顔を見ていると、男はきっとした眼で私をにらみつけた。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄蔵は、自分の眼の下のところが、ひきつるやうな気がした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
