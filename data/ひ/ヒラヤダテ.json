    "definitions": [
      {
        "index": 1,
        "gloss": "single-storied house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その向うに樅の木立ちにかこまれた陰気な平屋建てがある。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "北から南に、長い木造の平屋建てだった。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがいずれも平屋建てで、障子が白々と陽に光っている。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "要介達の泊まっている家は、宗家嘉門の門の中の平屋建ての一軒であった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが平屋建ての、六間ばかりしかない粗末な借家なのであったが、野村は仏壇のある六畳の茶の間へ引っ張って行って先妻と二人の子供の写真が飾ってある光景までも見せたりした。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその時分、甲子園の家が漸く明け渡されたので、一日御牧も西下して蘆屋を訪い、幸子と雪子とを誘ってその家を検分に行ったが、それは阪神電車の北側数丁の所にある、わりに新しい平屋建てで、夫婦が女中一人を置いて暮すには手頃の広さであり、殊に百坪に余る庭の附いているのが何よりであった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで学院の隣に別な小さな門があって、そこに平屋建ての、西班牙風な瀟洒な住宅があったが、学院の校舎とは庭つづきで行け行けになっていた。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "学院の門は殆ど埋没して纔かに門柱の頭が少しばかり地面に露出しているに過ぎず、平屋建ての校舎も、スレート葺きの屋根だけを残して埋まっていた。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階造りの店とはべつに、中庭を隔てて、平屋建ての住居があった。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "モアナ・ホテルが完成して間もない頃の写真を見ると、海岸を縁取っている林のなかに平屋建ての個人の家がならぶだけという景色のなかに、モアナ・ホテルが一軒、忽然とあらわれたという印象だ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭にプールのある平屋建ての家に、僕は前の年から住んでいた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷地はまずとにかくプールのためのものであり、プールの周囲を快適に整えたあと、プールをほどよく囲んで保護するものとして、平屋建ての家がＬの字にあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱帯樹林が山なみのように重く横たわり、そこから手前に向けて、空き地とも農地ともつかない、起伏が細かく連続する土地が広がり、そのなかに平屋建ての倉庫のような建物、あるいは民家が、点在していた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれに広くスペースをとった平屋建てのおおまかに大きな民家が、おたがいに存分な距離をとって、並んでいた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンゴーの樹に囲まれた、木造のごく平凡な平屋建ての家だ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんのすこしだけ走ると、右側に木造平屋建ての長い建物があった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "板張りの平屋建てで、例によって正面にはフォルス・フロントがあった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路からすこしだけ下がったところに建っていて、平屋建てだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "平屋建ての、細長い建物だ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "平屋建てのバンガローのような建物だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「変わってるでしょう」　平屋建ての小ぶりな家だ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前にある家の竹林の向こうに、平屋建ての恵子の家があった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "平屋建ての庶民の家がびっしりとあって、すぐ近くの銭湯では煙突の補修工事がおこなわれてた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも平屋建てで、ぜんたいの雰囲気だけではなく、ふとした細部まで、似たところがたくさんあった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を境にして左右に分かれて高低差のある、高いほうの敷地のなかの、平屋建ての家だった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり息子に嫁が来たらここに住むようにと、母親が敷地のなかに小さな平屋建てを、勝手に建てたのです。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "店は平屋建ての民家のような木造だった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡り廊下でつながった別棟の平屋建てが、私の住んでいるところなの」「うかがいます」　電話はそこで終わった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋に向かうコンクリート敷きの小径が、平屋建ての別棟に向けて枝分かれしていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向こうに、平たい屋根の平屋建ての家があった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
