        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "警視庁の人事相談所開始当時（大正十二年十月）は流石に人探しの相談が多かった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に押し詰まって来ると、次第に人探しの申込みが減って来た。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋人探しの若い娘の、一生懸命の声だからである。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸川さんが宣伝してくれたので、「一頁もの犯人探し」の注文が押しよせた。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あとは犯人探しだ。",
              "citation": {
                "source": "一九五〇年の殺人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "落人探しの武士どもであった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日からして宗三郎、奥庭に建ててある離れ座敷を、仮りの住居に借り受けて、道人探しに取りかかった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋人宗三郎の目的が、道人探しにあると聞くや、思い出したのは彦兵衛の事、道人の住居を知っているらしい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と山影め明日か明後日、道人探しに行くだろう。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "味方は大勢、山窩がある」詭計にかかった宗三郎　その翌日のことである、山影宗三郎は家を出て、道人探しに発足した。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついてはいかがでございましょう、道人探しの競争の中へ、妾をお加えくださいますまいか」まず切り出したものである。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "では妾も道人様を目付け、宗春様を妾の手へ、お返ししていただくことに致しましょう」　道人探しの目的は、こうして期せずして一致したが、何をするにもこの内牢から、逃げ出さなければならなかった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新橋の某楼に於て昇龍丸の犯人探しの会を開くから出席されたい。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人探しの当日はすでに明日に迫っていた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十嵐が大きな声で、「犯人探しをしてオレに犯人を教えてくれるとは大和にしては出来すぎた親切だが、どうも、そこが臭いじゃないか。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は私の司会で犯人探しをやろうという趣向ですが」　一度はこの伏兵に慌てたらしいが、みんな聞かれて名探偵に開き直られては仕方がない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "新十郎が事もなげに犯人探しを言いだしたから、虎之介は甚だしく解せない顔、「明日犯人が分りますかい？",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "新十郎はポケットから一枚の紙片をとりだして、「さて、今村さんだけが、本日欠席されましたが、欠席の理由は後刻申し上げますが、ここに質問にお答をいただいた紙片がありますから全員参集と認めて犯人探しにうつります」　新十郎は改めて紙片に見入った後、顔を上げてキンに話しかけた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐々木三郎盛綱は、この浜の地理に詳しい男を一人探し出し、直垂、小袖、刀などを与えて、機嫌をとってから、「この海の中で、馬でも渡れるところがあるか」といって尋ねた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな優しい人殺しは珍らしからう」「――」「荒つぽい男や、浪人者の仕業ぢやねえ」「――」「八、俺はもう下手人探しが厭になつたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "くるひ咲",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな優しい人殺しは珍しかろう」「…………」「荒っぽい男や、浪人者の仕業じゃねえ」「…………」「八、俺はもう下手人探しが厭になったよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "くるい咲き",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の方へ出掛ける人も人探しらしいのが頻々として目につく。",
              "citation": {
                "source": "地異印象記",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本号で犯人探しを締切ります。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人探しにはふさわしくない変なお話になってしまいましたが、読者の多くは、論理的にではなくても、作者の隠している真犯人を、已に感づいていらっしゃることと思います。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は僕は初代さんなり深山木氏なりの敵討ちに、君に御手伝いして、犯人探しをやってもいいとさえ思っているのだから、僕の考をすっかり順序立てて話をして、君の意見を聞こうじゃないですか。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホールから出ると、ロナルド・ホープが人探しており、小声で言った。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャロウェイ嬢はすこぶる美人で、とびきりかわいいから、侍女が真犯人を同嬢と言い張る程に似ていれば、犯人探しは難しくない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
