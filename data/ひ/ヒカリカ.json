        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが近代では、都会も田舎もおしなべて電光化し、事実上の都大路になつてゐるのだから、彼等の詩人に月が閑却されるのは当然である。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮の主府京城に景福宮を訪ねられた事のない方々には、その王宮の正門であるあの壮大な光化門が取り毀される事について、おそらく何らの神経をも動かす事がないかもしれぬ。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光化門よ、光化門よ、お前の命がもう旦夕に迫ろうとしている。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光化門よ、お前の存在はまもなく奪われるのだ。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光化門よ、愛する友よ、道ならぬ死に迫られてさぞ無念に思うであろう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、光化門よ、光化門よ、雄大なる哉汝の姿。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光化門において人は李朝の美の権化を目前に仰ぐのである。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に今日の光化門は、その不撓な精神の大胆な披瀝であった。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの光化門の如きは近代の作であるとは言っても、東洋中にそう沢山はない建築である。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に朝鮮を想わせる諸｜官衙を左右にひかえ、聳える北漢山を背景として遥か大通を向うに光化門を仰ぐその光景は、忘れ難いものではないか。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東には建春門、西には迎秋門、北には神武門、そうして南面の正門をこそ、人は名づけて光化門と題したのである。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがために光化門に続く興礼門は既にあとかたもあらぬ。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして残る光化門がその位置に立つべき意義は酷くも奪われてきたのである。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かよくあの洋風の建築が光化門の存在を無視して設計せられたのである事を否定する事が出来るであろう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の東洋、特に走馬燈のように凡てが激変してゆく現代の朝鮮において、あの光化門こそは貴重な遺作品ではないか。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なる技術が光化門より、より荘厳なより巨大なより美しい門を代って建て得るであろう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてあの光化門を破壊するような考えにまで吾々を導かなければならないのであるか。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間は躊躇する事なく光化門の死期を吾々に近づけている。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光化門は景福宮の門であって何処の門でもあらぬ。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、光化門よ、如何にお前は寂しく思うであろう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "光化門よ、長命なるべきお前の運命が短命に終ろうとしている。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし雑誌『改造』に寄せた「光化門」（本書所載）に関する一文は、意外にも忽ちに反響を呼び、東京の英字新聞には直ちに英訳が掲載され、京城の『東亜日報』（朝鮮語新聞）には諺文に依る翻訳が出た。",
              "citation": {
                "source": "四十年の回想",
                "author": "『民藝四十年』を読んで",
                "note": "青空文庫"
              }
            },
            {
              "text": "（第一回目は前述の如く「光化門について」）そうして昭和卅二年（即ち沖縄に渡島してから約二十カ年の後）沖縄タイムス社から往時を追懐してか、公に沖縄文化への貢献者として感謝状を贈られるに至った。",
              "citation": {
                "source": "四十年の回想",
                "author": "『民藝四十年』を読んで",
                "note": "青空文庫"
              }
            },
            {
              "text": "景福宮という王宮で、王宮の正門を光化門という。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "光化門の奥に総督府のこの近代的などえらい庁舎をぶっ建てるとき、景福宮のその正門を東側に移した。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "総督府の前のひろい光化門通りを南へおりると、それと十文字に結ぶ鐘路通りに出る。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "王都の中央にてエルベ河を横ぎる鉄橋の上より望めば、シュロス・ガッセに跨りたる王宮の窓、こよひは殊更にひかりかがやきたり。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "王都の中央にてエルベ河を横ぎる鉄橋の上より望めば、シュロス、ガッセにまたがりたる王宮の窓、こよいはことさらにひかりかがやきたり。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "×浪のひかりか、月の出か、寝覚を照す、窓の中。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北斗は遠し影高し望の光り愛の色かれにもしるき參宿（七）のもなかにひかりかゞやきて（かたどる影は眞善美）三の星こそ並ぶなれ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
