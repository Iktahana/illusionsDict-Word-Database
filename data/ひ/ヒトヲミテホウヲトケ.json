          "literary": [
            {
              "text": "」「どういたしまして、」　と青年はいよいよ弱って、「人を見て法を説けは、外国人も心得ているんでしょう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人を見て法を説けというやつだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人を見て法を説け。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を見て法を説けとやら、こんな場合には矢張り段違いの神様よりも、お馴染みの祖父の方が、却って都合のよいこともあるものと見えます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし翻って考えてみるに、人を見て法を説けという言葉もあり、この計画は雑誌社の人に対してはまず適用されないと思った。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
