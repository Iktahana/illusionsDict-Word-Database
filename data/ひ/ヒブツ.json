[
  {
    "uuid": "21cb9aac-ca59-5d35-98d2-00a5e74258ec",
    "entry": "秘仏",
    "reading": {
      "primary": "ひぶつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
