[
  {
    "uuid": "199b0ca9-de7f-51fc-bac2-590ed6683227",
    "entry": "一溜まり",
    "reading": {
      "primary": "ひとたまり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "holding out for a short while",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『うゝん』と大将、もう一溜まりもなく目を廻してしまったという筋さ」　と語り終った。",
              "citation": {
                "source": "社長秘書",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし大きな地震でもありますと、一溜まりもあるまい。",
              "citation": {
                "source": "母校復興",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花袋は、その後「蒲団」や「一兵卒」など自然主義派の見本のような小説を作って、国木田独歩、岩野泡鳴ら同主義の作家と呼応して、自然主義を文壇思潮の主流たらしめ、硯友社その他の既成老衰作家などを、ひとたまりもなく押し流してしまった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたして、ひとたまりもなかった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひとたまりも無かったのである。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に見よ、瞬間のさき、仄かなる愁の文にしみじみと竜馬の羽うらにほひ透き、揺れて縺つれし水盤の水ひとたまり。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お弓はひとたまりもなく川へ落ちて水音をたてた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四個の薪束の重さで、足がよろよろ浮いているところを、崖に墜落して行く馬の手綱にぐっと引かれて、伝平はひとたまりもなく谷底へ伴れて行かれてしまった。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時のつけ元気で苦しさをまぎらかしたのも、姑息の安を偸んでわずかに頭を休めたのも月末という事実問題でひとたまりもなく打ちこわされてしまう。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その勢いが余りに激しかったので、おきぬはひとたまりもなく突き倒されて、まばらに閉めてある雨戸に転げかかると、雨戸ははずれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "がために、ひとたまりもなくそれは破裂してしまつた。",
              "citation": {
                "source": "水車小屋の日誌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は屡々怒山の実家に、家財横領の目的で闖入するのですが、腕力にかけてはおかくの敵ではなくひとたまりもなくおかくに畳まれてしまふのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その香いのいちばん奥に、中年の男に特有なふけのような不快な香い、他人ののであったなら葉子はひとたまりもなく鼻をおおうような不快な香いをかぎつけると、葉子は肉体的にも一種の陶酔を感じて来るのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠅はひとたまりもなく逃げ去つた。",
              "citation": {
                "source": "若い作家と蠅",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとたまりもなく三人の青坊主達はちぢみ上がって、へたへたとそこに手をつきました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉はひとたまりもなくはね飛ばされて、空地を区切っている塀に投げつけられた。",
              "citation": {
                "source": "人を殺す犬",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はひとたまりもなく、投げ出された形だつた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、人間があのビルディングの五階の窓からあの敷石道へ墜落したら、ひとたまりもなくその場で即死することは疑問の余地がありませんね。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三はどこかそこいらにかの青年の幻がいるような気もしたが、葉子が逗子に行かない前から彼の予感にあったあの恋愛も、現実面へ持ち来たらせられてみると、ひとたまりもなく砕けてしまったのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表情を見るような見ないような視線のはじにうつしとって、瞬間の皮肉を感じながらゆきすぎる男女の生活は、日々の勤勉にかかわらず三千七百円ベースの底がひとたまりもなくわられつつある物価の高さによろめき、喘いでいるのだ。",
              "citation": {
                "source": "偽りのない文化を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もろもろの太陽をも容赦しない時の經過は、私の腦裡に生起する心像の無限をひとたまりもなく片附けてしまふであらう。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　或る日社から早目に歸つて來た圭一郎の苛々した尖つた聲に、千登世はひとたまりもなく竦み上つて、「見つかり次第、何時でも引き越せるやうにと思つて……」と微かな低聲で怖々言つて、蒼ざめた瓜實顏をあげて哀願するやうな眼付を彼に向け、そして片付けてゐたトランクの蓋をぱたりと蔽うた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に河原の近くに位置している為に洪水が出たとすればひとたまりもなく圧し流されてしまう危険があり、あまりに人里離れた土地故に盗賊の心配又大変なものである。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拳しにかかつては、如何に頑丈さうに見えてもその見知らぬ男は恐らくひとたまりもなく、立ちどころに打ちのめされたことだらう。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ひとたまりもなく倒れる相手の男の顔を、したたか藁沓でふみにじった。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、脆い、変化をうけ易い、何か異常な企図を決行しようとする際のような心理状態では、その衝撃には恐らくひとたまりもないことでしょう。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その状態は、そこに何か衝動さえ与えられれば、恐らくひとたまりもないほど脆弱いものだったに違いありません。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "語られる哲学における懐疑説は、おそらくこの投ぜられた槍によってひとたまりもなく射殺されるであろう。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもうそのときには彼らの傍に横たわり拡っていた海が、破壊的な大波をもって襲い寄せて彼らをひとたまりもなく深い闇の中に浚ってって」］行くときは来ておるのである。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "もろもろの太陽をも容赦しない時の経過は、私の脳裡に生起する心像の無限をひとたまりもなく片附けてしまうであろう。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
