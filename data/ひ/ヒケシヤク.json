        "examples": {
          "standard": [
            {
              "text": "火災現場に到着した火消し役が、ホースを伸ばして消火活動を開始した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の火消し役は、命がけで火と戦っていたのだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "火消し役の訓練は非常に厳しく、体力と精神力が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
