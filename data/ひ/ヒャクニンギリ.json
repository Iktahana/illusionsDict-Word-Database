          "literary": [
            {
              "text": "文の段・忍びの段・百人斬りの段などを、誦み上げるやうにして、聞かしてくれた。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "百人斬りは、かなりしつかりとして、力ある上に、笑はせる様な文句も這入つてゐる。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は戦国時代の豪傑の様に、あの百人斬りを、無論文字通り斬る訳ではありませんけれど、百人の命をとるまでは決して中途でこの殺人を止めないことを、私自身に誓ったのです。",
              "citation": {
                "source": "赤い部屋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
