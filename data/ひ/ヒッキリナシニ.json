        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それがまた、若い恋人達にとっては、引っ切り無しに逢っている口実にもなり、お互の必要性を強調する方法でもあったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "結婚ラプソディ",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯一の大通りは狭く山羊が跋扈し、それらが引っ切り無しに鳴らす多彩な鈴の音が心地よい調べを醸していた。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンネン技師からはひっきりなしに、向こうの仕事の進み具合も知らせてよこし、ガスの圧力や山の形の変わりようも尋ねて来ました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法使いは、ひっきりなしに、なべの中に新しいものを入れました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ひっきりなしにうなずきました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、そのあいだも、ひっきりなしに、鉄砲のたまが、アシの中へとんできて、ザワザワと音をたてました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヒルの子は、水の面がすっかりこおってしまわないように、ひっきりなしに、泳ぎまわっていなければなりませんでした。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、おばあさんがお話をすると、ひっきりなしに、「だって、だって」と言っては、口をはさみました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前のほうを見ると、人のかげが、ひっきりなしに、ふわふわと通りすぎていきます。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなずまは、ひっきりなしにピカピカ光り、かみなりは一晩じゅう、ゴロゴロ鳴りつづけました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "外では、遠くで、ドドン、ドドンと、砲声がひっきりなしにきこえました。",
              "citation": {
                "source": "張紅倫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへん御利益のある地蔵様だそうで、信濃、身延のほうからも参詣人が昼も夜もひっきりなしにぞろぞろやって来るのだ。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君枝はその方の案内に、混雑時など、「△△方面へお越しの方はございませんか」　と、ひっきりなしに叫び、声も疲れた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "灸をすえて三十分後にすぐ温泉に浸り、そして十三時間湯殿から一歩も出ず、灸の穴へひっきりなしに湯気をあてて置けば良いのだ。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはその神のさしずで、さっそく、にわとりをどっさり集めて来て、岩屋の前で、ひっきりなしに鳴かせました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "電光もひっきりなしに物凄く燃えた。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とひっきりなしに叫び、声も疲れた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤玉が屋上にムーラン・ルージュをつけて道頓堀の夜空を赤く青く染めると、美人座では二階の窓に拡声機をつけて、「道頓堀行進曲」「僕の青春」「東京ラプソディ」などの蓮ッ葉なメロディを戎橋を往き来する人々の耳へひっきりなしに送っていた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから神との往来がひっきりなしに行われた。",
              "citation": {
                "source": "青蛙神",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の陽に輝きながら、ひっきりなしにぱらぱらと散るのだった。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おやゆび姫はひっきりなしにしくしく泣きました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦工場からの煤煙が、その上から、ひっきりなしに降った。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした厭な空想が、ひっきりなしに瑠璃子の頭を悩ました。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書館のことを考え出すと、彼はその中で過したいろいろな時代の自分の姿が、ひっきりなしに頭の中に浮んできた。",
              "citation": {
                "source": "出世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜店｜商人のまわりには用もない通行人がたちどまって、そこここに人垣をつくっており、夜店などには眼もくれない連中が、両側の人垣の間を、ひっきりなしに次から次へと往き来していた。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "遙か窓の下の街の方では自動車がひっきりなしに走ってゐた。",
              "citation": {
                "source": "稲妻",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その局には、アメリカ各地からの諜報が、ひっきりなしに集ってくる。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の海底には、ひっきりなしに小地震が起っているんです」「まあ愕きましたわね。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も頭上ではいつまでも飛行機の音がひっきりなしにぶんぶんいっていたがね」　船長の顔が夕闇の中に溶けこんで、その表情が見えなくなった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
