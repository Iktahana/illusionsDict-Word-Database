        "examples": {
          "standard": [
            {
              "text": "日本飛行協会が主催する航空ショーには、毎年多くのファンが詰めかける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飛行協会の会報誌には、貴重なヴィンテージ機の修復記録が詳しく載っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "民間の飛行協会が、災害時の物資輸送を支援するためのネットワークを構築した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "余り富裕でないアグネスは英国婦人飛行協会員にはなれなかったので此の募集に自分の将来への活路を見出したように喜んでしまった。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲買人９・25（夕）　堂島の仲買人曾我某氏がいつぞや帝国飛行協会に一万円を寄附した事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "国防飛行協会クラブ主催屋外音楽会の広告ベンチがいくつも壁にそって並んでいる。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝国飛行協会はこれを三百にまで漕ぎつけようとして奮起した。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
