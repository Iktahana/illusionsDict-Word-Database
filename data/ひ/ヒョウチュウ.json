  {
    "uuid": "8599d626-0f61-5ba5-8919-f8f1bd31309c",
    "entry": "評注",
    "reading": {
      "primary": "ひょうちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
