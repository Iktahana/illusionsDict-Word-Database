        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "挫折を繰り返すうちに、彼の性格は次第に捻くれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "世の中の不条理を嘆くばかりで、彼の心は捻くれる一方だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "捻くれた見方ばかりしていると、大切なことを見失ってしまうよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
