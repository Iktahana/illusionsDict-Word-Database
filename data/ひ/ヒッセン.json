          "literary": [
            {
              "text": "クリストフの筆戦をよさせようと彼に決心させるためには、これ以外に策はないと彼らは見て取ったのである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の音楽上の筆戦にはもうたくさんだ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
