    "definitions": [
      {
        "index": 1,
        "gloss": "emperor's wife and concubines",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "無遠慮に評せば、擬人せる貧窶の妃嬪の裝束したるとやいふべき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが発達すれば、后・皇子の為のものは、妃嬪・諸王・寵臣の上にも及ぶこと、既記の通りである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、代々の后妃に出雲系、随つて、水神系の多い事は、事実であつて、此で見ると、代々の妃嬪は古く皆、水神の娘の資格で、宮廷に上られ、更に、出雲系の女の形式を以て、仕へ始められたものといふ事が、出来さうなのである。",
              "citation": {
                "source": "神道に現れた民族論理",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷には父王とその千人の妃があり、それに対して新王は、恋愛のことにははなはだ理想主義的であって、理想の女のほかには妃嬪を寄せつけない。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "インカの妃嬪は多数であるが、位を嗣いだのは正式の王妃の長子であったらしい。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくに兄の一条｜頭ノ大夫行房は、隠岐配所にまでお供をして、始終、帝とあの一ト頃の艱苦を共にした侍者の一人でもあったから、還幸の後は、みかども、いちばい行房にはお目をかけられ、末の妹の勾当ノ内侍も後宮に入って、あまたな妃嬪のうちでさえかがやく寵幸を身一つにほこっていた。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしずく後宮の私たちは、廉子さまはじめ二十人もの妃嬪で御寵を競っていました。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、まわりの妃嬪や、貴族たちにあります。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、宮枢の秘に触れ、天皇、上皇、妃嬪たちをも、一列の登場人物とみなして、淡々と、えがいてみたい希いを伴っています。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬もひひんと鳴いています。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬もひひんと鳴いてゐます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か黒山のような物に打付かって、斛斗を打って仰様に転ぶと、滝のような雨の中に、ひひんと馬の嘶く声。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の馬の皮を被せられた太った尼は、馬になるとともにひひんひひんと言って地を蹴だした。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと気がつくと、何処かで人の声がする、馬のひひんと嘶くのが耳に這入る。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかりでちょうど百たび打った時、もうだんだん虫の鳴くような声でそれでもひいひいいっていた坊さんは、急に一声高く「ひひん。",
              "citation": {
                "source": "人馬",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとさっきの鬼の坊さんは、また戻って来て、こんどは二ばんめの坊さんを庭に引き下ろして、同じようにむちで百たびぶちますと、これも馬になって、「ひひん。",
              "citation": {
                "source": "人馬",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はひひんといなないて、ぱっか、ぱっか、あるき出しました。",
              "citation": {
                "source": "たにしの出世",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に珍しいつやつやとした黒毛の若駒で、背も高く骨組みもたくましく、ひひんといなないて太い尾を打ち振りながら、ぱっかぱっかと街道を進む姿は、見るも勇ましいものでした。",
              "citation": {
                "source": "天下一の馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、家へ戻ったらうんとごちそうしてやるからな」　馬はその言葉がわかったように、ひひんと一声高くいなないて、しゃんしゃんぱかぱかと、鈴の音も蹄の音も勇しく、足を早めに歩き出しました。",
              "citation": {
                "source": "天下一の馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚兵衛はとても追っつかないので、馬車の上に飛び乗りますと、黒馬はひひんと高くいなないて、またたくまに家まで駆け戻りました。",
              "citation": {
                "source": "天下一の馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後姿を見送って、甚兵衛はあっけにとられてぼんやりしていましたが、ひひんと一声高く馬がいなないたので、初めて我に返って、馬の頭を撫でてやりながら、あはははと大声に笑い出しました。",
              "citation": {
                "source": "天下一の馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩馬は、痛さにたえかねたらしく、ひひんと嘶いて急に駈けだしました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろばはひひんとわめきました。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の姿が公園の入口の石段のところにあらわれると、馬は、いかにも待ちどおしかったというように、首を大きくあげたりさげたりしながら、ひひんと嘶く。",
              "citation": {
                "source": "キャラコさん",
                "author": "馬と老人",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬のほうは、ただ、ひひんといなないただけであった。",
              "citation": {
                "source": "キャラコさん",
                "author": "新しき出発",
                "note": "青空文庫"
              }
            }
          ]
        }
