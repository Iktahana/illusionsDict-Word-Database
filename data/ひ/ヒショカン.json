    "definitions": [
      {
        "index": 1,
        "gloss": "minister's secretary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然らざればヂニアスは真個の狂人のみ、靴屋にもなれず、秘書官にもなれぬ白痴のみ。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は東京に在りて、すでに天方伯の秘書官たりしが、余が免官の官報に出でしを見て、某新聞紙の編輯長に説きて、余を社の通信員となし、伯林に留まりて政治学芸のことなどを報道せしむることとなしつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "門者に秘書官相沢が室の番号を問いて、久しく踏み慣れぬ大理石の階を登り、中央の柱に「プリュッシュ」を被える「ゾファ」を据えつけ、正面には鏡を立てたる前房に入りぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所長の俸給………………………………五〇〇弗政務長官の俸給………………………………四一五弗警察署長（瑞典人）の俸給…………………一四〇弗裁判所長秘書官の俸給………………………一〇〇弗サモア王ラウペパの俸給………………………九五弗　一斑推して全豹を知るべし。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事知りて諌めし、内閣の秘書官チイグレルは、ノイシュワンスタインなる塔に押籠めらるるはずなりしが、救ふ人ありて助けられき。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が、日本で初ての政党内閣に、法相の椅子を、ホンの一月半ばかり占めた時、秘書官に使って以来、ズッと目をかけて来た男だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　その翌朝の九時頃、霞ヶ関の東亜局の一室で、露木秘書官が、朝の一便で着いた手紙の整理をしていた。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははは」　彼は秘書官の肩ごしに、ぽいとその手紙を事務机の上へほうりだした。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　露木秘書官は心配そうな表情をして局長を見あげて何か言おうとしたが、局長は柱時計を見て急に言った。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "局長は大きくのびをして秘書官を振り返って言った。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十六号に乗っていたのは、東亜局長と秘書官とではなくて、東亜局長の次男の勝男だった。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし大帥閣下、馮副官からの無電がまいりました」　と、蒋秘書官が、楊博士の長い袖を引いた。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が、日本で初ての政党内閣に、法相の椅子を、ホンの一月半ばかり占めた時、秘書官に使つて以来、ズツと目をかけて来た男だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御覧の通り、今晩はこんな宴会中ですから……」　たぶん菊池とかいう秘書官らしい男が僕の名刺を持って挨拶に出て来た。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　秘書官は引っこんで行った。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "変なことをするなと思っていると、こんどは左手の壁の中にあるドアを開けて、さっきの秘書官がはいって来た。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も此の様を見ずとても下女や仲働きが「秘書官」と云う様な文章も観察と共に優れた本を著わし得る筈はない故、少し考えればお酉でないと充分に分る所では有るのサ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫まで秀子は今まで通り此の土地の宿屋に居て日々此の家へ来る筈だ」余「何しに来ます」叔父「己の書き物などを手伝いに来るのサ実は朝倉家に居る間も手紙の代筆などを頼んで見たが流石『秘書官』の著者だけに、己が在官中に使って居た書記よりも筆蹟文章ともに旨い。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "是から日々此の家へ来て幽霊塔の修繕に就いての考案などを己と相談し其の傍ら己の書斎をも整理して呉れる筈だ、其の様な事柄には仲々面白い意見を持って居るよ、己は先ア娘兼帯の秘書官を得た様な者だ」と云い、更に思い出した様に「シタがお浦は何うした」と問うた。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かに聞き得たのは、此の国へ来るまで米国のルイジヤナ州の州会議員から挙げられた行政官何某の秘書を勤めて居て、爾して彼の「秘書官」と云う書を著し、其の書の出版前に米国を出たと云う一事だけだ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤公が、金の飾りのついた洋杖をかたわらに、何か書いた紙片を満鉄総裁｜中村是公氏、宮内大臣秘書官森泰二郎氏に示している。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話は、実に面白いではないか、右筆といえば、今の秘書官だが、宰相の片腕ともなるべきこの右筆が、孔子の名さえ知らないといえば、その人の学問も大抵は知れる。",
              "citation": {
                "source": "黙々静観",
                "author": "勝海舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に較べると、今の秘書官などは、外国の語も二つや三つは読めるし、やれ法律とか、やれ経済とか、何一つとして知らないものはない。",
              "citation": {
                "source": "黙々静観",
                "author": "勝海舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、不思議のことは、孔子の名さえ知らない右筆を使つた時の政治より、万能膏の秘書官を使ふ時の政治が、格別優つても居ないといふ事だ。",
              "citation": {
                "source": "黙々静観",
                "author": "勝海舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は東京に在りて、既に天方伯の秘書官たりしが、余が免官の官報に出でしを見て、某新聞紙の編輯長に説きて、余を社の通信員となし、伯林に留まりて政治学芸の事などを報道せしむることとなしつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "門者に秘書官相沢が室の番号を問ひて、久しく踏み慣れぬ大理石の階を登り、中央の柱に「プリユツシユ」を被へる「ゾフア」を据ゑつけ、正面には鏡を立てたる前房に入りぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時同君はすでに床次内相の秘書官になつてゐた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそんな具合にして、しまいには馬を『秘書官』などと呼んだりした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそれが主事の手許へ行き、課長のところへ移されて、それから秘書官に廻されるちうと、初めてそれが秘書官の手を経て本官の許へ提出されるのが順序なのじゃ……」「ですけれど閣下、」とアカーキイ・アカーキエウィッチは、なけなしの勇気をふりしぼると同時に、おそろしく汗だくになったと自ら感じながら口を切った。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
