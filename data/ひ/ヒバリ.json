    "definitions": [
      {
        "index": 1,
        "gloss": "skylark (Alauda arvensis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "キャディが雲雀の巣を見付けた。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち「竹とその哀傷」「雲雀料理」最も古く、「悲しい月夜」之に次ぎ、「くさつた蛤」「さびしい情慾」等は大抵同年代の作である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲雀料理五月の朝の新緑と薫風は私の生活を貴族にする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の生活にもいつかは一度、あの空に光る、雲雀料理の愛の皿を盗んで喰べたい。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲雀料理ささげまつるゆふべの愛餐、燭に魚蝋のうれひを薫じ、いとしがりみどりの窓をひらきなむ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれあれみ空をみれば、さつきはるばると流るるものを、手にわれ雲雀の皿をささげ、いとしがり君がひだりにすすみなむ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦心霜ふりてすこしつめたき朝を、手に雲雀料理をささげつつ歩みゆく少女あり、そのとき並木にもたれ、白粉もてぬられたる女のほそき指と指との隙間をよくよく窺ひ、このうまき雲雀料理をば盗み喰べんと欲して、しきりにも焦心し、あるひとのごときはあまりに焦心し、まつたく合掌せるにおよべり。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長詩二篇雲雀の巣おれはよにも悲しい心を抱いて故郷の河原を歩いた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原よもぎの中にかくされた雲雀の巣。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴよ、ぴよ、ぴよ、ぴよ、ぴよ、ぴよ、ぴよ、ぴよと空では雲雀の親が鳴いてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはかわいさうな雲雀の巣をながめた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巣の中のかすかな光線にてらされて、ねずみいろの雲雀の卵が四つほどさびしげに光つてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴよ、ぴよ、ぴよ、ぴよ、ぴよ、ぴよ、ぴよ、ぴよと、空では雲雀の親たちが鳴いてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはいぢらしくも雲雀の卵を拾ひあげた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無人島でない事はその山よりも高い空で雲雀が啼いているのが微かに聞こえるのでわかる。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "田畑ある島と知れけりあげ雲雀、これは僕の老父の句であるが、山のむこうには人家があるに相違ないと僕は思うた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを云うと、虫屋さんに憎まれるかも知れませんが、松虫や草雲雀のたぐいは値が高いばかりで、どうも江戸らしくありませんね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "畠の岸で見つけた雲雀の卵を取って、罰金と仕末書を取られた者がある。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピイ、キリ／＼と雲雀が鳴くと、ぐらりと激しく俥が揺れた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と喚くと、楫棒をたゝき投げて、車夫は雲雀と十｜文字に飛んで遁げた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春も闌の遅桜、早桃が見渡す限りの筑紫野の村々に咲き乱れて、吾れ勝ちに揚る揚雲雀も長閑な博多東中洲の野菜畑の間を縫うて行く異様な二人連れがあった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜種と蓮華草のモザイクに数限りない雲雀の声と蝶の羽根が浮き上っている。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから辛夷の花が咲き、郭公が訪れ、木の芽が木の種類によつて花よりも美しい鮮明な色に染まり、雲雀が謠ひ出し、あらん限りの春の花が一時に競ひ咲くまでには一ヶ月を要しないだらう。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その汗を乾かさうと、雲雀は空に隲る。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "土は薔薇色、空には雲雀空はきれいな四月です。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてトシオが来たのは、春の頃、トシオが雲雀の声を聞き乍ら、お友達とのどかに摘み草をしたり、夏のみずみずしい緑葉をふみ乍ら、姉様達と蛍狩をした、広い野原でありました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "里の言葉を知らぬ身も、戀には女賢うして、袖に袂に蔽ひしが、月日經つまゝ、鶴はさすがに年の功、己が頭の色や添ふ、女の乳の色づきけるに、總毛を振つて仰天し、遍く木の葉を掻搜して、男の裾を見出ししかば、ものをも言はず一嘴、引咬へて撥ね飛ばせば、美少年はもんどり打つて、天上に舞上り、雲雀の姿もなかりしとぞ。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲雀は鳴こうとしているんでしょう。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、ひばりも、あまり美しい鳥ではありませんが、よだかよりは、ずっと上だと思っていましたので、夕方など、よだかにあうと、さもさもいやそうに、しんねりと目をつぶりながら、首をそっ方へ向けるのでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまが又かっと明るくなり、二人はむしろに座ってひばりもゐないのに、「ひばり焼げこ、ひばりこんぶりこ、」なんて出鱈目なひばりの歌を歌ってゐました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
