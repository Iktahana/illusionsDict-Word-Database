[
  {
    "uuid": "d847ffa9-d832-5e11-b2f2-e947464db1c2",
    "entry": "人山",
    "reading": {
      "primary": "ひとやま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
