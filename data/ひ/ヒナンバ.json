      {
        "index": 1,
        "gloss": "evacuation center (typically indoors, e.g. schools, gyms, community centers)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
