[
  {
    "uuid": "a68943bc-d56d-56a2-961c-971a2877b6ce",
    "entry": "人出",
    "reading": {
      "primary": "ひとで",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
