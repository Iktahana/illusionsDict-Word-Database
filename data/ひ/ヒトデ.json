      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "crowd",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新宿ほどにも人出が多くて、新宿ほどにも非近代的な所はなからう。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぺ吉がまた一人出て来て、「そでない。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "広小路の松坂屋へはいって見ると歳末日曜の人出で言葉通り身動きの出来ない混雑である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街は人出で賑やかに雑鬧していた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭ならいいさと二人出て行こうとする。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは氣持のよい、人出入りの多い病院ではあるけれど、私達はノオトル・ダァム・ド・パリの正面を眺めようとしたら、ほとんど命がけだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "じいさんとばあさんとは、大きな建物や沢山の人出や、罪人のような風をした女や、眼がまうように行き来する自動車や電車を見た。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに人出の少ないのは時刻のせいだろうが、これなら、いつかそのうちにスケッチでも描きに来るといいという気がした。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは美しい秋晴の日であったが、ちょうど招魂社の祭礼か何かの当日で、牛込見附のあたりも人出が多く、何となしにうららかに賑わっていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ衣装をつけた舞人が四人出て、同じような舞をまうのであるが、これもちょうど管弦楽と全く同じようにやはり一種の雰囲気を醸出する「運動の音楽」であるように思われた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに尾州家から侍が二、三人出て来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "順礼がとぼ／＼と一人出た。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて背中に紗の翼のはえた、頭に金の冠を着た子供の天使が二人出て来て基督孩児の両側に立つ。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町はたいそうな人出で巡査がおおぜい出て警戒しています。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると向うのすすきの中から、荷物をたくさんしょって、顔をまっかにしておかみさんたちが三人出て来ました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の日曜とて、青山の通りは人出多く、大空は澄み渡り、風は砂を立てぬほどに吹き、人々行楽に忙がしい時、不幸の男よ、自分は夢地を辿る心地で外を歩いた。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは出られましやうとも、然し空知川の沿岸の何処等ですか其が判然しないと……」「和歌山県の移民団体が居る処で、道庁の官吏が二人出張して居る、其処へ行くのですがね、兎も角も空知太まで行つて聞いて見る積りで居るのです。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜は昼間の賑わいに引きかえて、月の景色の妙なるにもかかわらず人出少し。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを相島は引きとつて、「うむ、長屋のアマゾン連も二三人出て見て居た」と云ふ。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは寺院の森の霧つた空……その時子供は父母の膝下で蕎麦を食うべ、その時銀座はいつぱいの人出、浅草もいつぱいの人出、その時子供は父母の膝下で蕎麦を食うべ。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時銀座はいつぱいの人出、浅草もいつぱいの人出。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時囚人は、どんな心持だらう、どんな心持だらう、その時銀座はいつぱいの人出、浅草もいつぱいの人出。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も、ごぞんじ無いのだ、と私は苦しさを胸一つにおさめて、けれども、その事実を知ってしまってからは、なおのこと妹が可哀そうで、いろいろ奇怪な空想も浮んで、私自身、胸がうずくような、甘酸っぱい、それは、いやな切ない思いで、あのような苦しみは、年ごろの女のひとでなければ、わからない、生地獄でございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治家肌のひとで、多少、政黨にも關係があつたやうである。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく、できるひとで、クラスのトツプだつたらしいが、いまは、どうしてゐるだらう。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木校長が檢事局につれて行かれて、そのつぎに來たのは、戸澤とかいふひとであつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白皙の肌の匂ひと、香水の匂ひとでぎつちりだつた。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならどんなこどもでも、また、はたけではたらいているひとでも、汽車の中で苹果をたべているひとでも、また歌う鳥や歌わない鳥、青や黒やのあらゆる魚、あらゆるけものも、あらゆる虫も、みんな、みんな、むかしからのおたがいのきょうだいなのだから。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　するとすぐ足もとで星の形で赤い光の小さなひとでが申しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんたちは青いひとでのしるしをつけていますね。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
