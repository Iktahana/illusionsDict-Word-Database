  {
    "uuid": "06ec2c20-ad8a-525f-b094-b8f7d3c641f1",
    "entry": "貔貅",
    "reading": {
      "primary": "ひきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ferocious leopard-like beast (Chinese legendary animal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これ適以て軍旅の鋭を殺ぎ、貔貅の胆を小にするに過ぎざるのみ、智なりという可からず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "峻峰皆將軍、磊嚴盡く貔貅たり。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾に讎あり、貔貅群がる、　　　　　　讎は逃すな、勇士の膽。",
              "citation": {
                "source": "從軍行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでせきばらいでもされたなら何千万の貔貅といえども道を開けるに違いない。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども商売が如何に繁昌するも、産業がなにほど隆盛に趣くも、はたまた個人の所得如何に裕かに、国庫の歳入が幾ら充溢するも、更にまた鉄艦海を蔽うも、貔貅野に満つるも、未だ以て必ずしも国家の基礎鞏固なりとは申されません。",
              "citation": {
                "source": "国民教育の複本位",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "つつしんで賀唱いたします――」銅雀台高ウシテ帝畿壮ナリ水明ラカニ山秀イデ光輝ヲ競ウ三千ノ剣佩黄道ヲ趨リ百万ノ貔貅ハ紫微ニ現ズ　と朗々吟じた。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "是ニヨリテ、不才、犬馬ノ労ヲ尽シ、貔貅ノ大軍ヲ領シテハ、六度、祁山ノ陣ニ出ヅ。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
