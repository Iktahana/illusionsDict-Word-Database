        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "霧の向こうに何があるのか、瞳を凝らして見極めようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古文書の消えかけた文字を読むために、老学者は瞳を凝らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "瞳を凝らせば、水平線の向こうに微かに船影が見えるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "浜の砂庭に吹き散り、陸橋の下には傷つきし犬瞳を凝らす。",
              "citation": {
                "source": "庭園の雨",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、息をあえいで太腿を改め、凍りついた、腐肉の上に瞳を凝らすと、やはりそこにはグレプニツキーの言うがごとく、EL DORADO RA という文字がしたためてあるのだ。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ――たしかに、誰ぞ、似た顔を見たような――」　三斎は、ますます魅入られたもののように瞳を凝らす。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして五人いっしょに立並んで、じっと瞳を凝らすと、まさしくそれは大きな裸の人形で、俯向きに草のなかに放りだしてあり、頭のおかっぱの毛がちょっぴり見えていた。",
              "citation": {
                "source": "椿の花の赤",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞳を凝らすと、それが次第に濃くなってきた。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて、ひとみをこらす中意識がはっきりして来たらそれは夢の一種のつづきで、襖をもれる隣室の電気の光を、夢でみていたものとむすびつけてそうみていたものという事が解った。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
