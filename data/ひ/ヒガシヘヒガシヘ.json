    "definitions": [
      {
        "index": 1,
        "gloss": "constantly eastward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが淀みなく東へ東へと走り続けるのである。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園を抜けて、北浜二丁目に出ると、男は東へ東へと歩いて行きます。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処は鄂博――蒙古児陀羅海、春ながら冬、霾らす、霾らす茫漠たる内蒙古、涯しなき視野、東へ東へと移動しつつある沙漠の凛然たる寒気の底に於て。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、例の樺と白との別荘だなと思うと、中仙道は川添いの松原と桃林との間を東へ東へと驀進しつつある。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、そこから、なお東へ東へとかじを取って、やがて摂津の浪速の海を乗り切って、河内国の、青雲の白肩津という浜へ着きました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、眞珠や黒耀石を追ひ求めては、果てしない太平洋の眞蒼な潮の上を、眞紅な帆でも掛けて、恐らくは葦の莖の海圖を使用しながら、或ひは、今でも我々の仰ぐオリオン星やシリウス星を頼りに、東へ東へと渡つて行つたに違ひない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、真珠や黒耀石を追い求めては、果てしない太平洋の真蒼な潮の上を、真紅な帆でも掛けて、恐らくは葦の茎の海図を使用しながら、あるいは、今でも我々の仰ぐオリオン星やシリウス星を頼りに、東へ東へと渡って行ったに違いない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓首」　御用のため、江戸表へ急の旅立と偽って桝形門を抜け、石堂川を渡って、街道を東へ東へと急いだ平馬は、フト立止まって空を仰いだ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日凍りつくような濃霧の間を、東へ東へと心細く走り続ける小さな汽船の中の社会は、あらわには知れないながら、何かさびしい過去を持つらしい、妖艶な、若い葉子の一挙一動を、絶えず興味深くじっと見守るように見えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆のような闇が大河の如く東へ東へと流れた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "迫り来る敵機　大胆にも飛行島の夜間偵察をおえた柳下航空兵曹長は、艦載機一号を操縦して暗の中を東へ東へとびつつあった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――船中では誰もが南京虫にやられて、ぽり／＼からだをかきながら苦笑してゐる、飯は純外米、ぽろ／＼こぼれる、ボロ船だけれど、ごろ／＼寝てゐるうちに東へ東へ、南へ南へ。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす青い様な空気の中に素早い動作で游いで居るトンボと蝙蝠の幾匹かは、一層高いところを、東へ東へと行く白鳥の灰色の影の下に如何にも微妙な運動をしめして居る。",
              "citation": {
                "source": "ひととき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二列縦隊に蜒々と、東へ東へとあるいて行く。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合自動車は街を出外れると、細い田舎道を東へ東へと疾駆した。",
              "citation": {
                "source": "旧師の家",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「アトリエ」昭和四年七月）旅の断片　私の旅の希望をいうと、東風が吹けば東へ東へと用事も責任もなく流れて行く流儀の旅がしてみたいと思うのである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす汚なく曇つた空の下に、無秩序に無反省に無道徳に活動し發展しつゝある大阪よ、さらばさらばといふ樣に、烟突から煤烟を吐き出しながら、東へ東へと急走した。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、富士男の父の所有する、スクーナーと称する帆船で、この団体は夏期休暇を利用して、近海航行についたのが暴風雨になやまされて、東へ東へと流されたのであった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、昭和遊撃隊は、今や海の猛獣となって、東へ東へまっしぐらに驀進するのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　やがて『荒鷲』は、舵を下げて嵐の中を、東へ東へと、波とすれすれに低く低く飛んで行った。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　フーラー博士が、窓から首を出して外の海をのぞくと、あっ、見よ、荒れ狂う海上を、鯨のような大潜水艦が三隻、一列の縦陣をつくって、東へ東へ走っているではないか。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしらは日本の同盟軍　それから十幾日、波また波を乗りこえ、島から島をつたって、五艘の小艦隊は東へ東へ航海した。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどりの島を後にして、東へ東へすすむ二百隻。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠は深夜の江戸市中を東へ東へと進んで行った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先登はヘッスラーで、次が私、フォイツは後殿である、ガイドの持ったランターンが、踏み固めた雪路に赤くにじんで、東へ東へと揺れて行く。",
              "citation": {
                "source": "登山の朝",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "デンクマール・シュトラーセから、また湖水のふちに戻って来たが、霧は深し、日曜ではあるし、街をうろついても初まらないから、そのままクエイ・ナツィヨナール Quai-National から、真っ白な湖畔のプロムナードを、宛てもなく東へ東へと歩いて行った。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "先登はヘッスラーで、次が私、フォイツは後殿である、ガイドの持ったランターンが、踏み固めた雪路に赤く滲んで、東へ東へと揺れて行く。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "西なる京に生れ玉へる君はしも、東に覇府ありてより幾百年、唯東へ東へと代々の帝父祖の帝の念じ玉ひし東征の矢竹心を心として、白羽二重に緋の袴、五歳六歳の御遊にも、侍女を馬にして、東下りと宣らしつゝ、御所の廊下を駆り玉ひき。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒雲は、手の届きそうな近くに、怒濤のように渦を巻きつつ、東へ東へと走ってくる。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがだん／＼に東へ東へと進んで行きまして、五畿内地方からその附近が金屬を用ひる時代になりましたが、東北地方にはその後長く、石器時代の文化が殘つてゐたものと思はれます。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
