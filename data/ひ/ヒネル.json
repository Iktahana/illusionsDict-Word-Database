[
  {
    "uuid": "84a3fc97-fd2e-5ae6-bb98-7b48f12899bf",
    "entry": "捻る",
    "reading": {
      "primary": "ひねる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to twist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、まあこのおしまひの手合なんぞは、云つてることに何の意味もないにしてからがチヨイト頭を捻ること言換れば位置にお構ひなしに移動の万能範囲を拡げることが、いとも優秀なことのやうに思はれることは現時の流行感冒である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本紙を幅五、六分に引き裂いたのに火鉢の灰を少し包み込んで線香大の棒形に捻る。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この捻ることが縁であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ですよ、奥庭に有った手水鉢を見ましたがね、青銅のこんな形、とお鹿の女房は仕方をして、そして竜の口を捻ると、ザアです。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とばかりで、三和土に立った警官は、お孝が降りて来た階子段を斜に睨んで、髯を捻る事｜専なり。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と極めて、その気で髯を捻るのであったが。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、皿から捻るやうに引摘んで、別に燒團子を五串添へた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお先刻の腹癒に、滅茶々々に撲り潰さんと、例の鉄棒を捻る時、銀平は耳を聳てて、「待て！",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目を避けて、蹲って、虱を捻るか、瘡を掻くか、弁当を使うとも、掃溜を探した干魚の骨を舐るに過ぎまい。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と脇腹へ両肱を、しっかりついて、掻竦むように脊筋を捻る。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さてさて捻るわ、ソレそこが捻平さね。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　また甘えるように、顔を正的に差出して、頤を支えた指で、しきりに忙く髯を捻る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蚤だか虱だかを捻る片手間に、部屋から下ったという蕎麦の残り、伸びて、蚯蚓のようにのたくるのを撮んじゃ食い、撮んじゃ食う。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　その間に、お君は縁側に腰をかけて、裾を捻るようにして懐がみで足を拭って、下駄を、謙造のも一所に拭いて、それから穿直して、外へ出て、広々とした山の上の、小さな手水鉢で手を洗って、これは手巾で拭って、裾をおろして、一つ揺直して、下褄を掻込んで、本堂へ立向って、ト頭を下げたところ。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と謂ふも譽め樣を捻るのなり。",
              "citation": {
                "source": "神樂坂七不思議",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、何時帰った、ブルジョアはちがったものだね、ちょっと俳句を捻ると云っても、あんな処まで出かけて往くのだから、どうだ、好い女でも見つかったかい」　画家はとり散した絵具だらけの穢い室でウイスキーを飲んでいた。",
              "citation": {
                "source": "草藪の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢中で居ながら、あれ、誰が来て怨む、彼が来て責める、咽喉を緊める、指を折る、足を捻る、苦しい、と七転八倒。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（呑口を捻る）――親仁、またそこらへ打倒れては不可いよ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と引くり返して鼻緒を掴んでちょっと捻る。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭は竈の前に両足を拡げながら、片手で抜取って銀煙管を銜え、腰なる両提ふらふらと莨を捻る。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "被せられるのを、「何、そんな、」とかえって剪賊に出逢ったように、肩を捻るほどなおすべりの可い花色裏。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目を避けて、蹲つて、虱を捻るか、瘡を掻くか、弁当を使ふとも、掃溜を探した干魚の骨を舐るに過ぎまい。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "捻る、押すか、一たび指が動けば、横浜、神戸から大船が一艘、波を切って煙を噴くんだ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、尼婆さんの首を捻る処へ上って来て、当世はやりの黒繻子の帯……　と言継いだ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一品生産的なハードの作り方はここでも変わっていなかったし、価格も技術屋連中が「どうやって上司をだまそうか」と頭を捻るレベルだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたを付けたと思っていた遺伝に関しても、首を捻るような事実がいくつも見つかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ん坊の手を捻るのは、造作もねえこった。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "答えるというより捻るのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この画房は椿岳の亡い後は寒月が禅を談じ俳諧に遊び泥画を描き人形を捻る工房となっていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから一方が水道の栓を捻ると、一方が屈み難い腰を無理に屈めて水道の栓に噛りついた。",
              "citation": {
                "source": "飯田橋駅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
