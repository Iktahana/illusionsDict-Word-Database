    "definitions": [
      {
        "index": 1,
        "gloss": "to resound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "響くといふこともないけれども、何かしら本当に仕事してゐるものを却て一時的とはいへ吃驚させたりするのだ。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論かういふことは、これと明確に云へることではないが、今仮りに手短かに云つてみるならば、短歌・俳句は、その形の大小を云ふのではないが、はやかぼそい歌声と我等が耳に響くのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコトコと足音が後頭に響くと、先刻父と話してゐた弟が来て、トランプをしようと言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "地車のとどろと響く牡丹かな　牡丹という花は、夏の日盛りの光の下で、壮麗な色彩を強く照りかえすので、雄大でグロテスクな幻想を呼び起させる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かで轡虫の鳴くのが静かな闇に響く。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外にまだなんだか胸に響くような鋭い喜びと悲しみの念が湧いて来る。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単調な声でゆるやかな拍子で「ナーンモーンデー」と唱えると鉦の音がこれを請けて「カーンコ、カンコ」と響くのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳に響くはただ身を焼く熱に湧く血の音と、せわしい自分の呼吸のみである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは空の歌、朝、高空に、鳴響く空の歌とでもいふのであらうか？",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはもう少し誰にも分かりやすい言葉で誰の頭にもぴんと響くようなものを捕えて来るのが捷径ではないかという気がしますが如何でしょうか。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらあの方が神仙の乳を飲まして下すったって……」　いうことがどういうふうに女に響くか窃視したのち、「ねえ、お嬢さん。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の前がすぐ大堰川の流で「梵鐘は清波を潜って翠巒に響く」という涼しい詩偈そのままの境域であります。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "関の小まんが米かす音は一里聞えて二里響く。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ石英安山岩、いやに響くなこいつめは。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わが祖国」というよりは「マイン・ファーターランド」といった方が遥に荘重に響く。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の物いう声が遠方に聞こえる代りに自分の声が妙に耳に籠って響くので、何となく心細くなってしまった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの録音ならびに発音器械の不完全を利用して、近いピストルを遠く聞かせたり、人声を井戸の底から響くように聞かせたりすることも可能になるわけである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして枕もとの時計のチクタクだけが高く響く、あるいは枕に押しつけた耳に響く脈搏を思わせる雑音を聞かせるのもいいかもしれない。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう云ったニーチェのにがにがしい言葉が今更に強く吾々の耳に響くように思われる。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "声の響くほど山は静かなのだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）翌朝――猿若町に櫓の太鼓鳴り響けば　鳴り響く櫓太鼓――　＝（Ｆ・Ｉ）お光の茶店（朝まだき）　駕籠が一丁待っている。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫓に芝居の果てを知らせる太鼓が鳴り響く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「我が慈悲道得の刀を　受けよと言うより早く」　と話す武蔵「スラリとばかりＴ「両刀抜き放ちて　飛びかかり」　身振り手振りも面白くＴ「この時妖雲　谷を覆い　山は轟々　と鳴り響く」Ｓ＝辻堂　猛々と立ちこめた白煙。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の下の往来を馬車が通つて、窓硝子に響く。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はＫさんと言葉を交へながらも、自分の聲が肝高に響くやうな氣がしてならなかつた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夜が更けて行つたならば、あのさわやかな鐘の音が眞夜中を報じてしんしんと鳴り響くのであらう。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上の眞黒に繁つた枝から水がぼた／＼落ちる、墓穴のやうな溪底では水の激して流れる音が悽く響く。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "食らう時かたわらよりうまきやと問えばアクセントなき言葉にてうましと答うその声は地の底にて響くがごとし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野分」「二百十日」こういう言葉も外国人にとっては空虚なただの言葉として響くだけであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バーからひびくレコード音楽は遠いパリの夜の巷を流れる西洋｜新内らしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
