        "examples": {
          "standard": [
            {
              "text": "ファンタジーの世界では、ライオンの体と鷲の頭を持つヒポグリフが空を駆ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "魔法使いの少年は、忠実なヒポグリフに乗って広大な森を探検した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神話の生き物であるヒポグリフは、しばしば誇り高く、気高い存在として描かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "精神を、救済者を、ペガサス（翼馬）やヒポグリフ（鷲頭怪馬）などに乗った広大な騎者を、両翼をひろげて蒼天からおりて来る曙の色に輝いた戦士を、燦然たる未来の騎士を、かかる宿命は永遠に待っていなければならないのであろうか。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
