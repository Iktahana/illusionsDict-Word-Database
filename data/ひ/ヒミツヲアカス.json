          "literary": [
            {
              "text": "お前の婚礼がすんで翌る日になったら、わしはお前にその真珠の秘密を明かすとしよう。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "友――君に秘密を明かすと、おれが背中を向けるが否や、すぐに、そいつを手帳に書きつけるんだ。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密を明かす　それで私は前大蔵大臣に申しました。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
