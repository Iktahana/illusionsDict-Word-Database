        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "消費税の増税後、個人消費の冷え込みが顕著に現れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "景気の冷え込みを受けて、多くの企業が設備投資を控えるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "株式市場の冷え込みが続いており、投資家たちは慎重な姿勢を崩さない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
