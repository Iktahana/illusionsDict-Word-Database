        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつだったか、ヒマラヤ山脈のふもとの村にあらわれて、人々をおどろかしたというあの恐龍。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界地図をひろげてみるとわかるが、日本からヨーロッパへとぶには、どうしても、ヒマラヤ山脈にぶつかるのであった。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから針路をインドの北どなりにとり、まるで天然の万里の長城のようなヒマラヤ山脈を越え、チベットやネパールやブータンの国々の間をぬい、そして一気にアフガニスタン国のカブールという都市まで無着陸の飛行をつづけなければならなかった。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら、ここは、ヒマラヤ山脈の高峰らしいが、どこかに、人間はいないであろうか。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤヨイ号は、ぶじに雲をぬけて、ヒマラヤ山脈は、もうはるかうしろになってしまったよ。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子バクダンの時世に、焼夷弾ごときチンピラのチョロ／＼した攻撃に一となめという哀れさだもの、秋田平野の全体に材木の山を積み重ねヒマラヤ山脈の高さに積んで見せたって、「大」の存在するイワレはない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大ヒマラヤ山脈と日本アルプスとを対等に見て下さるのはむしろ有難迷惑です。",
              "citation": {
                "source": "日本アルプスの五仙境",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "園亭の前は雪を戴いたヒマラヤ山脈を遠景にした広い人工の沼で、インド産の白鳥が二羽、羽毛のほの白い色をうきあげながらゆるゆると遊弋していた。",
              "citation": {
                "source": "泡沫の記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界で一番高い山は、中央アジアにあるヒマラヤ山脈のガウリサンカア山だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その峰を超えてその夜はマルクーという駅に宿りまして、翌二月一日早朝チャンドラ・ギリーすなわち月の峰に上りまたヒマラヤ山脈の妙光を見まして少しく下ると、山間におけるネパール国の首府カトマンズ付近の全面が見えます。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはただチベット国内だけでなくて、チベットとネパールの間のヒマラヤ山脈の間にも沢山｜棲んで居る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "曠原中の雪峰　この辺もまたヒマラヤ山脈の雪峰が曠原の間にどっかりと腰を掛けて居るがごとく、いわゆるこの辺の景色を称して雪山｜榻子の国とでもいうのであろうと思われる。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
