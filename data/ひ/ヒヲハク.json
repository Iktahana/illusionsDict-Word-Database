    "definitions": [
      {
        "index": 1,
        "gloss": "to breathe fire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わたくしの身体の続きの上で同じく火を吐く幾つかの眷属。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柘榴　人の心もやゝ倦む頃の天に打対ひて、青葉のあちこち見ゆる中に、思切つたる紅の火を吐く柘榴の花こそ眼ざましけれ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、おや、きょうは、どういう風の吹きまわしか、紅唇、火を吐くの盛観を呈している。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方が手遊びに拵える、五位鷺の船頭は、翼で舵取り、嘴で漕いで、水の中で火を吐くとな………』『天守の上から御覧なされ、太夫ほんの前芸にござります、ヘツヘツヘツ』とチヨンと頭を下げて揉手を為て言ふ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽衣を着けたる仙女も此領地の中に舞ひ、悪火を吐く毒鬼も此の裡に棲めり。",
              "citation": {
                "source": "思想の聖殿",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "正勝の奴に騙されて、彼女は急に心変わりがしたのだ）　敬二郎は火を吐くような息をして、心の中に呟いた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾一郡の怒りは火を吐く有樣である。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時などは、天竜の本流の岸に、トロッコの線を敷くためのハッパだつたので、十メートル前のトーチカ陣地から、機関銃が火を吐く、と云ふ形容だつて決して過ぎてはゐなかつた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "フ氏曰く、竜は仮作動物で、普通に翼ありて火を吐く蜥蜴また蛇の巨大なものと。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "また中世地獄を画くに、口を開き火を吐く竜とした。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは獅の首山羊の胴蛇の尾で火を吐く鵺同然の怪物だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして歯をギリギリと噛み鳴らし、身体をワナワナと震わせながら、剣の柄を砕くるばかりに握り締めて、屹と女王の顔を睨み付けましたが、やがて火を吐くような声で罵りました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もえしきる家の戸口からは、まるで、コンロから火を吐くやうに、炎をはき、そのすさまじい火勢に思はず、すくみあがる思ひがしました。",
              "citation": {
                "source": "思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの目玉がみがき上げた鏡を並べたようにきらきらかがやいて、剣を植えたようなきばがつんつん生えた間から、赤い舌がめらめら火を吐くように動いていました。",
              "citation": {
                "source": "田原藤太",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺にも少し文句がある※」　胡坐を組んで空間を睨めながら時々、火を吐くやうな勢ひでこういつてゐたが、生れつき無口な素直な彼は、それ以外何にも口に出さなかつた。",
              "citation": {
                "source": "梁上の足",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文の端に皐月なかばの晴れた日に、気早い蝉が一つ啼き、何とて啼いたか知らねども、森の若葉はその日から火を吐くやうな息をする。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに、土部三斎や、日本橋の大商人、長崎屋なんぞを、かたきと狙っている奴――どっちへ売り込んでも、こいつあ大した代ものだが――　と、呟いて、ぐたりと、うなだれて、火を吐くような吐息をして、　――でも、おいらには、何だかそれが出来ないんだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたやさしき情緒の持主なればこそ、われわれは彼の往年の猛烈な、火を吐くような、折伏のための戦いを荒々しと見ることはできないのである。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、何故彼はかくの如く、猛烈に、火を吐く如くに叫び、罵り、挑戦し、さながら僧にしてまた兵の如くに奮闘馳駆しなければならなかったか。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "質素な襟飾をつけた謙遜な教授は尊敬すべきであるが、そのために舌端火を吐く街頭の闘士を軽蔑することはできぬ。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、○○艦から対岸に向つて盛んな砲撃が開始され、敵陣地と覚しい高地の麓からも、時々火を吐くのが見える。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "両脚をガッシと左右にひらいて娘をよび、「それ、突いてこい」　娘は拳をかためて充分に身構え、火を吐くごとくに打ちかかったが、オヤジの腹はそれをマトモに発止とうけていささかもタジロギを見せない。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は心をとり直して再び三たび身体ごと打ちこむように突きかかるが、フシギなもので、火を吐く拳の力はもう認めることができない。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、幸内は拙者の手にかけて亡き者にしてやった、お前の好きな幸内は拙者のためにならぬ故、亡き者にしたけれど、その代り、お前には別に好きな人を授けてやったはず」「ああ、幸内がかわいそうだ」　お銀様は火を吐くような息を吐き、神尾の手から井戸縄を奪い取って、力を極めて車井戸を軋らせました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ標本室が火を吐く」長井君が叫ぶ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は蒼々と澄み返り、呼べば答えを返しそうに片雲を浮かべて静まり返り、不断に火を吐く大日輪はその中ほどに燃えている。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新十郎は火を吐くような目で、中橋の死体を睨みつづけていた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "その情熱は、はげしい火を吐くようなものではないが、静かに落付いた情熱である。",
              "citation": {
                "source": "天草の春",
                "author": "長谷健",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は要さんをそんな意気地の無い男とは思わなかった……」　火を吐くような言葉を、男の顔に浴せると、お豊は百年の恋も褪め果てたように、クルリと背を向けて、欄干の上に顔を伏せました。",
              "citation": {
                "source": "礫心中",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不治の病にかかっている人間が、あの若い娘を、音立てぬ、火を吐くような、燃えるばかり肉感的な情熱で――その少年期の、同じ種類の最初の衝動に釣り合った情熱で恋しているのは、明らかなことではないか。",
              "citation": {
                "source": "幸福への意志",
                "author": "DER WILLE ZUM GLUCK",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
