    },
    "definitions": [
      {
        "index": 1,
        "gloss": "peer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "斯の比倫なき（仏の児）は山窟に入りて禅思す。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその時は、日本が古今に比倫のない大伝奇を持つ時だ。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分はさつきまで、本朝に比倫を絶した大作を書くつもりでゐた。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその時は、日本が古今に比倫のない大伝奇を持つ時だ。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分はさっきまで、本朝に比倫を絶した大作を書くつもりでいた。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "死屍累々たる原野のただなかに、彼は膂力比倫を絶した自分の姿だけを見いだす。",
              "citation": {
                "source": "三島由紀夫",
                "author": "ナルシシスムの運命",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの人格思想は、伊藤公爵大隈伯爵等と對照すれば、より多く東洋的なりと雖も、若し強ひて歐洲に其の比倫を求めば、英國のウエリントン其の人を擧げざるべからず。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの人格思想は、伊藤公爵大隈伯爵等と対照すれば、より多く東洋的なりと雖も、若し強ひて欧洲に其の比倫を求めば、英国のウエリントン其の人を挙げざるべからず。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "十里廷無河上塵、収容七百万余民、街皆築岳高低屋、路自翻波来去人、管道車中夜欺昼、水晶宮裏夏猶春、日新月盛成其美、天下何都能比倫。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "――人倫の倫は比倫とか絶倫とか云って、「たぐい」であり類であり、根柢に於てそれが性関係に基くことを示しているだろう。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、和尚の面は、ブン廻しで描いたほどにまんまるく、眉と目は、細く霞のように上庭の一部に棚曳き、鼻は、ほんの申しわけに中央に置かれ、その代り比倫を絶して大きいのはその口と唇で、大袈裟にいえば、夜具の袖口ほどあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
