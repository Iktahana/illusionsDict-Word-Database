        "examples": {
          "standard": [
            {
              "text": "津波の危険がある沿岸地域では、海から離れた高台にある広場や公園が、命を守るための緊急避難場所として指定されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "防災マップを見ながら、自宅から一番近い避難場所だけでなく、もしそこが使えなかった場合の予備の場所も確認しておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大地震が発生した直後、近隣住民が続々と指定の避難場所に集まってきて、お互いの無事を確認し合う姿が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "絶好の避難場所、そういう想念がすぐ閃めくのであった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶好の避難場所、さういふ念想がすぐ閃めくのであつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨宿りのできそうな避難場所をさがして見回すと営業していない浜茶屋が潮風に吹きさらされて寒々としている。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れ果てふらふらになった彼は岩屋の苔むした床に座り、今いる避難場所の下に渦を巻きながら勢い良く流れ込む渓谷を見つめた。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "外科学はインド医学の達した最高峰であり、最終の避難場所（ultimum refugiens）とみなされるが、優れた技術が必要であり、本質的に空論から離れている。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三、大村氏にとっての安全な避難場所になる。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "避難場所が殆ど無く食物は少なかった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
