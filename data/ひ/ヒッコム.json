    "definitions": [
      {
        "index": 1,
        "gloss": "to draw back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　そいつらは正体を見破られて引っ込むどころじゃなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前の場面にもこの主人がマダムに氷を持って来いといって二階へ引っ込む場面がある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トその時料理番が引っ込むと、やがて洗面所の水が、再び高く響いた。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、さようでございますかで、すご／＼引っ込むような不様なことにしないだけの確っかりしたものを相手からは、もう掴んでいるだろうねと言いました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っ込む、面を出す。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの話を聞いてしまって、お銀は自分の家へ引っ込むと、せがれの友之助が帰って来た。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば邯鄲という曲に於て、主演者の盧生という人物が、能を終って引っこみがけに、自分の持っていた団扇を、舞台に置き忘れたまま幕に入る型がある（通常は持って引っ込む）。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それほど結構な人間なら、土地にいられねえような不義理をした訳もあるめえに、折角売れ出した娘を無理に引き摺って、なぜ草深いところへ引っ込む気になったのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "色もつけてみたいが、絵の具は国に引っ込む時、絵の好きな友だちにくれてしまったから、おらのような絵にはまた買うのも惜しいし。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなかなかの名狆であるのだが、戸川家も世が世で微禄され、御隠居も東京を引き上げ、郡部へ引っ込むについて狆を田舎まで伴れて行くのも大儀｜故、何処か好い貰い手があれば呈げたいものというので、合田氏へも話しがあったが、合田氏も狆を飼って見る気もないので話はそれ切りになってしまったのである。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "好き狆のモデルを得たはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かインチキがありそうに、今さら田舎へ引っ込むことになった心境と理由についての、涙まじりのくどくどしい説明も、取ってつけたような彼女の鼻元思案のように思えたが、彼はにやにやしながら、ただ頷いていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉は苦い顔をして引っ込む。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは後の問題として、田舎へ引っ込むのがどうしても厭なら、一応私の方から、兄さんの方へ言って上げてもいい。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "単なる好奇な飾りだろうけれど、それにしても、生真面目な金いろの小さな人形が四つ、ひょこひょこ出てきて引っ込むところはいかにも現代ばなれがしていて、北の水郷の大人たちのお伽噺趣味をよくあらわしていて面白いと思った。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあの護謨糸で自動的に中箱の引っ込む仕掛けの、ミラノ製の Italianissima 燐寸のような、非常に役立つ、寸分の隙もない効果だった。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "請ぜられるままお光は座に就いて、お互いに挨拶も済むと、娘は茶の支度にと引っ込む。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には非文化的なことをここまで来てもやるとはけしからぬと怒って自室へ引っ込むものも一二あったが、むらむらと舞い立った一団の妖気のような粘りっこい強さには爆かれた水のように力がなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の跡片づけの手伝いをすませた瀬川艶子は、自分の部屋に定められた玄関脇の三畳に引っ込むと、机の前に崩れ坐った。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "権利とか名誉とか利益とかいうものであれば、他に握りようもあるか知らぬが、僕は人生の妙味とか真の幸福とかを重く思うから、むしろやわらかく握って、すなわち自分は引っ込む態度でなるべく人に譲るをもって人生の真味を味わい得るものと思う。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは山へ引っ込むもよい、塵界を去るもよいが、それが理想を養う必要条件では断じてない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪でも引いちゃあ詰まらねえ、戸締りでもして寝るがいい」　こんなことを云って引っ込む者もあった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "持ち返って手を入れたらどうじゃな」　満座の前で云い出した以上豊後守も引っ込むことは出来ない。",
              "citation": {
                "source": "北斎と幽霊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オホン」とそんな時は大いに気取って空の咳でもせいて置いてさて引っ込むのが策の上なるものだ。",
              "citation": {
                "source": "北斎と幽霊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち窓から娘の顔が、引っ込むと同時に身を躍らせて、露路から外へ飛び出したのであった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かまうものか通しっちめえ」　女房が引っ込むと引き違いに一人の武士が入って来た。",
              "citation": {
                "source": "戯作者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田舎へ引っ込むのはね、社会から遠くなるのじゃなくて、自分らの虚栄から遠くなるのだ。",
              "citation": {
                "source": "分配",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の汗は引っ込むが、氏はそんな場合咳をされる。",
              "citation": {
                "source": "小酒井不木氏スケッチ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、不審顔の巴剌帖木の手を引き、道行きのおかし味よろしく、下手へ引っ込む。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この飛行島一隻がありさえすれば、極東のライオンも、だまってひっこむより仕方がないでしょう」と暗に、日本を押しかえす力があることをほのめかし、「しかしこんな恐しい超航空母艦であることは、当分のうち絶対秘密にしておかねばなりません。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理がとおれば道理がひっこむ、といういろは歌留多の悲しい昔ながらの物わかりよさが、感傷をともなった受動性・屈伏性として、急進的な大衆の胸の底にも微妙な形に寄生している。",
              "citation": {
                "source": "冬を越す蕾",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
