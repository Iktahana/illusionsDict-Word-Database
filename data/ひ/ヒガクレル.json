    "definitions": [
      {
        "index": 1,
        "gloss": "to set (sun)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな風に、馬に騎つたままで、いつも日が暮れるのだつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れると、彼女たちは彼のところに燭をもつてくる、まだ見たこともないやうな燭を。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前五時出航なので船客は日が暮れると乗船を始め、私は午後九時頃に及んで荷揚場から黒奴に案内されてデッキに昇っていった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷者は、Ａの日が暮れるとＢの日を待った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂの日が暮れるとＣの日を待った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れると間もなく大概の店は戸を閉めてしまった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れると、源次がこっそりたずねて来て、お化け師匠の検視はけさ済んだが、人が殺したか蛇が殺したかは確かに決まらないらしかったと話した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に十日ほど前にも、千次郎が先に来て待っていると、午頃になって娘が来て、日が暮れるころ一緒に帰ったとのことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが學校から歸る頃から寒い雨がそぼそぼと降り出して、日が暮れる頃には可なりに強い降りになつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼婆で名高い浅茅ヶ原に近いだけに、鬼娘の噂がそれからそれへと仰々しく伝えられて、残暑の強いこの頃でも、気の弱い娘子供は日が暮れると門涼みに出るのを恐れるようになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかに聞いたほどでもあるまいが、それが本当ならば見殺じゃ、どの道私は出家の体、日が暮れるまでに宿へ着いて屋根の下に寝るには及ばぬ、追着いて引戻してやろう。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそのころは、ぼんやり暗くなって、まだ三時にもならないに、日が暮れるように思われたのです。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れるとすぐ寝てしまう家があるかと思うと夜の二時ごろまで店の障子に火影を映している家がある。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の日が暮れると神廟のようなオペラの建物は闇の中にいよいよ黒く静まり返える。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處らの芥も眞黒に、とつぷりと日が暮れると、先刻の少女が、鼠のやうに、又出て來て、「そつと／＼、」と、何にも言はさず袖を曳くので、蒋生、足も地に着かず、土間の大竈の前を通つて、野原のやうな臺所。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそのころは、ぼんやり暗くなつて、まだ三時にもならないに、日が暮れるやうに思はれたのです。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日ばかり学校から帰っちゃあその足で鳥屋の店へ行って、じっと立って、奥の方の暗い棚ん中で、コトコトと音をさしているその鳥まで見覚えたけれど、翼の生えた姉さんは居ないので、ぼんやりして、ぼッとして、ほんとうに少し馬鹿になったような気がしいしい、日が暮れると帰り帰りした。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四五日、引続く暑さと云うは、日中は硝子を焼くが如く、嚇と晴れて照着ける、が、夕凪とともに曇よりと、水も空も疲れたように、ぐったりと雲がだらけて、煤色の飴の如く粘々と掻曇って、日が暮れると墨を流し、海の波は漆を畝らす。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、朝からの吹き降りで、日が暮れると警報の出た暴風雨である。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れると、意氣地はない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも日が暮れると、白い首でも出てちとは客が寄ろうも知れぬ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお一段と余情のあるのは、日が暮れると、竹の柄の小提灯で、松の中の径を送出すのだそうである。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪戯が蒿じて、この節では、唐黍の毛の尻尾を下げたり、あけびを口に啣えたり、茄子提灯で闇路を辿って、日が暮れるまでうろつきますわの。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天を凌ぐ山毛欅の梢の間から、僅に洩るる空の色を仰いで、「もう日が暮れるのに間もあるまい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二十四）　冬子を送って隣村まで出向いた安行と七兵衛とは、日が暮れるまで戻らなかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は朝から急に涼風が立つて、日が暮れるともう単衣では冷々するくらゐでしたが、不思議なことにはその晩｜些つともお客が無いんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし怪談の噂はなかなか消えないで、ゆうべも振袖を着た女の子を見た者があったとか、どこの家の戸を叩かれたとか、いろいろのことを言い触らす者があるので、気の弱いわたくし共は日が暮れると外へも出られず、雨のふる晩などは小さくなって竦んでいる位でございます。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれじゃ若夫婦もたまらんわい」　と云ったり、それから後、深良屋敷のラジオがピッタリと止んで、日が暮れると間もなく真暗になって寝静まるのを見た人々が、「あれは一知がラジオの械器を毀したのじゃないらしい。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとマユミも亦マユミで、何だかわからないまま両親の吩付けを固く守って、一知が時折コッソリと泣いて頼むのも聞かずに、一度も鍵を外してやらなかったので、一知は悩ましさの余りに昼の間じゅう死に物狂いに働いて、日が暮れると同時に前後不覚に眠るより他に自ら慰める方法が無くなった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひがくれると、少女はへとへとになってしまいます。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
