  {
    "uuid": "4c304677-d6f8-5db0-a438-198c4d42f7f3",
    "entry": "日柄",
    "reading": {
      "primary": "ひがら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
