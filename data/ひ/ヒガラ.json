    "definitions": [
      {
        "index": 1,
        "gloss": "coal tit (Parus ater)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家の奥まつた部屋の中で、終日雀の鳴聲を聽きながら、優しく、惱ましく、恥かしげに、思ひをこめて針仕事をして居る娘を見る時、私はいつもこの抒情味の深い、そして多分に加特力教的な詩人の言葉を思ひ起す。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の奧まつた部屋の中で、終日雀の鳴聲を聽きながら、優しく、惱ましく、恥かしげに、思ひをこめて針仕事をして居る娘を見る時、私はいつもこの抒情味の深い、そして多分に加特力教的な詩人の言葉を思ひ起す。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大喜びで毎日毎日雀を撃って歩きましたが、一匹も中りません。",
              "citation": {
                "source": "若返り薬",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊『太平洋畫會畫集』に序す鈴蘭の歌一『深山樒の小枝にも、花はほのかにくゆる日を、日雀、日雀女、そなたには、母御が無いか、子が無いか、何故に色音の濕るや。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、　　さつさ、いよこの、　　　　日雀女。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　　さつさ、いよこの、　　　　日雀女。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日雀を一羽、二羽、と捕って帰った、捕った雀は新らしく買った大きな鳥籠に入れて飼っておいたが、どういうものか、次ぎ次ぎと死んで行った。",
              "citation": {
                "source": "美人鷹匠",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上森が骨を折って呉れ、つひに森佐生等が間へ入り、社長に断じ込み、先日雀事件で休職の連中、今日付を以て、休職を解くの達しがあり、めでたく解決。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "などゝ云ひがらもぐり込むのであつた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その汗を拭ひがら、「今年からはこの田圃も一つしつかりと甘土を肥やしてやるべえと思ひまして。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一月ばかりして九月の初旬になると、山全體が乾き切つて、煙草の喫ひがら一つ落ちても、草に燃付き易く、めろ／＼めろ／＼と燃えて、三日も四日も消えず、幾峰幾谿に亙つて燒き拂ふ事がある。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "その機智には「うま味」がない代りに「ひがらさ」がある。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉は私の吸ひがらを掌にのせて、長くそれをもてあそんでゐた。",
              "citation": {
                "source": "ふるさとに寄する讃歌",
                "author": "――夢の総量は空気であつた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その肉はひがらくさい臭いがあったが、それさえ厭わなければ、一羽の鳥で、十二人がほどほどに飽くことができた。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
