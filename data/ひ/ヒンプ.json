    "definitions": [
      {
        "index": 1,
        "gloss": "wealth and poverty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今少しく精細に云って見るならば、役人の家庭、職人の家庭、芸人の家庭、学者の家庭、新聞記者、政治家、農家、商家、其の外に貧富の差がある、智識の差がある、夫婦諸稼の家庭もある、旦那様奥様の家庭もある、女の多い家、男の多い家、斯く数えて来たらば際限がない。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の貧富と子供の体格　近頃スコットランドの文部省でグラスゴー府の小学児童の体格検査をした結果を発表した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "常時非常時に拘らず、貴賤貧富を問わず、私たちの生活態度は斯くあるべきであり斯くあらざるを得ない。",
              "citation": {
                "source": "物を大切にする心",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "然りと雖も相互に於ける身分の貴賤、貧富の隔壁を超越仕り真に朋友としての交誼を親密ならしめ、しかも起居の礼を失わず談話の節を紊さず、質素を旨とし驕奢を排し、飲食もまた度に適して主客共に清雅の和楽を尽すものは、じつに茶道に如くはなかるべしと被存候。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴賤貧富の別が無いんだ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私産を認め、結婚を認めると、貧富幸不幸が生ずる。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶太希臘の古田制　古代民族の間に貧富の懸隔を生じたのは、主に權豪が田地を兼併するがためであつた。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "まこと貴賤も貧富もなき自由平等の樂天地は、はじめて茲に發見すべし。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮香は燕児の不思議を聞いて、桑に勧めて媒をたのんで結婚させようとしたが、桑は貧富の懸隔が甚しいのですぐ蓮香の言葉に従うことができなかった。",
              "citation": {
                "source": "蓮香",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いっそ死にたい」と極度の疲労のため精神｜朦朧となり、君子の道を学んだ者にも似合わず、しきりに世を呪い、わが身の不幸を嘆いて、薄目をあいて空飛ぶ烏の大群を見上げ、「からすには、貧富が無くて、仕合せだなあ。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし世上普通の立場に於て言を為せば、貧ということは不幸福を意味し、富ということは幸福を意味することになって、貧富は幸不幸に相即くものとなって居る。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧富を幸不幸から引離してしまおうというのも、理窟は兎に角、余り甘心する人はあるまい。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧富を幸不幸に即けてしまおうというのも、そんなに面白い見解では無い、俗過ぎる。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは傾かんよりは平らかに、私有らんよりは公に、貧富を択むの念に住せずして平等に化度したが宜しいという意に於てであった。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦の親族で、無論高貴の種姓で、そして二十相好を具えたと云わるる美男で、かつまた心の優しい、しかも道に進むの望を有して弟子となっていた阿難は、この事を目撃して、成程貧富を平等に視なければならぬと考えたので、如何なる家をも択ぶこと無く接近した。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧富の前に大手を振って歩いたのは可いが、恋という変な者に掩撃されたので、鉛の獅子が火に逢ったように忽ちぐにゃりとなってしまって、捕虜にされて危く自体を失わんとするに至った。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧富などいうことは恋の烈火の前には一片の塵ぐらいなものだ。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論恋愛というものは桂馬という将棋の駒が如何なる他の駒の威厳をも無視して働くように幽奇神奇の働をするものだから、恋愛に憑かれた者は随分俗物でも貧富位は容易に突破超越してしまうのであり、貧乏即不幸福などいう妄見はその霊光によって照破してしまうのである。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ貧富と幸福不幸福とを正比例だと思う如き妄見を脱却して、貧乏は貧乏でも幸福は幸福であるという見方にして、灰打ちたたく鰮一枚を二人で飯の菜にしても、清く面白く暮らした方が端的に美的生活即幸福生活である。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧富何ぞ論ずるに足らんや、ただ一日を如実に働くべきのみ、幸福も不幸福も忘れた時が真の幸福であるだろう。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧富ヲ無視シタル劃一的平等ヲ考フルコトハ誠ニ社會萬能説ニ出發スルモノニシテ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "但シ家庭等ノ隊外生活ニ於テ物質的差別アルベキハ、兵卒ガ等シク其ノ範圍ニ於テ貧富ニ應ジタル自由アルガ如シ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、かういふ態度にゐる作者の人生観は、わるく社会といふことのみに引張られて行つてゐて、貧富とか、艱難とか、幸福とかいふことを余りに多く問題にしすぎてゐる。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧富とか、名誉とか、さういふことは人間には何でもないことだ。",
              "citation": {
                "source": "脱却の工夫",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは人によつてその求めるものが違ふとほりに、そのなぐさめも違ふでせうけれど、貧富を超越してお互に容し合ひ援け合ふ愛のなぐさめこそは、一番揺ぎのない力だらうと私は信じてゐます。",
              "citation": {
                "source": "響",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論上下、貴賤、貧富の差はあっても、同じ様に男女関係を骨子としてある。",
              "citation": {
                "source": "紅葉山人と一葉女史",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟垢の附いた着物を着ていたとて、庭に襁褓が乾してあったとて、平生名利の外に超然たるを高しとする私の眼中に、貧富の差は無い筈である。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその翌年の春頃には、学校で「貧富の懸隔を論ず」などという論文を書いて、自分だけは一ぱしの社会改革家らしい気持になっていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた僕は、海老名弾正の『基督伝』や何とかいう仏教の博士の『釈迦牟尼』の、キリスト教および仏教の起源のところを読んで、やはりトルストイの言うように、原始宗教すなわち本当の宗教は貧富の懸隔から来る社会的不安から脱け出ようとする一統の共産主義運動だと思っていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貧富」や「新兵」の先例から推すと、近々の中に深尾君もまたやって来なければならぬのかな。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
