[
  {
    "uuid": "927e723d-c6be-5599-9fba-2859f4931bdd",
    "entry": "引揚者",
    "reading": {
      "primary": "ひきあげしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
