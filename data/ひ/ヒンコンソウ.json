        "examples": {
          "standard": [
            {
              "text": "都市部では、貧困層が密集する地域があり、生活環境の改善が急務となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "社会福祉政策は、貧困層の教育機会を増やし、社会的な孤立を防ぐことを目指すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "経済格差が広がるにつれて、貧困層がさらに困難な状況に置かれる懸念がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼らが一所懸命に働かないことや商売のやり方についてまったく無知であったために、士族が富裕層から貧困層へと没落するのを見てきた。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧困層の大多数は米国価格で米国品を買うから、米国品が大量に供給された。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうしている間にも貧困層は凍死します。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
