[
  {
    "uuid": "1d544dd1-7230-5657-829c-f9d9578e01d1",
    "entry": "畢",
    "reading": {
      "primary": "ひつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
