    "definitions": [
      {
        "index": 1,
        "gloss": "poor village",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "地租特免になつても、小作ばかりの此貧村の百姓に何のお蔭があらう。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧村のこととて金借りの連中が多かった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこげな山の中の素寒貧村には過ぎた学士様じゃ。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その村は明治に入ってから出来た新開の村で、子供の頃から私がよく行った時分は貧村であった。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が特に農村の副業としてかかる品の発展を熱望する所以は、これによってただに北国の貧村が潤うのみでなく、真に地方的な産物として栄えると思えるからである。",
              "citation": {
                "source": "蓑のこと",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜はチョモ・ラハリという山際の、ラハムトェという貧村に泊った。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただカモかアヒルのように、川の辺や蘆のほとりの貧村に出没しているばかりさ。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田がその顔を見つめていると、やがて、「だが、わしはこの頃貧村に出没しながら発明したことがある」と目を鋭く光らせた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと、この北国の貧村と、痩せたる民の膏血で作った第宅の見すぼらしさよ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
