        "examples": {
          "standard": [
            {
              "text": "この無謀な挑戦は百害あって一利なしだ、と皆が止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜更かしは百害あって一利なし。早く寝るのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「百害あって一利なしって言うけど、それ本当に？」と彼は疑わしそうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "当事者二人ともその論理の出発点が全然個性的で、先生の論理と論理の性質を異にしているから、新聞の短い文章で答がでるのは百害あって一利なし。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その四　人形の家",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速お手紙を引きくらべて顧問になって貰ったところ、今の雑誌は百害あって一利なし「医者さえ騙かされるんだから」読まないに如かざるものの由です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
