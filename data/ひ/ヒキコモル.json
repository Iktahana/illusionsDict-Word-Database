        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "国に帰った彼は自分の城に引きこもると、一向に迎える準備もしなければ、部下を連れて太宰府を守りに来る様子もない。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "カイツブリはその危機をすごすために淋しい池に引きこもる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "左近は一万円と久吉をつれて自分の部屋へひきこもる。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉乃がひきこもるようになってから、日に三度は必ずようすを訊きにゆく。",
              "citation": {
                "source": "竹柏記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「病気だと聞いたが」　――昨日到着して、すぐ医者の診察を受け、数日は休養のためにひきこもるとのことでございます。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽柴夫人と早苗さんと壮二君とは、早くから寝室にひきこもるようにいいつけられました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いアメリカ人たちは、結局のところ、自分自身について問いただされると、やはり「すべての黒人がラルフ・バンチのような人間なら、ランチ・カウンターでともにハンバーガーを食べよう」という態度のなかにひきこもるのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
