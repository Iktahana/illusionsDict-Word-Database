    "definitions": [
      {
        "index": 1,
        "gloss": "awning (over a window, doorway, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "秋風や干魚かけたる浜庇　海岸の貧しい漁村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥来る音うれしさよ板庇　渡り鳥の帰って来る羽音を、炉辺に聴く情趣の侘しさは、西欧の抒情詩、特にロセッチなどに多く歌われているところであるが、日本の詩歌では珍しく、蕪村以外に全く見ないところである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その同じ心は白梅や誰が昔より垣の外　という句にも現れ小鳥来る音うれしさよ板庇愁ひつつ丘に登れば花｜茨　などのロセッチ風な英国抒情詩にも現われている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒りて書物を投げすてひとり校庭の草に寢ころび居しがなにものの哀傷ぞはるかに彼の青きを飛び去り天日直射して　熱く帽子の庇に照りぬ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外には程近い山王台の森から軒の板庇を静かにそそぐ雨の音も佗しい。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すじ向いに座を構えたまうを帽の庇よりうかゞい奉れば、花の御かんばせすこし痩せたまいて時々小声に何をか物語りたまう双頬に薄紅さして面はゆげなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉代吉と人夫が荷を卸して、油紙で庇を拵えてくれるのを、待ち兼ねて、石の中へ潜って寝た、雨はざんざ降りになって、庇から岩を伝わっては、ポタポタ雫が落ちる、防水布の外套に包まれて、ココアを一杯興奮剤に飲んだまま、飯も喰わずにたわいもなく痲痺したようになって寝た。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "庇が波形に曲ったり垂れ落ちかかったり、障子紙が一とこま一とこま申合わせたように同じ形に裂けたり、石垣の一番はしっこが口を開いたりするという程度からだんだんひどくなって半潰家、潰家が見え出して来た。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "據なく車掌臺に立つて外を見て居ると、或る切通しの崖の上に建てた立派な家の庇が無殘に暴風に毀されて其儘になつて居るのが目についた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "百貨店の大きな出庇の亀甲形の裏から金色の光線が頸の骨を叩き付けるほど浴せかける。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして森の落葉を唇に喰いそれをまた体中にまぶし付けた一人の日本男、狂人として彼は伯林市の市街巡査等の庇護の手にとらえられた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか、翁は天宙から頭上へ目庇のように覆い冠って来る塩尻の形の巨きな影を認めたかに感じた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の確りしたところで、いつも気を引立てられている勝気にも性の弱い弟は、この秘密で冒険な行旅を、姉の敢行力の庇に在って、共々、行い味われたので、一も二もなく賛成した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆はのっけに打ってかかってもいいようなものの、昭青年の意気込みには、鯉魚と答える一筋の奥に、男が女一人を全面的に庇って立った死物狂いの力が籠っています。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと、これから三つ上の宿の島田の生れなので、晩年、斎藤加賀守の庇護を受け、京から東に移った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいぼれは一晩中こごんで肝臓を庇っていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱穀小屋の庇の下に、貯蔵庫から玉蜀黍のそりを牽いて来た二｜疋の馬が、首を垂れてだまって立って居ました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家は腰高の塗骨障子を境にして居間と台所との二間のみなれど竹の濡縁の外には聊かなる小庭ありと覚しく、手水鉢のほとりより竹の板目には蔦をからませ、高く釣りたる棚の上には植木鉢を置きたるに、猶表側の見付を見れば入口の庇、戸袋、板目なぞも狭き処を皆それぞれに意匠して網代、船板、洒竹などを用ゐ云々」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "外界よりの光を庇、袖垣、または庭の木立で適宜に遮断することを要する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一とせ下谷のほとりに仮初の家居して、商人といふ名も恥かしき、唯いさゝかの物とり並べて朝夕のたつきとせし頃、軒端の庇あれたれども、月さすたよりとなるにはあらで、向ひの家の二階のはづれを僅かにもれ出る影したはしく、大路に立て心ぼそく打あふぐに、秋風たかく吹きて空にはいさゝかの雲もなし。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には庇ばかりで屋根のない家に唐人のような漱石先生が居る事もある。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝も驚いたが、　嘉助老人スワとばかり、　五郎蔵をドンと突いて仲蔵を背後に庇って刀に手を掛けた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、女を庇って立った。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初は腰の左手を上へ挙げて、額に翳している右の腕に添え、眩しくないよう眼庇しを深くして、今更のように文化の燎原に立ち昇る晩夏の陽炎を見入って、深い溜息をした。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪のかゝらない軒庇から負傷者が乗りこむのを見ていた看護長は、「何だ？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家苞に參らせん、と思ふほどに、はや出でさせ給ひにければ、と云ひさして、根もとをこなたに向けて、三把ばかり出だしけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いひさしてお力は溢れ出る涙の止め難ければ紅ひの手巾かほに押當て其端を喰ひしめつゝ物いはぬ事小半時、坐には物の音もなく酒の香したひて寄りくる蚊のうなり聲のみ高く聞えぬ。",
              "citation": {
                "source": "にごりえ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いひさしてお力は溢れ出る涙の止め難ければ紅ひの手巾かほに押当てその端を喰ひしめつつ物いはぬ事｜小半時、坐には物の音もなく酒の香したひて寄りくる蚊のうなり声のみ高く聞えぬ。",
              "citation": {
                "source": "にごりえ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさしと縁側を設けて日射と雨雪を遠ざけたりしているのでも日本の気候に適応した巧妙な設計である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根の勾配やひさしの深さなどでも南国と北国とではいくらかそれぞれに固有な特徴が見られるように思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
