        "examples": {
          "standard": [
            {
              "text": "庭園で、深紅の紐鶏頭が長く垂れ下がる姿は圧巻だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "紐鶏頭は、その独特の形状から「アマランサス」とも呼ばれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏の終わりに咲く紐鶏頭は、秋の訪れを感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何時見ても長い紐鶏頭の花を吊したやうだ。",
              "citation": {
                "source": "梅原良三郎氏のモンマルトルの画室",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "空穂草や黒穂草や鳩豆草やガヴロールや紐鶏頭など、すべて麦を害する有害な雑草を畑から根絶させるための種々な「処方」を知っていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
