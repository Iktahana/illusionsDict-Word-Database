        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "廿九日、丁卯、兵衛尉清綱、昨日京都より下著し、今日御所に参る、是随分の有職なり、仍つて将軍家御対面有り、清綱相伝の物と称して、古今和歌集一部を進ぜしむ、左金吾基俊書かしむるの由之を申す、先達の筆跡なり、已に末代の重宝と謂ひつ可し、殊に御感有り、又当時洛中の事を尋ね問はしめ給ふ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日、丁卯、晴、寅刻大地震、未剋又少し動ず。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿七日、丁卯、晴、陰、将軍家大将に任ぜられ給ふの間、御拝賀の為、鶴岳宮に参り給ふ、早旦行村の奉として、御拝賀有る可きの由を、下向の雲客等に触れ申す、申の斜に其儀有り。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年丁卯、二十一歳。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年半ばの頃よりも年号替わるなり云々とありて、永正四｜丁卯、弥勒二年丁卯と並べ掲ぐ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁卯三月南窓下偶書、小楠。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁卯は慶応三年である。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後文化四年丁卯と十年癸酉とに春水は又待遇を改められた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "状に「丁卯加禄卅石、十年癸酉進徒士将領（歩行頭）之列、職禄百二十石、并旧禄為三百石」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒の釈奠の詩は二首あつて、丙寅の冬「聞雪」の作と、丁卯の春徳見※堂に訪はれた作との間に介まつてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは姑く長崎明倫堂の丁卯春の釈奠は中丁を以てしたものと定める。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "※斎詩集には客崎詩稿の次に、森｜枳園の手迹と覚しき文字で文化四年丁卯以後と朱書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁卯三月に霞亭は茨曾根にゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁卯歳先我游于信越之間。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "正方の死は藤陰舎遺稿丁卯の詩題にも「十一月廿二日公上不諱」と書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁卯には五十八歳であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東春日長陽陽春丁卯の五艦函館港に向ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年丁卯　平八郎十五歳。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶応三年丁卯四月十一日　　河上源介」　この控には、「四月二十七日被下被差免候」との追記がある。",
              "citation": {
                "source": "御萩と七種粥",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年｜丁卯五月稿",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十六　慶応三年｜丁卯五月六日、鷲津毅堂は御物頭格に座席を進められ明倫堂督学に任ぜられた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "『枕山詩鈔』三編丁卯の集に「梅潭杉浦君箱館ニ赴任スルヲ送ル。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ領事館書記官Ａ・ボルトメンが倒壊寸前の徳川幕府当局から江戸横浜間の鉄道利権を取った日付は慶応三年｜丁卯十二月二十三日、一八六七年十月十七日となっている（この詳細については井上清『明治維新』三四六―三四八頁参照）。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化四｜丁卯の歳創製する所という）を創成せしより以来、各国相距る事遠きもなお近きに異ならず。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁卯の年八月十五日崩りたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この天皇は御年八十三歳、丁卯の年の八月十五日にお隱れなさいました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、私の運勢をみていただけましょうか」「まず、お生れ年と、月日を」「本年三十二歳、甲子ノ年、乙丑ノ月、丙寅ノ日、丁卯ノ時刻に生れました。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この弥勒二年｜丁卯という年が、後柏原天皇の永正四年、西暦一五〇七年に該当することにはまず疑いがない。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば皇極紀の元年十一月｜丁卯（十五日）の条に、天皇御新嘗（……ニハナヒをきこしめす）、又是日皇太子大臣各自新嘗（……ニハナヒしき）とある。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
