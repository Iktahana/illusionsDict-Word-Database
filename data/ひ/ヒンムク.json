        "examples": {
          "standard": [
            {
              "text": "漁師は慣れた手つきで、巨大なマグロの皮を力強くひん剥いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は驚きのあまり、目をこれでもかというほどひん剥いて固まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなに勢いよくバナナの皮をひん剥いたら、中身が潰れちゃうよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "なぜなら、この勇ましい帆村探偵や、えらい塩田大尉や、また小さいながらなかなかかしこい一彦少年やミチ子などが、がんばっているかぎり、いつかはマスクの下の怪塔王の素顔をひんむくときが来ることでしょう。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし否定すれば、台上にある眼の前の試し刷りで、嘘の皮をひんむくぞ」　ハントが長いゲラ刷りをちらと見て、そわそわ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
