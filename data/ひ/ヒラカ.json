[
  {
    "uuid": "e7d89c87-a462-5127-9634-2de4cb9c7dcf",
    "entry": "平瓮",
    "reading": {
      "primary": "ひらか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
