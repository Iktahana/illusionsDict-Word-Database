        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "肺結核でそこに転地しているある人を見舞いに行って一晩泊まった時がちょうど旧暦の盆の幾日かであった。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だって一晩中立ち通したかねえからな」「冗談云うない。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鍋を火山の火にかけて一晩おいた後に一番鶏が鳴いたら蓋をとってみようと思っている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩中くらいはかかって燃えそうに見えた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいぼれは一晩中こごんで肝臓を庇っていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際一晩の観測簿を尤もらしく偽造するための労力は十晩百晩の観測の労力よりも大きいものだろうと想像されるのである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松も家を出て来る時には、一晩泊るつもりで来たものの、来て見ての様子で見ると、此の上一晩泊ったら、愈別れにくくなると気づいて、おそくも帰ろうとしたのだが、自分が少しもお松を離れないので、帰るしおが無かった。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま民子が泣きやんでしまえば何のこともなく済んだであろうが、民子はとうとう一晩中泣きとおしたので翌朝は眼を赤くして居た。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子はゆうべ一晩中泣きとおした。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに母に叱られたか……一晩中泣きとおした……なるほどなどと思うと、再び熱い涙が漲り出してとめどがない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分に燈火をつけた紙鳶を夜の空に上げて田舎の村人を驚かし、一八九七年には箱形の紙鳶を上げ、糸を樹につないだまま一晩揚げ切りにしておいたこともあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうかすると一晩くらいそこで泊るような必要が起るかもしれない。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩くらいなら蝋燭で間に合せるにしても、もし数日も続いたら誰もランプが欲しくなりはしないだろうか。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはたつた一晩きりでした。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして一晩ぢゆう書いてゐました。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつに一晩ぢう唸られた日には、その間はあらんかぎりに金屬の音を響かせても、どうすることも出來なかつたので。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一晩中坐つたまま、書いてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大勢の知らない方と一つ部屋で一晩暮すのは厭なものでございますね。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは英介氏のむかし馴染みの女友だちがたずねてやってきて、英介氏を郊外の酒場へさそったり、彼女たちのアパルトマンでポーカーを一晩中やったり、英介氏にタキシードを着せてテッフィン（レストラン）に連れだしたりしたからだ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私よりは冷い、親爺に一晩中、くっ付いていた。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『一晩厄介になりたい。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの鳥はゆふべ一晩なき通しだな。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも宿がなくなって今夜｜一晩とめてもらいたいと云うのか。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚兵衛さんがこの前、月夜の晩私たちのお家の前に坐って一晩じょうるりをやりましたよ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は二人とも、きっとお宮に帰って、きちんと座り、空の星めぐりの歌に合せて、一晩｜銀笛を吹くのです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は二人ともきっとお宮に帰ってきちんと座ってそらの星めぐりの歌に合せて一晩銀笛を吹くのです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一晩睡らないで、頭のしんしん痛む豚に、又もや厭な会話を聞かせたのだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこいつはぐるぐるして昨夜一晩寝ないんだな。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで一ヶ月の肥育を、一晩で台なしにしちまった。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして枝のかげにかくれてひとばん眼をひからして網をのぞいてゐた。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
