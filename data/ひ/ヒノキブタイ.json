[
  {
    "uuid": "a106a952-ee65-56af-8c99-665f00957511",
    "entry": "檜舞台",
    "reading": {
      "primary": "ひのきぶたい",
      "alternatives": [
        "ヒノキぶたい"
      ],
      "is_heteronym": true
