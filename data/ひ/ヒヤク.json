[
  {
    "uuid": "fd9b6e96-4051-58ea-ab69-cbe5390492be",
    "entry": "秘薬",
    "reading": {
      "primary": "ひやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
