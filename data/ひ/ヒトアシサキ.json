    "definitions": [
      {
        "index": 1,
        "gloss": "(a) step ahead",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
