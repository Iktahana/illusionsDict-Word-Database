        "examples": {
          "standard": [
            {
              "text": "彼は少し注意されただけで「自分ばかり責められる」と僻みっぽいことを言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "年を取るにつれて、彼女は以前よりも僻みっぽい性格になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "僻みっぽい人間だと思われないよう、努めて他人の成功を祝福するようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は自身の子供じみた僻みっぽい魂情を、いくらか悔いてもいたが、とかく苦悩と煩いの多いこの生活を、一気に叩きつけるのも、彼女に新らしい恋愛もまだ初まっていない、こんな時だという気もしていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの人たちをみんな小説に書いたわけではないが、留さんを書いたことは（留さんの口ぶりから察すると）相当ひろく伝わっていると考えなければならないし、ひがみっぽい性質の者は、どれを読んでも自分のことだと妄信するかもしれない。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
