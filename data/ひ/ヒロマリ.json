        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "流れの淀むところは陰暗く、岩を回れば光景瞬間に変じ、河幅急に広まりぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの遺言はいつとなく噂となって世間に広まり、果は鶴原家の耳にも入るようになった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "装丁を簡素化する傾向が広まり、手書きの文様も次第に書き込みの度合いを薄めていきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が我を知る・知らない、世の我を認める・認めないことに無関心に月日を送っても、学問が次第に成り徳が次第に向上すれば自然に人にも知られ、世にも認められ、世の為人の為にもなり、天地善導の助けにもなって、我が道は広まり、我が志も報われる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、組織の根が広まり、それが可なりしっかりしたものになってくると、それを工場内の眼のつく所にワザと捨てゝ置いたり、小規模だが、バラ撒いたりするようになっていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして水路は徐々に広まり、やがて水路は大河となった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小説におさせにならないでも、こんな奇怪なことは話になって世間へ広まります」「珍しいことだというのですか。",
              "citation": {
                "source": "源氏物語",
                "author": "蛍",
                "note": "青空文庫"
              }
            },
            {
              "text": "光線は盛り上り広まり伸びて鮮明な像を少年の眼に映す。",
              "citation": {
                "source": "童貞記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつとはなく、「王子は神様の生まれ変わりだ」という評判が国中に広まりました。",
              "citation": {
                "source": "お月様の唄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の事がパッと世間に広まりまして、さア諸家から召抱えにまいること何人という数知れず、なれど文治は、　文「手前は主取りの望みはござらぬ、折を見て出家いたす心底でござる」　と一々断りましたが、旧主堀丹波守殿よりの仰せは拒むに拒まれず、余儀なく隠居同様として親の元高三百八十石にてお抱えになりました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の上から左の方を見ると、クリークの幅がぐつと広まり、湖のやうになつてゐた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きた人形が、店飾りになったといううわさが四｜方に広まりますと、町の人々は、みんな、一｜度それを見ようと前へやってきたので、この呉服店の前は、いつもにぎやかでありました。",
              "citation": {
                "source": "生きた人形",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "物識りが、「天下一｜品」といった仏像が、この村の中にあるといううわさが、たちまちあたりに広まりました。",
              "citation": {
                "source": "天下一品",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "サクラソウの図ヒマワリ　ヒマワリは一名ヒグルマ、一名ニチリンソウ、一名ヒュウガアオイと呼ばれ、アメリカ合衆国の原産であるが、はやくに広く世界に広まり、諸国で栽培せられている。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この発見によってキュリー夫妻の名声は、学界ばかりでなく一般の社会にまでも俄かに広まりました。",
              "citation": {
                "source": "キュリー夫人",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしだんだんに学者の間にそれが広まり、またハンフリー・デヴィーなども氷を互いに擦り合わせると、融けて水になることを実験で確めてこの説に賛成しました。",
              "citation": {
                "source": "ヘルムホルツ",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己解剖、自己批判、の傾向が段々と人心の間に広まりつつあり、精神が極めて平民的に、換言すれば平凡的になって来たのであります。",
              "citation": {
                "source": "教育と文芸",
                "author": "――明治四十四年六月十八日長野県会議事院において――",
                "note": "青空文庫"
              }
            },
            {
              "text": "会田の争いが動機となってか、はた社会状態の変わったためであるかはともかくとして、寛政より文化文政となるに従い和算は著しく世に広まり、社会の各階級から、また全国の各地から和算家が輩出したのは事実である。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年に対して正式な告訴がされた訳ではありませんでしたが、ネロが暗くなってから何かよからぬ意図をもって粉屋の家の近くをうろついていたとか、アロアと付き合うのを禁じられて、コゼツのだんなに恨みをもっていた、といった類のうわさ話が広まりました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "』五六　ベラドンナの実　悲しい話しが、家から家へ、村中広まりました。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいつしか動きは広まり、ついに「民藝」という文字は辞書にも現れるに至った。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで相当に腕も出来、顔も広まり、川辺――これは村の名である――「川辺の三郎どん」の存在は、ようやく明かになって来た。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな噂はすぐ広まりますからね」「じゃあ知っていたんですね。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話の呼び出しですからずっと面倒がありませんのでね）そして、私の商売仲間や特に親戚のあいだでは私の訴訟の噂が広まりはじめますし、そのためあらゆる方面からの中傷が起りましたが、最初の審理が近く行われるだろうという徴候さえもさっぱり見えません。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安な噂が広まりかけていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからというもの、月心院のあの庫裡では、夜な夜な若い男女の、世にも悲しい泣く音が洩れると、白い細い手が柱から壁、壁から長押と撫で廻しては、最後にまた絶え入るばかり、よよと泣き沈む……　そういう伝説が、パッと縁無き世間にまで広まりわたっている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種のゴシップはどこの土地でも広まりやすいものだが、ことに浦粕ではもっとも歓迎される特報で、たちまち少年少女のあいだにまで伝わってしまった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな間違った話はない」となかに縁談が始まったと聞いたとき、足助は云った、「――姉さまをさしおいて、妹の縁談を先にきめるなんということは順序が違う、庄屋さまともある人がそんなことをして、世間に済むわけがあるものではない」　その評はまず出入りの者に広まり、半左衛門夫妻の耳にもはいった。",
              "citation": {
                "source": "榎物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　ところがその話はだんだんひろまりました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう本は、世界じゅうにひろまりました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
