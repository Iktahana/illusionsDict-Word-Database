        "examples": {
          "standard": [
            {
              "text": "ヒドラジンはロケットの燃料として使用されるが、毒性が非常に強いため扱いには注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工場での事故により、ヒドラジンが外部に漏れ出した可能性があるというニュースが流れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水加ヒドラジンを還元剤として用いて、金属ナノ粒子を合成する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "とくに燃料のヒドラジンは、現在のところ需要が少いので、大量生産がされていない。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでヒドラジンの製造工場も、ここに設けた方がよいかもしれない。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
