    "definitions": [
      {
        "index": 1,
        "gloss": "blighted love",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "＝（Ｆ・Ｉ）川端　柳の木の下に悲恋に泣く男女の姿。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーヴィングという人の「悲恋」（Broken Heart）という条りだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかんずく、イタリアの美しい自然を背景として美少年アントーニオと歌姫アヌンチアータとの悲恋を描いた『即興詩人』のごときは忘れがたい作品の一つであるといえよう。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "その詩はすこぶるセンチメンタルなものであって、死を憧憬し、悲恋を慟哭する表現がいかに少女の情緒にも、誇張に感じられた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんは御自分の悲しい恋に引くらべ、到底悲恋であるべきお兄様のお心を思ひくらべ乍ら何にも御存じなくそれを仰るお嬢様の御顔をぢつと見詰めて涙を流されたと云ふことですよ。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――結局おとうさんはＳ家からお退きになつた……お嬢様といふ悲恋の対象から御自分を退かせる為と御子息の悲恋の対象である自分をお邸から消す為にね……。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢獄の外に三千｜乃至三万の世界ありとも、我には差等なし、我は我牢獄以外を我が故郷と呼ぶが故に、我が想思の趣くところは広濶なる一大世界あるのみ、而して此大世界にわれは吾が悲恋を湊中すべき者を有せり。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に於ける我が悲恋は、雪風｜凛々たる冬の野に葉落ち枝折れたる枯木のひとり立つよりも、激しかるべし。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイアナ（Diana the huntress）の小間使ひとして、綺麗な悲恋に泣きつゞけてゐるエコウの想ひ人である Narcissus the hunter である。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美女と野獣」、「悲恋」などは多くの観衆をあつめた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、悲恋の物語だな。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と思う間もなくどこの何者とも知れない女性の叫びに苛責なまれ初めた絶体絶命の活地獄……この世の事とも思われぬほど深刻な悲恋を、救うことも、逃げる事も出来ない永劫の苛責……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの中には、一葉女史の悲恋をも多分にふくめているが、武子さんにあの読後感をききたいとおもいもした。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "お春悲恋に哭いて自害する事　根岸の里を物さびしい夜闇が侵しはじめたころ、片里が住居を打立った三挺の駕籠があって、上野山下を飛ぶがごとく、切通しから湯島台へと上ってゆき、天神の辺り、見はらしの良い茶亭にはいりましたが、これが即ち片里をはじめ、露月、呉羽之介の連中でした。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代日本の文学以前の詞章に、悲恋悲歌とも言ふべきものゝ多かつたことである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギターが自慢で、不遇なギター弾きの深刻な悲恋か何か演じれば巧技忽ち一世を風靡して時代の寵児となるのだけれども、それが分りすぎるから同僚の嫉みに妨げられて実現できないのだという。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し今日、八百屋お七がなほ純情一途の悲恋として人々の共鳴を得てゐるのに比べれば、お定さんの場合は、更により深くより悲しく、いたましい純情一途な悲恋であり、やがてそのほのぼのとしたあたゝかさは人々の救ひとなつて永遠の語り草となるであらう。",
              "citation": {
                "source": "阿部定さんの印象",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面からの体当りはどんな愚かしい場合でも嗤ふ余地はないものだが、この老書生は悲恋の古風な詩人的哀愁に酔ひ歎いて、行方定めぬ一人旅に出やうといふのだ。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ面白いのは、マライ映画はたいがい恋愛が悲恋に終って、めでたしめでたしのあべこべに終るばかりでなく、例外ないほど一方が自殺してしまう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男の数年昔の強迫観念の話、悲恋の話、心中の話。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲恋とよぶには詩情がなかつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、元々が好きな女だったので、いまだ一、二回は上京後も送金していたろうか、近松秋江の「黒髪」や「津の国屋」を読むたんび、この作者の悲恋に似た境涯から早く足を洗えた自分自身を心から祝福しないではいられない。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "内界は悲恋を醸すの塲なる事を知りながら、われは其悲恋に近より、其悲恋に刺されん事を楽しむ心あるを奈何せむ。",
              "citation": {
                "source": "松島に於て芭蕉翁を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "又その悲恋のむごたらしさに堪えがたかったであろうよ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "北条君は珍しく酔つて、同君がそのころ悶々してゐた悲恋に付いて談るところがあつた。",
              "citation": {
                "source": "山の手歳事記",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く母に死別し、自分の手一つで美しい乙女にほころびかけている弥生が、いま花の蕾に悲恋の苦をなめようとしている！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
