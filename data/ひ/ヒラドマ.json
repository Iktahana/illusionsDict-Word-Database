    "definitions": [
      {
        "index": 1,
        "gloss": "seats immediately in front of the stage (e.g. in kabuki)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（たらいに番附入れたのを肩に乗せ売って歩いている等芝居小屋の情景よろしく）　平土間で「幕開けろ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間でパチパチ手を叩く奴がある。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の客も幕が開くので落ちつく。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の観衆、花道の方を見て居たが、ドッと喚声上る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の客、動揺して一斉に一方を見る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ聞いたか平土間の一人の客が「オホホ」Ｔ「此村大吉」　と眼見張る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の客は愈々騒々しい。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、二三度振り払ったが、尚もしつこく掴みに来るので逆に強い男の腕掴んで、二三間曳きずって物の見事に花道から、　平土間へドスーンと投げつけた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、平土間の一人の客が、Ｔ「そんな無茶な！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫んだのをきっかけに、平土間の群衆騒然たり。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の観衆忽ち驚く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　平土間やや静かになる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉花道から、大刀片手に大跨にヅカヅカと舞台へ来り、平土間に向って、Ｔ「文句が有ったら　上って来い」　観衆睨み乍ら舞台の端を行ったり来たり「文句ある奴何奴だァ」と怒鳴って歩く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「平土間残らず　俺が相手だ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、尚も舞台を歩き廻り乍ら平土間に、Ｔ「此村大吉が芝居を　滅茶苦茶に　ブッ壊したんだ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "走り出し、　舞台の隅へ坐って平土間の客に向い、拍子木叩いて、Ｔ「東西――　東西――」　「ベラベラベラ」何だか喋言り出す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の客「面白うなったぞ」と固唾呑む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間ワッと喚声上げる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は二人一度にズバリ――　平土間騒然たり。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ツ巴の大波瀾を予期した江戸ッ児連が中村座に雪崩れ込んで……　＝（Ｆ・Ｉ）芝居小屋　大人気大入の平土間。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月、市村座六月興行の入場料は、桟敷代八十五匁、高土間八十匁、平土間七十五匁。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代には桟敷三十五匁、土間二十五匁が普通にて、それに比較すれば明治以後は大いに騰貴したる次第なるが、一匁は一銭六厘五毛なれば、平土間七十五匁は一円二十三銭七厘五毛、それを七人に割付けるときは、一人前は十七銭六厘余に相当す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○五月、沢村座の番附に、桟敷代上等金一円八十五銭、中等一円四十銭、高土間上等一円七十銭、中等一円三十銭、平土間上等一円五十銭、中等一円十銭と記載す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "入場料は桟敷一間四円七十銭、高土間三円五十銭、平土間二円八十銭。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間より舞臺へ幅廣き梯をわたしたるが、樂人の群の座はその梯の底となりたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間なる客二三人、何とかおもひけん、これに和したるに、叱々と呼びて、この過當の褒美にあらがふもの少からず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "前よりも、おっぴらに、誰に遠慮も入らないと思いましたから、平土間の成るべく舞台に近い、よい場所を買切って毎日のように通いました。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間のいつもの場所に坐っていると信乃になった染之助が、直ぐ私を見付けてしまいました。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "又それと反対に、どんなに入りが少い時でも、貴女のお姿が平土間の一隅に見えますと、私は生れ代ったような力と精神とで、私の芸を演じました。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは確か、私が八犬伝の信乃で舞台へ出た時であります――見物席の方を眺めますと、何時もとは異って、平土間の見物席の辺りが神々しく輝いているように思ったのであります。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
