[
  {
    "uuid": "77d95bae-6744-5645-9e7f-d34b4a591325",
    "entry": "ひた隠し",
    "reading": {
      "primary": "ひたかくし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
