[
  {
    "uuid": "9d69ea23-2df8-5e8f-accc-3df695da47ff",
    "entry": "暇を見て",
    "reading": {
      "primary": "ひまをみて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
