    "definitions": [
      {
        "index": 1,
        "gloss": "hereditary disposition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
