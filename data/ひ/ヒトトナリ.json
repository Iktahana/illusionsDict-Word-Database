[
  {
    "uuid": "52d2802c-8ed9-565b-9c19-f77f3a8b2e3f",
    "entry": "人となり",
    "reading": {
      "primary": "ひととなり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
