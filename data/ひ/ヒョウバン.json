    "definitions": [
      {
        "index": 1,
        "gloss": "reputation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「西部劇通信」だの「ゼーロン」だのを書いた昭和五年の頃は、彼の返り咲きの観があつたし、評判がよかつたのであるが、あの頃のものよりも、それから暫く後に書いた、水車小屋の壁に凭れて月の明りで手紙を読む短篇なぞの方が、遙かに牧野さんらしいものであると思はれる。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織袴を忘れずに、帽子はなるべくアミダに冠らないやうにして、六ヶ敷い顔をして、理想を前例に照して持つてゐれば、近所知己の評判は良いのでありませう。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生の詩の特長の一つは、一般に「易しくて解りよい」といふ評判のあることである。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、口に出して言われないような、われながらみっともない形で女のひとに逃げられたものであるから、私は少し評判になり、とうとう、佐野次郎というくだらない名前までつけられた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は独り息子であるから、ずいぶん可愛がられて、十年ほど前にお母さんが死んで、それからは厳父は、何事も大隅君の気のままにさせていた様子で、謂わば、おっとりと育てられて来た人であって、大学時代にも、天鵞絨の襟の外套などを着て、その物腰も決して粗野ではなかったが、どうも、学生間の評判は悪かった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の中学を市中の私立で一番評判の良いものにしたのは前校長であつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一体自分の評判は好いのか悪いのかと自問してみると何とも決りが着かなかつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時或る若い新進の詩人が、ヱルハーレンの影響を受けてると言ふので評判された。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々小説のような物を書いて雑誌へ出す事もあるが、兎角の評判もないようである。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園裏にて下り小路を入れば人の往来織るがごとく、壮士芝居あれば娘｜手踊あり、軽業カッポレ浪花踊、評判の江川の玉乗りにタッタ三銭を惜しみたまわぬ方々に満たされて囃子の音ただ八ヶまし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "露伴の妹などは一時評判であったがやはり駄目だと云う事だ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畸人という通称があったが、しかし難儀な病気の診断が上手だと云う評判であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれまで、私の性格、體質などに就いて、ずゐぶん誇張されて言ひ傳へられ、たしかに私にも不用意な點があつて、明かにそれは私のいたらぬところであつたけれど、あらぬ傳説が一部の人たちに信じ込まれてゐた樣子で、たいへん評判がわるかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "國民でコンクールやつて、僕は評判がわるいから、びりから二、三番だらうつて。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は讃岐の産れで、国には崇徳上皇の御陵のある白峰という阜陵がある、上田秋成の『雨月物語』や、露伴氏の作として、かなり評判のあった『二日物語』は、この白峰に取材がしてあるが、まさか、あの白峰じゃあなかろうと、真面目になって考えこんだものである。",
              "citation": {
                "source": "日本山岳景の特色",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャンゼリゼーの北側の店にこの間から展観されていた評判の夫婦乗軽体飛行機が売れたらしい。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その丁度向側の家が持主の代が変りそうだという評判を聞いて、その家は保存的価値のある建築であったので、美術大臣が周章てて今度の持主に手紙で政府の保護を申出でた。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時間目事件が学校内の雑多な評判のなかからすつかり消えた頃、神経衰弱で東北の方へ転地して居た溝口先生が、なくなられたと学校へ聞えて来ました。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて訊くと「あんな伯母さんのことを気にかけるものではありません」「仔細あって私たちは交際ってはいません」「あれで、なかなか裏に裏のある女でね」「あんな大きな山に住えば誰だって評判はよくなるさ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いってみれば運のよい女さ」「私たちと違って苦労知らずの女さ」「女のことは何一つできないあれが、どうして評判がいいのだろう」まずは悪評に近い方だった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女にだんだんもの心がつき、比較によって自分と他とを評価する力が生れて、福慈岳の評判を聞いてみると、その秀でさ加減はあまりにも自分の資格とはかけ離れたものであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の方はそうであったけれど、兄や嫂やお増などは、盛に蔭言をいうて笑っていたらしく、村中の評判には、二つも年の多いのを嫁にする気かしらんなどと専いうているとの話。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して大変評判のよかったある二、三の風景画などには、あまりにあらわな眩目的な見せつけ場所や、眼を突くような技巧の鉄条網が邪魔になって私にはどうしても絵の中へ踏み込めなかった。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから少し方面はちがうがあまり評判のよくなかった芋銭の「石人」などからも何事かを教えられた。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、如何に評判の絵でも、自分に興味のないものは一度きりで見ないで済むし、気に入った絵なら誰に気兼ねもなく何遍でも見て楽しむことが出来る。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "評判のあったトリプシンもあまりきかぬ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真の無線電送　近頃写真電送という事が大分評判になったが、従来の法はみな電線によって電流を伝えるのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日では、たとへ「思ひ出」のやうな名詩集が現はれても、文壇は全く之れを顧みず、ただ狹い詩壇だけの評判となるにすぎない。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「今江戸中、　人気の焦点、　評判男の中村仲蔵が……」　「その仲蔵が……」と過去を想い起すらしく、Ｔ「二十年以前、　貧に窮して、　おやじ橋に捨てた　我子、仲蔵とは……」　「わしはこんな嬉しい事はない」　聞いてた雪枝が仕事の手を止めて、Ｔ「今晩にでも、　兄様に会いに行かれては？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉助、暗然と涙声で、Ｔ「仲蔵は、　我子とは思わぬ」　と云って、Ｔ「雪枝　そなたもあれを、　兄とは考えるでないぞ」　と云われて、雪枝が涙ぐんで承知して見せると、　老人も泌々、Ｔ「わしは、あれの　素晴らしい評判を、　聞くだけで、　もう満足……」　武家気質の老人が淋しい満足です。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
