        "examples": {
          "standard": [
            {
              "text": "スマートフォンの地図アプリを開いて、自分の現在位置を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「現在位置を見失いました。誘導をお願いします」と登山者が無線で叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ＧＰＳの信号が遮断され、モニター上の現在位置が動かなくなってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私とエヴァンズとは、一行のうちでもいちばん教養があったので、船尾の隙間に座って現在位置をはじき出し、どの岸へ着くべきかを考えた。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も声や声によって現される言葉には、その人間が現在位置している場所、つまり、職業とか身分地位というようなものを綜合的によく具現しているに相違ないからである。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その八　安吾愛妻物語",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
