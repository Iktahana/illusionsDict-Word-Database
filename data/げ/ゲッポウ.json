    "definitions": [
      {
        "index": 1,
        "gloss": "monthly report",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（昭和五年四月、改造社『現代日本文学全集』月報）",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和三年五月『漱石全集』第十三巻、月報第三号）",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　デビスというのは、ご存知の方もありましょうが、私たちの派のまあ長老です、ビジテリアン月報の主筆で、今度の大祭では祭司長になった人であります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月、「文学月報」に発表された短篇小説を拝見して、もう、どうしてもじっとして居られず、二十年間の、謂わば、まあ、秘めた思いを、骨折って、どもりどもり書き綴りました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本篇の内容中日本共産党と同研究会との関係等重要部分に於て嘗てこの「思想月報」第一号に掲載した「唯物論研究会経過」の趣旨と必ずしも一致しない点がある。",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "製畳機を作る店の月報を出すことを、宿やの主人とその家の主とできめ、月給二人の細君連で相談して四十五円、五十五円として十円はやどに入れる。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやどやを急に出され、月報の店や何かうろつき夜一時すぎ、不明の七条の一軒の家を四組でかりて居る家に住む。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月報の原稿は何か雑感風のものを半ビラで十枚位内の程度で口述し数日中に送りますからよろしく願います。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三二年六月六日",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜、先生の身邊机邊には、美女の靈がどれほど折重なつて、とりまいて、凝と思ひをこらしてゐた事でせう……（昭和十六年六月發行『鏡花全集』第十三卷月報より轉載）",
              "citation": {
                "source": "水色情緒",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりに文芸春秋にゆき原稿を置いて、東京堂へゆき、月報注文。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "極秘の陸軍試験月報によれば、地底戦車は、地中では最高三十五キロ、海底では、百五十キロまで出ると発表されているぞ」「えっ、それまで知っているのですか。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京堂月報に拠ると昭和八年上半期の新刊書数は、実に二千四百余種に達しています。",
              "citation": {
                "source": "書を愛して書を持たず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十一年二月『漱石全集月報』）",
              "citation": {
                "source": "寒月の「首縊りの力学」その他",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし『三四郎』の中の野々宮さんは勿論漱石先生の創造で、ただその材料が寺田寅彦先生の所から供給されたものであったのは明瞭なことで、前月の月報に小宮さんの詳しい解説のある通りである。",
              "citation": {
                "source": "「光線の圧力」の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十一年七月『漱石全集月報』）",
              "citation": {
                "source": "「光線の圧力」の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三二　冬彦の語源　先生の筆名、吉村冬彦の語源は、この月報に前に矢島氏が多分こうだろうと考証をされたが、その通りであって、全く同じ意味のことを前に先生から伺ったことがある。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十二年三月『漱石全集月報』）",
              "citation": {
                "source": "冬彦夜話",
                "author": "――漱石先生に関する事ども――",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳細は、『露伴全集』の月報の中で、既に武内博士によって紹介されている。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその当選祝ひが、会下山の筒井花壇に開かれたが、その席へは是非新見君が出席して下さるやうにと、海運月報社長の小畑が誘ひに来た。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、これは、この上とも月報「一葉ふね」で補足をつゞけつつ同時に統一もし、漸次完全なものにして行くつもりである。",
              "citation": {
                "source": "「樋口一葉全集第二卷」後記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（鎌倉にて、十二月廿七日）（『横光利一全集』第二十三巻月報、昭和二十五年九月）",
              "citation": {
                "source": "横光さんと梶井君",
                "author": "淀野隆三",
                "note": "青空文庫"
              }
            },
            {
              "text": "書店の希望もあるので、この全書〔『唯物論全書』〕の「月報」でも利用して、順次に答えて行きたいと考えている。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大本教は電気現象や光の現象に対して特有な組織的説明を与えている（某月『学士会月報』）。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルガスによって衛生状態が著しく進歩している証拠として1912年の月報のうちの１冊を無作為に取り出して例としよう。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸侯はそれを各々その祖廟に納め、毎月朔日に羊を供えて朔月報告の祭典を行う。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではこれから仕事（『報知』月報）の準備にとりかかります、お大切に、お大切に。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三六年五月―十二月　百合子宛※東京堂月報一ヵ年予約のこと※堀『リカアドウ』※『わが七十年を語る』※『猟人日記』※『散文詩』※『栄養食と治病食』※『内科読本』※『国民保健読本』一九三七年　百合宛　『プーシュキン全集』※丸善目録？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『東京堂月報』、とりあえず、家に来ているのをお送りしておきます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『東京堂月報』のことわかりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "エーテル・マーニンというひとのこと、その婦人作家のこと月報ですか？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
