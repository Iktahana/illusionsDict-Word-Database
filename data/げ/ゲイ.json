[
  {
    "uuid": "f5212c50-59b0-5109-a0dd-fa4f2084d56f",
    "entry": "ゲイ",
    "reading": {
      "primary": "ゲイ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
