    "definitions": [
      {
        "index": 1,
        "gloss": "tattoo (esp. a traditional Japanese one)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
