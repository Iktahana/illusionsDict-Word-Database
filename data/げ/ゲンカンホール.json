        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "玄関ホールからの光と、トゥリーのイルミネイションだけが、サロンを照らす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関ホールから、サンタクロースが白い袋を背負って入ってきた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、三人の一年生が、歓声をあげながら、玄関ホールへと駆け抜けた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどよい広さの玄関ホールに立っている恵子を、田島は観察した。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "色は黒が多くて」「作りがしっかりしているところは、みんなおなじだね」　玄関ホールは間取りの中央に位置している廊下のまんなかでもあった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あてはありません」「私がいこうかしら」　玄関ホールでふたりは向き合って立った。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関ホールから、居間とは反対側へとつながる廊下を歩き、奥の寝室に入った。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "漠然とした玄関ホールから板張りの廊下に上がったところに、受付があった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは玄関ホールから外へ出た。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とりあげていただきました」「覚えてますよ」「ありがとうございます」　玄関ホール右側の開いたままの観音開きのドアから、中年の女性があらわれた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は玄関ホールで、こういうＬ字型のスペースの取りかたは、使いやすくていいですよ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関ホールに戻り、居間とは反対へ歩いた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この玄関ホールの置きかたがひとつのポイントなんだね。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関ホールのようなスペースから二段だけ上がって、店の中心となっている板張りのフロアが、ほどよい広さで横たわっていた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関ホールの板の間を越えた正面に二階への階段があった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段の左側を奥へ向かう廊下、そして玄関ホールから右へ向かう廊下の二本を、ヨシオは見た。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関ホールの板敷の部分に上がり、誰もいない家の内部の静かさを彼は受けとめた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関ホールの明かりを消し、暗いなかを居間へ歩き、ドアのない入口から居間に入った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "辺りに召使いは一人もおらず、玄関ホールのテーブルにアネット宛てのメモがあり、伯爵夫人がパリへ発ったこと、帰宅する時は電報を打つ旨が記されていた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
