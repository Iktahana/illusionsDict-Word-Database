        "examples": {
          "standard": [
            {
              "text": "多文化共生社会を実現するためには、より柔軟な言語教育のあり方が現場で求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「言語教育の現場では、最近は文法よりもコミュニケーション能力を重視する傾向が強まっているよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はボランティアとして、放課後の教室で移民の子供たちへの言語教育に携わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "意識なしにした言語教育であつた。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語教育と文学教育とを対立させる立場では、言語教育は言語の技術面を、文学教育は言語の内容面を分担するものと考へられてゐるやうである。",
              "citation": {
                "source": "文学教育と言語教育",
                "author": "時枝誠記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
