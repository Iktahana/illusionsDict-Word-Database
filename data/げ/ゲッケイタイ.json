          "literary": [
            {
              "text": "「おや、あの机の脚の下にヴィクトリア月経帯の缶もころがっている。",
              "citation": {
                "source": "悠々荘",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "物置の隅に、柿の皮をむいたやうなねぢくれかたで、月経帯が干してあつた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バカ程いやなものはない、何ういふ量見か、英語をやたらに入れて、話をするし、しまひには「僕、クヰーンビクトリアの研究をしてる」と言ふから、「月経帯の研究か」と、からかってやった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
