          "literary": [
            {
              "text": "ただ奇怪なのは、假面の、といふ限定詞である。",
              "citation": {
                "source": "三島由紀夫",
                "author": "ナルシシスムの運命",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヌカは今日では主として粉糠のことをいふが、古い用法ではアラヌカの方がヌカで、玄米を精げる時に出來る方が特別であり限定詞を被つて居たのである。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヌカは今日では主として粉糠のことをいうが、古い用法ではアラヌカの方がヌカで、玄米を精げる時にできる方が特別であり限定詞を被っていたのである。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
