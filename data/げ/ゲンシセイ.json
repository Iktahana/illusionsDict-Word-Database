        "examples": {
          "standard": [
            {
              "text": "宇宙には、まだ光を発していない原始星が数多く存在している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "原始星は、やがて核融合反応が始まり、恒星へと進化する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新の望遠鏡は、遠く離れた原始星の形成過程を観測することに成功した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "むしろ星団形成の根原となるべき原始星雲は一つの星団のすべての星が合致したもので、それらの運動が熱と光に変化しその結果としてすべての物質が再び星雲状態となるような温度を生じたと考えた方がよい。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
