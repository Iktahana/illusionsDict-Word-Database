  {
    "uuid": "e1f515a8-59e0-5fc8-bf23-29dc691fbd6b",
    "entry": "下刻",
    "reading": {
      "primary": "げこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "final third of a two-hour period",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――――――――――――――――　十一月二十四日の未の下刻である。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "元旦｜寅の下刻の刻限と定めて、総勢一度に鬨を挙げて攻め上げた。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "久喜の宿へはいったのが翌日の午の下刻――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "申の下刻をすこし過ぎたと思ふ頃には、きまつてその大内裏から下つて來る警衞の懸聲がそれとなくはつきりきこえるのであつたが――他にも九條殿だの、小三條の殿だのの警蹕もないではなかつたけれども、それは長年の習慣で、その懸聲の調子や何かで、今のは誰？",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもはや申の下刻になる頃だつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の酉の下刻に、上邸から見分に来た。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本の内では九郎右衛門が指図をして、荷物は残らず出させたが、申の下刻には中邸一面が火になって、山本も焼けた。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "戌の下刻になった時、九郎右衛門は文吉に言った。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "酉の下刻と思われる頃であった。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "酉の下刻に西丸目附｜徒士頭十五番組水野｜采女の指図で、西丸徒士目附永井亀次郎、久保田英次郎、西丸小人目附平岡｜唯八郎、井上又八、使之者志母谷金左衛門、伊丹長次郎、黒鍬之者四人が出張した。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日｜卯の下刻に、水野采女の指図で、庄野へ九郎右衛門等三人を引き渡された。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日酉の下刻に町奉行｜筒井伊賀守政憲が九郎右衛門等三人を呼び出した。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人が筒井政憲の直の取調を受けて下がったのは戌の下刻であった。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "酉の下刻に与力仁杉八右衛門の取調を受けて、口書を出した。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "九郎右衛門等三人は口書下書を読み聞せられて、酉の下刻に引き取った。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから筒井の褒詞を受けて酉の下刻に引き取った。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰の下刻に親戚山本平作、桜井須磨右衛門が麻上下で附き添って、御用部屋に出た。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "少壮者は往々夜宴の開かるるを待ち兼ねて、未の下刻頃より「もう日が暮れた」と叫びつつ、板戸を鎖し蝋燭を燃やし、酒饌の出づるを促した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八月廿三日微雨、廿四日廿五日続て微雨、廿五日暮て次第に降しきり、南風烈しく、戌の下刻より殊に甚しく、近来稀なる大風雨にて、喬木を折り家屋塀墻を損ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿部伊勢守正弘は三四月の交病に罹り、五月以後には時々登城せぬ日があり、閏五月九日より竜口用邸に引き籠り、六月十七日午下刻に瞑した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "年表には「東風にて西神田町一圓に類燒し、又北風になりて、本銀町、本町、石町、駿河町、室町の邊に至り、夜｜亥の下刻鎭まる」と云つてある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日も漸う巳の下刻になつて、ちやんと共揃ひをした武士が改めて愚老を迎へに見えましたが、美濃守樣はもう前の日の八つ頃に御臨終でござりまして。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はもう亥の下刻であつた。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、きょう未の下刻に、お前さんと寺の門の前で、会う事になっていると言うじゃないか。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政紀元十二月二十八日の夜、酉の下刻、神田多町二丁目北側の乾物屋三河屋半次郎の店から発火して南の方日本橋まで延焼した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "午の下刻、上様ご中食の後、お仮屋青垣までお出ましになるが、特別の思召しをもって、垣そとにて両人に床几をさしゆるされる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "丹頂の鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰の下刻、鳥見役の案内で狩場に立ちいでる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "丹頂の鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜、十四日の真夜中、丑の下刻とあるから八つ半、いまで言う午前三時ごろだった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "于時兩氏計策をなして唐人兩人連歸りて米子に參着し、同年四月二十七日未の下刻灘町大谷九郎右衞門宅に入、斯て兩人島の趣、兩人の唐人召連歸帆の事を大守へ訴るに、遂に武都の沙汰に留るとかや伯耆民談。",
              "citation": {
                "source": "他計甚※（竹島）雜誌",
                "author": "松浦武四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形の家のノラともならずの中七に苦悩のかげこくひそめている此句は、婦人問題や色々のテーマをもつ社会劇の縮図である。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            }
          ]
        }
