    "definitions": [
      {
        "index": 1,
        "gloss": "talk on drama",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この夜はあたかも嫩会の若き人々わが家にあつまりて劇談会を催す例会の夕なりしかば、通知するまでもなく皆々来りあつまる。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "M. F 君は劇談会で二三度出会つた人である。",
              "citation": {
                "source": "追儺",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和三十一年二月、青蛙房刊『綺堂劇談』所収「甲字楼夜話」より）",
              "citation": {
                "source": "怪談劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正一四・二・演芸画報）（昭和三十一年二月、青蛙房刊『綺堂劇談』所収「甲字楼夜話」より）",
              "citation": {
                "source": "小坂部伝説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉館の劇談会　日清戦争劇の流行した明治二十七年の頃、わたしは中央新聞社に籍をおいて劇評の筆を執っていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "松居君の話から更に思い出したのは劇談会のことである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜこういう人までが劇談会に加入しているのか、それは私には判らなかったが、かれは歌舞伎座の座主千葉勝五郎のふところ刀で、内部ではよほど勢力のある人らしいから、そんな関係で桜痴居士が推薦したか、あるいは本人自身から進んで参会を希望したのであろうと察していた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本読みをした劇談会は毎月開会のはずで、三月の下旬に第二回を築地のひさご家に開いたが、松居君もわたしも差支えがあって欠席した。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の劇談を団菊左の死に止めたのは、“筆を獲麟に絶つ”の微意にほかならない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで成斎の観劇談を聴くことしばしばであった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "品坐劇談暁にいたりて二人に別る。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その二百六十四　わたくしは此に塩田氏の観劇談を書き続ぐ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その二百六十五　わたくしは塩田氏の観劇談を此年嘉永壬子の事とした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百六十六　わたくしは此年嘉永壬子十一月十六日に榛軒の歿したことを叙し、次に編日の記を続いで歳暮に至り、最後に壬子年間の事にして月日を詳にせざる塩田氏の観劇談に及んだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その三百二十五　柏軒が父蘭軒、兄榛軒と同じく近視であつたことは、既に上の松田氏観劇談に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "倦メバ則アルイハ坐シ、アルイハ臥シ、劇談一｜餉、善ク戯謔シテシカモ虐ヲナサズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "○劇談抄ありがたうございました。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今劇談抄を読んでゐます。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校時代の思出話が劇談に移って行った。",
              "citation": {
                "source": "蟲",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食済むと伊原青々園の「演劇談義」に読みふける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口松太郎来り、ルパンで日独伊防協の祝杯から、川口と劇談数刻。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
