        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宇宙間に於ける至大至高の玄妙がこの中に含まれているのだからね。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴ゆる氣になれば、氣象玄妙、神理幽微、予輩たゞ教を外に受けて證を内に全うせざる者は、兌を塞ぎ坤に居る可きのみであるから姑く擱きて言はぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは實に玄妙でもあり、又｜然樣いふ道理も存在して居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉の説明せんと企てたるは、粋の粋の其奥に入りたる玄妙不思議なるところは如何なる可き、といふ問題にてやあらむ。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれ共世の中にこれ位高尚で、玄妙で、無害で楽しみの深い境界に容易に到達し得る宗旨は滅多にあるまい。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の芸術だと、こうした玄妙を後世に伝えるのは不可能である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の者は懼れ戦いて、玄妙観へ行って魏法師にこの怪事を祓うてくれと頼んだ。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは、こんな処へ籠っている隠者だから、そんなことはできない、それは何かの聞き違いだろう」　人びとは玄妙観の魏法師から教えられて来たと言った。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の者は道人の行方を訊こうと思って玄妙観へ行ってみると、魏法師は口が利けなくなっていた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬生は恐れて寺を走り出て隣家まで帰り、その夜は老人の家に泊めてもらって、翌日｜玄妙観と云う道教の寺にいる魏法師の許へ往った。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の者は懼れ戦いて、玄妙観へ往って魏法師にこの怪事を祓うてくれと頼んだ。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは、こんな処へ籠っている隠者だから、そんなことはできない、それは何かの聞き違いだろう」　人びとは玄妙観の魏法師から教えられて来たと云った。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の者は道人の行方を訊こうと思って玄妙観へ往った。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桂枝のもとには草｜生ぜず、麻黄の茎には雪積らず、これに準じて、注意しながら山を廻っておると、自然に薬が知れてくる」　照道寿真はそれを発端として玄妙な仙道の秘訣を教えはじめた。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "繊細な段階があると同時に、忖度も成し難き大技巧の斧の音が時を経、作を重ねる如に、玄妙なる隈どりを持つて花やかなる芸の空にいんいんと鳴りわたる様を、僕は聴き洩らすことは適はなかつたのだ。",
              "citation": {
                "source": "「尾花」を読みて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴える気になれば気象玄妙（気性が奥深く優れ）神理幽微（真理、幽かで微妙）、我等ただ教を外に受けて教を体得できない者は、悦びを塞ぐ迷いの境地にいるべきであるから此処では言わない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは実に玄妙でもありまたそういう理屈も存在する。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、玄妙不思議なオランダの医術に対する賛嘆の心であった。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに天地自然｜玄妙摩珂不思議、畜生ながら奴等もまた生き物であって見れば甚だ無理がないのです。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「玄妙観の魏法師は故の開府の王真人のお弟子で、おまじないでは当今第一ということであるから、お前も早く行って頼むがよかろう」　その明くる朝、喬生はすぐに玄妙観へたずねてゆくと、法師はその顔をひと目みて驚いた様子でした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "剪燈新話",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらの墓にむかって法事を営み、肉と酒とを供えて祭ればよし、さもなければ命を亡うことにもなるので、土地の人びとは大いに懼れ、争ってかの玄妙観へかけつけて、なんとかそれを取り鎮めてくれるように嘆願すると、魏法師は言いました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "剪燈新話",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、聞き違えではない、玄妙観の魏法師の指図であると答えると、道人はさてはとうなずきました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "剪燈新話",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに玄妙観をたずねて、そのゆくえを問いただそうとすると、魏法師はいつか唖になって、口をきくことが出来なくなっていました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "剪燈新話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは玄妙の、静寧の「死」の大神が、わがまなこ、閉ぢ給ふ国、黄金の、浦安の妙なる封に。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは玄妙の、靜寧の「死」の大神が、わがまなこ、閉ぢ給ふ國、黄金の、浦安の妙なる封に。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "……暫く眼をつむつて考へてゐると、いつか徐ろに、それが、あんな騒ぎと、そんな囃子とに、恰も、火と水、無限大と無限小とが終ひに合して虚無の大調和ともなるべき茫漠たる彼方から次第に、近く遠く去来してゐる程の想ひを抱かせられる玄妙不思議な合致が感じられて来るのであつた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこのプラグマティズムは教法にして教法ではなく、学問にして学問ではなく、きわめて広大無辺、玄妙幽遠な運命学であるから、虞世南のいうごとくたしかに宰相の学でもある。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
