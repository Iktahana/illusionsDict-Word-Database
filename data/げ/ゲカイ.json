[
  {
    "uuid": "e6dd95dd-8190-5a64-b8eb-5609bdbb7941",
    "entry": "下界",
    "reading": {
      "primary": "げかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
