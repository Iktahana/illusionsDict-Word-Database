[
  {
    "uuid": "9df95423-16ed-5502-80ab-e0dc896e88b7",
    "entry": "現実感",
    "reading": {
      "primary": "げんじつかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sense of reality",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが振返つて考へてみれば、さういふことが流行してゐる今だとて、さういふことを口にしてゐる人は、現実感を以て云つてゐる筈はない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）その四（幻影が姿を消して仕舞ったあと、舞台面は現実感が一しお強められる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち当時に言われた「実感で書け」の意味は、美的陶酔のない感情、プロゼックな現実感で書けの意味だった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこれ等の「現在しているもの」は、その現実感の故にプロゼックである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対にまた詩人の書いた小説は、観照が主観の靄でかすんでいるため、どこか感じが生ぬるく、真の小説的現実感に徹しない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば彼等は本質的にがっしりとした、大地を堅く蹈みつけている、或る力の強い、現実感のある文学を要求した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここだけが抉り取られて、日本の景色を見慣れた私たちの感覚に現実感を与える。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女七歳にして、という古い教えが、突然おそろしい現実感として、私の胸をついて、はっと思いました。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉には妙な現実感があった。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、読者も、はじめの四、五回は少し勝手が違ってまごつくかも知れないが、しかし、手紙の形式はまた、現実感が濃いので、昔から外国に於いても、日本に於いても多くの作者に依って試みられて来たものである。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "安宅安五郎――『菊』は定着性ない現実感がかへつて人に迫るものがある、然しこの方向は危険だ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "須田の場合は同じ古典画作りとしても、須田式な現実感があり、能動的な虚無主義者として躍如としてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "△中山一政氏――なんの感覚としての動きなく、これは器である左様、これは水である左様、といつた現実感が産ました絵。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "極度に神経を集中しなければならないときに起こる、あの非現実感が慶一をとらえていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか現実感がないまま、慶一は令子にむかって足を踏みだし、頭のなかで、ギターコードを鍵盤上に展開した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにも深い空白のせいで、現実感がない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼の現実感情の要素は遙に錯綜した影をもっている。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この道に古人なし」それは古人の跡を追随するなという意味、完成された芸術に屈服するな、今日の現実感覚に立て、という意味できわめて強調されているのである。",
              "citation": {
                "source": "芭蕉について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら、それらの個々の人物とその行動とをいきいきと生かし全篇の背景となるところのＡ村全体の生活は、どうも、まとまった現実感をもって読者の腹に入って来ない。",
              "citation": {
                "source": "作家への課題",
                "author": "――「囚われた大地」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者のこの気象から出る作家的な気張りは、その文章の構えかたにもあらわれ、一般読者は作中の人物、事件は何となくガラスのようで、研究材料のようだとは感じつつ、ある程度まで作者の確信や度胸で遅疑なくキューと描かれている輪廓のつよさ、鮮明さに、錯倒的現実感をひき起されるであろう。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化的形而上学が、実証的な現実感に薄いことは云うまでもない。",
              "citation": {
                "source": "技術的精神とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月発表されたのは前篇であり、後篇での見とおしはつけ難いのであるが、この小説は、もっと主要な部分部分を、突っ込んで綿密に書かれたら、描かれている世界の現実感も深まり、意義ふかい、社会的な立体性も強く活かされたであろうと思う。",
              "citation": {
                "source": "十月の文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の一方は今日の日本の社会生活の現実感情に近づいたリズムやメロディーで新しい日本音楽を創造してゆこうとする努力である。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻の銀三の沈んだ物言いを思い合わせて、わたくしにはだんだん寿女さんの訃が現実感をもって迫ってくる。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく正気で見るよりも美しい回想の夢を見るのだから、現実感も十分持つてゐるものとして、すべての狂乱から新しい手を出した積りなのだらうが、我々には其ねらひを捉へる事が出来ない。",
              "citation": {
                "source": "合邦と新三",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、欅の大木は影絵のように浮き出して、引き裂かれた傷口だけがなまなましく、そこだけが現実感を露呈していました。",
              "citation": {
                "source": "落雷のあと",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が待合の戸を開きだしたら、深夜に響くその音に、三人の酔つ払ひは始めて強烈な現実感を呼びさまされ、これは逃げるに如かずだと一目散に駈けだした。",
              "citation": {
                "source": "市井閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "道化的なるものをマジメに扱い、世相に意味をもたせて強調するから煽るだけの話で、道化に仕立てる、悪事の荘厳や現実感がなくなるから、素人は魅力を失う。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "惑うべからざる切実な現実感覚なのである。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "程度の相違こそあれ、従来の劇作家は、登場人物の誰彼れに、差別のない、又は、類型に過ぎない一種の標準語をしやべらせたことから、対話の月並さ、生彩の乏しさ、引いて、現実感の稀薄さを生んだのである。",
              "citation": {
                "source": "最近の戯曲について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
