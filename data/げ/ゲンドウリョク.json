[
  {
    "uuid": "6fee402b-22f2-5be9-b753-0d4ced6e0f26",
    "entry": "原動力",
    "reading": {
      "primary": "げんどうりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
