[
  {
    "uuid": "42db644d-dbb4-51f9-8d66-4740b027e266",
    "entry": "現役",
    "reading": {
      "primary": "げんえき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "active duty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大体、戦前から戦後にかけて彼の筆役勤務の現役を終えた文人であって、この付近に雑誌社、新聞社の巣窟があった時代の習慣で足はおのずとここへ向く。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹長は現役志願をして入営した。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年、二、三カ月で、現役から、おっぽりかえされるシュギ者が不思議にも、二人か三人這入って来る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、現役の陸軍中佐でございますが、ちっともふとらず、おかしなことには、いつまで経っても五尺一寸です。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業する年には持って生れた統帥力は全校八百の総指揮を鮮やかにやってのけて顧問の現役陸軍士官に賞讃された程だった。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は現役ではないのに、相変らず軍服を着用して、威張りかえっていた。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "現役であったにも拘らず、第○聨隊最初の出征に加わらなかったんに落胆しとったんやけど、おとなしいものやさかい、何も云わんで、留守番役をつとめとった。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼や口なぞいう動的表現役者の真中に取り囲まれながら、悠然として静的表現を守っていられる筈はない。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂によると、現役のもしくは元牧師とのことだが、長くない館生活では、かなり聖職者らしくないと思われる振る舞いがあるとか。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウッカリすると柔道かボートの現役選手に見られそうな風采である。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "現役の受験となった一九七四（昭和四十九）年、美大には軒並みふられたものの、静岡大学教育学部の美術専攻に受かりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "従テ假令國外出征中ノ現役將卒ト雖モ何等ノ制限無ク投票シ且ツ投票セラルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "現役兵ニ對シテ國家ハ俸給ヲ給付ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "特ニ其ノ兵質ガ、前註説明ノ如ク今ノ少尉級ニ匹敵スベキヲ以テ自ラ現役年限ノ短縮トナルベク、一年又ハ一年半ノ軍隊的軍艦的訓練ハ如何ナル專門的使命アル者モ身心ノ根源ヲ培養シテ其ノ使命ノ大成ヲ準備セシムル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "現役兵ニ俸給ヲ給付スベキハ國家ノ當然ナル義務ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和魂は現役軍人だけの持ものじゃない。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ日本軍勢の三倍にあたる兵力であり、加之、日本部隊に於きましては現役士官の大多数は死傷して、予備後備の士官達が出動するの状態に至りつゝあつたのに引き換へて、露軍の輸送力は大陸の無尽――欧露の線列兵を挙げて波の如く尽きざる優勢であります。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」新調の軍服10・25（夕）　ぢぢむさい蛹が化けて羽の黄ろい足長蜂となると、尻つ尾の先に剣をつけるやうに、中村雄次郎｜男は、満鉄総裁から関東都督に職業替へをしたばつかりに、一旦｜予備役になつた身で、再び現役中将になり戻つて腰に佩刀をがちやがちやさせるやうになつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで読み直して見ると前後重複するところもあり、補修すべき点も少なくないが、現役最後の思い出として取敢えずこのまま世に出すこととした。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に現役将校の養成制度について一言する。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして現役、在郷を通じて一貫せる制度となるのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "能力により現役幹部志願者は先ず下士官に任命せられる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世が恋しい人々は現役を去るが宜しい。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十四回国際ペンクラブの大会は、会合地の関係もあって、英米ともに文学の現役を送らず、文学的には貧弱であったが、それにしても猶、日本から遙々出席した「夜明け前」の作者藤村は、深き様々の印象を与えられたらしい。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然科学者の本多光太郎、長岡半太郎、木村栄の三氏は国際的な大科学者であり、夫々斯界の長老であり、そして現役の大物であることに於て、正に適切だと云わねばならぬ。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして現役の長老はいない。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現役軍人は政治的意見を個人的に発表する自由を、軍人勅諭によって禁ぜられてあるが、勿論それだけではない。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが現役軍人達が所詮ジャーナリストでない理由は、単に又現役の忙しさからだけ来るのではない。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
