        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが通り過ぎてからしばらくすると、今度は宿の浴室のほうでだれかガーガーゲーゲーと途方もない野蛮な声を出して咽喉や舌のつけ根の掃除をする浴客がある。",
              "citation": {
                "source": "軽井沢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはこれらの心理作用によって、待ち兼ねた食事が済むと、すぐに次の食事を、ゲーゲーおくびを出しながら待つのである。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、稍ともすればゲーゲーと喉を鳴して、その時彼がするやうに両手を糸に吊された亀の子のやうにひらひらさせて、その彼の苦悶の真似をした。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか良介にも、彼のあの朝の「ゲーゲー」が伝染してゐた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分からまた彼は、長夜の晩酌を始め、また朝のゲーゲーが激しくなつてゐた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちはみな箸を投げ出し、わざとらしくのどをゲーゲーいはせ、賄征伐の寄宿舍の惡童のやうに卓をたたいてもう飯は食はぬといひ出した。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥のグチャグチャいう音と豚のゲーゲー啼く声に送られながら、彼は祭司長の家へと乗りつけた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女らは、あの男、この男と、代りばんこに泊り歩いて、店へ戻ると、ダタイの妙薬と称する液汁をのみ、ゲーゲー吐いているのであった。",
              "citation": {
                "source": "死と影",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "石段の下に寢そべつてゐたクロは氣配に勘付くと、むくむくした胴體を破れた毬のやうに彈ませ、とたんにゲーゲーといつもの咳になつてしまつた。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "目が醒めればゲーゲー云ふ。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしいことがあつてもゲーゲーが始まる。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か食べたいとか、玄關に入れてくれとか、夜中に用を足しに出たいとか、さういつた要求の表現もゲーゲーなのである。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "行人はゲーゲーに吃驚して振り返る。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーゲー犬が聾なのを知つてゐる惡童は不意に横から石を投げつけたりする。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーゲー云ひながら、そのわりには元氣よく先行するクロを私は久しぶりにしみじみと見て、犬としたらクロはおばあさんより上かな下かなと訝つた。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "使ひ果して裸にまでなつたおばあさんに、萬といふお金が入ると云つたら、おばあさんはクロのやうにゲーゲーとでも云ひ出しはしないだらうか。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………（昂奮のあまり、やがて、ゲーゲーと嘔吐する）登美　あら！",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーゲーと言つてゐた区長を思ひ出してゐる。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（柴田がこのとき、ゲーゲーと言って、食べた物を吐いてしもう。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけすぐらいの鳥がゲーゲーと争っている。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらふらとはいってきて、台所へ急ぐと、しゃがみこんでゲーゲーと苦しそうに吐いた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "上段の屑鉄屋がごそごそ降りて、部屋の隅の洗面器へ飛んで行ったと思うと、ゲーゲーやり出した。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがすぐ、また降りてきて、ゲーゲーやった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜、船室で「あーあ」と溜息をついた男で、お互いに屑鉄屋のあのゲーゲーに悩まされたことが俺たちを暗々裡にすっかりもう親しくさせたかのような口調で、自分は新聞社の特派員だと言い、風巻という名だと自分から名乗りをあげた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜のゲーゲーからは誘われず、自分の詩をほめられると、ゲーと吐きそうになって、「あんなもの、しようがない。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
