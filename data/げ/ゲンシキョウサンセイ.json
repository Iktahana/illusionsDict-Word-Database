        "examples": {
          "standard": [
            {
              "text": "広島に原子爆弾が投下された時、巨大な原子雲が発生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "原子雲は核兵器の使用を示す恐ろしい象徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画で原子雲が映し出され、その破壊力を物語っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで一部落の住民が共産体をつくつて、所謂原始共産制が出現する。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば人々は原始共産制・封建制・資本制等々の段階を分ち、又或る段階の資本制を第一期・第二期・第三期等々の段階に分ける。",
              "citation": {
                "source": "再び「科学の歴史的社会的制約」に就いて",
                "author": "――岡邦雄氏に答える――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
