    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese milk vetch (Astragalus sinicus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日では、田の草どころでなく、わざと紫雲英草を種子蒔き前の田に植えて、空中窒素を地中に吸い取らせて土地を肥沃します。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　うの花にはまだ早い、山田｜小田の紫雲英、残の菜の花、並木の随処に相触れては、狩野川が綟子を張って青く流れた。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面に紫雲英が生えた、その葉の中へ伝わって、断々ながら、一条、蒼ずんだ明るい色のものが、這ったように浮いたように落ちています。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今｜貴僧がここへいらっしゃる玄関前で、紫雲英の草を潜る兎を見たとおっしゃいました、」「いや、肝心のお話の中へ、お交ぜ下すっては困ります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根の埃も紫雲英の紅、朧のような汽車が過ぎる。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外は、裾野の紫雲英、高嶺の雪、富士｜皓く、雨紫なり。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "シヽデンキウモンの苗なるもの、二日三日の中に、此の紫雲英の葉がくれに見えずなりぬ。",
              "citation": {
                "source": "草あやめ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日を経るまゝに何事も言はずなりし、不図其のシヽデンの菜に昼食の後、庭を視むることありしに、雲の如き紫雲英に交りて小さき薄紫の花二ツ咲出でたり。",
              "citation": {
                "source": "草あやめ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、根を抜かれた、肥料になる、青々と粉を吹いたそら豆の芽生に交って、紫雲英もちらほら見えたけれども。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空、青山、正面の雪の富士山の雲の下まで裾野を蔽うといいます紫雲英のように、いっぱいです。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかで来し道了薩陀、紫雲英田もうしろになりぬ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲を潜って隠れた水も、一面に俤立って紫雲英が咲満ちたように明るむ、と心持、天の端を、ちらちら白帆も行きそうだった。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の春日が、麗かに垣の破目へ映って、娘が覗くように、千代紙で招くのは、菜の花に交る紫雲英である。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の沓形の畠やや中窪なのが一面、青麦に菜を添え、紫雲英を畔に敷いている。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく、青麦の畠になって、紫雲英で輪取る。",
              "citation": {
                "source": "瓜の涙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫雲英の花あちこち、菜の花こぼれ咲く。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "菫、蒲公英、紫雲英、いろんな花が咲いてゐた。",
              "citation": {
                "source": "雲雀病院",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫雲英の莖は次第に多くの葉をつけて地を這ひ、近寄つて見ると早いものはやがて花梗になるべきものをもう軸から抽き出してゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜種や紫雲英は暖かになるにつれてこやしを多くむさぼつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、野を逍遙して、野の花を観賞した、すみれ、きんぽうげ、菜の花、紫雲英、とり／″＼にうつくしい、青草もうつくしい、虫もうつくしい。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の晴れた日には、紫雲英の咲き揃った畑中に寝ころんで、凧をあげながら、彼方に連なる山の峰と、その高さをきそった。",
              "citation": {
                "source": "故郷",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "田は紫雲英の花ざかり。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は紫雲英の花氈を敷く。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦の穂は一面｜白金色に光り、蛙鳴く田は紫雲英の紅を敷き、短冊形の苗代には最早｜嫩緑の針がぽつ／＼芽ぐんで居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十五年）紫雲英　午後の散歩に一家｜打連れて八幡山、北沢間の田圃に往った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫雲英の花盛りである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前は畝から畝へ花毛氈を敷いた紫雲英の上に、春もやゝ暮近い五月の午後の日がゆたかに匂うて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟々と見て居ると、紅の歓楽の世に独聖者の寂しげな白い紫雲英が、彼所に一本、此処に一｜株、眼に立って見える。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は田川の生温い水で泥手を洗って、鬼芝の畔に腰かけつゝ、紫雲英を摘む女児を眺めて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽか／＼した暮春の日光と、目に映る紫雲英の温かい色は、何時しか彼をうっとりと三十余年の昔に連れ帰るのであった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
