        "examples": {
          "standard": [
            {
              "text": "月央に予定されている納品に向けて、プロジェクトメンバー全員で作業を急いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毎月、月央になると預金残高が心細くなり、外食を控えるようになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "月央の週末に実家へ帰る約束をしていたが、急用で行けなくなってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それからもう一つは、瓦斯屋電気屋、これが勘定を晦日に取りに来ないで月央の妙な時に取りに来るばかりかまず大抵は剰銭を持っていない。",
              "citation": {
                "source": "独居雑感",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
