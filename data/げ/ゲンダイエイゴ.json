        "examples": {
          "standard": [
            {
              "text": "彼は、現代英語の表現やスラングを学ぶために、海外ドラマをよく見ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この辞書は、現代英語の語彙や用法を網羅しており、学習者には非常に役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "英語の論文を書くときは、現代英語の自然な言い回しを心がけるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その筆跡は大変ごちゃごちゃして古めかしく、ウォード青年の会話と同じように現代英語とかけ離れており、それはどうみても外国人が苦労して書いたからではなかった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
