    "definitions": [
      {
        "index": 1,
        "gloss": "offender (esp. murderer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして翌朝になって銘々の絹帷子を調べ「少しも皺のよらざる女一人有」りそれを下手人と睨むというのがある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし下手人は決して分らない。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤吉だって悪い人間じゃあない、根は正直者なんですから、たとい粗相とは云いながら相手を殺した以上は、自分も下手人に取られなければならない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それが心中の片相手ならば下手人にもなりますが、女は自分ひとりで死んだんですから、男は別に構ったことはありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人が御座りゃあ下手人は一｜刻の間にわかる」「いったい何処の娘かいナ」「今和尚さんが言い御座ったろうが。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や……下手人が……お……おわかりになりましたので……」　そう言ううちに和尚はモウ眼を白くして膝頭を戦かせ始めた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人どころか……まだ斬られた女の身の上さえ、わかっちゃおらん」「ゲエッ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ど……どうして御存じ……」「タッタ今、臭いと思いましたがな……」「ソ……それではあの母様が下手人……」　和尚は一層、青くなって唇を舐めた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……も……もしやあの……非人が下手人では……」　良助は返事をしなかった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこまで気が付けば今一足で下手人に手がかかる。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタ程の人がそこまで睨んでおんなさるなら、今一足で下手人の肩に手が届くと思うがなあ」「それが、まだ届いとらん」「ハアテ……なあ……」「イヤ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり間違うて大公儀の耳にでもそげな事が入ったなら、直ぐさま、黒田五十五万石のお納戸の信用に差響いて来るやら知れぬ話じゃけに、成る限り大切を取って極々の内密に、しかも出来るだけ速よう下手人を探し出せと言う大目付からの御内達で、お係りのお目付、松倉十内｜様も往生、垂れ冠って御座る。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず万一、この一件が片付き兼ねる……下手人がわからぬとなると吾々は元よりの事、御主人の松倉様まで、十手捕縄を返上せにゃならぬかも知れぬと言うので、松倉十内様は今のところ青息吐息、青菜に塩の弱りよう……」「ちょっと良助さん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十二、十三と三日も経っとるのに下手人がわからんとは余りにも手｜緩いちゅうて、大目付から矢の催促じゃ」「ふうん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "トテモこの下手人には吾々の手が及ばんと見て取っての無理難題の悪脅喝。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この下手人がわからねば妾ゃ死んでも浮かばれまっせん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はあの娘の事に就いて少々相尋ねたいために今日、良助に同道致させた次第じゃが……万一、その方の申立てによってあの胴切りの下手人が相わかれば、褒美を取らするぞ」「ヘエヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……しかしその方は何か……その下手人について心当りでもあるかの……」「ヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがお気付きになれば下手人はわかります。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りにこの両三日のうちにはキット下手人を探り出いてお眼にかけまする私の所存……何卒……何卒御容赦を……」　松倉十内は、何か思い直したように切柄をかけた白鞘の脇差から手を離した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞くだけ聞いてからアトは斬り棄てる了簡と悟ったけに、わざっとカンジンカナメの下手人の名は言わずに置いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人は喋舌ったわ、代りに首は斬られるわ……なら、喋舌らん方がええ位の事は知っとるわい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お熊さんの下手人を探し出いて貰わねばこっちも気が休まらぬと申しまして、様子を聞きに見えた目明の良助さんにもくれぐれも頼んでおりましたが、掻い暮れ手掛りが御座いません様子。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしや父は下手人の疑いで引かれたのではないかと……」「ははあ……良助どんはそのお差紙を見ましたか」「いいえ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰助は医師に向い、「下手人がしらばくれて、（死）をたしかめに来たものらしい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞にてたたかれし口惜さと、綾子に対して言訳なさと、秘蔵の狆の不幸とが一時に衝突して、夫人の剣幕さながらダイナマイトのごとくなれば、矢島は反返って両手を前に突出し、「で……で、下手人はその場を去らず、と……捕えました。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――塩で釣出せぬ馬蛤のかわりに、太い洋杖でかッぽじった、杖は夏帽の奴の持ものでしゅが、下手人は旅籠屋の番頭め、這奴、女ばらへ、お歯向きに、金歯を見せて不埒を働く。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いま妄想の疲れより、ふと起りたる薬種屋内の人殺、下手人は色白き去勢者の母。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、云え、なんでお岩を殺した」「そう云わっしゃるなら、わたしがお岩さまを殺した下手人になりますから、どうか彼のソウセイキを」「べらぼうめ、彼の唐薬は、さっき質屋へ渡したのだ」「それでは、あれは、彼の質屋に」　小平が走って往こうとする後から、伊右衛門は刀を脱いて斬りつけた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人の石川の詮議は厳重になった。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
