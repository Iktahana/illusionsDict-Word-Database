    "definitions": [
      {
        "index": 1,
        "gloss": "first day of the month",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たまたま『文章世界』第二巻第十三号で、片上天弦、前田木城、水野葉舟、吉江孤雁ら合評の紀行文家月旦が出た。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の中でも何でも、大きな聲で婦人の月旦をする。",
              "citation": {
                "source": "室生犀星の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学論は更に聞かれず、行くところ行くところ、すべて人物｜月旦はなやかである。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、かかることについても、作家の人物｜月旦やめよ、という貴下の御｜叱正の内意がよく分るのですけれども私には言いぶんがあるのです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近世のローマンサーなる曲亭馬琴に至りては批評家の月旦甚だ区々たり、われも今｜卒かに彼を論評する事を欲せず。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書はまず袁世凱・孫逸仙の人物｜月旦に始まり、支那民族性への洞察から、我が国民の彼に対する買被り的同情（この書は大正元年十月刊行。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女客の來て座を占むるあれば、ベルナルドオ必ずその月旦を怠ることなし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その聲調は、始て我をしてさきよりの月旦評の毫もマリアが耳に入らざりしを悟らしめき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その重要な社会的・階級的モメントをとばして、転向をよぎなくされたプロレタリア作家、その個々の人物月旦。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我読む部分は雑録、歴史、地理、人物｜月旦、農業工業商業等の一部なり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば一わたり上戸と下戸の口にあう鮨と餡ころの月旦を試みように、弥助は両国の与兵衛、代地の安宅の松、葭町の毛抜鮨とか、京橋の奴や緑鮨、数え立てたら芝にも神田にも名物は五ヶ所七ヶ処では利かないが、何といっても魚河岸のうの丸にとどめを差す。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれ、この話を聞きて、局長の意中も、さては、と感激し、また、その「強情をとこ」の月旦は、おのれが立てつるすぢを洞見せられたりけり、「人の己を知らざるを憂へず」の格言もこれなりなど思ひて、うれしといふもあまりありき。",
              "citation": {
                "source": "ことばのうみのおくがき",
                "author": "大槻文彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上の他に、藤沢浅二郎は新聞記者だとか、福井は『東西新聞』にいたがとか、壮士芝居の人物を月旦していることもあった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼や、彼の身近かなものが、よりより月旦したようにあの男の底も見届けたといきまいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち新聞雑誌に掲げられる月旦とか人物評論とかあるいはいわゆる三面記事を見ると、某はかくのごときことをなし、国賊であるとか、その肉を食っても※たらぬとか、倶に天を戴くを恥じとするとか極端の言葉を用い、あるいは某が某女性と関係したる始末を細々と記してある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本近来の批評家、動もすれば、此の消息を忘れて、芸術的作品を、より多く、人間的交渉の上に立ちて論じ、芸術家を、より多く社会的見地より月旦せんとする風あるが為めに、創作は日を追ふて生彩と香気を喪失し、自己弁護的調子と道学者流臭味とを盛らざれば小説に非ず、戯曲にあらずと思惟するに至れり。",
              "citation": {
                "source": "一言二言三言",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは浮浪人同様のもので、月旦の席へは上せられない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、此がなか／＼の講談通で、当代講談界の名人上手を月旦して、一々、その芸評がまた肯綮に当つてゐる。",
              "citation": {
                "source": "落語家温泉録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "その父は漢学者だとかいう事であるが、清岡は仙台あたりの地方大学に在学中も学業の成績は極めて不出来で、卒業の後文学者の仲間入はしたものの、つい三、四年ほど前までは、更に月旦に登るような著述もなかった。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れば老兄の月旦、上方筋宜しき旨□□□。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "御互に月旦の善悪は疾痛｜痾痒の関るところなれば、僕之を聞きて寝ること能はず。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、雲如生其後御地へ罷り出候節小生を湯島の芝居と月旦致候由。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "然り而して所謂当世文壇の月旦に上るものを以て成功の文士となさば二子の如きは寧憐むべきものなり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の手もとに襲名の時調べた橘家圓太郎の代々があるから、詳しい一人一人の月旦はまた他日として、この際ほんのメモ代わりに書きつけておいてみよう。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時私はまだ美術学校の学生時代だつたから、酒を飲んだりモデルの女の月旦位はしたけれども、紅灯緑酒の巷のことは、殆ど知らないと云つてもよかつた。",
              "citation": {
                "source": "酔狂録",
                "author": "吉井勇",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて為政、八篇は礼を主題としてこれに関する問答を集め、里仁篇は仁と君子とに関する孔子の語を録し、公冶長、雍也の両篇は弟子およびその他の人物月旦となり、述而、子罕の両篇は孔子自身の述懐や孔子の人となりについての弟子の語やあるいは郷党と同様な孔子の生活描写など、孔子についての伝記的なものを集めている。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟子たちの人物｜月旦を集めた公冶長・雍也の両篇および弟子との交渉を多く語っている述而・子罕の両篇は、孔子の生活が弟子と密接に連関しているという理由で、孔子伝の重大な要素となるものを含んでいるのであるが、しかし同様な資料を集録しているものは下論にも多い。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時評と云うと新聞や雑誌に載る月旦のことで、哲学的に問題にならない下等なものだと考えて見せる向も多いようだが、それは却ってその人間が如何に現在の「ジャーナリズム」になずんでいるかを告白するものだ。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ラズーミヒンの試みた最愛のロージャの月旦に、堪え難い悩ましさを抱き続けたプリヘーリヤは、思わずこう叫んだ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "床へ入り、「サンデー毎日」に頼まれた、「僕の映画月旦」十枚を書き、くたびれて寝る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
