        "examples": {
          "standard": [
            {
              "text": "古墳の奥深くには、被葬者が安置された玄室がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "盗掘団は、玄室から貴重な副葬品を持ち去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発掘調査により、未発見の玄室が明らかになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その玄室の奥ぶかくから漂ってくる一種の湿め湿めとした気とともに、原始人らしい死の観念がそのあたりからいまだに消え失せずにいるようで、僕はだんだん異様な身ぶるいさえ感じ出していました。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄室の石の一ツの大きさだけでも呆気にとられるね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下の、棺を納める広い玄室は、花崗岩の大きな切石で方形に造られ、天井はセリ持ちで円天井風に組上げてある。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
