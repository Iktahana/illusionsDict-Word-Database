    "definitions": [
      {
        "index": 1,
        "gloss": "monthly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私が來てから初めての記者月例會が開かれたのも、恰度一尺程もの雪の積つた、或る土曜日の夕であつた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『然し藝妓も月例會に出た時は、大變｜大人しくして居ますね。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "親善を厚うするとか、相互の利害を議するとか、連絡を圖るとか、趣旨は頗る立派であつたけれど、月例會は要するに、飮んで、食つて、騷ぐ會なので、主筆の所謂人の惡い奴許りだから、隨分と方々に圓滑な皮肉が交換されて、其度にさも面白相な笑聲が起る。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "月例會に逢つた限の菊池君が何故か目に浮ぶ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が来てから初めての記者月例会の開かれたのも、恰度一尺程も雪の積つた、或土曜日の夕であつた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『然し芸妓も月例会に出た時は、大変大人しくして居ますね。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "親善を厚うするとか、相互の利害を議するとか、連絡を図るとか、趣意は頗る立派であつたけれど、月例会は要するに、飲んで、食つて、騒ぐ会なので、主筆の所謂人の悪い奴許りだから、随分と方々に円滑な皮肉が交換されて、其度にさも面白相な笑声が起る。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "月例会に逢つた限の菊池君が何故か目に浮ぶ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方から柿の会三月例会、一洵、三土思、無水、藤君、和蕾の五君だけ来庵、今晩は女性を欠いだ、なごやかな句座であつた、席上で朱鱗洞句碑建立の具体案がやゝまとまつたのはよかつた、十一時頃散会。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、無水君来訪、俳談閑談しばらく、ほどなく一洵老来訪、九月例会について談合する。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の方へ横に羅馬字でDIDASKALIAと書いて、下には竪に十一月例会と書いてある。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の方へ横に羅馬字で DIDASKALIA と書いて、下には竪に十一月例会と書いてある。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時は「ぷろふいる」を中心に神戸をはじめ名古屋、京都、大阪、はては仙台、札幌、遠くは大連にまで探偵小説クラブという会が出来て同好の連中が集まり毎月例会の消息を知らせてくるという盛況ぶりであった。",
              "citation": {
                "source": "探偵小説思い出話",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例月例年の命日の読経などはさしつかえないが、葬式やお通夜の場合は泣きの涙でいる人も多いのだから大音を発しすぎてはグアイがわるいようであるが、オナラの戸締りに力をこめてお経を読むわけにいかないので、自然あきらめるようになった。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年八月例の米騒動があって、京都付近でも部落の人々が大分これに関係した如く噂された。",
              "citation": {
                "source": "編輯雑感",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "去歳秋日、偶々私は月例の円朝、狂馬楽ら墓参の途次、池畔に佇つて今更ながら田海桑滄以上の感慨、催さないわけには行かなかつた。",
              "citation": {
                "source": "下谷練塀小路",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定してみると、先生が毎月例として墓参に行く日が、それからちょうど三日目に当っていた。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年十二月の試合は、単なる月例試合ではなく『稽古おさめ』の式を兼ねているし、その成績によって、次の一年の席次がきめられるのである。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月例試合のあった日で、その夜は道場で小酒宴がひらかれる。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ月に一度、月例試合のあとでだけ、質素な膳に酒が付くのであった。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、内膳がどうしたと」　――酒井邸のようすは変りました、涌谷さま御出府以来、酒井邸の応対ぶりはまことによそよそしく、月例の御挨拶にあがりましても、老職に会うことさえ稀になっているようなしだいです。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の同僚や先輩たちの何人かが組織している栄光ロードレース・クラブの、月例ツーリング大会だ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月例ツーリングに、今日、ぼくは、はじめて参加している。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "月例の上覧闘犬のほか、五月の“犬合せ”は、鎌倉中のお犬祭りといってよい。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、二条加茂川べりの水鳥亭は、月例の“文談会”の日であった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "月例、欠かさぬ二次会なので、馴じみでない客、馴じみでない妓はない。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "月例の文談会は、まだ一事例にすぎない。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
