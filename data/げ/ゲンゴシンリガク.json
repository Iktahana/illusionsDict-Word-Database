        "examples": {
          "standard": [
            {
              "text": "子供がどのようにして複雑な言葉を獲得していくのか、言語心理学の観点から長年研究を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「言語心理学の実験に被験者として参加して、単語の記憶メカニズムについて詳細に調査を受けたよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "視覚情報と言語情報の処理における優先順位の競合について、言語心理学的なアプローチで解明を試みる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これは懐疑主義というがごとき、言語心理学的な間延びのした知的なものではない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章論は言語心理学の領分に入れるべきもので、文法から解放せられなければならない。",
              "citation": {
                "source": "形容詞の論",
                "author": "――語尾「し」の発生――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
