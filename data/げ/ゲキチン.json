    "definitions": [
      {
        "index": 1,
        "gloss": "(attacking and) sinking (a ship)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「報告、きょうあけがた、セピラの峠の上に敵艦の碇泊を認めましたので、本艦隊は直ちに出動、撃沈いたしました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど今日に於ては、海賊も餘程狡猾になつて、かゝる手段に出づる事は稀で、加ふるに海底潜水器の發明があつて以來、海賊船は多く其發明を應用して、若し漫々たる海洋の上に金銀財寳を滿載せる船を認めた時には、先づ砲又は衝角をもつて一撃の下に其船を撃沈し、後に潜水器を沈めて其財寳を引揚げる相である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、かの船は私の想像するが如き海賊船であつたにしろ、左樣無謀には本船を撃沈するやうな事はあるまい、印度洋の平均水深は一｜千八｜百三十｜尋、其樣な深い所で輕々しく本船を撃沈した處で、到底かの船の目的を達する事は出來まいから。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し然なくば隱見出沒、氣長く我船の後を追ふ内、本船が何時か海水淺き島嶼の附近か、底に大海礁の横る波上にでも差懸かつた時、風の如く來り、雲の如く現はれ出でゝ、一｜撃の下に其處に我が船を撃沈する積かも知れぬ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早疑ふ事は出來ぬ、海蛇丸は今や立浪跳つて海水淺き、此海上で我が弦月丸を一撃の下に撃沈せんと企圖てゝ居るのだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今世紀に於て最も進歩發達して居ると稱せらるゝ佛國シエルブル造船所の一等潜行艇でも、此二個の缺點のある爲に充分の働作も出來ず、首尾よく敵艦に接近しながら、屡々速射砲等をもつて反對に撃沈される程で、とても、我が櫻木海軍大佐の破天荒なる、此海底戰鬪艇とは比較する事も出來ぬのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』の號令の下に、軍艦「日の出」の士官水兵は勇氣百倍、息をもつかせず發射する彈丸は、氷山碎けて玉と飛散る如く、すでに度を失つて、四途路筋斗の海賊船に、命中るも／＼、本艦々尾の八｜吋速射砲は、忽ち一隻を撃沈し、同時に打出す十二｜珊砲の榴彈は、之れぞ虎髯大尉の大勳功！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「報告、けふあけがた、セピラの峠の上に敵艦の碇泊を認めましたので、本艦隊は直ちに出動、撃沈いたしました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、商船の無制限撃沈を試みたり、都市の空中攻撃を企てたりした責任者はある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいねがわくば楊大先生の降魔征神の大科学力をもって、古今独歩未曾有の海戦新兵器を考案せられ、よってもって我が沿岸を親しく下り行きて、軍船を悉く撃沈せられんことを。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「軍艦を殲滅する一大発明をなし、そしてこれを使って、軍船をことごとく撃沈してしまえばいいのだ。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さだめし祝電であろうと思って読んでみると、「貴様の撃沈したのは、あれはみな、わが海軍の精鋭軍船である。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者はわが艦隊が露国軍艦レトウィーザンを撃沈した事実を脚色したもの、後者は鎌倉時代の蒙古襲来を脚色したもので、いずれも時局を当込みの産物であったが、わたしは前に言ったような事情で見物するの余暇を持たなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして川上の行方をさがすと共に、いやしくも日本に対する陰謀を発見するなら、そのときは容赦なく飛行島を撃沈してしまう。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "場合によったら、直ちに飛行島を撃沈してしまう！",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く撃沈してしまわないと、飛行島にもしものことがあっては」「なあに、怪潜水艦のいた海面は、すっかり取巻いたから、もう心配なしだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その数日前｜独逸潜航艇のために撃沈された汽船のあるという噂は一層その不安を深くさせた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイテ戦は総敗北、海軍の大本山、戦艦大和も撃沈された風説が流れていた。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女が樺太に嫁いでいる折、引上げ家族を乗せた船を、国籍不明の潜水艦が撃沈したという噂が拡がって来たからだが、本家の参右衛門の家の長男も樺太にいる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの未亡人を爆発させた火薬と、バルチック艦隊を撃沈した火薬が、同しものだってことも察しているんだよ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月の十九日タラント軍港を襲撃しての、『レオナルド・ダ・ヴィンチ』号の撃沈も、年を越えた五月二十六日コマンドルスキイ沖の合衆国巡洋艦『提督デイウェイ』との戦闘も、このとおり艇内日誌にはちゃんと記されておりますが、その公表には、どうしたことか時日も違い、各自自爆のように記されてあるのです。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、射撃演習そっくりにあの汽船を撃沈すれば、燃料や食料品はしこたま手に入るだろう。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして呉淞砲台の沖で、米国駆逐艦三隻を撃沈したのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、あいつらはきっと『陸奥』や『長門』を撃沈するぞッ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "『千代田』の攻撃は、ざんねんに、しくじったが、『秋津洲』は、敵の戦艦『モンタナ』を撃沈した。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わが艦隊は敵戦艦七隻を撃沈した。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦艦が七隻撃沈されている。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "清少年の『千代田』は、ペリスコープをこわされたけれど、大胆な肉弾的行動で、戦艦『ライオン』と『スター』を血まつりに上げ、つづいて航空母艦『メキシコ』をはじめ、十九隻の敵艦を撃沈した。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
