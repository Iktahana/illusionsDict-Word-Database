[
  {
    "uuid": "031bf986-5c4b-5106-9c41-e3798a87f3b9",
    "entry": "逆鱗",
    "reading": {
      "primary": "げきりん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
