    "definitions": [
      {
        "index": 1,
        "gloss": "abandonment of the status quo",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
