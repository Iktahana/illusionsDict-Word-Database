    "definitions": [
      {
        "index": 1,
        "gloss": "to strengthen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――――――――――――――――――――　趙は修法の時に規律を以て束縛するばかりで、楼観の出入などを厳にすることはなかった。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文庫の出納を厳にするが好いと云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "左れば父母が其子を養育するに、仮令い教訓の趣意は美なりとするも、女子なるが故にとて特に之を厳にするは、男女同症の患者に対して服薬の分量を加減するに異ならず。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "匪賊の最も横行する場所とのこと、乗組の護衛兵は一層警戒の眼を厳にする。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "云ひかへれば、農村生活の「かくあるべき姿」を理想として絶えず頭に描き、現実処理の方法が、断じてかゝる理想を踏みにじらないやう警戒を厳にするばかりでなく、現実の要求そのものゝうちに一歩でも「美しい夢」を実現させる機会をとらへる工夫を怠らないからである。",
              "citation": {
                "source": "農村の文化について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピストルやダンビラを枕もとに並べ、用心棒や猛犬を飼って国防を厳にする必要があるのは金持のことである。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝、奥州征伐の決心を固うし、いよいよその実行に着手するに至っても、彼はその敵の容易ならざるを慮って、ただに武備を厳にするのみならず、しきりに神仏の加護を求めた。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへもって来て上司からは警戒を厳にするようにとの矢のようなお達しだ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "――併し、こうした戒心を厳にするということは、無論、インテリの無条件な又は完全な無力を認めることではなかった筈で、之は実は単にインテリに対して、却ってインテリ固有に制限された社会的活動性を指示するために過ぎなかったのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうしろを、黒鉛のような夕暮の色が沈鬱にし、金色の射る矢の光が荘厳にする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしくいっそう蕃情に対して警戒を厳にするよう。",
              "citation": {
                "source": "霧の蕃社",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも子　冗談もいいかげんにするものよ、人を馬鹿にして。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見当違いもいいかげんにするがいい。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう僕も饒舌はいいかげんにする。",
              "citation": {
                "source": "片信",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でつとめても出来ませんよ、　極端に走る人がつとめていいかげんにする事は出来てもねえ、　私の様な人間はこれっきりなんですよ。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたもいいかげんにするもんですよ。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげんにするわけではないが、どうしてもそうする。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のあそびではあるまいし、悪戯もいゝかげんにするがいゝ、といふので、帆まへ船に向つて、口々に罵り出しました。",
              "citation": {
                "source": "海坊主の話",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほほほ、いいかげんにするものですよ、源様。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮山　……（それを見ているうちに、はじめてフテブテしくニヤリとして）あんたも、しかし、いいかげんにするがいいなあ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげんにするがええぞ。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "机上の空論もいいかげんにするがいい。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "負けおしみも、いいかげんにするがいい。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに五日間なんて、でたらめもいいかげんにするがいい。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「フフフ……、でたらめもいいかげんにするがいい。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
