    "definitions": [
      {
        "index": 1,
        "gloss": "disembarkation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが、今は私は、一銭の傷害手当もなく、おまけに懲戒下船の手続をとられたのだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かのウ※ルターが、コロンボで下船して遁走しましたことは、すでにお話ししましたが、その後、私は、最近、はからずも、アデンの、チグリス河の河岸で彼に出会ひました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼からは、コロンボでの下船以来、それとも最近に何か音信が来ましたか。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠足に行つた少年の樣に滿足し切つて船に戻ると、下船しなかつた警官が私に言つた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠足に行った少年のように満足し切って船に戻ると、下船しなかった警官が私に言った。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸からずっといっしょであった米国の老嬢二人も、コンチャーの家族も、いよいよここで下船して、ジェルサレムへ、エジプトへ、思い思いに別れて行くのであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおその三人は昨晩みな下船していたことがわかっている。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "――船長は明朝になったら、三上を懲戒下船命令を発して、一年間あるいは三年間ぐらいは乗船不可能にしてしまうだろう。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホホホホホ」「僕は下船したんだから、当分また厄介になるよ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらあ今日下船したぜ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船乗りが、下船してボーレンに休めば、次の船に乗るまでの間、そこに休んでその間に、口をさがすのが、その唯一の道であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそうじゃないか、おれたちあ、船を桟橋まで着けないで下船しちゃおう、ばかばかしいや！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三人が煙草をのんでいるところへ来て、チーフメーツは非常におこって、すぐに下船を命ずるといっていたが、自分はやっと頼んで、やめてもらって来たから、どうか、一服したらすぐに荷役にとりかかってもらいたい、そうしないと、チーフメーツは、すぐボーレンへ代わりを連れに行く気でいるのだから、といって来た。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし交渉が不調になったりした場合、同盟下船とでもいうことになれば自分は明らかに乗船停止を食うだろう。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "要求条件を出しただけでは、まだなんでもないんだからね、それで容れられない時に、休業するか、怠けるか、下船しちまうか、等の方法があるわけだね。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなところで下船するというわけにも行かないから、それもやむを得ない時はもちろん、裸ででもこの雪の中へおりる覚悟はしているんだが、下船するということは、最後の場合にとって置いて、そう大切でない時は怠けて、これをやっては絶対にいけないというような仕事の日には休業しちまうんだね。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前に下船を命ずる！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷をまとめて、あの伝馬で上陸して行け、合意下船ではないぞ、下船命令だ！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボースンは業務怠慢で下船命令を食ったから、一年間乗船を海事局の名によって停止されるのだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことにでもなって見ろ、船長は、一人残らず下船を命じかねないから、お前はどうするつもりかい」チーフメーツはボースンから切りくずして行こうととっさに考えついた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃ、勝手に下船して行ったらどうだったい。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれが、いつお前に、どうぞ、下船しないで乗ってくださいと頼んだ！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船ばかりへ日が照らないと言って、下船したところで、他の船でも、陸でも同じことです。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、なけれや私もストキは、早く処分しなけりゃならないとは思っていたのですから、代わりさえあれば、ここで下船させるつもりだったんです。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでしょうあいつだけを、下船させることにして、あとはチビチビやったら……でないと横浜正月がフイになりますよ」　チーフメーツもボーレンを探っていたのだ！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も、浜で正月をしたいと思ってるんだが、それさえなけりゃ、十日や二十日｜錨を入れたってかまやしないんだけどなあ、じゃあ、応急手当として、ストキだけ下船さすか」船長も賛成した。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、ストキのやつに下船を命じよう」船長は言った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつらを「殺しても、あき足らないほどなのに、場合によっては、下船どころか金まで出すとは！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの因果でわいが河童路地を夜逃げせんならん」　いつにない強い口調だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの因果で河童路地を夜逃げせんならん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
