[
  {
    "uuid": "5f2c98d1-e803-5c10-9315-1d38dda2c9df",
    "entry": "下船",
    "reading": {
      "primary": "げせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
