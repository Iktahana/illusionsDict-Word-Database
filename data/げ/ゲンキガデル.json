    "definitions": [
      {
        "index": 1,
        "gloss": "to feel uplifted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もっと金を持たせると元気が出るんだが……そう思いながら、彼は眼をつむった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ブルジヨア的になると、元気が出るかも知れないから、危ないぞ。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが念仏申さるるように生きると元気が出る。",
              "citation": {
                "source": "念仏と生活",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "別にこれは商売にしているものではないけれども、畑のことに話が向くと、どんな相手にだッても自分は時々われを忘れるほどにおもしろく、元気が出るのであった。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「越後の長岡から三国を越しての旅、おいぼれの私には難渋でございましたが、一晩でも湯治が出来ましたら元気が出ることでございましょう」　猿ヶ京と云われているだけにこの辺には猿が多く、それが木の枝や藪の蔭などから、この人たちを眺めていた。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを食べたら来年の夏は、随分元気が出ることだろう。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は親切で、深く恩に感じる人間であり、心が大きくなる度合は、腹の皮がご馳走でふくらむのに比例し、ものを食べると元気が出るのは、ほかの人が酒をのんだときのようなものだった。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "州太　　それや無論、お前が側にゐてくれゝば、お父さんも元気が出るさ。",
              "citation": {
                "source": "浅間山",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき、ふと、吉雄は、さっきお母さんがおいいなされたことから、「やまがらにも、あたたかなお湯をいれてやったら、体があたたまって、元気が出るだろう。",
              "citation": {
                "source": "ある日の先生と子供",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とうとう三辺目に見物人が手伝って往生さしたという話です」と寒月君がいうと、「やれやれ」と迷亭はこんなところへくると急に元気が出るのは、漱石先生の実感であったのかも知れない。",
              "citation": {
                "source": "寒月の「首縊りの力学」その他",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう三返目に見物人が手伝って往生さしたと云う話しです」「やれやれ」と迷亭はこんなところへくると急に元気が出る。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はちょっと上野の図書館まで調べ物に行ったです」　高柳君は道也先生に逢うと何だか元気が出る。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だから、あなたがこうして私のそばにいてくださるだけで、ずいぶん元気が出るんです。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達が行くと、小父様は元気が出るのですって。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら元気が出るわよ。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲しいのは元気が出る強力な薬と、いいタイプライターです。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "また元気が出るぜ」「そうだ、砲兵隊と消防隊の合体だよ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕は原口君に励まされると元気が出る。",
              "citation": {
                "source": "村一番早慶戦",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君と話していると、つい釣り込まれて元気が出るが、一人になると又考え出す」　と新太郎君は事実その通りだった。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「目を覆っている布切れを取ってくれないか、お前達を見ると元気が出るんだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
