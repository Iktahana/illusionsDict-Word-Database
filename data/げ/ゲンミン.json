          "literary": [
            {
              "text": "沙漠の花原民喜　堀辰雄氏から「牧歌」といふ署名入りの美しい本を送つて頂いた。",
              "citation": {
                "source": "沙漠の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四七年十二月八日原民喜",
              "citation": {
                "source": "ある手紙",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「屍の街」原民喜　私はあのとき広島の川原で、いろんな怪物を視た。",
              "citation": {
                "source": "「屍の街」",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒロシマの声　ペン・クラブ広島の会にて原民喜　ペン・クラブの一行に加わって私はこんど三年振りに広島を訪れた。",
              "citation": {
                "source": "ヒロシマの声",
                "author": "ペン・クラブ広島の会にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和への意志原民喜　二つの特輯が私の心を惹いた。",
              "citation": {
                "source": "平和への意志",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "死について原民喜　お前が凍てついた手で　最後のマツチを擦つたとき　焔はパツと透明な球体をつくり　清らかな優しい死の床が浮び上つた　誰かが死にかかつてゐる　誰かが死にかかつてゐる　と、　お前の頬の薔薇は呟いた。",
              "citation": {
                "source": "死について",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空の梯子原民喜　二階の窓に桜の葉が繁って、彼は中学を休んだ。",
              "citation": {
                "source": "青空の梯子",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯田橋駅原民喜　飯田橋のプラットホームは何と云ふ快い彎曲なのだらう。",
              "citation": {
                "source": "飯田橋駅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "移動原民喜　庭のすぐ向ふが墓場だったので、開放れた六畳の間をぐるぐる廻ってゐると、墓地でダンスしてゐるやうだった。",
              "citation": {
                "source": "移動",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲妻原民喜　疲れてゐるのに芳子の神経はたかぶってゐた。",
              "citation": {
                "source": "稲妻",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛を調弄ふ男原民喜-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）摩った。",
              "citation": {
                "source": "牛を調弄ふ男",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁起に就いて原民喜　就職のことがほぼ決定してその日の午後二時にもう一度面会に行けばいいと云ふ時、恰度午後一時半、彼は電車通りで下駄の鼻緒を切った。",
              "citation": {
                "source": "縁起に就いて",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "川原民喜　彼の家は川端にはなかったが、彼の生れた街には川が流れてゐた。",
              "citation": {
                "source": "川",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月五日原民喜　四月五日　山村家から招ばれたので昼から出掛ける。",
              "citation": {
                "source": "四月五日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五ニズム述懐原民喜-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）女童：入力者注　主に外字の説明や、傍点の位置の指定（例）自惚れた。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄の門原民喜　お祭りの夜だった。",
              "citation": {
                "source": "地獄の門",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀原民喜　酔ぱらって雀を憶ひ出した二人は新宿まで出掛けた。",
              "citation": {
                "source": "雀",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚いてしまふ原民喜-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）耀るのだらう。",
              "citation": {
                "source": "焚いてしまふ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹那トンネル開通祝ひ原民喜　頼太は四十歳の独身の独眼の発明家だったが、まだ汽車へ乗ったことがなかった。",
              "citation": {
                "source": "丹那トンネル開通祝ひ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れもの原民喜　ポストのところまで歩いて行くと、彼はポケットから手紙を取出した。",
              "citation": {
                "source": "忘れもの",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "棉の花原民喜　十歳の時の夏、構造は川端の小母の家で暮した。",
              "citation": {
                "source": "棉の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏日の散歩原民喜　その男は顔が仮面のやうになってしまって、毀れものを運ぶやうにおづおづと身体を動かしてゐた。",
              "citation": {
                "source": "真夏日の散歩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬晴れ原民喜　上と下に路があって真中に桜の並木が植ってゐるが、上の方の路にはよく日があたった。",
              "citation": {
                "source": "冬晴れ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "よみがへる父原民喜　父の十七回忌に帰って、その時彼の縁談が成立したのだから、これも仏の手びきだらうと母は云ふ。",
              "citation": {
                "source": "よみがへる父",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸漿原民喜　結婚式の二時間前、彼女は畳に落ちてゐた酸漿を拾って鳴らして捨てた。",
              "citation": {
                "source": "酸漿",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜原民喜　樟の大きな影が地面を覆って、薄暗い街燈が霧で曇ってゐた。",
              "citation": {
                "source": "夜",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇天原民喜　放蕩の後の烈しい哀感が街中に慄へてゐるやうな日だった。",
              "citation": {
                "source": "曇天",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の日のちぎれ雲原民喜　まっ青な空に浮ぶ一片の白い雲がキラキラと雪のやうに光ってゐる、山の頂である。",
              "citation": {
                "source": "夏の日のちぎれ雲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "比喩原民喜　机を前にして二人の少年は坐ってゐた。",
              "citation": {
                "source": "比喩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "遍歴原民喜　植民地を殖すのだとか、鉄道を敷設するのだとか云ふ譬喩で、新しく友達を作ることを彼は説明するのであった。",
              "citation": {
                "source": "遍歴",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
