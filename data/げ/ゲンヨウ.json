        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「どうも、ありがとうございました」「いやあ、――あ、荷物、荷物……」　赤井と二人掛りで渡して、「これだけですか」「はあ、どうも……」「じゃ、気をつけて、ごきげんよう」「ごきげんよう、どうもいろいろと……」　頭を下げたが、しかし彼女は立ち去ろうとしなかった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごきげんよう、ストーナさん。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごきげんよう、坊や。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ごきげんよう、そしてさようなら。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同　親分、ごきげんよう。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（九郎助拾い集めて掌中に丸める）牛松　じゃ、稲荷の兄い、ごきげんよう。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "十蔵　弥助兄い、ごきげんよう。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥助　ごきげんよう。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札場のきわまで送って来た女は、「いろいろごやっかいになりまして、……ではごきげんよう」と丁寧にお辞儀をした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、ごきげんよう……」「まてッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしとしては、転校しますといわれて、はい、そうですか、では、ごきげんようというわけにはいかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……乳母や、きげんよう。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごきげんよう、と謹んで申し上げます。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "さようなら、ごきげんよう。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……七時、さよなら、ありがたう、ごきげんよう、青衣子よ、坊ちやんよ。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……野蕗老のまめ／＼しさよ、おべんたうを詰めて貰ひ、残りの酒を酌んで別れる、なが／＼お世話になりました、さよなら、ごきげんよう。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "若水君ありがたう、皆さんごきげんよう、伊那よ、さよなら、――七時出立。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝酒を頂戴する、今朝はお別れだ、林五君、奥さん、坊ちやん、ありがたう、ごきげんよう。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝だしぬけにやあさん来訪、呉郎さんよんで来て、ちよつとおわかれの言葉など、さよなら、ごきげんよう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、十郎さんが白米を供養して下さつた、ありがたい、これで当分は安心して暮らせる、呉郎さんも来訪、いよ／＼おわかれ、さよなら、ごきげんよう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "落出の街はずれ大野大師堂でお通夜、ゆっくりして八時出立、それではどなたもごきげんよう、たいへんお世話になりました。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "西へ東へ、或は南へ北へ、さようなら、ごきげんよう。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と桃太郎は言って、「では、ごきげんよう。",
              "citation": {
                "source": "桃太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ皆さん御きげんよう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ皆さん御きげんよう……何年ぶりかで見上げる夜空の寒いこと、私の肩掛は人絹がまざっているのでござります。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "シベリア線で、籌子夫人して武子さんが帰朝ときまったとき、訣別の宴につらなった良致氏は、黙々として静かにホークを取っただけで、食後の話もなく、翌日、出立のおりもプラットホームに石の如く立って、「ごきげんよう」と、別れの言葉は、この一言だけだとある。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごきげんよう……」　とたんに、飛行艇は海面にたたきつけられた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……では、ごきげんよう。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、　ごきげんよう！",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
