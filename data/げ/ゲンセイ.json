    "reading": {
      "primary": "げんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "blister beetle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水銀とか、芫菁とか、それぞれ薬を入れて煉るのです。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時書生さんがお勝手まで駈けて来て、真赤な顔をして、頻りに嚔をして苦しそうなので、「どうなすったの」と聞きましたら、「今薬局で芫菁を磨っているのですが、どんなに我慢をしても、あれには叶いません」とのことで、それから暫く外へ出て休んでいました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らずに芫菁のいる木の下に休んでも、すっかり負ける人もある」とおっしゃいました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芫菁は発泡に使うのです。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
