[
  {
    "uuid": "fc0bf288-bae1-54cb-ae8a-3ce0a4074e0b",
    "entry": "原動",
    "reading": {
      "primary": "げんどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
