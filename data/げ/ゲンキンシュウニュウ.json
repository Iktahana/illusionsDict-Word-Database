        "examples": {
          "standard": [
            {
              "text": "彼は副業でかなりの現金収入を得ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "農業だけでは現金収入が少ないため、アルバイトをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "安定した現金収入を得るために、彼は新しいビジネスを始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "現金収入がいかにも少く、妻の欲しがるものを食べさせることもできない。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この土地にゐて、君、固定した現金収入があるつていふことは、なによりの強味だぜ。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その現金収入で、また次の作品を作る。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
