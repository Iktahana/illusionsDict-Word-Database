        "examples": {
          "standard": [
            {
              "text": "市場で買い物をする時は、現地語で挨拶すると店員さんがおまけしてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は通訳を介さず、独学で覚えた現地語で住民たちと交流を深めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その国には多くの部族がおり、地域ごとに異なる現地語が話されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "うまいことに俺は完璧な現地語が話せる」　手提げかばんを取り、都市の真ん中にぶらり飛びこんだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "城では誰も現地語を話さない。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時かがんで、召使いの耳に何事か現地語でささやいた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
