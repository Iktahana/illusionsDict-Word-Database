          "literary": [
            {
              "text": "こういう自主的な音楽運動は主として「日本現代音楽協会」が指導している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代音楽についても、やっと私が同感出来るところまでやって来ました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それでも世人は皆、世界を革新する事柄をでも話すような様子ありげな言葉で、フランス現代音楽のことを話していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代音楽の傑作として後世に残るオーケストラ作品を、いくつも作っている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
