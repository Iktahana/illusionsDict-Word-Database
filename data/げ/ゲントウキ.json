        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この山小屋は厳冬期には雪で閉ざされてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厳冬期に向けて、暖かいコートと手袋を準備した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厳冬期の夜空は、星が特に美しく見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そのげんとうきは、ずっと遠くからうつせるから、だれもいないように見えたのだよ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
