    },
    "definitions": [
      {
        "index": 1,
        "gloss": "winter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "玄冬素雪のさむさにも、嵐を友として砂に臥して龍顏のおんいきざしを守り、聊もそむき奉らじとふるまはれしに、寂寞の風に心を破られて、草を枕としては松のひとりにならんとするを悲み、あはれ／＼この世はよしやさもあらばあれと、花にむかつて涙をそゝがれしといふは、誰のことでござりまするか。",
              "citation": {
                "source": "山家ものがたり",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄冬和空皆方外ノ侶ナリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは、げんとうだよ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのげんとうきは、ずっと遠くからうつせるから、だれもいないように見えたのだよ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
