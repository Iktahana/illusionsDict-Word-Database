        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四辺は寂然ひそまり返り、諸所の波止場や船渠の中に繋纜りしている商船などの、マストや舷頭に点されている眠そうな青い光芒も、今は光さえ弱って見えた。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは舷頭からパイロットが吹く呼子笛の一声一声の下に、全員のハンマーが鳴るので、一種何ともいえない音響をもち、ドック中を震撼する。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは、げんとうだよ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのげんとうきは、ずっと遠くからうつせるから、だれもいないように見えたのだよ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
