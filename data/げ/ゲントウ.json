  {
    "uuid": "eef7ac71-4528-5c64-a8a6-7c4ac1d6abee",
    "entry": "舷灯",
    "reading": {
      "primary": "げんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "running lights",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "往復の船は舷灯の青色と赤色との位置で、往来が互に判るようにして漕いで居る。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "舷灯の無い、暗い甲板だが、星の光で、四辺の様子がうかがわれる。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のすう二つの大きな葉巻が舟の中で紅色の舷灯のように燃えた。",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、だがまだ予定の位置じゃない」「それに舷灯も点けていません」「まあ待て」　太平丸は号笛を鳴らしながら、相手の方へ近寄って行った。",
              "citation": {
                "source": "流血船西へ行く",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは、げんとうだよ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのげんとうきは、ずっと遠くからうつせるから、だれもいないように見えたのだよ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
