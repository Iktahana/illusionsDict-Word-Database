  {
    "uuid": "2763021b-870d-5573-9990-3f34f4174737",
    "entry": "減等",
    "reading": {
      "primary": "げんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reduction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雑誌なら雑誌の程、力の入れ加減等を知ると云うことは、一方から云うと確にわるい。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは、げんとうだよ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのげんとうきは、ずっと遠くからうつせるから、だれもいないように見えたのだよ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
