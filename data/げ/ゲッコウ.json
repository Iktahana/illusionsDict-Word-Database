[
  {
    "uuid": "ed4bdda5-10a8-57b7-adea-90496779eba2",
    "entry": "月光",
    "reading": {
      "primary": "げっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "moonlight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其処に月光的な悲哀が漂つてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔月光の鉛のなかに〕宮沢賢治月光の鉛のなかにみどりなる犀は落ち臥し松の影これを覆へり",
              "citation": {
                "source": "〔月光の鉛のなかに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には中秋の月が冴えて、氷のような月光が独り地上を照らしている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光の下、ひとり深夜の裏町を通る人は、だれしも皆こうした詩情に浸るであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光うけて失神し　　庭の土面は附黒子。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつめたい水の底まで、ラムネの瓶の月光がいつぱいに透とほり天井では波が青じろい火を、燃したり消したりしてゐるやう、あたりはしんとして、たゞいかにも遠くからといふやうに、その波の音がひゞいて来るだけです。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく水はサラサラ鳴り、天井の波はいよいよ青い焔をあげ、やまなしは横になつて木の枝にひつかかつてとまり、その上には月光の虹がもかもか集まりました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "重く流れる月光の底をその小さな犬が尾をふって來る。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面の爪草の花、青白いともしびを點じ微かな悦びをくゆらしそれから月光を吸ふつめくさの原。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはらわたの鈍い月光の虹、それから小學校の窓ガラスがさびしく光り、ひるま算術に立たされた子供の小さな執念が、可愛い黒い幽靈になってじっと窓から外を眺めてゐる。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "メーテルリンクの青い鳥は、月光の下で見ると青い鳥だが、それを捉へて晝間見ると、普通の平凡の鳥になつてる。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光がときをり長い稻妻のやうに過ぎた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の芸妓達は月光の下でスカリプタの恋愛小説を読みながら顔見世の順番を待っている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "イサックの黒い顔に月光のような涙が光った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "西根の山山のへっぴり伯父は月光に青く光って長々とからだを横たへました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今は崇高な月光のなかに何かよそよそしいものが漂ひはじめた。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊の木の中でも樺の木でも、またかれくさの地下茎でも、月光いろの甘い樹液がちらちらゆれだし、早い萱草やつめくさの芽にはもう黄金いろのちいさな澱粉の粒がつうつう浮いたり沈んだりしています。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光に洗われたベンガル湾が見える。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光は初めてその深祕さで雪の積った風景を照していた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜更けて彼が便所へ通うと、小窓の外の屋根瓦には月光のような霜が置いている。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "干潮で荒い浪が月光に砕けながらどうどうと打ち寄せていました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光がその人の高い鼻を滑りました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、月光による自分の影を視凝めているとそのなかに生物の気配があらわれて来る。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは月光が平行光線であるため、砂に写った影が、自分の形と等しいということがあるが、しかしそんなことはわかり切った話だ。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩が現われ、頸が顕われ、微かな眩暈のごときものを覚えると共に、「気配」のなかからついに頭が見えはじめ、そしてある瞬間が過ぎて、Ｋ君の魂は月光の流れに逆らいながら、徐々に月の方へ登ってゆきます。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "地形がいい工合に傾斜を作っている原っぱで、スキー装束をした男が二人、月光を浴びながらかわるがわる滑走しては跳躍した。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
