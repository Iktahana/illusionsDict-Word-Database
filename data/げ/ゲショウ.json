    "definitions": [
      {
        "index": 1,
        "gloss": "person of humble birth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まあまあナマクラ者にゃ似合い相当のところでげしょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の百円札みたいなネットリした紙にミッチリと書詰めたもので、黒い線に青と赤の絵具を使った挿絵まで這入っているんですから、それだけでも大層な珍本でげしょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書なんてものは信心でもしない限り滅多に読んでみる気がしないものですし、その本を持ち伝えた先祖代々の人も、それがソンナ本だって事を云い伝える事も出来ずに、土蔵の奥に仕舞い込んで御座ったんでげしょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、どうです、つるつるのつるつると、鮮かなもんでげしょう。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、お出迎えがないといった寸法でげしょう。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でげすがな、これから切通しの坂を一ツお下りになりゃ、五両と十両は飛ぶんでげしょう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士　――また冷返る夕嵐、雪の松原、この世から、かかる苦患におう亡日、島田乱れてはらはらはら、顔にはいつもはんげしょう、縛られし手の冷たさは、我身一つの寒の入、涙ぞ指の爪とりよし、袖に氷を結びけり。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士と謂やあお前さん、大したもんでげしょう。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ私の名は忠三でげしょう」「妾ア忠公かと思っていた」「ひどうげすな。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりほかに今のところ、いい手段はないのだからね」「そうでげしょう、そうですともさ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寮住まいはようげしょうが、南蛮屋だってようげしょう！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "袴様はようげしょうが、忠三だってようげしょう！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俗人は拙が作蔵を婆化したように云う奴でげすが、そりゃちと無理でげしょう。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も日本固有の奇術が現に伝っているのに、一も西洋二も西洋と騒がんでもの事でげしょう。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分じゃア、この梅雨は乾梅雨でげしょうか、な？",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼な申し分ではございますが、まったく張り合いがない、どッと来べきところをでも皆様がたはおすましになっておられます」「そりゃ生活がまるで違ってるから、ね」「そうでげしょう、な」彼はさすがに学問ある人の仲間は違うものだと考えられた。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせまずい生活をしているのは御承知であったでげしょうが、――猫八と申す芸人の家はこちらか？",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ先が唐の物でげしょう。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あればまず寺子屋の師匠でも言いそうな、四書五経の講釈だけでげしょう。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに加うるに有難屋の宣伝もありという塩梅で、ずいぶん共にオカカの感心、オビビのビックリに価する、奇妙｜奇天烈な記録の内容でげしょう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうやって自分の手にかけたお座敷で、兄弟分がこしれえたお庭を眺めながら、旦那様のお相伴をして一杯頂戴出来るなんて職人｜冥利の行止まりでげしょう。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸ッ子の「コンチワ」が「チヤア」で済むようなもんでげしょう。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "男でも女でも物を呉れるたんびに「タヌキ」と云ってやると喜んでいるんですからヤッパリ獣なんでげしょう。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもまだ自惚れが残っていたんですから感心なもんでげしょう。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあっしはこの時に虫が知らしたんでげしょう、何となく……これあイヤナ処へ来たナ……と思いましたよ。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは脊髄神経が見る夢なんでげしょう」「ヤッ……こいつは……」　と柳井副院長は、チョット面喰ったらしく、頭を掻いて、苦笑した。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――刀なんぞ野暮でげしょう。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでげしょう、ねえ、旦那。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
