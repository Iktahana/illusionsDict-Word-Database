[
  {
    "uuid": "327b92e8-be68-511c-b85a-b1766223446a",
    "entry": "下人",
    "reading": {
      "primary": "げにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
