        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それより南にめぐれば、佐間口、下忍口、大宮口あり。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと下忍まで行ッて来るッて出かけて行ったよ。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその日本の布教は、目下忍耐を必要とする微妙な境遇に追い込まれている。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
