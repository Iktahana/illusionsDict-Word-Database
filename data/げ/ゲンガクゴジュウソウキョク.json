        "examples": {
          "standard": [
            {
              "text": "モーツァルトの弦楽五重奏曲は、室内楽の中でも傑作の一つに数えられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "四重奏にビオラが一本加わることで、弦楽五重奏曲の深みが増す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "演奏会では、シューベルトの有名な弦楽五重奏曲が披露された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "五重奏曲では「弦楽五重奏曲ト短調Ｋ五一六」はモーツァルト晩年の憂愁を盛った曲で、普通ヴィオラの五重奏曲中の傑作とされている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弦楽五重奏曲ハ長調作品一六三」は第二チェロを加えた五重奏曲で、スケールの大きい、厚壮な五重奏曲である。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
