          "literary": [
            {
              "text": "こんな愚かな芸無しどもが、もろもろの芸術の神であるとは、どうしても私には考へられないのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一向ツマラヌ芸無し猿じゃ」と自分でも云うて御座る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ相も変らぬ芸無し猿、天才的な平凡児として持って生まれた天性を、あたり憚らず発揮しつくしながら悠々たる好々爺として、今日まで生き残って御座る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私しゃ、芸無し猿でがして、何も出来ねえんでがすが、ただ一つ、手品を知ってますで……」　万はそう言って座敷の真ん中へ出て行った。",
              "citation": {
                "source": "手品",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術批評家と夏蜜柑７・９サンデー毎日　日本の宴会には、よくお客同志の余興づくしといつたやうなものがあつて、それあるがために自分の隠し芸を、人前に押し売りをする事の出来る楽しみもあるが、どうかすると、自分が芸無しのために飛んだ恥をかゝされることがよくある。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東野や矢代をふと見ると、いずれも役者になったことも知らず、苦苦しくふくれている芸無し猿の二本の大根に見えて来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "家作が何軒あるの地所を何程持っているのって外、何一つ碌な口も利けない芸無しの癖に。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
