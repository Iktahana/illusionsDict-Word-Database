[
  {
    "uuid": "d663e67e-f67a-5943-8ea3-a4702b1b9471",
    "entry": "月色",
    "reading": {
      "primary": "げっしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "moonlight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すでに死を期しては月色に冴えまさり行く翁の心丹に一ひら未練の情がうす紅色に冴え残った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山河月色、昔のままである。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園は森邃として月色ますます昏く、夜はいまや全くその死寂に眠れるとき、※谺に響き、水に鳴りて、魂消る一声、「あれえ！",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八日、丙戌、霽、子剋、将軍家南面に出御、時に灯消え、人定まりて、悄然として音無し、只月色蛬思心を傷むる計なり、御歌数首、御独吟有り、丑剋に及びて、夢の如くして青女一人前庭を奔り通る、頻りに問はしめ給ふと雖も、遂に名乗らず、而して漸く門外に至るの程、俄かに光物有り、頗る松明の光の如し。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴飼橋畔の夜景に低廻して、『わが詩の驕りのまのあたりに、象徴り成りぬる栄のさまか』と中天の明月に浩歌したりし時、我と共に名残なくその月色を吸ひたるもこれ也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光・月色・風塵・草卉・魚・鳥の諸相、季節と生活、單にただ一々の歌品を以て、偶ま同好にして渾厚の士の清鑒に供へむとするのみ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光・月色・風塵・草卉・魚・鳥の諸相、季節と生活、単にただ一々の歌品を以て、偶ま同好にして渾厚の士の清鑒に供へむとするのみ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥声草花我を迎ふるが如く、雲影月色我を慰むるが如く感ずべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨餘逢月色　　雨余月色に逢はば、高趣畫難成　　高趣画けども成り難からむ。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "擧付斯茅宇　　挙げて斯の茅宇に付し、教誇月色深　　月色の深きを誇らしむ。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "25陽の色のふかまるなかに　突風のもえたつなかに　なほあはあはと手をひらく薄月色の薔薇の花。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "当年流行の新月色に、眼も眩ゆい春霞と、五葉の松の刺繍を浮き出させた裲襠。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いのは天井裏のパンカアと、海月色に光る切子硝子のシャンデリヤだけだった。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターバンのうしろに光っている海月色のシャンデリヤまでが、後光のように神秘的な光りをあらわして来た。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手の方、路の片隅によりて月色｜渦をなし、陰地には散斑なる蒼き光、木の間を洩れてゆらめき落つ。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙念　（下手あたかも月色の渦巻ける片隅に立ちたれば、彩られたる血の色｜鮮かに、怪体なる微笑を浮めつつ狂喜の語調にて）たたきひしいでくれたぞ。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ僧徒らに何らの抗意なく、いたずらに戦慄けるのみなると、さきには陰地に立てりし妙念の、今ところを異にして月色の中に輝けると異る。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにこの三四ヶ月色々の意味で衰弱が深まつてゐるのです。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて日は海に入りて、陰暦八月十七日の月東にさし上り、船は金波銀波をさざめかして月色のうちをはしる。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の夜月色｜清輝なり。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍は藍がかりし雪の色（即ち明快なる藍）及空の黒さ（即ち濁りし藍）及び桃花を照す月色（即ち紅味を帯びたる藍）なり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "厠の窗より夜の庭を窺見るに霜を浴びたる落葉銀鱗の如く月色氷の如し。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ夜月色奇明ナリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ夜月色清佳ナリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "目にも止まらぬ無双廻わし、月色｜蒼茫たる深山の静寂を微塵に破って閃めく息杖。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背山面海望悠悠、月色潮声入客楼、遥認波間光数点、星星都是仏英舟。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "）背山面海望悠悠、月色潮声入客楼、遥認波間星集散、灯台光底仏英舟。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
