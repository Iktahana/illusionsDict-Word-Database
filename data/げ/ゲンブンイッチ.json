[
  {
    "uuid": "dc328355-ee39-5d69-b2c7-77fc46e51b60",
    "entry": "言文一致",
    "reading": {
      "primary": "げんぶんいっち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
