    "definitions": [
      {
        "index": 1,
        "gloss": "unification of the written and spoken forms of a language",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "甲板をあちこちする船員の靴音がコツリ／＼と言文一致なれば書く処なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十年間に、文学運動の上では、言文一致の提唱とその勝利があったが、そしてそれは、より直接的に社会生活を反映し得る手段を整えたものと云い得るのだが、作品に於ては、現実は歪曲され、愛国主義は鼓吹された。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間も或新聞社の人に話したが、言文一致體の語尾の「だ」と「である」との事で、予は「だ」といふと強く當り過ぎると思ふ。",
              "citation": {
                "source": "文章の音律",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉先生も、はじめは「豆府と言文一致は大嫌だ。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに明治の末になってから、西洋の言文一致を学ぼうとして、始めてこの日常語が文章に取り込まれ、永く物置場に投げ込まれていた日本語が、急に芸術的に研ぎ出される状態になってきた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし言文一致が始まってから、今日まだ漸く半世紀に達しない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日では一番言文一致が行はれて居るけれども、句の終りに「である」「のだ」とかいふ言葉があるので言文一致で通つて居るけれども、「である」「のだ」を引き拔いたら立派な雅文になるのが澤山ある。",
              "citation": {
                "source": "「自然を寫す文章」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから言文一致は便利ではあらうが、何も別にこれでなければ自然は寫せぬといふ文體はあるまい。",
              "citation": {
                "source": "「自然を寫す文章」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども漢文くづしの文體が可いか、言文一致の細かいところへ手の屆く文體が可いかといふ事は、韻致とか、精細とかいふ點に於て一寸考へものだらうとは思ふ。",
              "citation": {
                "source": "「自然を寫す文章」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "而シナガラ實ニ他ノ歐釆諸國ニ見ザル國字改良漢字廢止言文一致羅馬字採用等ノ議論百出ニ見ル如ク、國民全部ノ大苦惱ハ日本ノ言語文字ノ甚ダシク劣惡ナルコトニアリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかと謂つて、柳浪の言文一致も、余りシヤロウで、会話沢山で、思はしくない。",
              "citation": {
                "source": "明治文学の概観",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』だの、『いちご姫』だのゝ言文一致に満足せずに、『二人女房』を書いた。",
              "citation": {
                "source": "明治文学の概観",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅俗折衷でもいかんし、言文一致もイヤだし、仕方がない、地の文と会話とを全く分けたものでやつて見ようと言つて、さうした試みをしたことなどもあつた。",
              "citation": {
                "source": "明治文学の概観",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし雅俗折衷にしようか、言文一致にしようかと作者が小説を書くにすら皆迷つてゐた時代だから仕方がない。",
              "citation": {
                "source": "ペチヨリンとゲザ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅俗折衷だの、言文一致だの、国文復興だのと、文体すらまだ一定しないやうな時代で、堅苦しい漢文調で小説を書いて居たものすらあつた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "美妙二葉亭の言文一致、西鶴を模倣したやうな紅葉露伴の雅俗折衷、落合直文や小中村義象を中心にした新しい国文調の文章、さういふものが段々に出来て行つた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　二葉亭が書いた『浮雲』の言文一致はかれを促がして『二｜人女房』を書かしめた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは、美妙の『いちご姫』などに於ける言文一致に満足して居られなかつた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何うせ言文一致だから、もう少し自由に行かなくつては詰らない』かう言つたのを私は幾度も聞いたことがある。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『二人女房』は言文一致に於けるかれの最初の試みである。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後、かれは『紫』と『多情多恨』とを言文一致で書いた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "言文一致とかれの『写実主義』とはいつも並行して行くやうに見えた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "言文一致で書く時には、かれは大抵平凡な日常生活をその材料にした。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅俗折衷、地の文と会話との関係、言文一致などゝ、かれが小説を新聞に公けにした時には、必ず何等かの新しい試みが施されてゐた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "……候文も古くさいし、言文一致ではだら／＼するし……」　光子さんは、紙をひろげてペンを執りましたが、何から先へ書いたらいゝか？",
              "citation": {
                "source": "蛍",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十二年に、八十に近いお婆さんが、大胆な言文一致体で手紙を書いていたのである。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑雨のデリケートな江戸趣味からは言文一致の飜訳調子の新文体の或るものは気障であったり、或るものは田舎臭かったりして堪らなかったようだ。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて新らしい言文一致と奥浄瑠璃の古い「おじゃる」詞とが巧みに調和した文章の新味が著るしく読書界を驚倒した。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に美妙斎の生緩い冗漫の言文一致は論難に不適当であって、いとど薄弱なる議論を益々力弱くさせて世間の軽侮を招くようになった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
