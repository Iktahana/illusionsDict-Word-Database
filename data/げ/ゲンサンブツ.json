        "examples": {
          "standard": [
            {
              "text": "この協定によれば、農産物などの原産物は特恵関税の対象となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自国の原産物を保護するために、輸入品に対して高い関税を課す方針だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "途上国から届いた原産物を加工して、付加価値の高い商品を開発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "たとえ穀物の輸入が原産物では禁止されていても、法律を決めるお堅い連中は加工品を禁止することまでは考えてないんだ、しかもこの分野では小麦が主力品なんだよ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
