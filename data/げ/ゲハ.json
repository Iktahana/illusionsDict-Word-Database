        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ペンクは名実共にゲハイムラートであって、時々カイザーから呼立てられてドイツの領土国策の枢機に参与していたようである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲハイムラート以下皆往復共に四等客車に収まって行った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは日本と関係のないよその話ではあるが、自分の知るところでは一九一〇年ごろのカイゼル・ウィルヘルム第二世は事あるごとに各方面の専門学術に熟達したいわゆるゲハイムラート・プロフェッソルを呼びつけて、水入らずのさし向かいでいろいろの科学知識を提供させて何かの重要計画の参考としていたようである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケレド　ヒロツパノ　マンナカノ　カゲハ　ウゴキマセンデシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソウレ　ゴラン、オマエサンノ　カゲデ　ナイ　シヨウコニ、オマエサンガ　トンデモ、アノ　カゲハ　ウゴカナイデハ　ナイカ」ト　ポストハ　イヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガ　ユウガタニ　ナツテ、タイヤウガ　オチテ　シマフト　ヒロツパノ　マンナカノ　マルイ　カゲハ　ナクナツテ　シマヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とき折その可能を、ふと眼前に、千里｜韋駄天、万里の飛翔、一瞬、あまりにもわが身にちかく、ひたと寄りそわれて仰天、不吉な程に大きな黒アゲハ、もしくは、なまあたたかき毛もの蝙蝠、つい鼻の先、ひらひら舞い狂い、かれ顔面蒼白、わなわなふるえて、はては失神せんばかりの烈しき歔欷。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水兵が呉れた駄菓子の袋をポケツトに入れて、ぽつぽつと噛じりながら歩かうとした時、一羽のジヤコウアゲハがわたしの眼の先を飛んでゐるのを発見した。",
              "citation": {
                "source": "或るハイカーの記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹、シダ、コケ、花、鳥、ヘビ、ルリタテハもアゲハもカブトムシもみんな、それから山もだ」　いよいよ話がわからなくなって、慶一は高志の横顔を見なおす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は、カラス・アゲハの翅が展翅板からはみ出るので、ハガキを切つて板の端に付け足してゐた。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミスヂ其他（２）アゲハ……クロ（５）キ（３）カラス（７）ジヤコウ（６）アヲスヂ（３）△鞘翅。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると緑と黒の幻色をひらひらと陽りに翻したカラスアゲハが崖ふちの枳殻にとまつてゐた。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏アゲハを探してゐるのだ。",
              "citation": {
                "source": "居酒屋の聖人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺は昆虫採集家の往来する所で、さういふ一人がこの親爺に向つて、アゲハは三百円もするといふ耳よりな話を吹きこんで行つたのである。",
              "citation": {
                "source": "居酒屋の聖人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、烏アゲハを三百円の金に代へたといふ話もきいたことがない。",
              "citation": {
                "source": "居酒屋の聖人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も少し気になつたので、東京の牧野信一へ手紙を出して、烏アゲハが三百円もするかどうか尋ねてみた。",
              "citation": {
                "source": "居酒屋の聖人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧野信一は二十年も昆虫を採集してゐて、僕もお供を仰せつかつて小田原山中アゲハを追ひ廻したことなどもあつたからである。",
              "citation": {
                "source": "居酒屋の聖人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "折返し返事が来て、烏アゲハはたしかに値段のある昆虫だけれども、神田辺で売つてゐる標本は三円ぐらゐだつたと記憶してゐるといふ文面だつた。",
              "citation": {
                "source": "居酒屋の聖人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケサハヤク　ノハラデ　アソンデヰテ、ヒヨイト　ミタラ、ボクノカゲハ　キミヨリ　ズツト　オホキカツタンダゼ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イクラ　オホキク　フンバツテモ、チイサナ　カゲハ　オホキク　ナリマセンデシタ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アサ　ミタトキヨリモ、モツト　モツト　カゲハ　オホキク　ナツテヰタノデス。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キミノ　カゲハ　オホキイガ、ボクノカゲハ　モツト　ズツト　オホキイヨ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "走るいなずまにたとえられる、必殺の一撃、「おッ」　それをサッとかわして、とびのいた天魔太郎は、まさにうつくしいアゲハのチョウの身がるさです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいアゲハチョウを見るような、天魔太郎のうつくしいすがたと、牛若丸のような身がるさによわされて、なにがなんでもこれを負けさしたくないような心持になっていたのです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、まさかあれは」――とつぜん衝動にかられて、ぐっと首をつき出しながら――「フランスからきた生徒のカラムが私と一緒にキアゲハを追っかけたとき、許可なくして道から外れたことと、思わず母国語で叫んだことの罰として、兄弟パーゲルから減食処分にされた空地じゃあるまいな！",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯揚ゲハ絽ノ生地ニ白ト薄イピンクノ暈シ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
