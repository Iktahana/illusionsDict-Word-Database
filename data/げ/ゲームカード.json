        "examples": {
          "standard": [
            {
              "text": "Nintendo Switchのゲームは、ダウンロード版とパッケージ版のゲームカードがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、新作ゲームのゲームカードを発売日の朝に買いに行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、お気に入りのゲームカードを友達と交換し合って遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "prepaid IC cards used in pachinko parlors",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
