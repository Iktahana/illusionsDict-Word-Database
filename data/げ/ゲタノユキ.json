        "examples": {
          "standard": [
            {
              "text": "彼は有力議員の影にぴったりと寄り添い、下駄の雪のようにどこへ行くにも付いて回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分では何も決められず、いつも誰かの後ろを歩くだけの下駄の雪のような生き方はしたくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの人は社長の下駄の雪だから、機嫌を損ねないように注意したほうがいい」と忠告された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "下駄の雪を落す音が聞える。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度ばかり掻取った路も、また薄白くなって、夜に入れば、時々家の外で下駄の雪の落す音が、ハタハタと聞える。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "表では下駄の雪を電柱ではたき落す音が手に取るやうに聞えた。",
              "citation": {
                "source": "故郷を辞す",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
