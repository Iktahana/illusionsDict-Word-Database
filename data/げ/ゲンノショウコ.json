        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "現の証拠にゃ、さっきの小者があば敬の組屋敷のほうへ飛んでいったじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろんのことに、そいつあ疑いだけのことなんで、現の証拠を突きとめたわけじゃねえんだが、てっきりもう江戸屋のしわざにちげえねえと、嵐三左衛門が会う人、出会う人に吹聴したからたまらねえんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにあるんです、現の証拠は、どこにあるんです」「この品さ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "現の証拠にゃ、うしろにその匕首がころがっているから、なにより確かなんだ」「…………」「ね、だんな、どうですかね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺を知らずに迎えに来たちう現の証拠が……」「アハハハ。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　矢筈草は俗に現の証拠といふ薬草なること、江戸の人｜山崎美成が『海録』といふ随筆第五巻目に見えたり。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、「矢筈草俗に現の証拠といふこの草をとりみそ汁にて食する時は痢病に甚妙なり又｜瘧病及び疫病等にも甚｜効あり云々」。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分のうちにはたしかに孫四郎なぞのうかがいも得ぬ何かがあると自信してはいるもののまだその現の証拠を実現したわけではない。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分の裡にはたしかに孫四郎なぞの窺ひも得ぬ何かがあると自信してはゐるもののまだその現の証拠を実現した訳ではない。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで通り古代における発疹チフス出現の証拠を求めている。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "げんのしょうこという草は腹薬として重宝がられるが、何というつつましい草であろう。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "げんのしょうこを煎じた日向くさいような匂がその辺に漂っていた。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女の給仕が、縁のかけた大湯呑に、げんのしょうこを煎じた代用茶を入れてほのぼのと湯気だったのを盆にのせ、それを目よりも上に高く捧げて持って来た。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "破れ障子に強い風が当ったような音をたてて彼は極く熱つのげんのしょうこを啜った。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件引継簿の頁の上にはげんのしょうこの液の玉が盛上っていた。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも赤見沢博士の重大性なるものは……」「粗茶ですが、どうぞ」　少女の給仕が茶を入れて持って来て、臼井の前に置き課長の大湯呑にはげんのしょうこをつぎ足して来た、課長は客に粗茶をどうぞと薦めたわけだ。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドソルビンをのむ、げんのしょうこをのむ。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "火傷には油を、下痢にはげんのしょうこをだけ。",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "下で今げんのしょうこを煮て居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、アドソルビンをのんで、げんのしょうこをのんで。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "げんのしょうこが植物で薬草だということを知ったのも鳴尾君のたまものである。",
              "citation": {
                "source": "西隣塾記",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
