[
  {
    "uuid": "8b087921-62bd-5a73-90ac-c29b5b2914f0",
    "entry": "下乗",
    "reading": {
      "primary": "げじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dismounting (esp. from a horse as a sign of respect)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――目だたぬように名人はすばやく下乗札の陰に身を引くと、静かに直訴状を取り出して押し開きました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "下乗之事禁中ヨリノ御使イ、並ビニ江戸公儀ヨリノ御使者以外ニ夜中ノ通行堅ク御差止メノ事　はっきりと禁裡御所からのお使い、並びに江戸お公儀からの使者以外は、夜中の通行堅くお差止めの事と書いてあるのです。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "下乗橋からお庭伝いに右へいって、中ノ口。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままつけて行けい」　下乗橋からゆったり乗って、さしかかったのが常盤橋御門、ぬけると道は愈々暗い。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "呑込めないながら、呑込み顔に聞いてみねばならぬ仕儀は小娘と同じことで、おたがいに要点を逸して、それで要領を得たようなつもりでいるところへ、ドカドカと熱田の宮の鳥居前から下乗橋が、たちまち人でいっぱいになりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しずまれというのに、しずまらぬか」と御下乗の衛士のいうようなことをいって、遠くから久太夫を宥めにかかった。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "目下乗船中、一週間以内に到着する予定だ。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなくても、到る所、山の神域は、「下乗」の石が立っていないのをいい事にして、参道から玉垣を越え、神殿までもおかそうとする。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マガリャンスはこの探検隊の最高権力を握ることを要求し、王より各船長以下乗員に対して総指揮官への絶対服従を命じて貰った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに大手の濠際には、下馬下乗、あまたの大名や旗本の駕籠がこみ合ッていて、供待の者どもが憂色をつつんでいる様子。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "“下馬下乗”はいうまでもない。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「下乗されよ」　それは、左兵衛ノ府の衛士たちの声々だった。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "一せいに、轅を捉えて、下乗を命じる。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "prohibition against entering the grounds of a temple or shrine on horseback",
