    "definitions": [
      {
        "index": 1,
        "gloss": "original title",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「一六三五年に書かれた俺の先生の（方法通説）の原題は（理性を正しく導き、学問に於て真理を探究せんがための方法の通説。",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "原題はフランス語なので読めませんが、たぶん、ぜんぜん関係ないタイトルでしょう」　高志はまったく平然としている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス語だから原題はわかりませんが、すこしは関係のあるタイトルかもしれません。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲のタイトルは原題の音訳を原則とし、邦題についてはほとんど配慮していない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "原題「映画の普遍性とは」）",
              "citation": {
                "source": "映画の普及力とは",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "原題「トオキイ監督の苦悶――雑文的雑文――」）",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "原題：A Dog of Flanders (1872)邦題：フランダースの犬",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新潮」昭和二八年四月号、原題「幸福論（十）―井伏鱒二によせて」）",
              "citation": {
                "source": "井伏鱒二によせて",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "『審判』という標題が邦訳の定訳となっているが、原題は「訴訟」という意味である。",
              "citation": {
                "source": "「世界文学大系58　カフカ」解説",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "原本は高名な漢学者で、原題を「啓蒙｜婦女庭訓」といい、広く読まれている評判の本であった。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　原題 Servitude volontaire すなわち「意志の隷従」とは意志の自由 〔liberte' volontaire〕 と対をなす言葉で、一口に言えば奴隷根性のことである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「孔子っていつごろのにんげんだい」「敬称をおつけなさい、孔子などと呼びすてにしてはいけません、聖人といわれるくらい偉大な方なのですから、――孔子さまは今から二千三百年ほどまえの方です」　これにはびっくりした。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
