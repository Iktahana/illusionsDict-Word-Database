        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "船酔いで気持ち悪くなり、ゲロゲロと吐いてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "食べ過ぎてお腹を壊し、夜中にゲロゲロだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの時のパーティーは、みんながゲロゲロになるまで飲んでいたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "蛙かやかやこやこや、ころころ、げろげろ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから胸がむかむかして、げろげろとやってしまった。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "法座の上の僧正の、たゞひとりの講讃まではつきり拡声機によつて聞かれたことは、好奇心を満足はさせたかもしれぬが、読経のあひまに喉に痰がひつかゝつて、げろげろとあさましく痰を吐くその音まで境内一杯に拡声放送されたのには失笑した。",
              "citation": {
                "source": "君臣相念",
                "author": "龜井勝一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
