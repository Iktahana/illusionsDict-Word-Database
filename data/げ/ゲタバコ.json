[
  {
    "uuid": "9180aced-3a28-5646-abe8-12ec2eff73ed",
    "entry": "下駄箱",
    "reading": {
      "primary": "げたばこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
