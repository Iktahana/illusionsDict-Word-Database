        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただし俺はカイン・ゲルトだ。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はしばし茫然として立ちたりしが、ふと油燈の光にすかして戸を見れば、エルンスト・ワイゲルトと漆もて書き、下に仕立物師と注したり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五日間世話になった船員にそれぞれトリンクゲルトを渡さなければならないのに、ちょうど食事時でボーイらは皆食堂へ出ているのでぐあいが悪くて少し気をもんだ。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は暫し茫然として立ちたりしが、ふと油燈の光に透して戸を見れば、エルンスト、ワイゲルトと漆もて書き、下に仕立物師と注したり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仍リテ鼠ノ所在スル附近ヲ厳重監視シ、可及的速カニ密輸方法ヲ取調ベ、本部宛報告スベシ」　ゲルトネル氏菌の登場、そして数十万ルーブリの真珠の頸飾の密輸。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "街へ出かけて買物、米、炭、味噌、等々（うれしいことにはそれらを買ふだけのゲルトは残つてゐた）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜の良かつたことは、――樹明君といつしよに飲み歩かなかつたこと（これは彼が避けたのかも知れない）、そしてＮさんに無理なゲルトを出させなかつたこと。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時の汽車で宇土へ、宿においてあつた荷物を受取つて、九時の汽車で更に八代へ、宿をきめてから、十一時より三時まで市街行乞、夜は餞別のゲルトを飲みつくした。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一刻も早くアルコールとカルモチンとを揚棄しなければならない、アルコールでカモフラージした私はしみ／″＼嫌になつた、アルコールの仮面を離れては存在しえないやうな私ならばさつそくカルモチンを二百瓦飲め（先日はゲルトがなくて百瓦しか飲めなくて死にそこなつた、とんだ生恥を晒したことだ！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の憂は一日にて足れり――キリストの此言葉はありがたい、今日泊つて食べるだけのゲルトさへあれば（慾には少し飲むだけのゲルトを加へていたゞいて）、それでよいではないか、それで安んじてゐるやうでなければ行乞流浪の旅がつゞけられるものぢやない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日今日すつかり音信の負債を果したので軽い気になつた、ゲルトの負債も返せると大喜びなのだけれど、その方は当分、或は永久に見込みないらしい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはもうアルコールもいらない、カルモチンもいらない、ゲルトもいらない、フラウもいらない、……やつぱりウソはウソだけれど、気分は気分だ。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "更けてやつと出来た御飯が半熟ゲルトが手にいつたので、何よりもまづ米を、炭を、そして醤油を買つた（空気がタダなのはほんたうに有難いことだ）。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "此宿は新らしくて掃除も行き届いてゐる、気持よく滞在出来るのだが、憾むらくはゲルトがない（殊に同宿の煩はしさがないのがうれしい）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の画家に酒と飯とを供養する、私が供養するのぢやない、私の友人の供養するのだから――友人から送つてくれたゲルトだから――お礼がいひたかつたら、友人にいつて下さいといつたりして大笑ひしたことだつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日読書静観、ゲルトがないと坊主らしくなる。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "予期しないゲルトが少しばかり手に入つた、酒を買ふたり、頭を剃つたり、胡瓜もみをこしらへたり、いやはや忙しい事だつた、嬉しい事だつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲルトなし、アルコールなし、エゴなし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――歌唱詩人オスワルドは、ヴェントシン（ヒヨスの毛茸ならんと云わる）を入れたる酒を飲むと見る間に、抱琴を抱ける身体波のごとくに揺ぎはじめ、やがて、妃ゲルトルーデの膝に倒る。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道子ハ悲鳴ヲアゲルト同時ニソノ場ニ気ヲ失ッテ倒レテシマッタノデス。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからメラニーやゲルトルーデもつかまったの。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲルトルーデは憲兵を引っかいたわ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどゲルトルーデの妹のイルミナが、訴えたもんだから、捕り手が来たのよ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはついお隣のマダム・レスリッヒ――ゲルトルーダ・カールロヴナのところに下宿してるんですよ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手のドア、ソーニャの部屋をゲルトルーダ・カールロヴナ・レスリッヒの住まいとへだてているドアの向こう側には、同じくレスリッヒ夫人の住まいに属する中間の部屋があって、もう長いこと空き間になっていた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒盤物では、ベッテンドルフと映画で親しみのあるエゲルトが興味だろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャッガァ号というのですが、今私共の読んでいるこの巻物は、いずれもその駆逐艦に乗り組んでいたカアル・フォン・ワイゲルトという若い独逸の中尉によって書かれたものです……」と言いかけて、微笑して博士は語を切った。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
