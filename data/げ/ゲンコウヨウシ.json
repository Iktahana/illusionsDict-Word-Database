[
  {
    "uuid": "40dcd8df-67cd-565d-85d4-d9e48cf4374e",
    "entry": "原稿用紙",
    "reading": {
      "primary": "げんこうようし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
