    "definitions": [
      {
        "index": 1,
        "gloss": "Air on the G string (Bach, from BWV 1068)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
