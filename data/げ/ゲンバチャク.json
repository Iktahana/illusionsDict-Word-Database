        "examples": {
          "standard": [
            {
              "text": "資材の現場着が遅れたため、今日の工事予定を一部変更せざるを得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大型クレーンが現場着次第、すぐに設置作業を開始してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "納品される製品の現場着時間を、事前に所長へ連絡しておく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "澤山の勞働者が次から次へと、現場着のまゝ連れられてきた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は急いで蚊帳を出ると、ソッと現場着を着て茶屋を出た。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はソッと中に入って、自分の棚から着替えの現場着を出すと、汗に濡れた着物を脱ぎ捨てて、前の清水で手拭を絞っては、べとつく汗を拭きとった。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            }
          ]
        }
