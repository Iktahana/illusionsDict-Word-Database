[
  {
    "uuid": "48a2bceb-13b1-52e3-b79e-3f563d79bccc",
    "entry": "月給",
    "reading": {
      "primary": "げっきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "monthly salary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは恰度月給日のその日のことだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "月給日といへば女優部屋などは、普段とは和気の可なり横溢してゐるものだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等仲間の党派に変動を来すのも、半分は此の月給日のことだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして月給がなくなって困る／＼とこぼしながらぶらぶらしていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時私は大学の講師をして月給三十五円とおやじからの仕送りで家庭をもっていたのである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等が一段ずつ位と月給が上って、俺たちゃ立ち腐れになるんだ）「誰だい？",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああして月給取も店員も運転手も職工も小僧も女事務員も町娘も女給も仲居もガソリンガールも一緒になって踊っているのは何と美しく善いことだろう。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ君は黙って聞いてしまってから物価騰貴と月給の話をした。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家産の管理を引受けた弟のエドワードは始めは月給を貰っていたが、後には利益配当の方法によった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遊んどって月給が貰えるんだから、そんなべら棒な仕事はないだろう。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは食扶持いっさいむこう持ちで月給が七円だというのです、それでからだを動かすことはあまりないというんですから、さっそくそれに決めたのです。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今月は、いくら月給を貰ったい？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あのう、月給を半分だけでも渡して貰えるように、あんたから、小山さんに頼んで呉れませんか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「当分、月給を渡さないということになってるんだがなあ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月給の不渡りと、食糧の欠乏と、張宗昌の無理強いの戦闘に、却って戦意を失ってしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳は、そこの支那人と並んで、腰かけに腰かけ、南京から何人くらい一緒にやって来たか、今夜はなお、あとから何人くらい来る見込みか、月給はいくら貰っているか、そんなことをたずねだした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "製品を売って、月給は、その中から取る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月給を貰っていなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、息子が中学を卒業して、高等工業へ入って、出ると、工業試験場の技師になり、百二十円の月給を取るのを想像していた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜって巡査なんてものは実際月給も僅かですしね、くらしに困るものなんです。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその高慢税は所得税などと違って、政府へ納められて盗賊役人だかも知れない役人の月給などになるのではなく、直に骨董屋さんへ廻って世間に流通するのであるから、手取早く世間の融通を助けて、いくらか景気をよくしているのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　平太はこの時月給をとったばかりでしたから三十円ほど余ってゐました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今朝云ふのを忘れたが虎猫君は月給が十銭あがつたよ。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の月給を取っておいでになる修身の本家本元みたいな立派な紳士の方が、時々この手をお出しになるんですから驚きますよ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘエッ……これは三百円のお金……今月のお月給の全部……私に下さるんで……ヘエッ……あの聖書のお手附け……千円の内金と仰言るんで……これはどうも恐れ入りましたナ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州福岡の民政系新聞、九州日報社が政友会万能時代で経営難に陥っていた或る夏の最中の話……玄洋社張りの酒豪や仙骨がズラリと揃っている同社の編集部員一同、月給がキチンキチンと貰えないので酒が飲めない。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　二十八の夏でございました、そのころはやや運が向いて参りまして、鉄道局の雇いとなり月給十八円｜貰っていましたが女には懲りていますから女房も持たず、婆さんも雇わず、一人で六畳と三畳の長屋を借りまして自炊しながら局に通っておったのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本へ来ている外国人には珍しい下等な暮しをしていたが、しかし月給はかなり沢山に取っているという噂であった。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月給鳥という鳥の漫画には「この鳥はモネーモネーと鳴く」としたのがあったのを覚えている。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう学校を卒業して月給も取れている長男夫婦は銀の置時計ぐらい奮発しましょうし、女学校へ行っている娘は手芸を丹精して贈りましょうし、幼稚園へ通っている末の子は富士山の貼紙細工でもして贈りましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
