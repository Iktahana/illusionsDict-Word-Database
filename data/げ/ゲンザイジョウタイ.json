          "literary": [
            {
              "text": "現在状態がつゞけば氣遣である。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在状態が變化すれば此狂態もやめるかも知れぬ。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし是から三千代の顔を見るにした所で、――また長い間見ずにゐる気はなかつたが、――二人の向後取るべき方針に就て云へば、当分は一歩も現在状態より踏み出す了見は持たなかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしこれから三千代の顔を見るにしたところで、――また長い間見ずにいる気はなかったが、――二人の向後取るべき方針に就て云えば、当分は一歩も現在状態より踏み出す了見は持たなかった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
