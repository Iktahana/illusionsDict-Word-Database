  {
    "uuid": "9e10b049-b681-5a5a-8b58-570d49491ccc",
    "entry": "現世利益",
    "reading": {
      "primary": "げんせりやく",
      "alternatives": [
        "げんぜりやく"
      ],
      "is_heteronym": false
    },
    "grammar": {
