        "examples": {
          "standard": [
            {
              "text": "元和偃武によって、戦国時代は完全に終焉を迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "元和偃武は、徳川家康の天下統一を象徴する出来事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "元和偃武以降、日本にはおよそ250年間の平和が訪れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "尊王の大義は、元和偃武未だ五十年ならざるに、徳川幕府創業者の孫なる彼の口より宣伝せられぬ。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ元和偃武以来、幾んど四半世紀、忽然として清平の天地に砲火を上げ、竪子を推して、孤城を嬰守し、赫々たる徳川｜覇府の余威を籍り、九州の大名これを合囲し、百戦老功の士これを攻め、年を改めて始めて抜くを得たり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "元和偃武以来、蔵めて鞘にありし宝刀も、今はその心胆と共に錆びて、用に立つべきもあらず。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
