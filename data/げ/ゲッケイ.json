[
  {
    "uuid": "0e84f285-7063-544d-bd47-90514fc0479c",
    "entry": "月経",
    "reading": {
      "primary": "げっけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "menstruation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひと月ふた月経った。",
              "citation": {
                "source": "過古",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、二月経って、兄は仕事を完成させずに死んでしまいました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二月経ったが、手一つ握るのも躊躇される気の弱さだった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋がいゝのか最初歩三つが一月経つと角落ちになり、二月目には平手で指せるようになった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月経って漸くその顔に馴染んで来た頃、鼻の上の蝋がとけ出した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども一月経っても、二月経っても、私の果敢ない恋が何の報いられるところもなかったことは御存知の通りです。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "イワンの兄は、不思議なことにも、それから幾日経っても、幾月経っても幾十年経っても再び姿を現わしませんでした。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、やがて五六ヶ月経って秋の収穫期になると、後家さんの下ッ腹が約束の通りにムクムクとセリ出して来たのでドエライ評判になった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石を大切に祭れば、お前の女房の血の道は一と月経たぬうちに癒る。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は死んだ者が蘇生ったようになって、家へ帰りましたが、丁度全三月経ったです。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の心が通ずるのか、貴下も年月経ち、日が経つても、私の事をお忘れなさらず、昨日までも一昨日までも、思ひ詰めて居て下さいましたが、奥様が出来たので、つひ余所事になさいました。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナミオ商会では、見習期間の給料が手弁当の二十五円で、二月経つと三十円であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに一箇月経つと警察もとうとう投出したらしく「遂に迷宮に入る」という新聞記事が出た。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　再びほんのりとした意識が、還って来る迄に幾日経ったか幾月経ったか、それとも幾年経ったか判らなかった。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇とも雲とも土とも分らない道の上で何日経ったか判らない、いや日を数えるのでなく月を数えても、幾月経ったかも判らない、いやもう一二年も経って居るのかも知れない。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、電話機消毒商会では、見習期間の給料が手弁当の二十五円で、二月経つと三十円であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば豹一が見たのは頭髪をむやみに伸ばして眼鏡を掛けたところだったが、一月経てば、丸坊主になり、眼鏡を外してしまっていないとは保証出来ないのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "入社してから半月経っていたのだが、全くの見習記者に過ぎぬ豹一は、仕事らしい仕事も与えられず、ただ意味もなく毎日出社しているだけのことだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピナに来て六ヶ月経ったばかりの頃、僕は彼女と出逢いました。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が非業の死を遂げたのが八五年の一月ですが、それから二年八ヶ月経ちました。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして見ると、月経の血が戸惑をして鼻から出ることもあるように、性欲が絵画になったり、彫刻になったり、音楽になったり、小説脚本になったりするということになる。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三箇月経って、この兄は病死した。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十年ほど前フレザーが『金椏篇』を著わして、その内に未開国民が、ある年期に達した女子を定時幽閉する習俗あるは、全く月経を斎忌するに因ると説いたのを、当時学者も俗人も非常の発見らしく讃め立てたが、実はわが邦人には見慣れ聞き慣れた事で、何の珍しくもない事だった。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "李中行　娘が死んで、まだ半月経つか経たないのに、せがれが又こんなことになるとは……。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して二月三月経つと、何処の竹もすべて寒山竹は枯れ出した。",
              "citation": {
                "source": "中秋の頃",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹部の痛みが月経と関係があるのを気づいて、葉子は婦人病であるに相違ないとは思った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも御多分に洩れないズボラであって、一度は金のために奇禍を買ったので、その後を潔くする意味で雪後と改称したが、一生借金の苦労に追われて終に名を成す遑がない中に、夫妻相続いて急性の肺患に犯され、一と月経たぬ間に夫婦とも鬼籍に入った極めて不幸な作者であった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が三月と宣告したんだから、力んでも踏反り返っても三月経てばゴロゴロッと痰が咽喉へ引からんでのお陀仏様――とこう覚悟して置かにゃ虚偽だよ、」と片頬に笑を含みつつ力の抜けた空元気で、「そこは大悟徹底している。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから数月経って聞いた咄だが、最後は石橋思案と丸岡九華が専ら世話をしたそうだ。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
