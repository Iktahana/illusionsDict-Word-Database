        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "午後は奈々子が一昼寝してからであった、雪子もお児もぶらんこに飽き、寝覚めた奈々子を連れて、表のほうにいるようすであったが、格子戸をからりあけてかけ上がりざまに三児はわれ勝ちと父に何か告げんとするのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹振り放して逃げんとして抱き戻された。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵ヅカヅカと駕籠に寄り、垂れを上げんとした時、アッと叫んで蹴飛ばされる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いたお光、アッと叫んで逃げんとする。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵が、Ｔ「黙って居りゃ　いい気になって　よくも俺達の面に　泥塗って呉れた」　逃げんとする仲蔵の襟がみとって引き戻す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げんとする腕を捻じ伏せて右門は、　おふみに、Ｔ「おふみさんこの面をよッく御覧なせえ」　おふみ不審そうにその顔を見る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜治子より手紙来たり、今日｜午過ぎひそかに訪問れて永久の別れを告げんと申し送れり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも文學といふ分野に於て、詩に優つて純粹に藝術の遂げんとする要求を追求してゐるものはない。",
              "citation": {
                "source": "詩への逸脱",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然生活をなしつつあった人々がその飽くことなき人間の欲望を遂げんとして、知識に、経験に、感情に、感覚に、その威力を振って都会を築き上げて来たのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一団の烟が急に渦いて出るのを、掴んで投げんと欲するごとく、婆さんは手を掉った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年が勇威｜凜々として今大鷲を搏った時の風采は、理学士をして思わず面を伏せて、僵れたる肉一団何かある、我が妻をもてこの神将に捧げんと思わしめたのである。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをしも、祭司次長が諸君に告げんと欲して、敢て咎めらるべきでない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春枝丈けは其後無事に皈つて來たものゝ、君の行衞は知れず、私が兼てより、有爲な帝國海軍々人に養成して、國に獻げんと心に樂しんで居つた日出雄は、君と共に、印度洋の藻屑と消えてしまつたと斷念した時には、實に泣くより辛かつたです。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば二人はいよいよ死を決して、嬢が悲を除き、日頃の思を遂げんと、いよいよ今日正十二時を期し、日比谷公園より、各自の飛行船に乗じて出発の途につくべしと。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "家邸も何かせむ、皆得三に投与えて、かかる悪魔の火宅を遁れ、片田舎にて気散じに住みたまう気は無きか、連れて遁げんと勧めしかど、否、先祖より伝わりたる財産は、国とも城ともいうべきもの、いかに君と添いたいとて、人手には渡されず。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ、と前褄引合して、蹌踉ながら遁げんとあせる、裳をお録が押うれば、得三は帯際取って屹と見え。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "へいげんというは東京……学校の御雇講師にて、富豪をもって聞ゆる――西洋人なるが、毎年この別荘に暑を避くるを常とせり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夕へいげんと両々手を携えて門前を逍遥し、家に帰りて後、始めて秘蔵せし瑞西製の金時計を遺失せしを識りぬ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "応接室にては三郎へいげんと卓子を隔てて相対し、談判今や正に闌なり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "撲殺して占め損い、遁げんとして馬丁に見露され、書生のために捕えられて、玄関に引摺込まれし、年老いたる屠犬児は、破褞袍を衣て荒縄の帯を〆め、踵の辺は摺切れたる冷飯草履を片足脱ぎて、花崗石の上に平蜘蛛。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こらっ――」　見張員と休息員と無頼漢等を引挟んで、片手に一人ずつ引掴めば、洩れたる者も逃げんとはせず。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と夫人に謝して再び梶棒を上げんとせり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲暗き山の端より月かすかに近づくを、獲ものよ、虐げんとすれば、其の首の長きよ、口は耳まで裂けて、白き蛇の紅さしたる面ぞ。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無頓着なる白糸はただその健康を尋ぬるのみに安んじて、あえてその成業の期を問わず、欣弥もまたあながちこれを告げんとは為さざりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ幸ひとよび止めて馬を借受け、むかうの岸までは渡りしが……これより遠き旅をゆくに、馬の足を假らでは不便なり、ぬすみて逃げんと馬をはやめて、二三町ばかり駈けぬくれば、馬士はおどろき追ひ來りて馬盜人よと罵りさわぐ。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根川のほとりきのふまた身を投げんと思ひて利根川のほとりをさまよひしが水の流れはやくしてわがなげきせきとむるすべもなければおめおめと生きながらへて今日もまた河原に來り石投げてあそびくらしつ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は東京駒込追分の坂路に夕日を浴びて汝に水桃を捧げんとする。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそは桂子自身の生命が、更に桂子の生命を支へ上げんとする健気な力、そして永遠に新しき息吹である。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は無言なれば、老生も無言のままに引下り、件の入歯を路傍より拾い上げんとせしに、あわれ、天の悪戯にや、いましめにや。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
