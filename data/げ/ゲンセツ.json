[
  {
    "uuid": "b2a011cf-0dc6-530e-a303-39ebaa95ab2a",
    "entry": "言説",
    "reading": {
      "primary": "げんせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
