          "literary": [
            {
              "text": "二百円ずつの月賦販売も取りあつかいます。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "文泉堂という本やがあってね、これは『古事類苑』だの何だのの月賦販売者ですが、いろいろの名士のところへまわって歩く、妙な中爺ですが、この男はいろんな人間を見ているものだから一種の哲学をもっていてね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "然り、床屋――理髪店とか、調髪師と称するには、余りに狭い間口であり、余りに二十箇月月賦販売丸丸商会仕入れの椅子である。",
              "citation": {
                "source": "青バスの女",
                "author": "辰野九紫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
