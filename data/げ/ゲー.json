[
  {
    "uuid": "683e55ac-10a0-5896-bad9-c62e7d63fce1",
    "entry": "ゲー",
    "reading": {
      "primary": "ゲー",
      "alternatives": [
        "ゲ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-接尾辞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(video) game",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とはいへ、彼は決してニイチエやゲーテの如き意味でのよき詩人ではない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "『人生でいちばん楽しい瞬間は』とゲーテが言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし藤村をゲーテとすれば、當時の泣菫はキーツであつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして僕の個性は、ゲーテよりもキーツやシエレーに近かつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーテも、ハイネも、ニイチェも、日本では早くから名が叫ばれて流行し、その文學的概論さへ解らない中に、既に「流行おくれ」となつてバタ屋の紙屑箱に賣られて行つた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも昭和十年頃の最近になつて、それらのもつと古臭いゲーテやハイネが、漸く少しばかり本體を知られて來たのである。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人株ではカナル線の発見者ゴールトシュタインや、ワールブルヒなどがおり、若手ではゲールケ、プリングスハイム、ポールなどもいた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年アインシュタインに対する反ユダヤ人運動でひどく器量を悪くしたゲールケはやはり一座の中でいちばん世間人らしいところがあった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーテのライネケフックスの訳本を読んで聞かせてくれたり、十歳未満の自分にミルの経済論、ルソーの民約論を教授してくれるという予告だけでもしてくれた楠さんは、たしかにその時代の新人であり、少なくも自分にとっては、来るべき「約束の国」の先触れをする天使の役をつとめてくれたように思われる。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コムプレッサーでは、ゲージは九十封度に昇っていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代的のものでもゴルフの外に庭球野球｜蹴球籠球排球などがあり、今は流行らぬクリケット、クロケーから、室内用にはピンポン、ビリアードそれから例のコリントゲームまである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒場で悪漢が密談している間に、隣室で球突きのゲームをとる声と球の音が聞こえている。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シェークスピアを尊敬してゲーテをそれほどに思わないらしい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人のアインシュタインに対する関係は、一見ボスウェルのジョンソン、ないしエッカーマンのゲーテに対するようなものかもしれない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーベンスやゲーンスボローやないしはアルマタデマに無くしてセザンヌ、ゴーホあるいはセガンチニなどに存するところのものである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの牝牛のやうに健康で、ゲーテのやうに萬有を包合する人類愛の詩人高村光太郎が、最近に於けるニヒリスチックの詩は何を語るか。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーテは八十歳になつて戀愛詩を書き、トルストイは老年になつて、尚ほ狂氣の如く正義を求め苦しんだ。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋では反對に、ゲーテが八十歳になつて戀をしたと言つて敬嘆された。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちゲーテの言ふ如く、すべての文學者は、素質の詩人と素質の哲學者とを、性格に於て要素して居る人物でなければならぬ。",
              "citation": {
                "source": "本質的な文學者",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ゲーと進藤飛び上った。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝が、Ｔ「何時も貴方と　御一緒の……」　「こんな頭で、こんな顔の」雪枝が言えば、　半次「そうそうＴ「あの先生なら　此村大吉」　ゲーッ？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その詩や、ハイネ、ゲーテの訳詩に感心したのでもない。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが仏教の渡来ということもあいまってわが国におけるこれらのゲームの絶滅をかろうじて阻止することができたのかもしれない。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた小倉の霜降りの洋服を着て、脚にも泥だらけのゲートルをまき、草鞋を履いている。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ヨーヨーとコリントゲーム　ヨーヨーがすたれて、コリントゲームがいまだに残存している。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしコリントゲームの方には公算的統計的の要素が入り込む。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーヨーの緊張時代のあとにコリントゲームの弛緩時代がめぐって来たものと見える。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔すゝきすがるゝ丘なみを〕すゝきすがるゝ丘なみを、　　にはかにわたる南かぜ、窪てふ窪はたちまちに、　　つめたき渦を噴きあげて、古きミネルヴァ神殿の、　　廃址のさまをなしたれば、ゲートルきりと頬かむりの、　　闘士嘉吉もしばらくは、萱のつぼけを負ひやめて、　　面あやしく立ちにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリレー、トリツェリ、ヴィヴィアニ、オットー・フォン・ゲーリケ、フック、ボイルなどといったような人がはなはだ粗末な今から見れば子供のおもちゃのような道具を使って、それで生きた天然と格闘して、しかして驚くべき重大な画期的実験を矢継ぎばやに行なったのがそもそもの始まりである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
