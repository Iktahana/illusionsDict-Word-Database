        "examples": {
          "standard": [
            {
              "text": "原子戦が勃発すれば、地球上の生命は壊滅的な被害を受けるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの人々が原子戦の脅威に怯えていた時代があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は原子戦の悲劇を二度と繰り返さないために活動している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしながら一方では戦争が原子戦争の姿をとり、他方では有効な世界的集団安全保障の機構が成立するというような時代になれば、軍隊の有無は国家としての不可欠の条件とみられないようになるかも知れぬ。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
