[
  {
    "uuid": "ff4481fb-042c-5dce-b6c0-c87904a8b185",
    "entry": "厳戒",
    "reading": {
      "primary": "げんかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
