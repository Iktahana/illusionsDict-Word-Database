        "examples": {
          "standard": [
            {
              "text": "中学生の時、現代国語の授業で夏目漱石の作品を読んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代国語の教科書には、様々なジャンルの文章が掲載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は現代国語の成績が非常に良く、特に読解問題が得意だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "東宝系は三船敏郎の『奇巌城の冒険』で、これは現代国語の宿題になった、『走れメロス』を映画化したものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラの期末試験の現代国語は、四〇点だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語に音楽、古文、漢文に現代国語の個人教授を受け、中学校三年生では四人の家庭教師がついた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
