        "examples": {
          "standard": [
            {
              "text": "大地震によって、あの原子力発電所は大きな被害を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海岸線に建設された原子力発電所は、地域の主要な電力供給源だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テレビのドキュメンタリーで、原子力発電所の内部が公開されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もう二、三年もしたら、原子力発電所も、註文書一通で、出来ることになるかもしれない。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけは、現在各国で造られている原子力発電所にしても、アメリカの原子力潜水艦にしても、原子力をすぐ電力に変えるのではなく、原子力をいったん熱にかえて、その熱を機械的エネルギーおよび電気に変えるのである。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで現在の火力施設は、石炭ボイラーを原子力ボイラーに置き換えるだけで、そのまま原子力発電所になるわけである。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日某新聞の記者が「ソ連の原子力発電所が、いよいよ出来上がったそうで、その写真が手に入りました」といって、五、六枚の写真をもって来た。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
