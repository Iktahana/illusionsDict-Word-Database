        "examples": {
          "standard": [
            {
              "text": "有名アーティストのデビュー当時の貴重な原盤が、レコード会社の倉庫から発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "デジタルリマスター版を作成するために、30年前の原盤を慎重に修復する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この原盤には、当時のスタジオの空気感まで克明に記録されています」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "原盤からプレスする方式で数百枚まとめれば、一枚三百円前後でケースに収めたＣＤ―ＲＯＭが出来上がります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＤ―ＲＯＭの原盤を工場に送ってさすがにほっと一息つき、エキスポでどんなことを話そうかと考える過程で、私は暗くて冷たかった闇の記憶のかけらを払い落としていったのだと思います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
