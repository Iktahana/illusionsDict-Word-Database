        "examples": {
          "standard": [
            {
              "text": "この機械の原動機は非常に強力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "船の原動機に故障が見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小さな原動機でも、工夫次第で大きな力を生み出すことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんどの地下戦車は前のものよりも、すこし重量を増して、四十トンちかくとなったが、これは主として原動機を三個に分けたためであった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "原動機は廻転し、ベルトはふるえ、軸は油をなめまわし、攪拌機はかきまわし、加熱炉は赤く焔え、湯気は白く噴き出し、えらい騒ぎが毎日のように続いた。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
