      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "strict order",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "行ってこい」　清逸は我れ知らず威丈け高になって、そう厳命した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、二、三、兵隊のように歩調を取って自分の所まで歩いてこい、そう彼女は私に厳命を下した。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日、癸卯、鷹狩を停止す可きの旨、諸国の守護人等に仰せらる、事度々厳命有りと雖も、放逸の輩、動もすれば違犯有るの旨、聞食し及ぶに依りて、此の如しと云々、但し所処の神社の貢税の事に於ては、制するの限に非ずと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王厳命して疾行すること三百里、途に偵騎に遇えば、尽く之を殺し、一昼夜にして暁に比びて滄州に至る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄は陣形を十二段に構え、迂廻軍の到着迄持ちこたえる策をとり、百足の指物差した使番衆を諸隊に走らせて、諸隊その位置をなるべく保つようにと、厳命した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが秀吉は姫路を通るとき、家へ立ち寄るものあらば斬るべしと厳命した。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく、多年等閑に付し来たれる神社を、一朝厳命の下に、それ神職を置け、基本金を積めと、短兵急に迫られし結果、氏子｜周章、百方工夫して基本金を積み存立を得たるも、また値上げ、また値上げとなり底止するところを知らず。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は素より女将に厳命せし事のかくも容易すく破れんとは知るよしもなく、人のけはいをばただ女将とのみ思いなせりしに、図らずも妾の顔の顕われしを見ては、如何で慌てふためかざらん。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇の神崎が果たして江戸に隠れているかどうかは疑問であったが、この厳命を受けた彼等は毎日｜暁六ツから屋敷を出て夕六ツまで江戸中を探し歩かなければならなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の二股になった所で左に行こうとすると、闇をすかしていた仁右衛門は吼えるように「右さ行くだ」と厳命した。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんの厳命を忠実に果すまで。",
              "citation": {
                "source": "お父さんのお寝坊",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると或る日、その中の一頭が巡査に吠付き、追われて元の飼主たる徳永商店に逃込んだのを巡査は追掛けて来て、店から引摺出して店前で撲殺し、かつ徳永を飼主と認定するゆえ即時に始末書を警察へ出せと厳命した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "危険と目指れた数十名の志士論客は三日の間に帝都を去るべく厳命された。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一般にも、言葉をつつしみ、ことに飛行島の方に川上機関大尉のことを洩らすなとの厳命だ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "交換の方にも厳命が下って、単に受話器を持上げただけで、直ちに警部の卓上電話と接続され、消魂しい鈴の音が鳴り響こうという趣向である。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "門番にはチチコフがいつ、どんな触込みでやって来ても決して通してはならないという厳命が下された。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとコイツが恐ろしく利いたと見えて、その夕方、安島家から厳めしい顧問弁護士が、玄洋日報社へ乗込んで来て、社長と山羊髯に面会して記事の取消を厳命したという事で、その翌る日の朝刊の一面に「事実無根……安島家云々」の二号活字の取消広告と、社会記事の末尾に小さな取消記事が五行ばかり出た。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは腹が立とうが、ビックリしようが、何でもカンでも感情が動きさえすればおなじ事……泣くか、笑うかの一本槍で、ほかの感情の一切を外へあらわし得ない病気であるが、この病気の説明を脳髄はヤハリ『脳髄が物を考える』式で押し通して行くべく、全世界の科学者に厳命している。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこの厳命を奉戴した世界中の科学者たちは、こうした中風の症状を「これは脳髄の全体が、出血のために痺れてしまっているのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は余りの事に驚き呆れまして、暫くは教会の門前に立ちつくし、茫然とあとを見送っておりましたが、それにしてもこの十数年このかた打ち絶えておりました夫の消息を初めて聞き知りました妾の身として、たとい、Ｊ・Ｉ・Ｃの厳命でございましょうとも、何しにこのまま立ち去る事が出来ましょう。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは性来のなまけ者で自由思想崇拝者の小生としては実に不満苦痛に堪えない境遇でありましたが、父の厳命が恐ろしいと同時に、経済上の都合から、苦学をする勇気もないままに、止むを得ず隠忍致しておる状態でありました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体彼は、仕事中は決して室にはいってはいけないと、召使たちに厳命していたものである。",
              "citation": {
                "source": "奇怪な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "探検を、一時中止しろという厳命がくだってしまった。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の場合は母の厳命であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳命を受けた彼らが後始末のために帰る途々考えたことは後の場合であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大尉はにわかにマドリッドを退去してパリーへ北上すべしという厳命を受け取った。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
