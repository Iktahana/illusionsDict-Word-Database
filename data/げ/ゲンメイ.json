[
  {
    "uuid": "0e3541d4-36cb-5224-921b-d494367e3716",
    "entry": "厳命",
    "reading": {
      "primary": "げんめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
