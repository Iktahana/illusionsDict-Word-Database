    "definitions": [
      {
        "index": 1,
        "gloss": "Monday",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして明日の今頃は　　長の年月見馴れてる　　故郷の土をば見てゐるのですさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな月が出てゐるにはゐたが、それでも木の繁つた所は暗かつた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "へい、――それには全く気が付きませんでした、自転車は月の光を浴びながら、ガタ／＼といつて引揚げられた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹌踉めくままに静もりを保ち、聊か儀文めいた心地をもつてわれはわが怠惰を諫める、寒月の下をゆきながら、陽気で坦々として、しかも己を売らないことをと、わが魂の願ふことであつた！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「西部劇通信」だの「ゼーロン」だのを書いた昭和五年の頃は、彼の返り咲きの観があつたし、評判がよかつたのであるが、あの頃のものよりも、それから暫く後に書いた、水車小屋の壁に凭れて月の明りで手紙を読む短篇なぞの方が、遙かに牧野さんらしいものであると思はれる。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が最初に会つたのは、一昨々年の五月である。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二※月くらゐして、やつぱりその同人の集りのあとで、谷君他三人ばかりが、円タクの中からオイデオイデをするから行つてみると、これから牧野さんを誘ひ出しに行くから乗れといふのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処に月光的な悲哀が漂つてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々と詩論は毎月の雑誌にも現れてをりますが、此の雑誌に訳載中のアランの論文と、それからこれは直ちに詩論と呼べる限りのものではありませんが、フィードレルの芸術論、まづまづ此の二つが此の数年来に読みました詩論の中で心に残つたものであります。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に反して、月末の支払ひだけ片付くとなれば安心の出来る人達は元気でゐる。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処に見られる感性は、古来「寒月」だの「寒鴉」だの「峯上の松」だのと云つて来た、純粋に我々のものである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、二ヶ月も気持が腐つて、湯にも這入らない後で、偶々お湯に這入つてごらんなさい！",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "長の年月、海を見るたびに、おぼろに感じてゐたことが、急に明るみに出た感じ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあれ日は過ぎ月は逝き、なれ等血もなく涙なく、よくぞ鬩めげる数千年、さても殺生はての死の、よくぞ好きなる、おゝ永遠の闘争よ、おゝ恩怨の同胞よ！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその海の上にも星変り、月変つて、――と茲で、私の目は漸く海を去つて、なんだか海と空との中間の奥といつた感じの方角に、過ぎ逝ける諸世紀が、黒光りする中世の武具の色をして、堵をなして潜んでゐるやうに感じられる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくばかり我に信なきともがらに、なにのかかはりあるべしやは、空しく坐して祈り、遠き遍路に消え殘る雪を光らしむ、いのちはひとりのもの、ただ我が信願をかくるにより、木ぬれにかかり、有明の月もしらみてふるへ悲しめり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月蝕皆既萩原朔太郎みなそこに魚の哀傷、われに涙のいちじるく、きみはきみとて、ましろき乳房をぬらさむとする。",
              "citation": {
                "source": "月蝕皆既",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔まひるつとめにまぎらひて〕宮沢賢治まひるつとめにまぎらひてきみがおもかげ来ぬひまはこころやすらひはたらきしそのことなにかねたましき新月きみがおももちをつきの梢にかゝぐれば凍れる泥をうちふみてさびしく恋ふるこゝろかな",
              "citation": {
                "source": "〔まひるつとめにまぎらひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ゆがみつゝ月は出で〕宮沢賢治ゆがみつゝ月は出でうすぐもは淡くにほへり汽車のおとはかなく恋ごゝろ風のふくらしペンのさやうしなはれ山の稜白くひかれり汽車の音はるけくなみだゆゑ松いとくろしかれ草はさやぎてわが手帳たゞほのかなり",
              "citation": {
                "source": "〔ゆがみつゝ月は出で〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔月光の鉛のなかに〕宮沢賢治月光の鉛のなかにみどりなる犀は落ち臥し松の影これを覆へり",
              "citation": {
                "source": "〔月光の鉛のなかに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔青びかる天弧のはてに〕宮沢賢治青びかる天弧のはてにきらゝかに町はうかびて六月のたつきのみちはいまやはた尽きはてにけりいさゝかの書籍とセロを思ふまゝ〔以下空白〕",
              "citation": {
                "source": "〔青びかる天弧のはてに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "看痾宮沢賢治七月はさやに来れど故しらに人はなほ疾み日過ぎ来し白雲の野はさびしくも掃き浄めらる",
              "citation": {
                "source": "看痾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔このみちの醸すがごとく〕宮沢賢治このみちの醸すがごとく粟葉などひかりいでしはひがしなる山彙の上に黄なる月いざよへるなり夏の草山とになひてやうやくに人ら帰るをなにをかもわがかなしまんすゝきの葉露をおとせり",
              "citation": {
                "source": "〔このみちの醸すがごとく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（新生三月号をよみて）",
              "citation": {
                "source": "書信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルスリーヌ・デボルド―※ルモオルは千七百八十六年七月の二十日にドゥエ（Douai）に生れ、千八百五十九年七月二十三日巴里で死んだ。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」兄はそれを畳の上に投げつけた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がひとに深切を施すのは、たいへんの美徳で、さうして内心いささか報恩などを期待してゐるくせに、ひとの深切には、いやもうひどい警戒で、あいつと對等の附合ひになつてはかなはぬなどと考へてゐるんだから、げつそりしますよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘をはたっと睨み、焦げつく声でいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
