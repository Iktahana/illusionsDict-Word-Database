[
  {
    "uuid": "b04c6716-f42a-5ef6-9488-86312794e50f",
    "entry": "言及",
    "reading": {
      "primary": "げんきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
