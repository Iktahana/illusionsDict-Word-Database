    },
    "definitions": [
      {
        "index": 1,
        "gloss": "plaintiff",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "裁判所は坪内逍遥博士に鑑定を命じ、結局原告の勝訴となる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "記に「然る間｜前の大掾源護の告状に依りて、件の護並びに犯人平将門及び真樹等召進ずべきの由の官符、去る承平五年十二月二十九日符、同六年九月七日到来」とあるから、原告となつた者は護である。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年十二月二十九日の符が、今年九月になつて、左近衛番長の正六位上｜英保純行、英保氏立、宇自加｜支興等によつて齎らされ、下毛下総常陸等の諸国に朝命が示され、原告源護、被告将門、および国香の麾下の佗田真樹を召寄せらるゝ事になつた、そこで将門は其年十月十七日、急に上京して公庭に立つた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが原告であったか、被告であったか知らないが、ともかくも裁判の結果が、ある婦人に甚だしい不利益をあたえることになった。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ＣＯＤＥ』『コモンズ』などの著作で知られ、この裁判で原告代理人もつとめた法学者のローレンス・レッシグらは、保護期間延長への批判と抵抗を、今も続けている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "原告も本人が来てゐた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "原告は、非常な能弁家だつた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とでも思つてくれゝば好いが――終ひには私は、原告の法律的術語の羅列があまりに流暢であるのに反して、まつたくの唖である自分が少々きまり悪くなつて、判官達に対してそんな途方もない空頼みを念じたりした。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "原告は、番になると稍々得意気に益々とうとうと弁じたて、次に私の番になると変りなく「は？",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と「はい」とより他になく、また彼は軽いセヽラ笑ひを浮べて立ちあがると（原告が何か云ひ終ると腰を降すのが私には、大胆不敵に見えてゐた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）活気の溢れた原告が大いに被告の非を申告してゐる時だつた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶話３・20　デイケンスは『ぴくゐつく・ぺえぱあす』のなかで、「被告の身にとつては人の好い、福々した、朝餐を甘く食べた裁判官に出会すといふ事が大切だが、原告になつてみると、平常も不満足たらしい、腹の減つた裁判官を見つけるやうにしなくてはならない」と言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正四（一九一五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "里恵は原告節斎に有利なる証言をなしたのに、思軒は誤つて被告鰐水に有利なる証言をなしたものとした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本國に屬したる貿易運上の權も我一方に在らず、裁判の權も我政府の自由に任せず、現に内外の間に起る公事訴訟も我國人は常に被告と爲て彼は常に原告たり。",
              "citation": {
                "source": "亞細亞諸國との和戰は我榮辱に關するなきの説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事の方でも、元々一家内の事だし、原告側にも確証はない、裁判にでもなると大へん面倒な事なので、原告が取下げたのを幸いに、不問にしたらしいのだ。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は甚だ原告たる元右衞門の申條を認めぬ判決だと思ひます。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に竹内柳右衛門という郡奉行があって、大いにその撲滅に苦心し、種々工夫の末、新令を発して、全く賭博の禁を解き、ただ負けた者から訴え出た時には、相手方を呼出して対審の上、賭博をなした証迹明白な場合には、被告より原告に対して贏ち得た金銭を残らず返戻させるという掟にした。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、タルボットの親戚は、なおその訴訟を続け、盛んに権利を主張しておったが、ジェームス一世の時に至って始めて判決が下り、原告の敗訴と決定して、領地は第十一代のバークレー侯に帰したのである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "被告は原告と決闘して正邪を決せんことを請求することが出来る。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし決闘は実際には行われなかったが、被告の見幕に恐れをなして、原告は訴訟を取下げてしまったのである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれは唯原告を宥めるのに有効なために私へお云ひになつただけでしたから、私自身は罰らしい苦しい気持でお受けしませんでした。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "民事裁判の場合などでも、原告被告の人柄とか、判事の私生活との類似とかというようなことから、微妙な傾斜が起りはじめる危険がありそうに思われる。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは係争中の事件で、手記の婦人は原告でもあるし、被告でもあるそうだ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その一〔判官巷を往く〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、しづは結婚前の交際の頃、二人で東劇へ行った時、原告は帽子もかぶらず、アロハシャツをきてきたので、いやであったとかいっていました。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
