[
  {
    "uuid": "08870c10-c010-548e-bb29-ac0f61fe9ff0",
    "entry": "原告",
    "reading": {
      "primary": "げんこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
