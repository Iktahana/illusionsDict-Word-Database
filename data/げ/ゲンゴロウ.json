    "definitions": [
      {
        "index": 1,
        "gloss": "diving beetle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は「また源五郎かしらん」と思った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚や鮒の腹に食いつく源五郎虫のように、彼女達は水上で不良の男達の艇にねばられることがあった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女たち娘仲間の三四人は、これに「源五郎」と符牒をつけていた。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞の記事によると、おいねは旧幕臣の安達源五郎の妻で、源五郎は越後へ脱走するときに、中間の権七に供をさせて妻のおいねと娘のおむつを上総の親戚の方へ落してやったが、源五郎戦死の噂がきこえて後、おいねと権七の主従関係はいつか夫婦関係に変ってしまった。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際｜初鹿野源五郎忠次は主君義信を掩護して馬前に討死した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあお聴きなさい」　半七に十手を突き付けられた武士は梶井源五郎といって、西国の某藩士であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "下のかたより以前の昭全が源五郎を案内して出づ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五郎は二十二三歳の猟師にて、火縄銃を持つ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭全は家内を指して何か囁けば、源五郎は半信半疑の体にて考えている。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）源五郎　（小声で。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）源五郎　（また疑うように。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（源五郎は内をのぞきながら又考えている時、奥よりお妙は行燈をとぼして出づ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）源五郎　おお、お妙さん……。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お妙は源五郎を見つけて、奥をみかえりながら縁を降りる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（源五郎と昭全は先に立ちてゆく。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）おいよ　源五郎がよび出しに来て、お妙さんは出て行ったらしい。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下のかたより源五郎とお妙、あとより昭全も出づ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）源五郎　今もいう通りのわけで、一昨日の晩、昭全さんに飛び付いたのは、確におまえの姉さんだと云うのだ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五郎　あんまり途方もないことで、おれにも本当とは思われないが……。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）源五郎　（おなじく惑うように。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五郎　お前ひとりが見たというのでは、まだ本当の証拠にはならないのだ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五郎　血の付いたような着物の袖を……。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五郎　まあ、まあ、静にしろ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五郎　まったく夢のようだが、今のおまえの話を聞くと、だんだんに疑念が募るばかりだ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妙　（源五郎と顔を見合せる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五郎　この小僧め。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五郎　こんな奴が方々へ行って触れ散らすので、おれが皆んなに戯われるのだ。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源五郎　（俄に上のかたを見る。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、和太郎さんのふところから、大きなふなと、げんごろう虫と、かめの子が出てきたからであります。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童は南国ほど崇敬され、ガヮッパ様などと敬称されるほどであるが、北国へ行くに従つて通力と値打を失ひ、仙台から越後あたりの線でガメ虫（げんごろう）にまで下落してゐるさうである。",
              "citation": {
                "source": "日本の山と文学",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
