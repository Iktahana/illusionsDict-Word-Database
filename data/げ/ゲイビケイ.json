        "examples": {
          "standard": [
            {
              "text": "猊鼻渓の舟下りは、四季折々の景色が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家族で岩手県の猊鼻渓へ旅行に行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "猊鼻渓の「運玉投げ」は縁起が良いとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "陸中の猊鼻渓は今は一の関から軌道が出来たのでわけなく行ける。",
              "citation": {
                "source": "あちこちの渓谷",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の郷里は、名題の猊鼻渓から又二十里ほど山奥、中央山脈のお盆の中で、三年に一度も浮世の人の来るところじゃない、あんな所に育つと、大概身軽にもなるよ、嘘だと思うなら、僕と一緒に来て見るがいい」「イヤ弁解は警官にしろ、逃げるな」　黒津は躍起となって、出口へ立ち塞がります。",
              "citation": {
                "source": "判官三郎の正体",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
