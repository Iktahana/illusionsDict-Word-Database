[
  {
    "uuid": "126cf28c-9185-5809-8cc6-860da0188deb",
    "entry": "原像",
    "reading": {
      "primary": "げんぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
