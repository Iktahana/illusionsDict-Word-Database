        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "文化祭のクラス出し物で、シェイクスピアの劇を演じることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は役になりきって、あたかも自分のことのように劇を演じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼い頃、妹と一緒に即興で劇を演じて、両親を喜ばせた思い出がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "戯曲の方面では、最近、相当目星い作品を生んでゐますが、舞台的には、まだ新劇を演じるために必要な才能と教養とを兼ね備へた俳優がゐません。",
              "citation": {
                "source": "演劇漫話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、わたくし共は常々露西亜語以外に、万国共通の言語によつて劇を演じることを心掛けてゐるからであります」と云つた。",
              "citation": {
                "source": "『桜の園』の思ひ出と印象",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと刑事とがお極りの活劇を演じるのだ。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
