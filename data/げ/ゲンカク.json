[
  {
    "uuid": "15ca7b47-dae4-562a-99c3-c6d24e9e8094",
    "entry": "厳格",
    "reading": {
      "primary": "げんかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
