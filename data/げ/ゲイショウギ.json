    "definitions": [
      {
        "index": 1,
        "gloss": "geisha and prostitutes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
