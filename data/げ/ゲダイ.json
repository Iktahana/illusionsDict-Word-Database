      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wholesale price",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "六、七、一尺角、二尺角等と拂下代價に區別なし。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "書籍は篤と取調べ、かつ刻本｜売下代金を以て費用を返納すべき積年賦をも取調べるようにということであった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも文明十一年十一月六日条に、五ヶ所唱門鳩垣内西坂等事、古市下代官徳丸去出申者也。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度古市自先日存開之処、下代官于今不相触之間、厳密仰付故也。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｂ）の qb 量の所有者（１）が――以下代数記号で呼ぶ――市場に現われ、そのうちのある量 ob を供給して、自分が需要する（Ａ）の da 量と交換するとすれば、方程式dava=obvbにより、彼は（Ａ）の da 量と（Ｂ）のを所持して帰っていくであろう。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて肝要は元祖以下代々の先祖を敬うべし〔祖先を敬するは、家風を保つ所以、家もまた国の如く歴史あり、祖先を敬するは、その家声を墜さざる所以〕。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "河内・和泉その他畿内の国々では、ダイというのは他の地方で組とか坪とか区とか言うのに該当するらしく、上代、下代、東代、西代などと対立するものが多く、文字は常に代の字である。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "城下代官と町奉行を兼ねている桐井角兵衛の役宅だ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ引越される、と聞きましたら、（引越すんじゃない、夜遁げだい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
