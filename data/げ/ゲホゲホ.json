        "examples": {
          "standard": [
            {
              "text": "「隣の部屋から、げほげほというひどい咳が聞こえてくるけど、風邪でも引いたのかしら。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "朝からげほげほと咳き込んでばかりで、まともに会話もできないほど喉の調子が悪い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "土埃の舞う工事現場の近くを通りかかったら、思わずげほげほと激しくむせてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "チミーは　げほげほ　うぐうぐ、　あばらが　いたみます。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            }
          ]
        }
