[
  {
    "uuid": "67b51a33-8c3f-54a1-a234-bd4e48e161ad",
    "entry": "原罪",
    "reading": {
      "primary": "げんざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
