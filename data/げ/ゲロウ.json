        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なりひらは高禄の御武家様が御忍びと言った形、半次はお供の下郎である。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆氣に取られて瞻るのを、優しい洋傘の影から、打傾いて流眄で、「お手紙の上書で覺えましたの……下郎は口のさがないもんですわね。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と身振をして、時々頬摺、はてさて氣障な下郎であつた。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に猫族のもつあのすばらしい原始の本然のすがたを抹殺し、しかも猫の妙に誇張された特徴をしつかり掴んではゐるが、これは明かに彼の觀念の下郎に過ぎない。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下郎の分ざいで、主人をにらむとは生意気千万。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに精出して、そこな下郎の周囲を捜せ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆の者、そこな下郎は殊勝であるぞ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下郎、思い知ったか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はははは、下郎は口のさがねえもんだ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると鯱に似て、彼が城の天守に金銀を鎧った諸侯なるに対して、これは赤合羽を絡った下郎が、蒼黒い魚身を、血に底光りしつつ、ずしずしと揺られていた。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "国王は、「私どもはこれからいついつまでも、天皇のおおせのままに、おうま飼の下郎となりまして、いっしょうけんめいにご奉公申しあげます。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小賢しき口返答する下郎かな。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは下司下郎じゃ」　という事をアトでよく云ったが、何の事やら誰の事やらむろんわからなかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下司下郎のお能は下司下郎だけで芝居小舎ででも演んなさい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "下郎のそちに、仔細は云えぬが、そちの命が助かるようになっているのだ。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて男ども上陸して各手当り次第に履を穿くと、女ども来って自分の符標ある履はいた男を引っ張り行く、醜婦が美男に配し女王が極悪の下郎に当るもかれこれ言わぬ定めだ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "心得がのうては狂言ができぬとなれば、役者は上は摂政関白から下は下司下郎のはしまで、一度はなって見なければ役者にはなれぬはずじゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "手数をかけさせる下郎共じゃな。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、それなる下郎、御前の御身寄りじゃと申さるるのでござりまするか！",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こ奴共も、六松とやらいうた怪しい下郎と同じ穴の貉やも知れぬ。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「血のめぐりがわるい下郎共よ喃。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この下郎めは、三十両の目腐れ金で、大切な主人の命を売った不埓者じゃ。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かげろうか何かゆれている。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の足なみがかげろうのようにちらちらちらちら光りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃紅色の花を群生させるが、少しはなれた所から見ると臙脂色の団塊の周囲に紫色の雰囲気のようなものが揺曳しかげろうているように見える。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原からはもうかげろうがゆらゆら立って向うの水などは何だか風のように見えた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの野はらや丘が、あんまり立派で明るくて、それにかげろうが、「さあ行こう、さあ行こう。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のしぶきのなかからは、あちらからもこちらからも、薄羽かげろうがアフロディットのように生まれて来て、溪の空をめがけて舞い上がってゆくのが見えた。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何万匹とも数の知れない、薄羽かげろうの屍体だったのだ。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの「かげろう」というものも、この茶わんの底の模様と同じようなものです。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
