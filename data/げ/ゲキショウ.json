[
  {
    "uuid": "eff2cdf7-2ff1-5330-99a0-29534a8e7e3c",
    "entry": "激賞",
    "reading": {
      "primary": "げきしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
