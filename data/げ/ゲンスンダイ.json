        "examples": {
          "standard": [
            {
              "text": "恐竜の骨格標本が原寸大で展示されており、子供たちが興奮していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ウェブサイトで靴のサイズを選ぶ際、原寸大表示の機能があると便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このポスターは、新製品の写真を原寸大で掲載している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "摸写の方法は、入江氏の揚げ写し法を除いては、皆原寸大の写真の上に直接色をつけるのである。",
              "citation": {
                "source": "壁画摸写",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "原寸大の模型のように僕は感じた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
