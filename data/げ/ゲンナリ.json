    "definitions": [
      {
        "index": 1,
        "gloss": "to be weary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "薄青い電燈の光が掻巻にくるまつた彼女の姿をげんなりと照してゐた。",
              "citation": {
                "source": "あかんぼの首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いつまで続く、ともうげんなりして、思慮が、ドドドと地の底へ滅入り込む、と今度は、戸棚の蔽が纏って、白い顔にはならない替りに、窓の外か、それとも内か、扉の方角ではなしに、何だか一つ、変な物音……沈んだ跫音。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地は幾十通とある郵便物を見たばかりでいいかげんげんなりした様子だったが、だんだんと興味を催して来たらしく、日の順に一つの束からほどき始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの興味もない、針の先ほどの刺激もない一日々々の中に、その身が浸つて居ることを思ふと、体も精神もげんなりしてしまつて、何も彼もすつかり倦れきつてしまふ。",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真ん中どころを射あてられ、さすがの早引忠三も、げんなりとして苦笑したが、反動的に猛くなり、えぐってえぐってえぐってやれ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッキリし過ぎていらあ」げんなりとして笑ったが、ヒョイとお町の胸を見た。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や不整方程式には、頭も乱次になり、無理方程式を無理に強付けられては、げんなりして、便所へ立ってホッと一息｜吐く。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを夫人がタオルで清潔に拭くと、女中が着物を被せるといふ手順で子供達をそつくり湯を済ます時分には、親はげんなりと草臥てしまふといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故と言つて、長い道程を歩き草臥れて、誰も彼も草の葉のやうにげんなりした顔をしてゐたのが、今通りかかつてるのは遊女町だなと気が注くと、急に蘇生つたやうに生々して来たからである。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ロツクフエラアの積りでは、疲労を護謨輪にもぢつた言葉の洒落らしいが、実際食後のお喋りは、どうかすると聴衆をげんなりさせて、お腹の消化まで悪くさせるものだ。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般の読者の中には、現実生活の重苦しさにげんなりした心持をプロレタリア文学の闊達と称せられない有様に結びつけ、その評言を当っているように思い、つづいて昨今青野季吉氏によっていわれている闊達自在論をそれなりによしと感じるひとがあるかも知れない。",
              "citation": {
                "source": "プロ文学の中間報告",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊であったかと感じる程、身じろぎもせず、げんなりした風もなく突立っている。",
              "citation": {
                "source": "粗末な花束",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに泥鰌も味噌汁に限ることを言っておこう、駒形の名物泥鰌に浮れ込み、いやに江戸がって骨抜きせぬのをとりよせ、丸煮の鍋に白い腹を出してるのを見て、俄にげんなりしてしまい、嫌々むしって喰べる連中、近来は大分多くなったと、内々嗤ってる手あいがある。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふ昼と夜とが続いて、百歳も草木の萎えたやうに、げんなり気を腐らせて居た。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母親はげんなりした様子をして学校からかえって来る千世子のかおを見ちゃあたって居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をきいた大伯母がげんなりした様に、　それなら、その小説屋さんとか云うものもいけず、ねえ。",
              "citation": {
                "source": "千世子（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よく人が云いますね、菓子屋へ奉公すると、いくら甘いものの好な男でも、菓子が厭になるって、御彼岸に御萩などを拵えているところを宅で見ていても分るじゃありませんか、拵えるものは、ただ御萩を御重に詰めるだけで、もうげんなりした顔をしているくらいだから。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "安達君が私を叱りて軽挙を戒めるのでたいへん御きげんなり。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときばかりはさすがの机博士も、よっぽど肝をひやしたと見えて、青菜に塩のようにげんなりしていたが、それでも、いうことだけはいい。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩のかるくなった、のうのうとした心持と同時にげんなりした寂しい心持がして来た。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "とさもげんなりした様に云った。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれやれ、これでまあ、こっちも助かった、船頭親子も怪我がない限り、おっつけ舟も廻って来るだろう、と旅人どもは、市が栄えたような心持で、げんなりしたが、白雲ひとりだけの興味は、決してそれで尽きたのではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "解散したとすれば、あの一味はドコへ行ったものでしょうか」「多分、大江山でしょうと思いますが」　またしても大時代――胆吹山でなければ大江山、兵馬はこれにも、げんなりせざるを得ません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "無学な連中も、見あきるほど見たし――もうげんなりだよ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、東京へ出てからは、暗黒街にうごめく多くの若い女達、失業者街にうろつく多くの浮浪者達の、絶望的な生活も、げんなりするほど見て来た。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年のような飢饉が来るというのも、いよいよ世が末になった証拠だ」「だからさ、どうせ干死ぬなら、せめて一度でも、米のめしをげんなりするほど喰って見てえと思ってるだ」「一度でも喰えりゃまだいいだ。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、いくぶんげんなりして、そいつをにんじんの髪の毛へなすりつける。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は、さつきから続けざまに読み役をやらされ、みんなの血走つた眼つきや、黄色くよどんだ会場の空気にげんなりしたので、子供部屋に引つこんで、火鉢に当りながら本を見てゐる。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "八五郎は、昨夜からのごちそう攻めで、さすがにげんなりしてしまったものか、しきりに尻をモジモジさしておりますが、肝腎の平次は悠然と坐り込んで、テコでも動きそうはありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄酒のように――」「啜ろうと、仰ごうと、一般に酒は苦手でね」　内海が、もう酒の席にはいくぶんげんなりしたように云った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
