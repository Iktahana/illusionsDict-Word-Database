    "definitions": [
      {
        "index": 1,
        "gloss": "refusing to see a visitor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「点をもらいに」来る生徒には断然玄関払いを食わせる先生もあったが、夏目先生は平気で快く会ってくれた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、きざに大先生気取りして神妙そうな文学概論なども言いたくないし、一つ一つ言葉を選んで法螺で無い事ばかり言おうとすると、いやに疲れてしまうし、そうかと言って玄関払いは絶対に出来ないたちだし、結局、君たちをそそのかして酒を飲みに飛び出すという事になってしまうのである。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑固な人だからね、玄関払いを食うかも知れんぞ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関払いなどされないように。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ていのいい玄関払いだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふつうの玄関払いとは性質が、ちがうようだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎藤氏のお家へはじめてお伺いして、ていのいい玄関払いを食って帰った時にも、之に似た気持を味わった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「のこのこ出掛けて行って、玄関払いでも食わされて大きい騒ぎになったら、それこそ藪蛇ですからね。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房や子供などを連れていって、玄関払いを食らわされたら、目もあてられないからな。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞記事などに拠って見ると、夏目さんは自分の気に食わぬ人には玄関払いをしたりまた会っても用件がすめば「もう用がすんだから帰り給え」ぐらいにいうような人らしく出ているが、私は決してそうは思わない。",
              "citation": {
                "source": "温情の裕かな夏目さん",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外は人に会うのが嫌いで能く玄関払いを喰わしたという噂がある。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、杉浦からかねがねきいているので、玄関払いとか居留守などを使われる心配がないと思いましたから、非常に安易な心持で出かけたのです。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトは要らぬと玄関払いじゃ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関に書生さんが二人、今朝早くから頑張っていて、専務取締とかいう頭の禿た紳士のほかは、みんな玄関払いにしているから、病室の中は静かなもんよ。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら畸形だといって同情と友情を哀願する者を玄関払いすることがあるだろうか。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は千駄木へはじめて御伺いした時は玄関払いを覚悟していたのです。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "清盛も、何とか、法皇の気持をとりなそうと参内したけれど、風邪気だからと体のいい玄関払いを喰う始末で、この一件だけは、徹頭徹尾、法皇の無理が通ってしまった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "美濃の土岐といえば、日本中に聞えた武家であるのに、実隆は取次の人がないというので、これに玄関払いを食わした。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼な女だ、厚かましい奴だと最初は玄関払いで面会を拒絶した私が、いつの間にか根負けして渋々ながらでも会ったり、話したりするようになってしまいました。",
              "citation": {
                "source": "機密の魅惑",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ森川さんの家へ談判に出掛けようと思ったが、間宮の野郎が玄関払いを喰わせるに定っていると気が付いた。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点では、いきなり玄関払いを食うべき無作法だが、不思議と宿では、「それ、おいでなすった」　この無作法千万なる来客を、待っていたとばかり、帳場も、男衆も駈出しという体で、下へも置かず、手をとって、早くも座へ招じ上げようとする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関払い　七月にはいって、急に暑い日が続いている。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はそれまでに、三度訪ねて三度、玄関払いを食っている。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、親切に引見してくれたのは、森鴎外、与謝野鉄幹、尾崎咢堂など三、四人にすぎず、ことに小説家の連中は、ほとんどが玄関払いを食わせたと、啄木は憤慨して語っていた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四度も行ったのに、四度とも玄関払いを食わされた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "友田の方も、いるときには、居留守を使ったり、玄関払いを食わせたりすることはなかった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は玄関払いを食わされなかった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年ばかり玄関払いを食い続けた。",
              "citation": {
                "source": "変人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関払いを食わせやがった」「変だね」「もう行かない」「何かの間違だよ」「いや、三度目には打ち合せて置こうと思って電話をかけたが、御主人は一切電話口へお出になりませんという口上で要領を得ない。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに私は先頃三男の入学試験前に某中学校長を訪れたら、「入学志望のことならば、昨今｜然うした意味の来訪者が多くて困りますから、御面会はお断り申上げます」　と美事玄関払いを食わされた。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
