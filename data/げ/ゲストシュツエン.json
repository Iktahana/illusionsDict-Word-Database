        "examples": {
          "standard": [
            {
              "text": "その人気歌手が、サプライズでテレビ番組にゲスト出演した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は友人のコンサートにゲスト出演することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゲスト出演のおかげで、番組の視聴率が大幅に上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ＴＶシリーズへのゲスト出演があり、撮影はホノルルでおこなわれるから、あなたの都合さえつくなら会うことが出来る、という連絡だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "知り合ったきっかけがすぐには思い浮かばないような、ずいぶん以前から知っているような錯覚があるのです」　そう答えた日比谷は、高村恵子がラジオ局のアナウンサーをしていた頃、彼女の番組にゲスト出演して知り合ったことを、後藤とその妻に説明した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『グランド・オール・オプリイ』のステージに立っても、ヴェテランのハンク・スノウやアーネスト・タブでも、おもてむきは一夜が七〇ドルくらいにしかならず、一曲だけのゲスト出演なら、悪くすれば無料にされる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
