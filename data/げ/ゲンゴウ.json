        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日本の元号は、天皇の即位に合わせて改められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "平成から令和への元号の変更は、大きなニュースとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "書類の記入には、西暦だけでなく元号も併記することが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "年号や元号を書き忘れても、丙午三月とか丁寅七月というように干支の方は書き忘れない。",
              "citation": {
                "source": "ヒノエウマの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
