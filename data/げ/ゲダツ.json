    "definitions": [
      {
        "index": 1,
        "gloss": "liberation from earthly desires and the woes of man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこに生死を解脱して永世に存在を完うしようとする人間根本の欲望さえ遂げ得られるのではないか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この解脱は何によって生じたのであろうか。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」に左袒する者は 〔amour-gou^t〕の淡い空気のうちで蕨を摘んで生きる解脱に達していなければならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その飽くまでも靈の世界の永遠を信ずるの強きに於て、また絶え間なき祈祷と瞑想によつて精神生活を充實せしめ、怠りなき勞働によつて肉體を鞭打ちつつ妄執と欲望と邪念から解脱せんとする努力に於て、私は尊ぶべきものあるを思ふことが出來る。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの飛躍もない、なんの解脱もない。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爾の時に疾翔大力、爾迦夷に告げて曰く、諦に聴け、諦に聴け、善く之を思念せよ、我今｜汝に、梟鵄諸の悪禽、離苦解脱の道を述べん、と。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我今｜汝に、梟鵄諸の悪禽、離苦解脱の道を述べんと。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我今｜汝に、梟鵄諸の悪禽、離苦解脱の道を述べんといふことは。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我今｜汝に梟鵄｜諸の悪禽離苦解脱の道を述べんと。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爾の時に疾翔大力、爾迦夷に告げて曰く、諦に聴け、諦に聴け、善くこれを思念せよ、我今｜汝に、梟鵄諸の悪禽、離苦解脱の道を述べん、と。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我今｜汝に、梟鵄諸の悪禽、離苦解脱の道を述べんということは。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我今｜汝に梟鵄諸の悪禽離苦解脱の道を述べんと。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩次郎が、いよいよ肉体的な恐怖に襲われ、専門の僧になって、その解脱を図ろうとしたのは十五歳の時だった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、この若き修道僧は、宗教的解脱の慾望を諦め、消極的ではあるが趣味に生きようと気持を転換さした。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この僧は唐時代の名僧で、解脱の道に就いては信ずるに足る師父として、日本でも昔から禅の宗門の間で、誰一人、尊敬しないものはなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は今まで解脱ということを、自分の身の上の慾望とのみ考えて来たが、今は死んだ果敢い女の魂の為にもその事が必要のように思われて来た。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が解脱することはこの絆を断ち切って彼女を夢より醒すことでもある。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にはただ座禅して無心になっているその生活中に解脱や安楽があるのだと説くものもあった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "掌に載せた真桑瓜のその色を見、その重さを感ずるようにわが五感の感覚や意識で明白に解脱の正体を見きわめなければ安心出来なかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "解脱の正体はすべて象徴的な言葉をもって述べられてはいるに違いないが、しかし体験としては歴々として掴んでいるもののあることはどの人の上にもほぼ推測が出来た。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して解脱はあるものである。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてただ裸一箇の自分となり独力、座禅思惟の一法によってかの解脱を掴むか掴まえぬか、面と向った真剣の勝負に驀地に突き進むこととなった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと反して夫婦愛はなかなか複雑なものではあるが、いずれか自我を捨てて無我となり、両者一身のごとく融け合って、遂には、性的愛着から解脱するものさえあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い光までなんとなく重たげだつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると此方で、太陽の下では睡げだつた連中が、ウアハハハツと云つて欣ぶ。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに對して劣等組・不良組の一派に屬する子供等は、人品が野卑で、ざつくばらんで、率直ではあるが賤しげだつた。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の姉の學校は下の姉の學校よりも小さいまちにあつたので、お土産も下の姉のそれに較べていつも貧しげだつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在妹のおときさんの身にすれば、あんな死方をした兄をどんなに悲しんでおあげだつたかと、すぐにも手紙を書きたかつたけれど、つひのび／＼に今日になつてしまつたのです。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の日、裏の井戸に近所の人々が通つて來るのを見る駒平は樂しげだつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の調子は物憂げだつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
