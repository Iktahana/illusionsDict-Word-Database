        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヒア・ゼイ・カム・アゲイン、ザ・モンキーズ、〈ラスト・トレイン・トゥ・クラークスヴィル〉」　三三四号室の池田知子さんというのは、あの知子のことだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は下船してホースリーダウンのゲインスフォード・ストリート、ニュー・レイン、８番地に住むことにした。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミルトンは当時ロンドンの疫を避けてここに幽栖し、その間に傑作『パラダイス・ロスト』を完成し、さらに『パラダイス・リゲインド』を起草せりという。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の背後で轟々と音を立てる川は、私にカリゲイン渓流を思わせた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこんな際限もない段々をポッコリポッコリ下りるよりも、カリゲインを十二度下りた方がいい。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "今できることは紙を踏んづけて隠し、ゲインズバラの絵に心を奪われている振りをすること。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
