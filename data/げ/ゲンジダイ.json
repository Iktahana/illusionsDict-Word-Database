          "standard": [
            {
              "text": "現時代は、情報化とグローバル化が急速に進んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現時代に求められる教育のあり方について議論が交わされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、現時代を代表する思想家の一人として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "現時代を指して「紙の時代」と稱する學者もあるが、強ち不當なる Beiname であるまい。",
              "citation": {
                "source": "紙の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのことについてブランカは現時代人として最も貴重な教育を受けつつあると感じて居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
