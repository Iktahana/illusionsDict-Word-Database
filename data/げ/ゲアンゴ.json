          "literary": [
            {
              "text": "夏の初めから夏安居に入って、破れ寺の瑞雲寺でも型ばかりの結制を行っていた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その習慣が伝わって、後世の夏安居になったという。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "叢林に夏安居して修業したる年数をいう、と末尾に註釈がある。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『正法眼蔵』の第二はこの年の夏安居に「衆に示した」ものと記されている。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
