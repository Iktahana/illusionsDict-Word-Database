        "examples": {
          "standard": [
            {
              "text": "高等裁判所は、一審の原裁判を支持し、被告の控訴を棄却した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "原裁判における事実認定には重大な誤りがあるとして、上告が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "差し戻し審では、改めて原裁判の内容が詳しく検証されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "之より先、常藏は第一審で有罪と決し、二審三審を經て矢張り原裁判通りに判決され遂に一年餘の刑に問はるゝ事となつて昨年の今頃既決監に移されたのであつた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
