    "definitions": [
      {
        "index": 1,
        "gloss": "this world",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "望んだ死は与えられず、そのかわり現世の厳粛な苦しみを与えられた。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、多くの思想家たちが、信仰や宗教を説いても、その一歩手前の現世のヴァニティに莫迦正直に触れていないことを不思議がっているだけである。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現世の故郷はうつり変っても画の中に写る二十年の昔はさながらに美しい。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ未來の可能性を考へない間が現世の極樂である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室にいた間は母にたのんで現世の出来事に関する詳細なノートをとって、それを届けてもらって読んでいたという話も伝えられている。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで現世界における動物の脳の目方は体量の二十分の一以下万分の一の間にあるものと思えばよい。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは妹の足の早いのを、慾望的な、現世的な努力を表現してゐるやうに感じて、妹を警醒するやうな口吻で、「兄は可哀さうな男だつたな」と云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "現世とはただわずかな糸でつながって、飄々として風に吹かれているような趣があったかもしれない。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一目見て、幼い織次はこの現世にない姿を見ながら、驚きもせず、しかし、とぼんとして小さく立った。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "数※社参する中に、修験者らから神怪｜幻詭の偉い談などを聞かされて、身に浸みたのであろう、長ずるに及んで何不自由なき大名の身でありながら、葷腥を遠ざけて滋味を食わず、身を持する謹厳で、超人間の境界を得たい望に現世の欲楽を取ることを敢てしなかった。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この悪臭によって自分はこの現世から突きはなされてただ一人未知の不安な世界に追いやられるような心細さを感ずるのであった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらそんな不都合なことはいけないと言っても、どうしてもだれか征伐に行くのが現世の事実である。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方では捨てようとして捨て切れない現世への未練の糸の端をこれらの遺物につなぎ留めるような心持ちもあるかもしれない。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "犀などがだんだんに人間に狩り尽くされて絶滅しかけているという事実はたしかに彼らが現世界に生存するに不利益な条件を備えているためであろう。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、現在映画の世界にのみ存する事象が将来現世界に可能とならないという証拠もないとすると、現在の映画の夢は将来の現実の実相を導き出す先駆となり前兆とならないとも限らない。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理想主義者は、悲しい哉、現世に於いてその言動、やや不審、滑稽の感をさえ隣人たちに与えている場合が、多いようである。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは絶対的善美なものの得られない現世であらゆるものの価値判断に関係して当てはまる普遍的方則ではあるまいか。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亮のような柔らかい心臓と彼のような透明な脳とを同時にもって生まれるという事は、現世にあっては不幸な事かもしれない。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと言葉を変えて言えば、すべての事がらは、現世で確率の大きいと思われるほうから確率の僅少なほうへと進行するから不思議でないわけにはゆかないのである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと反対に、現世で予測のできない事がらが逆転映画の世界では確定的になるから妙である。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、仏教の最終の目的は人々が最上の智慧を開覚いて最も完全な人格を完成するのに在るので、現世上の救難授福はその目的からは第二義的のものでありますが、しかし眼前の幸福は衆人が望むことでありますから、仏、菩薩においてもこれを蔑ろにしないで工夫に工夫を凝らされていることはもちろんのことであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教が、私たちの日常の生活を視るのに、通り一ぺんの表面の現実とか、あるいは現世の支離滅裂な乱脈の方面ばかりを現実だとするような、そんな安っぽい見方をしないのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ最も高遠なる理想を最も現世的のものに見出す大師一流の仏教哲学の帰結の方法であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現世の執着の一つであるあなたの愛によって、わたくしを妨げず、そして因より備わって居るその世界の月の光を曇らせまいと心がける処に、はっきりとその道は開かれるのです。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは今朝あなたのお言葉を聞いて、現世の愛の果敢ない事も本当の愛の世界の不壊な事ものみ込めました。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は愛という一つの神秘に融け合うのに、あまりに現世のままの我が肉体や心が邪魔になるので御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現世の肉体や心が、兎もすれば現実の「自我」というメスを二人の間に差し入れて、冷たく元へ引戻し勝なので御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現世の愛の苦労を厭う狡猾な男女は、二人が恋の神秘に辿り着いた時、其処まで運んで呉れた此世の舟を乗り捨てるので御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あな悦ばしや地獄の責苦によりて、現世の罪を償う事よ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あな悦ばしや現世の咎を地獄の責苦によってうち訂さるることよ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
