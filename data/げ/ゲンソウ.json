[
  {
    "uuid": "d833c4df-4649-50cb-a7f3-c524284793ab",
    "entry": "幻想",
    "reading": {
      "primary": "げんそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
