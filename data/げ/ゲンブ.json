    "definitions": [
      {
        "index": 1,
        "gloss": "Black Tortoise (god said to rule over the northern heavens)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なるほど玄武岩の天然の六方柱をつかったものである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　東京――（壱）――芸学校の教授にして、（弐）――術院の委員、審査員、として、玄武青竜はいざ知らず、斯界の虎！",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら此の森の伏屋、小川の芦、海は申すまでも候はず、岩端、松蔭、朝顔、夕顔、蛍、六代御前の塚は凄く涼しく、玄武寺の竜胆は幽に涼しく、南瓜の露はをかしげに涼しく、魚屋の盤台の鱸は……実は余りお安値からず涼しく、ものにつけ涼しからぬはこれなく候。",
              "citation": {
                "source": "逗子より",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜山の背後に、薄黒い雲は流れたが、玄武寺の峰は浅葱色に晴れ渡って、石を伐り出した岩の膚が、中空に蒼白く、底に光を帯びて、月を宿していそうに見えた。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早や、これでは、玄武寺を倒に投げうっても、峰は水底に支えまい。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄武寺の頂なる砥のごとき巌の面へ、月影が颯とさした。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊五郎の原田重吉が玄武門破り、不評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先頭に進んで行き、敵の守備兵が固めている、玄武門に近づいて行った。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の受けた命令は、その玄武門に火薬を装置し、爆発の点火をすることだった。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎廻りの舞台の上で、彼は玄武門の勇士を演じ、自分で原田重吉に扮装した。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその芝居は、重吉の経験した戦争ではなく、その頃｜錦絵に描いて売り出していた「原田重吉玄武門破りの図」をそっくり演じた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金鵄勲章功七級、玄武門の勇士ともあろう者が、壮士役者に身をもち崩して、この有様は何事だろう。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度昔、彼が玄武門で戦争したり、夢の中で賭博をしたりした、憐れな、見すぼらしい日傭人の支那傭兵と同じように、そっくりの様子をして。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ぢきその飛石を渡つた小流から、お前さん、苫船、屋根船に炬燵を入れて、美しいのと差向ひで、湯豆府で飮みながら、唄で漕いで、あの川裾から、玄武洞、對居山まで、雪見と云ふ洒落さへあります、と言ふ。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱蒼たる熱帶樹に蔽はれ苔に埋もれてはゐるが、素晴らしく大きな玄武岩の構築物だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱蒼たる熱帯樹に蔽われ苔に埋もれてはいるが、素晴らしく大きな玄武岩の構築物だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄武岩の柱がごつごつした岩肌に並ぶ様は、石化した怪物か何かの肋骨のようだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいわく都城必ず四神を祀り以て四方を鎮す、子はすなわち北方玄武神、世俗これを子聖あるいは鼠のほこらというと、これは拠って按ずるに、太田道灌江戸造立の時祀りし社なる事疑いなし、その方角すなわち北に当れり云々。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の西南の隅に、大きな玄武岩の洞窟があつた。",
              "citation": {
                "source": "伊良湖岬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄武洞の驛まで行くと、城崎も近かつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は玄武洞や温泉寺を省いて瀬戸、日和山の方面を探ることにした。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄武湖に行くと、ここには柳が沢山ある。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩質はと問へば、玄武岩なりといふ。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "海抜高一、六○○米、気温は最高二五度、最低六度のところで、玄武岩質の赤土地帯で、茶の生育には、気候条件の不利を償つてあまりある由なのだと、富岡が説明してくれた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、☆げんぶきも芽を出しましたよ。",
              "citation": {
                "source": "さまざまな生い立ち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "☆げんぶき――ゆり科のぎぼうしの仲間か？",
              "citation": {
                "source": "さまざまな生い立ち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
