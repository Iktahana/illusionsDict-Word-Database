    "definitions": [
      {
        "index": 1,
        "gloss": "(sense of) reality",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こういう現実味からいうと演劇フィルムは多くははなはだ空疎なものである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画ではそのほかにも犬が非常に活躍していて、この映画の現実味を助けている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実味と真実味とを区分したり、人生味と自然味と優劣を争うたりする境地を脱していない。",
              "citation": {
                "source": "最近の感想",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも昔の小説だと風采と心が一致している場合が大変に多いのであるが、それはお伽話か神話以来の遺習で、現実味の強い今の小説ではそう手軽く行かないから困る。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくともアメリカがベトナムから手を引く奇跡よりは、東大解体は現実味を帯びて見えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに彼の作品に、一味の現実味とまた芸術性とを与えている理由がある。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ皇帝がルパンに面会に来たり、ルパンが一人で同時に三人に変装していたりするのは、痛快には痛快だが、それ以上に現実味を損するという欠点がともなう。",
              "citation": {
                "source": "私の要求する探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが少くとも、わが国の現下の事情に於て、オルガニザチヨンやアギタチヨンやプロパガンダ等の特に政治的な言論活動形態と平行して、特に必要で又特に現実味のあるものが、活動活動だろうということは、常識的にも承認出来ることではないかと考える。",
              "citation": {
                "source": "啓蒙の現代的意味と役割とについて",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂現実味が欠けてゐるとでも申すのでせう。",
              "citation": {
                "source": "Ｓ先生に",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがしだいにたくさんのメモリーがマシンに組み込まれるようになり、いざフロッピーディスクを使おうといったところまで来ると、パーソナルコンピューターでもＯＳの利用が現実味を帯びてきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『日本の目ざめ』はその扱う事がらの性質上、現実味の薄らぐおそれが無いでもない。",
              "citation": {
                "source": "茶の本",
                "author": "はしがき",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を書こうとしたのか分らない、焦点がはっきりしない、抽象的すぎる、現実味が乏しい、などなどの評言である。",
              "citation": {
                "source": "私の信条",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "生々しい現実味を帯びて、甦えって来たのだ。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勅　たゞ一道にいたゞきはせで勅にそむく　そむかず　正し見て、罪の有無　うたがひはらせ後の歌、現実味は十分調子に出てゐる。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして、次第に、自然に現実味と描写態度とを加へて来たが、近松になつて徐々に、さうして姑らくしてから急激に変化し、飛躍して、其後の浄瑠璃は唱導的意義を一切失ふ様になつて了うた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では殊にさうです、調和と統一ある舞台の現実味、これは、未だ嘗て何人も完全に表現し得なかつたのであります。",
              "citation": {
                "source": "演劇一般講話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は色魔ですと臆面もなく言ひきることの厭味や卑屈さに堪へきれぬ私は、結局それにこだはることも多いわけで、彼女等にそれを言はれた瞬間の苦痛や怒りが、想像の中に於てもやや生々しい現実味を覚えさせられるほどであります。",
              "citation": {
                "source": "女占師の前にて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふの山のもみぢよりもずつと赤く、もつと現実味の赤である、それをみんながこちらに向けてゐる、いきにも帰りにもにんじんを買つてくれないなんて、ぼんやりなお客だね。",
              "citation": {
                "source": "東北の家",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙旅行は、目下、世界的なブームであるが、現実味が少しでもある話は、皆ロケット、あるいは類似のものである。",
              "citation": {
                "source": "あすへの話題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここからは小石川牛込一帯の低地を眺めて、なかなかの景色ですが、そんなものはもとより眼にも入らず、巨盗蝙蝠冠兵衛の亡霊だけが、三人の胸の中に、次第に現実味を帯びて生長して行くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもちゃみたいな作りにしては変な現実味がある。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが少なくとも、わが国の現下の事情に於て、オルガニザチヨンやアギタチヨンやプロパガンダ等の特に政治的な言論活動形態と平行して、特に必要で又特に現実味のあるものが、啓蒙活動だろうということは、常識的にも承認出来ることではないかと考える。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々の現に知っているものに似かよった処があればある程その凄みに現実味がある。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲劇に於けるこの歴史的必然性の内に、その現実味、切実さ、或いは又深刻さと呼ばれるものが横たわる。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が他方に於て、一種の評論家や一種の社会人に云わせると、そうした常識超越論ほど非常識なものはなく、常識のない処には何等の現実味もないのだ、というのである。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌というほど予備知識を持ち回りすぎた連中さえ多分この時初めて判ったのだから、そうした予備知識を信用しなかったり全く知らなかったりした連中が、事件の発生した日の内に、この事件の現実味を呑み込むことが出来なかったというような場合も、きっと少なくはなかったろうと思う。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独防共協定は勿論、ここでも充分に現実味を有っているだろう。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこの種の犯罪が、一般の世間人から見て、紛れもなく実証的な現実味を有っていると見えるからなのだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう個処に於て科学的精神が問題になり得るのも、実はそれが社会科学・哲学・乃至文化理論と直接に連関するものとして、或いはそういう資格を取ることによって、初めて可能なことなのであるから、科学的精神は、正に社会的関心と結びついて初めて、重大な現実味のある問題となるのである。",
              "citation": {
                "source": "再び科学的精神について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもなお、これらの見知らぬ風土は夢の中で驚くほど多彩かつ明確に現れ、目覚めた世界などこれに比べると色あせて現実味がないくらいだ。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
