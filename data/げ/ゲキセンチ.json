    "definitions": [
      {
        "index": 1,
        "gloss": "site of a bloody battle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
