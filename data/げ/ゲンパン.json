[
  {
    "uuid": "d947f462-c7fd-5f0a-969d-f4f4b4a4d10e",
    "entry": "原板",
    "reading": {
      "primary": "げんぱん",
      "alternatives": [
        "げんばん"
      ],
      "is_heteronym": false
    },
    "grammar": {
