[
  {
    "uuid": "8b5ea6c9-0dcc-5065-b9c6-eb0ae8845537",
    "entry": "下巻",
    "reading": {
      "primary": "げかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "second volume (in a two-volume set)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新撰映画脚本集、下巻。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔なじみの部員に古い○○館出版の西鶴全集の下巻を出して貰って。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も此三十五版と云うのは上巻で、中巻や下巻はもっと版数が少い。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの『夢殿』は主たる覊旅歌を上巻とし、副たる人事生活篇を下巻とした。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "編纂方法に就ては、上巻の覊旅歌は略倒叙の形態をとり、下巻に於てはその内容について分類し、その篇毎に年月の順を概ね正しくした。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "降って『因果物語』下巻五章に、僧が蛇となって銭を守る事二条あり。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから下巻になると、矢張り多少はそれ等の人々の影響もあるが、一番多く真似たのはガンチャロフの文章であった。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の下巻または巻を取るは苦しからず。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "藝備偉人伝は、蘭軒を載せた下巻がわたくしの手許に無いが、同じ著者の「頼山陽」に引いた文を見れば、亦復編年では無ささうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂本｜箕山さんが其藝備偉人伝の下巻に引いてゐる「尾道贈伊沢澹父」の詩題は其一である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此書の下巻は未刊行のものださうで、頃日箕山さんは蘭軒の伝を稿本中より抄出してわたくしに寄示してくれたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "下巻　まだ月が出ない。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、「ニーベルンゲン譚詩」は下巻へと移るのである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上巻は出たが、下巻は出ぬ。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "下巻が出るまで待つ訳に行かぬから又、読んでは書いたが、下巻へかかって暫くすると勇気を恢復して、とうとう二百枚にちぢめたが、この本はもう何処にもあるまい。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "下巻の方に初期の作が収められて居るのであるから、歴史的に云へば註釈も下巻から初めねばならぬものかも知れぬが、故人の意を尊重して私はやはり初めに編まれたものを前にする。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下巻も扉に「五月中旬鏤刻也」の句あるを除いては、全く上巻と異同なし。",
              "citation": {
                "source": "奉教人の死",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "両巻とも紙数は約六十頁にして、載する所の黄金伝説は、上巻八章、下巻十章を数ふ。",
              "citation": {
                "source": "奉教人の死",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上採録したる「奉教人の死」は、該「れげんだ・おうれあ」下巻第二章に依るものにして、恐らくは当時長崎の一西教寺院に起りし、事実の忠実なる記録ならんか。",
              "citation": {
                "source": "奉教人の死",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその下巻を直に写して松山の霽月氏に与えて、さきに上巻を見せてもらった報酬をした事である。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "上巻終下巻第九回　かくて黄金丸は、ひたすら帰途を急ぎしが、路程も近くはあらず、かつは途中にて狼藉せし、猿を追駆けなどせしほどに。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "記の綏靖以降開化までの叙述と、下巻の末のとは、おなじく簡単でありながら、取り扱ひが違うてゐる。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "糧米をカリテと訓むは、霊異記下巻に糧（可里弖）とあるによっても明かで、乾飯直の義（攷證）だと云われている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "下巻五月二十七日（木曜）　マリアの日記、千五百頁以上アリ。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道標」下巻、第一章一、二まで。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十七日（火）　午後一時　放送委員会、エスカルゴ　仕事をはじめた、「道標」下巻　三。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "手許に下巻しかないが、一八一七年ゲルツェンが五歳だったとき、ロンドンのロンドン、シティ、タ※ーンで行った宗教的偏見打破の公開集会からのち（1830 年）オーエンは（事実上無産階級の運動者となったのである）と本位田祥男の解説にかかれている。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今さらに何かなげかん打ちなびき心はきみによりにしものを　これは万葉にある歌だがいい歌だと思う。",
              "citation": {
                "source": "愛の問題（夫婦愛）",
                "author": "――生命の法に随う――",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れ路を何かなげかん越えてゆく　　関もむかしの跡と思えば　この、関も昔の跡というのは、先祖平貞盛、俵藤太秀郷が将門追討のために東国へ下ったことを思い出して詠んだものである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
