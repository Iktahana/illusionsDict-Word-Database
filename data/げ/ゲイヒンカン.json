    "definitions": [
      {
        "index": 1,
        "gloss": "reception hall (esp. for visiting state dignitaries)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "外交官は迎賓館で重要な会議を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "迎賓館の美しい庭園は一般公開されることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "迎賓館での昼食会は、和やかな雰囲気で進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "軍需大臣の官邸にするとか、迎賓館にするとか、趣向を凝して供出を迫ってきているが、いまのところ頑張り通していると。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中ベルギー大使館の手前で外人に英語で道を尋ねられ、不器用なジェスチャーで迎賓館の方向を示した。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "迎賓館に通じる大通りを渡り、四谷見附橋を渡り、最後に赤信号を無視してホテルニューオータニに抜ける小さな横断歩道を小走りに渡ると、北門から上智大学に入った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿通りを麹町方向に進み、迎賓館前を通って首都高速に乗る。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "State Guest House (esp. Akasaka palace, also guest house in Kyoto)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "迎賓館赤坂離宮は、日本の歴史的建造物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "京都迎賓館は、日本の伝統美を伝える貴重な施設だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "迎賓館の内部見学は、事前に予約が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
