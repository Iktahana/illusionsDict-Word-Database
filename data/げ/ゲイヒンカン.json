    "definitions": [
      {
        "index": 1,
        "gloss": "reception hall (esp. for visiting state dignitaries)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軍需大臣の官邸にするとか、迎賓館にするとか、趣向を凝して供出を迫ってきているが、いまのところ頑張り通していると。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中ベルギー大使館の手前で外人に英語で道を尋ねられ、不器用なジェスチャーで迎賓館の方向を示した。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "迎賓館に通じる大通りを渡り、四谷見附橋を渡り、最後に赤信号を無視してホテルニューオータニに抜ける小さな横断歩道を小走りに渡ると、北門から上智大学に入った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿通りを麹町方向に進み、迎賓館前を通って首都高速に乗る。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
