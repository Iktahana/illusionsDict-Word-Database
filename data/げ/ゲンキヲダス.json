          "literary": [
            {
              "text": "元気を出すんだ」「一人と一人じゃ駄目だ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう二三日経てば屹度元気を出すよ。",
              "citation": {
                "source": "父を売る子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を出てから、ずっと黙っていた友は、国道のアスファルトの路へ出ると、「元気を出すんだな、挫けてはいかんよ」　と呟いた。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君も元気を出すンだよ」「えゝ」「云はないでゐようと思つたが、僕も、いよいよ、また勤めへ戻るンだよ」「まア！",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう何米ぐらいはいったかな」「まだ三米ぐらいだよ」「あと七米だね、元気を出すぜ」　ダビットは足をばたばたさせた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通り、元気を出すんだ。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし修業を積むと、すこしは咳を緩和出来るらしいことに気をよくして元気を出す。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これを飲んで、元気を出すさ」　リーマン博士が、僕の手に盃を握らせた。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も心配しないで、無罪放免を確信して元気を出すことだね。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分はいろいろ悲観するようなときは百合子さんの笑い顔を思い出して元気を出す」そんなことを云っていらしった。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍りついたようになって、元気を出すことができなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと元気を出すんだ」「いや、もう駄目です」　僕は忠八の遺言が身に沁みて、東金を見返す決心を固めた。",
              "citation": {
                "source": "村一番早慶戦",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
