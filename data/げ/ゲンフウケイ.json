    "definitions": [
      {
        "index": 1,
        "gloss": "indelible scene of one's childhood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故郷の山と川は、私にとって永遠の原風景だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "幼い頃に見た、夕焼けに染まる海の景色が、今でも私の原風景として心に残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの神社のお祭りは、私の故郷の原風景として、色褪せることなく記憶されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この八月の豊原風景はまさしく貴公子の緑の雨外套だろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻村氏の「ハイランド」は我々にこの二つの東西の高原風景を結び付けて、親ましめてくれる。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀縁の眼鏡をかけた理知的な美人が自分の勃起を観察している光景は、彼にとって原風景のように深く心に浸透する。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
