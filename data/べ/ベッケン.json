          "standard": [],
          "literary": [
            {
              "text": "それらは別件として、ここにはただ桃太郎が鬼が島を伐つに犬を伴れ行ったという類話が南洋にもある事を述べよう。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この数週間に二度だけだが、尋常ではない別件が起きた。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "別件がございまして。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく別件で誰かに素性を見抜かれたのでしょう。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に話すべき別件がある。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
