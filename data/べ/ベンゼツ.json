[
  {
    "uuid": "e0452609-89d7-57db-ab6c-291f076d1b0a",
    "entry": "弁舌",
    "reading": {
      "primary": "べんぜつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
