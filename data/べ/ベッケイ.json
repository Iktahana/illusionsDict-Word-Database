        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はといへば、人生を己が野心の対象物と心得ても猶くたびれない程虎でもなく、かといつて己が信念なぞといふものは、格別形態を採る程湧き出ても来ぬ。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此はかいにから出た別形であらう。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――愛のために、そして、愛の別形である叡智のために、生まれたのだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
