        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは別掲のとおりだった。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは別掲のようなものであった。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "予に實驗者から寄せられた書状は別掲の通りである（ラザフォード卿からの書簡參照）。",
              "citation": {
                "source": "原子核探求の思い出",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大使館ニ於テハ取敢エズ更ニ詳報｜方船長ニ向ケ打電同時ニ別掲容態表｜並ニ乗組船医二名ノ手ヲ｜以テ最善ヲ尽ス可キ旨同船長ヨリノ回答ニ接シタリ。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
