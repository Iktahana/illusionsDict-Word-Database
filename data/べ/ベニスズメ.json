    },
    "definitions": [
      {
        "index": 1,
        "gloss": "red avadavat (Amandava amandava)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四　紅雀　年を取った独身の兄と妹が孤児院の女の児を引取って育てる。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　泉　童話的な「紅雀」に対照すると「泉」は比較にならぬほど複雑で深刻な事件とその心理とを題材として取扱っているから、もし成効すれば芸術的に高級なものになり得るはずであるが、同時にこれを娯楽のための映画として観ると、観たあとの気持はあまり健全な愉快なものではないはずである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は毎日百｜遍ずつ息をふきかけて百｜遍ずつ紅雀の毛でみがいてやりましょう」　兎のおっかさんも、玉を手にとってよくよくながめました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモイはごはんがすんでから、玉へ百｜遍息をふきかけ、それから百｜遍紅雀の毛でみがきました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたいせつに紅雀のむな毛につつんで、今まで兎の遠めがねを入れておいた瑪瑙の箱にしまってお母さんにあずけました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にその中には、かけすと鶯と紅雀と、ひわと、四｜疋はいってばたばたしておりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでいつものように、フッフッと息をかけて、紅雀の胸毛で上を軽くこすりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ、紅雀の毛を少しおくれ」そしてお父さんは熱心にみがきはじめました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々｜悪戯をして、その紅雀の天窓の毛を※ったり、かなりやを引掻いたりすることがあるので、あの猿松が居ては、うっかり可愛らしい小鳥を手放にして戸外へ出してはおけない、誰か見張ってでもいないと、危険だからって、ちょいちょい縄を解いて放してやったことが幾度もあった。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方今の紅雀のその姉さんだの、頬白のその兄さんだのであったろうと思われる。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、運転手が通いつめていた新世界の「バー紅雀」の女給品子は豹一のものになった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々悪戯をして、其紅雀の天窓の毛を※つたり、かなりやを引掻いたりすることがあるので、あの猿松が居ては、うつかり可愛らしい小鳥を手放にして戸外へ出しては置けない、誰か見張つてでも居ないと、危険だからつて、ちよい／＼繩を解いて放して遣つたことが幾度もあつた。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、その運転手が通いつめていた新世界の「バー紅雀」の女給品子は豹一のものになった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつはつはつはつ……あつはつはつはつ……崖の下の蚕豆畑真赤なお天道さんが沈まつしやる……それだのにまだ、紅雀が鳴きしきる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし猶好く見ているうちに、沈んだ強い色で小さい体を彩られている紅雀が末造の目を引いた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで余り売りたがりもしなさそうな様子をしている爺いさんに値を問うて、一つがいの紅雀を買った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようよう籠を一つ頼むようにして売って貰って、それに紅雀を入れさせた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "末造は紅雀の籠を提げて爼橋の方へ引き返した。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中の据えた黒塗の膳の向うに、紅雀の籠を置いて、目に可哀らしい小鳥を見、心に可哀らしいお玉の事を思いつつ、末造は余り御馳走でもない茶漬屋の飯を旨そうに食った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "拾捌　末造がお玉に買って遣った紅雀は、図らずもお玉と岡田とが詞を交す媒となった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る大きな活動写真の撮影場に行って見ると、九官鳥、鸚鵡、インコ、紅雀、カナリヤ、※なぞが籠に入れて備え付けてある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かい泡粒を赤い嘴で噛んで、皮丈を吐きすてる紅雀や、大豆程の卵を生んでは一生懸命に孵すカナリヤの母親なぞを可愛がって眺めますのは、私の一番大きい楽しみでもあり、悲しい時の慰めでもありました。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "移って行った父の家には、もう一羽の紅雀も居ては呉れませんでしたが、その代りに私の実母ではない若い母親が待って居りました。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り返しのつかない事ですが、私は番いの紅雀を斯うして病室へ運んで来ました。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争のさいちゅうで、もし家が焼けたら、かごの中の鳥がかわいそうだといって、自分はかわいいやまがらを逃がしたし、友だちも、おなじ日に、べにすずめを逃がしたのでした。",
              "citation": {
                "source": "おかまの唄",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君のべにすずめは、南の国へ飛んでいくし、僕のやまがらは、北のふるさとへ帰るだろう。",
              "citation": {
                "source": "おかまの唄",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毎朝、この窓のところへ、べにすずめがきます。",
              "citation": {
                "source": "春近き日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、べにすずめが窓にきて鳴きました。",
              "citation": {
                "source": "春近き日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
