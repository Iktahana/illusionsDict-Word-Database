          "literary": [
            {
              "text": "米材を使ってはあったけれど住み心地よくできていた。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この家どこもかしこも米材なり）都市としての江戸の形成の過程と東京の変遷を考え、一種異様な感がします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持って来てたびたびの地震や火事で、焼けた跡に建てられるのは北海松や米材の附け木のように白っちゃけた家か、亜米利加の場末へ行ったような貧弱なビルディングである。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
