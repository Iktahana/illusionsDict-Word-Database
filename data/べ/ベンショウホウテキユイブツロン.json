[
  {
    "uuid": "49805790-5c3d-5068-bc2c-9a9ba1a8d2ee",
    "entry": "弁証法的唯物論",
    "reading": {
      "primary": "べんしょうほうてきゆいぶつろん",
      "alternatives": [],
      "is_heteronym": false
