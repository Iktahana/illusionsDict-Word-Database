        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "由なき戯れとは思いつつも、少女がかれに気づかぬを興あることに思いしか、はた真白の皿に紅の木の葉拾いのせしふるまいのみやびて見えつるか、青年はまた楓の葉を一つ摘みて水に投げたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車に連るる、野も、畑も、畑の薄も、薄に交る紅の木の葉も、紫｜籠めた野末の霧も、霧を刷いた山々も、皆｜嫁く人の背景であった。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の一ぱい咲いている百日紅の木に、蝉が来て鳴き出した。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お初の門口には大きな百日紅の木が立っていました。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝涼のあいだと云っても一里半ほどの路を来たので、駕籠屋は汗びっしょりになって、店さきの百日紅の木の下でしきりに汗を拭いています。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　よびかけられて振り向くと、三津子さんはパラソルをつぼめて、その百日紅の木かげに立っていました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして庭一面に、紅の木の葉を、散りしかせたのでした。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中に大きな百日紅の木がある。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう言って利休は庭におり立ち一樹を揺すって、庭一面に秋の錦を片々と黄金、紅の木の葉を散りしかせた。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "年四十となり給へども、若き人、みづみづしき人、初秋の陽光を全身に受けて、人生の真紅の木の実そのものと見ゆる人。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらないことを申しましたなあ」ここでさらに嘉門はよろめいて、左内とお菊とが向かい合って、黙然とたたずんでいる真ん中のあたりをヒョロヒョロと縫って向こう側へ行ったが、そこには花をつけていない百日紅の木が立っていた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い花をつけた百日紅の木があって、それが霧の中で匂っていた。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムク犬は米友に従って薬師堂の裏手へ廻ると、そこで米友がピタリと足を留め、「なるほど、この百日紅の木がいい足場になるんだ、この枝を伝わってああ行くと、塀を躍り越すなんぞは盲目にもできらあな。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
