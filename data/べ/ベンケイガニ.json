        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ちょっと待って弁慶蟹を踏みつけそうで歩けやしませんわ」　そう葉子は申しわけらしくいって幾度か足をとめた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楓の根がたの青苔のうへをば小さい弁慶蟹の子が二疋で、さつきから久しいこと遊んでゐる。",
              "citation": {
                "source": "なまけ者と雨",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の鉢のまるっこの子は、大きくなったかしら、背中がはげてきたかしら、目高がつッつきゃしないかしら――「ねえおまっちゃん、弁慶蟹ね、なにを食べてるだろう。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくばいの吸込みの小さな穴へもぐってしまった弁慶蟹の子が、年々大きくなって、片っぽの鋏だけがやっと穴から出せる位に、吸込みの穴の中で成長してしまった。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちの犬に吠えられてしまうぜ」「とんでもない戴冠式のお召し車だ」　山木も河合も、弁慶蟹のように顔を真赤にして、はずかしさにやっとたえていた。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弁慶蟹……あの赤い小さなやつ、知っているね。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの弁慶蟹は実にばかな奴だ。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、蟹については、井野格三郎老人の弁慶蟹の話も思い出された。",
              "citation": {
                "source": "非情の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――弁慶蟹をつかまえ、怒らせておいて、その手にマッチの棒をはさませ、火をつけるのである。",
              "citation": {
                "source": "非情の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その酔漢は、まるで弁慶蟹のように真赤な顔をし、帽子もネクタイもどこかへ飛んでしまって、袖のほころびた上衣を、何の意味でか裏返しに着て、しきりと疳高い東京弁で訳もわからないことを呶鳴りちらしていた筈である。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の隙間からは弁慶蟹がよく鋏を出した。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "路ばたの垣根のあひだから美しい弁慶蟹が出てきては俥の響に驚いて逃げこむのをほしいと思つて横目にみながらゆくうちに海岸へでた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき色のうすい弁慶蟹が目をうごかしながらじわじわとはいあるく。",
              "citation": {
                "source": "妹の死",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田郡兵衛半弓　赤い弁慶蟹が一匹、悠々、橋の上を横にあるいている。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
