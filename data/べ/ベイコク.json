[
  {
    "uuid": "6bc59a48-c1da-5ab2-b5d6-a92f649a1b12",
    "entry": "米国",
    "reading": {
      "primary": "べいこく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
