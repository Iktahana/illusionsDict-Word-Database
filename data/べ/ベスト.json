[
  {
    "uuid": "2de3fb4e-5b0d-5d71-8315-043feab67fdc",
    "entry": "ベスト",
    "reading": {
      "primary": "ベスト",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞-の形容詞",
