      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "best",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ベストも尽しもしよう、人間業のあらゆる方法も講じよう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手紙くだされば、私の力で出来る範囲内でベストをつくします。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "身長五フィート七インチ、体格よし、顔色悪し、黒髪、頭頂に小禿あり、たわわな黒い頬髯口髭、色眼鏡、話し方はやや訥々、失踪時の服装は黒のフロックコート、黒のベスト、金のアルバート鎖、下はハリスツイードの鼠色、ゴム布の長靴に茶褐色のゲートルを重ねる。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "上着とベストが床に落ち、扉の後ろの鈎金から、首まわりに吊り帯を巻き付け、仏・中英金物株式会社社長はぶら下がっていた。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわい褐色のベストからは太い真鍮製のアルバート型時計鎖が垂れ下がっていて、先には四角く穴のあいた金属の小片が装飾品としてついていた。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一部のベストセラー作家は別ですが、概して本を書くことや訳すことは割のいい仕事ではありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が家には、ベストセラーとなった『綴方教室』と『山びこ学校』があったような気がします。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがベストセラーとなり、ＢＢＣはドラマの続編を作りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "延長すれば、ごく少数のベストセラーによって売り上げを確保する傾向に拍車がかかり、新しい作品の録音や、新たな投資への意欲を減ずることになる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が生涯の恥ずかしいものオールタイム・ベスト３に入るような誤字事件の発生を、その後このソフトウエアは防いでくれてはいる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "九千七百円のシリーズの何本かは、安定してベストセラーの上位に顔を出し続けている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "破れかぶれのライターに発表会を葬式にされてしまったワークスは、売り上げランキングの上位をキープする大ベスト・セラーとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクル・クライトンの Jurassic Park は日本語版がベスト・セラーとなったばかりで、スピルバーグによる映画化も決定している。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "てなことで今回は、一九九一年私が怖かったコンピューター事件ベスト３で一席だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その父と母が別れると聞いたときの衝撃は、オレの怖かったものオールタイム・ベスト10の輝く第一位である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も気づいていないだろうからこのへんで断っておくが、実は今回は「一九九一年のコンピューターここが怖かったベスト３」という前回からの続きである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一息に堂々恐怖のベスト３を発表するつもりで、「第三位、Ｗｉｎｄｏｗｓ３・０勇気を出して始めての告白事件」「第二位、アップルコンピューター衝撃の金ピカ合体事件」までたどり着いたものの、合いも変わらず両手のおしゃべりが過ぎて、肝心のベスト１がはみ出したていたらくがこれである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来なら引き続いて、両親の離婚騒動に胸を痛める全世界のまるちゃんへのメッセージなども書きたいところだが、今回ベスト１を書かずに終われば『パソコン・マガジン』にオレの席はない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ自分のベストをつくすよりほかにしかたがないのである。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうち、例年のとおりベスト・テンを選ぶとすれば、なお三十八本の平凡作が残る。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の「人生劇場」は最近でのベスト・セラーズの一つであったが、この作品について見ると、氏の「私」の社会化は先ず一般的な人間感情への同情を手がかりとしているように思われる。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分のベストを尽すということより外にこの友達の志に酬うべきものは無いと思った。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年度の映画の中でベストワンといはれる“土”の入場券を貰つてゐたけれど、たうとう――行かず仕舞になつた、衰へたるかな山頭火、いつまでも青年性を失はないであれ、老いても老いぼれたくない、若い老人のよさを保持せよ。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　文化戦線の問題　花山信勝の「平和の発見」や、永井隆の「ロザリオの鎖」「長崎の鐘」などがさき頃のベスト・セラーズでした。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に世間的に有名になった将校で評論雑誌に筆を執ったりベスト・セラーズにぞくする単行本を書いた者は決して少なくはない（石原莞爾氏や秦彦三郎氏）。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンドレッド・ベスト・ホームソングスというような厚い四角い譜ももって来た。",
              "citation": {
                "source": "きのうときょう",
                "author": "――音楽が家庭にもたらすもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "キュリー夫人伝は日本でも昨今ベスト・セラーズの一つであった。",
              "citation": {
                "source": "市民の生活と科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のベストを尽した時でなければ、心から満足を感ずることも出来ないのに、私の周囲にある人達はどうしてこう小さなことに一生懸命になったり悦んだり悲しんだりして、それでいながら根本の問題には触れようともしないのでしょう。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
