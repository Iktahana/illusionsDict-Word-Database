[
  {
    "uuid": "43fcaf1a-2adc-5bc5-9d8e-7b21ce5c6c9b",
    "entry": "可し",
    "reading": {
      "primary": "べし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
