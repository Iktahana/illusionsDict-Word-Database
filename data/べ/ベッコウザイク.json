          "literary": [
            {
              "text": "室子の家の商売の鼈甲細工が、いちばん繁昌した旧幕の頃、江戸｜大通の中に数えられていた室子の家の先代は、この引き堀に自前持ちの猪牙船を繋いで深川や山谷へ通った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "困難し、打ち合わせなどするうちに、後の廊下で、一人の老人が丹念に人造真珠の頸飾や、古本や鼈甲細工等下手に見栄えなく並べ始めた。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈甲細工屋と、洋傘屋の多いのに驚いた。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈甲細工屋のになっていたが、黒い三巾の垂れ暖簾に※の白ぬきのれんが、鼈甲屋とは思わせない入口だった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のキャプション付きの図（fig55990_593.png、横260×縦200）入る］図‐593」のキャプション付きの図（fig55990_594.png、横200×縦244）入る］図‐594　長崎は鼈甲細工で有名である。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎の鼈甲細工も世に聞えます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
