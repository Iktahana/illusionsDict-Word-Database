[
  {
    "uuid": "8463c8a7-0fa6-579b-b769-e45b6d9d34a2",
    "entry": "別事",
    "reading": {
      "primary": "べつじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
