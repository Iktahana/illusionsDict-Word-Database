        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ある時三四郎は念のため、アフラ・ベーンという作家の小説を借りてみた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "試しにアフラ・ベーンという人の小説を借りてみたが、やっぱりだれか読んだあとがあるので、読書範囲の際限が知りたくなったから聞いてみたと言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アフラ・ベーンならぼくも読んだ」　広田先生のこの一言には三四郎も驚いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、ついでだからちょっと聞いておきますがさっきのなんとかベーンですね」「アフラ・ベーンか」「ぜんたいなんです、そのアフラ・ベーンというのは」「英国の閨秀作家だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時三四郎は念の為め、アフラ、ベーンと云ふ作家の小説を借りて見た。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "試しにアフラ、ベーンといふ人の小説を借りて見たが、矢っ張りだれか読んだ痕があるので、読書範囲の際限が知りたくなつたから聞いて見たと云ふ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アフラ、ベーンなら僕も読んだ」　広田先生の此一言には三四郎も驚ろいた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、序だから一寸聞いて置きますが先刻の何とかベーンですね」「アフラ、ベーンか」「全体何です、そのアフラ、ベーンと云ふのは」「英国の閨秀作家だ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一、ブリズベーン行　二十九日、晴れ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "これよりクイーンズランド州の首府たるブリズベーン市まで九マイルあり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "メルボルンの蠅、ブリズベーンの蚊、ともに豪州名物なりとの評あれども、秋冷の加わりたるために、蚊軍の襲来を聞かず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝汽車に駕して、ブリズベーン市に至る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四はブリズベーン市（クイーンズランド州首府）、人口十三万七千六百七十人。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリズベーンよりここに至る海路、四百五十五マイルあり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学はシドニー、メルボルン、アデレード、ホバートの四市に建設せられ、ブリズベーン市にも新設のことに決定しおり、各州に大学を設立する方針に候えども、そのいわゆる大学すなわちユニバーシティーは、わが高等中学程度くらいのものに見受け申し候。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の考え方はＡ・ベーン（†1903）によって代表される。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "会話の時間に頓狂ものゝニコル先生が赤羽君の名を、「ミスター・アカベーン」　と呼んだ。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Akabane とある羅馬字綴りを動もすると英語読みにアカベーンとやる。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それではミスター・アカバネ」「はい」「君は好い話題を提供してくれました」「…………」「アカベーンと呼ぶと何故皆が笑いますか？",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その理由を教えて下さい」「…………」「アカベーンは木の名ですか？",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も半分りだったが、「アカベーンの説明だよ」　と智恵をつけてやった。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アカベーン」　と赤羽君は早速目の下に指を当てゝ舌を出した。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミスター・アカベーン」「日本、アカベーン」「ミスター・アカベーン」「日本、アカベーン」「ミスター・アカベーン、やめなさい！",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
