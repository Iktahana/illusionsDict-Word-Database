          "literary": [
            {
              "text": "ところで例の予言者のピエール・ベントス神父がこの地域にいないか。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ベントス神父は見つかります。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベントス神父は郊外に修道院を持っており、若い僧侶を鍛えています。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピエール・ベントス神父に会ったか」「いま隠れ家から戻ってきたところです。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベントス神父は事情を充分理解しました。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんピエール・ベントス神父のことは聞いたことがあるでしょう。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベントス神父が言った。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
