[
  {
    "uuid": "4787a465-0ac6-5997-8474-75781ac88f7f",
    "entry": "便利",
    "reading": {
      "primary": "べんり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
