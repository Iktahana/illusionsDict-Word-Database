        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "別送のメロンは今年はじめて試作したものですがお口に合ふか、心配でなりません。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみに見本の皿破片全部別送｜仕候あいだ、なにとぞ新品とお較べのうえ御満足をもって御嘉納下さるよう願上げ候。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "別送の一幅に含ませて、その謎を嵯峨家に奉呈するものである。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別送の「状紙」が榮之助の手に渡つたかどうか？",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚お、粗品ながら別送の小包御笑納相成度く、向後益々御健康祈上候。",
              "citation": {
                "source": "流転",
                "author": "山下利三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋは実に小さい体で精一杯やってくれましたから、きょう速達で餞別送りました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民服を着て奥で喋っている男に訊いたら曰く「さアわかりませんな、この頃ちっとも扱いませんから」そこで別送の雑誌一つ買って一円七銭のところを五十銭出したら突かえして「こまかいのありませんか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらは　なつの　べっそうでして、　うちの　あなぐら　――　いや、　ふゆの　いえでは　――　ぐあいが　わるいでしょうから。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
