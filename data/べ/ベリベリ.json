[
  {
    "uuid": "67cac22b-ee46-5acb-b67d-dd833381b7a9",
    "entry": "ベリベリ",
    "reading": {
      "primary": "ベリベリ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
