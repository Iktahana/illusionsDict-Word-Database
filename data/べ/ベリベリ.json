        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beriberi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「……ガガアーッガガアーッ……助けて助けてッ……」　金剛力に掴まれた中野学士の服地がベリベリと破れ裂け初めた。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女は、そこまでいってくると自分の言葉で、激昂したと見え、着ていた縮緬の羽織の袖を口にくわえてベリベリと引きさいた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "廂がベリベリと吹き飛ばされるのですもの。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こいつだッ」　何を思ったか、彼は下に着ていた毛糸のジャケツをベリベリと裂いた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして帆村を離すと、ベリベリと音をさせて、われとわがワイシャツを裂きその間から屍のように青白い胸部を露出させた。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ確かだった時に、丸をつけたり線を引いたりして、夢中になって読んだ本の中に座り込んで、あの、白痴特有のゲタゲタ笑いをしながら、書いたものを文庫から引きずり出しては、ベリベリ……ベリ……と、引き裂いて居る。",
              "citation": {
                "source": "熱",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はいきなり障子へ足を突込んでベリベリと破った。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "キット……俺あ見てたんだが」「ベリベリッと音がしたじゃねえか。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "色のさめたカーテンに手をかけると、紙のようにベリベリとさけた。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、マリ子の頸のあたりをしきりに調べていたが、やがて、「おお、やっぱりそうだ」　といって、指先で、マリ子の皮膚をいじっているうちに、ベリベリと音をさせて、マリ子の頸のところから顔面へかけて皮膚を、はいでしまった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧さんは、大きいハトロン紙の包みをベリベリと剥いた。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして持ってきた包みをベリベリと剥がした。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　怺えきれなくなった私は、尻あてに指先をかけると、ベリベリと引っぺがした。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワンピースの簡単服は、茨にひっかかって、たちまちベリベリと裂けてしまった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "春木少年は実行家だったから、そう決心するとまず老人を元のようにねかし、それから急いで服をぬぎすて、縞のシャツをぬぐと、それをベリベリと破って長いきれをこしらえ、端と端とつなぎあわせた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小ねずみが、つつーと走るたびに棚の上から食器やなんかが、がらがらとおちたり、カーテンがベリベリと破れて、床の上へ大きなものが落ちたような物音がしたり、それからまたひとりで箒が宙をとんだりした。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その三味線の音に二人が耳をやったトタンに、それまでズッと聞こえていたその音が大きくなり、ベリベリ、バリンと叩きつけるように響いて、ピタリと止む）私　…………（そっちに気をとられている）若宮　……（ニヤリとして）昔、聞いた事がある。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人は歯牙にかけず、一人はニヤリとしてカーテンをベリベリと引きちぎる。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右奥の少し離れた所でガーン、ベリベリと大きな物音。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベリベリベリと鳴ったのは喜助の身体が障子を破って襖の所まで飛んで行った音）金吾　野郎っ！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドシン、ベリベリベリッ、ドサン、ガチャンと、まるでイノシシがあばれるような物音。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "板椅子や、テーブルなどのベリベリとこわれる音。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぐった手が村子の上着にひっかかったのをグッと引くと、それがベリベリベリと破れて、肩から腕から、胸部の半分が、むきだしになってしまう）……殺してえ！",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "健二　そら、行くぞ、お花どいてろう……カーンと打ちこんだ音でヒノキの大木がベリベリベリ、ザザザーッと倒れる音。",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベリベリッと音がして、ちぎれたお光の片袖を手に握ったまませい子がはねとばされて、床の上に倒れる。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
