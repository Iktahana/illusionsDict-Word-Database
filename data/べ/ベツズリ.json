          "literary": [
            {
              "text": "）そんなことをしょんぼり考えているところへ、印刷所から、別刷りだと言って、百部ほど刷り上りを持って来た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別刷りというのもあるんですね」と豹一はそれとなく社長に訊いてみた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、御苦労やけど、別刷りの新聞二部、府庁の特高課へもって行ってんか」「今直ぐですか」反射的にそう言ったが、むろん怒ったような声だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の記事が別刷りの埋草だけに使われたということへの怒りが、この気持に拍車を掛けた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
