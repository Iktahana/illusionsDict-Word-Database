[
  {
    "uuid": "3e98c737-f33b-5179-957d-5aa16dd8db28",
    "entry": "べきでは無い",
    "reading": {
      "primary": "べきではない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
