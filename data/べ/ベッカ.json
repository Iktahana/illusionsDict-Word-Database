    "definitions": [
      {
        "index": 1,
        "gloss": "special course",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "戦争中軍事目的のための科学技術者速成のためにさまざまの形で特別科学教育を行っていた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は卒業後に佐賀県師範学校に赴任し、暫くして罷め、慶応義塾の別科を修め、明治十二年に『新潟新聞』の主筆になって、一時東北政論家の間に重ぜられたが、その年八月十二日に虎列拉を病んで歿した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同行者の山田は、保と同じく本科に、中西は別科に入った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中西は別科を修めた後に郷に帰った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の壻｜秀三は東京帝国大学医科大学の別科生になっていて、家にいなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その熱心さが坪内博士を動かして、特別に別科生として止まる事が出来たのであった。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが特殊科学とか個別科学とかといわれるのもそのためである。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学を出てゐなくとも、試験さへ通れば別科に籍を置くことができる。",
              "citation": {
                "source": "明治大学文芸科に演劇映画科を新設する件",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この学校なぞは親切なもので本科の外に別科として看病料理、育児料理というものを教えるそうだ。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄はそのためヤケ酒を飲むようになり、家が治まらなくなったので、もともと松岡家は医者だったからということで、家と地所を売り、その金で当時の東大別科に兄を遊学させることとなった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の長兄が上京して東大別科に入学したさいも、学費の不足を支弁するため、父が漢文で柴原氏に手紙を書き、種々の世話になったことがある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういったイデオロギーが最近の個別科学者に要請されているといってもいい。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃、石原純氏（「自然現象と社会現象」―『改造』）や、鈴木清太郎氏（「科学と社会認識」―『科学ペン』）、その他の人によって、個別科学理論（物理学理論）から社会現象への類推がなされているのも結構なことだが、類推は一応は譬喩として面白いに違いない。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、近時とりあげられてる個別科学者の批判にしても、科学として発展するためには、あくまで科学的批判でなければいけないのだ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――去年また稽古を始めたのは、退校してから十年とちょっとになるわけで、むろん一般の門人とは別科の扱いであり、教えるのも三人の助教が担当した。",
              "citation": {
                "source": "改訂御定法",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別科の稽古に来るのは、いちど精士館を出て、すでに役付きになった者が多く、躰調をととのえるくらいが目的であって、本科の若者たちはこれらを「養老組」と呼んでいた。",
              "citation": {
                "source": "改訂御定法",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "精士館の控え所で稽古着に替え、別科の道場へ出てゆくと、若い藩士が五人、面をつけない稽古着でやって来て、直衛を半円に取巻いた。",
              "citation": {
                "source": "改訂御定法",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人けの少ない別科の道場の、しんとした空気の中で、床へ落ちた竹刀の乾いた音が、おどろくほど高く聞えた。",
              "citation": {
                "source": "改訂御定法",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おべっかを使って、落ちこぼれをめぐんで貰おうと心がけている手あいだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社員に、おべっかを使うように、ペコペコ頭を下げた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あンちき生、課長や、山長さんにゃおべっかばっかしこけやがって！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この猫は鼠を一匹も捕らぬくせに泥棒猫で、近所から嫌われていましたが、「ニャーニャーゴロゴロ」とおべっかを使うのが上手なので、この家の人に可愛がられていました。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真で片眼のべっかんこなのは知っていたが、ひどい若白髪だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ、しゃくるぞ、水｜汲むぞ、べっかっこだ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "カステラも、パンもあるよ、などと言って騒ぎますので、自分は持ち前のおべっか精神を発揮して、おなかが空いた、と呟いて、甘納豆を十粒ばかり口にほうり込むのですが、空腹感とは、どんなものだか、ちっともわかっていやしなかったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も居ない洗面所の鏡の前へ停って舌を出したり額を撫でたり、はては、にやにや笑い、べっかっこをした顔を写し、それを誰も知らないつもりで済まし返って部屋へ引っ込んで行った氏。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた達は、お金持の奥さんに、おべっかを言っていただけなんだ。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの習慣については、実は内心大いに閉口しているのだが、しかし、これとても、私のつまらぬおべっかの報いに違いないのだから、誰をも恨む事が出来ない。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中へ、べっかっこで、（ばあ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぶさったお前さんが、それ、今のべっかっこで、妙な顔……」「ええ、ほほほ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
