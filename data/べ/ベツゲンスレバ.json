          "literary": [
            {
              "text": "別言すれば彼は術語の罪過を犯せしものなり。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "別言すれば結果は源因の写影たるに外ならず。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "別言すれば、因縁の真理を知らざることが「迷い」であり、因縁の道理を明らめることが「悟り」であるといっていい。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "別言すれば外政上に大捷を得たる消極論派も内政についてはまた大敗を取りたりというべし。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "別言すれば、烏啼が苅谷邸から攫っていったのは、姿こそ繭子夫人であったが、その中身に至っては当の夫人ではなく、実は猫々先生であったのである。",
              "citation": {
                "source": "奇賊は支払う",
                "author": "烏啼天駆シリーズ・１",
                "note": "青空文庫"
              }
            },
            {
              "text": "別言すれば肉が靈に依憑する状態から現實の實踐が行はれることである。",
              "citation": {
                "source": "龍土會の記",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "別言すれば軍備競争のために、現時の各国民の生活はほとんどミニマムにまで低下したという憐れむべき状態である。",
              "citation": {
                "source": "世界平和の趨勢",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
