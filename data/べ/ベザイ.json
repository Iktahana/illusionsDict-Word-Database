    "definitions": [
      {
        "index": 1,
        "gloss": "large Japanese junk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
