      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "increase in basic salary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "てにはは器械のギアーでありベアリングである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ベアトリチェの喜びはあたし自身の喜びであり、コルデリアの悲しみはとりも直さずあたしの悲しみだったの。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "神かけて、嘘ではありませんよ、僕のベアトリイチェ。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ベアトリイチェや、帳場へ行って電話をかけて来ておくれ。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンテとベアトリーチェがめぐり合ったというアルノー河には冬の霧が一ぱいかかっていた。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神曲に見えたるベアトリチエとの戀は、夙く九歳の頃より始りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベアトリチエとの淨き戀、戰爭の間の苦、逐客となりてアルピイ山を踰えし旅の憂さ、異郷の鬼となりし哀さ、皆我詩中のものとなりぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある事件があって「これは完全に振られた」と覚悟した当時十七歳の少年は、それまでベアトリーチェを思いながら書いてきたおびただしい日記と随筆もどき、詩のまがいものを一気にノートに書き写し、当惑する少女に手渡して哀しい初恋にけりを付けようとした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の肉※蓉は御肉と同じく列当科に属すれど別物で、学名をフェリベア・サルサと呼び、西シベリア、蒙古、ズンガリアの産、鎖陽は蛇菰科のシノモリウム・コクネシウムで蒙古沙漠に生ず（ブレットシュナイデル『支那植物学編』三）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス・ギャル、芦川いづみ、シェリー・フェブレー（ワラの発音だとシェリー・ファーベアズだけど、そんな名前で〈ジョニー・エンジェル〉を歌っているすがたなんて、どう考えても想像できない）、パティ・デューク、浅丘ルリ子、シルヴィー・ヴァルタン、マリー・ラフォレ……。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、呆れた様な顔をしながら、それでも急いで吸殻を膝から払ひ落して、『先生、出したつても今日の事だがら、まだ校長の手許にあるベアハンテ、今の間に戻してござれ。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、呆れたやうな顏をしながら、それでも急いで吸殼を膝から拂ひ落して、『先生、出したつても今日の事だから、まだ校長の手許にあるベアハンテ、今の間に戻してござれ。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルメンの物語でばかりスペインを知っている人々にとって、またダンテとベアトリチェの物語だけでイタリヤの心を知ったと思う人は、これらの国々で不幸な愛人たちが自分たちの幸福への願望と共に流した血潮の多量なことに心から驚かずにいられないだろう。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその娘は私のベアトリチェであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をしてみると、マーケティングマネージャーのデーブ・スコットは、長時間テストしてベアリングが完全に磨耗した試作装置をスペアーのベアリングを付けて提供してくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まア、はひつて一杯召し上るベア」　お母さんが酒でも燗徳利に入れてゐるのでせう。",
              "citation": {
                "source": "谷間からの手紙",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベアリング工場とか、印刷屋だのがごみごみした通りの、掘り返した道路に面した番地を、たんねんに探して、ゆき子はやつと、狭い路地の中に、加野の下宿先を探しあてた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベアトリチエは正宗氏の言ふやうに女人よりもはるかに天人に近い。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しダンテを読んだ後、目のあたりにベアトリチエに会つたとしたならば、僕等は必ず失望するであらう。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベアトリチエも亦同じことであらう。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもかう云ふベアトリチエはベアトリチエ自身を示さないにもせよ、ダンテ自身を示してゐる。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボール・ベアリング、鉄の円い玉だが、カフス・ボタンやいろんなものにつかって銀ぐらいねうちのあるもの、あれの製造工場をやっているし……」「儲かります？",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――実はそのことじゃあ僕清水を怨んでるんです」　清水とは太田の従兄で、ボール・ベアリングの共同投資人なのだ。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その端正な美しさは、とうてい陶器で作った、ベアトリチェの死像と云うほかにないであろう。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉のジナイーダは寝台の下にある屎瓶を布片で覆うてから、悠然と上って来たが、二七、八になるらしい彼女の神々しい美しさには、粗服の中にも聖ベアトリチェの俤があった。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「簡単さ、ベアリングを入れて、自由に動くようにすればいいのさ。",
              "citation": {
                "source": "ロボットとベッドの重量",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷かに光ったベアリングが、前後に、左右に、円滑な運動のできるよう、適当に噛合っていて、電気の通じてくる銅線、液体の入ったゴム袋。",
              "citation": {
                "source": "ロボットとベッドの重量",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
