          "literary": [
            {
              "text": "又はお酒の代として、別勘定にして来ることもあるそうである（この式で只口先だけでいくらと払わせるのも、ほかにいくらもある）。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は毎日一ルーブルの夕食をしたためることにして、ただし飮物は別勘定ときめていた。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "支度し、別勘定を払ってしまふと、もう四千円しか残ってゐない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の別勘定を済ませ、八時、タクシー来、長岡駅迄。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
