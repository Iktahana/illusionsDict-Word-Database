        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下痢や便秘といふこともなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに便秘しさえすれば、必ずひきつける子供だった。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寝の人間には常習便秘が多いんですから……」「……ハハア……」　と医者が感心してタメ息を吐いた。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、一学」「私の馬鹿は昔からで」「それが今日は特に悪い」「いやはやどうも、お口の悪いことで」「お前、今日は、便秘だろう？",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、そうでもございません」「なあに、そうだよ、便秘に相違ない」「これはまたなぜでございますな」「便秘だと頭が悪くなる」「あッ、やっぱり、そこへ行きますので」「ひまし油を飲めよ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯の温度は百六十三度｜乃至百五度ぐらいで、打撲金瘡は勿論、胃病、便秘、子宮病、僂麻質私などの諸病に効能があると申します。",
              "citation": {
                "source": "名人長二",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "○便秘者に菓物野菜牛乳等を与うべし、煮たる杏は最も便通に功あり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂には歯ぐきの色灰の如く白みを帯びて腫れ出し、頑固の便秘を起して重体に陥るものなり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒れはてた秋の海を藪の中から覗きながら、茱萸の実をもいで食べて、やがて便秘を起したものだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的ノナカツタ丈　冷静デアツタ太陽ガ汗ニ濡レタ背ナカヲ照ラシタ時影ハ背ナカノ前方ニアツタ人ハ云ツタ「あの便秘症患者の人はあの金持の家に食塩を貰ひに這入らうと希つてゐるのである」ト‥‥‥‥‥‥‥‥‥‥‥１９３１・６・５",
              "citation": {
                "source": "異常ナ可逆反応",
                "author": "李箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは渋柿を食えば便秘する、便秘すれば逆上は必ず起るという理論から来たものだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになったら僕も便秘をしなくなるだろう。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば私なんかこんなに丸くたって、婦人科のお医者が、丸い女につきものといういろんな条件、頭痛だとか不眠だとか、便秘だとかは一つもないのですものね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生ここ二三日便秘し脚気気味なりと。",
              "citation": {
                "source": "同居人荷風",
                "author": "小西茂也",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来便秘がちで、排便した後で発作がおこり易い。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "便秘をしないように緩下剤の服用をすゝめる。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなければあなたが便秘した馬のような顔をして僕の前に立っているはずがないでしょう！",
              "citation": {
                "source": "親友たち",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日もべんぴしているのだそうで、どうも頭が割れるようでのうと云う。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
