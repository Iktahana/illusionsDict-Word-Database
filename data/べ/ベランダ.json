        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西洋人は東洋暖地へ来てやっとバンガローのベランダ造りを思いついたようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き残った家鴨どもはわれわれには実によく馴ついて、ベランダの階段の一番上まで上がって来てパン屑をねだる。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "着くとすぐ手近なベランダの檜葉を摘んで二十倍で覗いてみた。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年と同じ家のベランダに出て、軒にかぶさる厚朴の広葉を見上げ、屋前に広がる池の静かな水面を見おろしたときに、去年の夏の記憶がほんの二三日前のことであったようによみがえって来た。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦笛を吹くような声でピーピーと鳴き立ててはベランダの前へ寄って来て、飯の余りやせんべいの欠けらをねだるのである。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池を隔てた本館前の広場で盆踊りが行なわれて、それがまさにたけなわなころ、私の二人の子供がベランダの籐椅子に腰かけて、池の向こうの植え込みのすきから見える踊りの輪の運動を注視していた。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベランダの天井の電燈は消えていたが上がり口の両側の柱におのおの一つずつの軒燈がともり、対岸にはもちろん多数の電燈が並んでいた。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベランダから池の向こうの踊り場を正視していたときに、正面から左方約四十五度の方向で仰角約四十度ぐらいの高さの所を一つの火の玉が水平に飛行したというのである。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前記の浴室より、もう少し左上に当たる崖の上に貸し別荘があって、その明け放した座敷の電燈が急に点火するときにそれをこっちのベランダで見ると、時によっては、一道の光帯が有限な速度で横に流出するように見えることがある。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはもうフランスの国境近くで、屋敷のベランダから牧場越しに国境の森が見え、またヴォルテールの住まっていたという家も見えます。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時自分は星野温泉別館の南向きのベランダで顕微鏡をのぞいていたが、爆音も気づかず、また気波も感じなかった。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくして私がベランダの手欄から眼の下に四五町程離れて見える運動場を見下すと、そこに三人はパンの子のやうに自然の中にまぎれ込んで、何かゝにか人手も借らずに工夫した遊戲に夢中になつてゐる。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になるとがや／＼云ひながら子供達はベランダの階子段を上つて來た。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は部屋を出て幅の廣いベランダに行つた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベランダの板は露に濡て、夜冷えがしてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は椅子や卓子の間を拾ひながら、ベランダの上を往つたり來たりした。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して口早に女中に留守の事を色々頼まうとしたが、結局どれ程綿密に注意をして置いても、出來るだけの事より出來ないと思つて、唯「留守をしつかり頼むよ」とだけいつてベランダに出た。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてベランダの上にだが見れば銅貨が落ちてゐる、いやメダルなのかアこれは今日昼落とした文子さんのだ明日はこれを届けてやらうポケットに入れたが気にかゝる、月は※荷を食ひ過ぎてゐる灌木がその個性を砥いでゐる姉妹は眠つた、母親は紅殻色の格子を締めた！",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ均一を見舞うだけの旅行であったが、逢ってみると別に話すべきこともなく、今の自分の姿にも負け目が感じられ、後は加世子に委せて、ベランダヘ出て風に吹かれていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ均一を見舞うだけの旅行であったが、逢ってみると別に話すべきこともなく、今の自分の姿にも負け目が感じられ、後は加世子に委せて、ベランダへ出て風に吹かれていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と社長は、その凌霄花の陰のベランダで、食後の涼をいつまでも入れている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり支度をしてしまってもう明日は船に乗り込めばいいことにして、千代重は私とＧホテルのベランダで、夏の夜更けまで、港の灯を眺めながら語った。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "倭文子は、ベランダのてすりに身をもたせて、遠く天城の連山をながめていた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れるまで、彼女はベランダへ出て海を見ていた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は、ベランダへ出て来て、倭文子に、「お寒くありませんか。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝床は妻の寝室と同じであるとしても、軽症者の静臥すべきベランダにあった。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベランダは花園の方を向いていた。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこのベランダで夜中眼が醒める度に妻より月に悩まされた。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう夜には、彼はベランダからぬけ出し夜の園丁のように花の中を歩き廻った。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の母はベランダの窓｜硝子に頬をあてて立ったまま、花園の中をぼんやりと眺めていた。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
