        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「兄さんなぜあたいの青いおべべ裂いたの。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このべべ何としたんや」と言って濡れた衣服をひっぱってみても「知らん」と言っている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この顔が――くどいようだが――楊貴妃の上へ押並んで振向いて、「二十だ……鼬だ……べべべべ、べい――」　　　　　　　四　ここに、第九師団｜衛戍病院の白い分院がある。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に赤ちゃんの着る花模様のおべべを着て、でんでん太鼓など振って、その九十歳だか百歳だかの御両親のまわりを這いまわって、オギャアオギャアと叫び、以て親の心を楽しましめたり、とあります。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十の老人が、赤ちゃんのおべべを着て、でんでん太鼓を振りまわしている図は、むしろ醜悪で、正視にたえないものです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると婦人は私の肩に手をかけて、「綺麗におけい／＼（お化粧）が出来て、おべべ（着物）もよくお似合い」　そう言って夫人はわたくしの袂の八ツ口の根元を指先で抓み、指先の早業で下着の裏や襦袢の地質を検め見ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはこれを聞くと、意味は充分には判らないながら辱かしめの爛らす熱湯のようなものが胸のまわりから頸筋へ突き上げて来て、これを我慢をするため唇を屹と噛み締めますと、べべべと不可抗の力が唇を上下に破りまして、箸と茶碗をそこへ投げ捨てると同時にわっと泣き出しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青縞、茶縞、茶縞のおべべ、ちゆうちゆうぱたぱた、何反織れたか。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでお前さん、さらのおべべが揃うだけの儲かり話があるんだが、よもや遠慮するまいね？",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみやげどっさり、うんとこしょお菓子におべべにキスにキス踊って待てよ待てよ、魔子、魔子。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おべべを着更えましょうね」と節子は二人の子供を呼んだ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、もうすぐ朝鮮に行くんだから、そのおべべを着てそこいらへ挨拶に行って来るんだ」　と、みんなのものに言われて、私は叔母と一緒に学校や近所の家へ暇乞いにまわった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いべべを着たお人形さんや、ロッペン島のあざらしのような顔をした土細工の犬やいろんなおもちゃもあったが、その中に、五、六本、ブリキの銀笛があったのは蓋し、原君の推奨によって買ったものらしい。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "我らは昔し赤ん坊と呼ばれて赤いべべを着せられた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あべべい、酒は茨だねえ、不快極る存在じゃよ、と言いながら。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "聖なる酔っ払いは神々の魔手に誘惑された話",
                "note": "青空文庫"
              }
            },
            {
              "text": "あべべい、酒は茨だねえ、不快極る存在ぢやよ、と言ひながら。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "――聖なる酔つ払ひは神々の魔手に誘惑された話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "甜めろ、甜めろ、泥をなめろ、飴を甜めろ、牛のけつを甜めろ、赤いおべべを着て踊れ。",
              "citation": {
                "source": "佐渡が島を出て",
                "author": "江南文三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは夜のあいだに、自分が食べべるために、この人たちの貯えの一部を盗むことにしていたが、そうすることがこの家の人たちを苦しめることがわかると、それをやめて、近くの森で集めてきた苺、胡桃、根菜の類で満足した。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子にとっては桃の花のつぼみのような年ごろから、男の子にとってはしょうぶの葉のような伸びゆくさかりの年ごろから、山のものを祝い、海のものを祝いして、新しいおべべに着かえながら、そういう節句にめぐりあうというのも楽しいではありますまいか。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、寝ている勇ちゃんのお母さんは、「みい子のお好きな赤いおべべが、はいっているというのですよ。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、みい子ちゃんの赤いおべべが。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「赤ちゃんのおべべよりも、きれいだといっていただきたいのですよ。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎ちゃんのお母さんは、たんすを開けて、みい子ちゃんの、きれいなおべべをごらんになりました。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きれいな、いいおべべですこと。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊や、すわると、おべべが、よごれるよ。",
              "citation": {
                "source": "鳥鳴く朝のちい子ちゃん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊お洗濯知つてるの……』『ぼうしつてる、おべべばつちくなつたとき、じやく／″＼してきれいにすることでせう』『あゝさうです／＼、坊よく知つてゐるわね。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんがばつちくなつたおべべを川へ持つて行つてお洗濯をしてゐるとね、向ふの方から大きな桃が、どんぶらこ／＼と流れてきました』『おばあちやん、そのもゝどんなにおほきかつたの？",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            }
          ]
        }
