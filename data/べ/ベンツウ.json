        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「だって、お便通剤が一向利かないんですもの――。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人と相談さしてもらいまっせ」　政江は興奮の余り、便通を催した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも余りに便通がないので、名古屋では挙って心痛したということであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は火がつくようにまた便通を訴えた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして同時に便通を訴へた。",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "12　ラジオ、映画、演劇、新聞、郵便通信、宗教、教育等の戦時的統制からの解放。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時頃便通後やや苦しく例に依りて麻痺剤を服す。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小腹御硬満、時々滴々と二勺不足位之御便通有之、尤竹筒相用候程之は通じ無之、始終袱紗にてしめし取申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "便通がありさうになつた。",
              "citation": {
                "source": "雨になる朝",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、――急に便通を感じた。",
              "citation": {
                "source": "伝吉の敵打ち",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの健康と太き神経なく、金持ちの応接室と聞いただけでも便通を催すという潔癖なる神様で、パトロンも金もなかったら、この現代ではいかに善き作品を作っても、作れば作るほど、食物が得られない。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "便通が甚しく不整だった。",
              "citation": {
                "source": "怒りの虫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒暖計八十二度（午后三時）　未明ニ家人ヲ起シテ便通アリ。",
              "citation": {
                "source": "呉秀三先生",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "便通及繃帯トリカヘ。",
              "citation": {
                "source": "呉秀三先生",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○便秘者に菓物野菜牛乳等を与うべし、煮たる杏は最も便通に功あり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○柿、銀杏、竜眼肉、罌粟の如き菓物は収斂性食物にして便通を秘結せしむ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○杏、林檎、覆盆子、桃李の類は清涼性食物にて便通を促す。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十日（水）　昨夜、便通がつまって苦しく大さわぎした。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時すぎに一回便通があったが、大して悪い便でもなかった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、便の色は薬のためである、便通は薬に多少下剤が混じているので少し度数が多くなるかも知れない、然し心配のことはない、という答えだった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘔吐八回、尿二回、便通二回、腸洗一回。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "便通は腹の調子を告げるばかりでなく全身の工合を語るから、それが苦情すくなければ何よりです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "便通のこと、早速会議にかけましたら、この頃は大変よくなって、毎日一度は必ずあるとのことですから御安心下さい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石先生は毎朝便通に行かれることを一つの楽しみに数えられ、それは寧ろ生理的快感であると云われたそうだが、その快感を味わう上にも、閑寂な壁と、清楚な木目に囲まれて、眼に青空や青葉の色を見ることの出来る日本の厠ほど、恰好な場所はあるまい。",
              "citation": {
                "source": "陰翳礼讃",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンナ風デ何楽シミニ生キテルノカト、人モ思ウダロウシ、自分デモ思ウコトガアルガ、幸イト云ッテイヽノカドウカ、不思議ナコトニ食慾ト睡眠ト便通トハ至ッテ満足ニ行ッテイル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "便通モ日ニ二回ハアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし絞り腹と云う奴なので、催す毎に少量の便通しかなく、そのためになお苦しいのであった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の診断がおくれたのも、一つはそのせいなのであるが、一つには、赤痢にしては熱が高く、それに最初の一日は便通がなく、下痢が始まったのは発病してから二十四時間後の一昨々日の夜であった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘロポントスは急性熱疾患にかかり、液状胆汁色の便通、しぶり、腹痛を訴えた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
