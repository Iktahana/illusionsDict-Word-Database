        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ブルッ、と手で顔を撫でると、全で凍傷の薬でも塗ったように、マシン油がベタベタ顔にくっついた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか、外塀や、電柱に、伝単がベタベタ貼りさがされていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは小さな板へかいた習作であったがなるほど濃厚な絵の具をベタベタときたならしいように盛り付けたものであった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、はじめてです」　顔のオデキをかくそうとしてベタベタと塗り立てたのか、おかしい位こってりと厚化粧した女は、安白粉の匂いをプンプンさせながら、小沢の傍に掛けると、「――おビール持って来まひょか」　大阪弁を使っているが、アクセントは上方のそれではなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから提灯を消して傍の壁にかけて、ボロボロ浴衣を脱ぐと、くの字なりに歪んだ右足に、黒い膏薬をベタベタと貼りつけたのを、さも痛そうにラムプの下に突き出して撫でまわした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "西湖十景だの三十六｜名蹟だの、七十二勝だのと、人間の手垢をベタベタ附けて得意がっています。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そんな年頃の、いかがわしい女は、若さの持ついやらしさがベタベタとぬった白粉や口紅を、不潔に見せていたが、この娘の白粉気のない清潔な皮膚には、遠いノスタルジアがあった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼等はここから出て来たんです」　彼はそう云いながら、泥の上にベタベタとついた足跡を指さした。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "……アナタ……」　と云ううちに老婆は、古ぼけた畳の上を、赤ん坊のようにベタベタと這いながら引込んで行った。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "止むを得ず、一番たくさん飼っていて、一番沢山減った、飼主が、一匹ずつ引っ捕まえて、スタンプ用の赤インクを、ベタベタと背中へ塗りつけたのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベタベタした長髪のジジイって、よくいるじゃねえか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "白木綿に朱印をベタベタと捺した巡礼の笈摺を素肌に引っかけて、腰から下に色々ボロ布片を継合わせた垢黒い、大きな風呂敷｜様のものを腰巻のように捲付けている恰好を見ると、どうやら若い女らしい。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道にめずらしいベタベタした「暖気雪」が降っていた。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の後の埃の中をベタベタな藁草履をはいた子供達が、四五人追いかけていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ればリノリウムを敷き詰めた床の上には、なるほどそのような妖怪の暴れた跡らしく、点々としておびただしいガラスのかけや血海のほかに、なんとなくぬらぬらした穢らしい色の液体が、ところかまわずベタベタと一面にこぼれており、それがまたなんとも言えない生臭いような臭気をさえ、室中に漂わせているのだ。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後には、たくさんの丸いメーターがベタベタ並んでいて、黒い目盛盤の上に白い指針がピクピク動いていた。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むうう」とうなると可哀そうな文三、ベタベタとすわったものである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベタベタとすわって手をついたのは、憐れみを乞うというよりも、一種荘厳の光景に、強く胸を打たれたからであった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、とうとうとらえたね」キュッとだきしめるとベタベタと、頂きへ坐ったものである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び返ってきたイスラエルのお町、ベタベタと縁へすわってしまった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でベタベタと地面へ坐ると、茫然として考え込んでしまった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるときは赤ペンキは忽ち自動車をベタベタに染め、運転手が驚きて拭わんとすれども中々おちぬところに新種ペンキの特長あり。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "□“しぐるるや犬と向き合つてゐる”四国をまわっていて、気のつくのは空家が多いことである、ベタベタビラを張られた空家が見すぼらしく沿道に立ちならんでいる！",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "間に挿まれた老人と老婆は、ベタベタと道へ蹲居った。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨にベタベタに濡れて光る浪花節のポスターが、床屋の表にぶらさがつてゐるが、その横を折れて二軒目がさうである。",
              "citation": {
                "source": "釜ヶ崎",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "問屋筋のかたぎのうちでは、大きな、極印のような判をベタベタと押した。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙取りが帰って来ると、紙面にざっと眼をとおして、人の注意をひきそうな事件を見つけては、売子たちの籠の前にぶらさげるビラに、「浅草の七人斬り」とか「深川の大火」とか筆太に書きなぐって、赤インキでベタベタと二重丸を附けるのもこの平田さんの仕事の一つであった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣伝ビラのようなものもベタベタと貼ってあった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "色のベタベタにじんでいるような街路には、私と護謨靴屋さんの店きりだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歪んだガラス戸に洗った小切れをベタベタ張っていたお母さんは、フッと思い出した様に云った。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
