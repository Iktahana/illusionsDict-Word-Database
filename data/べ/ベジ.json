        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その下にしゃがんで、チュンセはキャベジの床をつくっていました。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり気分が直ったらキャベジのいい処を少しやれ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャベジの青いいい所を助手はわずか持って来た。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、窓もすっかり明けましたし、キャベジのいいのもやりました。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえのような狸をな、キャベジや塩とまぜてくたくたと煮ておれさまの食うようにしたものだ。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君がどんなに頑張って、馬鈴薯とキャベジ、メリケン粉ぐらいを食っていようと、海岸ではあんまりたくさん魚がとれて困る。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また農場へ行ってめまいをしてもいけません、なぜなら、その魚粕をつかうとキャベジでも麦でもずいぶんよく穫れます。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにキャベジ一つこさえるには、百疋からの青虫を除らなければならないのですぜ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもちろんキャベジも植えた。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人がキャベジを穫るときは僕はいつでも見に行った。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペムペルがキャベジの太い根を截ってそれをはたけにころがすと、ネリは両手でそれをもって水いろに塗られた一輪車に入れるのだ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人は車を押して黄色のガラスの納屋にキャベジを運んだのだ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いキャベジがころがってるのはそれはずいぶん立派だよ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてキャベジと鮒とをな灰で煮込んでおいてくれ。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（お母さん、これから仲善く一処に暮しませうね、）――（たしかに私はあなたのオベジエント、ソンです、今迄のことは許して下さい。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰ってシチ（キャベジ入スープ）を食って、さてまた市のあっちの端まで、たとえば労働者新聞で今朝読み工場では一時間の昼休みに職場委員がそのために集った「生産経済計画」の演説をききに行く気になるだろうか。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "構内の学生食堂で、キャベジ・スープをたべてると、赤い襟巻をしたマトリョーナがやって来た。",
              "citation": {
                "source": "ワーニカとターニャ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャベジ、人蔘、ジャガ薯、肉片。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は夕方、紙切れを握って塩漬キャベジの匂いのする食糧販売店の減った石段をトン、トン、トンと下りて行った。",
              "citation": {
                "source": "モスクワの姿",
                "author": "――あちらのクリスマス――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステパン・ステパノヴィッチ、古いキャベジがいるからお茶が不味かったんですって？",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は昼の残りの肉を　ナイフでたたき乍ら――この肉上げましょうか、食べたくなる程美味しい肉ですよ　全くさ　それでも三週間キャベジの煮たのだけたべてやっと百グラムの牛肉が食べられるようになったのだから、彼女はその肉も結局は食べ終る。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場のモスクワ式ごろた石の通路では、花キャベジの葉っぱ、タバコの吸殻、わら屑、新聞の切れっ端が踏みにじられていた。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る駅ではキャベジ一貨車を腐らした。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在ソヴェト同盟にある食糧困難は……食糧困難は、偶然の現象……つまり雨が降りすぎて、どっかの畑でキャベジが腐ったというようなもんじゃない。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう塩漬キャベジを百グラム買うのに、何分列に立たせられたと思う？",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプがついている下で、大きい瀬戸物のスープ入れの壺のまわりへ親子がかたまり、かわりばんこに木匙をつっこんでキャベジスープをたべた。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の耕地からとった一枚ずつのキャベジの葉っぱを味わって食っている風だ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャベジの根を切ったものが出て来る。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この古くて全く新しい国が一九二〇年代の終りから三〇年にかけて経験した二十四時間は、食物でも紙でも衣類でもひどく品不足で、キャベジの四分の一塊りのために朝子はたくさんの道のりを歩き、長く列につき、なおあの五つの大キャベジも自分の一人前のところでなくなりはしないだろうかとはらはらした。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
