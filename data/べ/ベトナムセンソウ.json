          "literary": [
            {
              "text": "ベトナム戦争のさなかで「愛と平和（嗚呼！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十九日には、アメリカ大統領ニクソンがベトナム戦争の終結を宣言した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニクソンによるベトナム戦争終結宣言の直後には、タケシはもう働きはじめていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "反権力、反権威をかかげ、ベトナム戦争への大学の関与を指弾する一方で、大学とはなにか、大学生である自分とはなにかを問いなおそうとしたこの運動は、のちに世界中で火を噴いた学生運動のテーマとスタイルを先取りしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリス人の数学者で、哲学に関する著作を残し、核兵器廃絶やベトナム戦争反対をかかげる平和運動家でもあったバートランド・ラッセルの明快で実践的な主張は、まっすぐに心に染みてきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
