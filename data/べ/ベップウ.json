        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "玉稿、本日別封書留にてお送りいたしました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当社ではおたのみした記憶これ無く、不取敢、別封にて御返送、お受取願い上ます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの無心聞き済み無く候はば、別封にいたし置候一通を披見なさるべく候、御聞きとどけ下され候はば、右の別封は御開封におよばず、そのまま御返し下さるべく候　開封に及ばずとあれば、あけて見たいのが人情である。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市兵衛はその別封をあけて見ろというと、手代共も一種の興味をそそられて、すぐに封をあけた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人も奉公人も店の灯の下に顔をつきよせて、その別封の文面をよんでみると、これは本文の丁寧なのに引きかえて、穏かならざる文言が列べ立ててあった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "然ニ別封桂小五郎先生まで相達申度、何時ニてもよろしく御便の節御送奉願候。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年一月三日　久保松太郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ怪しと存ぜしまま、その白粉を摘み取り、自宅へ持ち帰り候が、別封をもってお眼にかけし物こそ、その白粉にござ候。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、お手紙が」　「あ、乃舅だな」　壮夫はちょいといずまいを直して、封を切り、なかを出せば落つる別封。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、お手紙が」「あ、乃舅だな」　壮夫はちょいといずまいを直して、封を切り、なかを出せば落つる別封。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "事業の目論見書は別封にて御送り申上げ置き侯共、御一議の上、小生に御協力給わる御気持を以って至急御状況煩し度、此段切に願入候。",
              "citation": {
                "source": "泡盛物語",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "魯庵氏への紹介状別封差上候間御使可被下候。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて別封（小説「葦切」）は佐瀬と申す男の書いたもので、当人はこれをどこかへ載せたいと申しますから『ホトトギス』はどうだろうと思い御紹介致します。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十三日金　　　　　虚子先生　　　　　　○明治四十一年七月二十三日（封書）　拝啓　別封「花物語」は寅彦より送り越し候もの。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別封｜宮寛と申す男より参り候。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別封の一通御覧、この人の心中察し給え。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューメン駅には一行を転送する特別封緘列車が待っていた。",
              "citation": {
                "source": "淪落の皇女の覚書",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "御約束によつてお祝ひの印まで、別封の萬年筆さしあげます。",
              "citation": {
                "source": "受驗生の手記",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方の方から御注文であった本の目録は別封でお送りいたしましょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間うちから一度かいて見たいと思っていることがあります、それは別封で。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは又別封でつづくのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう受とって来た請求書、つづけてかきかけましたが、いつも別封にとおっしゃるのを思い出し別にいたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "別封お送り致しましたのは、私の拙い創作でございます。",
              "citation": {
                "source": "人間椅子",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "別封に、彼へ宛てて、一書を認めておいたから、これを携えて、一度城中に彼を訪い、彼、後藤基国をして、その主君別所長治によく利害を説かせ、大勢の帰するところを諭したなら、長治とて、よも鬼神ではなし、かならず開悟一転、城を開いて、和睦を乞うて来ようかと考えられる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
