        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ベースボール」は「野球」に完全に駆逐されてしまった。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が見たら人間のテニスやベースボールは定めて間だるっこくて滑稽なものだろうという気がするのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛾をはたき落す猫を羨み讃歎する心がベースボールのホームランヒットに喝采を送る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば相対性原理とはどんな事か、マルキシズムとは何か、バロック芸術とは何、ベースボールとは何、ジャズとは何、そういうことが望みのままに早分りがすれば甚だ便利であり、また時代に適応する所以であるかもしれない。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では仙台にこの人形を売る店が二軒位しかないそうですが、そこへ行ってみると、水兵だとか、ベースボールのバットを持っているものだとかいうものばかりで、一向面白くない。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ光線　電車会社の大きなベースボールグラウンドが、村外れの松原を切り開いて出来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本物のベースボールというものは、戦争みたように恐ろしいもので時々｜怪我人が出来る。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "松浦先生は……しかしベースボールの方が気にかかっていたかして、そのまま自転車に乗って大学を出たらしかった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他運動と云っても、当時は未だベースボールもなく、庭球もなかったから、普通体操位のもので、兵式体操はやらなかった。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十歳まで大学に通ってベースボールをやる必要なんか無論ないよ」「其日庵という俺の雅号の由来を知っているかい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新文化の最も目ざましい表象として維新時代の夢のまださめ切らなかった生徒たちの心に強い印象と衝動を与えたものはベースボール、フートボール、クリケット、クロケーそれからボートレースなどの新遊戯であった。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まいた種のうちでもクリケットやクロケーは風土に合わなくてじきにしおれて枯れてしまったが、ベースボールとボートレースはのびのびと生長した。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が見たら人間のテニスやベースボールはさだめてまだるっこくて滑稽なものだろうという気がするのである。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛾をはたき落とす猫をうらやみ賛嘆する心がベースボールのホームランヒットに喝采を送る。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "單純ナル遊戲トシテ男子ガ撃劍柔道ニ遊ビ女子ガ長刀鎖鎌ヲ戲ルルハ其興味ニ於テ「ベースボール」「フートボール」等ト雲泥ノ相違アリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟は、いつの間にか裏の空地へ行つて友達とベースボールを初めたらしくワイ／＼といふ声が聞えた。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校にいたころは、有名な運動家でベースボールなどにかけては級の中でかれに匹敵するものはなかった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えて見ると学校にいた時分は試験とベースボールで死ぬと云う事を考える暇がなかった。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠太郎と云ふ子は近頃ベースボールに熱中してゐる。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誠太郎、御前はベースボール許遣るもんだから、此頃手が大変大きくなつたよ。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校では器械体操とベースボールとに夢中になっていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "男なら角力かベースボールでも見やアがれ。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠太郎と云う子は近頃ベースボールに熱中している。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誠太郎、御前はベースボールばかり遣るもんだから、この頃手が大変大きくなったよ。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度そのころ、私の兄が町の小学校からベースボールといふものを農村に伝へ、童幼の仲間に一時小流行をしたことがあつた。",
              "citation": {
                "source": "子規と野球",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "東北地方の村の百姓は、さういふ閑をも作らず、従つて百姓間にはベースボールは流行せずにしまつた。",
              "citation": {
                "source": "子規と野球",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "正岡子規が第一高等中学にゐてベースボールをやつたのは、やはり明治廿二年頃で、松羅玉液といふ随筆の中でベースボールを論じたのは明治廿九年であつた。",
              "citation": {
                "source": "子規と野球",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ベースボールには只※一個の球あるのみ。",
              "citation": {
                "source": "子規と野球",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治卅一年、子規はベースボールの歌九首を作つた。",
              "citation": {
                "source": "子規と野球",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
