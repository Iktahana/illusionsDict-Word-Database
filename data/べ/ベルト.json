    "definitions": [
      {
        "index": 1,
        "gloss": "belt (worn around the waist)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
