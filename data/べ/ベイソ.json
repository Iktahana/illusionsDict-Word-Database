        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "以下トッテン師匠は自殺行為としか思えない米ソフトウエア産業の怠慢と不健全とをさらに指摘する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験と称して、大気中で米ソがドンパチぶっぱなす原水爆への不安に真正面から取り組んだ作品で、これが実に重苦しい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯ベルリン陥落乃至はドイツ休戦申入れをめぐって、英米ソの間にまた一波瀾ありそうだ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦隊司令パパーニン中佐」　米ソ両艦隊の海戦は、いよいよはじまった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "石細工だけで四年もかかって、五年目から山の製造にかかったが、そのころ米ソの関係も険悪の度を加え日本の諸方に米軍基地の急造が目立つようになったので、さては水爆よけの防空濠を造っているに相違ないと部落の人々は考えた。",
              "citation": {
                "source": "保久呂天皇",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "米ソの対立とか米ソ戦ということについては、私にはとても見当がつかない。",
              "citation": {
                "source": "安吾巷談",
                "author": "野坂中尉と中西伍長",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　米ソいずれに学ぶべきか　以上のような話は、いわばわかり切ったことである。",
              "citation": {
                "source": "自由と進歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "米ソ両陣営の谷間にもがいているというのは、少し極端であるが、その傾きがなくもない。",
              "citation": {
                "source": "救国論",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで北極の開発には、米ソともに、大いに力瘤を入れている。",
              "citation": {
                "source": "アラスカの氷河",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞にも、米ソ戦争などという文句が出ています！",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮は米ソ二国軍によって、樺太・千島はソ連軍によって、南洋群島は米軍によって、満州国（租借地および鉄道附属地をふくむ）は、チャイナおよびソ連軍によって、占領された。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
