        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "部屋の片隅の洋服掛に美事なタキシードが掛けてあって、その上下にベロア帽とカンガルー皮の靴と銀頂のスネーキウッドの杖が置いてある。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六一〇年頃出たベロアル・ド・ヴェルヴィルの『上達方』三九章にも似た話あって遥と面白い。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "就いて想い出すはベロアル・ド・ヴェルヴィルの『上達方』三十九章にアルサスのある地の婦女威儀を重んずる余り七日に一度しか小便せず、火曜日の朝ごとに各の身分に応じ隊伍を編み泉水に赴き各その定めの場について夥しく快げにかつ徐かにその膀胱を空くる。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベロアル・ド・ヴェルビュの『上達方』に婦人は寺で天女、宅で悪魔、牀で猴と誚り、仏経には釈尊が弟の難陀その妻と好愛甚だしきを醒まさんとて彼女の瞎雌猿に劣れるを示したと出づ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベロアル・ド・ヴェルヴィユの『上達方』に、鶏卵の笑談あまたある。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子は舶来の緑色ベロアに同じ色のリボン七｜吋四分の三。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "半身を起して足許の壁の方を見るとそこの釘に掛っているのは命よりも大事な自分のベロアの中折帽子らしい。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と鮮やかにベロアの帽子が思い浮んだでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
