        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私には纒むべき論文の想もない、また體の疲れを休めやうなどと云ふ心持もない。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "非ユークリッド幾何学の出発点がいかに常識的におかしく思われても、これを否定すべき論理は見つからない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにこじつけたくても、フィンランドの鳥獣と東京の高襟や、江戸前の鮨とを連結すべき論理の糸は見つからない。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物が火より成るとか、地水火風から成るとか、また金は金、骨は骨と、いわゆるホメオメリアより成るとか、そういう考えから来る困難を列挙し、また一方では自説に対するこれら他学派の持ち出すべき論難に対して勇敢に応戦している。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、我等の正に反省すべき論旨は別にある。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの詩人たちは、純粋に理論を重んずべき論文に就いてすらも、詩作上に於ける如き言語の表象性を濫用している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「諸君、彼は余の憎むべき論敵である。",
              "citation": {
                "source": "「風博士」",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十八歳で歿したゴーリキイが晩年においては、最も概念的であるべき論説においてさえ、ますます具体性と輝やかしい感性とをもった文章を書き、世界の文化に尽したという全く対蹠的な一事実を、心理学者は何と分析するであろうか。",
              "citation": {
                "source": "芸術が必要とする科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は首肯すべき論である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くこれを評すれば政論社会の通人ともいうべき論派なり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は爾来十余年、未だ天下に彼の如く恐るべき論客あるを知らず。",
              "citation": {
                "source": "恒藤恭氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "往々にして一部の批評家は、氏の「雑感」を支持すべき論理の欠陥を指摘する。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚くべき殆ど無鐵砲ともいふべき論の立て方である。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して予は最も無邪気にして最も信認すべき論敵を失し也。",
              "citation": {
                "source": "北村透谷君",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "一応傾聴すべき論であり、日本人の血などと称して後生大事にまもるべき血などある筈がない、と放言するあたり、いささか鬼気を感ぜしむる凄味があるのだが、私の記憶に誤りがなければ彼の夫人はフランス人の筈であり、日本人の女房があり、日本人の娘があると、却々こうは言いきれない。",
              "citation": {
                "source": "堕落論〔続堕落論〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、彼は余の憎むべき論敵である。",
              "citation": {
                "source": "風博士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは必ず到達すべき論理的結論である。",
              "citation": {
                "source": "青年に訴う",
                "author": "AUX JEUNES GENS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには 〔Georg Schu:nemann〕 ゲオルク・シューネマンの注目すべき論文が付いている。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙る血潮、みちあふれた墳墓、涙にくれてる母親、それらは恐るべき論告者である。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "一応傾聴すべき論であり、日本人の血などと称して後生大事にまもるべき血などある筈がない、と放言するあたり、いささか鬼気を感ぜしむる凄味があるのだが、私の記憶に誤りがなければ彼の夫人はイギリス人の筈であり、日本人の女房があり、日本人の娘があると、却々こうは言いきれない。",
              "citation": {
                "source": "続堕落論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは必ず到着すべき論理的結論である」　社会主義者の中に俺は身を投じたいと思った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾聴すべき論文であつた。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
