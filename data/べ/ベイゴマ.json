    "definitions": [
      {
        "index": 1,
        "gloss": "spinning top (traditionally made of Japanese Babylon shell)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その日大阪おばあさんが学校にきて、私が我儘で家の者の云うことをきかず、また日頃｜貝独楽やめんこ遊びに夢中になっているということを先生に告げたのであった。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "貝独楽やめんこ遊びは良い子のすることではないと私も思っていたから。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しい貝がらもあれば、金光りのする石もあり、また釣りの道具もまじっていれば、形の変わったべいごまもはいっていました。",
              "citation": {
                "source": "すいれんは咲いたが",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　頭を、かしげながら、ほこりに、よごれた紙を、あけてみると、べいごまが、六つばかり入っていました。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年の春あたりまで、べいごまが、はやって、これを持って原っぱへ、いったものです。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "べいごまを、ふところへ入れると、赤土の原っぱをさして、出かけていきました。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま善ちゃんや、勇ちゃんや、信ちゃんたちが、べいごまをするのに、ござがなくなってこまっているのを見て、しまっておいたござを、思い出したのです。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きっと、善ちゃん、べいごまのことだよ。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、ぼくの子供の時分には、べいごまなどというようなものは見なかった。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
