        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ラスベガスで開かれた家電製品の展示会、コンシューマー・エレクトロニクス・ショーでのことだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ベガ――……競馬の広告だ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八二年十一月、ロータスディベロップメントはラスベガスで開かれた秋のコムデックスで１―２―３を発表した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パロアルト研究所からマイクロソフトに引き抜かれてマルチプランの開発にあたったチャールズ・シモニーは、ラスベガスで開かれた一九八二年秋のコムデックスの会場で、ロータスディベロップメントの１―２―３とビジコープのＶｉｓｉＯｎに衝撃を受けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空の丁度ま上に見える琴座の一等星ベガ一名織女星を目がけて、グングン高くのぼり始めた。",
              "citation": {
                "source": "月世界探険記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "進路がベガに向けられて、早や三日目になった。",
              "citation": {
                "source": "月世界探険記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、全市の電気をボルダー・ダムの発電所から全部供給されているラスベガスの町は、アメリカでも最も電力の安い町の一つになっている。",
              "citation": {
                "source": "アメリカの沙漠",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
