        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜中、何者かがこの部屋をうろついているらしく、時に居間とベッドサイドを行ったり来たりしながら、私のことをじろじろ見るのだ。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は予後判定にとくに注目して「最良の医師は、まずベッドサイドにおいて患者の現在、過去および将来を見抜き明らかにし、患者たちが発言で省略したものを追加することにより、予後判定ができる者である。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドサイド、実験室、書斎の書き物机と場所は違っても彼らはすべて同じであり医師であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドサイドで臨床を習った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい学問が実際の場面すなわちベッドサイドで臨床にほとんど役立たないことはバリヴィの行動にはっきりと示された。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以後になると医者が患者を診てベッドサイドにおいて行う最初の任務は診断であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "親しく接触した人、ベッドサイドで彼を見て話を聴いた人は誰でもその影響を振り切ることができず神聖な火は一生のあいだ燃え続けて理想的な医師像を目の前に持つことになったであろう。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人のベッドサイドで彼の個性はすべて示されていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者のベッドサイドで理論は表面に出ない。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者のベッドサイドの医師はそこで進行していることをヒポクラテスが観察したように出来るだけ精確に観察するべきであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの始まりは病人のベッドサイドではなく書斎であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学を病人のベッドサイドからではなく本からのみ学ぼうとする人は絵や彫像を文章の記載で知ろうとする人と同じである」と。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人のベッドサイドではなく実験室がシンボルになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスの医師たちは患者のベッドサイドで病気を学び研究室で死体解剖を行っていた時にドイツの医師たちは机に向かって病気および全世界の性質について論文を書いていた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし研究室や患者のベッドサイドで研究が進められている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人・小説家・随筆作者として著名であり特に随筆の「朝の食卓」シリーズはオスラーが10編のベッドサイドライブラリーとして医療関係者が読むべき本としてあげたうちの１つである。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
