    },
    "definitions": [
      {
        "index": 1,
        "gloss": "urge to defecate (or urinate)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "丁度学生が試験を受けに出るときに、どうかすると便意を催すのと同じ事である。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間を合わせておくと不意の来客に妨げられるし、幾時の汽車に乗ろうと思って急ぐと急に便意を催す。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は下痢で悩んでいたので、熊本まで五時間のバスの中で便意を催したらどうしたらいいのかと人に云えない苦労のために意気銷沈していたのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "便意を催して厠に入っているうち、俄に芸術を覚えだして、懐中からナイフを取り出すと、前面の板戸へ日頃得意とする男女愛欲図を、等身大に彫りはじめた。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "消毒薬の臭ひのこもつた薄くらがりのなかで、少年は便意を失くしてしまふ。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その晩もアルコオルがきれたので、こういうことだけはパンクチェアルに、しくしく便意を催おしはじめた。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっぴきならねえ用でもあるなら格別、そうしてごろごろしている暇がありゃ、両方へ二、三べんいってこられるんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "相馬　　なんべんいつてもおんなじだが、君を松沢に会はせようといふのは、ただ学校の復旧資金を……。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後何べんいっても師匠は会ってくれなかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何べんいいましても、とても勘定しきれしめエん。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
