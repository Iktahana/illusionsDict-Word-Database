[
  {
    "uuid": "0df445bb-42a2-586a-bdf9-df89e9143b5e",
    "entry": "便意",
    "reading": {
      "primary": "べんい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
