[
  {
    "uuid": "112f45b3-c44c-5c55-8425-34238d945cc9",
    "entry": "便",
    "reading": {
      "primary": "べん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
