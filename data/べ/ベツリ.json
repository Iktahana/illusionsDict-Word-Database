        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしながら運命が、不幸にも我々を別離させた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛別離苦の悲しみと偉大なものに生命を賭ける壮烈な想いとで翁の腸は一ねじり捩れた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その愛別離苦の悲しみや壮烈な想いで、わしの腸はこんなに螺の貝のように捻じ巻いたのじゃないか」と山の祖神の翁は負けん気の声を振り立てていった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が朝鮮へ行かなければならなくなりましたのは、男女の哀別離苦の情、目もあてられぬほどのものでありました。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしとにかく二人ははたで見る目も無惨な哀別離苦のかぎりをつくし、かたく再会を約して別れました。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はその腕を闇の方へ向けて私にそれを振つて見せながら、私がお前から切り離して自分と一しよに持つて來たものを私から更に切り離して、逃げて行つてしまはせた……お前のその別離の手振りは、永い別離の印なのではなかつただらうか？",
              "citation": {
                "source": "窓",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドン停車場に於ける別離が妾達の永遠のお別れとなったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "また絶えず石炭を積み込む荷揚ロープの緩急が打ち寄せる波の音と和して、消燈された甲板のゴルフ棒の蔭で船員と港の土人街の女とが抱擁して別離を悲しんでいる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が一緒に日本へ行きたいと訴えるのだが、船人のたくましい腕の絆も別離が切って落す。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジェステック・ホテルの一室には、南北戦に於て南軍が明光を占領、定遠の包囲攻撃の報を得て徐州に迫る南軍の総師として戦線に出る蒋介石が、寝間着姿の婚約者と別離の笑談を交していたのが暗に紛れて潜かに租界の安全地帯に逃れた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の離れることのできぬ別離も、数年後再び我々の陽光の下で俺達は嬉しい邂逅ができることを俺は信ずるのだ！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は彼の岩石のような胸に爆弾を装置しながら別離の接吻をした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジェステック・ホテルの一室には、南北戦に於て南軍が明光を占領、定遠の包囲攻撃の報を得て徐州に迫る南軍の総帥として戦線に出る蒋介石が、寝間着姿の婚約者と別離の笑談を交していたのが暗に紛れて潜かに租界の安全地帯に逃れた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "別離苦に一目てえんでたった一人｜駈出してさ、吹雪｜僵になったんだとよ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜怒愛憎の高潮に伴なう涙は理知や道徳などとは関係の薄い情緒的のものであるが、哀別離苦の焦心の涙にはよほど本能的なものがあって、純粋な肉体の苦痛によるものとかなりまで相通ずるものがありそうに思われる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田島は、そこへ、一週間にいちどくらい、みなの都合のいいような日に、電話をかけて連絡をして、そうしてどこかで落ち合せ、二人そろって別離の相手の女のところへ向って行進することをキヌ子と約す。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、別離は、くるしい。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "別離の行進は、それから後の事だ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ただ兄をこわがって、いつまでもケイ子との別離をためらっているのは、ケイ子に対しても失礼みたいなものだ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私……もう御別離をお見送り申し旁々、せめて、この橋まで一所に来て、優しい事を二人でして、活きものの喜ぶのを見たかったんですけれども、二人ばかりの朧夜は、軒続きを歩行くのさえ謹まねばならないように、もう久しい間……私ねえ、躾けられているもんですから、情ないのよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月を見て、面影に代ゆべくは、誰かまた哀別離苦を言ふものぞ。",
              "citation": {
                "source": "芥川龍之介氏を弔ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ母親の死を悲み別離に泣きし涙の今なお双頬に懸れるを光陰の手も拭い去るあたわざるなりけり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この父と子と突然に別離を告げたのである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも尋常一様の別離でない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十八）　山椿の下では、お葉と重太郎との詩的な別離があった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何人も返答に苦む所であるが、兎にかく此の物語はお葉と重太郎の最期を一段落として、読者と別離を告げねばならぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いが、相手の真価を発見して行くためにも、次々の危機に打ち勝って、別離せずに結婚をし直し、進まなければならぬ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
