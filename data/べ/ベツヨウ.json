  {
    "uuid": "1b37c00a-dd82-52ec-b6ae-61f29bb5c4e7",
    "entry": "別用",
    "reading": {
      "primary": "べつよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
