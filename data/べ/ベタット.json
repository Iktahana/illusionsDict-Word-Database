        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "学生の間に流行っているらしい太いズボン、変にべたっとした赤靴。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子の桟には埃がべたっとへばりつき、便所には蜘妹の巣がいくつもかかったまゝ、押入には汚れ物が一杯押しこまれていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の露が紺ヘルのズボンを透して、べたっと尻にへばりつき、気持がわるかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と思ったって間に合わねェ、知らねェで運転して車庫の検査で、めっけたって奴もあるぜ源さんの来る前にいたもんだがね、見ると輪のところへ、ひらひらしたもんがくっ附いている、さわったが落ちねえ、ぐっと引っ張ったら、べたっと手についたんだ『わッ！",
              "citation": {
                "source": "鉄路",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○そして男同胞の love affair などに加担する、ぜいたくする、ゴタゴタの花をいけたりする、横坐りになって　べたっとして横目つかう。",
              "citation": {
                "source": "バルザック",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は呼吸せわしく長いこと掻きまわしていたが、べたっと尻餅をついた。",
              "citation": {
                "source": "とも喰い",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなあんばいに、わっしの面へペンキをべたっとつけて、逃げ出しやがったんで、わっしもそのあとを追っかけて行きました。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしっ……僧正様ッ、おねがいでござりますっ」突然、一人の男が壇の前へ飛びだしてきて、べたっと、手をつかえた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」老人は開いた口をしばらくそのまま、「…………」小皺の中の眼をこらして、いつまでもいつまでも性善坊の顔を見つめ、一転して、その側にきちんと坐っている範宴の姿を見て、「や、や、や……」萱乃の襟がみから手を離して、そこへ、べたっと坐ってしまった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、あ……」　露八は、一日の根気をいちどに疲らして、荷梱の下へ、べたっと、坐ってしまった。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉松の根元へ、濡れ仏のように、べたっと坐り込んでいた老母の顔は、途端にさっと蒼ざめた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "力まかせに引ッぱり上げると、ばばは、雑巾のようにべたっと坐って、「今の男は、もう何処ぞへ走ってしもうたか」　と、小次郎の問いたいことを、却って問う。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この衝立は、そも、誰の指図で出しなされた』　孫太夫は、べたっと、板敷へ両手をついて、『おそれながら、申し上げまする。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ゆるして下されい、内匠頭どの』　懐紙を取り出して、つつむように顔へ押し当てると、梶川は、老の弱腰を、べたっと下へくずしてしまった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅野内匠頭儀、吉良上野介ヘ刃傷ニ及両人共｜取糺中ニ付｜諸供方騒動致ス間敷者也一番｜早駕『や、やッ』　堀部と、赤埴の二人は、掲示の下に、べたっと、腰をぬかしてしまった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "召使が、背に負って畳の上まで運んだ程で、その畳へ、べたっと手を落すと、『ああ……』　あやうくそのまま意識を失ってしまいそうにすら見える。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆ、ゆるしてくれ』　肱まで、べたっと畳へついて、郡兵衛は訴えた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は勢いよく、一歩外へ出てから、べたっと坐ってしまった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
