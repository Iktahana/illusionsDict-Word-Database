[
  {
    "uuid": "b6808e49-3a7f-5966-b873-ab68104b3409",
    "entry": "便じる",
    "reading": {
      "primary": "べんじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to satisfy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして私もまた自分の職業を以て一家の経済を便じることに苦心して来た。",
              "citation": {
                "source": "鏡心灯語　抄",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に用を便じるのに必要であるとか、口が利ければ勢ひ日本人に馴れ親しむとかいふ直接の効果も十分考へられるが、それだけならこつちが支那語を覚へさへすればおんなじ理窟である。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは人間の通行という用のみに便じる道ではなくて、道を歩くこと自体が遊びであり、あッちの店をのぞき、こッちの店へ色目をつかい、ノンビリ行楽するところである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう用を便じるために、入場券だけは買う。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "炊事は千種が引受けることにしたが、雑用を便じるため、特に、土地の案内人として土人を二人傭ひ入れた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
