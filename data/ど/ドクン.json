          "literary": [
            {
              "text": "酌いどくんねえ、酌いどくんねえ、」「可いから、まあおあがんなさい。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、おとなしく、むこういって、郁子でも、くどくんだな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの異人さん来ましたよ」　百代は、胸がどくん、と鳴るような気がした。",
              "citation": {
                "source": "部屋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの幹は丈夫ですし、それにあと一伸びすればガラス屋根にとどくんですわ。",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "対手の肩口の着物が、胸の下まで、切り裂けて、赤黒い血が、どくんどくんと、浪打ちつつ噴き出していた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとのことはあてがあんじようしますさかい、ぼんぼん連れていんどくんなはれ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今｜直に御膳を持つて來させるよつて、飯喰べたらいんどくんなれや。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、穴からどくんどくんと光をおびたきれいな水かこぼれ落ちた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "原則からいうと、無限大の距離でもとどくんだが、まだすこし集めて一本にする技術が完全というところまでいっていないので、まず、四、五千メートル以内なら有効にはたらく」「四、五千メートルまでなら、じゅうぶん使い道がありますよ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうあと百キロばかり間をつめることができれば、ガス弾がとどくんだがなあ」「ほう、あと百キロですか」　すると、千二が、測距機で、彼と我との間を読んで、「ええ、丸木艇は、百三十キロのところをとんでいますよ」「ふふん、そうか。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、あたしは、ユラさんに頼んどくんだが、ひとつ、リキさんは、この催しについて、どう思ふか。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）すると――そんなら、あたしのを繋ぎませう――つてメリンスの、赤い帯をほどくんだ。",
              "citation": {
                "source": "ぶらんこ（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫　　ほどくんだよ。",
              "citation": {
                "source": "ぶらんこ（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知るや知らずや、主人は別段重箱を取り出す気色もなく、ただお茶などくんで待遇していた。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
