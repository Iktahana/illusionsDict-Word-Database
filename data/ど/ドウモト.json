    "definitions": [
      {
        "index": 1,
        "gloss": "banker (gambling)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
