        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おゆきの住居や習慣は、樋口一葉が「にごりえ」などでかいた雰囲気の中のものだった。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにローランド社のどでかいシンセサイザーまで鎮座ましましている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どでかい新しいことをやろうと、いま石橋の中央に要石を入れるところだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうか、どこかに、どでかい財産がある。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
