        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少々の銭を残してやるよりや、教育をつけてやっとく方が、どんだけ為めになるやら分らせん。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十円もあったら、ふんとにどんだけ楽だかわかんねえのにさ。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体どうしたんです」「きのうのお午すぎに仲働きのお竹どんを連れて、浅草の観音様へお詣りに行ったんですが、途中でお菊さんにはぐれてしまって、お竹どんだけがぼんやり帰って来たんです」「きのうの午過ぎ……」と、半七も顔をしかめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒げにしょんぼりとして、うどんだけ食している容子に厶ります」「やはりここも次第に寂れが見ゆるな。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ甚兵衛どんだけが、正直でずけずけいうてしもうたんじゃけにのう。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんだけ寄り込んだもんだかね。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長うなりますから、省きますけンど、和武の鑑定の事につきましては、砂山さんと二人で、どんだけ苦労したやら知れまへン。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの爆弾や機械掃射なら油断さえしておらなければまず大丈夫だが、今度のぴかどんだけはまったく対策がないのだ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の年寄り連中のなかには、いや、たまにや若いもんのなかにもさういふのがゐるだが、ここへ別荘地ができたおかげで、このへん一帯の百姓がどんだけ潤ふたかわからんといふもんがある。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしどもの力でどんだけのことができるか、それはわからんけんどが、わしどもは日本の農村をどうせにやならんかといふことを真剣に考へて、夜昼働いとるだ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "金吾　と、とんでもねえ――俺あ、どんだけ助かっているかしれねえんだ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花岡　おれがつかまると、どんだけ、えらいことになるか知らないから、君あそんなことをいってるんだ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい」「じゃあ、どんだけだ？",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんだけか教えてやる。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "「男と言つても、扇三郎さんと八百吉どんだけ」「その扇三郎は三十そこ／＼の若さぢやないか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の祕薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりぐらしの気らくさや、やとい人を遠ざけさえすれば、奥のひと間にいるのは、自分とあんどんだけ。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは一番役に立たないから、却ってすまないと思っているのに」「あんたがいるけに、どんだけ心づよいかしれん」　登代は、心に何か切ないものがあって、皆の働いている午後、こうしてひろ子一人の二階へ上って来た。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんだけの人間がたまっているかしれんのに、第一、ベンチなんかあるものですか。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「石田と申します、思いがけず大変御厄介になりまして……」「いやいや、わたしの方が、どんだけお世話になったかしれません」　眼の不自由なその人は、広島辺の、同じ会社の支店長をしているのであった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "せい　先生はたいした事はなくっても、双葉さん、また、どんだけ心配なさるか――ちったあ、それ、考えておあげんならなきゃ、あなた――柴田　はは、なにさ――清水　なんでしたら、自分が埋めましょうか？",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "双葉　ちい兄さん――私たちが、ちい兄さんの事、どんだけなにしているか――欣二　離せよ。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中、兄さんが引っぱられていた一年半の間、信姉さんと双葉がどんだけ苦しんで、どんだけ死ぬような思いをして此の家を支えて来たかさえも、兄さんは知りゃしないんだ。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブローカァーや御用商人や、そいからエタイのしれない人たちが、コソコソやって来ちゃ、金だとか物だとか置いて行くだけでも、どんだけだか知れないのよ。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「文治どんだけでした――それから庭男の久六」「文治は泳ぎはうまいと言つたね」「――」　お勢は默つてしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青葉の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィラが二人の為にどんだけ苦しんだか、忘れないでほしい。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
