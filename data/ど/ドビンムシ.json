        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "松茸の香りが食欲をそそる土瓶蒸しは、秋の味覚の代表だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "料亭で上品な味の土瓶蒸しを堪能した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寒い日には、温かい土瓶蒸しが体に染みわたる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「どれ、もう一唸り唸つて、早松の土瓶蒸しでパイ一行くとしようかい。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松茸は土瓶蒸しに限りますなア。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、數之介はまた土瓶蒸しの松茸を狙つてゐた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
