    "definitions": [
      {
        "index": 1,
        "gloss": "fish large enough to swallow a whole boat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
