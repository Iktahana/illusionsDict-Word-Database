        "examples": {
          "standard": [
            {
              "text": "この街のどこら辺に美味しいレストランがありますか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は今、仕事でどこら辺を回っているの？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地図上のどこら辺を指しているのか教えてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「ちょっとお訊ねいたしますが、刑部屋敷と申します屋敷は、どこら辺りでござりましょうか？",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那様のすぐお側に住んでいる者でございますよ」「ついぞ見掛けぬ仁態じゃが、どこら辺りに住んでいるな？",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「百姓のじじいみたようだが、いやに威厳があるじゃないか、ここの女あるじの正躰もわからないし、いったい甘利なんという処は、どこらへんにあるのかな」「見ず聞かず云わず」　同僚が肩をすくめて答えた。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
