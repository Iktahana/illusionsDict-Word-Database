    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bronze color",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶どきと見え青い茶が乾してあったり、茶師の赤銅色の裸体が燻んだ色の町に目立っていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は、この突然の闖入者の濃い髯でかくれた、中年の苦悩に刻まれた古銅色の顔、霜枯れた衣服の下で凍った靴に、死人のような膚が覗いているのを見た。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテル・マンションには、青銅色の秋が訪れていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの美しい緑色は見えなくなって、※びたひわ茶色の金属光沢を見せたが、腹の美しい赤銅色はそのままに見られた。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は、通りと同様に、赤銅色に塵埃をあびていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半信半疑で警戒を怠らなかった赤銅色の売手は、店をたゝむひまもなしに、忽ち、中山服に取りまかれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの通りの銅色の顔をして無心に藻草の中をあさっている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅色をした太陽が今ちょうど子午線を横切っているのだが、地平線からの高度が心細いように低い。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅色の太陽がもうよほど低く垂れ下がって、葉をふるった白樺の梢にぐるりぐるりと廻っているように見えた。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍らを見ると叔父さんは酒がまわったか銅色の顔を日の方に向けたままグウグウといびきをかいていた。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰が薄れると太陽が銅色や卵黄色に見えた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば其光の顫音は悲しく、氏の銅色の額に反射した。",
              "citation": {
                "source": "北原白秋氏の肖像",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘りに年の寄つた銅色の顏の老爺が火鉢の縁を指先で撫でながら何も知らぬやうに俯いてゐた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るからに気候風吹く空の果銅色のうろこ雲｜湿潤に燃えて恒河の鰐の脊のごとはらばへど、日は爛れ、大地はあはれ柚色の熱黄疸の苦痛に吐息も得せず。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚空には銅色の日の髑髏転びかがやき、雲はまた血のごと沈黙に鎔けゆき影だに留めず。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頭には乗っかる、突き飛ばす、赤銅色の漁師の腕はすり抜ける、嚊衆の洗濯物はばたつかす。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、かの人種の皮膚は銅色がちの鳶色だとジョン・バチェラー氏はいった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の波濤は穂がしら白く、内のとろみは乳黄で、またやや光った銅色で、閑かなようでもどうにもならない澱みがある。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "老爺は六尺に近い大男で、此｜年齡になつても腰も屈らず、無病息災、頭顱が美事に禿げてゐて、赤銅色の顏に、左の眼が盲れてゐた。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅色の、逞ましい、逞ましい老爺の顏！",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の白髯を集めて作った兜の飾り毛を風に靡かせ、獣歯の頸掛をつけた・身長六｜呎五｜吋の筋骨隆々たる赤銅色の戦士達の正装姿は、全く圧倒的である。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅色の戦士を満載して風上から入港して来るボートの群。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………　老酋長の一人が、赤銅色の皺だらけの顔に涙の筋を見せながら、――生の歓びに酔いしれる南国人の・それ故にこそ、死に対して抱く絶望的な哀傷を以て――低く眩いた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅色に近い・紅く濁った月である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時かの夜夢に起されて公宮の露台から見たのとまるでそっくりの赤銅色に濁った月である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事に赤銅色をした逞しい男が、眞赤な褌一つで漕いで來る。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の顏色は例によつて生々と、或ひはテラ／＼と茶褐色に飽く迄光り輝き、短い袖からは鬼をもひしぎさうな赤銅色の太い腕が逞しく出てをり、圓柱の如き脚の下で、靴の細く高い踵が折れさうに見えた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅色に近い・紅く濁つた月である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時かの夜夢に起されて公宮の露臺から見たのとまるでそつくりの赤銅色に濁つた月である。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
