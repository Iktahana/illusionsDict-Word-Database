  {
    "uuid": "cdf1b432-804a-5e89-b3b2-8c373fb3ff48",
    "entry": "銅色",
    "reading": {
      "primary": "どうしょく",
      "alternatives": [
        "あかがねいろ",
        "どういろ"
      ],
      "is_heteronym": true
    },
    "grammar": {
