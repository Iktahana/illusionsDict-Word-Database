          "standard": [],
          "literary": [
            {
              "text": "※２　顔料＝亜砒酸を使った、毒性の強いパリグリーン（エメラルドグリーン）を指す。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると、毒蛾の鱗粉は顕微鏡で見ると、まるで槍の穂のやうに鋭いといふこと、その毒性は或いは有機酸のためと云ふが、それ丈けとも思はれないといふこと、予防法としては鱗粉がついたら、まづ強く擦って拭き取るのが一等だといふやうなことがわかるのでした。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はそんな信吉の毒性を知らない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人種の血脈に、一種の醜惡な人種病が遺傳されて居るやうに、思ふに『良心』とは、我我人類の先祖の腦神經系統を犯した一種の黴毒性疾患が、われわれ末代の子孫にまで執念ぶかく遺傳したものに外ならないのであらう。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心とはくさりかかつた腦黴毒性の疾患である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな毒性な物の言い方する奴あるか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんまにけちんぼやぜ」「そない毒性な言い方しイな。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、時々、その活き活きした目がかすむのを井筒屋のお貞が悪口で、黴毒性のそこひが出るのだと聴いていたのが、今さら思い出されて、僕はぞッとした。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒であるが、因果と私はこれと離るゝ事が出來ず、既に中毒性の病氣見たいになつてゐるので殆んどもうその質のよしあしなどを言ふ資格はなくなつてゐると言つていゝ、朝先づ一本か二本のそれが濟まなくてはどうしても飯に手がつけられない。",
              "citation": {
                "source": "樹木とその葉",
                "author": "草鞋の話旅の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達は肉桂の根を噛むことの刺戟に、中毒性を覚えてゐるかのやうであつた。",
              "citation": {
                "source": "肉桂樹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、これは大秘密であるけれど、大熊老人は生前に於て、ひそかに喜助の手を借りて毒薬｜亜砒酸を常用していたが、それは多分、抗毒性の体質をつくりだすことにあったのであろうが、それは実際、老人にとってどんな役目を演じていたのであろうか。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあのとおり七人が七人やられてしまったんだ』『ほほう、そうかね』『このホスゲンは、相当濃かったので猛毒性をもっていた。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十分も嗅いでいれば、充分昏倒するぐらいの毒性はあったと認める。",
              "citation": {
                "source": "街の探偵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "又蟇石と称する宝石は蜘蛛やその他毒性の動物に嚼まれたとき、その疼痛を消すと伝へられて居る。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやうな場合は毒性の極めて強い毒が極少量に入つた場合であるらしい。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、突如として、上海に猛烈な毒性を有するコレラが発生したという報知が伝わった。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒性が極めて強かったためであろう、一回や二回の予防注射は何の効も奏せず、人々は極度に恐怖した。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年のは毒性が強いから、四時間で発病すると医者が言ったのよ。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃその尿毒性とやらになりますと、もうむずかしいんでございますか？",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう疑いなく尿毒性と診断したんです！",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしほかの医者は、どうまた違った意見があるかも分りません」「それで何でございましょうか、先生のお見立て通りでございましたら……あの、尿毒性とやら申すのでございましたら……」とお光はもうオロオロしている。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尿毒性であると、よほどこれは危険で……お上さん、私は気安めを言うのはかえって不深切と思うから、本当のことを言って上げるが、もし尿毒性に違いないとすると、まずむずかしいものと思わねばなりませんぞ！",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お時さんのお父つあんも、毒性な人や、手付けだけ取つといて、尻食ひ觀音はなア。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "然りといえども、馬はなお、その物の毒性なるか良性なるかを弁ずるの能力を有す。",
              "citation": {
                "source": "物理学の要用",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、二川子爵は全然私達の薬局に備えつけてないような猛毒性のアルカロイドを摂取しておられるんですよ」「解剖の結果、分ったのですか」「えゝ」　と、この時に野村は重大な事を思い出した。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度分を一｜時に呑まれましたよ」「然し――」　そういう猛毒性の立どころに死ぬような毒薬を煽った者が、今更一回分の催眠剤を追加して見た所で仕方のない事ではないか。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には瓦斯がどれ位の毒性のあるものか、正確な知識はないが、この部屋にこのガス管から一時間半噴出したとして、或いは知覚を失うとか、半死の状態にあるとか、仮死の状態になるとかいう事はあり得るかも知れないが、その時間内に絶命するという事はどうかと思われるのだ。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか、ひどくせいのひくい、子どもみたいなやつです。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
