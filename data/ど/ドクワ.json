[
  {
    "uuid": "7051c4ec-5e61-5876-95d2-e71eeb37c356",
    "entry": "独和",
    "reading": {
      "primary": "どくわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
