        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その日は土曜日で、朝からよく晴れていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、最も平凡で簡單で最も有效な解決法としては、自分のやうなものは土曜日曜祭日などにかういふ處へ行かないやうにすればよいのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうだとすると、矢張り土曜日に出かけて人に揉まれに行く方が存外いゝ事になるかも知れない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二伸、――私は、土曜日に、ホオリンゲンの館のすばらしい小徑をさまよひながら、あなたのために、こんなストロフを作りました。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、今度の土曜日に。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから巴里に着きましたら、私は土曜日に貴方のアトリエを御訪問いたすやうにします。",
              "citation": {
                "source": "リルケ書翰（ロダン宛）",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の土曜日に天気ぁ好がったら又おれぁ迎ぃに行がはんてなぃ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち月曜日には孟子、火曜日には詩経、水曜日には大学、木曜日には文章規範、金曜日には何、土曜日には何というようになって居るので、易いものは学力の低い人達の為、むずかしいものは学力の発達して居るもののためという理窟なのです。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "土曜日に尾張町へ泊まりに行くと明るくて暖かでにぎやか過ぎて神経が疲れたが、谷中へ帰るとまた暗く、寒く、どうかすると寒の雨降る夜中ごろにみかん箱のようなものに赤ん坊のなきがらを収めたさびしいお弔いが来たりした。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢田先生は、土曜日毎にお見えになり、私の勉強室でひそひそ、なんとも馬鹿らしい事ばかりおっしゃるので、私は、いやでなりませんでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では宿題帳はこの次の土曜日に直して渡しますから、きょう持って来なかった人は、あしたきっと忘れないで持って来てください。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで土曜日に私は藤原｜慶次郎にその話をしました。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七つの落ち葉の山、六つまで焼きて土曜日の夜はただ一つを余しぬ。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ土曜日の晩だから、宴会客で店中が湧くやうだつたのだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い年月が過ぎて行った一夏、日比野皆三博士が、学生たちを指導している間、葉山の別荘に夫人の涌子は子供たちと避暑に来ていて、土曜日毎に油壺から帰って来る良人を待受けていた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、土曜日なんで、」「そうか、」と謂い棄てて少年はずッと入った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで土曜日に私は藤原慶次郎にその話をしました。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春のせいか、土曜日のせいか、いやらしいくらいの雑閙だ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、或る土曜日の夕刻から、智子は初めて浅原を晩餐に招いて、母親とひき合せた。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の土曜日の夕方だった。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、今度の土曜日に、ここへ来てくださいませね」と、お姫さまは言いました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお話は、土曜日までに、作りあげなければなりません。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、土曜日になりました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "土曜日「さあ、お話してね」ヤルマールは、オーレ・ルゲイエに寝床へ連れていってもらうと、すぐに、こう言いました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い年月が過ぎて行つた一夏、日比野皆三博士が、学生たちを指導してゐる間、葉山の別荘に夫人の涌子は子供たちと避暑に来てゐて、土曜日｜毎に油壺から帰つて来る良人を待受けてゐた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど母も姉も湯治からかへることになつて、その出立の日が、あたかも土曜日であつたから、私は母たちを送つて行くといふ名目で、故郷へ戻ることが出來た。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は土曜日で、朝からよく晴れてゐた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは、土曜日である。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　周さんは、さらにくわしく説明して、藤野先生が、あの最初の解剖学の発達に就いて講義をなされて、それから一週間ほど経って、たしか土曜日だった、先生の助手が周さんを呼びに来たので、研究室へ行ってみると、先生はれいの人骨のむれに取りかこまれ、にこにこ笑いながら、「君は、私の講義が筆記できますか？",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むいかめは　どようびで　りすたちが　くるのも　これで　さいご。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
