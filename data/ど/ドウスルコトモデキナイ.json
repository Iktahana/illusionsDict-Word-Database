[
  {
    "uuid": "68d4fb55-98a9-5146-b949-3dee0249999a",
    "entry": "どうする事も出来ない",
    "reading": {
      "primary": "どうすることもできない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "形容詞"
      ],
