        "examples": {
          "standard": [
            {
              "text": "娘はクリスマスに新しいドールハウスをもらい、夢中になって遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "緻密に作られたミニチュア家具が並ぶドールハウスは、芸術品のようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔、私も小さなドールハウスを作って遊んだ記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ドールハウスは　だんろの　むかいに　ありました。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドールハウスの　もちぬしの　おんなのこは　いいました　――「おまわりさんの　かっこうした　おにんぎょうを　すえなくちゃ！",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして　まいにち　あさはやく　――　だれも　おきないうちに　――　もぐもぐハンカは　ちりとりと　ほうきを　もってきて　ドールハウスの　おそうじを　するのでした。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            }
          ]
        }
