[
  {
    "uuid": "04b79825-3164-5864-86ac-941ac61d7054",
    "entry": "独身",
    "reading": {
      "primary": "どくしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unmarried",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひどいのになると、独身だか妻帯者だか、わからない人物もあります。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "独身者同様の村上は時にこうして十五ばかり年下の山崎と会食をしながら寛いだ気もちで談笑するのが好きであった。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　紅雀　年を取った独身の兄と妹が孤児院の女の児を引取って育てる。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "独身者であることはたしかだが職業は誰にも判らず、店ではいつか先生と呼び馴れていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――貴方がおわらいになるのも無理もないのですが、しかし赤丸平家は日本の独身者の集合所なのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、夙川のアパートメントの独身部屋をノックする音で私は眼ざめました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がもし壮年の時から老人の時まで、純然たる独身生活すなわち親子兄弟の関係からも離れてただ一人、今の社会に住むなら並み大抵の人は河田翁と同様の運命に陥りはせまいか、老いてますます富みかつ栄えるものだろうか。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つは、遠い昔に妻をうしなって久しく独身の生活をつづけていた彼は、江戸へくる途中からすでにお万を自分の物にしていたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、あの人は、まだ独身者ですよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは、しかし、独身では無い。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "独身どころか、いまの細君は後妻である。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも言ったように、田島は女に対して律儀な一面も持っていて、いまだ女に、自分が独身だなどとウソをついた事が無い。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子は、それに遺憾の気持ちが多かったため、かなり沢山招かれた花嫁の友人の皆が既婚者であり、自分一人が独身であったということさえ、あまり気にならなかった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って傍の者達が、室子一人の独身であることを意識してかかっている様子を見せたり、おしゃまな級友は、口に出して遠廻しに、あまり相手を選み過ぎるからだなどと非難した。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の苦労に難んでいる人に独身者の慰めはあまり力になりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一人の独身の絵画の老大家が巴里に住んでいました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあるとき皆三の母親から聞いた皆三の、当分独身といった言葉は、皆三の性格としては、もっともと思えるが「何という意気地なし」というような言葉で、皆三を思い切り罵倒してやり度い気持ちがお涌に湧然として来た。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "病みつきましたのは、雪にござった、独身の御老体で。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ときめつけられて詮方なく一散に駈け出し、口の裡で、「御自分が独身だと思って、ちとお焼芋の方だ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえさんの壮年で、独身で、情婦がないなんて、ほんとに男子の恥辱だよ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は清川お通とて、親も兄弟もあらぬ独身なるが、家を同じくする者とては、わずかに一｜人の老媼あるのみ、これその婢なり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "独身の彼は弟子たちの手に因ってその亡骸をここに葬られた。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お杉は此の駅尽頭の蕎麦屋の娘で、飛騨小町と謳われる程の美人であったが、何ういう訳か不思議に縁遠いので、三十に近いまで独身で過した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門という人は、そのころ四十四、五で、御新造には先年死に別れたというので独身でした。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本業は漁師であるが、少しく風変わりの男で、若いときに一度は女房を持ったが、なにか気に入らないというので離縁してしまって、それから後は五十を越すまで独身で押し通して来た。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その友人は独身だったが、案外細君を貰っているかも知れない。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんば独身にせよ、たしか妹がいた筈だ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――女房の相手は、さっき言った蜂谷重吉という男ですが、こいつはあたしの中学時代からの親友で、一風変った男でしてね、もう四十を過ぎているのに、結婚しようとせず、いまだに独身で通してるんです。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、そういう縁遠い小姑が二人もいては、永助には嫁の来手があるまいと、永助の独身までが目立ち、ここでは彼の若さも通らなかったわけだ。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十二歳だが、客を相手に枢密院の話などする理屈っぽさは、しかしいかにも独身者めいていた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
