    "definitions": [
      {
        "index": 1,
        "gloss": "muddy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大めし食って、食後の運動のつもりであろうか、下駄をおもちゃにして無残に噛み破り、庭に干してある洗濯物を要らぬ世話して引きずりおろし、泥まみれにする。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "手袋も上衣もズボンもそれからマントも、泥まみれになつてゐる。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手袋も上衣もズボンもそれからマントも、泥まみれになっている。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の日など泥まみれの足を手ぬぐいでごしごしふいて上がるのはいいが絹の座ぶとんにすわらされるのに気が引けた記憶がある。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当に世に認められる仕事をするには、何か自分の得意とするもの、あるいは自分に振り当てられた仕事に就いて、塹壕戦のつもりで、自分の身形や他人からの悪口を気にせず、また躍り上る浮気心や他人のお世辞にのぼせ上らずに、埃だらけ泥まみれになって努力し続けなければ駄目でしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな埃だらけ、泥まみれになってまで成功しようと思わぬ人は、何も強いてそうする必要はありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時の汽車には間に合ったが、さて乗り込んだところが連日の強行軍で洋服は泥まみれ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "素足に染まって、その紅いのが映りそうなのに、藤色の緒の重い厚ぼったい駒下駄、泥まみれなのを、弱々と内輪に揃えて、股を一つ捩った姿で、降しきる雨の待合所の片隅に、腰を掛けていたのである。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も羊羮色になつた黒のモオニングに、穴のあいた中折を被り、そして泥まみれの深ゴム靴は圓い革を當てて處々｜繕つてある……」「何だい、まるで昔そのままぢやないか。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり坂道を泥まみれになって転がって行く円い玉であった。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴も何も泥まみれになる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも雑草の離々たる原っぱを横切って来たので、私たちの泥まみれの靴は綺麗に拭かれていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "樂　園寂光さんさん泥まみれ豚ここにかしこに蛇からみ秋冴えてわが瞳の噴水いちねん山羊の角とがり。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日の水晶薫り餓ゑて知る道のとほきをおん手の葦おん足の泥まみれなる。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "樂園寂光さんさん泥まみれ豚ここにかしこに蛇からみ秋冴えてわが瞳の噴水いちねん山羊の角とがり。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな泥まみれになり、ヴェランダは愛蘭土泥炭沼の如し。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥まみれになった袖口や、ビショビショに濡れた膝頭や、お尻のあたりからは、冷気がゾクゾクとしみ渡って来て、鼻汁と涙が止め度なく出て、どうかすると嚔が飛び出しそうになるのです。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なんと燃えさしの蝋マッチで、泥まみれだからちょっと見ではただの小枝にも見える。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　掌には、余るくらいなのが、しかも鰓、鰭、一面に泥まみれで、あの、菖蒲の根が魚になったという話にそっくりです。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに入れ込むうちに、首まで泥まみれになっている日本語処理のクソッタレ仕事をマシンに預けられるのではないかと期待し始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時の光景は今でも露眼に残つてゐるがと隠居は回想して、馬と三輪車の時ならぬ競争を目にした人々があれよ／＼と立ち騒ぐ彼方を、祖父は羽織の裾を突風に翻して虎のやうに上体をのめらせながらこゝを先途と疾走したが、忽ち傍らの泥田の中へ真つ倒まに転落して、全身泥まみれと化し腰に大きな打撲傷を享けた。",
              "citation": {
                "source": "写真に添えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は縁側の日向で、泉水を掘らうといふので弥三郎が職人に交つて泥まみれになつて働いてゐるのを見物してゐた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を血だらけにして泥まみれになった佐藤の跡から仁右衛門が這入って来るのを見ると、佐藤の妻は訳を聞く事もせずにがたがた震える歯を噛み合せて猿のように唇の間からむき出しながら仁右衛門の前に立ちはだかって、飛び出しそうな怒りの眼で睨みつけた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の母親達のように、泥まみれになって、割の悪い百姓仕事をし、年を老る気にはなれない。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は想い出すのだが、父が秋田で百姓をしていた頃、田から上がってくると、泥まみれの草鞋のまゝ、ヨクうつ伏せになって上り端で昼寝していた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "壜型の首のあたりを結んだ紐を解き、毛布をとり除くと、泥まみれの大風呂敷やら千切れた単衣やらと、とりどりの襤褸布が四、五、六、七重八重に剥ぎとられて、湿布が剥がされると漸く、頭のかたちから鼻筋へかけて稍々私のらしい線が現れかゝつてゐる粘土の原型が出たので、冗談を止めて私はモデル椅子に腰を降した。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も手伝ってくれれば、一切れ呉れてやるよ」怪しき盗聴者「泥まみれのパイなんか、僕は好きじゃないんだよ。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも泥まみれの濡れ鼠であった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身泥まみれとなり、反面にひどい火傷を負った男がフラフラと歩いていた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいまそちらへ参りまするでござります」　きき知ったか、奥の仕事べやから、両手をどろまみれのままで、当の藤阿弥がいかにも名ある人形造りらしい風貌をたたえながら、取り次がぬ先に姿をみせましたものでしたから、こわきにしていた髪の毛をつきつけると、鋭く問いただしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
