          "standard": [
            {
              "text": "デジタルイラストを描くために、新しいドローイングソフトウェアを導入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このドローイングソフトウェアは、初心者でも簡単に使えるインターフェースが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はドローイングソフトウェアを使って、プロ並みの作品を制作している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "万年筆は絶えず愛用せられたが、インキは何時もセピアのドローイングインキだったから、万年筆がよくいたんだ。",
              "citation": {
                "source": "温情の裕かな夏目さん",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドローイングをやる時や、写生する時、よく版を全部黒く塗つて刀で彫つた所が白く出で行く方法を取る。",
              "citation": {
                "source": "自刻木版画に就いて",
                "author": "岡本帰一",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学青年にとっては、力学やとくにドローイングは、まさに軽蔑すべき学問であった。",
              "citation": {
                "source": "私の履歴書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
