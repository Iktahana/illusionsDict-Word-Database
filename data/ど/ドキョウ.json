[
  {
    "uuid": "69471bb9-ab5f-55eb-8b34-e4bfc5cc92ef",
    "entry": "度胸",
    "reading": {
      "primary": "どきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "courage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お爺さん、はじめは、ぎよつとしたが、しかし、お酒飮みといふものは、お酒を飮んでゐない時には意氣地が無くてからきし駄目でも、醉つてゐる時には、かへつて衆にすぐれて度胸のいいところなど、見せてくれるものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分、いい度胸だよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "発破と度胸競べなんざ、真っ平だよ」　こんな訳であって、――どんな訳があろうとも、発破を抑えつけるなんて訳に行くものではない――岩鼻火薬製造所製の桜印ダイナマイト、大ダイ六本も詰め込んだ発破は、素晴らしい威力を発揮した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた日は全山を玲瓏と人の眼に突付けて、瑕もあらば、看よ、看よと、いってるような度胸のよい山の姿である。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道理で腕と言い度胸と言い見事なものだったよ」　と言ってお静に、　「この事は、誰にも喋言っちゃいけねえぞ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の方がたいてい大人しくしおらしくて女の方がたいて活溌で度胸がいいのがこうした群に共通な現象のようである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにあなたの偽物がまいって居りますから、どうか御立ち会いの上で御吟味をねがいとう存じますが……」　はじめの女はいよいよ顔色を変えたが、彼女はもう度胸を据えたらしく、急ににやにや笑い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この芝居はちっとむずかしかろうと思ったんですが、まあ度胸でやってみろという気になって、どうにかこうにか段取りだけは付けて見たんですが、親分に逢っちゃ敵いませんよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方ではそれがたいていは僕の気のせいだということは百も承知で、そんな度胸もきめるんです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺してください」女は、こうなると男よりも冷酷で、度胸がいい。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "」注文通り岩頸は丁度胸までせり出してならんで空に高くそびえた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パイプを右手にもち直し、度胸を据えて斯う云った。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "碌な本は在りやがらねえ……といったような恰好で悠々とバットの煙を輪に吹きながら出て行くんだから大した度胸でげす。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その睫の長い二重瞼の蔭から、黒い大きな瞳をジイッと据えて微笑された相手の青年は、その素晴らしい度胸と妖気に呑まれて恍惚となってしまったらしい。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ……エチオピアへでも行こうと仰言るのに度胸が御座んせんねえ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと度胸がきまったらしく、ソッと溜息をした。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し自分は到底悪人ではない、又度胸のある男でもない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年はどうかして合格しなければならぬと、試験度胸をこしらえるため、方々でやっている模擬試験（入学試験のまねごと）というのを度々受けたのでしたが、その翌年、本当の入学試験が来たとき、三つも中学校を受験してやはり駄目でした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "竪矢の字の帯の色の、沈んで紅きさえ認められたが、一度胸を蔽い、手を拱けば、たちどころに消えて見えなくなるであろうと、立花は心に信じたので、騒ぐ状なくじっと見据えた。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷では袂へ忍ばす金縁の度装の硝子を光々さした、千鳥と云う、……女学生あがりで稲葉家第一の口上｜言が、廂髪の阿古屋と云う覚悟をして度胸を据えて腰を据えて、もう一つ近視眼を据えて、框へ出て、はッと悪く落着いた切口上。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今言わしゃったは度胸でないで。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいぎさうにふうふう云つていらつして、それでもお客の前へ出ると、すつかり度胸をすゑちやつていらつしやるの。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "（度胸の据った悪党だ、）と泰助は心に思いつ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……見た處は千丈の峰から崩れかゝる雪雪頽の下で薪を樵るより危かしいのに――此の度胸でないと復興は覺束ない。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和出來の猪八戒と沙悟淨のやうな、變なのが二人、鯱の城下へ轉げ落ちて、門前へ齋に立つたつて、右の度胸だから然までおびえまいよ。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから楼を下って街路へおりて見ると、なるほどきょうは盆の十三日で昔ながらの草市が立っている。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は、××ですが、――人ちがいではないでしょうか」「けっして人違いではございません、さあ、どうか」　人ちがいでなければあがってみようとどきょうをきめて、云われるままにあがった。",
              "citation": {
                "source": "二通の書翰",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどきょうは早慶野球戦の日であると思った。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどきょうがおたん生日で、このとおりさかんなお祝をしているしだいでした。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどきょう某博士というのがきた。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
