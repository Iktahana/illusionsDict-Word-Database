        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それがお前さん、動員令が下って、出発の準備が悉皆調った時分に、秋山大尉を助けるために河へ入って、死んじゃったような訳でね。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "×××の方の連隊へも夫々動員令下った。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて言論界に於ても動員令が下されたと見ることが出来る。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは今か今かと動員令を待ち受けています。",
              "citation": {
                "source": "キュリー夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日動員令が下るか明日下るかと噂されていた頃に、岸本は高瀬と連立って白耳義行の人を北の停車場まで送りに行った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこここに貼付された三色旗の印刷してある動員令、大統領の諭告、貨物輸出の禁止令などを読もうとする人達が、今まで鳴を潜めて沈まり返っていたような町々に満ち溢れた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "動員令が下ってから三週間あまりというものは何事も手に着かなかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四　動員令　僕は例の夜学の帰りに本所警察署の前を通った。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは僕の留守の間に「動員令発せらる」という号外が家にも来ていたからだった。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は国内の三十万の青年に動員令に対する準備を命じた。",
              "citation": {
                "source": "ナポレオンと田虫",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは締めくくろうとする緊張した力の闇から、めり出す風にのび拡がり、やがて動員令が出た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また予備兵たちへは、動員令が発せられたそうである。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "連邦の最高委員長ワイベルト大統領は、今から一時間ほど前に、極秘のうちに、動員令に署名を終ったそうです」「そうか。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈から聞いた遂に汎米連邦に動員令が出たとの飛報は、私を強く興奮させてしまった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス政府は明日動員令を發することになつてるので、各地方に集結してる軍隊の輸送で列車は不通になる箇所が多く、早くパリを離れないと、六日までボルドーへ行けるかどうかわからないといふやうなことをいふ者もあつた。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の講義、臨時医学専門部の講義、いわゆる科学動員令による研究、結核予防のための工場、学校、同業組合などの集団検診、レントゲン診断、治療、ラジウム治療など、それはどの一つをあげてみても一人の医師、一人の教授に精一杯の役割となるものである。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年同盟、×（３）フラク彼はこの中で地味な地鼠のようにすばらしい活動をした動員令下の地下作業がどんなに困難なかは×（４）フラクと軍隊細胞のみが知っている！",
              "citation": {
                "source": "同志古味峯次郎",
                "author": "――現在高知牢獄紙折工なる同氏に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "動員令波立一-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）唐人笛｜：ルビの付く文字列の始まりを特定する記号（例）一銭五厘｜奴！",
              "citation": {
                "source": "動員令",
                "author": "波立一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日、又一動員令下るの報あり。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "既成技術家達が一般的な失業傾向現象の一部として、失業の危険に曝される可能性を持つその分量だけを、彼等は今日、部分的な一時的な「動員令」による就職の可能性によって、埋め合せている。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
