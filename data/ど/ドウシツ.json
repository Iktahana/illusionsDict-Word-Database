    "definitions": [
      {
        "index": 1,
        "gloss": "same room",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "岡崎賢七とか云う人と同室へ入れられ、宅へ端書したゝむ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしゃがれた声で早口に罵りはじめ、同室の婦人を指しては激烈に挑戦した。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同室だつた自分は隨分影響をうけた。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯島は中谷と私とが三高の寄宿舍で同室だつたことがある。",
              "citation": {
                "source": "講演會　其他（大正十五年二月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人のボオイが部屋を去ると、私はふと同室の寝台に乱雑に投げ出された女物の革手袋と粋な持物の下の花模様の部屋靴が私の目にとまるのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時ごろ、学校から帰ると、私の部屋に三人、友だちが集まっています、その一人は同室に机を並べている木村という無口な九州の青年、他の二人は同じこの家に下宿している青年で、政治科および法律科にいる血気の連中でした。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした場合に、同室にいる課長殿が、これは誰かに対する信号だということに気が付いたとしても、その信号を受けているのが室内のどの男だかということが分かりにくい。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……其の中で、山高が突立ち、背広が肩を張つたのは、皆同室の客。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼白なる顔を外套の襟に埋めて車窓の一隅に黙然と坐して居る一青年を同室の人々は何と見たらう。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも昔寄宿舎で浜口雄幸、溝淵進馬、大原貞馬という三人の土佐人と同室だか隣室だかに居たことがある、そのときこの三人が途方もない大きな声で一晩中議論ばかりしてうるさくて困ったというのである。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと御挨拶を申上げます、……同室の御婦人、紳士の方々も、失礼ながらお聞取を願いとうございます。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、同室の方々にも申上げます。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月三十一日早起して散歩した、同室者の人間臭にたへなかつたからである、人間の姿よりも山の姿がよろしい。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿、いや、同室一人、誓願寺詣の老人、好きな好々爺だつた、いづれ不幸な人の一人だらう！",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿同室は鮮人、彼も失職者、よく話すけれど嫌味がない、どこでも働らきたい、金を貯めて家庭を持ちたいといふ、彼によき妻あれと祈つた。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平は加世子と枕を並べて寝ながら、そんなことを考えていたが、加世子は少し離れて入口の方に寝ている女中と、お付きの女が氷をかいている患者のことや、療養所の看護婦や、均一と同室のいつもヴァイオリンをひいている患者の噂などで、しばらくぼそぼそと話をしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛は牢屋へはいってからもそのどこやら落ちつきはらった様子のために役人から馬鹿にはされなかったし、また同室の罪人たちからは牢名主としてあがめられた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（前略）嵐のせいであろうか、或いは、貧しいともしびのせいであろうか、その夜は私たち同室の者四人が、越後獅子の蝋燭の火を中心にして集まり、久し振りで打ち解けた話を交した。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、同室の者に介抱せられて気が注いた時には、もう彼の学生はいなかった。",
              "citation": {
                "source": "死体を喫う学生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにもかかわらず、その人物は、人々が騒いで掛けた革鞄の手の中から、すかりと握拳の手を抜くと斉しく、列車の内へすっくと立って、日に焼けた面は瓦の黄昏るるごとく色を変えながら、決然たる態度で、同室の御婦人、紳士の方々、と室内に向って、掠声して言った。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "札幌に貸家なけれど、親切な宿の主婦さん、同室の一少年と猫の糞他室へ移しこの室を我らのために貸すべしと申出でたり。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "同室の一等卒にやればよかつたが遣らなかつたので其奴が密告をした。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "同室は鰐口弦という男である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに淘汰の跡で、寄宿舎の部屋割が極まって見ると、僕は古賀と同室になっていた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同室の先輩たちを紹介しよう。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでだいたい僕の同室の先輩たちの紹介もすんだ事になるのだが、つづいて当道場の特殊な療養生活に就いて少し御報告申しましょう。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この助手さんは、僕と同室の西脇つくし殿に、前から好意を寄せているらしいのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十六日衛生について１　こないだから、女の事ばかり書いて、同室の諸先輩に就いての報告を怠っていたようだから、きょうは一つ「桜の間」の塾生たちの消息をお伝え申しましょう。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと、もうひとり、同室の固パンさんが、このごろひどく浮かぬ顔をしている。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どうしつぺなあ、私の病氣の爲にみんなが……』　ほろほろと病人の顏から涙が落ちた。",
              "citation": {
                "source": "四十餘日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
