    "definitions": [
      {
        "index": 1,
        "gloss": "being present (at the same meeting, occasion, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
