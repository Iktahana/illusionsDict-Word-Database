[
  {
    "uuid": "fa77776d-c526-5124-b31b-1370e6a99ddd",
    "entry": "瞠目",
    "reading": {
      "primary": "どうもく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
