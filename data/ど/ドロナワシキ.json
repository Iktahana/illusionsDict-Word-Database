        "examples": {
          "standard": [
            {
              "text": "泥縄式では良い結果は生まれないと、彼は常に計画的な準備を心がけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の泥縄式のやり方には、もう誰も付き合いたくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "泥縄式で資料を作成したため、誤字脱字が多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もちろん泥縄式の甚だしいものであったが、講義の中心をなす最終戦争を結論とする戦争史観は脳裡に大体まとまっていたので、とりあえず何とか片付け、大正十五年暮から十五回にわたる講義を試みたのであった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、今日会下山に来るなどは泥縄式でないこともないが、それでもなお私には百｜巻の書を読むに勝るものがあった。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
