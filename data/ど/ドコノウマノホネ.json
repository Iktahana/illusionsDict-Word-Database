        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ごつげな、いい金モール服を着てやがって、どこの馬の骨だい！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、このアルバムを見ただけでは、人は私を、どこの馬の骨だか見当も何もつかぬ筈です。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、三亀雄の妻は良家の娘ではあるが、実は養女であって、本当は誰の、どこの馬の骨の子か分らぬ私生児なのだ、という噂を耳にした時、だから政江は喜びの余りひどくそわ／＼したものである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎さんかて喜びはったのに……」「次郎さんてどこの馬の骨や？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの馬の骨か知らねえが、ひでえ男だ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの馬の骨か分らんようなでん公の種を宿して、認知もしてもらえんで、子供に肩身の狭い想いをさせるより、表具屋の息子が一寸間アが抜けてるのを倖い、しつこく持ちかけて逐電し、表具屋の子やと否応はいわせず、晴れて夫婦になれば、お腹の子もなんぼう幸せや分らへん。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様の口のはたも、どこの馬の骨か分りもしない奴の毒を受けた結果だぞ」　言っておかなかったが、かの女の口のはたの爛れが直ったり、出来たりするのは、僕の初めから気にしていたところであった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの馬の骨か分らんようなでん公の種を宿して、認知もしてもらえんで、子供に肩身の狭い想いをさせるより、表具屋の息子が一寸間ァが抜けてるのを倖い、しつこくもちかけて逐電し、表具屋の子やと否応はいわせず、晴れて夫婦になれば、お腹の子もなんぼう倖せや分らへん。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに我々の間に入って来た英国人などは、全くどこの馬の骨でしょう？",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地はどこの馬の骨かと思うような調子で、自分の名を名乗る事はもとよりせずに、軽く帽子を取って見せただけだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの馬の骨だかわからない者に、頭の上がらないくらいどやされたような気がした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの珠数屋の大尽とか申すは、どこの馬の骨じゃ」「何だと！",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っ越しソバを配るだけの義理が済めば、あとはどこの馬の骨か牛の糞かといった風である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かてて加えて、どこの馬の骨だか知れないような相手と、わけのわからない場所をうろつくのは、だい嫌いだよと言い足した。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの馬の骨だか……という侮蔑や反抗心も起って来た。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこの馬の骨だか解りもしねえものを、誰が上さんなぞにする奴があるもんか」「でも好い人じゃありませんか。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ある時母が云つた言葉は、『あんなどこの馬の骨だかわからないものにそんなにやるなんて……』というような事がありました」「どこの馬の骨？",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し自分でも、フト用足しに起きでも仕て、彼那どこの馬の骨だか分りもしない奴の錆棒なんかで、グーンと張り倒されたなりにでもなって仕舞ったら、どんなだったろう。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに第一、この男は、どこの馬の骨とも分らず、しかもあんな真夜中にやって来たりしたのだから。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この近所にも大尉が一人おりましてな、どこの馬の骨とも分らない癖に、わしの親類じゃなどと名乗って、と言ってからに、悔みを言いだしたが最後、急いで耳を塞がずにゃおられないような大声を立てますのさ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "あげくの果てには、こんなどこの馬の骨とも分らない蜜蜂飼風情までが、柄にもなく変な野心をおこすのだ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "また後へどこの馬の骨かしら這入って来るだろうぐらいに思ってるんじゃないか。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
