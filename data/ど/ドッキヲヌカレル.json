        "examples": {
          "standard": [
            {
              "text": "彼のあまりの真剣さに、毒気を抜かれて何も言えなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厳しい態度で臨んだが、相手の素直な返答に毒気を抜かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の満面の笑みを見たら、怒る気も毒気を抜かれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "良　三　一遍行って会って御覧、大抵の者はいい加減毒気を抜かれるよ。",
              "citation": {
