    "definitions": [
      {
        "index": 1,
        "gloss": "from out of nowhere",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
