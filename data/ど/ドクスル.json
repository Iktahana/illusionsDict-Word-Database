[
  {
    "uuid": "565e2755-4c84-53ef-a9fc-f98b299e2e0a",
    "entry": "毒する",
    "reading": {
      "primary": "どくする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be a bad influence (on something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは涜職者を出すから小学校長を全廃せよ、腐った牛肉で中毒する人があるから牛肉を食うなというような議論ではないかと思われる。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ならばフォルマリンか何かで消毒するだろうが、あのころそういう衛生上の注意が行き届いていたかどうか疑わしい。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、この、いじけた、流行しない悪作家に同情を寄せ、「文学の敵、と言ったら大袈裟だが、最近の文学に就いて、それを毒すると思われるもの、まあ、そういったようなもの」を書いてみなさいと言って来たのである。",
              "citation": {
                "source": "鬱屈禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオの騒音は決して文学を毒するものでは無かったのである。",
              "citation": {
                "source": "鬱屈禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉は左の腕を消毒すると、針を突き刺そうとした。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅馬は此一揆を滅すために手段を選ぶに遑あらず、井を毒するに至つた。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどその我を毒すること今の生涯に孰與ぞ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "『書紀』に小碓命少女の装いで川上｜梟師を誅したと出で、婦女男装して復仇したり、役者が女装して密通したりなど往々聞くが（『拾遺｜御伽婢子』三の三、『甲子夜話』続二一）、多くはその場だけで事済み、外国のような大騒ぎ社会を害毒するの甚だしきに至らぬ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間に見られ、批評され、或は崇拝され、或は非難され、或は人間を感化する傑作と云はれ、或は世間を毒する作と言はれても、それは実は作者の与り知らないことだ。",
              "citation": {
                "source": "心理の縦断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が振りまく粉薬も一種の秘薬で、蛇を毒するものに相違ない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、蝦や蟹のたぐいにはどうかすると中毒することがあります。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ漂白粉をバケツに入れてその上に撒かないと、沢山の市民が中毒する。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その一軒の家屋を消毒するかのように、真暗な屋内めがけて弾丸がぶち込まれた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は「精力が伝染するように無気力も伝染するもので、この太古のままに生きている人々の魂から、彼の活動的精神を毒するなにか鈍い毒気のようなものが、機械についた錆のように発散されるのだ」そして、「少しずつ彼を吸いとって弱めてゆく微妙なあるもの」は「かつて彼等を征服したあらゆる民族を噛みこなした。",
              "citation": {
                "source": "「揚子江」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師の糾や繁三が来ると、すぐに石を消毒して、済んだあとでもまた自分の手を注意深く消毒するのが気にくわなかったが、それすら今はあまり相手をしてくれなくなった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界平和大会が「世論を毒する宣伝を無力なものにするために、真理と理性の防衛のために広汎な戦線をうちたてる」ことが必要であることを、宣言しているのは実に実際的だと思います。",
              "citation": {
                "source": "わたしたちには選ぶ権利がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中毒する大豆粉にも、政府の命令ならば感謝する日本人というものを、軽蔑しないものがあろうか。",
              "citation": {
                "source": "目をあいて見る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公衆の面前で、一定の人間を、これでもか、これでもか、というふうにあつかったことは、直接そういう目にあうものを極度に苦しめたばかりでなく、ある距離をもってそのぐるりをかこみ、その光景を目撃している、より多数の、より不安定な条件におかれているものの精神を毒することはおびただしかった。",
              "citation": {
                "source": "ある回想から",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば丁度須田町の銅像が醜を曝すやうに電車、電灯が、人を困らすやうに、間違つた考へ方や間違つた見方感じ方を伝へては、世を毒する事になるからである。",
              "citation": {
                "source": "翻訳製造株式会社",
                "author": "戸川秋骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで社主が代って、あの調子を社会を荼毒するものだと認めたとしよう。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先生が、世を毒するような、あんな探偵小説を書くのは不思議です。",
              "citation": {
                "source": "途上の犯人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この行為は世を毒する。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一塗物類は熱湯に投じて消毒することはできないのみでなく、四角なものはよく見ることでありますが、隅々が奇麗に洗ってあることも少ないのでありますから従って不潔ではありませんか。",
              "citation": {
                "source": "蕎麦の味と食い方問題",
                "author": "村井政善",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれば即ちかの狂的妄想が那邊を蠧毒するに至るや推察するに難からずで、事甚だ憂ふべきものがある。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説書きが眼を奪われたら、運の尽きと思うから、手を消毒する石炭酸と、点眼薬と、黒い雪眼鏡を万田先生から貰って、念入りに包んで送ってくれ。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を消毒する薬液は愚か、血を洗う水さえ取りに行く隙が無かったので、私の両手の指は真黒く乾固まった血の手袋のために、折曲りが利かなくなった。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの娼婦が倫理的及び衛生的にその女自身を腐敗させるばかりでなく、倫理的及び衛生的に人類を毒するものであることはいうまでもない。",
              "citation": {
                "source": "私娼の撲滅について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一酸化炭素は猛毒性のもので、燃料ガスに中毒するというのは、つまりこの一酸化炭素にやられるのである。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、余りに目的意識にのみ囚われない限りにおいて、そして本質的に文学を害毒する強権主義に煩わされない限りにおいて、文学は作者の生活意欲を盛られるほど益々生命を帯びる。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のやうにべつたりとしたおほきな蜘蛛は、くたびれるのもしらないで、足も　手も　ぐるぐるする眼も葉ずれの蘆のやうに、するどくするどくうごいてゐる。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
