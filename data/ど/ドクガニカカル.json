        "examples": {
          "standard": [
            {
              "text": "甘い言葉に騙され、彼は詐欺師の毒牙にかかってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "若者は、一度ドラッグの毒牙にかかると、抜け出すのが非常に困難だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "不運なことに、彼は突然の病の毒牙にかかり、入院することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "水晶の印をお用いになれば、彼の新聞に出まするような恐ろしい詐欺や横領、その他文明社会に流行しまする法律悪用の悪漢の毒牙にかかる患いは一切ございません。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの最愛の妹が彼奴の毒牙にかかるかも知れないのである。",
              "citation": {
                "source": "吸血鬼",
                "author": "ジョン・ポリドリ",
                "note": "青空文庫"
              }
            }
          ]
        }
