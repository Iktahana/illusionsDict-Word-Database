    "definitions": [
      {
        "index": 1,
        "gloss": "one after another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれどもジョバンニは手を大きく振ってどしどし学校の門を出て来ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校で毎日のやうに物理學や數學をどしどし詰め込まれるのに忙しい私の頭からは、おふみと云ふ女の名も次第に煙のやうに消えてしまつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍事連鎖劇キネオラマ、　　寒天光のたゞなかに、　　ぴたと煙草をなげうちし、上等兵の袖の上、　　また背景の暁ぞらを、　　雲どしどしと飛びにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　青いきらびやかなねむりのもやが早くもぼんやりかゝるのに誰かどしどし梯子をふんでやって来る。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして肥育器を使うとしよう、飼料をどしどし押し込んで呉れ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もそれで幸いにどしどし他の生徒を乗越して抜擢されて、十三の年に小学校だけは卒業して仕舞った。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どしどし降る、これも、いけない。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次から次とどしどしはしらはやって来ます。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまは、空のずうっと遠くのすきとおったつめたいとこで、まばゆい白い火を、どしどしお焚きなさいます。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、どしどし階段を踏んで、通りに下りました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土神は草をどしどし踏み胸を踊らせながら大股にあるいて行きました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもジヨバンニは手を大きく振つてどしどし學校の門を出て來ました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いのばかりえらんでどしどし炭俵の中へ投げ込んでいるのです。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くも門があいていて、グララアガア、グララアガア、象がどしどしなだれ込む。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっこさん、あの雨にどしどし降られたので、どうにもこうにもやりきれなくなって、そこの土手からころがり落ちて線路の上へぶったおれたのでしょう。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてドイツ自身も第一にチリ硝石の供給が断えて困るのを、空気の中の窒素を採って来てどしどし火薬を作り出したあざやかな手ぎわをも思い出した。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は末広亭へ雨がどしどし降るのに出かける。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう事情に促進されて、詩文の技倆はどしどし上達し、寺へ訪ねて来る当時有名な詩人達と百句の連句を作るのに線香二三本の間に出来てしまうほど、短い期間の割には熟練を遂げた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが競馬の負けがこんで来るとどしどし料理の価を上げた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番何でもそういったものを、どしどし私たちが頂戴をすることにしようじゃないか。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもどうして小十郎はそんな町の荒物屋なんかへでなしにほかの人へどしどし売れないか。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに町からどしどし買って行くくらゐの現金があの村にある筈はない。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、リンパー先生　さてソンバーユー将軍は、いまやリンパー先生の、大玄関を乗り切つて、どしどし廊下へ入つて行く。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はどしどしその上をかけました。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
