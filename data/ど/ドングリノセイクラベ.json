    "definitions": [
      {
        "index": 1,
        "gloss": "having very little difference between one another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼らの実力はどんぐりの背比べで、どちらが勝ってもおかしくない状況だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のプロジェクトメンバーは、皆が優秀なので、まさにどんぐりの背比べだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "兄弟げんかをするたびに、「お前たち、どんぐりの背比べだよ」と母に言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どんぐりの背比べの中から物の弾みでひょいと頭一つ飛び出せば、後はこの空間を支配する標準化の力学が、あれよあれよというまに絶対的な強者に押し上げてくれた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからごらんのとおりいつまでたつてもどんぐりのせいくらべである。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "pointless competition (between two equally unimpressive parties)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの二人の争いは、結局どんぐりの背比べで、誰も得をしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "些細なことで言い争う彼らの姿は、どんぐりの背比べをしているようで滑稽だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結局、どちらの提案も大差なく、どんぐりの背比べに終わってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
