[
  {
    "uuid": "e6bb80ed-09e5-580e-b2e5-9a66ab1ea848",
    "entry": "同国人",
    "reading": {
      "primary": "どうこくじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
