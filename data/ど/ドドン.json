[
  {
    "uuid": "3e58dd9c-d59e-5a64-b680-162fa8e2986b",
    "entry": "駑鈍",
    "reading": {
      "primary": "どどん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dull-witted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれど、私は生来の駑鈍、いかんせん故人の寄託は重すぎます。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "庶わくは駑鈍を竭し、姦凶を攘除し、漢室を復興して、旧都に還しまつるべし。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所を、どどんがたがた、鼠が荒野と駈廻る。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ばっと鳴って、どどどんと水の音。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と口々に云う処へ、チャンチキ、チャンチキ、どどどん、ヒューラが、直ぐそこへ。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんちきちき面白そうに囃すかと思うと、急に修羅太鼓を摺鉦交り、どどんじゃじゃんと鳴らす。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "突如として、どどん、じゃん、じゃん。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――何がなるほどどんネ……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、そのたいそうな大船に押しまくられた大浪が、しまいには大きな、すさまじい大海嘯となって、これから皇后がご征伐になろうとする、今の朝鮮の一部分の新羅の国へ、ふいにどどんと打ち上げました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どどんが、どんどん。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ど、どどん、ど、どどん、どどんどどんどどん！",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は、こんどどんな幻を見るだろう……。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れの太鼓の音が、　どどどん、どどどん。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "清の事を考えながら、のつそつしていると、突然おれの頭の上で、数で云ったら三四十人もあろうか、二階が落っこちるほどどん、どん、どんと拍子を取って床板を踏みならす音がした。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ見ておれ」　パイクソンは銃をかまえると、その透明なかべをめがけて、どどん、どどんと銃丸を発射した。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どどん、どんどんと、はげしく雪山に響いた。",
              "citation": {
                "source": "雪魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙艇はだんだん舞下り、千メートルぐらいの高度をとってこの森の上まで来た時、にわかに森の中から、まぶしい火光がつづけざまに走ったと思ったら、どどどどん、どどどんと大きな音を立てて、高射砲弾が宇宙艇のまわりに炸裂した。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どどん、がらがらがら、がんがん。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だだだーん、ひゅーっ、どどどん。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "にげると見せておいて、にげもせず、波間からすきを見て、どどん、どどんと空中へ死にものぐるいの砲撃をはじめているのだった。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやとおもうまもなく、その煙はどどんと一度に爆発して、海面は一めんの焔の海と化した。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
