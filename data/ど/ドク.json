    },
    "definitions": [
      {
        "index": 1,
        "gloss": "poison",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それがなんだか気の毒で、私は何も云ひ出せなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年、「宮沢が死んだ」と聞いた時には、大変気の毒に思ひました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａは益々気の毒に思ふ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒にみえた奴が、忽ち自分の不得手なことを始めたからだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて再び、ＡはＢを気の毒がりさへし始めるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒がられては、Ｂとしては冠履転倒も甚だしいものだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめにはイヤな奴だと思つてゐたが、だんだん見てゐると気の毒になつた。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は次第に気の毒さうにしはじめ、そのうち少し私を「脳不足」だといふ意味の目配せを主人やお主婦さんと交すやうになつた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし朝顔に気の毒しました』と叱言を言われた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも自ら毒を服して、嚴然と持し、精神のストイックな安靜を失はないで。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、氣の毒に思ひ、いいえ、あなたを笑つたのぢやないんだ。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その人とは、口をきいたこともなかつたが、それでも、校長の官舍と、私の下宿とは、つい近くだつたので、登校の途中、ちらと微笑をかはすことがあつて、この人は、その、校長追放の騷ぎの中で、氣の毒であつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち不勉強の学生たちを気の毒に思い、彼の知識の全部を公開する事は慎しみ、わずかに十分の三、あるいは四、五、六くらいのところまで開陳して、あとの大部分の知識は胸中深く蔵して在るつもりでいたのだろうけれども、それでも、どうも、周囲の学生たちは閉口した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の肘の前にある灰皿の中の、喫ひ終つたばかりの喫殻から登る紫色の煙と、他の古い喫殻にそれが燃え移つて出る茶褐色の毒々しい煙とが、やゝもすれば彼の顔に打つ衝かつたが、そんなことには元来頓着ない彼であつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の視線が妻君に放たれた時に妻君がピクリと怖ぢけたので、まあ黙過しようかとも思つたが、少し赤坊の母親に気の毒な気がして来てゐた時なので云つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が気の毒であつた、福岡の客つて奴が癪に障つた、彼は自分の自信する詩が鼻にかゝつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にまた「忘れちやいやよ」に至つては、最近それが発売禁止になつたほど、一層もつと極端に、この時代的陰鬱の梅毒的エロチシズムを表現して居る。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では多人数の会へ出ても、不意に人の頭をなぐったり、毒づいたりしようとするところの、衝動的な強迫観念に悩まされることが稀れになった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道端に乞食が一人しゃがんで頻りに叩頭いていたが誰れも慈善家でないと見えて鐚一文も奉捨にならなかったのは気の毒であった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田寅彦さんと云う方は御座らぬかとわめくボーイの濁声うるさければ黙って居けるがあまりに呼び立つる故オイ何んだと起き上がれば貴方ですかと怪訝顔なるも気の毒なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒にもあり可笑しくもあれば終にそのままに止みぬ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし宅へ帰って考えるとそれが非常に気の毒になって矢も楯もたまらなくなる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千羽に一羽の毒がある」と云ってこの鳥の捕獲を誡めた野中兼山の機智の話を想い出す。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの事を考えると、何よりも年老いた父に気の毒だ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "細民街のぼろアパアト、黄塵白日、子らの喧噪、バケツの水もたちまちぬるむ炎熱、そのアパアトに、気の毒なヘロインが、堪えがたい焦躁に、身も世もあらず、もだえ、のたうちまわっているのである。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」オニハ　コナヒダ　アヅカツタコブヲ　ツケマス　ミギノ　ホホオヤオヤ　トウトウ　コブ　フタツブランブラント　オモタイナハヅカシサウニ　オヂイサンムラヘ　カヘツテ　ユキマシタ　實に、氣の毒な結果になつたものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　龜の毒舌は龍宮に着いたら、何だかまた一段と凄くなつて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいちこのさかなたちに氣の毒だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腐つた土から赤い毒きのこが生えて出るやうに、生命の不安が言葉を醗酵させてゐるのぢやないのですか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやいや、さうきめてしまふのは、この善良の龜に對して氣の毒だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
