[
  {
    "uuid": "5764f977-dab0-599d-9da4-c8fe977bc82b",
    "entry": "毒",
    "reading": {
      "primary": "どく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
