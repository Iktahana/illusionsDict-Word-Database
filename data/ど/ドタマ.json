        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今から考えてみるとあの時はヨッポド頭が変テコになっていたんですね。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "オペラ通りなどで、そんなデリカなショーウインドウとは似てもつかないけばけばしいアメリカの金持ち女などが停ち止って覗いているのなどたまたま眼につく。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにそれが女房に貸しつけた金の元利計算と来ては、ぞくぞくするほどたまらない。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしちょうどたまたまその時間がブレッシントンの散歩と重なり合ってしまった。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "水はどろりとして薄黒く、浮き苔のヤリが流れる方向もなく点々と青みが散らばってちょうどたまり水のような濁り水の上を、元気なくゆらりゆらりと漕いでゆくのである。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてクララの眼に涙が溢れるほどたまったと思うと、ほろほろと頬を伝って流れはじめた。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっとするほどたまらない道だったが、構内へはいるとさすがに木の多いだけに気分がせいせいした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "んだからわしや奴のどたまを火箸で割つてくれた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神秘というものほどたましいを覗くものはない気がした。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちみち俺はゆずらない」　ひっくり返るほどたまげながら、「こうなりゃ、ほかになんとしよう」アクリーナは「マクシムの額とワルワーラの編髪に祝福した」　若い者たちはアクリーナの思いやりのある才覚で、こっそり教会で婚礼の式をあげることが出来たのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くあの臭ひは嘔吐を催すほどたまらなかつた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そやつのどたまへ唾でもひつかけてやるさ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらの頭はしつかりしてるがめつかち村長のどたまの箍はえらくゆるんでグラグラしてるぞ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶屋ぶてぶて、村長のどたまを棒でぶてぶて、鞭で打て！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つ目小僧のどたまにやあ、これんばかしでも脳味噌があつたのかい？",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が六歳ぐらゐの時やつたなア、死んだおばんの先に立つて、あのお多福人形の前まで走つて来ると、堅いものにガチンとどたま（頭の事）打付けて、痛いの痛うなかつたのて。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "……武士の刀の先きへどたま打付けたんやもん。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「利兵衞の後家んとこへ公賣にいたときは、鍬一挺と針指し一つよりないんで、そいつを押へると、後家が怒つて、俺のどたま（頭）から水浴びせよつたなア。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が六歳ぐらゐの時やつたなア、死んだおばんの先に立つて、あのお多福人形の前まで走つて來ると、堅いものにガチンとどたま（頭の事）打付けて、痛いの痛うなかつたのて。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな平らなところに降っても、こまやかな凹凸があり、風の吹き廻しでさほどたまらなかった場所は、ほの白いかたまりが散って――雪の白さや冷たさより、却って春の芽ぐんだ大地の黒さと暖かさとを思わせる。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてときどきこうして孤独でいるのが私には殆どたまらないように思われる。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私などたまに會合に出席してこつてりした西洋料理で食もたれをしてゐる後で、次から次へと、五分十分の演説が續くので苦惱を覺えることがあるのである。",
              "citation": {
                "source": "私も講演をした",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "カランをひねらうとしてふと気がつくと、水盤は栓がしつぱなしで、濁つた水が八分目ほどたまつてゐた。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、命｜恙く国に帰れることにきまった」「この籾が帰国のしるしというのは」「この島で死なせようつもりなら、穀種などたまわるはずはない。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央郵便局の私書函には Service des Prisonniers de Guerre「俘虜郵便」の標示をつけた行嚢が、ロードスターでは一度に運べないほどたまっている。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてゐる輜重輸卒も耳の根つこまで赤くなるほどたまらなかつた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "コップが盆の上に三つ並んで、その二つに茶色の水が半分ほどたまっている。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきの「どん」に、なるほどたまらない爆音がこもっていたわけさ。",
              "citation": {
                "source": "鉄道事故",
                "author": "DAS EISENBAHNUNGLUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "缶づめの空缶の上の方を、きれいに取って、砂を半分ほど入れ、正覚坊の油をつぎこむと、油は砂にしみこみ、よぶんの油は、砂の上に三センチほどたまる。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
