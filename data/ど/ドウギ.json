    "definitions": [
      {
        "index": 1,
        "gloss": "motion (i.e. proposal to a committee, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
