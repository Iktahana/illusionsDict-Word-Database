[
  {
    "uuid": "8210534d-d72e-54b6-97ab-834c783d26f1",
    "entry": "どうかと思う",
    "reading": {
      "primary": "どうかとおもう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ウ行"
      ],
