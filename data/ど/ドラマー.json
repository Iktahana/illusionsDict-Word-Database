        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "慶一にとって、ロックンロール・バンドを格づけする第一の基準は、ドラマーだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーンズのチャーリー・ワッツは、慶一が憎悪している、「ジャズ・ドラマー」の親戚のような叩き方をする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽室のなかでは、五人のスネア・ドラマーが、音楽学校の女打楽器奏者の大声に合わせて、ほんもののスネア・ドラムではなく、板にゴムシートを貼りつけた練習台を相手に、「フラ打ち」の練習をえんえん一時間もつづけていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとくちにフラ打ちといっても、右と左の区別があり、そして、ドラムとドラマーにまつわる問題の大部分は、左右の区別があることから起きる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "打楽器セクションの指導者は、なぜか、かならず、「高橋路子先生」と、フルネイムで呼ばれている（慶一は、女のドラマーはハニーカムズのハニー・ラントリーしか知らないので、心のなかでは、高橋路子先生ではなく、ハニーと呼んでいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二分ができれば、自然に四分もできるようになります」　慶一は、他の四人のドラマーが、ため息をもらし、じぶんをにらみつけているのを感じながら、途中で練習を終えるのは、ものすごく残念なのだが、という雰囲気がでるように、いかにもイヤそうに、ハイといって、高志といっしょに音楽室を出た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志がひとりで、かなりテンポを落として、〈リトル・ドラマー・ボーイ〉を弾く。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいドラマーだったのに」「死んだ奴の勝ちなんだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガキのうちに鍛錬していたら、いいドラマーになっていたかもしれない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らよりうまいギタリスト、ベーシストそしてドラマーは、当時でもいくらでもいたでしょう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドラマーが急にやめたんだよ。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ坊や、あんた、なにもしなくていい、ひとつさもドラマーみたいな顔して、ここでだけ太鼓のうしろに坐っててくれないかね」　すっかり髪に櫛を入れた兄がそこに来ていた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔きいた米兵に右の手の腱を切られ、スティックを持てなくなったドラマーの話が、ふと彼の頭をかすめていた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、坊やはほんとにドラマーになる気なのかい？",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "カレは坊やをわれわれのドラマーに仕立てたいといってるんだ、それでほかのやつを入れない」「僕はバンド・ボーイですよ」と信二はいった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもそいじゃ弱ったな、ドラマーはどうしてもいるんだ」独り言のようにいい、荻村は車をとめた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこでもバンドはここんところは目がまわるようにいそがしいし、どうせ、そんなにすぐ僕にもドラマーがめっかるわけじゃないんだ。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "レッスンのたび、けっしてスティックを握らない安達を、信二は兄の話の腱を切ったドラマーだとわかっていた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通のコンサートだったらドラマーは二人くらいいるけど、二人とも必ずスティックはお客にプレゼントするじゃないの。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真にうつっているドラマーは、オーディションの現場で代役をつとめたジョニー・ハッチだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザ・シルヴァー・ビートルズは、オーディションにドラマーなしでやってきた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベース・ギターなどほとんど弾けなかったステュ・サトクリフはなかばうしろをむいているし、ドラマーのジョニー・ハッチは、退屈しきって面白くなさそうな顔をしている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、リンゴ・スターにとってかわられるまでのドラマー、ピート・ベストだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
