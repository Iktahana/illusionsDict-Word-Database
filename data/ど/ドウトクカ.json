[
  {
    "uuid": "7e95c7f8-95a1-5698-bb49-e706406f30d3",
    "entry": "道徳家",
    "reading": {
      "primary": "どうとくか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
