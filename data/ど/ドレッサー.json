          "literary": [
            {
              "text": "ＴＶは、部屋のむかい側の壁によせたドレッサーの上にあった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二辺のうちひとつはソファのある壁に面し、もうひとつはドレッサーや小さなデスクのある壁に面していた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "優しく白い容積に力強さとしての影が寄り添う魅力的な造形は、ベッドを離れてドレッサーへ歩いた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁ぜんたいに作りつけてあるドレッサーだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドレッサーのドアを開いた彼女は、なかの棚からなにかひとつ取り出し、続いてハンガーにかかっていたシャツを手に取った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
