        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「おや、どっから来たのですか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっから来たろうって云ったら風で飛ばされて参りましたでしょうて云やいいや。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前等、弾丸はどっから工面してきちょるんだ？",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どっから受取った？",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっから僕が、露西亜語をかじってるんをしらべ出したんですか？",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゃ、どっから、かっぱらって来たんだ？",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっから刈りこんでいいか、ぼくは無茶苦茶に足の向いた所から分け入り、歩けた所だけ歩いて、報告する――てやがんだい。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっから、そんなものが出てきたんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体、誰がどっから聞いてきたんだ？",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがやっぱり分って居ないからなんですよ、　実の生みの親で気の狂った人ででもなければどっから見てもどっからのぞいても恐ろしいものなんかの有ろう筈は有りません。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっから来たのかわからない水が浅くひろくその原を浸していた。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みみずは大きい龜さんをみて、どうもこのへんにはみかけない龜だとおもって、「おじさんはどっから來たの。",
              "citation": {
                "source": "龜さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉は何心なく、「あんた、どっからけ？",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙なんて……一体、どっから来るんだ。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の区切りなくして、お前さまノペタラに麦なんどこせえたら、どっからどこまでが俺の分だか、ひとにとられたって分りもしねえ。",
              "citation": {
                "source": "ペーチャの話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お前さん、どっからだね？",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい火のそばへボロ長靴をはいた足を出し、どっからか乾草をひっぱって来て、その上へころがっている。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どっからかっぱらって来たんか……見てな、きっと今にピムキンがあの枕かえせって来べえから……。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが私には不思議なの」「どっからどこまで調和してるなんて、そんなことないさ。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどっからは白菜種やるからな、おっかさんによくそう云うんで」　合点して出て行ったと思うと、すぐ、「兎が出とらあ」と告げて来た。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっからかながして来た新内が久し振りで珍らしい。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "車夫「どっからおいでなすったか。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっからか、ポーッといい香りがする、階子を下りて居るらしい。",
              "citation": {
                "source": "ひな勇はん",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子様の伝を書いても耶蘇の一代記を書いても、そりゃあ材料は欠点のないものですワ、どっから見てもネエ、けれ共、それを書いた結果が不成功だったら、ほんとうの純文学の価値はないでしょう。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今日はどっからも電話なんかかけてよこさないでしょうネ、来たってことわるんだからかまわないけど……」　千世子が独りごと云う間に母親はせっせと裏衿をつけて居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物でも持ちものでもどっからどこまでが母の方が美くしかった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
