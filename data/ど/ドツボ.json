    "definitions": [
      {
        "index": 1,
        "gloss": "terrible situation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は安易な投資に手を出した結果、あっという間に土壺にはまってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "計画性のない行動が重なり、プロジェクトは完全に土壺にはまってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "状況は土壺に向かっているように見えるが、まだ打開策はあるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "写字机と置戸棚の間にあった三稜剣が壁の隅のほうへ寄り、前列にならんでいたジャヴァの土壺がすこしばかりうしろへひきさげられ、そのかわり、今までは横側しか見えなかった油絵が、正面に向きかえられている。",
              "citation": {
                "source": "キャラコさん",
                "author": "雁来紅の家",
                "note": "青空文庫"
              }
            },
            {
              "text": "「『パソコン創世記』では、やりがいのある作業にのめり込めばのめり込むほど金銭との縁が薄れていくというどつぼにはまった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが落語のことを真剣に考えすぎたために鬱病のどつぼにはまった彼は、「一時は時うどんも繰られへんぐらいになり」、自殺寸前にまで追い込まれてから今の芸風に大化けして立ち直った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが当時は未だ、親への依存欲求のどつぼにはまりこんでいる真最中だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パソコン創世記』では、やりがいのある作業にのめり込めばのめり込むほど金銭との縁が薄れていくというどつぼにはまった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
