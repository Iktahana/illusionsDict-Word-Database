[
  {
    "uuid": "0570f259-066a-5227-9b69-077f8c6d044e",
    "entry": "どうした訳か",
    "reading": {
      "primary": "どうしたわけか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
