    "definitions": [
      {
        "index": 1,
        "gloss": "drop (candy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その羅宇屋が一風変った男で、小柄ではあったが立派な上品な顔をしていて言葉使いも野卑でなく、そうしてなかなかの街頭哲学者で、いろいろ面白いリマークをドロップする男であった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の子音 Bh と B をドロップさせるのがおもしろい。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最前から見物していたキャラメルの仲間のミンツ、ボンボン、チョコレート、ドロップス、飴玉の仲間の元禄、西郷玉、花林糖、有平糖なぞはソレというので馳け寄って、双方入り乱れてゴチャゴチャに押し合い掴み合っているうちに、みんなお互いにくっつき合って動けなくなってしまいました。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "くめ子はそこで学生が呉れるドロップを含みながら、もし、この青年たちの中で自分に関りのあるものが出るようだったら、誰が自分を悩ます放蕩者の良人になり、誰が懸命の救い手になるかなどと、ありのすさびの推量ごとをしてやや興を覚える。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョコレート二十、ドロップ十個を嚥下し、けろりとしてトラビヤタの鼻唄をはじめた。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、この事は、一高のドロップを知った直後に、颯っときめてしまっていたのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はポケットからドロップの紙袋を取り出すと、少しずつみんなの掌に配った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまるで凍えかかった魚のように赤や黄や青のドロップをしきりに嘗めた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドイツ語がおじょうずですね」などと言われて、おしまいにはまたドロップの瓶入りを買わされた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターの誕生にあたって活躍した多くは、社会や大学からドロップアウトした若者であった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この飴細工と※粉細工とが江戸時代の形見といったような大道商人であったが、キャラメルやドロップをしゃぶる現代の子ども達からだんだんに見捨てられて、東京市のまん中からは昔の姿を消して行くらしく、場末の町などで折りおりに見かける飴売りにも若い人は殆ど無い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ドロップ、ミンツ、キャラメル、チョコレート、ウエファース、ワッフル、ドーナツ、スポンジ、ローリング、ボンボン、そのほかいろいろ、ある事ある事……。",
              "citation": {
                "source": "お菓子の大舞踏会",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに五郎さんの胃袋は大変に大きいから愉快だ」　と道化役者のドロップが云いました。",
              "citation": {
                "source": "お菓子の大舞踏会",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ、苦しいと言っててよ」　とドロップ嬢が心配そうに云いますと、兎の姿をしたワッフルが笑って、「アハハハハ、自分が悪いのだから仕方がない。",
              "citation": {
                "source": "お菓子の大舞踏会",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつれて五色の着物を着た小人のミンツ達を先に立てて、キャラメル嬢をまん中にワッフルの兎、ドロップの道化役者、チョコレートの黒ん坊、ドーナツの大男、そのほかいろいろのお菓子達が行列を立てて行くあとから、スポンジ嬢が手鼓をたたきながらついて行きます。",
              "citation": {
                "source": "お菓子の大舞踏会",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまドロップスの入っていた空き缶の蓋を払いのけて底に小さな孔をあけ、そこに糸をさし入れて缶を逆さに釣り、鉛筆の軸かなにかでコーンと一つ叩いてみるがいい。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、もう一つのドロップの空き缶をとりあげて、前と同じように、糸でとめて、ぶら下げて置く、その上で、最初の缶を思いきり強く叩くのである。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく気をつけてみるなれば、あとから糸をつけて釣るした叩きもしないドロップの缶が、自然にグワーンと鳴っているのである。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "妊娠後｜二タ月や三月や四月の胎児は、ドロップの缶に付着した飯粒も同然で、ほんの僅かの力でもって子宮壁に付着しているのだった。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらこんどはドロップだぞ」　手塚は得意になって球をにぎりかえてモーションをつけた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦い茶を点れて、森永のドロップスなど出してくれた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その色はちょっとドロップスのそれに似ている。",
              "citation": {
                "source": "鳥料理",
                "author": "A PARODY",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私は一ぺん糖分が夢にはよく利くというのでドロップスをどっさり頬張りながら寝たことがあるが、その朝、私はそのドロップスにそっくりな色の着いた夢を見たっけ……）そう、そう、それから私がマリイ・ロオランサンの絵に夢中になっていたのもあの絵の色が私の夢のそれに似ていたからであった。",
              "citation": {
                "source": "鳥料理",
                "author": "A PARODY",
                "note": "青空文庫"
              }
            },
            {
              "text": "一斤のドロップと一缶のおたふく豆とが残り少になって、長い夜も漸く明けるまでには、雨水の湯が幾杯か飯盒で沸かされた。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュガー・ピースと呼ばれている白い果物入り飴は主として砂糖、デンプン、コーニッシュ・クレイコーンウォール産の白いパイプ粘土）からなり、赤いドロップはふつう下級の朱で色付けられている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」咳止めドロップへのまぜ物とその検出法　ロジンジ（咳止めドロップ、菱形）、とくに成分に生姜、クレモール・タルタール（酒石酸水素カリウム）、マグネシア、などのように水溶性でないものが入っているもの、はしばしば混ぜ物処理がされている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ入手した生姜ドロップのあるものが、石炭の火に偶然に放り込まれたときに殆ど変化を起こさないのを見て、私は少なからず驚いた。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "前もって赤熱しておいたシャベルの上にドロップを１つ置くとすぐに火がつくが、炎を出して炭になることはなく、火がついてほんの半分ほと弱い炎をだして後に石のように硬い物質を残し、ロジンジ（菱形）の形はそのままであった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            }
          ]
        }
