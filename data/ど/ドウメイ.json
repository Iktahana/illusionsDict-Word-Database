    "definitions": [
      {
        "index": 1,
        "gloss": "alliance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ユダヤ人種排斥という日本人にはちょっと分らない、しかし多くのドイツ人には分りやすい原理に、幾分は別の妙な動機も加わって、一団のアインシュタイン排斥同盟のようなものが出来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし万一の自然の災害か、あるいは人間の故障、例えば同盟罷業やなにかのために、電流の供給が中絶するような場合が起ったらどうだろうという気もした。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地の事は少しも分りません、早慶戦でＫＯが勝った事を一週間ばかり前に同盟通信のカメラマンに聞きました。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "――貴女の移気な恋愛のオアシス、近代女の株式、同盟破棄！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "人道主義の砲弾でさえ影を潜めて民族に対する愛着をなくした支那の現在が資本家とプロレタリアに分岐されず、国内に小協商、小同盟を作ってプチ・ブルジョワの戦が始められるのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半の都会が同盟｜罷業のような閑寂さを感じさせた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それはまた、労働者農民の祖国サヴェート同盟に対する戦争の準備ともなっているのだ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本プロレタリア作家同盟では、農民文学に対する特殊な研究会が持たれた。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本プロレタリア作家同盟の内部に農民文学研究会が特設されなければならぬ。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サヴエート同盟の市街、ブラゴウエシチェンスクと、支那の市街黒河とを距てる「海峡」は、その日から埋められた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説を傍聴さしてもらうぞ」　支那人、朝鮮人たち、労働者が、サヴエート同盟の土を踏むことをなつかしがりながら、大きな露西亜式の防寒靴をはいて街の倶楽部へ押しかけて行った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして国境外では、サヴエート同盟に物資が欠乏していると、でたらめを飛ばした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーブル紙幣は、サヴエート同盟の法律によって国外持出しを禁じられていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぱい喰わされたのはサヴエート同盟だった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本軍が撤退すると、サヴエート同盟の経済力は、シベリアにおいても復旧した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火酒がだめになると、今度は贅沢品でサヴエート同盟の資本主義的分子を釣った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、漁業会社は、普通相場の五分の一にあたる安いルーブル紙幣を借区料としてサヴエート同盟へ納めるのだった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ソヴェート同盟の国境にむかっての陣地を拡げた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「インタナショナルとは、国際的乃至世界的団結、全世界的同盟という意味である。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで与一は赤沢宗益というものと相談して、この分では仕方がないから、高圧的｜強請的に、阿波の六郎澄元殿を取立てて家督にして終い、政元公を隠居にして魔法三昧でも何でもしてもらおう、と同盟し、与一はその主張を示して淀の城へ籠り、赤沢宗益は兵を率いて伏見竹田口へ強請的に上って来た。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同盟書林という、大きい本屋の前を通りすぎて、すこしいってから、東へはいるせまい路地なかに、克巳の家はありました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、同盟書林をすぎると、ふたりは、首をがちょうのようにのばして、どんな細い路地ものぞきこみました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "復讐の同盟に加わることを避けて、先君の追福と陰徳とに余生を送った大野九郎兵衛は、不忠なる元禄武士の一人として浄瑠璃の作者にまで筆誅されてしまった。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の大将が残酷に取扱うので、同盟して此の山中に隠れたと云う意味を記し、最後に数十人の姓名が連署してあった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦災者引揚者急援同盟」の慈善鍋のマイクから流れる声を、聴くともなしに聴いていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦災者引揚者急援同盟募金成績第一回　七百五十二円三十銭　四月十三日　於円山公園第二回　三百四十三円十銭　　四月十七日　於嵐山「なんだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文楽の女って、皆哀しい女ばかりだけど、姉さんも哀しい女になってしまったのね」　東山では「悲願戦災者救援同盟」の慈善鍋が出ていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲願といえばね、僕はこの百円はどうせ悲願救援同盟に寄附するつもりだったんだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ドイツ』と『オーストリヤ』と『トルコ』と『イタリヤ』はどうめい國で仲がよくこの四つの國のうちでどの國かいくさをしたらすける（助けるの仙臺方言）といふほどでこつちは『イギリス』と『フランス』と『日本』と『ロシヤ』と『セルビア』でこれもいくさをしたらすけるといふようであつた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
