[
  {
    "uuid": "a1b0f1be-51e3-5561-b8fd-334d53edd114",
    "entry": "同盟",
    "reading": {
      "primary": "どうめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
