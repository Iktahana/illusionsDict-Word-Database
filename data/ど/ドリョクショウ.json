        "examples": {
          "standard": [
            {
              "text": "試験では良い成績を取れなかったが、授業への積極的な参加を評価され、「努力賞」をもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「運動会で一番速かったわけではないけれど、最後まで諦めずに走った彼女に努力賞が贈られた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このコンクールでは、結果だけでなく、予選での努力賞も設けられている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "おサイセンやお花があがっている代りに努力賞というものが具えてあった。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月の技芸賞は轟美津子、努力賞を「自叙伝」の中学生にやり、大入袋を皆に分ける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
