    "definitions": [
      {
        "index": 1,
        "gloss": "overswelling (of a blood vessel)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
