[
  {
    "uuid": "7fcaa59b-238f-5c1f-b459-ac9a90e6224f",
    "entry": "読過",
    "reading": {
      "primary": "どっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
