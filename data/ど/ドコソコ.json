    "definitions": [
      {
        "index": 1,
        "gloss": "such-and-such a place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
