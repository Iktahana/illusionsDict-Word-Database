        "examples": {
          "standard": [
            {
              "text": "ソクラテスが飲んだとされる毒は、毒人参から抽出されたものだという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毒人参は、外見がセリに似ているため、誤食に注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "畑の近くに毒人参が生えているのを見つけ、すぐに駆除した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わたしだったら、結局、本心から、毒人参ではなしにむしろ治狂草の方を処方したことであろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
