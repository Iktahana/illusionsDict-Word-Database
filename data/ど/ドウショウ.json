    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the said ministry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同省の地質所は、人民の依頼に応じて、研究して呉れる処なのだ。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時文部省には芳賀先生の親友上田萬年博士が専門局長であられたと記憶します、今日の学習院長福原さん、先頃まで大阪高等学校の野田義夫さんも同省に在官であられたでせう。",
              "citation": {
                "source": "漱石さんのロンドンにおけるエピソード",
                "author": "夏目夫人にまゐらす",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてその内務省における講演筆記を印刷して、同省を経て各府県に頒布してもらい、その後さらにそれをもととして、別にいくつかの歴史的研究を加えまして、「特殊部落研究号」と題する『民族と歴史』特別号を発行しました。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、同省の東川属が來訪して、切符が買えぬかも知れぬという。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は宮内省に入りてより同省の許可を得て現在は歴代の天皇の系譜を調査せり。",
              "citation": {
                "source": "佛蘭西人の觀たる鴎外先生",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへちょうど産業組合とか農会法とかいう農業関係の法律が一時にたくさん出たため、岡野敬次郎さんの口利きで、われわれ法学士が四、五人も同省へ入った。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "同省は外務省と協議の上、ソヴェート・ロシアに対して厳重に反省を求める意向を示した。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "同省は外務省と協議の上、ソヴィエト・ロシアに対して厳重に反省を求める意向だそうだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "随筆家にて司法次官の友人大森洪太氏の慫慂にて全国の刑務所を同省委員等と視てまわる。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お放しなすって、え、どうしょうねえ」　とおぼえず、声を放ちたり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀はただほっとして「あら、嫌否、私はもうどうしょうねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――仁右衛門が見た御新姐のように、この手が触って血を吐きながら、莞爾としたらどうしょう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、これからどうしょうかと思案しているらしかったが、やがて馭者にむかってきいた。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに十五日じゃな」「相違厶りませぬ」「しかと間違いあるまいな」「お諄う厶ります」「諄うのうてどうしょうぞ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あなたの鼻』などと常談申しますと『あ、どうしょう、私のこの鼻、しかしよく思うて下さい。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し生きてゐるやうなら……時も時、處も處、墓も墓、年を經た埋葬所、何百｜年の其間の先祖の骨が填充ってあり、まだ此間埋めたばかりの彼のチッバルトも血まぶれの墓衣のまゝで、定めて腐りかけてゐるであらうし、また眞夜中の幾時かは幽靈も出るといふ……えゝ、どうしょう、目が覺めたら？",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一気楽じゃないか、亭主は一年の半分上から留守で、高々三月か四月しか陸にいないんだから、後は寝て暮らそうとどうしょうと気儘なもので……それに、貰う方でなるべく年寄りのある方がいいという注文なんだから、こんないい口がほかにあるものかね。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちの信頼出来る唯一の科学まで否定して、君はそれで人間をどうしょうと云うのだ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたし、ひやひやしてましたのよ、今朝著いたんだけど、もしかして矢代さん、いらっしゃらなければどうしょうかと思ってたところなの。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあの三分の一でも日本を愛してくれればなアと思ったが、愛というものは、こ奴はどうしょうもないものだ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらには末山大将がいらっしゃるけれど、もしももしもあの恐しいフーラー博士の『荒鷲』が出て来たら……ああどうしょう？",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい世間で笑われようが、どうしょうが、わたしはどこまでもお前に随いて行く……行きますわいなあ」　二人はいつかいっしょに固く手を取合っていた。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、どうしょう／＼」　と不安気に呟く。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしをどうしょうてえの」　真名古は椅子に馬乗りになって、「どうもこうもあるもんかい。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばあちゃん、川がおごりよりますて」　おこったように、登代が、「どうしょうぞ！",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポウルさんはあんなもんでどうしょうというのです？",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはそんな事をシツコク聞いて全体どうしょうと言うんです？",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうえどうしょうって言うんです？",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの二の舞いふんだらどうしょうと思って。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、えらいこッちゃ、電話かけるのん忘れてしもてん」「ほれ、もう自動車来たらしいわ」「どうしょう、どうしょう」と、幸子は鼻を鳴らしたが、雪子はまるで他人事のように澄まし込んでいた。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
