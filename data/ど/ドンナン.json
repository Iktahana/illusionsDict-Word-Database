        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「どら、どんなんぞい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんまの鶴はどんなん？",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母あ、どんなん買って来たん？",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どんなんですか。",
              "citation": {
                "source": "床屋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とすぐに出しゃばり、「それは、どんなんです？",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんならどんなんがあるんだい。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いのちがけ、ということをきいて心配いたして居りますが、どんなんですか。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいろいろ種類があるでしょうから……」「どんなんでもいい。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなんでもいいんだ。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれどれ、どんなんだい。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ふだんは、どんなんだろう。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれでも、どんなんでも皆私にはこの上なくうれしいたよりであった。",
              "citation": {
                "source": "ひな勇はん",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかして君の生活をなりたたせたい、この活きた生活の流れの上に引きだしたいものといろいろと骨を折ったつもりだが、しかしこのごろになって、始めて、僕は君の本体なるものがどんなんか、少し解りかけた気がする。",
              "citation": {
                "source": "遁走",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたには子供が可愛いいというのがどんなんか、ちっとも解ってやしないのです。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藤の木って、いったいどんなんだったの、わたしちっとも気がつかなかったわ。",
              "citation": {
                "source": "白藤",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、どんなんでしょう。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなんだか、まだそれもよくは……。",
              "citation": {
                "source": "雪の上の足跡",
                "author": "高原の古駅における、二月の夕方の対話",
                "note": "青空文庫"
              }
            },
            {
              "text": "水品陣十郎という悪鬼のような男、あの男もお組や秋山要介と、深い関係があるようだが、その関係はどんなんだろう？",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあおつもりにしようといって師匠が切り上げたときはもうよほど遅く、おしのどんなんかつとに寝ていた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "私あ、子を持つた事は無いけど、どんなんだらうねえ、あんたの気持。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "才八どんなんか、ひとかど通なことを言つてる癖に、あのお吉さんを見る目は尋常ぢやありません」　さう言はれると、そんな素振りがあつたかも知れませんが、微妙な消息は平次にも判斷がつきさうもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "影法師",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「内容はどんなんです。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうどんなんでもあるんだ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どんなんでも、どんなんでもあるんだよ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの放縦なキリスト教主義は、何かの機会がありさえすれば、すぐに他の看板に地位を譲ろうと待ち構えていた――どんなんでも構わない、暴力、帝国主義、「笑う獅子」などでも。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その尺八は何を吹いていたんだい、それを聞かしてもらいてえ」「鈴慕の曲を吹いていたのですよ」「鈴慕の曲というのは、どんなんだい、面白かったかい」「ええ、ずいぶん感心を致しましたよ、今までに覚えのないほど、感じてしまいました」「そうかね、お前がそれほど感心するくらいならずいぶん面白かったろう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院に行く時だって、代りばんこに指揮者になって、号令をかけて門から出て行く」「学科というのは、どんなんだね？",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょと作じゃない子が溝い落ちるかい、きょときょとしよるさかい」「きょときょとやこい、しやせんわい、健、克ちゃんがいつもどんなんか思て目つぶって歩いてみたら、気いつけたのに落ちたんじゃい」　これにはお母さんも何ともいいようがなく、「きょうとやの、まあ」と、笑った。",
              "citation": {
                "source": "赤いステッキ",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはどんなんでも構わないんだが。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
