[
  {
    "uuid": "6f063c8a-3a79-552d-8869-e968227707e5",
    "entry": "度外視",
    "reading": {
      "primary": "どがいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
