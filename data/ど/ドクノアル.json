        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　チュンセ童子が黙って傷口から六｜遍ほど毒のある血を吸ってはき出しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の樣子を、間近に視ながら、毒のある目も見向けず、呪詛らしき咳もしないで、ずべりと窓に仰向いて、病の顏の、泥濘から上げた石臼ほどの重いのを、ぢつと支へて居る病人は奇特である。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、くきと見えたのは、じつは、見るもおそろしい、毒のあるヘビでしたし、また、花と思われたのは、そのヘビの口からはき出すほのおだったのです。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯台所で音のする、煎豆の香に小鼻を怒らせ、牡丹の有平糖を狙う事、毒のある胡蝶に似たりで、立姿の官女が捧げた長柄を抜いては叱られる、お囃子の侍烏帽子をコツンと突いて、また叱られる。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒のある蛇だと棒が一本いる。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "火花のように、雷光のように、毒のある花粉のように、嶮しい悪意の微粒子が家中に散乱した。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒のあるはえやあぶが、なん千となく、むれて馬車のなかへとびこんで来ました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気でお膳に向った日にゃ、お汁の湯気が濛々と立騰ると、これが毒のある霧になる、そこで咽死に死にかねませんな。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毒のある蝶々で、それに刺されるとひどく腫れ上がって熱が出ることがあるんだそうです。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪水が出ますと水と共に田畑へ鑛毒が這入りまして、高い所には這入らない處もありまして、鑛毒の無い水と鑛毒のある水とある。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾來御聖徳益々盛にましますのに、其麓の村々の鑛毒のある處に案内をして來る人がある。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄翁は今更殺生石におそろしい毒のあることを知って、ぞっとしました。",
              "citation": {
                "source": "殺生石",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "不吉な蒸気の輪が、不具の身体と一緒に動いていって、その手が触れるところは、すぐその場で、毒のある何物かに変ってしまうだろうと思われた。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び創口が裂けて、毒のある風が容赦なく吹き込みさうになつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説はもと／＼毒のあるものです。",
              "citation": {
                "source": "余はベンメイす",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにここには、子どもたちがうっかりすると取ってしかられる、毒のある黒木いちごがはえていました。",
              "citation": {
                "source": "真夏の夢",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ一は生梅あるいは不熟の李等には時として青酸といえる大劇毒のあるに因る。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒のある林檎であります。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鶴見は女の言葉に毒のあるのを悟った。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの御方はピンピンしているし、私の料理に毒のある筈はないのだがね。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ大尽にぶっつかる手術がなければ最後の手段は、先生が口癖に言う毒を飲ませることのみだが、口にこそ言うけれど、この先生は毒を飲ませて人を殺すような、そんな毒のある人間ではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "原因はわかりました、茸のせいです、毒のある茸のせいです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃもう――たしかに――「わざわい」が今もなお世の中を飛び廻っていて、減るどころか、却って数もふえて、それが大変いやな小悪魔達で、お尻にとても毒のある螫を持っていることも知っています。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペガッサスが空中を突進して行って、百ヤード以内に近づいた時、カイミアラはぱっと跳び上って、その大きな、不格好な、毒のある、とてもいやな胴体を、可哀そうに、まともにペガッサスにぶっつけて、力一杯に彼をかかえ込んで、その蛇のような尻尾を結んだように巻いてしまいました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りていらっしゃいよ」　それを聞くと、彼は急いで飛び出して、毒のあるエデンの花園に降りて来るのであった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラッパチーニの娘　アウペパンの作から",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがわたくしのからだに織り込もうとなすった禍いが夢のように、……この毒のある花の匂いのように、失くなってしまうところへ参ります。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラッパチーニの娘　アウペパンの作から",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒のある針でちくちく刺されるような痛みを、柔らかな肌に感じたばかりでなく、息苦しくなって、しまいには酔ったもののように、頭が重くなって、足もとがふらふらとして起っていられなくなるのでした。",
              "citation": {
                "source": "公園の花と毒蛾",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蝮を部屋へ放してやり、毒のある歯で噛ませてやろう）　彼女は蝮の頭を撫で、念ずるように口の中で云った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
