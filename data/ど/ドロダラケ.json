[
  {
    "uuid": "80bcc250-2c27-526d-9918-7be0447a63cf",
    "entry": "泥だらけ",
    "reading": {
      "primary": "どろだらけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
