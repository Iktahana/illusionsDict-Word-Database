    "definitions": [
      {
        "index": 1,
        "gloss": "covered in mud",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫人と結婚して間もない頃、雨でずぶ濡れになった小猫を拾って帰り、その泥だらけのままの猫を懐中に入れて、長い間やさしく暖めていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとうさん、大きなどんぐり、こいも／＼／＼／＼／＼みんな大きなどんぐり」と小さい泥だらけの指先で帽子の中に累々としたどんぐりの頭を一つ一つ突っつく。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から晩まで泥だらけで働いて、まずい飯しか喰えないこんな堅気な暮しが俺ァつくづく嫌ンなった」（Ｆ・Ｏ）Ｓ＝茶店（昼）　七五郎、来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた小倉の霜降りの洋服を着て、脚にも泥だらけのゲートルをまき、草鞋を履いている。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐いてみたら黒い血が泥だらけの床の上に直径十センチくらいの円形を染めた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰向きに泥だらけの床の上に落ちて、起き直ろうとして藻掻いているのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七が神前に奉納した箱のなかには、泥だらけの古草履が入れてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大急ぎで洋服を脱いで、衣桁に引っかけてあった浴衣に手早く袖を通し、泥だらけの洋服とワイシャツとズボンを丸めて、番号札のついた脱衣戸棚と天井裏との間に出来ている暗がりに突込んだ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真黒に日に焼けた、泥だらけの子供の笑い顔が見たくて見たくてたまらなくなった。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の郷里では、今は知らず二十年も以前は、婚礼の三々九度の杯をあげている座敷へ、だれでもかまわず、ドヤドヤと上がり込んで、片手には泥だらけの下駄をぶら下げたままで、立ちはだかって花嫁や花婿の鼻の高低目じりの角度を品評した。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは泥だらけな宝の珠だわ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の晩方、表町へ買物が有って、麻の法衣で、ごそごそと通掛ると、その足袋屋の小僧の、店前へ水を打っていた奴、太粗雑だから、ざっと刎ねて、坊さんが穿きたての新しい白足袋を泥だらけにしたんだとね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お足袋が泥だらけになりました、直き其処でござんすから、ちょいとおいすがせ申しましょう。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……其處で、昨日穿いた泥だらけの高足駄を高々と穿いて、此の透通るやうな秋日和には宛然つままれたやうな形で、カラン／＼と戸外へ出た。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥だらけの靴やちびった下駄のままで書きまくった小説でなければもう感心しない。",
              "citation": {
                "source": "土足のままの文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足を泥だらけにした野良着のままであったが、肩を聳やかして土間に這入るとイキナリ、人形をさし上げている爺さんの襟首に手をかけてグイと引いた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の外には老人や青年が真黒に集まって、泥だらけの白骨を中心に、大評議をしている……というわけで……そこへ文作が帰って来たのであったが、女房の死骸を一眼見ると、文作は青い顔をしたまま物をも云わず外へ飛び出して、村の人々を押しわけて、白骨の置いてある土盛りの処へ来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジイッと泥だらけの白骨を見ていたがイキナリその上に突伏して、「兄貴……ヒドイ事をしてくれたなア……」　と大声をあげて泣き出した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そのうちに、駐在所の旦那や区長さんが来て、顔中泥だらけにして泣いている文作を引きずり起こすと、文作は土の上に坐ったまま、シャクリ上げシャクリ上げして一伍一什を話し出した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の青年の働き方が足りないといって泥だらけの平手で殴り付けたりしたので、可哀相に今度は草川巡査が発狂したという評判まで立てられるようになった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗とホコリにまみれて、泥だらけの浴衣にくるまっている哀れな姿を見上げ見下しながら、静かに頭を左右に振った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は頭ぐるみ自分の作つた陥穽へ落ち込んで泥だらけになつて泣き出した。",
              "citation": {
                "source": "小学生のとき与へられた教訓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔に血の附いてる事もあれば、衣服が泥だらけになつてる事もあつた。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さいときから村の子供の中に混って遊ぶのが好きで啓司のいつもの話に彼が高等小学へ通う時分、小川の掻い掘りをしている泥だらけの子供を見て、中に似たような子供がいると思って気をつけてみるとそれは大概常司だったそうです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "探ってみると、穴の間口はさほどに広くもないが、深さは一間半ほどに達しているらしく、しかも殆んど切っ立てのように掘られてあるので、それから這いあがることは頗る困難であったが、父は泥だらけになってまず無事に這い出した。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして双方とも、泥だらけになり、やがて血までがだらだら流れ出しました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "午過、泥だらけになって、やっとマリエに着く。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに履物も何も履いていないので、綿と繃帯で包んだ白い象の足みたいな足の裏が泥だらけになっている。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その泥だらけの颯爽たる姿を、そこいら一面に生えていた、犬蓼の花と一所に思い出す。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のキャッチボールのそれ球をわんわんのように這って椽の下にさがしに行ったりどろだらけな靴下をつくろってやることもあります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
