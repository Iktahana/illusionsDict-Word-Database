[
  {
    "uuid": "087b2684-f372-57b8-ba5c-2cf432406bd2",
    "entry": "共",
    "reading": {
      "primary": "ども",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "first-person plural (or singular)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてさうである限り、新短歌も短歌と共に今後の発展を約束されるものではないとみねばなるまい。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "サッフォの熱い想ひと、ギリシャ詞華集のあの強靱なやさしさとは、共にその詩に具はつてゐた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に対して或人は理智の欠乏がその原因だといひ、或人は共通信条の不在を嘆いてゐる。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて時代の不安の原因が果して理智の欠乏だとすれば、人は直ちに理智の涵養に取掛かればよいのだし、又共通信条の不在がその原因なればそれの探究に取掛かればよい。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造はその温しさのために、馬鹿共が気にとめぬ謎である。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいかオイ……あんな奴と共同で仕事をして好いことがないのは分りきつてらあ……いいかオイ、俺が出来るだけは助けてやるからなあオイ」「うんうん」　それから猶暫らく彼は同じやうなことを繰返してゐたが、やがて其処を出ようと云ひだした。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の方は急を要する場合だし何時まで待つてもゐられないから、三田村の「あんな奴と共同で云々」のそのあんな奴に、私は私の最初の計画通り相談することに肚をきめる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それの周囲の棚だつた鉛の棒を共に抜取つた弟さへ、今は既に亡き数に入つたのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人共大変に歌舞伎通のやうである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私共は、既にかうした青春時代の花やかな、とはいへいくぶん狂気じみた創造の夢を過去に微笑して観ることさへもできる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や私共の狂暴な破壊は終つた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それは私共の第一番目の仕事であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに私共の、よき宴会の日は過ぎ去つた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の彼は、深い確信の下に人類の幸福を愛し、私共のために彼自身の立派な生活と、その高貴な感情のリズムとを別ちあたへやうとする者である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした彼の哲学（人格の語る哲学であつて思想の語る哲学ではない）は、ある意味に於て、あの偉大なる古代ギリシヤ人のそれと全く共通する。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに私共の求めてゐたものは、もつと鮮新で、もつと自由で、そしてもつとしんみりとした情熱をもつた、純日本言葉の美しい音楽であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした私共の要求を満足させて、最初に日本現代語の「音楽らしい音楽」を聴かせてくれたものは、実に私の友人室生犀星その人であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の新らしい詩の表現は、丁度、愛する妻と共に日暮れの街を歩きながら、楽しい買物の話をするやうな、平易な親しさの中に、力強い情熱のひびきをこもらせたものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し私共二人が、互にその思想や主張の上で自己を押し立てようとするならば、私共はとくに血を流すやうな争論を繰返して居なければならなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私共は、始から「思想のための友人」もしくばその共鳴者ではなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共が互にその対手に認めて崇敬しあつたものは、思想でも哲学でもなく、ただ「人間として」のなつかしい人格であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて稀にみる子供らしい純一無垢な性情と、そして何よりも人間としての純潔さを、私共は互に愛し悦びあつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに私共のはれがましい不断の交歓があつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンはその妻と共に、姑の老婦人と一家に同居し、純日本風の仕方でよく孝養の道を尽した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし琴、生花、茶道によって教育され、和歌や昔物語によって、物のあわれの風雅を知ってた彼の妻は、良人と共に、その楽しみを別ち味わうことができた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンにとっての夫人は、この世にただ一人の愛人であり、永久に『可愛い小さいママさま』であったと共に、またその仕事の忠実な助手でもあり秘書でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの妻であった日本女性は、もとより極めて聡明であったと共に、武士道ストイシズムの家庭教育から、非常な意志の力をもって努力した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人にとってのヘルンは、最も信頼する良人であったと共に、一面ではまた『大きな駄々ッ子坊や』でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそのお前自身にしてみれば、その註文を抱いてこそ生きてゐるやうなものでもあるのだ。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、自体インテリがインテリであるためには、衣食住の先のこと、換言れば観念を必要とし、それに就て仕事をする場合にインテリなのである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
