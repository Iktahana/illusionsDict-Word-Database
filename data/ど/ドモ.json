  {
    "uuid": "912ceaf7-7d5e-5fe0-8bb9-0d2b71b23cb2",
    "entry": "ども",
    "reading": {
      "primary": "ども",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "助詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "but",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれどもそのお前自身にしてみれば、その註文を抱いてこそ生きてゐるやうなものでもあるのだ。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、自体インテリがインテリであるためには、衣食住の先のこと、換言れば観念を必要とし、それに就て仕事をする場合にインテリなのである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その云ふ気持は分るけれど、それに、観念が稀薄であるよりは濃厚な方がよいに決つてゐるけれども、要するに、観念があるだけある上で見たり感じたりしてゐることが芸術になりもするのであるから、そこへ観念を持運んで来たつてたゞトンダお景品たるに過ぎない。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ断片的な云ひ方であるけれども、一寸ピカソの言葉に同感を表してみたかつたまでである。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪萩原朔太郎青くしなへる我が指のリキユールグラスにふるるとき生れつきとは思へども侘しく見ゆる爪形をさしも憎しと思ふなり",
              "citation": {
                "source": "爪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああふるさとの永日に少女子どものなつかしさたとしへもなきなつかしさやさしく指を眼にあててももいろの秋の夕日をすかしみるわが身の春は土にうもれて空しく草木の根をひたせる涙。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "まひる利根川のほとりを歩めば、二人歩めばしばなくつぐみ、つぐみの鳴くに感じたるわが友のしんじつは尚深けれども、いまもわが身の身うちよりもえいづる、永日の嘆きはいやさらにときがたし、まことに故郷の春はさびしく、ここらへて山際の雪消ゆるを見ず。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　いのちの孤獨、われより出でて徘徊し、歩道に種を蒔きてゆく、種を蒔くひと、みづを撒くひと、光るしやつぽのひと、そのこども、しぬびあるきのたそがれに、眼もおよばぬ東京の、いはんかたなきはるけさおぼえ、ぎたる彈く、ぎたる彈く。",
              "citation": {
                "source": "ぎたる彈くひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われらひとしく丘に立ち〕宮沢賢治われらひとしく丘に立ち青ぐろくしてぶちうてるあやしきもののひろがりを東はてなくのぞみけりそは巨いなる塩の水海とはおのもさとれども伝へてきゝしそのものとあまりにたがふこゝちしてたゞうつゝなるうすれ日にそのわだつみの潮騒のうろこの国の波がしらきほひ寄するをのぞみゐたりき",
              "citation": {
                "source": "〔われらひとしく丘に立ち〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨その原因を、暗中模索の揚句、社会問題に持つて行つて、其処で解決を得られると思ふ人も相当あるけれども、私にはさうは思はれぬ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新短歌が、短歌から出て来たものと考ふべきか、全然別個に発生したものと考ふべきかは甚だ疑問であるけれども、短歌にもはや発展の余地がないと思つた人々によつて工夫されたものであることは慥かである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この懐かしい遺風は今後とも決して忘られはしないであらうけれども、今後とも発展しさうには思はれない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてかういふことは、判然と示証することは出来ないけれども、短歌を作りたいといふことが、今後とも人々に全的な希望、全的な仕事として考へられることはあり得ないやうに思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、良い芸術品は、「感覚的」を透して理念（情緒をも含めて）を蕩揺させてゐるものである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論かういふことは、一々の短歌作品、一々の俳句作品に就いてそつくりそのまま当箝まることではないけれども、夫々の様式を規範的に観た場合そのやうに言ふことは先づ間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新体詩様式は、未だ十分の発達を示してはゐないけれども、人々はその案外に困難なる故を以てかどうか、何時の間にか退却し、昨今再び立向つてゐる状勢だが、猶極めて怠惰な立向ひ方と云へよう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの弱さうな、気の弱さうな人であるけれども、あれで却々野心家だとも思つてゐた。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨百姓達の方は、その態度が心許ないせゐではないが、何分嶄新なその耕作法は、聴けども聴けども分らない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "響くといふこともないけれども、何かしら本当に仕事してゐるものを却て一時的とはいへ吃驚させたりするのだ。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、通価といふものが此処で定つたとしても、通価といふものが物の全てではないといふことを、世間はまた全くよく知つてもゐるのである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼はつづけて大声で笑つてゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、　歩き出すと案外に平気だつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもここにはなにがあるか、遠く都會をはなれたここの田舍には何があるか、ああ、ここには風がある、はてしもなくひろがつた大空がある、たかく盛りあがつた土壤がある。",
              "citation": {
                "source": "都會と田舍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私共は、始から「思想のための友人」もしくばその共鳴者ではなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上に参るの時、あなた、シルクハット、フロックコートですよ』などと、子供をだますようにして説き伏せられ、やっと礼服を新調したけれども、やはり少しも着ようとしない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども新聞を見る迄もなく、ある本能の異常な直覺が、變事の疑ひ得ないことを斷定させた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども同時に何かしら腑に落ちない妙な疑問が、別に新しく心の底にきざしてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
