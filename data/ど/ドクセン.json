  {
    "uuid": "d2ce8530-353b-589c-acc2-cbc898ae21bf",
    "entry": "独占",
    "reading": {
      "primary": "どくせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
