        "examples": {
          "standard": [
            {
              "text": "チャップリンの映画は、ドタバタ喜劇の傑作として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "演劇部が上演するのは、古典的なドタバタ喜劇だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供向けのテレビ番組には、よくドタバタ喜劇の要素が取り入れられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "マックセンネットのスラップスティック――ドタバタ喜劇。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "替え玉を一時間か二時間やるのはほんの一時だが、更に数日もドタバタ喜劇をやるとなれば、全く別物だ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドタバタ喜劇役者が言いそうな台詞だが、今俺が演じているのがまさにそうだ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
