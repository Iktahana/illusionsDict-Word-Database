  {
    "uuid": "42252c6a-ba32-59be-b560-e8a0b6b4deb8",
    "entry": "独修",
    "reading": {
      "primary": "どくしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
