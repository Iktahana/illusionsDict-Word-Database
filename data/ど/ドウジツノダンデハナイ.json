        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "固より穀物問屋の婆あさんの、手の平で豆を選るのと、同日の談ではない。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又右衛門とは又同日の談ではない。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして生涯を空過した嘆きも亦ステンダールと同日の談ではない程深刻である。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に記号としては勾とか股とかいうごとき漢字をそのままに記して用うることができるのであるから、字母で文句を綴る西洋で代数記号がその代表する数量の名称そのままのものを使用することができないので記号の使用を考案することが至難であったのと同日の談ではない。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸方の人材の広く集まれる江戸においても実験科学の勃興に対して全く何等の事蹟もないというではないけれども、上述のごとき西方諸国の著しいものに比すれば、決して同日の談ではない。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新後の数学は、もとより和算と同日の談ではないが、しかし前に発達しなかった実験科学よりも、今ではかえって遜色があるかのうらみがないでもない。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘆本の句は観察の精粗において固より同日の談ではない。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
