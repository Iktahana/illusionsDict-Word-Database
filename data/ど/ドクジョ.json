    "definitions": [
      {
        "index": 1,
        "gloss": "single woman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ドラマに出てくるキャリアウーマンは、仕事もプライベートも充実した毒女だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は自分を毒女だと笑いながらも、独身生活を謳歌しているように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近、毒女をターゲットにした旅行プランが人気を集めているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "真ッ昼間だというのに、黄色のドーラン化粧に、青のアイシャドウ、おまけに垂れ滴るような原色の脣をもった、まるでペンキを塗った腸詰のようなその黴毒女を、春日が、例え噂にもしろ「ネネ」と呼んだ、ということについては、激しい不満を感ぜずにはいられなかった。",
              "citation": {
                "source": "腐った蜉蝣",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い医者だった彼は、その後の中毒女たちに投薬することに非常に巧みだった。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女と性交をすると生命を失うインドの“毒女性”の本性は知られていない。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
