          "literary": [
            {
              "text": "┌どんぐり　┌どんぐり先生（一洵）“三鈍”│どんこつ　│どんこ和尚（澄太）　　　　└どんびき　└どんびき老豆腐の佃煮とは！",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんびきが寒いのでひつこんでゐたが、また出て来た、今夜もあぶなく踏みつけるところだつた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつとポストまで、途上、どんぐり先生に逢ふ、明朝出立、どんこ和尚を訪ねるといふ、どんびき翁からよろしくとたのんでおいた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
