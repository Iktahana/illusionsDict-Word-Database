    "definitions": [
      {
        "index": 1,
        "gloss": "person with a sharp tongue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
