[
  {
    "uuid": "64a5afd1-b166-518a-be8b-7c07ed283a9a",
    "entry": "動じる",
    "reading": {
      "primary": "どうじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be perturbed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、文士の亭主はどういうものか妻の不貞に関して少しも動じる色がなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがなか／＼そんなことで動じるやうな婆さんぢやなくほゝゝゝゝといきなり甲高い声をあげて、ぢろり眼鏡の中からこつちを見据ゑながら、さういふ方達とお附合ひがおありになりまして？",
              "citation": {
                "source": "貸家を探す話",
                "author": "高田保",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんそれを用いているのですか」　こうひやかしても悠々と動じる色もなく、うなずいて、「先祖代々の商売だから小さい時から仕込まれてね。",
              "citation": {
                "source": "桂馬の幻想",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "げ、源三郎、迷惑しごくに存ずる」　角ばった口上――しかも、この場合母上という呼びかけは、熱湯に水を注ぐよう、まことにお座のさめた言葉ですが、お蓮様は動じるけしきもなく、「わたしの言うことをきけば、いいことばかりですよ、源さま」「ハテ、いいことばかりとは？",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし信念の仕事であったから、それらの批評に動じる事はなかったが、どんな仕事でも開拓的なものに風当りは強い。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの絶望させられてしまったかたたちがみずから自分の身を守ろうとし始め、普通の人間たちには考えられないような自制のあとでついにベルに手をかけ、ほかの手段ではどうしても動じることのないＫを追い払うために助けを呼ぶなどということは、それこそこれまでに起ったことがないようなことだ！",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引き換え、畏れ動じることもなく並々ならぬあの振る舞い、それが災いの種を蒔いてしまうとは、神ならぬ人にいかに知りえたであろうか。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "西アフリカへ行った２百人余りの西洋人の中で、唯一生き残って帰って来た男には、こんな些細な夫婦喧嘩などで動じるものじゃない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、相手はいっこう動じるふうもなかった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の三",
                "note": "青空文庫"
              }
            },
            {
              "text": "動じるな、わが心、して運命がおのれの味方だと悟れ。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かもつと大きなものがあるので、ものに動じる様子がない。",
              "citation": {
                "source": "赤絵鉢",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも彼の方は動じる風もなかった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私にはあんたの考えがよく分かっているよ」この男は動じることもなく冷静さを保って彼に言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人の帰らぬ旅立ちも、老母の死にも、いまは動じることのない丹女であった。",
              "citation": {
                "source": "日本名婦伝",
                "author": "小野寺十内の妻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洒落ッくせい」　さすがは日本左衛門、動じるさまもなくうしろへ身を捻って、顔をながめ、「うぬは釘勘だな」「…………」　釘勘は声が出ない。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　張飛は動じる態もなかった。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、さすがに一かどの者、端然と、階下に座をとり、すこしも周囲の威圧に動じるふうも見えなかった。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとよりお覚悟のこと、それに動じる後醍醐ではなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことは、ふつうの芸人であったら、いわゆるトチるとでもいわれはしまいかと、大いにてれたり、うろたえるところであろうに、検校はいっこう動じる容子もなく「え？",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
