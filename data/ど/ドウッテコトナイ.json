        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "叔父の心配事や暴言はどうって事ないが、メアリからは名誉を回復したい。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうって事ないだろ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうってことないよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうってことないさ」　腰掛けを押さえた高志の左手首が、三センチほど切れて、血をにじませていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハレマイヤ　どうってことない。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二十年て、どうってことないです。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふふふ、どうってことないでしょう。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくばかばかしい騒ぎなので、この陽気なアメリカ人には、どうってことない。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "島民がちっとも虐げられず、完全に自給できていたとしても、どうってことない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの大部分は例の海岸で座礁した難破商船から遠慮無く奪い取ってきた物であり、どうってことない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は行かない」「でも、あなた――」「おまえ、エズラはどうってことない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、それが私達には、どうってことないでしょ？",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな状況じゃ、何度も戦うはめになる」「では、危険なんて、どうってことないですね」　アメリカ人が身震いした。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女一人ぐらいどうってことない。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂で見つかっても、どうってことない。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "損しても一万ポンドぐらいどうってことないでしょう。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「人を非難できる立場にないでしょう、あなたは」「その線で来てもどうってことないぞ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌いが憎しみに変わっても、どうってことない。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもテンプルさん、どうってことない。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑務所に数日監禁されたってどうってことない。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして退社したフィッシャー部長が降りしきる雪の中、ベッドフォード広場の方へ眠そうに歩きながら持った感想は、結局世の中どうってことない。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの新聞社が脅しネタをつかんでもどうってことない。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
