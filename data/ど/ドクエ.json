[
  {
    "uuid": "68b423df-28a2-506b-84e5-3daba1e86d59",
    "entry": "毒荏",
    "reading": {
      "primary": "どくえ",
      "alternatives": [
        "ドクエ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese tungoil tree (Vernicia cordata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毒荏の木から採れる油は、かつて塗料などに利用されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毒荏の種子には毒性があるため、扱いには注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い日本の家屋では、毒荏の油が木材の保護に使われていたと聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それが何かひどくえらい事のように、――つまり、その男が他の少年達よりも大人である証拠であるかのように、彼等には思われたのであった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山稜の上に残った雪の上に、荷をおろして一休みした、後ろはひどくえぐられた深い崖の底に、ラウテラール・グレッチェルがのぞかれる。",
              "citation": {
                "source": "登山の朝",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "山稜の上に残った雪の上に、荷を下ろして一休みした、後ろはひどくえぐれた深い崖の底に、ラウテラール・グレッチェル Lauteraar Gletscher がのぞかれる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
