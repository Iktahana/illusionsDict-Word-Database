[
  {
    "uuid": "c4ae3256-963c-5a06-9544-1b0e56468414",
    "entry": "どきん",
    "reading": {
      "primary": "どきん",
      "alternatives": [
        "どきり",
        "ドキン",
        "ドキリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞-と",
        "副詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being startled",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、どきんと胸打たれた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の胸は宿題をなまけたのに先生に名を指された時のように、思わずどきんと震えはじめました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの心臟をどきんとさせて突然汽笛がなりはためいた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お末はどきんとして立ちすくんだ。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこれまで耳にした私に関する批評の中で、一番どきんとしたのは、伊吹武彦氏の、「ええか、織田君、君に一つだけ言うぞ、君は君を模倣するなってことだ」　という一言だった。",
              "citation": {
                "source": "私の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍へ来られると、坂田はどきんどきんと胸が高まって、郵便局の貯金をすっかりおろしていることなど、忘れたかった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　思いがけぬ時に、思いがけぬ妹の弓子を見て、千枝子はどきんとした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ、何を……」　円みを帯びた柔い感触に、鶴雄はどきんとした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」九「……望月のやつはね、思わずどきんとしたわ」　と、弓子は鶴雄に語った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところで、望月のやつは思わずどきんとしたまでは判ったが、それからどうなったの……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――どきんとして、まず手を離したのよ」「それから……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、こんなお方やなかったのに……」　と君勇はそんな三好をあわれむ前に、何か気味の悪いものがどきんと胸に来た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄は照れるよりも、まずどきんとした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫なんだ」　だから、あんな奴は殺してもいいと、ラスコリニコフみたいに呟いている自分に、しかし鶴雄はどきんとしたのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五「さあ、誰だろうね」　と言って、小田は自分で自分の言葉にどきんとした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三行書いて、新しい煙草に火をつけ、そして、一休みするつもりで、ペンを置いて、かたわらの新聞を取り上げて、読んでいるうち、小田はどきんとした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分なら、これから頼って行く細工谷町の友人の家は、無事に残っているかも知れないと、思いながら四ツ辻まで来た時、小沢はどきんとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小沢はどきんとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青さに、小沢はどきんとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも小沢は、何かしら得体の知れぬ予感を感じて、どきんとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――なぜ、こんなに怖れるのか」　と、考えて、豹吉はどきんとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に、豹吉はどきんとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官を見て、どきんとしたのではなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「三」の数字に信吉はどきんとした。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　信吉はどきんとした。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉はどきんとした。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜美子はうれしさに胸が温まって、暫らく口も利けず、じっと妹の顔を見つめていたが、やがて、いきなり妹の手を卒業免状と一緒に強く握りしめた、その姉の手の熱さに、道子はどきんとした。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　きいたことのある名だと思った咄嗟に、道子はどきんとした。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と嘲る言葉は当のお君より傍できいている豹一の胸にどきんとこたえ、豹一の眼は安二郎に挑みかゝるようにギラ／＼光るのだったが、安二郎はそんな彼には眼もくれず、たゞお君の連れて来たこぶ位に思って、問題にしなかった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
