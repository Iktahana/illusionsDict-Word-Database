        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうかするとその月にその温度の日が最も多いという意見に思いちがえられるのである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢えに泣いているはずの細民がどうかすると初鰹魚を食って太平楽を並べていたり、縁日で盆栽をひやかしている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかするとこの影が小川へ飛込んで見えなくなったと思うと、不意に向うの岸の野菊の中から頭を出す。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると自分の脚の上へ来るのでキャッ／＼と大騒ぎをする。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖、みんな眞面目で、みんな嚴肅な顏をして、みんな高尚な事ばかり言つて、哲學者氣取りでゐますが、それでゐて我々の大多數は百人のうち九十九人まで、まるで野蠻人のやうな生活をして、ちよつとどうかすると、すぐ啀み合つたり、惡口をつき合つたりします。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿坊の造りは一定していないが、往還から少し引ッ込んだ門構えに注連を張り、あるいは幔幕をめぐらせ、奥まった玄関に式台作りで、どうかすると、門前に古い年号を刻み入れた頂上三十三度石などが立っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその花は、一つのこずえの尖端に、十数個から二十ぐらい、鈴生りに群って、波頭のせり上るように、噴水のたぎるように、おどっているところは、一個｜大湊合の自然の花束とも見られよう、その花盛りの中に、どうかすると、北向きに固く結んだつぼみが見える。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵のうちには鈴を振るような音がよく聞こえたが、しかしどうかするとその音がまるで反対の方向から聞こえるように思われた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると一人の作者の顔が男になったり女になったりする事さえある。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかするとあまりに重く堅過ぎるように私には思われる事もあるが、考えてみると、それを取り去ってはやはり作者の影が稀薄になるかと思う。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば李白の詩を見ても、一つの長詩の中に七言が続く中に五言が交じり、どうかすると、六言八言九言の交じることもある。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの顔の赤い、そしていつでも少し眼が血走ってどうかすると泣いているように見える、あの生徒だ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると風呂場が肥溜と一つになっている。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚の妻女が二つになる子どもをつれてきて、そこに寝せてあればその子の呼吸の音がどうかするとわが子のそれのように聞こえる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もいままではどうかすると、哲学とか宗教とかいって、自分を欺き人を欺いたことが、しみじみ恥ずかしくてならなくなった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると帰りが晩くなる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうかすると一晩くらいそこで泊るような必要が起るかもしれない。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この著者がどうかすると腥さ坊主と云われる所以かもしれない。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの裸体の少女でも、あれを少しどうかすると支那画の童子のような感じが出そうである。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学の講義のようでもあり、また最も実用的な処世訓のようでもあり、どうかするとまた相対性理論や非ユークリッド幾何学の話のようでもある。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、文芸家仲間から、映画作家には自己内容が貧困していると言われる。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもどうかすると妙なことがある。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかするとペエテルの腰を掛けてゐた跡に、娘の手から飜れ落ちた草花が二三本落ちてゐることがある。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、どうかすると眞夜中過ぎても眠れずに、變に冴えてしまつた頭の中で物語のあとをまた色々に辿りながら、時には隣に寢てゐる祖父母達を呼び起したくなるやうな恐怖感に襲はれたりするのであつた。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、また作者が愛を熱心に宣傳して居るやうな場合にでも、寧ろその理智を以て故らにそれを力説しようとする爲めに、どうかするとその愛は、作者の心から滲み出たものではなくて、宣傳の爲めに宣傳してゐると云つたやうな感じがする事があります。",
              "citation": {
                "source": "三作家に就ての感想",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとは、「ポーピーポー」というふうに、中に一つ長三度くらい高い音をはさんで、それがどうかすると「起きろ、オーキーロー」と聞こえたものであるが、近ごろは単に「ププー、プープ」というふうに、ただひと色の音の系列になってしまった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると夜風は涼し過ぎる。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃かの地でボーアに会って帰って来た友人の話によると、このまだ若い学者は、どこか近い田舎に小さな別荘のようなものを有っていて、暇のあるごとにそこへ行く、そうして平和な周囲と新鮮な空気の中に想を練りペンを使う、どうかすると芝生の上に寝転がって他所目にはぼんやり雲を眺めているそうである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は懸命の努力にも拘わらず、どうかすると、こッくりこッくりと、脳髄が執拗な睡眠に襲われ、立ったまゝひょっと他の世界に引きずりこまれそうになった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
