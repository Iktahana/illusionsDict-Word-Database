          "literary": [
            {
              "text": "「別にどうってことはないんだ。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（くしゃみ、二つ三つ）諏訪　いいえ、それじゃ、妾の気持が済まないの、だから、あなたにどう、未納にどうってことはないの。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸太郎　早く帰ったからどう遅く帰ったからどうってことはないさ。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこうなればどうってことはない。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともザクロを戻してもらっても、どうってことはない。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうってことはない、彼は思った。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
