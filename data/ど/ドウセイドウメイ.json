    "definitions": [
      {
        "index": 1,
        "gloss": "having the same family name and given name (as someone else)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同姓同名の誤りだらうと云つた。",
              "citation": {
                "source": "秋・二日の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぢや同姓同名の誤りぢやないんですな。",
              "citation": {
                "source": "秋・二日の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "深尾みな子といえば私の妻とまさに同姓同名ではないか、いったい今日という日は何という日だろう。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、ホテルの中には、妻と同姓同名の女が、現に私の前にすわっているではないか。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は僕と同姓同名でミュンヘン大学の教授をつとめておりました。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが大阪の新聞に専門棋士を七人抜いた天才少年棋士のことが載っていて、それがあの時の少年木村義雄と同姓同名であったのを見て私は不思議の感を催していたところ、それから一年後の年始状に将棋六段木村義雄と署名したのが届いた。",
              "citation": {
                "source": "淡紫裳",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの系図の中にも、いかに同姓同名の人々がたくさんあることか＊。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　モンテーニュの家来の中にもピエール・エイケムという同姓同名が父以外にも二、三名あって、事実、後世の伝記作者に幾度も人違いをさせている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里の中学校で英語を習った先生と同姓同名だ。",
              "citation": {
                "source": "ロマンスと縁談",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同姓同名はありえない。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "配達のひとが、昨夜「下連雀の百何番だったかなあ、もう一人同姓同名のひとがありますねえ、やっぱり、ダザイ、オサムというんですよ」と申しました。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
