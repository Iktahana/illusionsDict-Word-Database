[
  {
    "uuid": "7c24981d-89f2-5b1b-9049-400baf3b6e17",
    "entry": "同格",
    "reading": {
      "primary": "どうかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞",
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the same rank",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "科学的知識の進歩した結果として、科学的根拠の明らかでない云い伝えは大概他の宗教的迷信と同格に取扱われて、少なくも本当の意味での知識的階級の人からは斥けられてしまった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳と目とが同じ高さにあるのは視覚空間と聴覚空間との連絡、同格化のために便利であろうと思われる。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ招待日が来るとＹ博士の家族と同格になって観覧に出かける。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文典の巻末にある作文や翻訳の例題と同格な応用数学的論文もなくはない。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが見るとムッソリニが閲兵式に臨んでいるニュース映画もこれと全く同格な現象のニュースとして実におもしろく見られるのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは能楽師として格外の名誉で、武功者が主君の御乗馬を拝領したのと同格である。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら鼻が動的表現に埋もれていても、何ぼ形容詞が沢山にあっても、何程都合がよくっても、又は鼻が神様と同格のものであるとしても、眼や口と同じような表現を鼻に押しつけるのは無理であるという事を、深く深く認めさせようという議論の立て方でありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、同格の旗本から物を教わるのに、こちらから出向かない法はないので、越前が辞退すると、「いや、遠慮めさるな。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれがだんだんに固定し現実化してしまって今ではもう一つの体験の記憶とほとんど同格になってしまっている。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お聞きなさい――橘さん……いやしくも東京から家元同格の貴下がおいでだと云うで、今夕、申合打合せのために出向いた、地謡、囃子方一同は、念のため、酒席といえども、裃を用意しておるですぞ、何事ですか、この状は。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は呼んで、宗家同格と渠を称える。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる攘夷家も蝙蝠安や与三郎と同格に認められるようになって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十か二十一で一躍して数年以上の操觚の閲歴を持つ先輩を乗越して名声を博し、文章識見共に当代の雄を以て推される耆宿と同格に扱われた。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "元より弓馬槍剣といったような武士に必須な技術においては、彼の技量はたちまちに上達して、最初同格であった近習たちをぐんぐん追い越して、家中においてその道に名誉の若武者たちにも、たちまちに打ち勝つほどの上達を示すのを常とした。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "野々宮君のような新式の学者が、もの好きにこんな家を借りて、封建時代の孟宗藪を見て暮らすのと同格である。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰参は叶ったというものの、当分は他の雇人と同格の待遇で、雇人同様に立ち働かなければならなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "正味は四丈八尺ですが、吹聴は五丈八尺という口上、一丈だけさばを読んで奈良の大仏と同格にしてしまいました。",
              "citation": {
                "source": "佐竹の原へ大仏をこしらえたはなし",
                "author": "高村光雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤポーシカとは我国の露助と同格で、日本人の賤称だ。",
              "citation": {
                "source": "露都雑記",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "――言ふ迄もなく画は黒繻子の帯と同格の値段だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "マクベスの門番は山寺のカッポレと全然同格である。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホルデーンに依ると、有機體は環境に、或ひは、環境は有機體に同格化され、これによつて生命が維持される。",
              "citation": {
                "source": "論理と直觀",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして男の暴力によつて、保護されたり、掠奪されたり、物品と同格にあつかはれる女の生活中には何があるのでせうか。",
              "citation": {
                "source": "嫁泥棒譚",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二十一）　刹那的文藝觀　豐太閤と云ひ、ナポレオンと云ひ、すべてかういふ風に解釋して見ると、國家の内部生命となつて居る文藝と同格であるのだ。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "参右衛門の末の娘はこの家に奉公しているが、前には、弥兵衛と同格の名門であった彼のこの没落には、人の同情を誘ういたましいものはない。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "平民と同格なるはすなわち下落ならんといえども、旧主人なる華族と同席して平伏せざるは昇進なり。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "新富座主が新機運を掴んだ機智と並んで、劇界の大明星であった、九世市川団十郎の人格、識見――伝統的｜大立物の風格が、当時の学者、識者、貴顕たちに、自分たちの埒外の分野から同格者を見出した欣びを以て尊敬し迎えいれられたことが見｜逃せない。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度び拜謁したる者は、假令幕臣ならざるも所謂御目見以上の格式にして、諸藩士の上に位し、幕府旗下の士と同格なるが故に、儒醫の身に在ては殆ど無上の榮譽にして、世間の名望甚だ高し。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の、極度に気をゆるしてかゝつてゐる素浄瑠璃会に、銭を出して見つけてゐる客から見れば、――其は批評家だつたのだが――、今日は同格の見物であつても、今日もやはり遠慮して貰ひたかつた筈だつた。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかくれぐれもおからだを大事になされてくだされませ」そして馬はていねいにおじぎをして向こうへ歩いて行きました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず与次郎が持って来てくれる――とまではむろん彼を信用していないのだが、まあどうかくめんしてみようくらいの親切気はあるだろうと考えている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
