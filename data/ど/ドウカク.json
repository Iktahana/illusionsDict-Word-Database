            },
            {
              "text": "双方の言葉が通じるというわけには行かなかったが、同伴者があるかどうかくらいのことは解った。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの職場へわたしがいった頃あそこにいた人たちに、どうかくれぐれもよろしく。",
              "citation": {
                "source": "ファシズムは生きている",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が帽子をかぶってたかどうかくらい、分りそうなもんじゃないか。",
              "citation": {
                "source": "話の屑籠",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかくれぐれもさうお伝へ下さい。",
              "citation": {
                "source": "空の赤きを見て",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかくれ／″＼もからだに気をつけて、かうして離れてゐる者の為に出来る限り元気な長命をなされて下さい。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "通常結婚期に達して居る男子の父母は、自分の財産および家の系統、階級等に相応した家に結婚期に達して居る娘があると、その娘の父母の家に媒介人を遣わしてその娘をばどうかくれろと申し込むのです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかくれぐれもお大切に。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となく小説にかきたくて、まだどうかくか分らなくている一つの気持があるの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかくのかまるで見当つかず。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妃がお産の床につきましたら、どうかくれぐれもいたわってやってください。",
              "citation": {
                "source": "手なしむすめ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまではどうかくつろいでください」　デンはしっかりした手つきで、ワインを手酌で飲んだ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだ、七重に話してみよう」やがて、眠れない寝床の中で彼はそう呟やいた、「七重に話してみれば見当がつくかもしれない、少なくとも悪戯かどうかくらいはわかるだろう」　明くる朝。",
              "citation": {
                "source": "艶書",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――罪を得るも、まぬがるるも、いずれにせよ、この病身、世に長い半兵衛とも思われねば、どうかくれぐれもお身に頼んでおく。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
