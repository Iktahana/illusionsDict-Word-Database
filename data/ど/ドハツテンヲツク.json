        "examples": {
          "standard": [
            {
              "text": "彼の無責任な態度に、私は怒髪天を衝く思いだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームの不甲斐ない結果に、監督は怒髪天を衝く勢いで選手たちを叱責した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の不正行為が発覚し、関係者全員が怒髪天を衝いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "異教徒席の中から赭い髪を立てた肥った丈の高い人が東洋風に形容しましたら正に怒髪天を衝くという風で大股に祭壇に上って行きました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんとネタが上っているんだぞ」　それは真に怒髪天を衝くといった形相だった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本も、軍事的行動に於て所謂怒髪天を衝く態に猛勇なばかりでなく、文華の面でこのように独自であり、政府もその評価に吝でないという一つのジェスチュアとして、アカデミーもつくられる一つの時代的必然があるのである。",
              "citation": {
                "source": "矛盾の一形態としての諸文化組織",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒髪天を衝くばかりの勢であった私は一たまりもなく慄え上った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒髪天を衝く、とはまさにこれを耳にしたときの彼の形相といってよい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
