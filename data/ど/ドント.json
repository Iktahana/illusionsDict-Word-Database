[
  {
    "uuid": "672af90a-611d-5930-b5d6-7d18a18b321b",
    "entry": "呑吐",
    "reading": {
      "primary": "どんと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
