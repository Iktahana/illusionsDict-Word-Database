[
  {
    "uuid": "5568f0ac-871c-57c2-9679-98b48e196a59",
    "entry": "土蛮",
    "reading": {
      "primary": "どばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "uncivilized indigenes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかも諸公の為す所を見れば、諸公の簡を尊ぶこと、土蛮の生殖器を尊ぶが如くなるは殆ど恐怖主義者と同一なり。",
              "citation": {
                "source": "文部省の仮名遣改定案について",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに戦争は、文明的戦争は、ヤクサ山の入り口における強盗の略奪より、パス・ドートゥーズにおけるコマンシュ土蛮の劫掠に至るまで、山賊のあらゆる形式を取り用い寄せ集めたものである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして彼は次第に、気の長い猛獣狩りの土蛮が豹を柵へ追いこむように追いつめられて、ついに曹操の大軍のうちに完封された。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げるわ逃げるわ、土蛮の群れは、さながら枯葉を巻くように四散してゆく。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "無智な土蛮の者といえども、その恩にはみな感じた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち、合図の角笛が鳴ると、四方に隠れていた土蛮が、董荼奴を殺し、阿会喃を取りかこみ、二つの首を取ると、死骸は谷間へ蹴落して、わあと、狼群のように本陣へ帰ってきた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "切りそいだ崖の根がたにどばんどばんと浪の打ちあげている所もあり、またその根に狭く荒い石原があってそれに白々と寄せている所もある。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
