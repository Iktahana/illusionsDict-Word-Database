          "literary": [
            {
              "text": "オレは進駐軍関係の土建業務もやっとるから、キリスト教のよいところも充分に知っとるが、やっぱし宗教はカシワデ、指圧。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "テキヤなどとは昔の言葉で、今では土建業、ナント力組、即ち、紳士である。",
              "citation": {
                "source": "カストリ社事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも、後で聞いたところによると、小夜子の夫は、やつぱり土建業の新興事業家だつた。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
