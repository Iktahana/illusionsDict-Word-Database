    "definitions": [
      {
        "index": 1,
        "gloss": "(young) girl",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "七つ八つの童女の容貌を持ち、ただその儘で身体は大きい。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "童女は黒地に赤い縞の洋服を着て、右の手に花を一輪もっている。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "間に合せものばかりのこの竹の台に、あの童女像ばかりはどうも間に合せでない。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを眺めているうちにも、また展覧会の童女の像を思い出した。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会で童女像を見た事と壷のアドヴェンチュアーとは一見何の関係もない事のようである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は娘を神秘な童女に思い做して、自家｜偶像崇拝慾を満足せしめたい旧家の家長本能を、貝原との問題に対してどう処置するであろうか。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五歳の童子や童女達であった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "童女のような可憐な泣き方なので、まんざらでない。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてウェルズの短編「壁の扉」の幻覚を思い出しながら、この次にいついかなる思いもかけぬ時と場所で再びこの童女像にめぐり会うであろうかという可能性を、さじの先でかき回しながら一杯の不二家のコーヒーをすするのである。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は二人の童女の項に軽く手を置き添えて、口の中で小さな祝祷を捧げてやった報酬に、まず二人から寝前の接吻を受け取った。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の届く限りに姿は見えないなと思う間もなく収穫小屋の裏木戸が開いて、斑入りの白い羽を半分開いて前に行くものの背を乗り越し乗り越し走り出た一群の鶏といっしょに、二人の童女が現われ出た。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファニーはとうとう童女の境を越えてしまったのだ。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前はもう童女じゃない、処女になってしまったんだね」　ファニーは見る見る額のはえぎわまで真赤になった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日から私は童女の清浄と歓喜とに燃えた元のようなファニーの顔を見ることができなくなってしまった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗てこんなとんきよな顏をして、頭をおかつぱにした童女がたしかに此世に生きてゐた事があるのだ。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその童女は今は何處を探してもゐないのだ。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その西原氏を狂童女がどこから眺めて送迎してゐたものか、西原氏の市中へ出る途を擁してゐて、或朝、まだ醉つてゐない西原氏に一人の品の宜い初老位な奧樣風の女性が、坂の上の大邸宅の一つから出て來て立ち向つた。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と彼女は、幾度も幾度も、考へ拔いた上のことらしく、語調に惡びれた樣子もなく、すらすらかういつて、西原氏に狂童女に一度會つて呉れるよう、ひたすら頼み入るのだつた。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ツ目小僧の童男童女。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しおくれて、童男と童女と、ならびに、目一つの怪しきが、唐輪と切禿にて、前なるは錦の袋に鏡を捧げ、後なるは階を馳せ下り、巫女の手より梭を取り受け、やがて、欄干擬宝珠の左右に控う。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と見れば貧民の童男、童女、多人｜数老婦人の身辺にありて、物珍しげに天窓より爪先までじろりじろり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、二十年の永い間、慈愛深い母親として自分を育て上げてくれた、浄かな童女の死顔の上に、永いこと泪に暮れていたのであった。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れな童女の歌声が、幻聴のように、かすかに遠くから聞えます。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の望む美魚はどうしても童女型の稚純を胴にしてそれに絢爛やら媚色やらを加えねばならなかった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人が童女のままで大きくなったような容貌も苦労なしに見えて、何やら苛め付けたかった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大きな童女のような女をして眼を瞠らせ、五感から享け入れる人の世の満足以上のものを彼女をして無邪気に味い得しめたなら料理それ自身の手柄だ。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "派手な童女型と寂しい母の顔の交った顔である。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生艶美な童女で暮した女だ」　友人はこれを聴いて、君助は孤独の寂しさから、少女｜病にかかつて、どの女も処女だと思ひ込むのだといつたが、君助はそれでもいゝ、結局男の望む理想の女はさうした女なのだと言ひ放つた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝、私は寝床の中で、童女のいい歌声を聞いた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰めのすぐそこから嘘がばれて行くに定まっているじゃありませんか」　「良く解りました、あなたのおっしゃること」　続けて尾田は言おうとしたが、その時、　「どうじょぐざん」と嗄れた声が向こう端の寝台から聞こえて来たので口をつぐんだ。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
