    "definitions": [
      {
        "index": 1,
        "gloss": "pleased to meet you",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ドウゾお構いなく、いずれ又そのうちに……どうぞ宜しく……」　と切れ切れに云い云い玄関に出て、靴に足を突込むや否や表に飛び出して、格子戸をピシャリと閉めた。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうぞ宜しく、」といって梓は戯れに頭を下げた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "梓はこれを聞いて、何か気がさしたような様子であったが、笑に紛らして、「どうぞ宜しく、」「ええ、それはもうね。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれお見舞にうかがいますから、どうぞ宜しく」　お安の祟りがだんだん事実となって現われて来るらしいので、文字春は身もすくむようにおびやかされた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どうぞ宜しく願います。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴天連様にもどうぞ宜しく仰しゃって下さい。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ宜しく」　キャプテン深谷氏の友人黒塚と云うのは、見たところまだ四十を五つと越していない、かっぷくのいい隆としたアメリカ型の紳士で、夫人の実弟洋吉と云う方は、黒塚氏に較べて体も小さく年も若く色の白い快活そうな青年だ。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も知らん顔もしていられないから、老人へは葉巻を二本、他の連中へもそこばくの黄白を撒いて「どうぞ宜しく」とやった。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生風の男は平一郎がまだ少年らしい中学生であることなどを知らないかのように「僕は宮岡と申します、どうぞ宜しく」と頭を下げた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様がお帰宅になったら、どうぞ宜しく申上げて下さい」「そうですか、では気をつけてお帰りなさいね。",
              "citation": {
                "source": "Ｐ丘の殺人事件",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美禰子さんも上る筈ですが、此頃少し忙しいものですから――どうぞ宜しくつて……」「何か特別に忙がしい事が出来たのですか」「えゝ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "御帰りになったら、どうぞ宜しく」「あの……」と口籠っている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ宜しく――」と紹介した。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さんにもどうぞ宜しく。",
              "citation": {
                "source": "羊羹",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、横田さんへどうぞ宜しく仰しゃって下さい。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イリリヤさん、これがわたしたちの新しい仲間……」と言ひかけた小幡氏の口上が終らぬうちに、「どうぞ宜しく」と流暢な日本語でいひ、はにかむやうにニッと笑ふと、ちよつとためらつてから手を差し出した。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ私が列車の中まで持って参ります」　汽車が出る時、黙って丁寧に会釈をした書生に、「どうぞ宜しく」と挨拶を返した津田は、比較的込み合わない車室の一隅に、ゆっくりと腰をおろしながら、「やっぱりお延に来て貰わない方がよかったのだ」と思った。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ宜しく」　三室銀子はそれを気にする様子も無く、丁寧に挨拶するのを見ると、深沢深はいやな心持になってそっぽを向いてしまいました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "結婚ラプソディ",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国から帰ったばかりで、お友達もありません相ですから、どうぞ宜しく」　そう言って、一座の人達に引き合せてくれました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "序の時、どうぞ宜しく取なして下さい。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "七人の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、君は翠川君、待っていましたぞ――御存じだろうが、私は唐崎荘之介、この平泉発掘事業の投資者だ、一緒に来たのは秘書の杉村三五郎君、どうぞ宜しく」「…………」　健一は黙って挨拶して、この古風な頬髭を持った実業家の向うへ腰をおろしました。",
              "citation": {
                "source": "水中の宮殿",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでの時、どうぞ宜しく取りなして下さい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "七人の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしても、お話はよくわかりましたから、帰り次第、その旨申伝えて置きましょう」「ではどうぞ宜しく御伝え下さいませ。",
              "citation": {
                "source": "青バスの女",
                "author": "辰野九紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それで、と申す訳でもございませんけれども、そんなことから、ついその、何でございます、………」「あはゝゝゝゝ」「どうぞ宜しく御推察を、………」「大方そんなことだろうと睨んでいたんですが、やっぱりそうだったんですね」「恐れ入ります」「で、何度ぐらい逢っておられる？",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年もまた、どうぞ宜しく御願いいたします。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞよろしく……」　という話が決定った。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞよろしく」　勃凸はそれを取り上げると蟆口の底の方に押し込んだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞよろしくお頼み申します」　といったような開き封の遺書が、叔父宛にした密封の書類と一緒に置いてあった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハハハハハハ」　二人は叔父の笑い声の前で椅子から立ち上って「どうぞよろしく」と挨拶を交した。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞよろしくお願ひしますだ。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
