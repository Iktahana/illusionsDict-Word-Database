[
  {
    "uuid": "e274c910-b70a-56de-8385-b02af68649e3",
    "entry": "独立自尊",
    "reading": {
      "primary": "どくりつじそん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(spirit of) independence and self-respect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人間は一方でイミテーション、一方で独立自尊、というような傾向を有っている。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし女としては、と女に向けられた面での言葉は、決して四十何年か前、福沢諭吉が気魄をこめて女子を励ました、そのような人間独立自尊の精神の力はこめられていない。",
              "citation": {
                "source": "三つの「女大学」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭髪の薄い円顔に小肥りな事業家肌のこの叔父にも、ひとむかし騒がれた鹿鳴館以来の開化文明の欧化思想に浸った形跡もあって、床には諭吉から直接に貰った独立自尊の軸物がよく懸っていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾党の男女は、独立自尊の主義を以て修身処世の要領と為し、之を服膺して、人たるの本分を全うす可きものなり。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二条　心身の独立を全うし、自から其身を尊重して、人たるの品位を辱めざるもの、之を独立自尊の人と云ふ。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "独立自尊の人は自労自活の人たらざる可らず。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "原因事情の如何を問はず、自から生命を害するは、独立自尊の旨に反する背理卑怯の行為にして、最も賤む可き所なり。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六条　敢為活溌堅忍不屈の精神を以てするに非ざれば、独立自尊の主義を実にするを得ず。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七条　独立自尊の人は、一身の進退方向を他に依頼せずして、自から思慮判断するの智力を具へざる可らず。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明の男女は同等同位、互に相敬愛して各その独立自尊を全からしむ可し。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夫一婦終身同室、相敬愛して、互いに独立自尊を犯さゞるは、人倫の始なり。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十一条　子女も亦独立自尊の人なれども、其幼時に在ては、父母これが教養の責に任ぜざる可らず。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "子女たるものは、父母の訓誨に従て孜々勉励、成長の後、独立自尊の男女として世に立つの素養を成す可きものなり。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十二条　独立自尊の人たるを期するには、男女共に、成人の後にも、自から学問を勉め、知識を開発し、徳性を修養するの心掛を怠る可らず。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "健全なる社会の基は、一人一家の独立自尊に在りと知る可し。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十四条　社会共存の道は、人々自から権利を護り幸福を求むると同時に、他人の権利幸福を尊重して、苟も之を犯すことなく、以て自他の独立自尊を傷けざるに在り。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "其大小軽重に論なく、苟も責任を怠るものは、独立自尊の人に非ざるなり。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々相信じて始めて自他の独立自尊を実にするを得べし。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十四条　日本国民は男女を問はず、国の独立自尊を維持するが為めには、生命財産を賭して敵国と戦ふの義務あるを忘る可らず。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り自ら尊大にして他国人を蔑視するは、独立自尊の旨に反するものなり。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育は即ち人に独立自尊の道を教へて之を躬行実践するの工風を啓くものなり。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは独立自尊の必要を固く心に沁み込まされているので、父の遺産の収入には手も触れないで、自分自身の給料で自活していた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし両方共困難ならぷつりと縁を截って、独立自尊の態度で敵を見ているがいい。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二十七年十月著者識独立自尊の精神　私は明治三年の生れで、生れたところは日本アルプスの山麓の穂高という村です。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治のはじめ、福沢諭吉翁が唱えていた「独立自尊」という言葉ですが、私はだいたいあの気持で商売をやって行きたいと思ったのです。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで晩年に至って先生の種々の修身、もしくは独立自尊、あるいは婦人問題という建設的の道徳論が沢山あるのは、ちょうどその破壊の後始末であると考えるのである（拍手）。",
              "citation": {
                "source": "明治文明史上に於ける福沢翁",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "福沢氏は大なる常識を備えてもっぱら西洋の物質的智識の教育を施し独立自尊の倫理を説き且つ実行した人、また新島氏は基督教主義の精神的教育を施した人で、遣り方はよほど異っていたけれども、両者共に独立不羈にして天下の徳望を博したる点に於ては他に比ぶ者がない。",
              "citation": {
                "source": "新島先生を憶う",
                "author": "二十回忌に際して",
                "note": "青空文庫"
              }
            },
            {
              "text": "独立自尊の意気、吾一人天下に抗せんと云うヒロイズムが最も必要である。",
              "citation": {
                "source": "第四階級の文学",
                "author": "中野秀人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
