        "examples": {
          "standard": [
            {
              "text": "奴隷貿易は、何世紀にもわたって続き、数え切れないほどの人々を苦しめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あれが果して奴隷貿易に便利だつたか、それとも早まつて獵用ナイフを使つた時の後始末に出來てる物だか、私には決める事は出來ない。",
              "citation": {
                "source": "醫師と旅行鞄の話",
                "author": "ロバート・ルイス・スティーヴンソン",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は利益が減少し続けていると言い張って奴隷貿易をあっさり放棄した。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
