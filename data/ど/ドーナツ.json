        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……ドロップ、ミンツ、キャラメル、チョコレート、ウエファース、ワッフル、ドーナツ、スポンジ、ローリング、ボンボン、そのほかいろいろ、ある事ある事……。",
              "citation": {
                "source": "お菓子の大舞踏会",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつれて五色の着物を着た小人のミンツ達を先に立てて、キャラメル嬢をまん中にワッフルの兎、ドロップの道化役者、チョコレートの黒ん坊、ドーナツの大男、そのほかいろいろのお菓子達が行列を立てて行くあとから、スポンジ嬢が手鼓をたたきながらついて行きます。",
              "citation": {
                "source": "お菓子の大舞踏会",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄黒いドーナツ面へ蒟蒻の白和えみたいに高価いお白粉をゴテゴテと塗りこくる。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "池　私はあの東京の大地震の時、幸いにも恵まれた二個のドーナツを大切に抱いて、やっと一夜をすごしたことがあった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで折角のうれしいドーナツも、乾いた海綿の如く口中に充満して私は悲しかった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "山だけの風景は震災のドーナツである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折角ゆうべドーナツこしらえたのに忘れてきてしまった」白ガスリのブラウズをもって来てくれる。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お汁粉、ドーナツ、曹達水を御馳走になって帰って来た。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りには奥様のお好きなドーナツを土産に、坊ちゃんと私は絵葉書を二組づつ買って戴きました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなドーナツもあれば、柔かいオランダ風ドーナツもある。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午扶桑書房清水氏來り青森の林檎、新宿中村屋ドーナツ其他を贈らる。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのドーナツ型の馬鈴、むかしのものは良質で音がよいから、狸小路の三軒の古道具屋が目当てであった。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーナツ型のでなく、映画「馬喰一代」で注意ぶかい人は見たはずの、すずらん型の小鈴である。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、さし渡し四十二間のドーナツみたようなものをつくればよいので、材料は二十くらいの小室分にわけて運ばれて来る。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このドーナツ型の人工衛星を、たくさんの小室に区切っておくことは、流星にうたれた場合に有利である。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さし渡し四十二間のこの大型ドーナツは、太さも太くて、切口の直径が約五間ある。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず渡洋旅客機の胴体の三倍くらいの太さの円筒が、大きいドーナツ型になったものと思えばよい。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうドーナツ型にしたのは、この人工重力をつくるのに便利なためである。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このドーナツをゆっくり廻転させてやればよいのである。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでドーナツの中心を通って、一本太いスポークを通しておく。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーナツの部分から、このはしごを上って行くと、次第に重力が感ぜられなくなり、中心へ行くと、全く身体が宙に浮いてしまう。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球から運ぶもの　人工衛星構築の材料や、各種の装置及び機械などは、初めの建設時代中に運び終ったとして、いよいよこのドーナツが出来上った時に、地球から運ぶべきものの中で、一番重いものは何であるか。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さし渡し四十二間のこの大きいドーナツと、スポークとの容積は、合計一八、四〇〇立方メートルになる。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーナツのような朱や緑の浮輪。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "▽　ドーナツツに穴のある様に、もつと現実的にいつて、便所の防臭剤に穴のある様に、丸ビルの内側にも、通風と採光の穴があいてゐる。",
              "citation": {
                "source": "丸之内点景",
                "author": "‥‥東京の盛り場を巡る‥‥",
                "note": "青空文庫"
              }
            },
            {
              "text": "細長いテーブルの上には、ゆで卵を盛った皿、袋入りのバター・ピーナッツを入れた瓶、それから、ドーナツ、ワップル、シュークリーム、渦巻カステラの類いを収めたガラスの菓子箱がならんでいる。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、コーヒーにドーナツだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はＢＬＴを食べ、ぼくはドーナツを食べた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウンターのなかの店主に、ぼくはコーヒーとドーナツを注文した。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
