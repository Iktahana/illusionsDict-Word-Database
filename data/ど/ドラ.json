    "definitions": [
      {
        "index": 1,
        "gloss": "loafing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だんだん薄暗くなって色々の灯でいろどられてゆく上野広小路の雑沓の様子を見おろしていたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうどら声があちらこちらに聞こえた。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧がまた少し来た、夜になると、甲府市の電燈が黄いろの珠のように、混沌の底から、ボーッと見えた、先刻の汽船といい、この電燈といい、人間に遇わずに、山から山を伝わって、野獣のような生活をつづけていた人々の胸をおどらせた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正年間の大噴火に押出した泥流を被らなかつたと思はれる部分の山腹は一面にレモン黄色と温かい黒土色との複雑なニュアンスをもつて彩どられた草原に白く曝らされた枯木の幹が疎に点在してゐる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池をかこんだ樹陰のほの暗さ、池はその周囲の幽暗にくまどられ、明方の月のように静寂な水の面貌を浮べていた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」向ふの席の燈台看守がいつか黄金と紅でうつくしくいろどられた大きな苹果を落さないやうに両手で膝の上にかゝえてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どら、」カムパネルラもそらを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の健康は今兄の手にもどらうとしてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どら、どんなんぞい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隊を指揮する、取っておきのどら声で怒なりつけようとした。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり空想だと笑われるかも知れませんが、白状しますと、六蔵は鳥のように空をかけ回るつもりで石垣の角から身をおどらしたものと、私には思われるのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四面に海をめぐらす大八州国に数千年住み着いた民族の遠い祖先からの数限りもない海の幸いと海の禍いとの記憶でいろどられた無始無終の絵巻物である。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またもしそれが夢幻的空想的であるとしても、日本人のそれのように濃厚に圧縮されたそうして全国民に共通で固有な民族的記憶でいろどられたものではおそらくあり得ないであろうと思われる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが池鯉鮒の御符売りであることは半七にもすぐに覚られたので、物に馴れている彼も思わず胸をおどらせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "どら、こっちへよこせ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事ははかどらなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、それを思うと、一寸の銅の針金、一つの銅の薬罐も、坑夫の血に色どられている気がした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よう…………」「どら、こっちへおこせ！",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」向うの席の燈台看守がいつか黄金と紅でうつくしくいろどられた大きな苹果を落さないように両手で膝の上にかかえていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして伝説の化け物新作の化け物どもを随意に眼前におどらせた。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地形測量をする測量班員が深山幽谷をさまようて幾日も人間のにおいをかがずにいて、やっとどこかの三角点の櫓にたどりつくと、なんとなくうれしさとなつかしさに胸をおどらすという話である。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋の身投をするならば、よし死にきれずとも、そのこがれた胸のおもいが消えうせるという迷信を信じ、リュウカディアの岬から怒濤めがけて身をおどらせた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、未来のさまざまな幸福を語り合って、胸をおどらせた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どらが鳴る新美南吉どらん　どらんどらん　どらが鳴る。",
              "citation": {
                "source": "どらが鳴る",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
