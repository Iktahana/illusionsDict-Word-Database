        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "米良は緑の窓硝子を透いて地平線の彼方、数理的な朝の太陽に銅鑼湾の火薬庫の壁が傾いて見えるなかを、露国飛行家の操縦するらしい単葉機が空中に水のような光を発して広東の方角に引返して行くのを見た。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔銅鑼と看版　トロンボン〕銅鑼と看版　トロンボン、　　孤光燈の秋風に、芸を了りてチャリネの子、　　その影小くやすらひぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノの鍵盤とピアノの音とが、銅鑼のクローズアップとその音とに交互にカットバックされるところなどあったように記憶する。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れた胸の裡を　花瓣が通るときどき銅鑼が著物に触れて。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "島で銅鑼がだるそうにぼんぼんと鳴り椰子の木もパンの木も一ぱいにからだをひろげてだらしなくねむっているよう、赤い魚も水の中でもうふらふら泳いだりじっととまったりして夢を見ているんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」太鼓も銅鑼も鳴り出して、軍は粛々行進した。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の船室の前の廊下を通り上手に銅鑼は擦られてゐる。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三回　怪の船銅鑼の響――ビール樽の船長――白色の檣燈――古風な英國人――海賊島の奇聞――海蛇丸　春枝夫人と、日出雄少年と、私とが、多の身送人に袂別を告げて、波止塲から凖備の小蒸ぎ三十｜分。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早袂別の時刻も迫つて來たので、いろ／＼の談話はそれからそれと盡くる間も無かつたが、兎角する程に、ガラン、ガラ、ガラン、ガラ、と船中に布れ廻る銅鑼の響が囂しく聽えた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、海上の規則では、船の出港の十｜分乃至十五｜分前に、船中を布れ廻る銅鑼の響の聽ゆると共に本船を立去らねばならぬのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五回　「ピアノ」と拳鬪船中の音樂會――鵞鳥聲の婦人――春枝夫人の名譽――甲板の競走――相撲――私の大閉口――曲馬師の虎　翌朝、銅鑼の鳴る音に驚き目醒めたのは八｜時三十｜分で、海上の旭光は舷窓を透して鮮明に室内を照して居つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "船中八｜時三十｜分の銅鑼は通常朝食の報知である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コラコラ、今から居眠りをするようでは駄目じゃッ」と、髯将軍の銅鑼声はまず車中の荒肝を拉ぐ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（銅鑼の音）左手より、特務曹長｜並に兵士六、七、八、九、十　五人登場、一列、壁に沿いて行進、右隊足踏みつつ挙手の礼　左隊答礼。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」左隊右壁に沿い足踏み（銅鑼）曹長特務曹長（互に進み寄り足踏みつつ唱う）「糧食はなし　四月の寒さストマクウオッチももうめちゃめちゃだ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」別々に退場（銅鑼）右隊登場、総て始めのごとし。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（銅鑼）曹長特務曹長「大将ひとりでどこかの並木の苹果を叩いているかもしれない大将いまごろどこかのはたけで人蔘ガリガリ　噛んでるぞ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（銅鑼）右隊入場、著しく疲れ辛うじて歩行す。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（銅鑼）立てるもの合唱（きれぎれに）「いくさで死ぬならあきらめもするがいまごろ餓えて死にたくはないああただひときれこの世のなごりにバナナかなにかを　食いたいな。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（共に倒る）（銅鑼）バナナン大将登場。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関につるしてある銅鑼を鳴らすと、「どーれ」　出て来たのは三好清海入道よりまだ汚い、あらくれの坊主である。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャランジャランジャランと銅鑼が鳴ると、税関前に降りた一同はしきりに万歳をとなえてくれた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに正午にはまだかなりの間があるうちから、しきりに腹が空いて、昼餐の合図の銅鑼ばかりが待たれて困った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう昼餐の銅鑼が鳴るのもじきであろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャランジャランと銅鑼が鳴る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、あのトロンボオンは、　クラリネットは、　おお、あの喇叭、　おお、太鼓は、銅鑼は、　そうだ、曲馬、曲馬。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という銅鑼声がうしろにした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、白い帽子の白詰め襟の老ボーイ、食堂の入口に現れるなり、燦爛と、さて悲しげに笑ったが、左に銅鑼、右に撥、じゃん、じゃららん、らんらんらんらん。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん薄暗くなって色々の灯でいろどられてゆく上野広小路の雑沓の様子を見おろしていたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうどら声があちらこちらに聞こえた。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
