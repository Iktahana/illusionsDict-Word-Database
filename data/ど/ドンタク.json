        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わざわざ瓢箪型や糸瓜型にこしらえた梳き毛の固まりを、耳の前にブラブラと釣るして歩くので、ドンタクでもあまり見かけない新型である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "断章　　　１ドンタクがきたとてなんになろ子供は芝居へゆくでなし馬にのろにも馬はなししんからこの世がつまらない。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、このあいだから催促に来るんですけれど、今は調練の最中だから面会は出来ないの、きょうはドンタクで外出したのと云って、いつでも逢わせてくれないんです」「そりゃあ困るな」　歩兵の連中は門番にたのんで、藤屋の女が来たならば追い返してくれと云ってあるに相違ない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうは増田君も一緒に来てくれると好かったのだが……」「増田君は二、三人づれで吉原へ昼遊びに行ったようです」「はは、みんな遊ぶのが好きだな」　歩兵隊はドンタクと称して、一、六の日を休日と定め、その日は明け六ツから夕七ツまでの外出を許されている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歩兵もきょうドンタクに外出したものと察せられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "その推測が適中して、きょうのドンタクに外出を許された彼は、この向島の小料理屋でどこかの侍と密会している。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンタクをかしてもらう。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十三日（金曜）　今日は自分の誕生日でドンタクだ。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はどうせドンタクだろう。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはすこしドンタクの日です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、きょうは本当に本当に久しぶりにドンタクでね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其故この頃の日曜は本当にドンタクなの、しずかで。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "春になると毎日ドンタク騒ぎをやりますよ」　と小三輪さんが説明した。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
