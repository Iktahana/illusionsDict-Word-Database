    "definitions": [
      {
        "index": 1,
        "gloss": "bulky and heavy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
