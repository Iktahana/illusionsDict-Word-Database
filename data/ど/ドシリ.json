    "definitions": [
      {
        "index": 1,
        "gloss": "sound of a heavy object falling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "主人は座へ帰ってどしりと座った。",
              "citation": {
                "source": "丹藤川〔「家長制度」先駆形〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は行きづまってしまったので、仙人主義を弁護する理屈に立ち返ってしきりと考えこんでいると、どしりとばかり同じベンチに身を投げるように腰をおろした者がある。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡ってゐる人の枕もとに大きな石をどしりどしりと投げつける。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どしりどしりとなぐりつけました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木樵は草の中にどしりと落ちてううんと云ひながら少し動いたやうでしたがまだ気がつきませんでした。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木樵は草の中にどしりと落ちてううんと云いながら少し動いたようでしたがまだ気がつきませんでした。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大急で帰宅って土間にどしりと俵を下した音に、泣き寝入に寝入っていたお源は眼を覚したが声を出なかった。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　どしりと夫人の横倒。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の裁判はネネムが出て行って、どしりと椅子にすわって物を云おうと一寸｜唇をうごかしますと、もうちゃんときまってしまうのでした。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はもとの席へ帰ってどしりと座る。",
              "citation": {
                "source": "家長制度",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……次にまた浴衣に広袖をかさねて持って出た婦は、と見ると、赭ら顔で、太々とした乳母どんで、大縞のねんね子｜半纏で四つぐらいな男の児を負ったのが、どしりと絨毯に坊主枕ほどの膝をつくと、半纏の肩から小児の顔を客の方へ揉出して、それ、小父さんに（今日は）をなさいと、顔と一所に引傾げた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすぐ傍にどしりと投げ皺められて七宝配りの箔が盛り上っている帯を掬い上げながら、なお、お納戸色の千羽鶴の着物や、源氏あし手の着物にも気を散らされながら、着物と帯をつき合せて、「どう、いいじゃないの……」と、まるで呉服屋の店先で品選りするように、何もかも忘れて眺めていた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、沖の方で大きなたとえば大砲を打ったような物音がして、それがどしりと地響きをさした。",
              "citation": {
                "source": "月光の下",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の肉身の弟ではあつたが、顔に小皺の寄つた、痩せて背の高い母には毫も肖た所がなく、背がずんぐりの、布袋の様な腹、膨切れる程酒肥りがしてゐたから、どしりどしりと歩く態は、何時見ても強さうであつた。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり卓子の上へショオルだの、信玄袋だのがどさどさと並びますと、連の若い男の方が鉄砲をどしりとお乗せなすった。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何故に、そんなことを」　直助はどしりと其処へ坐るなり、其の刀を己の腹に突きたてた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからか一匹の野牛が、この森の中にやつてきました、そして誰にことはりもなく、どしりと大きな体を草の上に横にして草をなぎ倒し、かつてに棲家をつくつてしまつたのでした。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "やうやうの事で自分のした事が分かると、どしりと膝を衝いて、荒々しい絶望の挙動をし始めた。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしてみのるが座敷の汚れを掃除してゐる時に、二階で人の寐返りを打つた樣などしりとした響きが聞こえたので、義男は二階に寐てゐるのだとみのるは思つた。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　割れかかった石榴に石を加えたように沖の言葉は久慈の心中へどしりと重みのある実を落した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "客はその光をまともに浴びて、一度は卓の方へのめりかかつたが、すぐに又立ち直ると、今度は後へたじろいで、今し方しまつたペンキ塗りの戸へ、どしりと背を凭せてしまつた。",
              "citation": {
                "source": "南京の基督",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "振かぶった木刀、どしりと又右衛門の腰へ入った。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると直ぐにどしりと尻を地面に落して止まった。",
              "citation": {
                "source": "蝦蟇",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は笑いながら身をくはずみに彼の手から滑って、其処にどしりと落ちて倒れた。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
