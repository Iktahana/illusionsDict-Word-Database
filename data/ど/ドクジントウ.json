        "examples": {
          "standard": [
            {
              "text": "あの演劇は、連日満員御礼の独参湯で、チケットが全く手に入らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しくオープンしたカフェは、開店初日から独参湯の盛況ぶりだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その歌手のライブは、常に独参湯で、ファンは開場前から長蛇の列を作る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また後庭林中の夜のラヴシーンはシュヴァリエ・マクドナルドの賛美者たる若きファンのための独参湯としてやはり欠くべからざる一要件であろう。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹羽長秀に送った手紙の内容にも、その独参湯的な味がつつまれている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
