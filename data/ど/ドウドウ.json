[
  {
    "uuid": "81557d9d-6990-5d51-9486-c176adb7b289",
    "entry": "同道",
    "reading": {
      "primary": "どうどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "going with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫人の姉エリーノアも同道した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこうして御迷惑じゃが、春吉三番町の松倉様のお屋敷まで、同道して貰うた訳じゃが……」「何の何の。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はあの娘の事に就いて少々相尋ねたいために今日、良助に同道致させた次第じゃが……万一、その方の申立てによってあの胴切りの下手人が相わかれば、褒美を取らするぞ」「ヘエヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの四角の処まで、手前と御同道が願いたい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其より御國許へ飛脚を飛して、御用の儀これあり、諸役人ども月番の者一名宛殘止まり、其他は恩田杢同道にて急々出府仕るべし、と命じ給ひければ、こはそも如何なる大事の出來つらむと、取るものも取り敢へず、夜に日についで出府したり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と暫時私の顏を眺めて居つたが『あの、妾の奧樣と日出雄樣とは今夜の弦月丸で、貴方と御同道に日本へ御出發になる相ですが、それを御｜延べになる事は出來ますまいか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわりにはの、道が寂しい……里へは、きこう同道せい。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し相手が武士であるから、迂闊に召捕るわけにも行かないので、手先ふたりは三河屋のせがれ善吉を同道して、次郎の屋敷の近所に網を張つてゐると、彼は湯屋へ行くらしく、手拭をさげて表へ出た。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れて、樹明君と同道して岐陽さんを訪ねる、さつそく酒になる、久芳校長も浅川国手もやつてこられて、一升瓶が何本か倒れた、下物はお手のもので凝つたものばかり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……同道して井上さんを訪ねる、また酒だ、シヤンもゐらつしやる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――樹明来、同道して散歩、そしていら／＼どろ／＼。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どういう事情か知りませんが、この土地もちっと居辛くなったそうで、本人が急に東京へ帰りたいと言ってよこしましたから、お父さん同道で、昨夜の九時の夜行で立って来ましたよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "御無礼、御叱りには測り兼ねまするが、今後御熟懇、永く御為に相成るべき者と御見知り願い度、猶不日了休禅坊同道相伺い、御礼に罷出ます、重々御恩に被ますることでござりまする。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ほれ、日の出温泉から出た足で、僕はＳ君の家に廻って、同道して天主公教会に訪ねて見た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことはくだくだしく申上げるまでもありませんが、それから又ふた月ほども過ぎた後に、松島さんがお母さん同道でたずねて来て、思いもよらない話を持出しました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　松島さんは、まだ年が若いので、自分ひとりで縁談の掛合いなどに来ては信用が薄いという懸念から、お母さん同道で来たらしいのです。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月×日　午前五時半出発、ファニイ、ベル、同道。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田等｜尤千万なる志であるとして、途中長浜の伊賀守勝豊をも同道し、宝寺に至って、秀吉に対面した。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしなんとかご都合がついたら、ジュピターと同道にて来てくれたまえ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼は自分ひとりで見届けに行くのを恐れて、文字吉同道で先ず町役人の門を叩いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "英公は猟を好んだので、あるとき敬業を同道して、森のなかへはいって獣を逐い出させた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「将軍はなぜ麗人を同道して、こんな蕃地へ踏み込んでお出でになったのです。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまだ一日二日は静かにお休みになるほうがよろしいでしょう」　と言って、また、「ここからのお送りは私がいたしましょう」　とも言ったので、その家へ行きたい気もなかったが、やむをえず源氏は同道して行くことにした。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「間さん、……」「何ですか」「私今晩は是非お話し申したいことがあるので御坐いますが、貴方お聴き下さいますか」「それをお聞き申す為に御同道したのぢやありませんか」　満枝は嘲むが如く微笑みて、「私何だか酔つてをりますから、或は失礼なことを申上げるかも知れませんけれど、お気に障へては困りますの。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡へ入って身を潜め誰か通らば救いを乞わんと思いいる内、暁方近く屠者はでっかい庖丁を磨ぎ、北の方同道でやって来て箱の戸を明け、「灰色の坊様出てきやれ、今日こそお前の腸を舌鼓打って賞翫しょう」と大いに呼ばわる。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は漢学者に似気ない開けた人で、才能を認めると年齢を忘れて少しも先輩ぶらずに対等に遇したから、さらぬだに初対面の無礼を悔いていたから早速寒月と同道して露伴を訪問した。",
              "citation": {
                "source": "露伴の出世咄",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "密々に旨を含めて、五、六人同道せい」　パカパカとひづめの音を鳴らして、事変突発注進の一騎が、霧のかなたに消え去りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると向うで、「北風ぴいぴい風三郎、西風どうどう又三郎」と細いいい声がしました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北風ぴいぴい、かんこかんこ　　　　西風どうどう、どっこどっこ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "干潮で荒い浪が月光に砕けながらどうどうと打ち寄せていました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
