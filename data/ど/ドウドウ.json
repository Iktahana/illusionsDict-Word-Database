  {
    "uuid": "b2d2e305-b22d-5a60-b35e-56521d6df41a",
    "entry": "堂々",
    "reading": {
      "primary": "どうどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "magnificent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然し三造は正々堂々と戦はうと思つてゐるのである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造くらゐ正々堂々と戦はうと思つてゐる者はない。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々のデパアトもある。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々の押し出しで、顏も美しかつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびは、まことにすまない、ゆるしてもらひたい、と堂々の演説口調で言つたので、生徒は、みんな笑つた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の代表的な思想家という説明文が附いていて、その友人は、八つ手の傍で胸を張って堂々と構えていた。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々と玄関を構えてる医者の家へ、ルンペンか主義者のような風態をした男が出入するのを、父は世間態を気にして、厭がったのは無理もなかった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美々しい回しをつけた力士が堂々としてにらみ合っていざ組もうとすると、衛士だか行司だかが飛び出して来て引き分け引き止める。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "檀君の仕事は今日すでに堂々のものである。",
              "citation": {
                "source": "檀君の近業について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "體躯は堂々、鼻も大きく眼光も鋭い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇討ちは須く正々堂々たるべきである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の代表的な思想家といふ説明文が附いてゐて、その友人は、八つ手の傍で胸を張つて堂々と構へてゐた。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命そのものすら売り物にしにくい場合に、生命とは何ぞや、と云ふやうなことを、無学無智な私などが、どのやうに堂々巡りをして考へたつて、それが商品にならないのも分り切つたことだつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しい事には吾々太陽の陪臣微々たる人間の目には堂々たる太陽の歩武がどちらに向いているという事がはっきり分らぬが、ただ周囲に動いている諸星の中でリーラ派のは速く動くように見え、カメロパルダリス派のは割合に吾等と歩調の差が少なく見えるから、先ず吾等は後の派に属するものと考えねばならぬ。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千四百トン余のタービン船で、なかなか綺麗で堂々としている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見たところでは別に堂々とした様子などはない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れも実は堂々と書きたかったのだけれどそんなこと云うている間にかけなくなってしまうからできるだけかけるだけかこうと思う。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座あたりの堂々としたカフエーには、どうしてもきまりが惡く、氣が引けて這入れないのださうである。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに今日の君が、立派な堂々とした風采と、藝術的意味での美しき容貌を持つてるだらう。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇の論陣今や輕佻｜亂雜卑小に流れて、飽までも所信に邁進する堂々たる論客なきを思ふ時、泡鳴さんのさうした追憶も私には深い懷しさである。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上ならず、馬の頭と髭髯面を被ふ堂々たるコロンブスの肖像とは、一｜見まるで比べ者にならんのである。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上ならず、馬の頭と髭髯面を被う堂々たるコロンブスの肖像とは、一見まるで比べ者にならんのである。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカンボの花などもさっぱり見所のないもののように思っていたが、顕微鏡で見るとこれも実に堂々たる傑作品である。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな奇麗な前庭を持っている、そのうえ堂々とした筧の水溜りさえある立派な家の伜が、何故また新聞の配達夫というようなひどい労働へはいって行ったのだろう。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな井桁、堂々とした石の組み様、がっしりしていて立派であった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男滝の方はうらはらで、石を砕き、地を貫く勢、堂々たる有様じゃ、これが二つ件の巌に当って左右に分れて二筋となって落ちるのが身に浸みて、女滝の心を砕く姿は、男の膝に取ついて美女が泣いて身を震わすようで、岸に居てさえ体がわななく、肉が跳る。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の丸善の旧式なお店ふうの建物が改築されて今の堂々たる赤煉瓦に変わったのはいつごろであったか思い出せない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろの見合いでは、たいてい婿殿のほうがかえって少しきまりが悪そうで、嫁様のほうが堂々としている。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "粥釣りに来るおおぜいの中でも勇敢なのは堂々と先頭に立ってやって来るが、気の弱いのは先頭の背後に隠れるようにして袋をさし出すのもある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも裏の事実は一人の例外なしに、堂々、不正の天才、おしゃかさんでさえ、これら大人物に対しては旗色わるく、縁なき衆生と陰口きいた。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
