        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第一部の劇場にての前戯に、道化方がアイン・ブラアウェル・クナアベのいるのは劇場の利方だと云っている。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐその跡で、道化方が作者にブラアヴであれと云っているので、誤ったのである。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "白小袖の上に、紫縮緬の二つ重ねを着、虎膚天鵞絨の羽織に、紫の野良帽子をいただいた風情は、さながら女の如く艶めかしい、この二人を囲んで、一座の道化方、くゎしゃ方、若衆方などの人々が、それぞれ華美な風俗の限を尽して居並んでいた。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥五七　（道化方らしく誇張した身振りで）さればこそ前代未聞の密夫の狂言じゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（皆の後から奥の方へはいる）弥五七　（やっぱり道化方らしいやや上ついた態度で）はて面妖な。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」突然かう叫んだのは、音楽のわかる道化方トロツテルである。",
              "citation": {
                "source": "防火栓",
                "author": "DAS GROBE VERGNUGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間を馬鹿にし切つた道化方でなくては、こんな智慧は出ない。",
              "citation": {
                "source": "防火栓",
                "author": "DAS GROBE VERGNUGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭カスペリイニイは天才の道化方に抱き付いて、給料を増す約束をした。",
              "citation": {
                "source": "防火栓",
                "author": "DAS GROBE VERGNUGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　町なかの公園に道化方の出て勤める小屋があって、そこに妙な男がいた。",
              "citation": {
                "source": "破落戸の昇天",
                "author": "モルナール・フェレンツ　Molnar Ferenc",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿楽能にも「開口」を演ずる場合は、主役と「もどき」（まぜ返し役・道化方の源流）とが、かけあひもし、同音にも謡うた。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふふふ、松五｜郎は、見かけに寄らねえ忠義者でげすぜ」　独り言をいって顎を突出した松五｜郎の顔は、道化方の松島茂平次をそのままであった。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "道化方後の世がどうのこうのと云うことだけはわたくしは聞きたくありませんな。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "道化方そんならあなたその美しい力を使って、詩人商売をお遣りなさるが好いでしょう。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "道化方（手づつに、ほとんどをさなく。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座は親方の竹松の外に、囃子も仕る、藝達者の女房のお六、木戸番の三太郎に、口上と道化方と、手品も少々は心得てゐる、珍々齋といふ四十男、それで全部ですが、眞珠太夫の人氣が大變で、門並みの小屋を壓して此處だけはハチきれさうな入りです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "眞珠太夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
