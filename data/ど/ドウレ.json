    "definitions": [
      {
        "index": 1,
        "gloss": "come in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "混成酒ばかり飲みます、この不愉快な東京にいなければならぬ不幸な運命のおたがいに取りては、ホールほどうれしい所はないのである。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝はうれしかつた、大山澄太さんのハガキが私を涙ぐましたほどうれしかつた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、おれは、泣くほどうれしい。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまそれを自分の唇の触管に触れさして、その触れ味を味わうことは身に沁みるほどうれしいのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうれ、おめえ等饂飩粉少と持つて來て見せえ、一ツ爪尻でえゝんだ、おゝえ持つて來うな、おつぎでもえゝや、よう」と兼博勞は促した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうれ、誰も寄せねえけりや俺れでも寄せてんべかえ」後の方から一人進んで來たものがあつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうれ、俺ら歸つて牛蒡でも拵えべえ、明日天秤棒檐いで出る支障にならあ」剽輕な相手は思ひ出したやうにいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうれで、先っきのは、なんだか新平に似た平吾だと思ったっけ。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうれ、一服いたしませうか。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはお嫁なんぞに行かないでもいい、あなた方とこうしているほどうれしい事はないと思いますよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそんな場面が起こり得たら葉子はどれほどうれしいだろう。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早くなど、その窓から僅かの光線の斜めに射し入るのが、何ともいわれぬほどうれしく感ぜられる。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうれ」　吉良は、じっと眺めていたが、「諸事あまりに切りつめてあるようじゃが」と、内匠頭の顔を見て、「これだけの費用じゃ、十分には参らぬと思うが」と、つけ足した。",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞうっと背中が寒くなるほどうれしくなりやがったね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頼もう、頼もう」「どうれ」　相手もまた古風に応じて、見るからに青やかな納所坊主がそこに手をついたのを見ながめると、ずばりといったことばが少しおかしいのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は欲ばりの大人に拝まれるよりも、こんなに親切な子供達に可愛がられる方がよっぽどうれしゅう御座います」　皆はパチパチと手をたたいて、お釈迦様の演説に感心をしました。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「有難え、ぬれてはいない」よっぽどうれしかったに相違ない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が附いている」　こう父が確かりした声で、私を抱いていった時、私は、一生に、この時ほどうれしかったことはありません。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "猛火の中の私たち",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう娘に会えないと心にきめて朝早く川沿を歩いて居た仙二は、とび上るほどうれしくそして又おどろきもした。",
              "citation": {
                "source": "グースベリーの熟れる頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きまつてら、どうれ。",
              "citation": {
                "source": "悲しめる顔",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "都にのぼりて大行天皇の御はふりの御わざはてにけるまたの日、泉涌寺に詣たりけるに、きのふの御わざのなごりなべて仏さまに物したまへる御ありさまにうち見奉られけるを畏けれどうれはしく思ひまつりてゆゆしくも仏の道にひき入るる大御車のうしや世の中　曙覧は王政維新の名を聞きて、その実を見るに及ばざりしなり。",
              "citation": {
                "source": "曙覧の歌",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな言葉と小さな言葉　好い手紙を人から貰つた時ほどうれしいものはない。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "たよりいろ／＼、なかんづく、緑平老からの手紙は涙がこぼれるほどうれしかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小包が来た、遠く浅間の麓から江畔老が心づくしの品――蕎麦粉である、涙がこぼれるほどうれしかつた、それは江畔老その人のやうにあたゝかくておいしい！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、樹明君来訪、停留所まで送る、酒をよばれた、いそがしい酒であつたけれどうれしい顔だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、たよりほどうれしいものはない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "東路君を訪ねあてる、旧友親友ほどうれしいものはない、カフヱーで昼飯代りにビールをあほつた、夜は夜でおしろいくさい酒をしたゝか頂戴した、積る話が話しても話しても話しきれない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れてから樹明兄来庵、野菜をたくさんいたゞいた、これだけあれば当分は安心してゐられる、野菜ばかりぢやない、別にまた一升寄贈だ、涙の出るほどうれしかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此に其｜辞の卑俚を嫌はずして、榛軒の女曾能子刀自の記憶する所のとつちりとん一｜みや丸薬や、頼まうどうれの取次や、それから諸家へ代脈に、往つて鍛ふが医者の腕、それを為遂げりや四｜枚肩。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
