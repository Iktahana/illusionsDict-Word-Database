        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ブルジョアといえば森村も生れは土百姓のくせにいやに臭いな」　ガンベはつけつけこういった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な土百姓になりゃあがったな、田舎漢め！",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、聞きゃ、河野の方で、妙の身体に探捜を入れるのが、不都合だとか、不意気だとか言うそうだが、」　噫、礼之進が皆｜饒舌った……「意気も不意気も土百姓の知った事かい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に上の橋と下の橋から斬り込んでおいでになったならば、土百姓や町人の兵隊共は一たまりもありますまい」　これを聞いた少年連は皆、手を拍って奈良原の意見に賛成した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り正体もなかなか見せませぬので、草になったり木になったり、土百姓に化けたり、旅僧の姿をしたりして、方々の小天狗共を凹ませては、大天狗道に入らせようと努力しております。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "土百姓の酒じゃ嬉しくねえ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地渾沌として日月も未だ成らざりし先｜高天原に出現ましませしに因りて、天上天下万物の司と仰ぎ、諸の足らざるを補ひ、総て欠けたるを完うせしめんの大御誓をもて国土百姓を寧く恵ませ給ふとなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "土百姓同様の貧乏士族の家に生まれて、生まれるとから貧乏には慣れている。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの土百姓があなたを、失敬な目附きをして見てゐるのに、あなたはなぜ人を好くして見返してお遣りになるのですか。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "町人や土百姓に鉄砲をかつがせてなんになるかい」「門地をどうするんじゃ。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "労農とかソビエットとかいうと当局はビクビクしているが、実はこんな土百姓や労働者を最も尊重した政治をすることだと思う。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少し張り込んで、金箔を塗った立派な表彰状を出してさ、授与式をワザと面倒臭く、おごそかにすれば、もう彼奴等土百姓はわけもなくころりさ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし徳さんもお玉さんもあくまで周囲の人間を土百姓と罵って、自分たちだけがほんとうの江戸っ児であると誇りつつ、長い一生を強情に押し通して行ったかと思うと、単に悲惨というよりも、むしろ悲壮の感がないでもない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番最後の少し奥に引っ込んだ石菖の鉢の格子のそばに置いてある家には、いかにも土百姓の娘らしい丸く肥った女が白粉をごてごてと不器用にぬりつけて二三人並んでいた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし徳さんもお玉さんもあくまで周囲の人間を土百姓と罵って、自分達だけがほんとうの江戸っ子であると誇りつつ、長い一生を強情に押して行ったかと思うと、単に悲惨というよりも、むしろ悲壮の感がないでもない。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ自分は、これまでプロレタリア作家が好んでとり上げたような闘争に高まった意識的な農民の姿だけを切りとって来ず、彼らの背後にひきつづいている現在のおくれた何千万という土百姓の生活と感情とを書いて見たいと思う、という抱負を話された。",
              "citation": {
                "source": "作家への課題",
                "author": "――「囚われた大地」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "土人はほんの土百姓かあるいは苦力かだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "野中の一軒家でも、家の造りが粗末ぢやからとて、水飮み土百姓が住んでをると思うては違ふ??ビールのあき瓶が五六本は必らず裏口のそとに棄ててある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "野中の一軒家でも、家の造りが粗末ぢやからとて、水飮み土百姓が住んでをると思うては違ふ――ビールのあき瓶が五六本は必らず裏口のそとに棄ててある。",
              "citation": {
                "source": "――泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "又た撲ぐる時には聲を掛けた、土百姓土百姓と各々口を揃へて言ふたのである。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査が人民を捕まへて「土百姓」と云ふ掛聲で撲つた。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の「土百姓」と云ふ掛聲は何處から出るのであるか。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ即ち古河市兵衞に頼まれて居るからして、鑛業主にあらざれば人間にあらず、土百姓は人間に非ざる樣に常に聞ひて居るからして、ツイ其れが出る。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百人の巡査が悉く土百姓と云ふ掛聲を以て酷どい目に逢はせた、鬨の聲を揚げた、大勝利を揚げた、大勝利萬歳の勝鬨を揚げたのでございます。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "』またキングなら『行っちまえ、タンボフ県の土百姓め！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはずさ、七八年も世間師をしていちゃ、旅人根性は生涯抜けやしねえ、今さらとても土百姓に返られるものか。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今よりズツともむないもん喰て、土百姓々々々と人間の數へも入らずに、あの天滿宮さんの神主の家へ行くんかて、門から草履を脱いで、臺所口へ平つくばつたもんや。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち宗義惟義二人ともに正四位に上下のあることを知らないことになるのであるが、赤の子供や土百姓素町人ならいざ知らず、殿上人の資格ある惟義の近親たる二人が知らないとは何事ぞ。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
