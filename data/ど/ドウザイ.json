        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分も良人と同罪だ。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は同罪になった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな妾が一人でした事だって……ですから貴方は……あなたは早く逃げて頂戴……同罪になるといけないから……店の金庫の合牒はイナコよ……サヨウ……ナラ」　彼女が受話機を取り落す音がした。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "古池や蛙とびこむ水の音　音の聞えてなほ静かなり　これ程ひどくもないけれども、とにかく蛇足的註釈に過ぎないという点では同罪である。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞盛は将門追捕の符を持つて帰つたが、将門の方から云へば貞盛は良兼追捕の符の下つた時、良兼同罪であつて同じく配符の廻つて居た者だから、追捕を逃れ上京した時、公に於て取押へて糺問さるべき者であるにかゝはらず、其者に取つて理屈の好い将門追捕の符を下さるゝとは怪しからぬ矯飾であると突撥ねてゐるのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一お前も、」　稲妻が西へ飛んで、「同類だ、共謀だ、同罪だよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻も云う通り、芳、お前も同類だ、同類は同罪だよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "左なる二人の女は同楼の鴇手と番頭新造にして、何れも初花の罪を庇ひし科によりて初花と同罪せられしものなりと云ふ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不義は同罪じゃ、娘からさきへ斬る」　平左衛門はそう云いながら、いきなりお露の首に斬りつけた。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし他言すれば、わたしの口ひとつでお前もきっと同罪に陥してみせるとお定は泣きながら彼を嚇した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らば余もその同罪なればその由ブラッデイ氏に申出でたるに何故か氏は余の言をとりあげざりし。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にとっては、三上が一秒間でも彼を侮辱したことは、三上の生涯を通じて所罰さるべきであり、そのそばに黙って櫓を押していた小倉も、その侮辱を聞いたという廉によって、同罪であるべきであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なあんだ、同罪か。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金次は同罪ともなるべきものを格別の御慈悲を以て遠島申し付けられて、この一件は落着した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地さんにけががあればわたしだって同罪以上ですからね。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなる妻女も、夫の罪業を手助けいたした罪により、同罪の遠島じゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そっちのお絹のあまも同罪だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はたぶん亭主と同罪じゃあるめえが、それまでは聞かなかったかい」「いいえ、聞きました、聞きました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすの点呼に遅れたら、このメンバーはみんな、外泊延期だ」「どうせ、雨が降ってるから、関係ないじゃん」「点呼時にじぶんの部屋にいない奴が、ひとりでもいたら、このメンバー全員、同罪だ」　そういい捨てて、芝は外に出た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らば余もその同罪なればその由ブラツデイ氏に申出でたるに何故か氏は、既に事終りたればとて余の言をとりあげざりし。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうなればお前も同罪だよ。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "訴えれば彼も同罪である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "吟味の上で、勘蔵は無論に獄門、六三郎と百助と四郎兵衛は三人同罪ということになりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋本に対しても彼も同罪だと観念した。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、それや、僕が第一、せっせと馬鹿な苦労をしたからだが、しかし、誰か一人が馬鹿なことをすれば、良いことをしているものでも人間は同罪になるらしい。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ようし、人間は同罪だ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やぶれかぶれで、いけない事もあつたけど、二人とも同罪だわ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまるところ、山羊髯と俺が同罪なんだ。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその結果の全部が、この通り吾輩の前に投出された」「……………」「……だから……目下のところＷとＭの二人は同罪である。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
