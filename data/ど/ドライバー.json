    "definitions": [
      {
        "index": 1,
        "gloss": "driver (of a vehicle)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここで血相を変えた電灯会社が飛び付いたのが、同じ時期にアメリカのドライバーハリス社が発明したニクロム線だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＭＳ―ＤＯＳにマウスからの情報を取り入れるためのドライバーソフトを組み込み、ボタンを押すと画面上にメニューが現われるように仕立てたデモには、インターフェイスの新時代がまさに開けつつあることを実感させる衝撃があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "増設スロットに差し込むマウス接続用のボードとＭＳ―ＤＯＳに組み込むドライバーソフト、そしてマウス本体を、笹渕は担当者に頼み込んで日本に持ち帰った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが２・０からは、ＵＮＩＸ流のファイル管理機能が組み込まれ、周辺機器などをコントロールするデバイスドライバーと呼ばれるソフトウエアを組み込んで、容易にシステムを拡張できるようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがエンジンとシャーシが固まり、車の基本仕様が決まったとしても、どの車を選び、その車でどこに行って何をするかという選択はなお、ドライバーに委ねられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ってくださいよ」　蜂矢は、ポケットからドライバーを出して器械の裏蓋をあけた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂矢は、ドライバーをほうりだして、受話器を取りあげた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから右手にドライバーを握り、ポケットからぼくたちを一つ摘みあげては、パネルの後側にあるターミナルの並んだアルミの小さい枠を、装置のフレームに取付けるため、両方の穴と穴とを合わせ、その中にぼくたちを植え込み、それからドライバーでくるっくるっとねじこんだ。",
              "citation": {
                "source": "もくねじ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドライバーをあてがって、力をいれてねじ込もうとすれば、ドライバーがねじの頭から滑ってしまう。",
              "citation": {
                "source": "もくねじ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてぼくの頭に、ドライバーが当てられた、ぐっと圧されて、きりきりと右へ廻された。",
              "citation": {
                "source": "もくねじ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドライバーは、何遍かつるりと滑った。",
              "citation": {
                "source": "もくねじ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの新型の人造人間については知らないんだが、一つ中を開けて見てみましょう」　そういって彼は物慣れた手つきでドライバーを手にとり、人造人間の胴中をしめつけている鉄扉のネジを外していった。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――こっちが増幅器で、こっちが継電器ですよ」と馬詰はドライバーの先で機械を指した。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゴルフの快味はドライバーショットです」　と確信をもって断言し、制規のコースへ行っても、キャデーにタマをひろわせてドライバーショットだけ半日でも一日でもあきずにやっているのである。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はゴンサカで数十名の老幼男女に取りまかれた時、すでに感じていたが、米国の少佐もドライバーもどこかへ行ってしまい、つまり僕を保護する立場の人は一人もいなかったのだが、何らの敵意を示すものもいなかった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "警乗兵は「おい、ドライバー、気をつけてくれよ。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、話しながらドライバーで色々いじくっているのだから、たまらない。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い勝手の揚げ蓋の隅に、古い蜜柑箱があって、その中に口の欠けた醤油注ぎや、ペンチや、ドライバーや、油じみた軍手や、ぼろ布が整頓されてある。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六ちゃんは油差とドライバーとペンチを持って車庫へゆき、自分の運転する電車を点検する。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しゃあねえな」六ちゃんは頭を振って呟く、「整備のやつ、なにょうしてるんだ、なっちゃねえじゃねえかな」　彼はドライバーを使ってどこかを直し、ペンチを使ってどこかを直し、軸受のところを足で蹴ってみる。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜんたいの題名は、『サンデー・ドライバー』ときめてある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、ギターのソロは、すごいんだ」「クラリネットが、サンデー・ドライバーなのか」「そう」「図式的だ」「そう思うか」「思う。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、マークのドライバーから、小川はぼくがさまたげになって、見えないはずだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーク※は左に寄ってとまり、ドライバーが外に出て、ミラーの折れた跡を見ていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いドライバーを握り、エンジンをまわしながらエンジン各部にあてがい、握ったところを耳に押し当て、聞き入る。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず外の方の握りのネジをドライバーではずし、心棒ばかりにして、それを細い針金でくくり、心棒をソッと室内へ突きおとす。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍵のほうはそのままにしておいて、ドライバーでドアの蝶番そのものを取りはずし、そこを出しひらいて出入りする。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
