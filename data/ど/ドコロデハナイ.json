        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これに達した径路は問う所ではないのである。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くのレビューでは、見ている間だけ面白くて、見てしまったあとでは綺麗に忘れてしまうのがむしろその長所であり狙い所ではないかと思うが、物理やその他の科学の教科書はそれでは困りはしないか。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際両側に広い空地を控えたこの垣根では嵐が吹き通したり、雨に洗われたり、人の接近する事が頻繁であったりするので蜂にとってはあまり都合のいい場所ではない。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども清夫はそれ所ではないのです。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大生命の洋々蕩々たる、而もその中に滑転の自在をきわむる巧妙さ、われらが胸計の及ぶ所ではない。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅毒患者が療養すべき土地にして、わざわざ東京から見物がてら避暑なぞという気の利いた所ではない。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の覺えたのは……そんな、そ、そんな怪しからん場所ではない。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なか／＼に稼ぐ所ではないから、いきつぎに表へ出て、近所の方に、たゞ今の禮を立話しでして居ると、人どよみを哄とつくつて、ばら／＼往來がなだれを打つ。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞで通す關所ではないけれど、下六同町内だから大目に見て置く。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『女神もいいが、これはまあ、とんだ所ではないか！",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから其処に眼を付けて自分の後を振り返ると、過去は夢｜所ではない。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい昼間にしても、町に住む人間、ことに女などに取っては用のありそうな場所ではない。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗やみで確かに判らなかったが、父が最初に落ちた穴と、二度目に落ちた穴とは、どうも同一の場所ではないらしかった。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、此所は玄関の方へ行く所ではないと思つて、後帰りをしようとすると、其所には冷たい壁があつて帰れなかつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳はそこで此所は閨閣に近い所ではないかと思った。",
              "citation": {
                "source": "西湖主",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育係の軍曹も要領は僕にならへといふ位であつたが見習士官は譽める所ではない。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の往かれる所ではない。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいしたむずかしい所ではないのだよ。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京朝日に出た『波の上』なども、新聞で毎日読んでは冗長なやうな気がするけれども、男女のもつれを二条はつきり出して見せたところは、凡手の及ぶ所ではない。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこれ以上彼のいる場所ではないと彼は思った。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所ではないかと訊けば、もう充分探したといふ。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかには東京はあまりおもしろい所ではないという一句があった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けしからんことだと思いながらも、なお引っ越し先の模様を尋ねてみると、とうてい自分などの行って、一晩でも二晩でもやっかいになれそうな所ではないらしい。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　しかし、この社務所が只の社務所ではないのです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊園別府、貧乏人や偏屈者の来る場所ではない。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような例は、この部分一ヵ所ではない。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "数にすれば少しでも、文学に無関係な文士なぞといふものが在るのは何れにしろ奇現象であるから、事実上は決して少い感じがするどころではない。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿どころではない。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇九年型の女優が一九三四年式のぴちぴちした近代娘に蝉脱した瞬間のスリルがおそらくこの作者の一番の狙いどころではないかと思われる。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これらの作家によって、現在までに生産された文学は、単に量のみを問題としても、我国人口の大部分を占める巨大な農民層に比して、決して多すぎるどころではない。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
