        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その地域には、昔からドサ回りがいると噂されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はドサ回りだったが、足を洗って真面目に働いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドサ回りとの関わりは、トラブルの元になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
