[
  {
    "uuid": "0dcd30e4-72b9-5bfc-9849-ee4f1893b883",
    "entry": "鈍甲",
    "reading": {
      "primary": "どんこ",
      "alternatives": [
        "ドンコ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dark sleeper (species of sleeper goby, Odontobutis obscura)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "辞書や伝承によって、鈍甲、胴甲、貪魚、鈍魚、などという字があててあるが、どれがほんとうなのか、私は知らない。",
              "citation": {
                "source": "ゲテ魚好き",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "神は、「わが妻の神よ、おまえがそんなひどいことをするなら、わしは日本じゅうに一日に千五百人の子供を生ませるから、いっこうかまわない」とおっしゃって、そのまま、どんどんこちらへお帰りになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしているうちに、ある日、出雲の国の御大の崎という海ばたにいっていらっしゃいますと、はるか向こうの海の上から、一人の小さな小さな神が、お供の者たちといっしょに、どんどんこちらへ向かって船をこぎよせて来ました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "工兵隊は引つづき毎日爆薬で、やけあとのたてもののだん片なぞを、どんどんこわしていました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてゴムはどんどんこっちへ輸入できる」委員Ａ「そうは思わんがなあ、僕は……。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自信と興味のある方は、どんどんこの門から御入場なされませい。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭でつかちのどんこは、餌をもとめて水腐れのした塵つ葉か何かをぱくりと銜へ込み、それと気づいてしぶしぶ吐き出しはしたものの、思ひ切れないで未練がましくまたその後を追い縋らうとする愚しさ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌どんぐり　┌どんぐり先生（一洵）“三鈍”│どんこつ　│どんこ和尚（澄太）　　　　└どんびき　└どんびき老豆腐の佃煮とは！",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつとポストまで、途上、どんぐり先生に逢ふ、明朝出立、どんこ和尚を訪ねるといふ、どんびき翁からよろしくとたのんでおいた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上平穏、一時宇品着、電車で局にどんこ和尚を訪ふ、宅で泊めて貰ふ、よい風呂にはいりおいしい夕飯をいたゞく、あゝどんこ和尚、どんこ和尚の家庭、しづかであたゝかなるかな、私もくつろいでしんみりした。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、考えている遑に、そのサイレンはどんどんこっちへ近づいて来た。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もぐらさん、さあ放すから、どんどんここを掘ってみておくれ」　一郎は、車のうえから、箱を下ろして、その入口を開いた。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うごかないものを、どんどんこしらえて、どうするつもりか」「すべて合理的な能率的なマッス・プロダクションをやって居りますです。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんことでも、僕はおどろきやしませんよ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "潜水艦などは、大吹雪も平気で、どんどんこっちへついているんだ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "北陸地方でごり、京都でどんこ、信州でうばがしら、江州でおこぜ、美濃でびんが、駿河でひとつばね、野州ではぜと呼ぶのも皆同じである。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、京都では鴨川上流で漁れたどんこの飴煮、金沢ではごりの佃煮、最上の小国川では鰍の煮こごりを食べたが利根川の鰍の味に勝るはなかった。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚のうちで、まばたきするのは河豚に、どんこ沙魚ぐらいのものだろう。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、どんこ（だぼはぜ、鯊、かじかの類）も水垢を好む魚であって、汀に近い石の頭をなめている。",
              "citation": {
                "source": "水垢を凝視す",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮎は笹の葉のような歯跡を石に印するが、どんこは、前歯で噛んだような歯跡を水垢に残している。",
              "citation": {
                "source": "水垢を凝視す",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどんこは、石の背面や横腹をなめない。",
              "citation": {
                "source": "水垢を凝視す",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、どんこ（だぼはぜ、鯊、かじかの類）も水垢を好む魚であつて、汀に近い石の頭をなめてゐる。",
              "citation": {
                "source": "水垢を凝視す",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮎は笹の葉のやうな歯跡を石に印するが、どんこは、前歯で噛んだやうな歯跡を水垢に残してゐる。",
              "citation": {
                "source": "水垢を凝視す",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが我々を町まで案内するといったバンカは、ここに流れ込んでいる相当な大きさの川を、どんどんこいで溯って行く。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙ってておくれ」「そうでもござんしょうが、市どんこそ災難だ。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんこのをぢさんが眼を、きよときよとさせて、小石と小石の間から出てきました。",
              "citation": {
                "source": "ごわごわごむ靴",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
