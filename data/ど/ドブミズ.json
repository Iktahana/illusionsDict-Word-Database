          "literary": [
            {
              "text": "吸へば滓でも殘りさうな、胸のむかつく、腐つた溝水のやうな空氣だつた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "見落しちゃっちゃ可愛そうでがすからなあ」そして、橋という橋にさしかかると親爺の歩調はきゅうにのろくなり、そこえらの溝水に纜っている船を注意ぶかく覗きこむのであった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり御無沙汰するてえと、何時こちとらも溝水を呑まされねえもんでもねえから」「あら、旦那――」おろくはちょっと奥へ眼を遣った。",
              "citation": {
                "source": "助五郎余罪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝水も泡立つ七月の天、およそものその平を得ざれば、なるほど音高き日和下駄響かせて、我からそこを追出しは、とつて十九の血性漢なりし。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀戸や竪川での場合は、溝水だから使えないが、ここのは潮水できれいだから、米も食器もお新香も、潮水で洗えと言う。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "三河島の河ぶちの暗い溝水に沿い、俥が走った。",
              "citation": {
                "source": "童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、庭と大屋根、水と欄とを、およそ幾棟か知れぬほど巧みに組みあわせた後宮建築の廊を、いかにも王妃の艶とは、この女性にきらめいている物かとばかり、御溝水のせせらぎと共に歩んで行くのだった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
