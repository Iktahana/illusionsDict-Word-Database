[
  {
    "uuid": "66a492d7-1d49-5006-ad60-e1f2aab2e26f",
    "entry": "吃り",
    "reading": {
      "primary": "どもり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
