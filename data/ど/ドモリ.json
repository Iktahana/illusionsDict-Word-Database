      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "stammer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "で吃り吃り左に云ふ所は、どうか笑はないで聞いて貰ひたい。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　「確かに俺が叩っ斬って、首は児分が持って先へ清水に帰ってしまった」　「よッよッよくもきッきッ貴様ッ」　「何を吃りやがるんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨は、うすい眉をはればれとひらき、吃りつつ言ひだした。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部さんは吃りで、癇癪持ちで、気むずかしやね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――』と娘は、吃りながら云うのであった。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、この父の容貌が――殊に段のある鼻つきが、それから又その吃りぐせが、そっくりそのまま自分に遺伝してきているのが、たまらなく不愉快であった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が冗談を言つてゐるのでもなく、氣が狂つてゐるのでもなく、又自分が聞き違へをしてゐるのでもないことを確かめると、彼は殆ど恐怖に近い狼狽を示して、吃りながら叫んだ。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が冗談を言っているのでもなく、気が狂っているのでもなく、また自分が聞き違えをしているのでもないことを確かめると、彼はほとんど恐怖に近い狼狽を示して、吃りながら叫んだ。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女達は驚きながら訳を訊ねると、女はあわてて吃りながら言いました。",
              "citation": {
                "source": "気の毒な奥様",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大酒を飲めば莫迦に陽気になるが、チビチビやる時は元来吃りのせいで無口の上に一層無口になり、客のない時など椅子に腰かけてぽかんと何か考えごとしているらしい容子を見ると、梅田の実家のことを考えてるのとちがうやろか、そう思って、矢張り蝶子は気が気でなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、お、お前、京都から、お、お、おれをつけて来たんだろう」　なぜつけた――と、北山は昂奮に吃りながら、狂暴な力でカラ子の肩を掴んでいた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊助は鼻の横に目だって大きなほくろが一つあり、それに触りながら利く言葉に吃りの癖も少しはあった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたしは少しく吃りながら挨拶すると、彼も笑いながら会釈した。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はあれでも耻しいとも何とも思つてはゐなかつたのか」とどもり吃り、つぎはぎだらけの仕返しをして、ほつと呼吸をつきました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳吉はいささか吃りで、物をいうとき上を向いてちょっと口をもぐもぐさせる、その恰好がかねがね蝶子には思慮あり気に見えていた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "挨拶の仕様がなかったので、柳吉は天候のことなど吃り勝ちに言うた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大酒を飲めば馬鹿に陽気になるが、チビチビやる時は元来吃りのせいか無口の柳吉が一層無口になって、客のない時など、椅子に腰掛けてぽかんと何か考えごとしているらしい容子を見ると、やはり、梅田の家のこと考えてるのと違うやろか、そう思って気が気でなかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚当時の私は、妻から言葉をかけられると、顔を赤くして、吃りどもりそれに答えるような人間であったからだ。",
              "citation": {
                "source": "秋草の顆",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、吃りながら婆やは、熊の皮の上に倒れている蔦代の死骸を指さした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは自分の下男から軽蔑されて、それで黙っているような、それほどの善人じゃないから」　敬二郎は怒りのために吃りどもり、身を顫わせながら言うのだった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　敬二郎は吃りながら顫えを帯びた声で言った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは吃りて、恕し給へ君と叫びぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にいかなる騒ぎが起るかと予が待ち構えようとしている時に、メントーニ家の一人の小姓が部屋の中へ駈け込み、感動のあまりに息のつまった声で、吃りながらきれぎれの言葉を発した。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「店の新どんに貰ったんです」と、宇吉は吃りながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "と吃りながら傍らの生垣のハチスの花をむしつたのが、あんまりしよげたのでＫ子さんにお手紙書かうとして今、夜になつてこのペンを執つてゐたら、胸のポケツトから幾枚も／＼花びらが出て来たので、もう何も書かずに封じ込んだのよ、真赤になつて。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に原稿紙の上でまで吃りになれとは誰が求めることができようか、せめて文章を書く唯一の自由を彼に学ぶべきであらう部分的には『純情』を売り、全体的には文字を売つて生活してゐる彼を見遁すべきだ、俗にいふ、好漢惜しむべきはあまりに好漢である。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがお酒を飲まない平素は、たいへん話下手で、それに吃りました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いきなり、カムパネルラが、思ひ切ったといふやうに、少しどもりながら、急きこんで云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおども安、手前どもりゃ人を斬るって話だが、此処で一ぺん、どど、と吃って斬って見ろ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "電線の喚びの底を、　　　　　　うちどもり水はながるゝ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
