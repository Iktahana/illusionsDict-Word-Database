        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜中にふと眼がさめると台所の土間の井戸端で虫の声が恐ろしく高く響いているが、傍には母も父も居ない。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云っておれの革スリッパを変な裏口のやうな土間に投げ出した。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩はばがひろくけらを着て馬を廐へ引いて入れ、土間でこっそり飯をたべそのまゝころころ寝てしまった。",
              "citation": {
                "source": "丹藤川〔「家長制度」先駆形〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には土間がいやに寂かだし主人のめだまは黄金のやうだしさ。",
              "citation": {
                "source": "丹藤川〔「家長制度」先駆形〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツの農夫は炉のそばの土間に燕麦の稈を一束敷いて、その上に足を投げ出して座り、小さな手帳に何か書き込んでいました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い農夫は、も一度自分の腕時計に柱時計の針を合せて、安心したように蓋をしめ、ぴょんと土間にはね降りました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩室の土間の壁面にメンバーの名札がずらりと並んでいる。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は台所の土間に藁火を焚いて、裸体の死児をあたためようとしている。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが自分の室内ならとにかく、税関の広い土間の真中で衆人環視のうちにやるのであるからシャツ一つになる訳にも行かない。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝店　源兵衛、淋しく土間へ下りると戸を閉める。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚えてろ」Ｓ＝亀崎の宿の旅籠「大野屋」（夜）　土間が居酒屋になって居る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝居酒屋（夜）　土間で三次が床几に腰掛けてチビリチビリやって居る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間に下りて来る棚倉の一行。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間に下りた棚倉が足を止めた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰だ」と三次要心深く土間へ下りて、　戸を開けると、　転がり込んだ勝坊。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（たらいに番附入れたのを肩に乗せ売って歩いている等芝居小屋の情景よろしく）　平土間で「幕開けろ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間でパチパチ手を叩く奴がある。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の客も幕が開くので落ちつく。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の観衆、花道の方を見て居たが、ドッと喚声上る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間の客「ナンヤロなァ」と声のした方キョロキョロ見る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の客、動揺して一斉に一方を見る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ聞いたか平土間の一人の客が「オホホ」Ｔ「此村大吉」　と眼見張る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の客は愈々騒々しい。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、二三度振り払ったが、尚もしつこく掴みに来るので逆に強い男の腕掴んで、二三間曳きずって物の見事に花道から、　平土間へドスーンと投げつけた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、平土間の一人の客が、Ｔ「そんな無茶な！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫んだのをきっかけに、平土間の群衆騒然たり。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間の観衆忽ち驚く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　平土間やや静かになる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉花道から、大刀片手に大跨にヅカヅカと舞台へ来り、平土間に向って、Ｔ「文句が有ったら　上って来い」　観衆睨み乍ら舞台の端を行ったり来たり「文句ある奴何奴だァ」と怒鳴って歩く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「平土間残らず　俺が相手だ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
