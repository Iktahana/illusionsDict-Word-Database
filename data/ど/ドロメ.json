        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔みちべの苔にまどろめば〕みちべの苔にまどろめば、　　日輪そらにさむくして、わづかによどむ風くまの、　　きみが頬ちかくあるごとし。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄き衣せしたはれめの、　　　ソーファによりてまどろめる、はてもしらねば磁気嵐、　　　かぼそき肩ををののかす。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とどろめく銃音しばし、痍つける悪のうごめきそこここに、あるは疲れて轢きなやむ砲車のあへぎ、逃げまどふ赤きもろごゑ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬眠冬眠ねむれよ、やすらかに、冬のあひだ、まどろめよ、和魂の香にとろみて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねむれよ、おだやかに、蛇よ、かはづ、まどろめよ、おのが肉食み足らひて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねむれよ、このもしく、夢も欲らず、まどろめよ、土の室塗りとざして。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねむれよ、息の緒のあるかなしに、まどろめよ、ゆるぎなく酔ひほうけて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねむれよ、やはらかに、日ももとめず、まどろめよ、こごり凍む地をいとひて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねむれよ、神ごころ、冬のあひだ、まどろめよ、ほろと、ただ、ああ、とろみて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今やまどろめる哥薩克を、乗せし駿馬は用心深く、その難所へとさしかかる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、秋の夜も名のみなりけり逢ふといへば事ぞともなく明けぬるものを　　（恋三、小町）ねぬる夜の夢をはかなみまどろめばいやはかなにもなり増るかな　　（同、業平）秋の夜は長いと言われるが、恋人と逢う夜は何をしたという気もしないうちに明けてしまう、長いというのはうそだ。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まどろめば夢に見ん、さむれば面影に立つと云うたのもほんとうの事に思われる。",
              "citation": {
                "source": "「平家物語」ぬきほ（言文一致訳）",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして耳慣れた曙の音が、遠い鐘、過ぎゆく小舟、水のしたたる二本の櫂、道行く人の足音が、二人に生きてることを思い起こさせながら、それを二人に味わわせながら、そのまどろめる幸福を、乱すことなく愛撫してゆく……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとまどろめばたちまち刑事の一隊に踏み込まれて、兄や嫂が数珠つなぎにうなだれて行くまぼろしに脅やかされました。",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
