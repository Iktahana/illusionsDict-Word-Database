    },
    "definitions": [
      {
        "index": 1,
        "gloss": "time for ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "われ星に甘え、われ太陽に傲岸ならん時、汝等ぞ、讃ふべきわが従者！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時だ、その壺が花を開く、その花は、夜の部屋にみる、三色菫だ。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、午睡の夢から覚めてみると　　みなさん家を空けておいでだつた　　あの時を妙に思ひ出しますさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神よ、しかしそれがよく編みなされてゐればゐる程、破れる時には却て速かに乱離することを知つてをります。",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお恵みが下ります時には、やさしくうつくしい夜の歌と櫂歌とをうたはうと思つてをります……（一九二九・一二・一二）",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "ア、バアバアバアバ、僕は赤ン坊の時したことを繰返した。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代といふ今は尠くも、あんな具合な元気さでゐられる時代ではないのです。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほがらかとは、恐らくは、悲しい時には悲しいだけ悲しんでられることでせう？",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今晩かなしげに、かうして沈んでゐる僕が、輝き出でる時もある。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が自殺した時、それも作家が自殺した時、その原因を簡単に云つてしまふなぞはよくないことである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕、邪魔はしないからねえ、邪魔はしないからねえ」と、みんなの者に云つたのがその時の挨拶であつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧野さんは当時南寺の借家にゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヤリの煙がユラユラと壁に映つて、十一時頃であり、そのうちまた出掛けさうな気配にもなつたりして、時は刻々に過ぎつゝあつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まあこのおしまひの手合なんぞは、云つてることに何の意味もないにしてからがチヨイト頭を捻ること言換れば位置にお構ひなしに移動の万能範囲を拡げることが、いとも優秀なことのやうに思はれることは現時の流行感冒である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "超現実派の詩論なぞも読んでをりますが、そして所々非常な卓見にも遭遇しますが、要するに読んだ後では「今時誰も結論には到達しないのだ」といふ何時も乍らの呟きを繰返さなければならない始末です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の所猶概して印象の羅列以上のことを為し得てゐるとは思へませんが、あれらの努力が何時の日か一個完成したものに迄到達しないものではありますまい。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ目下が精神の貧寒時代であることは分つてゐますし、詩人が存外の苦吟をするのであることも分つてゐるのですから、もつとあけすけにして、もつと具体的なことを論ずることが、詩壇の急務ではありますまいか。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食住さへ足りればよい人達は、不景気なれば、尚更ボヤボヤしてはゐられないといふので、景気のよい時よりも当然意志的になるのであらう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の云ひたいことは、今や、衣食住だけ足りれば好い人達の時勢だといふことである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、平凡万能の時勢が、表明するとしないとに関らず醸しだしてゐる空気といふものは、智的なものでも芸術的なものでもないといふことである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年、「宮沢が死んだ」と聞いた時には、大変気の毒に思ひました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには概念を出来るだけ遠ざけて、なるべく生の印象、新鮮な現識を、それが頭に浮ぶまゝを、――つまり書いてゐる時その時の命の流れをも、むげに退けてはならないのでした。",
              "citation": {
                "source": "宮沢賢治の詩",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、芸術が向上するとすれば、何時も全体的にであつて、要素々々の注入は、却て芸術家の統一を破るくらゐのものである。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさて、今よりも、子供の時分の方が、よつぽど海は好きだつたやうだから、してみると今よりも、あの頃の方が「こころまゝ」だつたのだらうか？",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか、猫の瞳孔が紋むやうに、海は急劇に曇つて来て、今にも時化でもやつて来さうだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しまあ、よく視よう、鏡なんだもの、と緊張を増すと同時に、急いで先が読みたくなくなる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ兄は手に水桃をささげもち、いつさんにきみがかたへにしたひよる、この東京の日くれどき、兄の戀魚は青らみてゆきて、日毎にいたみしたたり、いまいきもたえだえ、あい子よ、ふたり哀しき日のしたに、ひとしれず草木の種を研ぐとても、さびしきはげに我等の素脚ならずや。",
              "citation": {
                "source": "幼き妹に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、するどき薄刃をさげ、左手をもつて敵手に揖す、はや東雲あくる楢の林に、小鳥うたうたひ、きよらにわれの血はながれ、ましろき朝餉をうみなむとす。",
              "citation": {
                "source": "決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのスリツパをはいて、二階の廊下を懷手して、ぶらぶら歩き、ときどき富士を不機嫌さうに眺めて、やがて部屋へはひつて、こたつにもぐつて、何もしない。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木が好きで、學校のぐるりに樣々の植木を、優雅に配置し、ときどき、ひとり、兩手をうしろに組んで、その植木の間を、ゆつくり縫つて歩いてゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
