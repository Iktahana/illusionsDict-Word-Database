[
  {
    "uuid": "9cd9bf9c-1b7d-57aa-be94-c25c249a5119",
    "entry": "洞察",
    "reading": {
      "primary": "どうさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
