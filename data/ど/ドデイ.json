    "definitions": [
      {
        "index": 1,
        "gloss": "embankment made of earth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "片側の大名邸の高い土堤の上に茂り重なる萩青芒の上から、芭蕉の広葉が大わらわに道へ差し出て、街燈の下まで垂れ下がり、風の夜は大きな黒い影が道一杯にゆれる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "模造日本橋は跡方もなくなって両側の土堤も半ば崩れたのを子供等が駆け上り駆け下りて遊んでいる。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出すかと思うと一飛びに土堤を飛越えてまた芒の上をチラリ／＼して行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大船近くの土堤の桜はもうすっかり青葉になっており、将来の日本ハリウード映画都市も今ではまだ野良犬の遊び場所のように見受けられた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜木山の麓から私の坐つてゐた土堤へかけては山と山とに狹められたこの村中での一番大きな平地だ。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも土堤へ上った。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は土堤を川上の方へ、自分は土堤の西の方へと下りる訳だ。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩にした竿、手にした畚、筒袖の裾短かな頬冠り姿の小さな影は、長い土堤の小草の路のあなたに段※然たるその様。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の裏門を出て土堤へ上り、右に折れると松原のはずれに一際大きい黒松が、潮風に吹き曲げられた梢を垂れて、土堤下の藁屋根に幾歳の落葉を積んでいる。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は浜辺へ出るのに、いつもこの店の前から土堤を下りて行くから熊さんとは毎日のように顔を合せる。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土用の日ざしが狭い土堤いっぱいに涼しい松の影をこしらえて飽き足らず、下の蕃藷畑に這いかかろうとする処に大きな丸い捨石があって、熊さんのためには好い安楽椅子になっている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きるとすぐ波を見ようと裏の土堤へ出た。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜辺へ出て遠い沖の彼方に土堤のように連なる積雲を眺めながら、あの雲の下をどこまでも南へ南へ乗出して行くといつかはニューギニアか濠洲へ着くのかしらと思ってお伽噺的な空想に耽ったりしたものである。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "川添ひの土堤に立つて見る。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山、池、野原、川岸、土堤、寺、宮の境内、産地々々の幻をこの一室に籠めて物凄くも感じらるる。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌守りを懸けて、夜中に土堤を通ろうじゃあないか。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "土堤ばたに死んでる蛙のやうに白く腹を出してる遊廓地帶だ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年　あの子といつしよに、凧をあげたり、土堤のつくしをとつたりしようと思つて来たんだけどつまんないなあ。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、クリークの中を泳いですすむまね、掩護物のかげからかげに腰をかがめていく動作、トーチカを占領して万歳を絶叫する途端に腹をうたれて、ころころと土堤からころがりおちるところ――それらはみんな真にせまつてゐた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぼけ（稲漬）が並んでゐる刈田や、枯草の土堤や、裸の白い木などの冬の景色が、駈けて行く久助君の両側をながれた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまやの角をすぎて、お花畑から、麦畑へあがる、草の土堤の上で、虫をふせました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして土堤の下の葦の中へ、おそるおそる盥をおろしてやりました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでたつても、もとの土堤に帰りつくことはできないやうに見えました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は、ときどき、ちつとも近くならない土堤の方に、ちらつちらつと、絶望したやうな眼を投げました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう土堤はすぐそこでした。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "強くない柔かな春の陽光は、川の上に、川の向かふの土堤の枯草に、ふりそそいでゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が岸に着くと、良寛さんは改めて武助さんにお礼をいつて、寒さにがつがつ慄へながら土堤をのぼつていつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "草｜土堤の遠くから律儀な若者の歩みを運ばせて来る足音。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしおのおのの絵が実物とちがう「違い方」が物理学などでいう誤差の方則に従っていろいろに分配せられるとすれば重ね撮りの結果はちょうど「平均」をとる事になってそれが実物の写真と同じになりはしまいか。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒宴の席などでいろいろ滑稽な隠し芸などをやって笑い興じているのを見ると、むしろ恐ろしいような物すごいような気がするばかりで、とてもいっしょになって笑う気になれなかった。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
