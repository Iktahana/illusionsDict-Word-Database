    "definitions": [
      {
        "index": 1,
        "gloss": "how much",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "斯くの如き場合の斯くの如き誤解は、実に局外者の想像に余るものだといふことは、どれ程云つても云ひ足りはしないだらう。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝいふ作品を一つ書き上げることがどれ程の痛い體驗と苦悶とを値したか。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又創作家としてどれ程の矜恃を持つてゐたかそれも知らない。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して口早に女中に留守の事を色々頼まうとしたが、結局どれ程綿密に注意をして置いても、出來るだけの事より出來ないと思つて、唯「留守をしつかり頼むよ」とだけいつてベランダに出た。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな孤獨な中にゐて、しつかりと生命の道を踏みしめて行く人はどれ程悲しいだらう。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は自分の仕事にどれ程の自覺を持つてゐるのか、またどれ程自己省察の眞劍さを缺いてゐるのか、それは判らない。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは以前、古い支那の小説で、ある人妻が佯って、井戸の中に身を投げたように見せかけて、どれ程夫が嘆き悲しむか、それに依って夫の、自分に対する愛情を測ると云う話を読んだことがございました。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場にどれ程売行きが悪くても僕はビクともしません。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりか、良寛さんの偉さが、どれ程であつたかといふことは、大人達にもまだよく解つてゐないのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそ行きの着物といつたつて、れふしたちのは、普段着とどれ程も変つてゐない、厚ぼつたい手織の木綿であつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "足掛六七年になるが、これも怠けて居るから、どれ程の上達もして居ない。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子がどれ程深く喰い入りそこから取り出すであろう芸術も、それをあの賢夫人やその他多くの世間人達がむす子に予言するような、いわゆる偉い通俗の「出世社会」に振りかざし得ようとの期待は、親もむす子も持たなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は、その俤を鎌倉で別れて以来、日がたつにつれどれ程懐しんで居たか知れない。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この賭博法は千フラン以上どれ程巨額な相手にでも親になり賭を引受ける。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "養生したとて、どれ程長く生きられようぞ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小學校の高等科の生徒といふものは中學生のやうな小生意氣さが無く、實に良く働いて、中學生などよりどれ程役に立つか判らないといふのである。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く私はどれ程の多くの思索の種子を寢床の闇の中でむざ／＼と躪り潰して了つたことか。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは兎も角として、南海の人間はまだまだ私などにはどれ程も分っていないのだという感を一入深くしたことであった。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "官軍がこの地に本営を置いた事は、策戦の上でどれ程有利な結果を来したか知れないのである。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、そんな支障がなかったら、関東軍は、幸村等に、どれ程深く切り込まれていたか分らない。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の記臆はどれ程正しく續く者かを他日檢査する爲めにだ。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はお品の發病からどれ程苦心して其身を勞したか知れぬ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の悲哀はどれ程痛切でもそれは自己當面の問題ではない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し春の季節を地上の草木が知つた時、どれ程白く霜が結んでも草木の活力は動いて止まぬ如く、おつぎの心は外部から加へる監督の手を以て奪ひ去ることは出來ない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の閾を越すことが彼にはどれ程辛かつたか知れぬ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次はどれ程嚴重にしてもおつぎが厠に通ふ時間をさへ狹い庭の夜の中へ放つことを拒むことは出來なかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七のおつぎがどれ程それを喜んだか知れなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の食料がどれ程要るかそれは知れたものである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はおつぎがはき／＼と一言でもいうて呉れる毎に其の僻まうとする心がどれ程和げられるか知れないのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿に餌をやるどれほど面白きか知らず。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
