        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おやじも飲んだくれだが、嬶も飲んだくれで、どっこいどっこい、という土方の夫婦がいた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけ声には、やーすけどっこいどっこいな。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっこいどっこいそうはいかねえ！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でろでろ祭文」や「居合抜き」「どっこいどっこい」の賭博屋から「銅の小判」というような、いかもの屋までも並んでいる。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤケ気味に歌のつゞきの囃しを歌う）はあ、どっこいどっこい、どっこいさと？",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はあ、どっこいどっこい、どっこいしょ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてもごらん、マスカーニから音楽を奪い、ポインタやアルマ・タデマから刷毛や顔料を奪い、二度と絵を描くなと命令するようなもので、それはトリガーセン島の専制君主が貧しい老女ナオミを迫害するのと、どっこいどっこいだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どっこいどっこい！",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
