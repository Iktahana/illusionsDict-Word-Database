          "literary": [
            {
              "text": "性来動物好きの少年だった皆三が、標本に欲しかったということも充分理由にはなるのだけれど……。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "性来動物好きの少年だつた皆三が、標本に欲しかつたといふことも充分理由にはなるのだけれど……。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　私は元来動物好きで、就中犬は大好だから、近所の犬は大抵｜馴染だ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」馬を煽ぐ女９・２（夕）　市内の福島辺に動物好きの夫人が居る。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか生後三月ばかりのフォックステリアを、動物好きな咲子のために貰って来たこともあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は性来余り動物好きではなかったし、父は、全然無頓着な方であった。",
              "citation": {
                "source": "犬のはじまり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう動物好きの父が、どうしてああ屡々楠の鳥を撃ち落したか、私には今なお分らない。",
              "citation": {
                "source": "楠の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこならば邸内は広いし、熊一匹養いきれないほどの身上ではなし、留守居の人間も親切であり、動物好きだから、むしろ喜んで面倒を見るにきまっている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
