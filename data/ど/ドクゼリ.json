        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "調べて見ると、意外にも、それは猛毒を有する鳳凰角（毒芹の根）の粉末であった。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どくぜりはもつと／＼危険です。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "手でどくぜりの根を擦つて、それを嗅いでみるんです。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『此のどくぜりには二通りあります。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはおほどくぜりと云つて、湿つた処や、まだ耕やさない土地に生えるのです。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つはこどくぜりと云つてオランダぜりそのまゝです。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
