[
  {
    "uuid": "c1b3450f-3915-54e3-a955-5a798105d1d4",
    "entry": "どうでも良い",
    "reading": {
      "primary": "どうでもいい",
      "alternatives": [
        "どうでもよい"
      ],
      "is_heteronym": false
    },
    "grammar": {
