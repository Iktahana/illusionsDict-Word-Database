    "definitions": [
      {
        "index": 1,
        "gloss": "prefectural tax (of Hokkaido)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "電燈料もガス代も水道税も三倍だ。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道税の事で一寸聞き合せる必要が生じたので、宗助は歸り路に坂井へ寄つた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "水道税の事でちょっと聞き合せる必要が生じたので、宗助は帰り路に坂井へ寄った。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時など、急遽、水道税を納める為、母から百円紙幣一枚を渡され、局へ駈けつけたことなどある。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
