[
  {
    "uuid": "ffbc26e9-7377-51b7-b44c-81943ded4f32",
    "entry": "毒々しい",
    "reading": {
      "primary": "どくどくしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
