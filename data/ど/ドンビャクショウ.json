          "literary": [
            {
              "text": "」Ｔ「どん百姓、下りろ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア映画ではただのどん百姓が一流の名優として現われる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者になりたいからよろしく頼むなんどと白ばッくれて、一方じゃア、どん百姓か、肥取りかも知れねいへッぽこ旦つくと乳くり合っていやアがる」「そりゃア、あんまり可哀そうだ、わ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こつたらどん百姓が、えゝかげん嫌にならなかつたら阿呆だらう。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、石狩原野や十勝原野の樣な廣漠たる風景はなからうし、諸方の炭山事業も規模のああ大きいのは他にすくなからうし、住んでをる人間その物が片田舍のどん百姓でもなか／＼馬鹿にならん。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ出て行け、このどん百姓めが、とつとと出てうせやあがれ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いかにもおれの親父はどん百姓だったが、おれはというと、この通り白いチョッキを着て、茶色い短靴なんかはいている。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そりゃ金はある、金ならどっさりあるが、胸に手をあてて考えてみりゃ、やっぱりどん百姓にちがいはないさ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（間）うちの親父はどん百姓で、アホーで、わからず屋で、わたしを学校へやってもくれず、酔っぱらっちゃ殴りつけるだけでした――それも棒っきれでね。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どん百姓が何のかのと言うなら、山も野も原も焼き払ってやる！",
              "citation": {
                "source": "あまり者",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポポー※　（両の拳をにぎり、地だんだを踏みながら）このどん百姓！",
              "citation": {
                "source": "熊",
                "author": "МЕДВЕДЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そのゴルスツキンというのは、見かけは紺の袖無しなんか着こんで、まるでどん百姓のようだが、肚の中ときたら、まるっきり悪党なんだ、これがお互いの不仕合わせというのさ、つまり、恐ろしい嘘つきなんだ、これが問題なのさ、どうかすると、何のためにあんな嘘をつくのかと、不思議になるような嘘をつくんだ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "往年のアナーキストも今はどう見たって、ざいごから出てきたどん百姓だ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
