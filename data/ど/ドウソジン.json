[
  {
    "uuid": "5244f6cc-2d94-5076-b588-bced8e757c07",
    "entry": "道祖神",
    "reading": {
      "primary": "どうそじん",
      "alternatives": [
        "どうそしん",
        "さいのかみ",
        "さえのかみ"
      ],
      "is_heteronym": true
    },
    "grammar": {
