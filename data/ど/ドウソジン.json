      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "traveler's guardian deity (traveller)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "園は悚然として、道祖神を心に念じた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんが道祖神の化身なら、この子供には、こんがら童子の憑移ったように、路も馬も渉取り、正午頃には早く所口へ着きました。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが本邦に渡来してあたかも邪視もっとも強力なりし猿田彦崇拝と合して昨今の庚申崇拝が出来たので、毒よく毒を制する理窟から、以前より道祖神と祀られて邪視防禦に効あった猿田彦が、庚申と完成された上は一層強力の眼毒もて悪人凶魅どもの眼毒を打ち破るのだ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "予出口君の許しを得て珍しき猴の石像の写真をここに掲げんとせしも再考の末見合せ、代りに掲ぐる第十一図は余が南ケンシントン博物館で写真を模したもので、多くのインド人に尋ねしも訳分らず、しかし道祖神の一態たる和合神（『天野政徳随筆』一に図あり）のインド製に相違なかろう。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北多摩郡の多穀神社、笠島の道祖神、屋張の国の田県神社、印旛郡の熊野神社、奥州塩屋の金精神、信濃の△△、日向の△△、四国の五｜剣山、美濃の山神、いくらもあります！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いて通る旅人の無事を祈るためには、道祖神を祭りました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "海浜にさすらひ、去年の秋江上の破屋に蜘蛛の古巣をはらひてやゝ年も暮れ、春立てる霞の空に白川の関こえんと、そゞろ神のものにつきて心をくるはせ、道祖神のまねきにあひて取るもの手につかず。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありようは、五条の道祖神でござる。",
              "citation": {
                "source": "道祖問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その道祖神が、何としてこれへ見えた。",
              "citation": {
                "source": "道祖問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　道祖神は、ちょいと語を切って、種々たる黄髪の頭を、懶げに傾けながら不相変呟くような、かすかな声で、「清くて読み奉らるる時には、上は梵天帝釈より下は恒河沙の諸仏菩薩まで、悉く聴聞せらるるものでござる。",
              "citation": {
                "source": "道祖問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "道祖神は、それにも気のつかない容子で、「されば、恵心の御房も、念仏読経｜四威儀を破る事なかれと仰せられた。",
              "citation": {
                "source": "道祖問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――が、道祖神は答えない。",
              "citation": {
                "source": "道祖問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは夷神の除禍招福の思想が岐神・道祖神の信仰と結びついたものと思はれるが、市場の舊趾に就いては同書に、「戎社の西傍にあり。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳田先生の『石神問答』は、道祖神を中心にしての研究であったが、そのために、いろいろな石の神体のことを問題にせられた。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はあらゆる石の信仰を問題にせられたが、もういっぺん、そのいろいろの石の信仰を考えぬと、道祖神はわかってこない。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある場合には道祖神そのものが、石の神かと思えるほどである。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭りの標準の形は、正月の飾りを集めて鳥小屋を作り、その中に道祖神を祀り、中にこもっている。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の降る地方では、雪を積んでトンネルのようなものを作り、その中に道祖神を祀る。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大晦日と、十四日年越しと、節分とは、半月内外の遅速はあるが、考へ方によつては、同じ意味の日で、年占・祈年・左義長・道祖神祭・厄落しなどは、何の日に行うてもよい訣である。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "年頭に、男の子たちが、鳥小屋・かまくら・道祖神小屋などに籠るのと、一つ意味のものであるが、かうして分居した団員が、その謹慎によつて、新な社会的資格を得る様になつた、と見る事が出来る。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此行事は、道祖神祭りに与る団員たちよりも、今少し年齢が自由で、かなり年たけた娘たちも、仲間入りしてゐる事を思へば、成年戒に対して行はれた準成年戒――幼童から村の少年・少女となる――よりは、広く、成女戒に属したものではないかと思ふ。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れにしても、正月の道祖神祭りとの間に、一脈の通じる処はある様である。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子の道祖神勧進と、根柢において、かはる所はないのである。",
              "citation": {
                "source": "たなばたと盆祭りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "阪本氏の報告によると、信州上伊那辺の道祖神祭りに、竹を割いて拵へた柳の枝やうの物を配ると、其を受けた家々では輪なりにわがねて、家根に投げて置くさうである。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "年占・祈年・左義長・鳥追ひ・道祖神祭・厄落しは、何の日に行うてもよいわけである。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、賀美郡賀美村とか、宇賀美とか神山など神の字の地名が多く、賀美村の石神は日本の道祖神の総本家という伝えも残っている。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は男の側から言うても同じで、少年がまづ最初に元服すると、村の小さな祭り、即、道祖神祭りなどに与る事が出来、二度目に元服して、若者となつて、初めて、村の祭りに係る事が、出来る様になるのと同じ様に、少女にも、男の通ひ得るをとめと、真のをとめと二通りあつたのだ。",
              "citation": {
                "source": "はちまきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもが、道祖神のお祭りをするのは、何処にでもある。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに附随して神楽もあれば煙花もある、道祖神のお祭も馳せ加わるという景気でありましたから、女子供までがその日の来ることを待ち兼ねておりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しのぶ文字摺、しのぶの里月の輪のわたし瀬の上佐藤｜荘司が旧跡飯坂の湯桑折の駅伊達の大木戸鐙摺、白石の城　笠島の郡に入ると、実方中将の遺跡、道祖神の祠をたずねなければ、奥州路の手形が不渡りになる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
