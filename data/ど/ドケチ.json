        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はかなりのどけちで、割り勘でも一円単位まで細かく計算する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まったく、あいつはどけちだな！奢ってくれたことなんて一度もないぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どけちな彼が、高価なプレゼントを買うなんて珍しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どけちやえばいゝのに……」と、けとばして見たことも何度かあつた。",
              "citation": {
                "source": "石",
                "author": "平山千代子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし実のところ主人はこれほどけちな男ではないのである。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいあんべえに、金テコと鶴ハシはかついで来てゐるんで、小さい奴二つ三つはどけちやつたが、あとはどうにも重くつて手に負えねんだ。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唇をしめろ、なんというだらしのない顔だ」保馬が云った、「まるで紐がほどけちゃってるじゃないか」「ごめんなさい」といしが云った、「でもこれでいいって云う人もいるんですの」　女たちが嬌声をあげた。",
              "citation": {
                "source": "いしが奢る",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
