[
  {
    "uuid": "b558bb59-e15f-5e43-ba43-17c740393cb3",
    "entry": "同感",
    "reading": {
      "primary": "どうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
