    "definitions": [
      {
        "index": 1,
        "gloss": "which (of three or more)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
