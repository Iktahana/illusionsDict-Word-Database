    "definitions": [
      {
        "index": 1,
        "gloss": "by any means (possible)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
