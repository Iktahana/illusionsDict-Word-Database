          "literary": [
            {
              "text": "どうもこうもならん！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どうもこうもなりません。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（野中）　どうもこうも出来やしねえ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七「どうもこうも無いさ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　三十八「どうもこうもありはしません、それが当前じゃありませんか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（どうもこうもなくってよ……）とお三輪は情ない声を出す。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもこうもなりやしない。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもこうもありゃしねえ、そこで大変な代物に衝っ突かったんだい」「追剥にでもお会いなすったかね、当世珍らしくもねえ話だ」「馬鹿にするな、追剥ぐらいで江戸っ児が騒ぐかい。",
              "citation": {
                "source": "狢",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当、豆でも買って、まめになんねえで、どうもこうも……」　ひどく嗄れた、老人らしい声であった。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで、きみたちはどう思うかね」「どうもこうもねえことじゃありませんがなあ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今おめえに稼ぎを休まれたら、父が一人で、どうもこうもなんねえんだから……」　こう言う祖母の表情は、ことにその眼は、菊枝の心に温かな、しかも涙ぐましい影を落とした。",
              "citation": {
                "source": "緑の芽",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深田にいさえすればどうもこうも心配はいらないじゃないか。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、なにしろ御用が忙がしいんでどうもこうもならねえ。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この浪人者が何をしたというのじゃ」「どうもこうもねえんですよ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら異国渡りの秘像のようじゃが、あれがどうしたと言うのじゃ」「どうもこうもねえ、野郎達四人があれを種にひと芝居書きやがったんです。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先は、どうしてまた弥太一様が、こんな姿になりましたことやら、わたくし察しまするに――」「どうもこうもねえんだ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはいったい、どうした子細じゃ」「どうもこうもない、あの人形とぶつぶつさえずっている薄気味のわるいおやじが、さっき八丁堀で取り逃がした当の本人でござんすよ」「えッ※　――そうか、髪の毛と黒ねこがあの京人形に結びつくたあ、いかなおれも、にらみがつかなかったな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたというのでござりましょうな」「どうもこうもないよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃまた下手人が妙な野郎のところに結びついたもんですが、どうしてそんな眼がおつきですかい」「どうもこうもねえ、おめえが今その口で、勘当むすこが芸ごとと弓に凝りすぎたといったじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "お奉行さまはなんておいいだ」「どうもこうもねえんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがいったいどうしたというんですかよ」「どうもこうもしねえのよ、なぞはその急の字なんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、この騒ぎはどうしたというんだよ」「どうもこうもござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            }
