        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "はくは、脛の動詞化である。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "満潮に言うみつも、その動詞化したものであろう。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方から来ると言ふ義で、をちの動詞化の様に見えるが、或は自らするををつ、人のする時ををく（招）と言うたのか。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "引いては、神の憑り来る事も動詞化していつと言ひ、体言化していつかし・いちにはなど言ふ様になつたものか。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くど／＼」など言ふ副詞の語根「くど」から動詞化した「くどく」と言ふ語と同根と見、男女間のくどき言が多いからと考へて来たのは、実は間違ひかも知れない。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "満潮に言ふみつも、其動詞化したものであらう。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに与次郎が、どうしかられたかを聞いておきたいのだが、それはばあさんが知ろうはずがないし、肝心の与次郎は学校で取り逃してしまったからしかたがない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お公卿さまにてつだわさせた名人は、南部つむぎに浜絽の巻き羽織、蝋色鞘は落としざしで、素足に雪駄の男まえは、いつもながらどうしかられても一苦労してみたくなるりりしさでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉の水涼しく動きどうしかな六月九日　日本探勝会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬籠座右に千枚どうしかな冬籠心を籠めて手紙書く十二月二日　桃花会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、だけどね、北村君、仲間から、つまり君のいう、同じ労働者どうしからだよ、ただ、ただ、兄きの弟だという理由だけで、あんなにイジメられ、ヒドイめに逢ったという事は、コタエたよ！",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
