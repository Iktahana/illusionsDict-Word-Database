        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……どこのどいつや」　と、隼団の一人が言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい、どこのどいつがそんな遺言を書いて、大英百科事典を書き写す、そんなつまらない仕事にこんな金を払うんでしょうか。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッキントッシュは高級なおもちゃで、まともな仕事はＭＳ―ＤＯＳでやるものだとこの五年間ほざいてきたのはどこのどいつだ」とついつい口が悪くなる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく慎んでいてくれたのにと思うと、いったい父を誘った相手は、どこのどいつだろうと、そっと足音を忍ばせて近づいてみたそうです。",
              "citation": {
                "source": "勝負事",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのどいつなんだ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃなんですかい、その丑の時参りを押えとって、だんなのいつものからめ手｜詮議で糸をたぐっていったら、どこのどいつが、のろい参りのさむれえたちを、けさみてえにねらい討ちしているか、その下手人もぱんぱんと眼がつくだろうというんですかい」「決まってらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鍔は、どこのどいつに頼まれて彫ったか覚えはねえか」「控えさっしゃい」「控えろとは何がなんだッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "注文先はどこのどいつだ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのどいつが、こんなかわいらしい子どもたちを貧乏にしやがったんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ど、どこのどいつだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのどいつだ」　いいこころ持ちに納まっていたやさきでしたから、不意を打たれてぎょッとしながらききとがめようとしたのを、「そう気どるなよ、親方。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのどいつやろう。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな暑さの中でまで、精も根もつき果てるほど働いていながら、さてどこのどいつが僕をこうまでこき使うのやら、僕は自分でも知らないのさ。",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "交番の傍らには一人の巡査が例の戟にもたれて佇んでいたが、大声でわめきながら遠くからこちらへ走って来るのはいったいどこのどいつだろうと、どうやら好奇心を動かされたらしく、じっと目をこらした。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の田の畦、畑の畔から野良道へ出るとき、由兵衛はいちいち草履の底をこそげて一かたまりの土でも自分の家の土を、どこのどいつでも歩く道へ持ち出さないようにした。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧イネ帝国の敗走兵どもに、そのような尨大な軍備が整いそうもないじゃないか」「じゃあ、一体敵は、どこのどいつだろうかしらん」「それは、おれの方で、たずねているのじゃないか」　兵士たちは、とりどりの噂をしている。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その頃僕は酔っ払うと、しきりに椎の木の話をはじめ、ハラゴンに対する憤慨をのべ、どこのどいつだというような調子だったものだから、それは「椎の木の先生のハラゴンさん」みたいな話だとまぜっ返す者がでてきて、彼女はつい、竹山という実際の人だと口を滑らしたらしい。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "潜水兜をきているのでは、どこのどいつか顔が見えない。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのどいつが何するために俺等の米は奪り上げる！",
              "citation": {
                "source": "軍服を着た百姓源造の除隊",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺を呼んだはどこのどいつだ」　女駕籠と見て取って、長庵にわかに元気付く。",
              "citation": {
                "source": "村井長庵記名の傘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い話が現にあなただっても、こう申しちゃなんですが、じぶんの気持を分ってくれる人間であってくれさえすりゃ、たとえそれがどこのどいつであろうとも、ただもうその男一人に身も心もささげて、明け暮れ慰めもし励ましもしてやろうものをと、そんな気持でいらっしゃるに違いないんだ。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな悪口を言いふらす奴は、一体どこのどいつですかい？",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "して、その、おれを訴えでた友達てえのは、どこのどいつだ？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのどいつがおれの胸をついて、廊下にほうりだしやがったというのだ……」　さっぱりわけがわからない。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのどいつだ、うさん臭え、なんでひとの門口へマゴマゴしてやがる、手近にいたのが、「やい、こん畜生」　ガラリと木戸を引きあけて見ると、　スッと上身を反らして立っていたのが、藤堂和泉守の御息女加代姫さま。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "かごやの客",
                "note": "青空文庫"
              }
            },
            {
              "text": "なによ言やがる、その可哀さうな奴を、売り飛ばしたなあ、どこのどいつだ？",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実はイヤな事をお聞かせしなければなりませんが――いよいよ、毒を盛った人間の目星がつきましたよ」「ヘエ、どこのどいつでございます」　腕の痛みにも、毒薬の苦しさにもめげず、相手が判ったと聞くと又左衛門は膝を乗り出します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "南蛮秘法箋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのどいつが喧嘩の尻を持ち込んだのだろう。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "どろぼうたちはぷんぷん腹をたてて、そこにねている小僧は、いったいどこのどいつだ、とたずねました。",
              "citation": {
                "source": "三本の金の髪の毛をもっている鬼",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも混信状態であることは間違いないわ」「でもさあ、もし海賊放送だとしたら、一体どこのどいつがこんなことやってるわけなんだよ」「そうねえ、きっと暇な物好きか奇人変人の類に違いないわ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
