[
  {
    "uuid": "d4c4a5ce-caf3-56f1-ad43-a6e4632364fb",
    "entry": "独創的",
    "reading": {
      "primary": "どくそうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
