    },
    "definitions": [
      {
        "index": 1,
        "gloss": "creative",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかもそれらの人々が独創的であり見識家であるほど、その差別の程度も甚だしいのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや論文が独創的なものであればあるほど、疵やひびが多いのは当然であるから、そういうものが大勢の合議にかかれば無事に通過する気遣いはまず無いと云ってもいい。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学位授与恐怖病の流行によって最も損害を受けるものは、本当に独創的な研究によって学位を請求する人達であろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "独創的なものには玉もあるが疵も多い。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の人は正式の教育を受けない独創的気分の勝った人に往々見受ける事で甚だ惜しむべき事である。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大して金儲けには関係はないが、『織留』の中にある猫の蚤取法や、咽喉にささった釣針を外ずす法なども独創的巧智の例として挙げたものと見られる。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉の中には欧米学界の優越に対する正当なる認識と尊敬を含むと同時に、我国における独創的の研究の鼓吹、小成に安んぜんとする恐れのある少壮学者への警告を含んでいたのである。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの大政治家の能力と独創的天分とに感服すると同時に、科学的考察力の欠乏を認めた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには複製でない本当の原本と思われる絵を見出して愉快を感じる事もあったが、ややもすればその独創的な点がもうそろそろ一種の安心したような、これでいいといったようなおさまり方に変化するのを認めて失望した。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突飛な題材を無造作な不細工な描き方で画いているようではあるが、第一構図や意匠の独創的な事は別問題としても今ここに論じているような「不協和の融和」という事が非常にうまく行われているので、そこに名状の出来ぬ深みが生じ「内容」が出来ているのである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか人好きの悪そうな風景画や静物画に対するごとに何よりもその作者の色彩に対する独創的な感覚と表現法によって不思議な快感を促されていた。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が他の種々の点で優れたと思う画家の中でも色彩の独創的な事において同君と比肩すべき人を物色するのは甚だ困難である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アー、そんなものは君、もう二十年も前にドイツの何某が試みて失敗したものだよ」といったようなことをしたり顔に云って他人の真面目なそうして実際はかなり有望な独創的研究をあたまからけなしつけるようないわゆる大家も決して珍しくはない。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその巻頭に掲載された和辻哲郎氏の「風土の現象」と題する所説と、それを序編とする同氏の近刊著書「風土」における最も独創的な全機的自然観を参照されたい。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらの祖先にも、少なくも芸術の上では、恐ろしく頭のいい独創的天才がいた。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と云ってもいちばん多くの独創的な点をもっているのはいちばん小さい冬子の自由画であったが、その面白い点が一度認められ賞められるとそれがもう十八番になって、例えば富士山が出だすとそれがいかなる絵にでも必ず現われるのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学芸術の研究は個人の努力と、それから独創的思索にたよるものだ。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に彼の頭には色々の独創的な考えの胚子が浮んで来るのらしい。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしほんとうな意味での新しい独創的の研究をするのに市場に売り古されて保証の付いているほど陳腐な器械ばかり寄せ集めてできたためしはおそらくないであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんどいかなる理論的あるいは実験的の仕事でも、少しでも独創的と名のつく仕事が全然直観なしにできようとは到底考えられない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、たとえばすぐれた物理学者が、ある与えられた研究題目に対して独創的な実験的方法を画策して一歩一歩その探究の歩を進めて行った道筋の忠実な記録を読んで行くときの同学読者の心持ちは、自分で行きたくて、しかも一人では行きにくい所へ手を取ってぐんぐん引っぱって行かれるような気がするであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、一方には、およそ有りふれた陳套な題材と取り扱い方をした小説の「創作」と、他方では、最独創的な自然観人生観を盛った随筆の「中間物」とを対比させて見れば、後者のほうが前者よりもより多く創作的であり、前者のほうがひと山｜百文の模造物への中間にあるものと考えられるであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう種類のものにはやはり必ず何かしら独創的な内察があり暗示があり、新しい見地と把握のしかたがあり、要するになんらかの「生産能」を包有しているある物がなければならないのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある哲学者が多年の間にたくさんの文献を渉猟して収集し蓄積した素材の団塊から自身の独創的体系を構成する場合があるであろう。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の最初の捜し方が拙であったことはたしかであるが、それにしても、本屋に並んでいる書物が「類型的」であり「非独創的」であり、「懸崖作りのつるばら」のようなものであるという例証にはなるかと思う。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の科学的な利器は単に独創的な素人の思いつきや苦心だけで完成するにはあまりに多くの専門的知識の素養を必要とする、という明白な事実が日本のジャーナリストに一般には認識されていないのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある「小新聞」で或る独創的で有益な記事欄を設け、これがある読者のサークルで歓迎されたような場合に、それを「大新聞」でも採用するようにと切望するものがかなりに多数あっても、大新聞では決してそれはしないという話である。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでたとえば昔、広重や歌麿が日本の風土と人間を描写したような独創的な見地から日本人とその生活にふさわしい映画の新天地を開拓し創造するような映画製作者の生まれるまでにはいったいまだどのくらいの歳月を待たなければならないか、今のところ全く未知数であるように見える。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丙種の科学者になると、かえってこうした毛色の変わった問題に好奇的興味を感じ、そうして、人のまだ手を着けない題材の中に何かしら新しい大きな発見の可能性を予想していろいろ想像をめぐらし、何かしら独創的な研究の端緒をその中に物色しようとする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、またそういう独創的な仕事の常として「きずだらけの玉」といったようなものが多いから、アカデミックな立場から批評してそのきずだけを指摘すればこれを葬り去るのは赤子の手をねじ上げるよりも容易である。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
