    "definitions": [
      {
        "index": 1,
        "gloss": "drowned body of a person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いつ死のうかと逢う度毎に相談しながら、のびのびになっているうちに、ある日川の向うに心中｜態の土左衛門が流れて来たのだよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、内地の船頭が土左衛門を舟に積むのを忌み嫌うように。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「それが心配なの」　とおふみが言ってる時、前を通り過ぎる娘二人、Ｔ「厭なもんね土左衛門ッて」　えッとおふみ胸騒ぎがします。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返った娘に、Ｔ「見たんですか土左衛門を？",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　えーと娘が、Ｔ「たった今其処の橋の下で」　伝六が、その土左衛門、Ｔ「男ですか？",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大喜びのおふみ、ふと思い出して伝六に、Ｔ「土左衛門は」　伝六がアッ、Ｔ「其奴忘れてた」　で慌てて走り去る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端に土左衛門が置かれてある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六帰って来たおふみに、Ｔ「土左衛門は船頭だったよ」　と言う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）１３＝（Ｆ・Ｉ）以前の橋の処　土左衛門を調べる右門主従と敬四郎。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）13＝（Ｆ・Ｉ）以前の橋の処　土左衛門を調べる右門主従と敬四郎。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に飛び込んだる髯将軍、オットセイと称して浴槽の中へ仰のけのまま跳り込み、頭から、足からザブンザブン飛び込むこと十数回、危うく浴構内の土左衛門さんとならんとせしところを三人して引挙げ、ようやく事なきを得た。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし雲巌寺を出発してから行く途々、渓流に沿うて断岸の上から眼下を見れば、この渓流には瀑布もあれば、泡立ち流るる早瀬もあり、また物凄く渦巻く深淵などもあって、好奇に盥に乗って下ろうものなら、二人や三人土左衛門と改名したかも知れぬのだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の自分に女は助け舟だが土左衛門みたいに助けてもらって男が立とうか。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "土左衛門なら浮びもするが、俺は一生浮び上れなくなるのだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と狸はほくほくして、「でも、あの鮒つてやつは、素早いもんでなあ、おれはあいつを捕へようとして、も少しで土左衛門になりかけた事があるけれども、」とつい自分の過去の失態を告白し、「お前に何かいい方法があるのかね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文公は泳ぎを知ってるか知らん」「なに、トックリさ」「あすこで一つ滑ったら土左衛門だぜ」「もっとも、あいつは土左衛門には前に一度なりかゝったことがある。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「土左衛門じゃない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これから土左衛門が多いですよ」という。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう、水死人の、そうか、謂わば土左衛門塚。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実はわっしも今朝調べて来たのですが、鳥亀の亭主の安蔵というのは、去年の春の彼岸に下矢切で土左衛門になったそうで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠ばたの柳からまずその秋がふけそめて、上野、両国、向島、だんだんと秋が江戸にひろがると、心中、川目付、土左衛門舟、三題ばなしのように決まってこの三つがふえる。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつに、この横堀こそは、秋の隅田に名物のあの土左衛門舟が艫をとめる舫い堀なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
