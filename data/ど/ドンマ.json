[
  {
    "uuid": "df5766e6-5c5e-5342-a5f6-5c4fbfaf6248",
    "entry": "鈍麻",
    "reading": {
      "primary": "どんま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
