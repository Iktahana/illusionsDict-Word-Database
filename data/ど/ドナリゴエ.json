        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひどい怒鳴り声がする。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」暴っぽいラクシャンの第一子が金粉の怒鳴り声を夜の空高く吹きあげた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川一面に低く唸るような人声の総音、その上を転がって行く女の癇高い笑い声、夕風に爪を立てゝ引裂くような怒鳴り声、どこともなく浮かれた鳴物の音。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……静かに……静かにッ……」　という翁の怒鳴り声が暗い舞台の中に雷のように反響して私を縮み上らした。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年が重い鉄門を開けかねていると、博士の荒々しい怒鳴り声が聞こえ、怒って握り拳を振り回しているのも見えた。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつまでもマスかいてんじゃねえぞ」　という怒鳴り声と、またドアが悲鳴をあげる音。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四万温泉の丑の刻　丑満ごろに、闇をつんざいて聞えた鬨の声、ただならぬ廊側の足音、てつきり『山賊襲来』と思つたのは、丑の刻を知らせる田村旅館の番頭達の怒鳴り声であつた。",
              "citation": {
                "source": "大利根八十里を溯る",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "また向う側の監房で荒れ狂う音がする、怒鳴り声がする、歌を歌う、壁板を叩いて騒ぎ立てる。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うぬ、売女奴」　その瞬間に戸口が開いて、泥まみれの木履を穿いて頭巾つきのマントをかぶった子供が外から帰って来たが、父親の只ならぬ見幕とその怒鳴り声に胆をつぶした。",
              "citation": {
                "source": "生さぬ児",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずそれは聞え出したと思うと、急にこう云う怒鳴り声に変った。",
              "citation": {
                "source": "トロッコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "万平は親方に見付からないように、勝手口からソーッと這入って行くと、トタンに奥の方から大きな怒鳴り声が聞えた。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずそれは聞え出したと思ふと、急にかう云ふ怒鳴り声に変つた。",
              "citation": {
                "source": "トロツコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚も勘右衛門は門の内側で、酔ったあまりに思慮を失って、止める者のないのを幸いにして、怒鳴り声をつづけているようであったが、茅野雄には興味がなくなったので、怒鳴り声を聞きすてて歩き出した。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へん、どうするか見やアがれ」　恐ろしい見幕で怒鳴り声をあげた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」文は憎さげに怒鳴り声をあげ「福助の出る幕じゃあねえ、引っ込んでろ！",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お城方の勢が来ましたんで」　いかにもその時大勢の足音や、物の触れ合いぶつかり合う音や、喚き声や怒鳴り声や制止の声などが、この家の前の空地の辺から、さもけたたましく聞こえて来た。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何がきっかけだかは分りませんが、大きな怒鳴り声がしたので振向いてみると、両方立上って殴り合おうとしてるんです。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然この時怒鳴り声がした。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒鳴り声、罵しり声、喚き声、一つにかたまってやかましく、騒言となって聞こえては来るが、それさえ何んとなく不安らしい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーターの印象では、教授の怒鳴り声は神が乗り移った雷のように聞こえ、それが小柄な男の偽らざる意見に近いものであった。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "またマンダプーツの怒鳴り声が聞こえた。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのも、はっきりと区別できる一連の怒鳴り声の応酬が突発していたからだ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "隘路を吹き捲くり唸りを上げ笛のように叫び立てる風と消音器を下ろした発動機の爆音の中、ダンフォースと私は専ら怒鳴り声で感銘深い一瞥のことを話し合った。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "時どき、早く降りてこいと将昭の怒鳴り声が聞こえる以外、家はひっそりと静まりかえっていた。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "（――いきなりほとんど喧嘩のような怒鳴り声ではじまつた二人の青年の口論は、もう相当の時間つづいて来たものである。",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は悪いことをしてたような気がして、両手で急いで耳をふさぎ、恐るべき怒鳴り声をきくまいとした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "母や父や祖父から、腹だちまぎれの怒鳴り声を浴びせられても、なお彼女はやめなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆の者が、彼の悠長さに怒鳴り声をたてた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、つかまえたぞう」　とおくのほうから、さっきのおまわりさんのどなりごえが、きこえてきました。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
