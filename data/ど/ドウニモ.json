[
  {
    "uuid": "0ca43363-6fb0-5eb2-96b3-d4b9b720bde2",
    "entry": "如何にも",
    "reading": {
      "primary": "どうにも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
