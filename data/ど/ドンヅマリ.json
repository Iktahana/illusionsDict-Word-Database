        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "愈々どん詰りまで行けゃあ、俺だって虫けらた違うんだからな。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまた次ぎのどん詰りの三疊には電信學校の生徒がゐて、時々發信機の練習をがちや／＼やつてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかしあの問題のどん詰りまで行けば、面白い事件なんだよ」「そうかねえ、僕には全然分からない」　私は正直に白状した。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私から見ていると私に笑われて奮然とするような屋敷がだいいいちもうぼろを見せたので困ったどん詰りというものは人は動けば動くほどぼろを出すものらしく、屋敷を見ながら笑う私もいつの間にかすっかり彼を軽蔑してしまって笑うことも出来なくなったのもつまりは彼が何の役にも立たぬときに動いたからなのだ。",
              "citation": {
                "source": "機械",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどん詰りには、目ッかちで跛足の蜆屋がいる。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐と信濃の国境、富士見高原のどん詰り、八ヶ岳の渓谷に、極楽浄土があるそうだ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに、救世軍声を嗄らせどイースト・リヴァの澄まぬかぎり、ここの｜どん詰りは救われそうもないのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし、とどのどん詰りは、結局私あ近藤の妾にならなきやならんかも知れんねえ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ胆太くドッシリと腰を据えてこの事件のどん詰りまで見物してやろう。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり早水秀之進の今日まではこうしてどん詰りまで孤独だったのである。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どん詰りになって、女は彼の家へ逃げ込んだ。",
              "citation": {
                "source": "葦",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か二十余日でどん詰りまで来た。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三棟の長い丸太小屋と、少し離れて、谷のどん詰りにばかげたほど大きな、荒壁の庫が三棟。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな放浪の苦しみはもうたくさんである、わずか一食の銭を得るために、切腹のまねをしなければならないところまで来てはどん詰りだ。",
              "citation": {
                "source": "日日平安",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この水路にはきっと、どん詰りがある。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらふらと最前の橋廊下まで来て見たが、何の様子も知れないので、お延は我れ知らず廊下から廊下を伝って、館のどん詰りまで来た時、発矢と、激しい剣の音がしたのを聞いた。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう後ろは廊下のどん詰り、前には息さえ乱れぬ新九郎の太刀。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのどん詰りの藪畳で」「家中の者の眼に触れるようなことはあるまいな」「さっきも申し上げた通り、仲間部屋の者が夜遊びに出るだけで、めったにお見廻りが来る所じゃありません」「そうか」「ところで女は、どこへ押し込んでおくおつもりですかい」「お船蔵の綱部屋はどうじゃ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が海の底を探險しても、たいていここが海底のどんづまりだと見極めて引上げて行くのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい俺たちが、五人そろって貧乏のどんづまりに引きさがりながらも、鼻歌まじりで勇んで暮らしているのは、誰にもあずけておけない仕事があるからだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酷烈な気もちに追いつめられて見ていたそのどんづまりから湧き出した涼感であったかも知れないのだが。",
              "citation": {
                "source": "真夏の幻覚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が海の底を探険しても、たいていここが海底のどんづまりだと見極めて引上げて行くのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、そういう風に思い詰めるどんづまりに、また反撥心も起って、お祭騒ぎや、主義や理想も立て度くなるんじゃないのですか。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんづまりのどん底、おのれの誠実だけは疑わず、いたる所、生命かけての誠実ひれきし、訴えても、ただ、一路ルンペンの土管の生活にまで落ちてしまって、眼をぱちくり、三日三晩ねむらず考えてやっと判った。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、どんづまりのその女郎が殺されましてからは、怪我にもゆき人がございません、これはまた無いはずでございましょう。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうどんづまりで、広告に応じる切手もそれを貼る封筒もつらい始末で、事務所の階段を直接昇って靴をすり減らしたんですけれど、職を得るのはもうどこまでも遠く思えてきたのです。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の連続的な身の毛のよだつ恐怖のどんづまりの叫び声とも何ともつかぬ声をあげて、家ぢうを逃げ回るのであつた。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何んとか、かんとか云ったって……どんづまりはなア！",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに、これこそ人生のどんづまりである。",
              "citation": {
                "source": "映画と癩の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明暗」は十二年間のあらゆる意味でのどんづまりであったと感じられる。",
              "citation": {
                "source": "漱石の「行人」について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
