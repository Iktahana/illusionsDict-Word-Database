[
  {
    "uuid": "246d862c-a650-5c92-ac53-2c617ba151a2",
    "entry": "同船",
    "reading": {
      "primary": "どうせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the same ship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "留吉と呼ばれたその若者は子供の時分から漁業に從事してゐたが、去年暴風に遭つて難船し、同船の兄をば見す見す殺した爲めに發心してその職業を止めた。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この帽子と羊羹色になりたる紋付羽織とのために、同船の一商人をして我を天理教の伝道師と見誤らしめき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを護送するのは、京都｜町奉行の配下にいる同心で、この同心は罪人の親類の中で、おも立った一｜人を大阪まで同船させることを許す慣例であった。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『自分は自分の片腕と頼む男を南｜亜米利加に急行させてカラタール氏と同船させることにした。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ろうとすると、同船した昔なじみに出会って、ずっと一緒に歩いていたというのですが、この昔なじみの住所を問いつめても、満足に答えることもできませんでしたよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを護送するのは、京都町奉行の配下にゐる同心で、此同心は罪人の親類の中で、主立つた一人を大阪まで同船させることを許す慣例であつた。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを護送するのは、京都町奉行の配下にゐる同心で、此同心は罪人の親類の中で、主立つた一人を、大阪まで同船させることを許す慣例であつた。",
              "citation": {
                "source": "高瀬舟",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はかねて五十川女史から、田川夫婦が同船するから船の中で紹介してやるといい聞かせられていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、田川夫妻が自分と反対の舷の籐椅子に腰かけて、世辞世辞しく近寄って来る同船者と何か戯談口でもきいているとひとりで決めると、安心でもしたように幻想はまたかの若者にかえって行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と懇意なＫ書店の主人は、見送のためわざわざ神戸から門司まで同船することにした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が松の青い島々をめぐって行くうちに、同船の森知事が起って、かの老人たちを紹介した。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて一同船に乘らうとして海邊にある黄ばんだ砂を踏んでいつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "同船の誰かれ――日本人学生Ｎ氏とＮ氏夫人の英吉利婦人、Ｔ大学医学部教授Ｔ博士、などとみんな一緒に上陸して、出帆までの町の内外をドライヴする。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロンボの港（印度、錫蘭）からポオト・セエドまで同船した日本の絹商で、一度船の中で手を分った人に岸本は復たその港で一緒に成ったのであった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "小樽在住の番屋と共に同船して來たのは、小樽に着けば直ぐ來年の事業擴張の相談を濟ますつもりであつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "文學者だと思つてだらう、或代議士が遞相と同船中、家持の長歌「海行かば」云々、「山行かば」云々の句を解し得なかつた滑稽を、特に面白さうに話した。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分等と同船で樺太を逃げて來たり、自分等と小樽のはと場で別れてから、あの女放浪者はどこへ行つたらう？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "無電技師はエヴァンス一人きりで、彼が寝ている間、同船は聾なのである。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓町人、同船ならん。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と止めて、『同船許す、みんな乘れ。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "『武士、同船ならん。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄竹の高い聲に驚いて、百姓町人の群れまでが、後退りするのを、玄竹は優しく見やつて、『百姓乘れ、町人乘れ、同船許す。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽好きな公達を誘って同船して行ったのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に彼れは、同船のアメリカ人の夫婦と、そのためにはげしい論戦を開いたくらゐである。",
              "citation": {
                "source": "日本の女",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時妻ハ長崎へ月琴の稽古ニ行たいとて同船したり。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十二月四日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "然ニ先頃長崎より後藤参政と同船ニて上京仕候処、此頃英船御国ニ来るよしなれバ、又、由井参政と同船ニてスサキ港まで参り居候得とも、竊ニ事を論じ候得バ、今まで御無音申上候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年八月八日　坂本権平あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "其上ヱ小松へ御聞合｜被遣一人同船の儀、御頼可被遣度奉願候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月中旬　後藤象二郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢代は久慈とも同船で来たのであった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この善良な材料さえ手に入れますれば、まあどうせんでも、すでに美味い料理は出来ていると言いましても、過言ではありません。",
              "citation": {
                "source": "料理する心",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
