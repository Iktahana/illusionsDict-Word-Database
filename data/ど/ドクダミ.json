    "definitions": [
      {
        "index": 1,
        "gloss": "chameleon plant (Houttuynia cordata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
