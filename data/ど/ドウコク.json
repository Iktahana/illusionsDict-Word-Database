    "definitions": [
      {
        "index": 1,
        "gloss": "same country",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "火山の変形　昨年四月イタリアのヴェスヴィアス山がやや烈しい噴火をやったが、その後同国陸軍地理局で測量を行った結果によると、噴火前における最高点の高さ海抜千三百三十五メートルあったのが千二百二十三メートルに減じている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「今にもう一人ここへ来て寝るそうじゃが、お前様と同国じゃの、若狭の者で塗物の旅商人。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局員｜貴下、御心安かれ、受取人の立田織次も、同国の平民である。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスランドの火山 Askja は同国古語の Aska（灰）であるとすれば、これは英語の ashes（灰）と親類だそうである。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に双方が同国の長崎というんですから、おまんは誰よりも全真を余計に可愛がるような素振りが見える。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "諺をまだ知らない同国人の留学生等には彼の方から単純に説明した。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の人でも某老は同国人の借金の尻拭いを仕て遣り遣りして、終におのずからなる勢力を得て顕栄の地に達したという話だ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に夢の如き想像ではあるが、国香と護とは同国の大掾であつて、二重にも三重にもの縁合となつて居り、居処も同じ地で、極めて親しかつたに違ひ無い。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に罪を得たものは、同国人で同姓の兼有、高郷、興貞等十八人とあるから、何か可なりの事件に本づいたに相違無い。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあ、勝頼様と同国ですな。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三「今に最う一人此処へ来て寝るさうぢやが、お前様と同国ぢやの、若狭の者で塗物の旅商人。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同国の者はこの広告を見て「先生到頭死んだか」と直ぐ点頭いたが新聞を見る多数は、何人なればかくも大きな広告を出すのかと怪むものもあり、全く気のつかぬ者もあり。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "心ある同国人の二三はこれを見て泣いた。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "永正十一（十七）年｜駿河国興津に生れ、今川治部大輔殿に仕え、同国｜清見が関に住居いたし候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三年四月赤松殿｜阿波国を併せ領せられ候に及びて、景一は三百石を加増せられ、阿波郡代となり、同国｜渭津に住居いたし、慶長の初まで勤続いたし候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の人のためになら、同国の女を裸体にする取次は無論しない。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "某致仕候てより以来、当国｜船岡山の西麓に形ばかりなる草庵を営み罷在候えども、先主人｜松向寺殿御｜逝去遊ばされて後、肥後国八代の城下を引払いたる興津の一家は、同国｜隈本の城下に在住候えば、この遺書御目に触れ候わば、はなはだ慮外の至に候えども、幸便を以て同家へ御送届｜下されたく、近隣の方々へ頼入り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊は失望して死のうと思い、同国｜和気郡大字板根と云う処へ往ってそこの橋の上から身を投げようとした。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで明治二十八年になって、やはり同国｜御野郡金山の人に「神の告げがあった」と云って、三人の者が伴れだって訪ねて来たから、尊も始めて神仙の話をして聞かせた。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同国で言うは虎｜故なく村に入るは伝染病流行の兆と。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この上はなにを隠そう、われわれはその蛇神の女と同国の者でござる」　彼等もやはり西国の或る藩士で、蛇神のことはかねて知っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜に来ている同国人のあいだにも義理のわるい負債が嵩んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "同国ではあるが、親類ではないと、私は答えた。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "金井君は自分の下等な物に関係しないのを臆病のように云う同国人に、面当をしようという気になる。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同国人は荒肝を抜かれた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（資、一ノ三、二三八ページ）　一八五五年、ベルギーにおいても、デュクペシオー氏は、書物の中で、悲惨でないと思われている標準的の労働者が、同国における囚人の営養よりも、十三サンチームだけ営養が少なかったと書いている。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島猴もっとも多し、毎年二月十一日申の日を限り、同国島の八幡の社司七日の間｜祓を行い、申の日に至りてこの島に来り、猿の口開の神事を行う。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂといふのは、横浜に居るＦと同国生れの青年で、常々親しく往来してゐるといふことを、私は屡々Ｆから聞されてゐた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に豊後府内から同国｜津守に移されて、台所料として幕府から一万石を給され、晩年をこともなく過し、慶安三年九月十日に薨じた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスでは、ガストン・ルルーとモーリス・ルブランとが、恐らく同国探偵小説界の双璧でありましょう。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
