        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何処やらで滝の音が聞えて、石燕が窟の前を掠めて飛んだ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処やらで猿の声が聞えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の水音に消されて、今までは誰も聞付けなかったが、何処やらで微な唸声が聞えるようである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その面ざしの何処やら似ているのを見ると、あるいは兄弟か叔父甥などでは無いかという説もあったが、これとても一部の人々の想像に過ぎなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然として何処やらで小さな鈴の音が聞えた。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処やらでは、のうのうと、声をそろえて羽衣を謡っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜おそく何処やらの室の騒がしきは人や死にたらむと、息をひそむる。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処やらで単調な琉球蛇皮線の音がする。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も無かつた様な、まだ身体の何処やらに石油の余香を捧持してゐさうな、丈高いこの友の前に立つても可笑しく、あとになつても可笑しかつた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプ部屋ではまだ何処やら勇ましかつたが、今朝はあはれ見る影もない。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言うのは、こんな場合いつでもする様に、杉本は機関車の下ッ腹へ水を引ッ掛けながら、さて何処やらに若い娘のキモノでも絡まり込んでいないかなと注意して見たんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はもう、身体も心も綿の如く疲れきつてゐて、昼頃何処やらで蕎麦を一杯宛食つただけなのに、燈火がついて飯になると、唯一膳の飯を辛と喉を通した。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処やらで調子はづれた高い男の声が、最先に唄つた――（ヨサレ―茶屋のか―アかア、花染―の―たす―き―イ――）『面白いですねえ。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓の響と唄の声が聞える、四辺は森として、何処やらで馬の強く立髪を振る音。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処やらの日本婦人が世界を廻って帰って来て、横浜まで船が入ると、どぶんと海へとびこんで死んだという話もきいた。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見れば常さえ艶やかな緑の黒髪は、水気を含んで天鵞絨をも欺むくばかり、玉と透徹る肌は塩引の色を帯びて、眼元にはホンノリと紅を潮した塩梅、何処やらが悪戯らしく見えるが、ニッコリとした口元の塩らしいところを見ては是非を論ずる遑がない。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎は、何処やらどっしりしたのが好きですけれども、客間食堂は、真個にくつろいだ、愉快な処にしたく思います。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜松にて束の間の逢瀬、何処やらに惚れこみ、志を少し紙にひねつて、彼にも知らさずその袖に投げこんだを、あとで何と言ひしやら聞きたし。",
              "citation": {
                "source": "旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "“苧環をくりかけてあり梅の宿”“何処やらに鶴の声きく霞かな”“駒ヶ嶽に日和さだめて稲の花”井月の偽筆！",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この直木の態度と犬養健の態度との間には何処やら共通の一応の悧口さと基礎的な愚さとがある。",
              "citation": {
                "source": "ブルジョア作家のファッショ化に就て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、私どもに、祖母は何処やら気の毒な、必要以上にいつも勤勉な人として感じられていた。",
              "citation": {
                "source": "祖母のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皮と身と離るゝ体我持てば利殖の本も買ふ気になれり」　思わず――その体の持主が私共だということ、それに利殖の本を結びつけた機智の面白さ――笑ってしまう滑稽さがあるが、このユーモアには何処やら淋しさがこもっているようではないか。",
              "citation": {
                "source": "九月の或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓬々とした青草の面に、乾いた、何処やら白いような光線が反射し始めた。",
              "citation": {
                "source": "蓮花図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何処やら、対象の掴みかたがぼんやりしている。",
              "citation": {
                "source": "第一回日本アンデパンダン展批評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかれている人の名がわかって見る者は納得するというようなところがあって、画面そのものが何処やらただものでない一個の男をえがき出していて、おやと思ったら、或る人の肖像であったというような、画面の芸術的実在性が弱かったように思います。",
              "citation": {
                "source": "第一回日本アンデパンダン展批評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの頃は、自分たちの住んでいる街や村のまわりにも、何軒かは便乗景気のところもあって、何処やら努力のつぐのいは、身近いところにちらついていそうであった。",
              "citation": {
                "source": "便乗の図絵",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いかにも物懶さと云い、何処やら地から生え抜き日本離れのした雰囲気と云い、面白いのだが、私共は或虫、その他心配で迚も泊る気にはなれなかった。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りる一つ手前の駅で狂気の発作がひどくなったので、何処やらで狭窄衣を手に入れて、車掌や憲兵に手伝って貰って患者に着せたのだった。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "辞世は「何処やらで鶴の声する霞かな」と云ふ由。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いうと、おだやかでないが、陰気で、しなやかに撓む、クニャクニャした気象の女だったら、どうか我慢も出来たであろうが、お八重さんが、サックリした短所も長所も、江戸ッ子丸出しの気性だったのだから、その嫁と姑のやっさもっさが、何処やら、今から見ると時代ばなれがしている。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
