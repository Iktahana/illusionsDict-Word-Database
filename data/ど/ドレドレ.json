        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「どれどれ、内地の札だな。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が言い澱んでいると、先輩は、どれどれと言って私の手から巻紙を取り上げて、「むかしの事だから、どんな文句か忘れてしまった。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と懐より時計を出だして指示せば、「どれどれ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ……旅の事欠け、不器用ながら、梨の皮ぐらいは、うまく剥きます。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "因果娘は偸視て、「おや、出刃打ちの連中があすこに憩んでいなさるようだ」「どれどれ」と見向く年増の背後に声ありて、「おい、そろそろ出掛けようぜ」　旅装束したる四、五人の男は二人のそばに立ち住まりぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ……何を見とるのか」「……あそこにお母さまの顔が……」「フーン……どれどれ……どこに……」　と父親は腰を低くして、チエ子の指の先を透かしてみた。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と呟くのを聞いて、いじらしさに、つい涙ぐみ、「どれどれ、あら、ほんとう。",
              "citation": {
                "source": "おさん",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ、おまえは、これだけのめばいい。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ今日は三四日ぶりで家へ帰って、叔父さん叔父さんてあいつめが莞爾顔を見よう、さあ、もう一服やったら出掛けようぜ」と高話して、やがて去った。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ飯にしようか、長話しをした。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ掃除して参らしょうぞ。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のうちの消息欄に出てましたよ」「どれどれ……」　と、記者の出した新聞を見て、「――なるほど、出てるね。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌切雀舌切雀はどこへ行た、どこへ行た、どれどれ探しに出かけませう。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれどれ、ああ、さうだね、それくらゐあれや好いだらう、」　老婆は蟇を足元に投げ捨ててコツプを受け取つた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大層な雛だというが、どれどれと押上がって、やあ一人でやっていなさるの、私が相手をしようッて、そのお膳の前に坐りましたっさ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれどれ、どんなんだい。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれどれ拙者が」と安富寄碩が、子細らしく取り上げたが、これもしばらく考えていたかと思うと、思案に余って投げ出してしまった。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ、では一見してつかわそう――」　一向に無感激な物腰で、ふところ手をやったままのっそり人垣の中へ這入ってゆくと、じろり中の様子を一｜瞥したようであったが、殆んどそれと同時です。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ、では一見してつかわそう――」　一向に無感激な物腰で、ふところ手をやったままのっそり人垣の中へ這入ってゆくと、じろり中の様子を一瞥したようであったが、殆んどそれと同時です。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてはちと義理固すぎるようじゃが、どれどれ、鯛をもっとこちらへ。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ、どこにあります？",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ、事のついでにどの位出来そうか星をつけておいてつかわそう。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ、どんなお方でござります」　ギイとくぐりをあけて、しきりにためつすかしつ、差しのぞいていたが、菊路ほどの深窓珠をあざむく匂やかな風情が物を言わないという筈はない。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この受け取りは、おまえのところでたしかに出したか」「どれどれ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ、俺も一杯仲間入りをさせて貰はうか、はつはつ……、何が何でも関やしないぢやないか、笑へ、笑へ、だ！",
              "citation": {
                "source": "裸虫抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
