    "definitions": [
      {
        "index": 1,
        "gloss": "lodging in the same place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで茶をのんで餅をつまんでゐたら、同宿の若い夫婦連れがあとからはいつて来た。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで茶をのんで餅をつまんでいたら、同宿の若い夫婦連れがあとからはいって来た。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、心に何か決する処があってか、Ｔ「宮本先生と　御同宿致すとは　願ってもなき倖せ」　そうで御座います、と亭主。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日｜樋口という同宿の青年が、どこからか鸚鵡を一羽、美しいかごに入れたまま持って帰りました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンの宿に同宿していた何とかいう爺さんが、夕飯後ストーヴの前で旨そうにパイプをふかしながら自分等の一行の田所氏を捉まえて、ミスター・ターケドーロと呼びかけてはしきりにアイルランド問題を論じていた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿の山崎は、頻りに、この暴動を思い止まらせようとするのだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事を同宿のドイツ人に話したら、オペラはドイツに限るのだと言っていばっていました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜、厠へ行く途中、廊下で同宿のわかい女とすれちがつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人の同宿者があった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時先生の宿は西子飼橋という橋の近くで、前記の化学のＫ先生と同宿しておられた。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は同宿人のゐないことが、つまり六畳と三畳二間きりのその二階が私一人のものであることが、どんなに嬉しかつたか知れはしない。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「同宿、構わずに、しけ込めしけ込め。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿は四国生れの老遍路さん、彼もまた何か複雑な事情を持つてゐるらしい、ルンペンは単純にして複雑な人間である。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿は老遍路さん、可なりの年配だけれどがっちりした体躯の持主だった。",
              "citation": {
                "source": "遍路の正月",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿四人、みんな愚劣な人ばかりだつた（現代の悪弊だけを持つて天真を失つてゐる）。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝月残る木槿が咲いてゐるながれ　島へ渡しの、氷や菜葉や郵便や・氷屋ができて夾竹桃の赤や白や・落ちてきて米つく音の水がながれる・近道のいちはやく山萩の花・水は岩からお盆のそうめん冷やしてある　　行乞雑感（一）　八月十一日晴、暑かつたが気持は軽かつた、仙崎町行乞、そして滞在、新相客は伊佐で同宿の老遍路。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時出発、深川町を行乞しはじめたら大夕立がきた、そして地雨らしく降りつゞける、馴染の川本屋へとびこむ、こゝの主人公――押入聟さん――は私の放浪時代に度々同宿して打解けた飲友達だ、久振に一杯やらうといふので一升買つた、酔うて唄うて踊つて――誰も彼もいつしよになつて――近来の大散財なり。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宿――豊後屋といふ――はやつぱりよかつた、同宿者のおしやべりには閉口したけれど、一室一燈一張のよろしさだつた、便所のきたないのはぜひもない。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿の若い坑夫さんと山の観音様へ詣でた、一年一度のおせつたいがあるといふので、近村のおぢいさんおばあさんが孫を連れておほぜい詰めかけてゐた、山村風景のおもしろい一枚である。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿、いや、同室一人、誓願寺詣の老人、好きな好々爺だつた、いづれ不幸な人の一人だらう！",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿は少々気のふれた乞食老人、下らなく話しかけてうるさいから、すまないけれど黙殺してやつた。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿同室は鮮人、彼も失職者、よく話すけれど嫌味がない、どこでも働らきたい、金を貯めて家庭を持ちたいといふ、彼によき妻あれと祈つた。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子達一家は、麻川荘之介氏の自殺する五年前のひと夏、鎌倉雪の下のホテルＨ屋に麻川氏と同宿して避暑して居た。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（それを麻川氏が読んだか読まないか葉子は当時気にもとめなかったが、矢張り読んで居たことを一ヶ月間Ｈ屋に同宿して居るうちの麻川氏との交際で判った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　とにかく、こんな前提は、いよいよとなると葉子の心から一掃されて、葉子にはただ崇拝する文学者麻川荘之介氏と同宿するという突然な事実ばかりが歴然と現前して来るのであった。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、こんな日常倫理のうえの判り切った出鱈目を、知らぬ顔して踏襲して行くのが、また世の中のなつかしいところ、血気にはやってばかな真似をするなよ、と同宿のサラリイマンが私をいさめた。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の下、葎生ひ茂りて、星影の晝も見ゆべくおどろ／＼しければ、同宿の人たち渾名して龍ヶ谷といふ。",
              "citation": {
                "source": "逗子だより",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岸は法律上の知識は勿論、英語のほかにドイツ、フランスの語学にも精通していましたから、わたしはいい人と同宿したのを喜んで、その部屋へ押しかけて行っていろいろのことを訊くと、彼もまた根よく親切に教えてくれる。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝ここを発つときに、ふたたび松島さんのところへ尋ねてゆきますと、松島さんの部屋には同じ少尉の負傷者が同宿していました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
