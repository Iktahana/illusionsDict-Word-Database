        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "心理的に原因をさがすと、家庭の女性が余りドメスティケートされすぎ、極端に云うと永代女中頭みたいな点。",
              "citation": {
                "source": "京都人の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあなたが後にいい家庭の主となられて、かつて得られなかったところのドメスチックの愛と睦びと、ゆったりした幸福を得られることを心から願います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゅうしまつは、全く人間的にドメスティックだ。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "学名は Nandina domestica Thunb. で、そのナンデイナは南天に基づいた名、ドメスチカは人家の庭に植え養われてあるからいう。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドメスティックなの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの台所で働くユリはドメスティックでわるくないでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "国もドメスティックな人なので細君がいないと何となく悄気ていて気の毒よ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
