[
  {
    "uuid": "ff90cce8-e126-5ad0-bf06-b4f634d5f032",
    "entry": "動乱",
    "reading": {
      "primary": "どうらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
