[
  {
    "uuid": "ea7644c1-b7f0-5407-922f-251213aa7286",
    "entry": "道徳性",
    "reading": {
      "primary": "どうとくせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
