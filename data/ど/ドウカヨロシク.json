        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「どうか宜しく願います。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それでは、どうか宜しく頼む。",
              "citation": {
                "source": "生あらば",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石松つあんが帰ってお出なすったら、どうかよろしくおっしゃって下さいまし。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかよろしくおねがひ致します。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い細路を通って向うへ行ったら私の胃袋にどうかよろしく云って下さいな。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何ぶんどうかよろしくおねがいいたします。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「割に素直に書かれて在ると思いますから、いい作品だと思いますから、どうかよろしくお願いいたします。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺たちは、そのぉ、朝の暗えうちから、草鞋ばきの尻端折で、吉植です、ええどうかよろしく、ええどうかよろしくさ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更、木賀に対して、前川と何の関係もないと、抗弁するのも愚かしいことであったし、と云って木賀に、どうかよろしくと、依頼する気にもなれなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかよろしく」と、小さく挨拶を割り込ませた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにも、あのお嬢さんを嫁にしようなどとは、夢にも考えていなかったが、こうなると一番若返るかな、はゝゝゝゝ、じゃ、杉野さん、どうかよろしくね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかよろしく……」「さようなら……」　　そう言って別れた帰りがけに私は、彼女の身元引受人になっている下谷の伯母の処へ電報を打った。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢや、杉野さん、どうかよろしくね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はア」と、ちよツと氣恥かしい樣な返事をしたが、思ひ直して、「また來ましたから、どうかよろしく願ひます。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さだ子は小声で藤枝に、「先生、伊達さんの事をどうかよろしくお願いいたします」　と歎願するように云つた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕は初めて自分の不注意に気がつき、名刺を持っていなかったので手帳の紙にＲ・Ｃ・Ｃ加藤文太郎と書いてどうかよろしくと言って渡したのです。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではどうかよろしく」　すると、主人はてきぱきと一切のことをきめて言った。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうかよろしくお願いします。",
              "citation": {
                "source": "文章",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうかよろしくお願いします」「覚平さんだったね」とさしいれ屋の亭主がいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちが長良川博士、こっちがドン助教授です」「ああ、そうか、どうかよろしく、どうかよろしく」　と、クーパーは、ひたいを下にすりつけんばかりに大よろこびである。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかよろしくお願いしたい。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "静間　　どうかよろしく。",
              "citation": {
                "source": "賢婦人の一例（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "右どうかよろしくたのみます。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "燕尾服の自殺　――ブルゴオニュの葡萄祭り――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの十一屋の隠居にも、どうかよろしくおっしゃってください。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "女優Ｂ′　　では、まあ、どうかよろしく……。",
              "citation": {
                "source": "職業（教訓劇）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二階へ上りかける）夫　　（てれくささうに）ぢや鳥羽さん、御覧の通り世帯はまた開業ですから、どうかよろしく。",
              "citation": {
                "source": "世帯休業",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この娘、今日来たんですの、どうかよろしく……。",
              "citation": {
                "source": "ガンバハル氏の実験（ラヂオドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、どうかよろしく。",
              "citation": {
                "source": "動員挿話［第一稿］",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうかよろしく頼んます、村の為めならどんなこつてもさせますで」と親爺は懇ろに頭を下げて、青洟をたらした子供等にまで仲間入りを頼んだ。",
              "citation": {
                "source": "泥の雨",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            }
          ]
        }
