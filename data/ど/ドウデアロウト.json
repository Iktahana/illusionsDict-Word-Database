    "definitions": [
      {
        "index": 1,
        "gloss": "whatever (the case may be)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "余所のものはどうであろうとちっとも心には懸けないように日ましにそうなって来た。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の胃袋の加減や腹工合はどうであろうと、私が腑に落ちないと申しますのはここなんでございますが、その時はただもう冷汗びッしょり、穴へでも入りたい気になりまして、しおしお片隅の氷のような腰掛へ下りました。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "他のお客様にはどうであろうと、この坊ちゃんだけにゃ飽かしたくない。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学校での行状がどうであろうとも、学資を出してやっているわけではない。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーヴェエ氏は（君の覚え書で見たところでは）『レトワール紙』の記者と直接に会って、あの死体は記者の説がどうであろうとマリーの死体である、と主張して、その記者を怒らせたようだね。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、あとでどうなろうと、世間の人がどうであろうと、こんな処はとても私たちの出る幕じゃあない。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬られた事情はどうであろうとも、彼が盗賊であることは疑うべくもない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい事情がどうであろうとも、人間ひとりが殺されては一大事である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといその結果がどうであろうとも、かれは預りの金を奪わんがために毒酒を平吉に贈ったのであるから、容易ならざる重罪人である。",
              "citation": {
                "source": "放し鰻",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果がどうであろうとも愛する者は愛するのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの天幕を借りて、この夏此処に登って五日なり十日なりを独りで過して見たらどうであろうと思いついたのであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、私はこの観音のことに気が附き、これを合田医師へお礼としてはどうであろうと思いました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大病をした時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ陰陽の摂理とやらがどうであろうと、先に挑んだはそちらの馬じゃ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "河田や石川が自分にとって、どうであろうと、それが自分の運動に対する「気持」を一体どうにも変えようが無い筈ではないか。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つには、団菊左と云うような諸名優が舞台を踏まえていて、たとい脚本そのものはどうであろうとも、これらの技芸に対する世間の信仰が相当の観客を引き寄せるに何らの不便を感ぜしめなかったからである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし学者の意見はどうであろうとも、実際、かの内田が自己催眠に罹っていたにしても――僕の眼にそれが赤座の姿と見えたのはどういう訳だろう。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "成ほど、そんな事があるかも知れぬと、侍女下女を一々取調べた所が、果してその中に池袋生れの者があったので、当人の知った事ではあるまいが、兎も角もこれに長の暇を出して、さてどうであろうとその後の模様を窺うと、石は相変らず降る。",
              "citation": {
                "source": "池袋の怪",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "財政がどうであろうと皆様がお困りであろうと、国防上必要最少限度のことは断々固として要求する」旨お答えして辞去した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際には幾つかの事情がかたまって亡命させたのだろうが、原因はどうであろうとも、とにかく若殿の近侍であった宗房がその主人の死とともに出奔し得たところに、その時代の武士気質が崩れかけて、もう武家時代の気風と異って来ている空気が感じられて面白い。",
              "citation": {
                "source": "芭蕉について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの後の処分がどうであろうという心配が皆を悩まして居る内に一週間停船の命令は下った。",
              "citation": {
                "source": "病",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "精励な会社員はあくまで社員で、人物がどうであろうと、重役には重役の息子がなるのが今日の経済機構である。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "短波がどうであろうと、一見民衆の生活にかかわりないようないきさつに置かれている。",
              "citation": {
                "source": "市民の生活と科学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい説教僧がどうであろうと、教えそのものは叔母の腹に沁み入ったに相違ない。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "効果はどうであろうとも、私の生涯はその生長と推移のコースを動いて行かねばならない。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の言葉つきはどうであろうとも、彼が尽してくれる真心、賢い忠言に変りある筈はない。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがすえ子の意志であろうとなかろうと、どうなりましょう、すえ子は当時、親の為に犠牲になるようなことを云っていたのですが、勿論私にはそれがどうであろうと全然関係のなかったことです。",
              "citation": {
                "source": "悪魔の弟子",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれもだれも楽しんでいる中で、宮だけは「いかなれば近江の海ぞかかるてふ人をみるめの絶えてなければ」という歌の気持ちを覚えておいでになって、遠方人の心（七夕のあまのと渡るこよひさへ遠方人のつれなかるらん）はどうであろうとお思いになり、ただ一人｜茫然としておいでになるのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう詳細に知って書いてある人に存在の紛らしようもない自分ではないか、そうかといってその人にも、願わぬことにもかかわらず変わった姿を見つけられた時の恥ずかしさはどうであろうと浮舟は煩悶して、もともと弱々しい性質のこの人はなすことも知らないふうになっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "夢の浮橋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
