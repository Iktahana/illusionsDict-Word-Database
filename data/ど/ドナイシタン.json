        "examples": {
          "standard": [
            {
              "text": "「顔色が悪いけど、どないしたん？何かあったんか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「え、急に黙り込んで。どないしたん？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が泣いているのを見て、「どないしたん、話してみて」と優しく声をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「…………」「一体どないしたんや」「…………」「言うてみイ」　お雪はきっと涙にぬれた顔をあげて、「坊ちゃま。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伯母さんがどないしたんや……」　幹男は不安そうにきいた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何もかも……どないしたんや」　幹男はじれったそうにきいた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄貴、どないしたんや。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どないしたんや」四　いきなりそう言ったのは、この田村へ女を連れずにやって来るたった一人の男――いいかえれば、貴子が田村の改造費の二百万円を借りた木文字章三だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰り、どないしたんや、家あけてという声をきき流して、あちこちで貰う祝儀をひそかに貯めて二百円ほどになっていた金を取出し、着物を着変えた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毛利君、どないしたんや？",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちでその樣な間違のあつたゝめしが無いのに、どないしたんでつしやろ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えば、妙子がそんな忠告をした後の或る日、悦子が始めて気が付いたらしくて不思議そうに雪子の顔を見詰めながら、「あれ、姉ちゃん、眼の周りどないしたん」と、大きな声で聞いたことがあった。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその明くる日、終日妙子が姿を見せなかったので、今日はこいちゃん、どないしたんやろ、………風邪でもお引きになったんでしょうか、と、悦子とお春が不思議がった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どないしたん、………」貞之助がそう云うと、「今夜やわ、………あんた、………今夜がちょうど一周忌やわ。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
