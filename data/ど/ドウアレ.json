        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "理由はどうあれ、フェリアは独身をつらぬいた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみたちがやったことは、理由はどうあれ、きたないリンチだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "成績はどうあれ、試験のあとというのは、中学生にとっては、天国のイメージにもっとも近い。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "できはどうあれ（高志自身、慶一やワラや山崎に、これについて、ひとことでも感想をいったら、たとえそれがほめ言葉でも、二度と四〇七の秘蔵食料は食べさせない、といいわたしたぐらいだ）、テレビの画面にキャンパスや子どもたちが映っているので、父兄たちはけっこう楽しんだようだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、僕にどうあれといふ註文をしたつて無駄だよ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しかったのでサビナ専用の小屋へ入れてもらい、食欲がどうあれ、ヤギの煮込飯をかき込み、地ワインで流し込んだ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私がジャスパ家系の直系子孫だと証明できれば、あなたはどうあれ退位して、地位を私に渡さなければなりません。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がどうありたいのか、どうあれば幸せなのか、到達しようとして目ざしている状態があるのかなど、彼女がアルバイトを開始してひと月がたち、長かった残暑が終わる頃になっても、裕美子にはつかみきれないままだった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のラリから見れば、外人などくそ食らえだから、バラドスや同類と衝突しようが、どうあれ、むしろ楽しい。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "この謎がどうあれ、たとえここで殺人があったとしても、あの灰色服のご婦人は全くの潔白です。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間がどうあれ、いい娘だった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、どうあれ強烈な抗しがたい誘惑があった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "武松どの、あなたはどうあれ、私は以後、あなたを義の兄と立ててゆきます」　施恩は、武松にむかって四拝の礼をとった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはどうあれ、妾の口一つで、後からきっと二人は助けてとらせまする。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが名分はどうあれ、それは正成が尊氏へ降伏したものとなることに変りはない。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "窮極はどうあれ、尊氏もここでは自分を嘘の皮膜でくるんではいられない。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
