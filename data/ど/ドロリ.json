    "definitions": [
      {
        "index": 1,
        "gloss": "thick (of a liquid)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
