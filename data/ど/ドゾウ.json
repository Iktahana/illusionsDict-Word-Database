    "definitions": [
      {
        "index": 1,
        "gloss": "storehouse with thick (earthen) walls",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "柚の花やゆかしき母屋の乾隅　土蔵などのある、暗くひっそりとした旧家であろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに表現の構成を分析すれば、「柚の花」が静かな侘しい感覚を表象し、「母屋」が大きな旧家――別棟や土蔵の付いてる――を聯想させ、「乾隅」が暗く幽邃な位置を表象し、そして「ゆかしき」という言葉が、詩の全体にかけて流動するところの、情緒の流れとなってるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵もみんな焼け、所々煉瓦塀の残骸が交じっている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゆんべもおとといの晩も自分の家へ帰って来ませんとさ」　新日本音楽の先生の帰ったあと、稽古場にしている土蔵の中の畳敷の小ぢんまりした部屋になおひとり残って、復習直しをしていた老妓は、三味線をすぐ下に置くと、内心｜口惜しさが漲りかけるのを気にも見せず、けろりとした顔を養女に向けた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南国の盛夏の真昼間の土蔵の二階の窓をしめ切って、満身の汗を浴びながら石油ランプに顔を近寄せて、一生懸命に朦朧たる映像を鮮明にかつ大きくすることに苦心した当時の心持ちはきのうのことのように記憶に新たである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "角から四、五軒さきの質屋の土蔵のまえには、一挺の駕籠が下ろされて、そこには二人の駕籠舁と先刻の武士らしい男が立っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "３＝生島屋の附近　川端で土蔵の白壁が見えて居て柳の木が一本ある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の中の方が学校よりも都て厳格で、山本町に居る間は土蔵位はあったでしたが下女などは置いて無かったのに、家中揃いも揃って奇麗好きであったから晩方になると我日課の外に拭掃除を毎日々々させられました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵の横にある大きな柿の木の大枝小枝がまっさおな南国の空いっぱいに広がっている。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの空襲で豊田さんも全焼し、それに土蔵まで焼け落ちたようで、お気の毒です。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう百年ほど経って日本が紀元二千七百年の美しいお祝いをしている頃に、私の此の日記帳が、どこかの土蔵の隅から発見せられて、百年前の大事な日に、わが日本の主婦が、こんな生活をしていたという事がわかったら、すこしは歴史の参考になるかも知れない。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は生家の土蔵の奥隅になお二三十個のたからもののあることをも知っている。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書なんてものは信心でもしない限り滅多に読んでみる気がしないものですし、その本を持ち伝えた先祖代々の人も、それがソンナ本だって事を云い伝える事も出来ずに、土蔵の奥に仕舞い込んで御座ったんでげしょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ程の大家の娘が、あられもない賭博なんどとは……ちと受取り悪いが……」「ところが間違い御座いませんので……元来あの蔵元屋と申しまするは、蔵元町と申しまして町の名前にもなっておりまする位で、土蔵の数も七戸前。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "チトお話が荒う御座いますが、何にせい博多中の恵比寿講の帳面を預っておりますので、帳面合わせとか、金勘定とか申しまして、時々奥庭の別｜土蔵の二階でチャランチャラン遣っているのが、真夜中になると微かに聞こえます。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "相わかった、相わかった……しかし話はモトへ戻るが、その蔵元屋の別土蔵の二階の金勘定が真実の金勘定でない、賭博に相違ないという事は何処で見分けたか」「やっぱり塵箱が物を申しますので……」「ふうむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は土蔵の石段に腰かけて例の如く茫然と庭の面を眺めて居ますと、夕日が斜に庭の木の間に射し込で、さなきだに静かな庭が、一増粛然して、凝然として、眺めて居ると少年心にも哀いような楽いような、所謂る春愁でしょう、そんな心持になりました。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉はお花が土蔵の前の石段に腰掛けて唱う唱歌をききながら茶室の窓に倚りかかって居眠り、源造に誘われて釣りに出かけて居眠りながら釣り、勇の馬になッて、のそのそと座敷をはいまわり、馬の嘶き声を所望されて、牛の鳴くまねと間違えて勇に怒られ、家じゅうを笑わせた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に大溝の幅広い溝板が渡っていて、粋でがっしりした檜の柾の格子戸の嵌った平家の入口と、それに並んでうすく照りのある土蔵とが並んでいた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵の裾を囲む駒寄せの中に、柳の大木が生えている。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝に葉のある季節には、青い簾のようにその枝が、土蔵の前を覆うていた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵には、鉄格子の組まれた窓があった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ土蔵の窓から、体格のしっかりしてそうな眉目秀麗な子供の皆三が、しょっちゅう顔を見せている癖に、決して外へ出て、みんなと一緒に遊ばない超然たるところを子供達は憎んだ。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達は、お涌も時に交って、その土蔵の外の溝板に忍び寄り、俄かに足音を踏み立てて「ひとりぼっち――土蔵の皆三」と声を揃えて喚く。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌は今では、日比野の家の格子戸を開けて入ると女中の出迎えも待たず玄関の間を通り中庭に面している縁側へ出て、その突当りの土蔵の寒水石の石段に足をかける――「いるの」という。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときおくれ馳せに女中が馳せつけて「失礼しました」と挨拶してお涌を土蔵の中に導き、なにかと斡旋して退く――というような親しさになっている。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆三は血の気で頭の皮膚が破れるかと思うばかり昂奮して、黙って座を立って行って、土蔵の中の机の前に腰かけた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またおだやかな日々が暫く経って行った或日、今も良人の研究室になっている土蔵の二階から、涌子は昔、自分に貰った蝙蝠を良人が少年の丹念を打ち籠めて剥製にしてあったのを持ち出した。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、年とつたお母さんはお母さんで、嫁ごは子供をあまやかしすぎる、子供と猫はあまやかすほどぞうちやうする、とひびのはいつた金だらひを叩くやうな声で、いひはつてをりました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前回の名月騒動が、あのとおりあっけなさすぎるほどぞうさなくかたづきましたので、その埋め合わせというわけでもありますまいが、事の端を発しましたのは、あれから五日とたたないまもなくでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
