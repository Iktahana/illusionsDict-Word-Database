[
  {
    "uuid": "7043393b-9c49-55f9-b1c7-e2bb0f78d2ec",
    "entry": "同座",
    "reading": {
      "primary": "どうざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
