    "definitions": [
      {
        "index": 1,
        "gloss": "animal (in nature)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
