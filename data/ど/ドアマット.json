        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから何週もドアマットをまたがないこともめずらしくないんで。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はドアマットまで進むと呼鈴を押した。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元のドアマットがブンブンうなって悶えるので、彼は慌てて後ろに下がった。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドアマットに驚かないでください、チェルカソフさん――貴男はチェルカソフさんですわね？",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は頷き、目を彼女からドアマットに落とした。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三人の男は慎重にドアマットの上を歩き、中に入った。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　チェルカソフ氏は注意深くドアマットを踏んだ。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
