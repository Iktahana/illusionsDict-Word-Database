        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "グリーンランドのどの辺を舞台にしたものか不明なのが遺憾ではあるが、とにかく先ず極地の夏のフィヨルドの景色の荒涼な美しさだけでも、普通の動かない写真では到底見られぬ真実味をもって観客に迫ってくるようである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの空を涵してゆく影は地球のどの辺の影になるかしら。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「西太平洋って、どの辺だね？",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ははじめたった一人で行こうと思ったのでしたがどうも野原から大分｜奥でこわかったのですし第一どの辺だったかあまりはっきりしませんでしたから誰か友だちを誘おうときめました。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、ここはどの辺だか見て置かないと今度来るときわからないよ。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ははじめたった一人で行かうと思ったのでしたがどうも野原から大分奥でこはかったのですし第一どの辺だったかあまりはっきりしませんでしたから誰か友だちを誘はうときめました。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、こゝはどの辺だか見て置かないと今度来るときわからないよ。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸たずねますが、ひなげしさんたちのおすまいはどの辺ですかな。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茸だの、松露だのをちっとばかり取りたいのですが、霜こしなんぞは、どの辺にあるでしょう。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴雄はつんと身を引いて、「その辺ってどの辺だ」　ぶっ切ら棒に言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの辺りで止めるか、人さまざまだが、しかし、信吉のように、エスプリがないと思ったことが、相手の唇からはなれる動機になるというのは、些か異例であろう。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どの辺まで出かけるんですの？",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "では学術のどの辺から、詩の範囲に入り得るだろうか。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門のこの噂は、いつ、どの辺から起つたのか、どれだけの時間を経て屋敷全体に拡がつたものか判らないが、兎に角今までにない確実性と普遍性とを持つてゐる。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の姿はその時どういふ恰好で大雪原のどの辺にゐたか知れないのだ。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にても、ウテツなどの辺は風俗もやや蝦夷に類して津軽の人も彼等はエゾ種といひて、いやしむるなり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして貴方、お望の草をお採り遊ばすお心当はどの辺でござんすえ。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んだ道連れになって、さだめし御迷惑でございましょうが、実は警察がどの辺にあるか存じませんので、あなたに御案内を願いたいのでございます。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに蝋燭の火を入れて、父は再び現場へ引っ返したが、さてその穴がどの辺であったか容易に判らなくなった。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「片門前はどの辺か判らないかね。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平「君、三十二番地はどの辺？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平「三十二番地はどの辺でしょうか」初枝「三十二番地？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平「また迷子になってるんじゃないですか」節子「えゝ、二十二番地はどの辺でしょうか」庄平、初枝と顔を見合せる。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、高橋治平さんという人の家は、どの辺だね？",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、そのよく知った地理によって、夜おそくまで、あるいは徹夜でも営業する飲食店が、どの辺にあるだろうとの見当はついていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い上がった娘だという評判の伊予守の娘、すなわち紀伊守の妹であったから、源氏は初めからそれに興味を持っていて、どの辺の座敷にいるのであろうと物音に耳を立てていると、この座敷の西に続いた部屋で女の衣摺れが聞こえ、若々しい、媚めかしい声で、しかもさすがに声をひそめてものを言ったりしているのに気がついた。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田源之助の屍体を運んで行って、この海の中のどの辺へ沈めたのかって事をだね。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "素藤が初め捕われて再挙を謀る間潜伏した山というはどの辺を指すのか解らぬが、夷隅は海岸を除いては全郡山地があるが山がすべて浅くて且つ低くて人跡未到というような感じのある処はなさそうだ。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十五号室はどの辺になりましょう」　十五号は三四郎が今出て来た部屋である。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハータ、ターコ、コーマ、ハート……」そこまで読むと彼女は、ほんの今まで見てゐた、群から一寸外れて歩いてゐた蟻は、もうどのへんに行つただらうと思ひながら柿の樹の根元を見る。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
