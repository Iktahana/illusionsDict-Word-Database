        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は元来が何方付かずの男であつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方付かずに真中へ立つて、煮え切らずに前進する事は容易であつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は元来が何方付かずの男であった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何方付かずに真中へ立って、煮え切らずに前進する事は容易であった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は何方付かずの中間に出た。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うっかり途中でやめさしたら、どっちつかずの生れ半着で、これまで折角銭を入れたんが何んにもなるまい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、何ごとも、どっちつかずにして来て、この二年間で法科の課程を三分の一、それも不充分にしか卒えていない。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの事についても僕は前からそういうふうにはっきり片づけてしまいたいと思っていたんですけれど、姑息な心からそれまでに行かずともいい結果が生まれて来はしないかと思ったりしてきょうまでどっちつかずで過ごして来たんです。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村に取っては苦しい事だろうが、僕から考えるとどっちつかずで煩悶しているのよりどれだけいいかわかりません。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎はどっちつかずの中間にでた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一旦、許可したのを、今さらむげに解散させるというわけにも参らぬので、事を有耶無耶の中に葬ろうとして、どっちつかずの態度を取ることになった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、妙な性分だから、あなたが何だか噂にとりまかれて、どっちつかずに貧弱な暮しをしてるのが切なくなって来たわ。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏はどっちつかずに宙に浮いたふうで中将が結婚もしないでいることを見かねて、「あちらとの話をあきらめているのなら、左大臣とか、中務の宮とかからのお話が来ているのだから、だれと結婚をするか決めてしまうとよい」　とも言うのであったが、宰相中将は黙って恐縮したふうを見せているだけであった。",
              "citation": {
                "source": "源氏物語",
                "author": "梅が枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつの間にか自分も曖昧などっちつかずの心で絶えず父と母を窺うようなことをしているのに気付いた。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、おれはこれっぱかりも彼女に不自由はさせてねえだから、彼女が何でおれを袖にするもんか」　婆さんはどっちつかずの身振りをして、「知れたもんじゃねえわさ」　といったが、ふと調子をかえて、「うんにゃ、わしは悪口をいうでねえ。",
              "citation": {
                "source": "麦畑",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、この言葉の音には、どんな金嚢にもまして、卑しい人間をも、どっちつかずの人をも、また立派な人々をも、つまり万人を動かす何ものかが潜んでいるからである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "また中にはどっちつかずの変に瞹昧な表情をうかべている婦人もあって、それがいよいよ彼をまごつかせてしまった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、片方は死に、一方は過去の記憶を失っているという始末ですから、どうせどっちつかずの循環論になってしまって、結局はその二人の幻像が、ああでもないこうでもないと、物狂わしげな叫び声を上げながら、私の頭の中を駈け廻るにすぎませんでした。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちつかずの心持で、長崎から帰って今日で半年、ブラブラ遊んでいるのであった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が旧劇を見て、最も異様に感ずるのは、役者が自然と不自然の間を、どっちつかずにぶらぶら歩いている事である。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こういうどっちつかずの有様がお前たちみんなを怖がらせているんだよ。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿の老婦人は、アンを見ると、驚愕に近い表情になって、彼女のところへ飛んできたが、傍に仏が立っているのに気がつくと、俄に平静に戻ろうと努力し、「おや、まあ、これは……」　と、どっちつかずの挨拶をすれば、アンはそれを途中から引取って、「おばさま。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが今日までどっちつかずのままいさせたのかも知れません。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、喜びと不安と、どっちつかずの気持であった。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちつかずの状態が著しく人間を因循にすることは、あなたも御存じでしょうな。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）ほんとに、いつまでそう、どっちつかずじゃあねえ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当のことというものは、いいにしろ悪いにしろ、とにかくどっちつかずでいるより、少しは気が安まるもの。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、先生は、乞食部落を巴里市から区切る危い一線の上に、どっちつかずのようすで暮していられるのであって、先生の尊厳は、際どいところであやうく食い止められているわけである。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ小田原まで連れて行って、行儀作法を習わせたと聴いて、お前は変だとは思わなかったか」「へエ」　ガラッ八はどっちつかずの返事をしました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスとスペイン間の力の平衡、フランスとスコットランドとにおける党派争いの均衡、どっちつかずのオランダの運命、それらが、今日の目ではとうてい解き難いひねくれた彼女の外交に、働く余地を与えたのだった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
