        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「どうだい、あの毒づくことは！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言つても取りあげないばかりか、あべこべに、おれが碌でもないところをほつつきまはつたり、仲間と往来で無茶な真似ばかりしてると言つて、さんざ毒づくのさ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはお前の手が見えすぎる」と毒づく時の、ヴァレリイの眼の奥を覗くこと。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "長期に亘る事変に処して、国民の士気はあくまでも鼓舞しなければならず、当面の敵を忘れさせてはむろんならず、時には、頑迷な重慶政府を毒づくことも結構であるが、どうかさういふ時にも、国民の品位と余裕とを十分に示してほしい。",
              "citation": {
                "source": "一国民としての希望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆さんは、前にもいったようにきっとお前や柳町の入れ知恵もあったのだろうが、私にここのうちを出ていってくれといって、後には毒づくように言って追い立てようとした。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしまいには、呆れて応答も出来ないような野卑な口をきいて毒づくのである。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、彼がこういったたぐいの親切な世話をやくときはたいてい、みんなと喧嘩になってしまい、しかも、その人たちが恩知らずであると言ってひどく毒づくのである。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "と一｜図に決して、さてこそあの、裏で手を合わせて表に毒づくあいそづかし……お艶も江戸の女であった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたゞ、栄一に毒づくのである。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかをいい出せば、きまって兄は敗戦以来、魂の抜けた人のように、一向に働こうとしない父を毒づく。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように毒づくのであるから時々世間の人達のご機嫌を損うこともあるが、毒づいた当人にとっては心持のいい事｜夥しい。",
              "citation": {
                "source": "福沢先生の処世主義と我輩の処世主義",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生も我輩も毒づくばかりを能としない。",
              "citation": {
                "source": "福沢先生の処世主義と我輩の処世主義",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "胆がすわってやがると、毒気を抜かれたおもいの俺は、「加柴さんをマダムは知ってるのか」と風巻が言うのを耳にしたとき、「往年のテロリスト仲間さ」と毒づくように言っていた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭の神輿かついで廻ってたと言ふ、「いつもお祭よりバカなまねしてるんだ、今更みこしかつぐこたあるまい」と毒づく。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒づく老予言者に似ている。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄杖を引け」「怯んだか、腰抜け」「そう毒づくなよ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱い囚人は可愛がってやるが、上役に毒づくし、仲間の牢番なども、威張る奴へは、こッぴどくたてをつく。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無念無念と、ただ毒づくばかりだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
