    "definitions": [
      {
        "index": 1,
        "gloss": "to curse (at someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
