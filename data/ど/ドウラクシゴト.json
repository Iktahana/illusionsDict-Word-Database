    "definitions": [
      {
        "index": 1,
        "gloss": "work done for enjoyment (as a diversion)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
