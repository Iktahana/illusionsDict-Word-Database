        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうして長い頭髮の一本一本がことごとく腹の赤い毒蛇である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵に對してこの無數の毒蛇は、素早く一樣に鎌首をもたげ、しゆつしゆつと氣味惡い音を立てて手向ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の胸の中では、毒蛇が鎌首を投げた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩一歩の足の痛みと、「今日からの生活の悩み」が、毒蛇をつッついたのだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自殺用のピストルをいぢりながら、昨夜の馬鹿氣た行爲を後悔し、毒蛇のやうな自己嫌忌に惱まされる。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの映画であったか忘れたが東洋物の場面の間に、毒蛇とマングースとの命がけの争闘を写したものをはさんだのがあった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "李花は猛獣に手を取られ、毒蛇に膚を絡われて、恐怖の念もあらざるまで、遊魂半ば天に朝して、夢現の境にさまよいながらも、神崎を一目見るより、やせたる頬をさとあかめつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の名僧などで、信念の凝り固まったものには、悪人強盗はもちろん、猛獣毒蛇でさえ近寄れなかったと言い伝えられています。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　――港で待つよ――　と、恁う申すのではござりませぬか、と言ひも未だ果てなかつたに、島の毒蛇の呼吸を消して、椰子の峰、鰐の流、蕃蛇剌馬の黄色な月も晴れ渡る、世にも朗かな涼しい聲して、　――港で待つよ――　と、羽を靡かして、其の緋鸚鵡が、高らかに歌つたんです。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大佐は、今朝も定れる職務に參るが、昨夜は取紛れて語らず、今朝は猶ほ御睡眠中なれば、此水兵を以て申上げるが、此住家の十｜町以内なれば、何處へ行かるゝも御自由なれど、其以外は、猛獸毒蛇等の危害極めて多ければ、决して足踏みし玉ふな、大佐は夕刻に皈つて、再び御目にかゝる可し。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "此遊歩の間、武村兵曹の命ずる儘に、始終吾等の前になり、後になつて、豫め猛獸毒蛇の危害を防いで呉れた、一頭の猛犬があつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "※一行けば忽ち猛獸毒蛇に喰殺されてしもうから、死んだ人間は無いも同然。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處で此鐵車に乘つて、朝日島の名を刻んだ紀念塔を携へて、此處から三十｜里位いの深山に踏入つて、猛獸毒蛇の眞中へ、其紀念塔を建てゝ來るのだ、何んと巧妙い工夫ではありませぬか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "山に入ると、直ちに猛獸毒蛇の襲撃に出逢ふだらうとは兼ての覺悟であつたが、此時まで其樣な模樣は少しも見えなかつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "之が普通の塲所なら、かゝる死地に落ちても、鐵車をば此處に打棄てゝ、其身だけ免れ出る工夫の無いでもないが、千山萬峰の奧深く、數十里四方は全く猛獸毒蛇の巣窟で、既に此時數十の獅子、猛狒の類は此穴の周圍に牙を鳴し、爪を磨いて居るのだから、一寸でも鐵檻車の外へ出たら最後、直ちに無殘の死を遂げてしまうのだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛獸毒蛇との大奮鬪。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に今でもこの山中にはなかなか毒蛇が沢山いるという事だ、御用心御用心」と、首を縮めて腰の辺を撫でている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし猛獣毒蛇｜来らば、その眼玉で睨み殺して賜われ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし、気心の知れた丑の時参詣でさえ、牛の背を跨ぎ、毒蛇の顎を潜らなければならないと云うんです。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかに虎口を遁れ来て、仁者の懐に潜みながら、毒蛇の尾にて巻かれたる、下枝が不運憐むべし。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒蛇を咬倒したあとは、希くは鼠を獵れ。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……学円　綺麗な石が毒蛇の鱗？",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鬼、畜生、夜叉、悪鬼、毒蛇と言わるる私が身に、袖とて、褄とて、恋路を塞いで、遮る雲の一重もない！",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして長い頭髪の一本一本がことごとく腹の赤い毒蛇である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵に対してこの無数の毒蛇は、素早く一様に鎌首をもたげ、しゆつしゆつと気味悪い音を立てて手向ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔦と二人が、毒蛇になって、可愛いお妙さんを守護する覚悟よ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を呪って、人を詛って、貴方こそ、その毒蛇です。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "李花は猛獣に手を取られ、毒蛇に膚を絡はれて、恐怖の念もあらざるまで、遊魂半ば天に朝して、夢現の境にさまよひながらも、神崎を一目見るより、やせたる頬をさとあかめつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を食うて生きているのじゃ」と、問うたので、度肝を抜いてくれようと、蝮蛇を食うている旨答えると、「日の下にあって、最も聰明にして怖しき毒蛇をくらうとは、近頃珍妙じゃ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのお城のぐるりには毒蛇と竜が一ぱいいて、そばへ来るものをみんな殺してしまいます。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
