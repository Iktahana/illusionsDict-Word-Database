          "literary": [
            {
              "text": "同居人は我が動天の表情に微笑む。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで　ヒットが　一つ　でれば、どうてんと　なるのです。",
              "citation": {
                "source": "はつゆめ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "防空壕の水ぜめでつかれはてた二十面相は、心がどうてんして、そこへ気がつかなかったのです。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
