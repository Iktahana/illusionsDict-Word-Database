[
  {
    "uuid": "971af28b-30f9-575a-a892-e233db7bb379",
    "entry": "何処も",
    "reading": {
      "primary": "どこも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接続詞"
      ],
