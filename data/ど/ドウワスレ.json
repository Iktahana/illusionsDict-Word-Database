          "literary": [
            {
              "text": "年をとったのでついどう忘れをしてしまって。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに昔は最も通俗の日本語であったのを、吾々がとんとどう忘れをしているものがあるかも知れない。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさ、そちらに行くのだったか、水曜だか急にどう忘れして。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいさ」と私は自分に云った、「そのうちに忘れてしまうだろう」　誰がどう忘れるのか。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにをどれだけ記憶し、なにをどう忘れ、なにをいつ、なぜ、思い出すのか」「ほんとにそうなるかどうか」「やってみるほかない」　浴槽に水が満ちるまで、ふたりは洗面台の前にいた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
