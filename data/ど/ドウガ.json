[
  {
    "uuid": "59e4fffd-3822-599c-abac-d71681848a20",
    "entry": "動画",
    "reading": {
      "primary": "どうが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "video (esp. digital)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同様に絵や写真、動画、音などいろいろな形の情報も、今はすべてデジタルに変換できる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでなら、絵は紙やキャンバスの上、写真は印画紙、動画はフィルムやビデオテープ、音はレコードやＣＤと、それぞれ専用の〈器〉におさめられていた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大容量の必要な、動画にも対応できる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "動画の再生に加え、レーザーディスクなら静止画の表示も可能です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに、動画も組み込めるようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラウン管に比べれば、動画の表示にもたつきを感じさせ、めりはりを欠く印象のある液晶ですが、その分、目にはまったくといっていいほど圧迫感を与えないのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイパーカードのマルチメディア機能を生かせば、音や動画を組み込むという、新しい特徴も出せます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがては、動画を組み込むこともできるだろう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし単に文字と文字の結び付けに留まらず、画像、音声、QuickTime による動画など、様々な形の情報とのリンクが可能なハイパーカードを利用したことで、Expanded Book の注釈機能はマルチメディア対応となった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一九九二年一月になって、動画をマックで扱うクイックタイムという技術が登場してくると、レーザーディスクの存在意義はまた一段と薄れました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子本に、動画を入れたくなったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロッピーディスクの五百倍近い容量を持つＣＤ―ＲＯＭが使えるとなると、電子出版物でも動画や音にころうという意識が強まりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字だけを扱っていた段階から写真や絵に手を出して、「グラフィックスとはなんと容量を食うものか」と驚いていたところが、動画となると開いた口がふさがらないほどの情報量大爆発に直面させられます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえフロッピーディスクが常識のあいだは、動画を入れたいなどとははなから考えもしません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こった動画や音が使えるようになると、電子出版物のほとんどは、こうしたマルチメディアの特長をアピールするようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私自身も、ごく自然に「動画を組み込もう」と思うようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品の後から出す以上、動画の面でも工夫しなくては恥ずかしいと思うようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "動画に関しても、本文の目途が見えた段階で家庭用の８ミリビデオを買ってきて、操作の練習から始めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの五百八十メガバイトを、動画が占めています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらためて動画とは、なんと情報量を食うものかと呆れます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子本においても、質の高い動画を前面に押し出した作品が登場してくることは間違いありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ電子出版を業とする人たちは、動画を駆使して意匠を凝らす圧力を強く受け続けるはずです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身は動画の編集にかかりきりとなってしまい、β版をなだめながらの制作作業は、ボイジャージャパンの野口英司さんが全部背負い込んでくれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＷＷＷではさらに物や情報を売ろうとする試みが始まり、横並びの激しい競争の中で、音や動画まで送ろうとする工夫が続々と試みられました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高価な上に保守にも金を食い、そのくせ大した意味のない、動画やステレオ音声や、アイコンとマウスのインターフェイスの化け物ばかりが幅を利かせるようになった」と、締め出しはハートを嘆かせます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶版になった自分の本を仕立て直すところから始め、動画や音、インターネットへのリンクを組み込むといった、新しい工夫にも手を染めた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで仕入れてきたところによると、マルチメディアというのは音や動画までコンピューターで扱うぞという、気合いのようなものらしい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューター上でもっぱら文字だけを扱ってきた人間は、グラフィックスに手を染めてメモリの食われ方に度肝を抜かれ、音を扱って腰を抜かし、動画に手を出して金玉を縮み上がらせる仕掛けになっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした音や動画を扱っていくにあたっては、限りあるメモリの中でやり繰りするためにデータをどう圧縮し、それをどう伸張して再生するかが大きなポイントとなる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはやＮＥＷＳの立ち上げによってコンピューター市場への参入を果たしたソニーは、音や動画と言った新しい世界の開拓にあたっては、断固としてリーダーシップを取りにくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
