[
  {
    "uuid": "9e54f361-288f-594e-9ed3-7180c00b6aeb",
    "entry": "土壌",
    "reading": {
      "primary": "どじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "soil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "割合肥沃な土壌を作っています。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土壌が浅くて少し根をのばすとすぐ岩石でしょう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで土壌のほうでも説明します。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また穀物の生長に及ぼす、光、熱、電気等の影響とか、土壌の物質的性質とかいう問題でも、一つとして物理学の応用を待たぬものはない。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳説すれば、既に在る一切の物を根本からくつがへして、新しき最初の土壌を地に盛りあげねばならなかつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよや眠れる、くらき土壌にいきものは、懺悔の家をぞ建てそめし。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎のあぜみちに坐つてゐると、おほなみのやうな土壌の重みが、わたしの心をくらくする、土壌のくさつたにほひが私の皮膚をくろずませる、冬枯れのさびしい自然が私の生活をくるしくする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずまた火山の噴出は植物界を脅かす土壌の老朽に対して回春の効果をもたらすものとも考えられるのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また根の周囲の土壌の質や水分供給の差異によるとも思われなかった。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂壌かなたに受くるもの、　　多くは酸えず燐多く洪積台の埴土壌土と、　　　　植物群おのづとわかたれぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "噴火｜係の職をはがれ、その火山｜灰の土壌を耕す。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には大洋の水量の恒久と関係して蒸発や土壌の滲透性が説かれている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この氷河が消失して、従って新疆地方に灌漑する川々の水量が少なくなり、そのために土壌がかわき上がって今のような不毛の地になったらしい。",
              "citation": {
                "source": "ロプ・ノールその他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ、土壌の力学に関連してだいぶこの方面が理論的にも実験的にも発達して来たようではあるが、それはしかしほとんど皆静力学的のものであって、「粉体の運動」に関する研究は皆無と言っても過言でない。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "割合｜肥沃な土壌を作ってゐます。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土壌が浅くて少し根をのばすとすぐ岩石でせう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで土壌の方でも説明します。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの種子の生命は土壌と肥料その他唯物的の援助がなければ、一つの植物に成育することができないけれども、そうだからといって、その種子の生命は、それが置かれた環境より価値的に見て劣ったものだということができないのと同じことだ。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが資本主義の経済生活は、漸次に種子をその土壌から切り放すような傾向を馴致した。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "品種や土壌によりますがなあ、さうですなあ、陸稲一反歩となるというと、可成いろいろですがなあ、その塩水撰したやつとしないやつでもちがいますがなあ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」爾薩待「ははあ、塩水撰した陸稲の種子と、土壌や肥料にもよりますがなあ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王｜弁疏する能わざるところありけん、佯りて狂となり、号呼疾走して、市中の民家に酒食を奪い、乱語妄言、人を驚かして省みず、或は土壌に臥して、時を経れど覚めず、全く常を失えるものゝ如し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのモルモン教徒に比べても、大きさ、土壌の豊かさともに申し分ない土地だった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒野でもこのあたりは警部も言うように土壌が極めて固く乾燥している。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれに加えて時々、オゾンを発生する波の激しい海岸とか、または気温の激変のない海辺近くとか、または大気の湿気や暑熱の無い高燥の地、ないしは砂地土壌の土地とかであるならば、いよいよその人に物質的利益を供給する。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "マメ科植物が連作を嫌うのは、その土壌の養分を吸収し尽すからであるか、或いはその植物の発育に必要なバクテリヤ類の欠乏に基づくのか知らないが、何れにしても内的要求が存在して、そして新地に身を置きたがるのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "アサガオの色は土壌のアルカリ分酸分の多少によって異なって来る。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時にこの動物画の描き手にふさはしい、素朴な、朴訥な、田舎めいた、野趣に富んだ、動きのにぶい、社交下手な、土壌臭い、内省的な華楊といふ作家の人柄といふものを、あの作品の限りで想ひ出されて来るであらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "供物われらは我が友を、模糊とした祭神をわが傍にはつきりと観察し批判し、脆い古器物はそのふるさとへ、土壌へ還し新しい鉄をもつて新しい精神の神殿をつくり新しい信仰と延長しわれらの美とし、イリュジョンとし海、山、の衰退に再び春を呼ぶ。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて四郎と二人で用意しておいた――すなわち田溝で捕えておいたどじょうを鉤につけて、家を西へ出るとすぐある田のここかしこにまきました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
