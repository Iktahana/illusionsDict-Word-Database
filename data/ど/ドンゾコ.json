    },
    "definitions": [
      {
        "index": 1,
        "gloss": "very bottom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こうして被告を絶望のどん底におし込んでおかないと、あとの薬が利かない。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大都市の冬に特有な薄い夜霧のどん底に溢れ漲る五彩の照明の交錯の中をただ夢のような心持で走っていると、これが自分の現在住んでいる東京の中とは思えなくなって、どこかまるで知らぬ異郷の夜の街をただ一人こうして行方も知らず走っているような気がして来た。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のどん底から山の下の平野の空へ向って鉄路が上向きに登っているから、恰度大砲の中から打出されたような心持がして面白い。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると亀はもうとても追付く望みはないとばかりやけくそになって、呑めや唄えで下界のどん底に止まる。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには深い深い絶望の嗟嘆と、人間の心のどん底からにじみ出た恐ろしい深酷なセンチメンタリズムとがある。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の陰鬱な思想の仮装舞踊、光線が性的魅力にかくれて、イサックはロシア女の巨大な腰のまわりに赤い旗を立て、陳子文は東洋人らしいどん底を日本女に見出すのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今の上海投機の気まぐれで、銀塊相場を有史以来の崩壊に導いた、その余波のためにこの輸出綿花事務所は不況のどん底にいた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "北浜界隈も、支那財界の大混乱のために、対支商談は不況のどん底に陥ってしまった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば或る時代ドストイェフスキイは貧困のどん底にあつた。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その層の一番どん底を潜って喘ぎ喘ぎ北進する汽車が横川駅を通過して碓氷峠の第一トンネルにかかるころには、もうこの異常高温層の表面近く浮かみ上がって、乗客はそろそろ海抜五百メートルの空気を皮膚に鼻にまた唇に感じはじめる。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんおしまいの場面で、淪落のどん底に落ちた女が昔の友に救われてその下宿に落ち着き、そこで一｜皿の粥をむさぼり食った後に椅子に凭ってこんこんとして眠る、その顔が長い間の辛酸でこちこちに固まった顔である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は、いや、いまの人間は、どん底に落ちても、丸裸になっても、煙草を吸わなければならぬように出来ているのだろうね。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですからもし、お幸を連れて逃げでもすれば、行く先どんな苦労をするかも知れず、それこそ女難のどん底に落ちてしまうと、一念こうなりましてはかけおちもできなくなったのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明のどん底、東ロンドンの娼家の戸口から、意気でデスペラドのマッキー・メッサーが出てくる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して暫くしてから懺悔をする人の樣に少し下を向いて、「つまり僕は心のどん底が臆病なんですよ」とつぶやく樣に云つたが、ふツと擧げた其の面は見違へる樣に快濶になつて居る。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみのどん底にいるんだぞ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうしてお末は押し黙つて居る中に、ふつと腹のどん底から悲しくなつて来た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年人の棲まない妖怪邸の天井裏にも、ちょっとあるまいと思う陰惨とした、どん底に――何と、一体白身の女神、別嬪の姉さんが、舞台の礫の時より、研いだようになお冴えて、唇に緋桃を含んで立っていた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯うなるからは寧そのこと、どん底まで真直に降りて行って、彼のお杉の安否を確めた方が優かも知れぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてどん底まで辿り着くと、果して其処にお杉の死骸が倒れている。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "必然性は人間性のどん底にある。",
              "citation": {
                "source": "最近の感想",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」僕は絶望のどん底に叩き落とされて、目の前が真暗になった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳優として舞台に立つこともかなえられず、持って生れた美声を頼りに志望した声楽家にもなることができないままに、いくどか絶望のどん底におちいった。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、私の力を試してみよう」と、壓しつけられた曇天の日に、悲觀の沈みきつたどん底からさへも、人人は尚｜健氣に立ち上る。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつとそれをみつめて居るときに、私は胸のどん底から込みあげてくるところの、なんとも言ひやうのない恐ろしい哀傷をかんずる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "墮落のどん底にもがいて居る人間、どんな宗教でもどんな思想でも到底救ふことの出來ない私といふ不幸な奴を、光と幸福に導いて下さる唯一の恩人であり、聖母であるのだ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してまつくらな焦熱地獄のどん底に絶望的の悶絶をつづけながら、しかも尚、新らしい救ひをもとめようとしてもがきあがいてゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言いようのない憂鬱が、しばしば絶望のどん底から感じられた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お説教が彼の要求のどんぞこを突いたので、彼は悔と光明と法悦を心から感じた為でもあらうか。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、あくる日、運動場に出ずれば、蒼き鬼、黒い熊、さながら地獄、ここは、かの、どんぞこの、脳病院に非ずや。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
