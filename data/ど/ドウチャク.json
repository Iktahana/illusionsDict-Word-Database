[
  {
    "uuid": "034ddf02-cb42-54a2-9fdc-1c1075ac1a98",
    "entry": "撞着",
    "reading": {
      "primary": "どうちゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
