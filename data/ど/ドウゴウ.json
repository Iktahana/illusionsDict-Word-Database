    "definitions": [
      {
        "index": 1,
        "gloss": "monk's self-chosen pseudonym",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "至道は河野の道号であるのは云うまでもない。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此中には道号と名乗との混同もあり、文字の錯誤もあるであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒は道号に蘭※等の字を用ゐたので、特に蘭草のために多く詞を費すことを厭はなかつたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし此三人の下には各道号が註してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "安中侯節山板倉勝明撰の墓碑銘に、忠次郎の道号として、豊洲、花亭、醒翁、詩癡、又｜括嚢道人が挙げてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に道号を求めて帰空と命ぜられ、其文字を忌んで菊塢に作つたのだと云ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」所謂改名は道号を以て通称としようとしたのであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなん、この片田舎には過ぎた童塾（寺小屋）の先生、智多星の呉用で、道号｜加亮、あざ名が学究。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お騒がせして申しわけないが、拙者は公孫勝、道号を一清と呼ばるる者。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽斎というのは、細川藤孝の道号である。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "また道号を水鏡先生と申されます。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ああさては――これが司馬徽、道号を水鏡先生という人か。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新たに、玄徳の軍師となった孔明とは、そも、どんな人物か」「諸葛亮、字は孔明、また道号を臥龍先生と称して、上は天文に通じ、下は地理民情をよくさとり、六韜をそらんじ、三略を胸にたたみ、神算鬼謀、実に、世のつねの学徒や兵家ではありません」「其方と較べれば……？",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世々｜襄陽の名望家で、※統、字は士元、道号を鳳雛先生ともいう者ですが」「おお、鳳雛先生か。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、終南山の隠居、道号を夢梅という翁でござる」　容も凡ではない。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わが道号は鳳雛という。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは、魏王曹操とは、同郷の友で、左慈、字を玄放といい、道号は、烏角先生とも呼ばれておる。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
