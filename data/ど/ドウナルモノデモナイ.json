        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "如何に簡素清冷に御暮しになったとて、三千石ではどうなるものでもない。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうなるものでもないんだから、早く影をくらましたが、四日市で煩って、女房さん。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　20　過去ったことはどうなるものでもない。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをいつて天をうらんでをつたとて、どうなるものでもないぞや。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへに言つたつてどうなるものでもない。",
              "citation": {
                "source": "ダマスカスの賢者",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすうす気付いてはいたらしかったが、さて気が付いた所で、どうなるものでもない。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ったところで、どうなるものでもない。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい捕え得たところで、どうなるものでもないのであるが、それでも夢中になって追いあるく。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい捕え得たところでどうなるものでもないのであるが、それでも夢中になって追いあるく。",
              "citation": {
                "source": "薬前薬後",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が觀念的に否定してみたところでさうした存在がどうなるものでもない。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一プリンス伊藤を斃したところで、日本のジンゴイズムはどうなるものでもない。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯様な、デリケートなことは、仮令一日一晩、私が泣き明したとて、一時に、どうなるものでもない。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "井生君から貰つてきた改造と中央公論とを読んで、いろ／＼の事を考へないではゐられなかつた、殊にその一つのものと転換時代とはその熱力と意気とで私をうつた、私は今更のやうに私の生活について、存在の意義について考へた、今更どうなるものでもないけれど。",
              "citation": {
                "source": "行乞記",
                "author": "室積行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうなるものでもないのだ。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが飛びこんだだけでどうなるものでもない。",
              "citation": {
                "source": "故郷",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大嫌ひであつたところで、勿論どうなるものでもない。",
              "citation": {
                "source": "書けない原稿",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪趣味や無教養というものはフンジバッて、牢屋へ投げこんでも、どうなるものでもない。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう薬をあげたところで、どうなるものでもない。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "声の問題なんかは、特にいま気がついたからといつて、すぐあすからどうなるものでもないが、……まあ、これは、大事なことが案外軽くみられ、注意がお留守になつている一例にすぎません。",
              "citation": {
                "source": "俳優と現代人の生活（対話５）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "このせまい艇内では、どうなるものでもない。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "デーヴィス青年の新世界国人運動は、日本人にはモッケの幸い、というところであるが、どっこい、国籍だけ新世界国人になったところで、現実が伴わなければ、どうなるものでもない。",
              "citation": {
                "source": "インテリの感傷",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "搾取階級がなくなろうと、なくなるまいと、貿易に依存せずに、日本がどうなるものでもない。",
              "citation": {
                "source": "インテリの感傷",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、要するに、こういう病気というものは、心理を解いてみたって、どうなるものでもない。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、お父さまのほかに……、それが、娘のころは、たゞもう、夢中でさう思つてゐたのだけれど、お父さまのところへ来てからといふもの、たとへさういふひとが現れても、もうどうなるものでもないといふ、暗いあきらめが先にたつて……。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チビチビ江戸の金を盗んだところで、それがどうなるものでもない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に大運が降ってわいてくれた、とほくそえみ、更に殺人の証拠を握るべく、努力しようと思ったが、これは素人が外部からのぞいただけでは、とてもどうなるものでもない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "正二郎はいささか胸つぶれる思いであったが、お久美には今はメクラの連れ添う男がいて、小さい子供が五人も生れているといえば、今さら名乗りでて、どうなるものでもない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、そんなことを考えてみても、どうなるものでもない、と思われて来る。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうなるものでもない。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
