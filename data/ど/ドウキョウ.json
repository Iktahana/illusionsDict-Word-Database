[
  {
    "uuid": "b58dc2a4-2c85-5429-bf97-eed94591b999",
    "entry": "同郷",
    "reading": {
      "primary": "どうきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
