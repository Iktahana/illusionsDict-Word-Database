    "definitions": [
      {
        "index": 1,
        "gloss": "that year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "訃報を受取ることも、さう珍しいことでもないが、同年配の人の訃報を受取ることはまことに珍しい。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ星太宰治　自分と同年同月同日に生れたひとに對して、無關心で居られるものであらうか。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで四十になる俺と同年配ででもあるような、口の利き方をしやがる。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後に気を付けて見ると同年輩の友人の中の誰彼の額やこめかみにも、三尺以上｜距れていてもよく見えるほどの白髪を発見した。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほぼ同年頃の吾等の子供等と比べると眉宇の間にどことなしに浮世の波の反映らしいものがある。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初にやった実験は、電流計の磁針が交流でふれることに関するものであって、その結果は同年の British Association で報告している。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち「竹とその哀傷」「雲雀料理」最も古く、「悲しい月夜」之に次ぎ、「くさつた蛤」「さびしい情慾」等は大抵同年代の作である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊濁点付きの二倍の踊り字は「／″＼」-------------------------------------------------------　　　　　　一　内地へ帰還する同年兵達を見送って、停車場から帰って来ると、二人は兵舎の寝台に横たわって、久しくものを言わずに溜息をついていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に、敦賀から汽船に乗って来た同年兵は百人あまりだった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年兵達は、既に内地へ帰ってから、何をするか、入営前にいた娘は今頃どうしているだろう？",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年兵は二人だけであった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰還した同年兵は、今頃、敦賀へついているだろうか。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務室から出ることを許されて、兵舎へ行くと、同年兵達は、口々にぶつ／＼こぼしていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの同年兵達が、よそ／＼しい疑うような眼をして、兵舎へ這入って来た時、彼は始めて自分があの鮮人から贋造紙幣を受取っていやしなかったか、そのことを試されているのに、気づいた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷した同年兵たちの傷口は、彼が見るたびによくなっていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗本は、負傷した同年兵たちを気の毒がる、そういう時期をいつか通りすぎてしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春月と同年の生れで春月より三年早く死んだ芥川龍之介は、、私くらいの年恰好の者には文学の上でも年齢の上でもはるかに高いところにあると思われていた。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知っている青年達は中隊の班内で寝台を並べてねる同年兵たちに、そのことを噛みくだいて分るように語らねばならぬ、武器の使用方法を習って、その武器を誰れに対して用いるか、そのことについてほかの分かっていない同年兵たちに語らねばならぬ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街を歩いていると彼と同年くらいのロシアの青年たちの暗い影がちっともない顔を見てそう思うのだ。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年兵が悉く、ふさぎこみ、疲憊していた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "炊事場の入口へ同年兵が出てきて、それを見て笑っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一番手近の、グドコーフの家から、三四人同年兵が出て行った。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃同年輩の中学生で喫煙するのはちっとも珍しくなかったし、それに父は非常な愛煙家であったから両親の許可を得るには何の困難もなかった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年、文藝春秋に發表した。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年、純文藝册子、「文體」に二囘にわけて發表した。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皮膚と心」と同年の作である。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、一年半ばかりのうちに彼は、ロシア人を殺し、ついにはまた自分も殺された幾人かの同年兵を目撃していた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍には美しい妻が、――内地に残っている同年の男は、美しくって気に入った女を、さきに選び取る特権を持っているのだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、偶然にも、アンリ・バルビュスの「クラルテ」と同年（一九一九年）に発表された。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
