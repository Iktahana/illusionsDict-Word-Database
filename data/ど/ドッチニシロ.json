        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「これゃ、どっちにしろ戦争だ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、どっちにしろ、これゃ戦争にならずにゃいないぞ……」そして、彼は考えた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ見つかれば殺されるか、裸体に引きむかれるかだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その往か復か、どっちにしろ切符の表に、片仮名の（サ）の字が一字、何か書いてあると思いますか。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ……それはどっちにしろ……その木曾へ、木曾へのきっかけに出た話なんですから、私たちも酔ってはいるし、それがあとの贄川だか、峠を越した先の藪原、福島、上松のあたりだか、よくは訊かなかったけれども、その芸妓が、客と一所に、鶫あみを掛けに木曾へ行ったという話をしたんです。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ可恐しい、早くそこを通抜けよう。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どっちにしろ、友禅の（染）に対する（糸）なんだろう。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどっちにしろ、顔容は判然今も覚えている。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろわたしの腸に苦酸く浸み込む。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっちにしろ、いままでだって、放送部は、校舎でしか放送してないんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ、彼は好きなようにやるんだから」　長田は鏡を開いて、バイタリスをとりだし、キャップをあけながら、こんどは慶一を見てこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大丈夫、どっちにしろ、高志が相手じゃ、こっちが負けるだけだから」　令子はまたふりかえり、かすかにほほえんだが、歩みはとめなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっちにしろ、あのハモンドじゃ、ウィンウッドみたいな音は出ないって」「そうなの？",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どっちにしろ、令子が出ていかなくちゃならないなら、せめて、夏のあいだは楽しくやろうと思ってたんだ」　高志は、小さく首をふった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、どっちにしろ、もう、あんまりここにはいたくないんだ」　はぎとった紙を見なおし、高志はそれをていねいにふたつに折った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ、もうカビが生えて、聴けたもんじゃないだろう」「さてと。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ、道を知らない」「交番できくとか、タバコ屋できくとか、おまえだって、それくらいはできるだろうが」「おれ、浅井って苗字しか知らないぜ」「そういえば、そうだな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま、どっちにしろ、つまんねえ苗字だ」「つまんないことでも、ナゾとなると、興味がわくけどさ」「なら、楽しみは最後までとっておけ」「ひとつだけ教えてくれないか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ、政治への傾斜とか、ギター小僧の天下とか、洗練や完成度が重んじられたり、ただのダンスビートになったり、さんざんだ」　足を手すりの下の桟にのせる高志のしぐさが、慶一の記憶を刺激する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ彼等の来航する日は、日一日と近づきつつあるのである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ、絶対にこっちから襲って行くみちのない以上、全く老人のいうとおり、運命を信じ且つ祈りつつ、暫らく待ってみるよりほか何らの方法もないということになる。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりそれは落したものか、それとも盗まれたものか分らない」「どっちにしろ、市長の責任は遁れられぬ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろごく小さい室だ。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろかなり作られたことには変わりはないが、思い出話の信憑性はだいたいこの程度のものである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、どっちにしろ、××○○会社の内部ではあっちこっち働いている課の違う女事務員達の間に、廻状をまわすだけが、一仕事だった。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっちにしろ楽な路じゃありませんぜ、いつどこでどうなるかも判ったものでもありません、我慢出来るだけ我慢することだ、苦労はお互いというものだ」　急がずあせらず、草に埋もれて堂々と進むのであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、ともかく奥様は、大もてね」「それで僕が幸せってことになるのかね」「誇よ」「まあいいさ、どっちにしろ。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃア敵をふやすようなもので、こけ猿の茶壺を種に、司馬の道場へ加勢するか、あの伊賀の連中へ与するか、どっちにしろ、ここでぼろい儲けをしようとたくらんでいる与の公にとっては、大痛事。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ、源三郎としては今の場合、一難去ったわけですから、その細長い、蒼白い顔をニヤッと笑わせて、のこのこ床の間からおりてきた。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
