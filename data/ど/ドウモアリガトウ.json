          "literary": [
            {
              "text": "どうも有難うございました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも有難うございます」　二人が頻りに礼をいう声をうしろに聞き流して、半七は早々にそこを立ち去った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、この間はどうも有難うございました」とぼくはほっとして言った。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨晩は妹がとんだ厄介になって、どうも有難う。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう遅うございますから、またこの次に伺います」「そうですか、……それでは、また、お眼にかかります、どうも有難うございました」　女はのこり惜しいような顔をして別れて往った。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど運がいいのう、旦那、どうも有難うごぜえます。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも有難うございます。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも有難う』と、礼をいうのか、忌がらせをいうのか、こんな捨台詞を残して立去った。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私で能ることなら、往っても良いのですが」「それはどうも有難うございます、どうかお願いいたします」「何方ですか」「すぐですが、車を持っておりますから」　老嫗はちょっと背後の方を振返って指をさした。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、私が昨日路で買ってきた餅ですが、私は温かいのを御馳走になりますからあげます、あがってごらんなさい、ちょっと旨いですよ」「そうですか、それは、どうも有難うございます、いただきましょう」　婆さんはその餅を口に持って往った。",
              "citation": {
                "source": "蕎麦餅",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、さよなら」「どうも有難う、お孃さん。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも有難う、」　客は傘を受取つて心持頭をさげるやうにしてから出て行つて、外へ出るとちよつと立ち止まつて傘をぱつとひろげた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初枝「こゝですわ」庄平「どうも有難う（生徒Ａに）有難う（節子に）じゃ、失敬します」庄平、中へ入る。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで、もうすみました、どうも有難うございました」　正義はそのまま玄関へ出た。",
              "citation": {
                "source": "白っぽい洋服",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも有難うございました」と、久兵衛は彼女に礼を云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも有難うございました。",
              "citation": {
                "source": "女流作家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間はどうも有難うございました。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「只今残っておりますのはＰ、Ａ、Ｅ、Ｊ、Ｙ、Ｘ……」「いや、どうも有難う」　記者は安ネクタイを一つ買ってそこを出た。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん、どうも有難う。",
              "citation": {
                "source": "牛を調弄ふ男",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ハ、どうも有難う御座います。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうです」「いやどうも有難う。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "東屋氏は笑いながら、「いやどうも有難う……ではもう、この位でいいだろう。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この間は、どうも有難う」と、敬二はお礼をのべた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」小僧「どうも有難うござい。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」小僧「へえへえ、どうも有難うございます。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも有難うございます」と、松吉の背中から卸された男は礼を云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "『天野君のお手紙はどうも有難う。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お口に合うかどうかわかりませんが」「それは御厚意をどうもありがとう」　村上は山崎の友情を言葉でよりも心で深く感謝している様子だった。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしてから敏子は主人に「あ、松葉がれいをどうもありがとうございました」といった。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもありがとうございました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
