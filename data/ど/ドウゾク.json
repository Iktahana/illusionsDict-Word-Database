      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "same family (race, tribe)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その自動車は村の街道を通る同族のなかでも一種目だった特徴で自分を語っていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日に十里を楽々と走破しうる健脚を有し、獅子をも斃す白光鋭利の牙を持ちながら、懶惰無頼の腐りはてたいやしい根性をはばからず発揮し、一片の矜持なく、てもなく人間界に屈服し、隷属し、同族互いに敵視して、顔つきあわせると吠えあい、噛みあい、もって人間の御機嫌をとり結ぼうと努めている。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "サタンと天使が同族であるというような事は、危険思想である。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その児三郎｜年紀十七、才名同族を圧して、後来多望の麟麟児なり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、同族結婚などを頓着しているのでは無い。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の体躯が小児のように小さいのは、同族結婚や野蛮生活に因て身体の発育が衰えた為である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは彼を同族の公敵と認めた。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊商はみな同族だった。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、左京之進の同族比江山親興であった。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来織田氏の一族は屋張一帯に拡がって居て各々割拠して居たのだが、信長清須の主家織田氏を凌ぐ勢であったので、城主織田彦五郎は、斯波義元を奉じて、同族松葉城主織田伊賀守、深田城主織田左衛門｜尉等と通じて一挙に信長を滅そうとした。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は皆同族の叛乱であるが、この外に東隣今川氏の部将との交渉がある。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、中島商相を弾劾した菊池中将（九州の菊池神社を中心として、菊池同族会なるものあり、中将はその会長である。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その宰相の家には宣揚と云う独り児の秀才があったが、それが十八歳になると父の宰相は、同族の両班の家から一人の女を見つけて来てそれを我が児の嫁にした。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくそれらの五穀と同じ先祖から出た同族であろうと想像される。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪事には強い同族的類似性があってね、一〇〇〇の事件の詳細を自家薬籠中のものにして、一〇〇一番目の事件が解けないとすれば、それこそ奇妙な話。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると其同族の聲のみが空間を支配して居可き筈だと思つて居る蛙は、其囀る聲を壓し去らうとして互の身體を飛び越え飛び越え鳴き立てるので小勢な雲雀はすつとおりて麥や芒の根に潜んで畢ふ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "同族の肌は、この小さな場所に寄り添ふ。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "後子珍と同族で、同地生まれの王仲祥という人来合せ、まず先生に謁し、次ぎに子珍の宿に止まり、李玄石を見、翌日別れに臨み、子珍に、汝の友玄石は鬼だ、生きた人でないと告げると、子珍、玄石はこれ上聖の聖で、経書該博ならざるなく、辺先生すらこれを推歎す、何ぞこれを人でないと言うべきと答えた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "にげて、同族なる岩槻の太田三樂齋に據り、共に里見義弘をかつぎて、こゝに國府臺合戰を起しける也。",
              "citation": {
                "source": "國府臺",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も、私はウラスマルのすぐれた同族サーキヤムニの非常に珍らしい逸話の続きを、もう一度聞きたいと云ふ望みにかられて、再びあの無花果の立つてゐる庭へと足を向けたのである。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は兎も角、其の同族と考へる者と合する爲に、古來の傳説を言ひ立てゝ歸服して來たのである。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来木地師というものは、最も下等な漂泊民で、木地を目つけて山から山を、獣のように渡り歩き、採った木地類は漆器屋に売り、同族結婚、姦通、自堕落、無道徳というのが普通だのに！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カピューレット長者を先に、ヂュリエット及び同族の者多勢一｜方より出で、他方より出で來る賓客の男女及びロミオ、マーキューシオー等假裝者の一｜群を迎ふる。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（同族の一老人に對ひて）いや、叔父御、まま腰を下しめされ、貴下も予も最早舞踏時代を過してしまうた。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われわれの同族が、この先に集っているから、君をそこへ案内したい。",
              "citation": {
                "source": "最小人間の怪",
                "author": "――人類のあとを継ぐもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして種族中で一番知恵のある人間がいわゆる「医術者」（Medizinmann）となってこの経験を利用し、それよって同族の人間を引回していた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、同族は單に精神的つながりのみを殘すこととなるであろう。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "この動物の血で塗りかためた、貴様等同族の髪毛の鞭が一ふり毎に億の呪いをふり出すか、兆の狂暴を吐出すか後で判ろう。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父権につれて尊重され始めた家系というものがその利害や体面のため、同族の女性をどれほど犠牲にして来たかということは、日本の武家時代のあわれな物語の到る所に現れている。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうぞくれぐれもお気をおつけ遊ばして……。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
