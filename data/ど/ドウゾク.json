[
  {
    "uuid": "6505a957-c2a8-5205-b6ad-0bbaf9b47517",
    "entry": "同族",
    "reading": {
      "primary": "どうぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
