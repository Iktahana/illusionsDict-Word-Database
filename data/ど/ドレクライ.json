        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんならこのレンズの大きさがどれ位あるかまた〔〕その中のさまざまの星についてはもう時間ですからこの次の理科の時間にお話します。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全體お前さんの借といふのは今どれ位あるんだい。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、老人の眼つきと身振りとで、老人が、彼等の様子をさぐりにやってきたと疑っていることや、町に、今、日本兵がどれ位い駐屯しているか二人の口から訊こうとしていることが察しられた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これゃ、この塊で、どれ位な値打だろうか。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならこのレンズの大きさがどれ位あるかまたその中のさまざまの星についてはもう時間ですからこの次の理科の時間にお話します。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならこのレンズの大きさがどれ位あるか、またその中のさまざまの星についてはもう時間ですから、この次の理科の時間にお話します。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ど、どれ位飲んだ」　予て大人でも十分の二グラム飲めば命はないと聞かされて居るので、無益とは知りながらかう聞いて見た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『どれ位ご支度なさいました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "税務署長の考ではうんと悪口を云ってどれ位赤くなって怒る人があるかを見て大体その村の濁密の数を勘定しようと云ふのでした。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハンムンムンムンムン・ムムネの市まで、もうどれ位ありましょうか。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの処ではどれ位にします。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」爾薩待「五畝歩とするとどれ位でいいかなあ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体どれ位でございましょう。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰に手をひっぱられたのか、どこをどう通ったのか、どれ位時が経ったのか、やがてまるで端唄をうたうような意気な調子の高砂やの声に初てはっと眼覚める想いで、声の主をみた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮男は我儘故、女の苦心が分らぬ、蔭で泣いたことがどれ位あるかというのだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ位持つでしょうか」「そうだな。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様はおれがどれ位強いか知ってるか」「知らない。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人も僕の潔白を認めて下さると弁護士さんから聞きました、どれ位心強いかわかりません。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その嬰児の死んだ噂の消えた時分のこと、それは事件の起った時からどれ位時間の隔たりがあったか判らないが、某日の夕方、私は二三人の少年仲間とすぐ近くの畳屋と云う家の庭で遊んでいた。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と来たね」「ようよう、うまいうまい貴様、魚屋よりもキリシタンの坊主になれ、どれ位人が助かるか判らん。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の下の方がどれ位大切だか知れない。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問のある人の鼻は高く、人格者の鼻は端正に、無学文盲の鼻はヒシャゲて、悪人の鼻はねじくれていたら、世界の文化はどれ位向上し、人類の生活はどれ位幸福になるか知れませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに今一歩を進めて、すべての男女の鼻が義務教育終了程度、中等学校程度、専門学校程度、学士、博士、大博士程度とそれぞれ高さが違って行く位になったら、世界の文運はどれ位進展するか知れますまい。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は白粉の濃淡や頬紅の掛け引きなんぞでせめて正面から見た感じなりと誤魔化そうと、明け暮れどれ位苦心惨憺しておられるか知れませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽った鼻の表現の価値がどれ位のものであるか、同時に鼻がその人の二重三重の底意までも如何にデリケートな程度にまで写し出すものであるかという事は、今まで挙げました例証で最早充分に御了解出来た事と思います。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても此奴等がみんなおれ位にまでなり得たら、おれもどれ位気が楽になるか知れないがなあ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしのようなわるい児はこのまま散ってしまって、あの女の児が妾の代りになっている方がどれ位みんなのしあわせになるかもしれない。",
              "citation": {
                "source": "白椿",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しそれにしたところで、後で考えてみて、駿府あたりに開府するより、広濶な江戸に清新な気を以て幕府を開いた方が、家康にとってどれ位幸福だったか知れやしないと思う。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お酒がたいへんお好きのようでございますね」「酔っぱらいで困るのです」「どれ位めしあがりますの」「さあ」　飲みだすと一晩中でも飲むので己ながらはっきりした量が云えなかった。",
              "citation": {
                "source": "馬の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑いだすと果しがないけれども、いったい、彼にはどのような音楽理論があるのか、ヴァイオリニストとしてどれくらいの腕前があるのか、作曲家としてはどんなものか、そんなことさえ私には一切わかって居らぬのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
