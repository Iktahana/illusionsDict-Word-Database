[
  {
    "uuid": "6a1e6df5-9962-5079-bd77-d5756e4d484b",
    "entry": "同村",
    "reading": {
      "primary": "どうそん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
