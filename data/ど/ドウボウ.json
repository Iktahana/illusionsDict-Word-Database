    },
    "definitions": [
      {
        "index": 1,
        "gloss": "side of the road",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "道傍、溝の畔に萩みだれ、小さき社の垣根に鶏頭赤きなど、早くも園に入りたる心地す。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芒の蓬々たるあれば萩の道に溢れんとする、さては芙蓉の白き紅なる、紫苑、女郎花、藤袴、釣鐘花、虎の尾、鶏頭、鳳仙花、水引の花さま／″＼に咲き乱れて、径その間に通じ、道傍に何々塚の立つなどあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍に並ぶ柱燈｜人造麝香の広告なりと聞きてはますます嬉しからず。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍の氷店に入ってラムネ一瓶に夜来の渇望も満たしたればこゝに小荷物を預けて楠公祠まで行きたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝はこの椎茸が恐ろしく長くて、露にしめった道傍の草の上を大蛇のようにうねって行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍の崖に輕石の層が見える。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の近代的設備の脚下の道傍に古い石地藏が赤い涎掛けをして、さうして雨曝しになつて小さく鎭座して居るのが奇觀である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖を下りて停車場の方へ行く道傍には清らかな小流が音を立てゝ流れて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある谷を下つた處で、曲りくねつた道路と、其の道傍に榛の木が三四本眞黄に染まつたのを主題にして、稍複雜な地形に起伏する色々の畑地を畫布の中へ取り入れた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍の畑で芋を掘上げている農夫に聞いて、見失った青梅への道を拾い上げることが出来た。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍に小供が五六人集まって何か悪戯をして居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚や鶏は時々隊をはなれて道傍の芝生へそれようとするのを、小さな針金のような鞭でコツコツとつっついては列に追い返している男がいる。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――不思議に窓の空所へ橋に掛つた襖を傳つて、上りざまに屋根へ出て、それから山王樣の山へ逃上つたが、其處も火に追はれて逃るゝ途中、おなじ難に逢つて燒出されたため、道傍に落ちて居た、此の美人を拾つて來たのださうである。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、其の外側の濠に向つた道傍に、やう／＼地のまゝの蓆を得た。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか奈良へ旅した時、歩きくたぶれて、道傍の青草原に、べったり坐ってしまったくらいだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩きながら道傍の豆の葉を、さっと毟りとっても、やはり、この道のここのところで、この葉を毟りとったことがある、と思う。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう道傍の草原に、ペタリと坐ってしまった。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍に立つ柳、石の道陸神、湯槽から出て川に流るる湯の匂ひ、冬の穩かなる日の微かなる風、また野邊の揚雲雀、藺の田に淀む脂などは正に蕪村の詩趣である。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば神田の五軒町あたりは、広い道の両側に柳の並木、日にきらめける鉄条の上をけたたましい電車の嵐、と思つて一寸道傍の店先を覗くと赤く汚れた温い硝子戸を越してお七、吉三の古い錦絵、その隣を乳房をあらはに髪を梳る女、銘は何れも歌麿筆としてある。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍清泉所々に湧く。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "理想の抱負のと威張ってみたところで、所詮己は牛にふみつぶされる道傍の虫けらのごときものにすぎなかったのだ。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍のウカル樹の幹に手を突いて身體を支へ、目を閉ぢた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍の水溜には鰕の泳いでゐるのが見える。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍のウカル樹の幹に手を突いて身体を支え、目を閉じた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍の水溜には鰕の泳いでいるのが見える。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍のウカル樹の幹に手を突いて身体を支へ、目を閉ぢた。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズタズタに切り苛んで、青痰を吐きかけて、道傍に蹴り棄てても見せようものを……」「シッ……お声が……」　二人はそのまま人ごみに紛れて左右に別れた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉｜訛の違った山向うの村で、道傍の知らない小児と遊んだり、祭神のわからない神社の絵馬を眺めまわしたり、溜池に石を投込んだりして、それこそ心の底からルンペン気分になって行くうちに、案内もわからぬ野山の涯で日を暮らして、驚いて帰って来る。",
              "citation": {
                "source": "スランプ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
