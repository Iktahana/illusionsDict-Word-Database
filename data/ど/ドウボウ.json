[
  {
    "uuid": "e5911679-05b2-5a24-a6e3-34f645accad2",
    "entry": "同朋",
    "reading": {
      "primary": "どうぼう",
      "alternatives": [
        "どうほう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "companions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すべてこれらは、私たちの兄弟でありましたから、もう私たちは国と階級、職業とその名とをとわず、ただ一つの大きなビジテリアンの同朋として、「お早う、」と挨拶し「おめでとう、」と答えたのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち私は一仏教徒として我が同朋たるビジテリアンの仏教徒諸氏に一語を寄せたい。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねがわくは先輩諸氏｜愚昧小生の如きをも清き諸氏の集会の中に諸氏の同朋として許したまえ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯を食べながら、澄太さんから清水さんの話を聞く、聞けば聞くほど頭がさがる、そして自分の不甲斐なさを恥ぢる、是非一度は同朋園を訪ねたいと思ふ。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "同朋町の女髪結の所へ往くのである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "意を了して、その頃｜同朋町に店借をしていた長屋に引返して、残りの荷物を纏めたが、自分の本箱やら、机やら、二人｜乗には積み切れないで、引越車をまた一輛。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "数寄屋町、同朋町の芸者やお酌が大勢来た。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同朋町、和泉町、柏木、私は二十四歳になっていた。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同朋園の田中さんから、たくさん薬を送つてきた、ありがたし、さつそく服用する。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは同朋同行によって地上に建設されてゆく仏国にほかならない。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏の行者はたがいに「御同朋御同行」である。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる御同朋御同行主義は浄土真宗の本質的な特徴であり、そして、そこに信者の社会的生活における態度の根本がなければならぬ。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "同朋同行主義は念仏は弥陀廻向のものであるというところにその超越的根拠をもっている。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには我はなくわが弟子もなく、ただ教法のみが人を尊厳ならしめるのであって、互いに「御同朋御同行」として相敬うのである。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる同朋思想は、念仏の行者は同じ縁につながるものであるという意識によって深められるであろう。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま信心を得たものはかかる宿縁をよろこぶべきであり、念仏の行者はかかる宿縁においてつながるものとして原始歴史的自覚において、同朋の意識を深めるのである。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人して申されずば、同朋とともに申すべし。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "この他槍奉行、旗奉行、御蔵奉行、御料人様衆、御小姓衆、御しょう堂様衆、御｜同朋衆、御使者番、御右筆衆、御伽衆、御茶堂衆に至るまで、その数およそ五百人、座を圧して居流れていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田同朋町の銭湯松の湯では、朝から不相変客が多かつた。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田同朋町の銭湯松の湯では、朝から相変らず客が多かった。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "原則である隠者の生活の禁慾主義も、同朋の仲間に入れられたものは、或点まで実行して居たが、外に住む自由な連歌師には、妻も迎へ、髪も短く蓄へた輩もあつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした連衆の中、うまく檀那にとり入つて、同朋から侍分にとり立てられたものもあるが、さうした進退の巧に出来なかつたものは、賤の賤と言ふ位置に落ちて了うた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "と事を分けての話に文治も大に悦んで、帰り掛けに柳橋の同朋町に居るお村の母親お崎｜婆の所へ参りました。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が寺奴の出であらうと言ふ事は、半僧半俗と言ふよりは、形だけは同朋じたてゞあるが、生活は全くの在家以上で、殺生を物ともせなかつた。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "室町御所になつて出来た同朋が、荒事を捨てゝも、多く、社奴・寺奴の方面から出て居たのは、一つの註釈になる。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとつ倉岡元仲の父を倉岡元庵と名乗らせていることであるが、『圓朝全集』第十三巻の鈴木行三（古鶴）氏が『圓朝遺聞』を見よ、「妻子の事」の章に、「圓朝は（中略）不図した事から御徒町の倉岡元庵というお同朋の娘お里との間に一子を挙ぐるような間柄になった」　云々とある。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "その秘密は、永遠の時間の中へ完全に埋没してしまうはずであったが、はからざる機縁によって、驚異すべき調査の主題と、その蔭にひそむ人智に絶した秘境の実相が、さる同朋の口から曝露されたのである。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて親鸞は自身肉食妻帯を体験して、破戒の行業を辞せず、非僧非俗の愚禿と称して、在家法師、俗法師の徒を以て任じ、社会のドン底に沈淪した最下層民たる餌取法師、非人法師の徒をも疎外することなく、いわゆる御同朋御同行として、世間から最も罪業深いものと認められた、かの屠者の輩をまでも済度された。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "成島氏の家はもと同朋であったが、錦江が八代将軍｜吉宗に寵せられて奥儒者に挙げられてから、これを世襲の職となし、伝えて竜州、衡山、東岳、稼堂より確堂に至った。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後に居並んだは一藩の重臣、ご加判衆をはじめとし、城代、側用人、各奉行、用人、大目附け、大番頭、小納戸頭、小姓頭、奥医師同朋さえ居並んでいる。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
