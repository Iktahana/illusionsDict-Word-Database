          "literary": [
            {
              "text": "和尚は夫人を横抱きにして洞房の方へ往こうとした。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月廿一日　晴、申分なし、行程三里、入雲洞房、申分なし。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊女を評定所の給仕として差出したことについて「異本洞房語園」に次の如く記している。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野次郎左衛門百人斬の顛末は、かの「洞房語園」には、ほんの数行、誌されてあるに過ぎない。",
              "citation": {
                "source": "吉原百人斬",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
