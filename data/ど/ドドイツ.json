        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俳句のリズムと都々逸のリズムとが、「いき」の表現に対していかなる関係を有するかは問題として考察することができる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて都々逸を歌い出す。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "お糸さんも細いすきとほつた声で、中音に都々逸や端唄を歌ふ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "と色で纏まる壮佼等、よしこの都々逸唱い連れ、赤城の裏手へ来たりしが、ここにて血の痕｜途断れたり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実の苦痛に泣笑しつつ都々逸でも唄いたくなる。",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの罪人たちよりは一段と高いところに坐らされながら、次郎兵衛は彼の自作の都々逸とも念仏ともつかぬ歌を、あわれなふしで口ずさんでいた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は夜通し飲むんだ」　銀ちゃんも情ない足取りだったが、「――夜が明けて、グッドモーニングと挨拶かわし、盞かわしてグッドバイ……ってとこまで飲むんだ」　都々逸の調子を張り上げながら、執拗に坂野をはなさなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、大島節の歌詞が安来節でも歌えるし、都々逸の文句が相撲甚句にもなるという風です。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は樺太の山奧に入る時、熊よけに、汽船から借りて來た汽笛代用の喇叭を吹いたが、さういふ用意がないので、僕は下手な調子で銅羅聲を張りあげ、清元やら、長唄やら、常磐津から、新内やら、都々逸やらのお浚ひをして歩いた。",
              "citation": {
                "source": "日高十勝の記憶",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "都々逸は下品なものであるが女郎雲助を感動せしむるのは都々逸でなければならない。",
              "citation": {
                "source": "竹の里人〔二〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたが水商売でわては鉱山商売や、水と山とで、なんぞこんな都々逸ないやろか」それで話はきっぱり決った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こらッ、歯型も入れたな」　そう怒りながら、しかしだらしない声を出して少しはやに下り気味の自分が、つくづく情けなくなっていると、マダムは気取った声で、「抓りゃ紫、食いつきゃ紅よ、色で仕上げた……」云々と都々逸であった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "武者絵を描いた柘榴口のなかで都々逸の声は陽気らしくきこえたが、客は四、五人に過ぎなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな流行歌も知っているらしいが、それよりも都々逸というものが一ばんお得意のようである。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおその上、文句入りの都々逸というのがあって、これがまた、ひどいんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに、かれ自身も都々逸の文句入りというところなど、放送したくてたまらないのだろう。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かっぽれには、僕以上に固パンの英語が癇にさわるらしく、小さい声でれいの御自慢の都々逸、『末は博士か大臣か、よしな書生にゃ金が無い』とかいうのを歌ったりして、とにかく、さかんに固パンを牽制しようとあせっている様子であった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の相談役など、じっさい、文句入りの都々逸以上に困ると思った。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋へ帰ったら、まだ講話は始まらず、かっぽれが、ベッドにひっくりかえって、れいの都々逸なるものを歌っていた。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちの芝が人に踏まれても朝露によみがえるとかいう意味の、前にも幾度か聞かされた都々逸であるが、その時だけは、いつものような閉口迷惑を感ぜず、素直に耳傾けて拝聴したのだから奇妙なものだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇八年板ごむの「歴史としての民俗學」第一章などを見ると、今日開明に誇る歐羅巴人の多くの祖先も都々逸御順で、老は棄てられ壯きは殘る風俗で澄して居たらしい。",
              "citation": {
                "source": "棄老傳説に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歌を南方先生が字余り都々逸に訳すると「わが眼ほど耳がきくなら逃げ支度して人に捉られはせぬものを」だ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃故エドウィン・アーノルドが東京に来寓し、種々筆した内に「初め冗談中頃義理よ、今じゃ互いの実と実」てふ都々逸を賞めて訳出した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から名物の湯屋浄瑠璃、湯ぶくれ都々逸のたぐいは、明治以後も絶えなかった。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "義太夫、清元、常磐津、新内、端唄、都々逸、仮声、落語、浪花節、流行唄、大抵の音曲は皆ここで聴くことが出来たが、上手なのは滅多に無いのも昔からのお定まりであった。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "送りましょうか送られましょうか、せめて貴方のお門までというどどいつの文句を、お前はんしりへんのか。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "どどいつが大好きだという元気のいい男だ。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どどいつの様な芸謡の形式が、何の為に派生したのであろうか。",
              "citation": {
                "source": "歌の円寂する時",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どどいつの古い形とも見るべき江戸初期のなげぶしや室町時代の閑吟集の小唄類を見ても、口語律の変化が、歌謡の様式を推移させて行く模様が知れる。",
              "citation": {
                "source": "歌の円寂する時",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこを、やまと（当時、文楽）は、どどいつでやる。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
