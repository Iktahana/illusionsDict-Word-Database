          "literary": [
            {
              "text": "さらに、もうひとり、同学年の秀才と必ず親交を結ばなければならぬ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、山口という同学年生をのぞいては、みなうっすらと髭が生えた顔にも見おぼえがない上級生であり、年長者である。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一人の級は別だが同学年生の山口を、だからぼくは話相手にしようと思った。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
