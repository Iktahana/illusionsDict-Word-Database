        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年は土用丑に鰻を食べる予定を立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "土用丑の日には、スーパーで鰻が飛ぶように売れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "土用丑は、夏の暑さを乗り切るための昔からの習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、こんどの土用丑には子供の虫封じのまじないをここでしてもらいまんねんというのであった。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は土用丑の日、とうとう鰻には縁がなかつた、鰻よりも鮎を食べたいのだが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "土用丑の日を以て、形式にでも、水に浸らねばならなかつた。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
