[
  {
    "uuid": "91a210b4-1b49-58cd-9bd1-faf9f2732924",
    "entry": "動員",
    "reading": {
      "primary": "どういん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
