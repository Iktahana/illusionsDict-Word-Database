    "definitions": [
      {
        "index": 1,
        "gloss": "ramming",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此で以て地面をどん／＼と、胴突きして廻つたのである。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、先ずこれならばと思うものが揃うと、今度は彼が先棒となって、泥運びもすれば胴突きの繩も引張る。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの扇や足の遣ひ方に、たゝら・棒づき――どうづき――或は堂供養の要素が濃厚に見られる様な気がしたのである。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "木やり・石挽き・たゝら唄・どうづき唄。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
