          "standard": [],
          "literary": [
            {
              "text": "その後、同じ二日市で榊屋の隠宅というのに引越した時に、父が私に羊羹を三キレ新聞紙に包んだのをドンゴロス（ズックの事）の革鞄から出してくれた。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝、トラックがドンゴロスの袋を何千とはこんで来て、われわれ健康者は総出で砂嚢をつくり、三個積み上げたものを二列にして、病院の正面海岸に並べたが、波はそれを飛び越したり、洗い流したりする。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に部下の兵隊が便所に行ったところが、天井にしてあるテントがつぶれ、周囲をかこっているバーラップ――日本の兵隊はドンゴロスと呼ぶ。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその男と二人、たたきの上にアンペラを敷き、ドンゴロスの袋をかぶって寝苦しい一夜を明かした。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらためて部屋の中を見回すと、ふとん代わりのドンゴロスの袋、食器に使うゆがんだバケツ……。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            }
          ]
        }
