        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シャルル・ボードレエルは、酒と阿片とアシッシュとに就いて、その藥物學的比較觀察をした後で、酒がいちばん健全であり、毒物的危險性がない上に、意志を強くするといつて推奬してゐる。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがさうした毒物の麻醉を借りずに、もつと自然的な仕方によつて、夢を自由にコントロールすることができるならば、人生はずつと幸福なものに變るであらう。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家人を食った蚊の腹は、あかく透きとおり、私を食った蚊の腹は、くろく澱んで、白紙にこぼれて、かの毒物のにおいがする。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "棘のある毒物の感じである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだ檢出せられざる微量の毒物を、含有してはゐないか。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒物にも、どんな試験でも検出されないものがある。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私に微笑んでみせると、「相当毒物に手を出していますもので。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベラドンナ、阿片、毒物一般に詳しい。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、毒物の講義をしていた教授が、生徒にアルカロイドとか言うものを示しまして。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "オデッサのドルスキィ事件やモンペリエのレテュリエ事件が毒物に詳しい者ならすぐに思い浮かぶだろう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂューク・オブ・ヨーク島で有力家を葬るに、呪師來つて樹葉に唾吐き、數多の毒物と倶に墓穴に投じ死人を詛殺せし者を高聲に詛ひ、一たび去て浴し返つて復た詛ふ。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "強盗殺人犯の脱監密通した令夫人鉄道線路の飛び込自殺××氏の毒物嚥下山林中の強姦未遂。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟾蜍を欧人は大変な毒物とするところから拡げて、すべての悪性動物を制禁して生ずるなからしめたというたんだそうな（チャンバース『日次事纂』二、『フォクロール』五巻四号）。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり蛇や蟾蜍の毒気を雄鶏の生んだ卵が感受して、この大毒物を成すと信じたので、やや似た例は支那説に雉と蛇が交わりて蜃を生む。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に彼は薬学家として、毒物に対する肯定と尊敬とを持っていた。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒物にやられて呼吸中枢が止り、循環器官が停ると、もう一切のものは破壊へむかって展開するにきまっていると、原書で習った生理学の知識を思いうかべて、アーメンと小さい声で言った。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒物を盃に盛って、一と息に飲み下だし、盃がまだ卓子の上に、帰らぬ前に既に呼吸が止っているという彼の青酸｜加里も、実に管々しい毒物には相違なかったけれども、それを実行した先輩も少くないので、独創を尊ぶ喜助の満足を得ることは出来なかった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒物の出所もそれで大抵判ったので、半七は又引っ返して両国へゆくと、宗吉は店さきに水を打っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジギタリス剤、アトロピン、ムスカリン等の猛毒からアドレナリン、カンフル、カフェイン等の薬剤に至るまで心臓に作用する毒物薬物の殆どすべてにわたって、僕は一々の曲線を作り上げたのだ。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルネオに現住するヂヤークと称する土人は長さ七尺、直径五分ばかりの吹管を用ひて毒矢を吹き放ち、アデンの附近に産するある毒物は其の附近に住む、ソマリーと称する蛮族により矢毒として今も使用せられて居る。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して毒に関する迷信は凡そ二種類に大別することが出来、その一は即ち毒物そのものに纏ふ迷信であつて、其の二は即ち毒物ならぬ色々の物質を毒と思つて取り扱ふ迷信である。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　植物性毒と迷信　原始人類に最も喜ばれた毒物は、何れの地方にありても麻酔作用を有するものであつた。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "人参中にはマンドレークの含有するやうな毒物はなく、近時二三の研究家が、そのうちから特殊の成分を取り出したといふが、勿論俗間に信ぜられて居るやうな霊効のある訳ではない。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴の烏も弟をかばふ暇がなく、恋人同志もたびたびひどくぶつつかり合ひます。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雪童子はわざとひどくぶつつかりながらまたそつと云ひました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうこうするうちにチチコフは、馬車が前後左右に揺れて、自分の躯があちこちにひどくぶつかるのに気がついた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さん、本気でぶつたね、さつきよりひどくぶつたね！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなにひどくぶつけられ、やがて頸でも締められたらしく変な喉音が聴えた。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンダスンは私の乗っていたボートを指揮していたが、乗員を取締るどころか、一番ひどくぶつぶつ言った。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして死は、死人に対してよりも瀕死人に対して、いっそうひどくぶつかる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
