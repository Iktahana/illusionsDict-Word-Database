          "literary": [
            {
              "text": "私も少しどぎまぎして、わるかったかな？",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはもうどぎまぎしてまっ赤になってしまひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツはすっかりどぎまぎしてしまいました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は、リザ・リーブスカヤのことを思い出して、どぎまぎして「胸膜炎で施療に来て居るからそれで知っとるんです。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはもうどぎまぎしてまっ赤になってしまいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へいへい」　と、どぎまぎして慌ておれり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その名前を、そっと胸のうちで誦してみて、笠井さんは、どぎまぎした。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめて、しまってから、二人どぎまぎした。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はどぎまぎして了った。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清作はすっかりどぎまぎしましたが、ちょうど夕がたでおなかが空いて、雲が団子のように見えていましたからあわてて、「えっ、今晩は。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハーシュはどぎまぎして云ひました。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニはもうどぎまぎしてまつ赤になつてしまひました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして昨日のことなんか忘れてしまったように、親切に僕の手をひいてどぎまぎしている僕を先生の部屋に連れて行くのです。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡瀬はこの不意撃ちにちょっとどぎまぎしたが、すぐ立ちなおっていかなる機会をも掴もうとした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廻り椽の角の日本座敷、あすこはこの先ともずっとあなたの部屋になるところだから、どうにでも気儘にして寛いで下さい」　私はどぎまぎして良人のいうことの意味はよく酌み取れませんでしたが、良人の気性を充分に知っている私は、夫のそのいたわりを全部善意にうけ取ることが出来ました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "清作はすつかりどぎまぎしましたが、ちやうど夕がたでおなかが空いて、雲が団子のやうに見えてゐましたからあわてて、「えつ、今晩は。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは何といっていいかわからなくてどぎまぎしてしまいました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際私はいつでも困ってるんですよ」　軽便鉄道のシグナレスは、まるでどぎまぎしてうつむきながら低く、「あら、そんなことございませんわ」と言いましたがなにぶん風下でしたから本線のシグナルまで聞こえませんでした。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と牡丹形の肱座を取って突附けられ、平民と見えてどぎまぎしつ、「はッはッお何程で遣わされまする。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けげんな顔して引込むと、また窺いいたる、おその、と一所に笑い出して、二人ばたばたと行って襖際へ……声をきき知る表情にて、衝と出づる欣弥を見るや、どぎまぎして勝手へ引込む。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　君勇はわれにもあらずどぎまぎした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年の方でも、俄かに鼻さきへ突きつけられた美しい娘の顔に気がついて、どぎまぎしながら羞明そうに横を向いた。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　豈夫に螢狩とにも謂へぬから、どぎまぎしてゐると、「何か、また螢を捕へに行くんぢゃな。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "性慾に就いての、あのどぎまぎした、いやらしくめんどうな、思いやりだか自惚れだか、気を引いてみるとか、ひとり角力とか、何が何やら十年一日どころか千年一日の如き陳腐な男女闘争をせずともよかった。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "律子にそう言われて、三浦君は、どぎまぎした。",
              "citation": {
                "source": "律子と貞子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はどぎまぎしながら、やつと口の中で礼を言つた。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥右ヱ門はその眼ざしにでくはすと、われにもあらずどぎまぎしました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、どぎまぎしたのを平次に見られるのは一層やりきれないことなので、ごまかすためにゐたけだかになつて、呶鳴りました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はちょっとどぎまぎして、私の顔を見たが、必ずしも私が不平ではない様子を見て取って、自分も笑いながら、「やあ、御迷惑をかけたもんですなあ……でも、そういう役目も文学をやる方の天職じゃないのですか。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
