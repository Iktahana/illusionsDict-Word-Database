        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔こはドロミット洞窟の〕宮沢賢治こはドロミット洞窟のけ寒く硬き床なるを幾箇の環を嵌められし巨人の白き隻脚ぞかくて十二の十年は事なきさまに燃え過ぐる",
              "citation": {
                "source": "〔こはドロミット洞窟の〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の天性の我がまま気儘も、これに輪をかけて自分を洞窟の仙人にした。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は好んで洞窟に棲んでるのではない。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミネルバの梟は、もはや暗い洞窟から出て、白昼を飛ぶことが出来るだろう。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この若い男は、科野国の獣神であって、福慈の女神により人間に化せしめられつつあるうち病気をしてしまったのでこの洞窟内で療養せしめられているのだといった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつでも、自分だけの暗い洞窟に隱れてゐる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも彼だけの洞窟では壁の裏側に這つてる小蟲や、空氣の濕つぽい臭ひまで、殘る隈なく觸覺してゐる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、虐げられ、苛まれた人間ばかりが集ってくる洞窟のように感じられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、子供らしい笑いが洞窟のような宿舎に響き渡る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆島の西方、女木島という島には、海賊の住家だったらしい洞窟がある。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧妙にできた、かなり広い洞窟であるが、それがいま、オトギバナシの「桃太郎」の鬼が住んでいたところだと云われて、その島をも鬼ガ島と名づけ、遊覧者を引こうがための好奇心をそゝっている。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の洞窟や、部落のなかや、原に八十八の寺や、庵があるのである。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六百尺の、エジプトのスフィンクスの洞窟のような廃坑に、彼女は幽霊のように白い顔で立っていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、巨大な暗黒な洞窟が出来て来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十六畳敷き、二十畳敷きと、鑿岩機で孔を穿ち、ダイナマイトをかけるに従って洞窟は拡がって来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑夫は洞窟の周囲に、だにのように群がりついて作業をつゞけた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」脚の悪い老人は、心配げにカンテラをさし上げて広々とした洞窟の天井を見上げた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラが、洞窟の土の上や、岩の割れ目に点々と散らばって薄暗く燃えていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、洞窟全体は、ちっとも明るくならなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞窟の奥の真暗な横坑にふさぎ込められていた土田は、山を這い渡る途中に、又、第二の落盤でもありやしないか、びく／＼しながら、小さくなって、ころび出て来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　松ツァンの声は、薄暗い洞窟に、悲痛なひゞきを伝えた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、皆な洞窟から出るように云いつけた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三木脚の松ツァンは、ひょっくひょっくそこを通り越して息子がへしがれている洞窟へ這入って行った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下に立って見上げると、深い大きな洞窟のように見える。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これよりして、子の口までの三｜里余は、たゞ天地を綾に貫いた、樹と巌と石と流の洞窟と言つて可い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまたわが国の科学者がおりにふれてはそのいわゆるアカデミックな洞窟をいでて火災現象の基礎科学的研究にも相当の注意を払うことを希望したいと思う次第である。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類がまだ草昧の時代を脱しなかったころ、がんじょうな岩山の洞窟の中に住まっていたとすれば、たいていの地震や暴風でも平気であったろうし、これらの天変によって破壊さるべきなんらの造営物をも持ち合わせなかったのである。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士の吸ふ巻煙草がポツンと赤く見えるだけ、「斯う納まって見ると、我輩もさながら、洞熊か、洞窟住人だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士の吸う巻煙草がポツンと赤く見えるだけ、「斯う納まって見ると、我輩もさながら、洞熊か、洞窟住人だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国の小屋は半永久的に建てたもので、それはひと通り整ってはおりましたが、夜中に手燭一つで見る凄まじさはまた格別で、高い天井はどうくつのようにやみに閉ざされて、灯りの届かぬ土間の隅々も、ちみもうりょうの夜の住家でないとはだれが保証出来るものでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
