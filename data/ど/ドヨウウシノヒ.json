        "examples": {
          "standard": [
            {
              "text": "土用丑の日に鰻を食べると夏バテしないと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年の土用丑の日は、例年よりも少し早いらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家族で土用丑の日には、豪華な鰻重を囲むのが恒例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "今日は土用丑の日、とうとう鰻には縁がなかつた、鰻よりも鮎を食べたいのだが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "土用丑の日を以て、形式にでも、水に浸らねばならなかつた。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
