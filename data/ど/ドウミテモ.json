    "definitions": [
      {
        "index": 1,
        "gloss": "to all appearances",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "歌から見た宇都野さんはどう見ても世を捨てた歌よみ専門の歌人でなくて、この実社会に立ち働いて戦っている人のように見える。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇都野さんの歌はどう見ても大宮人の歌ではない、何処かしら東夷とでも云いたいような処があると私は思う。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう見ても野菊の風だった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある場面に出て来る小さな男の子にもどう見ても日本人としか思われないのがいる。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう見てもあそこで完結させることは出來ない。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　どう見ても、わざとの負傷と思われる心配がない、腰に弾丸が填っている初田が毛布からむく／＼頭を持上げた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔に銃と、弾薬盒と、剣は、どう見ても似つかわしくなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなりフランスくさくこしらえてあるが、しかしどう見てもそれはやはりドイツの本である。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう見ても金持ちらしい五十格好のあぶらぎった顔をした一人の顧客が、若い店員を相手にして何か話している。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフリカの蛮人でくちびるを鐃※のように変形させているのや、顔じゅう傷跡だらけにしているのがあるが、あれはどうもどう見ても美しいと思えない。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの直径がどう見ても三四倍になっている。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハイ」とお光は下て来て自分を見て、「オヤ兄様」と言ったが笑いもせず、唯だ意外という顔付き、その風は赤いものずくめ、どう見ても居酒屋の酌婦としか受取れない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋中でお俊はいつか噂にのぼり、またお俊の前でもお神さんはどう見ても意気だなぞと、賞めそやす山の神があるくらいですから私の目にもこれはただの女ではないくらいのことは感づいていたのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこの青年はどう見ても面会人のお客さんです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これではどう見ても面会に来たお客さんとは言われません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう見ても女子供の寄り付く柄ではない。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草に餓鬼大将をやってお在の時とは違って、品もよくおなりだし、丸顔も長くなってさ、争われない、どう見ても若殿様だ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうしてもどう見ても、母様にうつくしい五色の翼が生えちゃあいないから、またそうではなく、他にそんな人が居るのかも知れない、どうしても判然しないで疑われる。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰附、肩附、歩行く振、捏っちて附着けたような不恰好な天窓の工合、どう見ても按摩だね、盲人らしい、めんない千鳥よ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の事は云われないが、連の男も、身体つきから様子、言語、肩の瘠せた処、色沢の悪いのなど、第一、屋財、家財、身上ありたけを詰込んだ、と自ら称える古革鞄の、象を胴切りにしたような格外の大さで、しかもぼやけた工合が、どう見ても神経衰弱というのに違いない。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその生徒は都会人らしく、あかぬけがしていて、どう見ても私より秀才らしいのだから実にしょげざるを得なかったのだ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まん中に脂肥りのした體を紺の背廣服に包んだ中年の紳士、赧ら顏に赤鼻、厚い唇、白チヨツキの胸にからんだ太い金鎖の感じからが、どう見ても黨の有力者とでも云はれさうな代議士らしかつた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（縁側の真中の――あの柱に、凭懸ったのは太田（西洋画家）さんですがね、横顔を御覧なさい、頬がげっそりして面長で、心持、目許、ね、第一、髪が房々と真黒に、生際が濃く……灯の映る加減でしょう……どう見ても婦人でしょう。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、其の態度が如何にも自信に充ちていて、言葉こそ叮寧ながら、どう見ても此方の頤使に甘んずるものとは到底思われない。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が酷く瘠せッこけて、そうしょんぼりとしてる処は、どう見ても幽霊のようじゃ、行燈が暗いせいだろう。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、次郎の眼に恨みの色などすこしもなく、取り済ましているが、またとない上機嫌の表情がぴくぴく動いていて、どう見ても今日の見合いの相手であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう見ても快活な佐賀男だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに其の男の恰好がどう見ても己とそっくりである。",
              "citation": {
                "source": "怪談覚帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に類型的な田舎娘の扮装だったが、冴子はどうみても田舎娘になり切れなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその食べ方は、人の家の飯を食べていた時のように、黙祷や合掌こそしないが、どうみても抱えであった時分からの気習が失せず、子供たちの騒々しさや晴れやかさの中で、どこかちんまりした物静かさで、おしゃべりをしたり傍見をしたりするようなこともなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
