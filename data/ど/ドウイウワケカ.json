  {
    "uuid": "d468b3dd-01be-5123-bdf0-16b5761f2e8e",
    "entry": "どういう訳か",
    "reading": {
      "primary": "どういうわけか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
