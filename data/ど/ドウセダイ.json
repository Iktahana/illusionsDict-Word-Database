          "literary": [
            {
              "text": "ご想像つくかと存じますが、このような暮らしですので、同世代同身分の人とはなかなか付き合いが難しく。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれにいわせれば、同世代の人間の大部分は、あのとき、大人たちとおなじ世界にいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正の前半期に文学の同世代として衆目を引く出発をした芥川龍之介は、他の同輩菊池寛や久米正雄のようにそれぞれの才能の易きについて大衆文学へ移ることをしなかった。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついては日本に来ないか」と電話でまくしたてた東洋人が、同世代のシャープな人間であることを、ゲイツはすぐに理解した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョブズにとってウォズニアックは、自分よりもエレクトロニクスに詳しいと認めざるをえない初めての同世代の人物だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし同世代のすべての人たちがこのことばかりしていたら明らかに危険であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年亡くなった僕の父親と幼なじみの同世代だ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の父親なら、彼と同世代だ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけのこと」「周辺に同世代で何人かいる。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集者は裕美子よりふたつ年下の同世代だった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
