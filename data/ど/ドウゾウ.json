    "definitions": [
      {
        "index": 1,
        "gloss": "Dao Zang",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶山集甲子の詩に「題文晁画山為石子道」の七律、丁丑の詩に「次梧堂見寄詩韻兼呈混外上人」の七絶、庚辰の詩に「題石子道蔵松島図」の七古がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは所謂道蔵本と道蔵本に変改を加へたものとである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　千金方の道蔵本は即ち九十三巻の嘉靖本で、四庫全書の収むる所である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞうちの娘をお嫁にもらって下さいまし。",
              "citation": {
                "source": "ねずみの嫁入り",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞうまく行って呉れればよし。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このジョンという子伜めをどうぞうまく囮につかって敵の大将をおびき出したいとな。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百貨店などでも、停車場へ降りるお客様を自動車に迎えて、どうぞうちの店に来て下さいと、サービス専ら努めている。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞうまく、まとまれば好いがなあ……」 浩は、庸之助の体を、高く高く両手に捧げて、ドシドシと大きな広い公平な道を歩いて行きたいような心持がした。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかでしょう、どうぞうまい工夫で、いくらかはしのぎよくお暮し下さい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一一、四、夜十二時）　明日から第二場どうぞうまくゆくように。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
