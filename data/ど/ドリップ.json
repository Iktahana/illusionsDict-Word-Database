        "examples": {
          "standard": [
            {
              "text": "水道管からの水漏れで、天井からポタポタと水が「ドリップ」していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この野菜は、新鮮さを保つために、底にドリップを吸収するシートが敷かれている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あ！」と驚いた拍子に、手に持っていたコーヒーがテーブルに「ドリップ」してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「豆なんか、あるのかさ」「ああ、きのうのうちに、全部用意しておいた」　慶一はカップをさがしだして、調理台にならべ、高志は挽いてある豆を、慎重にドリップにのせていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志はやかんをもちあげ、ドリップに湯を注いでいく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その汽車には偶然英国班の最後の参加者アストン博士が観測の御手伝い役たる大使館員マッキンタイヤ、ピゴット、ペンダーカドリップおよびブロムレイの四氏と共に乗り込んでいた。",
              "citation": {
                "source": "英国日食班の印象",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
