        "examples": {
          "standard": [
            {
              "text": "疲れて帰宅した父が、ソファにドタッと倒れ込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "積み重ねた本が音を立ててドタッと崩れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はベッドにドタッと横になり、すぐに眠ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "前へ出ろッ」「面白れえ、俺も腕にかけて取って見せらあ、さあ出ろッ」　ドタッ、と筋肉の相搏つ音がきこえました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うとうととした私の上へドタッと重いものが落ちて来て。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "一と目千両",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて、ドタッ、ドタッ、陽の目見ずの闇を、縦横にきらめいてきた大刀の青光り。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは今、蝋燭の灯で深さを測った底知れずの穴――ドタッといった物音をこの世の名残りに、ああ馬春堂先生、「変な日」の予感がとうとう本ものとなって、真ッ逆さまに落ちこんでしまったようです。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドタドタッと天井裏の家鳴り。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドタッ……と誰か倒れたらしい。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
