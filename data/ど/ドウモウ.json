[
  {
    "uuid": "18cf3755-c9f7-5280-8d34-292cdbe2f9e1",
    "entry": "獰猛",
    "reading": {
      "primary": "どうもう",
      "alternatives": [
        "ねいもう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ferocious",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自然と人とは、時には獰猛に闘い、時には肉親のように睦び合った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　下顎骨の長い、獰猛に見える伍長が突っ立ったまゝ云った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」軍医と何か打合せをしていた伍長が、扉のすきから獰猛な顔を出して、兵舎の彼に呼びかけた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "獰猛な伍長よりも若そうな、小供らしい曹長だ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尉は下顎骨の張った、獰猛な、癇癪持ちらしい顔をしていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそこらにさまよっている野良犬のなかで、性質の獰猛らしいのを二匹も拾いあげた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、彼女のゆくところには、必ず一匹の獰猛な犬が影の形にしたがうが如くに付いて行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの老人の人に対する愛情は、人と同じ水準に立っては注ぐことは出来ないので、無理に高く自分を持ち上げて、その位置から獰猛に流しかけるのである。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花のあかみには、ごまのような、跳ねた粒子形のかたまりのような逞しい蝶が、花に打突かる獰猛さで飛んで来ては、また何処かへ行った。",
              "citation": {
                "source": "真夏の幻覚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が獰猛野獣の如きは其人境遇の罪で、其人自身の罪では無かった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして今｜独逸を縦横に且獰猛に活躍させてゐる此軍国主義なるものを、もつと遠距離から、もつと小さく観察したい。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "が顔はブルドッグのように獰猛で、美しい縹緻の金魚を媒けてまずその獰猛を取り除くことが肝腎だった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい神々しいおつな……獰猛な鹿田……富之助の頭のこの烈しい對照が更に幾多の不祥な聯想を呼んだ。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かあの岩疊の體格、獰猛な顏容の裡に此種の sentimentalisme を豫期しよう。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、陸に上って既に日に乾いたものは熊のように黄褐の毛が逆立ち、頬の髭が強く張って、いかにも獰猛な巨獣の相を現す。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼、　眼、　おそろしく獰猛な二頭が向き合った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れなるかな、激烈なる生存競争に敗れて気息｜奄々たる、一頭の成牝若くは処女獣をさえ収め得ず、小なる小なるハーレム一つ創り得ずに止む永遠の孤独者、または昨の英雄、かつてのハーレム中の獰猛者、しかもまた老大奮わぬ今日の悶々者、かつはまた既に煩悩の兆して、未だ力弱き半成牡。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は聖美なるもの、或は毒悪なるもの、或は慈仁なるもの、或は獰猛なるもの、宗教の変遷、思想の進達に従ひて其形を異にするが如しと雖、要するに二岐に分れたる同根の観念なり。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "獰猛なのになると、時に仔羊を襲って喰殺したりする。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはライオンに見られるような装飾風な馬鹿馬鹿しい大きさはなく、如何にも実用向きな獰猛さが感じられた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "苛刻な現実精神をかの獰猛な妖怪から、身をもって学んだわけだ、と、悟浄は顫えながら考えた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "獰猛な顔をした人とも鬼とも判らない者が二人入ってきたところであった。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は非常に獰猛な性質であり、また彼の権限を犯すようなことに対しては、すこぶる敏感をもっているからである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは獰猛な喧嘩好きの動物で、優に熊以上の力があるといわれているが、幸いにその動作はにぶく不器用なので、氷の上でかれらを襲ってもほとんど危険というものがない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い皺が刻まれて、痩せて角ばった、いかにも獰猛な相であった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたや息子の方はあの目立つ威勢もどこへやらで、危険な野獣の獰猛さが黒い目のうちに光り、整った容貌もゆがんでいた。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそこのあたりに獰猛な野獣でも放した方がましです。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはあの方が、あの天使が、獰猛なウッドリに一生縛り付けられると言うのか？",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中でコヨーテが忍び、空ではコンドルが旋回し、暗い谷には獰猛なグリズリーが岩間に餌を求めて闊歩している。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人がその青い粘土も持って来たのでしたが、蹄の痕があんまり深過ぎるので、どうもうまくいきませんでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
