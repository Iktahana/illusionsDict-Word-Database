    "definitions": [
      {
        "index": 1,
        "gloss": "remote countryside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いいえ、断じて自分は狂ってなどいなかったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるさとに帰った彼は、怠けてなどいなかった。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当は死んでなどいなかったのです。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、恐怖に打たれた世人の中には、こういう仕業を人間のすることと思う者はほとんどいなかった。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくさんの熱心な問い合わせはあったが、コイル部が最後まで障壁となって、記事のカメラには完成にこぎ着けられる人がほとんどいなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、こういう席に若い令嬢は殆んどいなかった。",
              "citation": {
                "source": "無法者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星人は、地球の人間のことを、前からくわしく研究して知っていたけれど、人間の方では、火星人の研究をしているものが、ほとんどいなかったのであるから、仕方がないであろう。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そんな苦情を二度と考え直すほどそれを気にかける者はほとんどいなかった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろそういう人がほとんどいなかったと言った方が、適当であるかもしれない。",
              "citation": {
                "source": "救われた稀本",
                "author": "――寺田寅彦著『物理学序説』",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して二人の兇漢は待ってなどいなかった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸に叔母などいなかったのに、何と思ったか、私はそのままとぼとぼ歩き出して、小一里もある遠方へ行ってしまった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田の人といえども彼の存在に気附く者はほとんどいなかったであろう。",
              "citation": {
                "source": "思い出す職人",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「特別な人々」を除くとこのように考えて実行する人たちは殆どいなかった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、朝になっても、不幸せな子どもなんてほとんどいなかったんですから。",
              "citation": {
                "source": "サンタクロースがさらわれちゃった！",
                "author": "A KIDNAPPED SANTA CLAUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑子の表むきの仲人だった野村の友人の井川がミネの家へ様子をききにきたとき、閑子がちょうどいなかったのでミネは、そのごの閑子の愚かなまでの言動を井川に話した。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は、渡り者の配達で、しょっぱんの前科のない者は殆どいなかった。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の大きな都市だけに医師が定着し、共同体から俸給を受けていたとしても数は極めて少なくほとんどいなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "また流行によって激しさの違うことが知られていてある時には死亡率が高く他の時には軽くて死亡者が殆どいなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の慷慨の士の中に、条約改正案の内容について大隈の計画と彼の真意について正しい認識をもっているものはほとんどいなかった。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際一つの例を挙げてみれば、彼らの間には我々の結婚の窮屈な制約を認めたものがほとんどいなかった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "横鼻緒の仕事は難儀で課程をやっている者は殆んどいなかった。",
              "citation": {
                "source": "その人",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう書いた私は自らつつしむような、そうした気持でなどいなかった。",
              "citation": {
                "source": "その人",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、それは後に述べます様に、彼は別段法律上の罪悪を犯してなどいなかったからです。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然、そこにはもう、曲者などいなかったばかりか、もしやと思っていた女の死骸さえ、ないのです。",
              "citation": {
                "source": "湖畔亭事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "介は、先ごろ故郷にのこしてある老母の病があついという報らせで、田舎へ帰っていてこの二月ほどいなかった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人などいなかったのです。",
              "citation": {
                "source": "親友たち",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "時節行事の一環であり、今晩は帰る人がほとんどいなかった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "レストランは現代風でなく、客もほとんどいなかった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いなことに酔っ払いはほとんどいなかった。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡崎の城には、松平元康をはじめ、元康の手飼の三河武士たちは、ほとんどいなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
