        "examples": {
          "standard": [
            {
              "text": "急な頭痛で、駅前のドラッグストアに駆け込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日用品も買える便利なドラッグストアが増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外の観光客がドラッグストアでお土産を買っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この頃は、夏休みのシーズンであるから、ドラッグストアや十セント店には、ピクニック用のものが、たくさん出ている。",
              "citation": {
                "source": "紙の洪水",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂糖菓子やドラッグストアの詰め合わせ、アイスクリームソーダや人口香料、は他の強力な原因である。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ロシア犬、生きたまま月に到着」ドラッグストアの店先に山積みになった新聞にヘッドラインが踊っていた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            }
          ]
        }
