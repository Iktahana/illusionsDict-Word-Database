        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "土瓶むしの土瓶のつるを持ち上げると土瓶が横に傾いて汁がこぼれた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土瓶の耳の幅が廣過ぎるのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土瓶や湯呑がとんで来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻想的なといへば幻想的な、子供だましのポンチ繪には、土瓶が鉢卷をして泳いでゐたり、日の丸の扇で踊つてゐたりするのがあるが、ブーブー唸つて走つてゐる自働車などを見れば吹き出したくなる位だ。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは今ここで教えてもこの病院ではできまへんで」　そしてそんな物々しい駄目をおしながらその女の話した薬というのは、素焼の土瓶へ鼠の仔を捕って来て入れてそれを黒焼きにしたもので、それをいくらか宛かごく少ない分量を飲んでいると、「一匹食わんうちに」癒るというのであった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所の土間の板縁の下に大きな素焼きの土瓶のようなものが置いてあった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩秋の夜ふけなどには、いつもちょうどこの土瓶のへんでこおろぎが声を張り上げて鳴いていたような気がする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このきたない土瓶からきたない水を湯飲みか何かにくみ出して、それにどっぷりおはぐろ筆を浸す。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれの原稿が、編輯者の机のうへでおほかた土瓶敷の役目をしてくれたらしく、黒い大きな燒跡をつけられて送り返されたこともポンチ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相島は仕切りの襖を締めて廊下に出て、其處の押入れから茶碗を二つと土瓶と茶筒とをつかんで來た。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相島は無頓着な風で茶筒から茶をこぼし／＼土瓶に移してストーヴの上の藥罐を下しながらにこついて居る。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢に懸けたる土瓶の煮ゆる音、ジュー。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と頷けば、手早く髪を束ねて櫛にて押え、土瓶片手に出行きけり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずたずたになれる筵の上に、襤褸切、藁屑、椀、皿、鉢、口無き土瓶、蓋無き鍋、足の無き膳、手の無き十能、一切の道具｜什物は皆｜塵塚の産物なるが、点々散乱してその怪異いうべからず。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩の物だけ重詰にして、夜さりまた掻餅でも焼いてお茶受けに、お茶も土瓶で持って行け。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が住めば水も要ろうで、何も釣瓶の音が不思議と云うでは、道理上、こりゃ無いのでありまするが、婆さんに聞きました心積り、学生の方が自炊をしてお在と云えば、土瓶か徳利に汲んで事は足りる、と何となく思ってでもおりましたせいか、そのどうも水を汲む音が、馴れた女中衆でありそうに思われました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "えら茶話がもてて、何度も土瓶をかわかしたで、入かわって私もやらかしますべいに、待ってるだよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そ、その鉢にゃ水があれば可いがね、無くば座敷まで我慢さっせえまし、土瓶の残を注けて進ぜる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上の棚には膳、碗、皿、小鉢、茶を入れたる罐、土瓶、茶碗などが載せてあり。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（重兵衛は太吉を横目に睨みながら、自在の湯沸しを取って下のかたへ行き、棚から土瓶をおろして茶の支度をする。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（重兵衛は盆の上に土瓶と茶碗を乗せて、再び炉の前に来る。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（土瓶の茶をついで飲む。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前通には皿や鉢や土瓶やドンブリや、何れも疵物の瀬戸類が埃に塗れて白くなつてゐた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにひろげられた枕屏風の蔭に、空っぽの飯櫃がころがって、無残に喰い荒された漬物の鉢と、土瓶と、箸とが、飯粒にまみれたまま散らばっている。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋茶を煮出した真黒な土瓶。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "土瓶敷代りにもたびたび使つた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋や土瓶の尻しみが表紙や裏に残月形に重つて染みついてゐた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは二十銭以上のお買物だから出すけど、今日は茶滓漉しの土瓶の口金一つ七銭のお買物だからお茶は出せないぢやないの」「お茶は四五日前に買ひに来たのを知つてるだろ。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　太郎左衛門が学校へ、どびんのふたぐらいの大きさの、まるいへんなものを持ってきて、「これね、とってもおもしろいんだよ」といった。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どびんのふたのように、一方がくぼんでいる。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
