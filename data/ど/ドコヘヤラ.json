    "definitions": [
      {
        "index": 1,
        "gloss": "currently nowhere to be seen",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
