    "definitions": [
      {
        "index": 1,
        "gloss": "what would (you) do?",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
