    "definitions": [
      {
        "index": 1,
        "gloss": "the same month",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同じ星太宰治　自分と同年同月同日に生れたひとに對して、無關心で居られるものであらうか。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三報、四月二十八日午後三時五分発、同月同日午後九時二十五分着。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "干支を廃し、おまけに七曜も廃するか、あるいはある人たちの主張するように毎年の同月日を同じ日曜にしてしまうというしかたは、一見合理的なようで実は存外そうでないかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四回は同月十九日で、笞打ほかに石七枚を抱かされた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ占めたといふのであつたらう、忽ちに手対ふ者を討殺し、七八｜艘の船に積載した財貨三千余端を掠奪し、かよわい妻子を無漸にも斬殺してしまつたのが、同月十九日の事であつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月十五日馬を進めて上野へ将門等は出た。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にして其約束は約束だけに止まり、予は同月の二十五日、一人函館を去つて海路から上京したのである。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して在監二週日の後同月の二十日に保釈の許可を得て帰宅、同二十八日に第三回の公判延期となり、本月十日の公判に簡単に無罪免訴の言渡しを受けて、刑事上には全く此の事件と関係を絶つ事になりました。",
              "citation": {
                "source": "わが敬愛する人々に",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに云う、竜池の狂歌の師初代弥生庵｜雛麿は竜池と同年同月に歿した。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月、「病中雜咏（一）」を無題で「アララギ」に発表。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月、「病中雜咏（二）」を「病中雜咏」の題で「アララギ」に発表。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月二〇日、九州大学附属病院に入院。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月、「鍼の如く（五）」を「アララギ」に発表。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "本能寺の変が報ぜられたのは、同月四日の夜に入ってからであるが、陣中の周章は一方でなく、戦半ばにして、勝家は越前に、盛政は富山に引き退いた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信雄信孝とは永禄元年の同月に生れ、信孝の方が二十日余りも早かったのだが、信雄が信忠と母を同じくしたのに引かえ、信孝は異腹であったので、人々信雄を尊んで、早速に信長に報告し、次男と云うことになって仕舞った。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に同月二十七日也。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏壇ですから数珠があるのに不思議はないが、男の子どもが三人と気違いと、よそから飛び込んできた疑問の女と、人物は五人しか現われないのに、祥月命日が同月同日の新しい位牌が二つあって、その前にけっこうな水晶の数珠があるとは、余人ならいざ知らず、名人の目をもってしてははなはだ大問題です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月二十三日の川開きには、牡丹燈籠二千個を大川に流した。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何卒平生の心事御了解被成下大納言様御手筋を以乍恐朝廷へ御取成寛大の御汰沙｜只管奉歎願誠恐誠惶　謹言酒井孫八郎吉村又右衛門沢｜采女三輪権右衛門大関五兵衛服部｜石見松平｜帯刀成瀬｜隼人正様　次いで、同月十八日、官軍の先鋒が鈴鹿を越えたという報をきくと、同文の嘆願書を隣藩亀山藩へ送った。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年同月十一日に故あって獄を出たる者なりと云う」との文字がある。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は犯行そのものを否認しつづけ、同月二十日に至り平山検事に単独犯行を自供した。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月十七｜日、いよ／＼發掘に行く事としたが家人も其状態が見たいといふので、然らば其用意して行くべしとて、妻と婢とに糧食を携へさせ、余は愛する親族の六｜歳の幼女を背に負ひ、玄子は器具など擔ぎ、鶴見にて電車を降り、徒歩にて末吉に著いた。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "末吉の貝塚",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して同月十七日大雨あり、翌十八日に至り海老瀬村人夫は前日の暴言を受けたるにも拘らず多数相携へて再び同所に至り、終日終夜一睡だも為さずして水防に努力せり。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月二十六日に長女｜純が幕臣｜馬場玄玖に嫁した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月四日血忌引御免被仰付候旨、山岡治左衛門殿被仰渡候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月八日此間出生仕候娘病気之処、養生不相叶申上刻死去仕候、七歳未満に付、御定式之通、三日之遠慮引仕候段御達申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月十一日御番入仕候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四月八日妻安産仕、女子出生仕候、依之御定式之血忌引仕候段御達申上候、同月十一日血忌引御免被仰付候、明十二日御番入仕候段御達申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「六月十六日、拝借御長屋附之品々、御払直段に而頂戴仕度段奉願上候所、同月十九日願之通被仰付候」と云ふのが其二である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又七月の記事中に、「同月廿二日、丸山御屋敷拝借御長屋え今日引移申候段御達申上候」と云ふのが其三である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
