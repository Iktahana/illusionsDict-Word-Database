        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "表に見張番の奴等が居ると五月蝿えからな」Ｓ＝表の部屋　石松に鶴吉が、　「昨日、お半さん、お前が何日帰るって訊きに来たぞ」　「お半の奴、どうしてる？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうしてるんだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「露助は、どうしてるんだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『時に吉さんはどうしてるだろう』と幸衛門が突然の大きな声に、『わたしも今それを思っていたのよ』とお絹は針の手をやめて叔父の方を見れば叔父も心配らしいまじめな顔つき。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたのお父さんはどうしてるの。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のワイフは今ごろどうしてるべなあ、と弟に聞いたら、弟は棧橋のらんかんを二三度兩手でゆりうごかしてから、庭あるいてる、ときまり惡げに言つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のワイフは今ごろどうしてるべなあ、と弟に聞いたら、弟は桟橋のらんかんを二三度両手でゆりうごかしてから、庭あるいてる、ときまり悪げに言つた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はどうしてるかと見ると、例の自分の長火鉢の前に坐って、子供を遊ばしてるような詰らなそうな顔をしています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は文吉を縁の側へ呼び寄せて、家の者には聞えぬような小声で、「本家のじいさん、どうしてる」と訊くのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼びかえして、「――あれはどうしてる？",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然し、どうしてるんだらう――遲い！",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてるの」と、多鶴子に言葉を掛けた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はどうしてるんだい？",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "見りゃ溜池の中に舟もあったし、材木もありましたが、水死人を捜すように鶏を浮しとく数じゃありませず、持扱いましたね、全く気が気じゃあなかったんで、一羽抱え込んで跣足で池の縁をまごまごしてる風ッてのはありません、我ながら薄ぼんやり、どうしてるのかと思いました。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "となりで女はどうしてるだらうかと想像して見る。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビートルズはどうしてるかな、と考えたとたん、たいへんなことに気づいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「國ではどうしてるべ。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓たちが仕事の合間にフト口をきくとき、「國ではどうしてるべ。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お文はどうしてる？",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてるかしら、あの人。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「毎日どうしてるんです。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの監房には本なんかありますか」「全然ないんですよ」「毎日どうしてるんです」「なに、毎日だまって坐っていますよ」そこで岡田はまた白い歯を出して笑った。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その後どうしてるんだい。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも道で出逢うと、恭さんはどうしてるとすぐ問いかける。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイやナポレオンは今どうしてるだろう。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親や兄が職場からそうして珍らしいところを見学しながら休む時、子供連は、ではどうしてるか？",
              "citation": {
                "source": "ソヴェト労働者の夏休み",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんはどうしてるかね。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はどうしてるんだね？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
