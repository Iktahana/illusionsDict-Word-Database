      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "social integration (esp. of burakumin)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "我意が生じれば人と同和せず人と異なる。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は大方四散して歌をもやめてしまつた樣だが、鷲野飛燕、同和歌子夫妻などはその頃から重だつた人であつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "願わくば再びこの地に来り日本仏教とチベット仏教との協同和合に一臂の力を尽し、幸いに世界仏教の基礎となるを得ば誠に愉快の事である。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち法制局長官神鞭知常を委員長とし、内務省土木技監工学博士古市公威、内務省衛生局長後藤新平、大蔵省主税局長目賀田種太郎、農商務大臣秘書官早川鉄治、農事試験場技師坂野初太郎、農商務省技師細井岩弥、同和田国次郎、同小寺戻次郎を委員に任命した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして城中へ逃げてきたところ、楼門の上から鞏志が弓に矢をつがえて、「城内の民衆は、みな自分の説に同和して、すでに玄徳へ降参のことにきまった」　と、呶鳴りながら、びゅうんと弦を反らした。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平もそれらの稽古本を開いて見ることもあり、古い江戸の匂いをかぐような気がして、民衆の間から産まれた芸術だというのと、声調が長唄ほどうわずった騒々しさがないのとで、時には聴く気にもなるのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が、どうわるいというのでも無いのに、すっかり陰気に濁ってしまって、溜息と、意地悪い囁きだけが、エルシノアの城にも、またデンマークの国中にも満ち満ちているような気がします。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡いとは、どうわるいのぢや。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、なるほどうわさにたがわず、あるじは右腕をすっぽりと切ってとられて、あけに染まりながらそこにうめきつづけていたものでしたから、右門は黙って近よると、まずその切り口をとっくりと改めました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、支度を」「僕は、からだが悪いので……」「どこが、どうわるい」「心臓やその他……機上で人事不省になるなんて、醜態ですからねえ」「なあに、心臓なんか、大丈夫だ。",
              "citation": {
                "source": "三重宙返りの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、わからないというのはどうわからないのか、それを述べて意見のかわりにしたいと思う。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒子　　（うなづく）譲　　どうわかつたの。",
              "citation": {
                "source": "驟雨（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "東山の上から、赤い旗を振つて、「きみのところへ　どうわとくほんが　つきましたか。",
              "citation": {
                "source": "にらめつくらの鬼瓦",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこが、どうわるいのです……？",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はじめておまえに会ったのはここだったな」「そうだな」とニール・オキャリーは答えて、「おう、金をどうわけようか」と言った。",
              "citation": {
                "source": "ニール・オキャリー",
                "author": "NEIL O’CARREE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぺんきりなんて――それなら、僕がはじめて接吻したとき、どうして君は、自分からしかえしたんだろう」　あの夜の瞬間の感情の激発を伸子は蜂谷にどうわからせることができただろう。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうわかったんだ。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより番頭の彌八と、養子の品吉と、甥の與之助と、手代の直次郎の金の費ひツ振りでも調べて見るんだな」「それならわかつてますよ」「どうわかつてゐるんだ」「彌八は少しくらゐは溜めてゐるし、手代直次郎は、男つ振りが好いから、あちこちでチヤホヤされて借金だらけ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "「読むのはよせよ」と彼はさぶのほうを見ずに云った、「皺になると使えなくなるぜ」「ちゃんと鏝がかけてあるよ」「だから読むのはよせって云うんだ、いつまでも子供っぽいやつだな」栄二は殆んどうわのそらで云った、「せわをやかせるなよ」　さぶは反故紙をそっと下に置いた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とてもおもしろいどうわの本でもよんでいるようなきもちでした。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校で」「どこがどうわからないのか、それがわからないのでしょう」　祐子は自分の言葉に自分で笑った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
