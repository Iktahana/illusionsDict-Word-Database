          "literary": [
            {
              "text": "「どうしたんだ、オイ、しっかりしろよ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "メーツは、ブリッジで、涼風に吹かれながら、ソーファーに眠っていたが、起き上って来て、「どうしたんだ」「左舷に燈台が見えますが」「又、一時間損をしたな」と、メーツは答えて、コムパスを力一杯、蹴飛ばした。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだのかい」「死んだらしい」「どうしたんだい」「やけに呷ったらしいんだ」「フーム」「………………」「で、水葬はいつかい」「一運に一度訊いて見よう」「酒が、わるかったんだね」「ウム、どうもはっきり分らねえ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんだらう。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂部さんはどうしたんだろうねい。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、まアどうしたんでしょう」　僕の詞に励まされて母はようやく涙を拭き、「政夫、堪忍してくれ……民子は死んでしまった……私が殺した様なものだ……」「そりゃいつです。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静、　「兄さんッたら一寸来てよ、大変なの」　「五月蝿えな」　「大変なのよ、来て御覧」　「どうしたんだ」　「今、家の表で喧嘩がはじまったの、大騒ぎよ」　「ちえッ、喧嘩なんか珍しくもねえ、喧嘩なら俺ァ毎晩やってらァ、昨夜も権六の野郎と喧嘩して向う脛蹴っとばしてやった」　「違うの、そんな喧嘩じゃないの。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「石さん、一寸」　「何んだよ」　「目出度い話さ」　「出し抜けに、どうしたんだ」　「実はね、石さん。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "七五郎が、　「あれ、石松、眼どうしたんだい」　「なに、なんでもねえんだよ」　石松、奥の間を見て、　「お父っつあん居ねえのか」　「清水へ行ったわ」　「清水へ？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ァ帰るのが厭になった」　「兄さん、今夜はゆっくり休んで、明日の朝早くお立ちなさいよ……ね」　「いや、矢張り今夜立つよ」　七五郎が、　「石松、話があるンだ」　「改まって、どうしたんだい」　「いや、お前のきっと喜ぶ事だ」　「俺の喜ぶ事って？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんだ石松」　「七五郎、しばらく、かくまって呉れ……吉兵衛の奴、卑怯にも欺し討ちにしやがった……俺の帰って来た事を何処で聞きやがったか、あの野郎……」　お民、　「お前さん、二階が……」　「そうだ、石松、二階に隠れてろ……石松、痛むか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「綺麗なひとは倖せね」　と言ったのを小耳にはさんだ三次が、　お内儀に「どうしたんです」と訊く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あの、藤子は、藤子はどうしたんです‥‥‥』と、私は叫んだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい近藤君、どうしたんだ？",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "密輸入者はどうしたんだろう。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんですか？",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしは富蔵の顔を睨んで、やい、てめえの頸のまわりや手の甲に引っかき疵のあるのはどうしたんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それにしても息子はどうしたんだろう」　盤台や天秤棒がほうり出してあるのを見ると、七之助はもう帰って来たらしいが、どこに何をしているのか、この騒ぎのなかへ影を見せないのも不思議に思われた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「息子はどうしたんだろう」　おまきの死骸を取りまいて、こうした噂が繰り返されているところへ、七之助が蒼い顔をしてぼんやり帰って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもまあ無理はねえ、ともかくもこれから一緒に行って、皆さんに宜しくおねがい申してやろうと、こうして出てまいりましたものでございますが、一体まあどうしたんでございましょうね」「いや、別に仔細はない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、どうしたんですえ、その中間は」「鶏をぬすんで絞めたんですよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたんだ、どうしたんだ、と云う者があった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんだ、どうしたんだ？",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんですか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよう、どうしたんです？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ボーイ、毛布はどうしたんだ？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんでありますか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高取なんぞ、どうしたんでありますか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
