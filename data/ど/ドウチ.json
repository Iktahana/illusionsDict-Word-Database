    "definitions": [
      {
        "index": 1,
        "gloss": "(logical) equivalence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
