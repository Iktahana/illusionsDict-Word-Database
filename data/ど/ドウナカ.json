[
  {
    "uuid": "95d4c3fa-0f16-55f2-a625-93203d01e2a8",
    "entry": "胴中",
    "reading": {
      "primary": "どうなか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
