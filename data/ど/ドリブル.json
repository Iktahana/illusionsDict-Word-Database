        "examples": {
          "standard": [
            {
              "text": "バスケットボールの試合で、彼は見事なドリブルで相手選手を次々と抜き去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「サッカーの試合では、ボールを奪われないように、素早くドリブルする技術が大切だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ホッケーの選手は、パックを巧みにドリブルしながらゴールを目指す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "と、又、それが密集してドリブルの稽古に移ったりした。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "半円形にドリブルしながら走っていき、ボールを両手に持って、ジャンプ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンプしてそのボールを取り、ふたたび半円形にドリブルして走り、こんどは反対側からジャンプ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この騒ぎのあいだずっと、バスケットボール・コートの女のこは、スノー・マンには目もくれず、ドリブルとジャンプとシュートを繰り返し続けた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
