    "definitions": [
      {
        "index": 1,
        "gloss": "more than anything (else)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
