        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、それよりも、釣りをすることを子供たちが、果して喜んだかどうかなのだつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうかなすつたの」と、隣の少佐夫人が云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奴等自身だって、熱量が補給されるかどうかなんてこたア、考えてみもしねえんだ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（どうかなさいましたか、）もうちゃんと法衣を着たから気丈夫に尋ねる。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人は目早く見つけたそうで、（おや、貴僧、どうかなさいましたか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれもやはり造化の妙機であって、ちょうど「鎖骨｜挫折」のような役目をするためにどこかがどうかなるのかもしれない。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれが少しどうかなとこう考えだしてごらん、そら、それは次の頁だよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いますと、一人の百姓は、「しかし地味はどうかな。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕なんかはどうかなあ。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれが少しどうかなと斯う考へだしてごらん、そら、それは次の頁だよ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもお前達の力で阿難が縛れるかどうかな。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日あたりからどうかなさって、お身体の工合が悪いのでしょう。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうかなさったのですか。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那、どうかなすつて、お床をさう云ひませうか。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひますと、一人の百姓は、「しかし地味はどうかな。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と睨附くれば、老婆は驚きたる顔を上げ、「へい、下枝｜様がどうかなさいましたか、「しらばくれるない。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ臨終に間に合うかどうかな。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さんは今日はあまり烈しく心を動かされたので、気がどうかなつてゐるのぢや。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまこそ、どうかなさって居られます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、いまの若い人たちには、どうかな？",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうたびたび一撃をくらってはたまらない、頭がどうかなってしまう、と思った。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がどうかなってしまった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那はどうかなさいましたか、顔色が悪いじゃありませんか」　丹治も今あんな目にあったから己の顔色が悪いだろうと思ったが、何か飲まないとゆっくりそれを話すことができなかった。",
              "citation": {
                "source": "怪人の眼",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、「どうかなさいましたか。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "サア、まことの糟糠の妻たる夫思いの細君はついに堪えかねて、真正面から、「あなたは今日はどうかなさったの。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「浮気じゃない、今度ばかしゃ大真面目だがね、君、どうかなるまいか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、」と伏目になったトタンに、優しげな睫毛が、（どうかなさいよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――貴下がその今日途中でその、何か、どうかなすったという……それから起ったんですな、三輪ちゃんの今の話は。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
