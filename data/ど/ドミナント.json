        "examples": {
          "standard": [
            {
              "text": "ジャズでは、ドミナントセブンスコードの響きが曲に独特の色合いを与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "作曲の練習として、様々なキーでドミナントセブンスのアルペジオを弾いてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このブルース進行では、Ⅴ7（ドミナントセブンス）からⅠ（トニック）への解決が期待される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "所詮、鼻は表現界中央の重鎮……表現界のドミナントであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池寛氏をはじめ手近に想い起される日本ジャーナリズムのドミナント・フィギュアを心に浮べて、ルースの持つような性格分裂、ジャーナリストとしての危険に多少ともさらされていない何人を挙げることが出来るだろう。",
              "citation": {
                "source": "微妙な人間的交錯",
                "author": "――雑誌ジャーナリズムの理想性と現実性――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
