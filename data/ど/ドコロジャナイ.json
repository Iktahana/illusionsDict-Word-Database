        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「一所じゃないです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、「そう、結構ですわ、似合のご夫婦」と褒めそやしてやりますと、池上は苦笑して、「なに、御台所じゃないよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「面白い家って、怪しい所じゃないだろうね」「大丈夫ですよ。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「台所じゃないかの。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前なんかの出しゃばる所じゃない！",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前やこしの来る所じゃないぞ、なんと思うとるんや。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここは音楽会をする場所じゃないね。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな所は人間の住む所じゃない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ変ったと云えば大に変り、変らんと云えば大に変らん所じゃないか。",
              "citation": {
                "source": "私は懐疑派だ",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の腰をかける西洋便所じゃない。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、パリのあちこちを歩いて見たが、こうした西洋便所じゃない、そして幾室あるいは幾軒もの共同の、臭いきたない便所がいくらでもあるのだ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃ君の清元の御師匠さんの近所じゃないか？",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蕪湖もそんなに悪い所じゃないぜ。",
              "citation": {
                "source": "母",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ヵ所じゃないですよ。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "交通整理の行き届いている事は、いくら贔屓眼に見た所が、到底東京や大阪なぞの日本の都会の及ぶ所じゃない。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも当の水兵連は、そんな事にかまう所じゃない。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に武劇――立ち廻りの多い芝居になると、何しろ何人かの大の男が、真剣勝負でもしているように舞台の一角を睨んだなり、必死に銅鑼を叩き立てるのだから、到底天声人語所じゃない。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人はどう云う人種か、それは私の知る所じゃない。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この猛烈な歓喜や苦痛は、若槻如き通人の知る所じゃない。",
              "citation": {
                "source": "一夕話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それというのも、お前達の徒なる狐疑逡巡の為す所じゃないか。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが生活する場所じゃないか、これじゃあんまり殺風景だ、鳥でも金魚でもおけ、気分の転換になる、気分の転換ということは大切だ、　だが小柳は、　面倒くさいよと云った。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い間はあんな町で好きなことをして暮らすのもよかろうが、歳を取ったらおれる所じゃない。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどあなたのおっしゃる通り人間のいる所じゃないでしょう。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「太田の原の傍です」「じゃ御前さんのじき近所じゃないか。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「静岡の伯父に譲らざる東京通なるには恐れ入る」「いくらでも恐れ入るがいい」「ハハハ日本堤分署と云うのはね、君ただの所じゃないよ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は勘定所じゃない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のなかだから、人の住んでる所は樟脳を採る小屋が一軒あるばかり、池の近辺は昼でもあまり心持ちのいい場所じゃない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "セブンどころじゃないイレブンくらいだろう。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田　　それどころじゃない。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "………私、それどころじゃないんですもの。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
