    "definitions": [
      {
        "index": 1,
        "gloss": "doburoku (unrefined sake)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
