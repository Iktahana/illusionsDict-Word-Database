        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "八つの道　次に第四の真理は「道諦」です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "道諦とは、「涅槃」の世界へ行く道です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が狐のやうで、わにみたいなどうたいをした、まつ黄色な、きたならしい犬で、そつくりかへつた、へんに大きなしつぽをしよつてゐます。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなうつくしいけしきも、この鏡にうつすと、煮くたらしたほうれんそうのように見え、どんなにりっぱなひとたちも、いやなかっこうになるか、どうたいのない、あたまだけで、さかだちするかしました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　翌くる朝、ヨシ子はもうすっかり快くなって、起きるなり食べものをねだり、満腹すると歌などうたい出した。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "空き車の上へ馬子が乗って、唄などうたい、浜の方へ帰る、ガラ、ガラという、轍の音が、だんだんかすかになると、ぼんやり立って、聞いている彼の耳もとへ、風は、「明日は、いいことがある。",
              "citation": {
                "source": "風はささやく",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "商業用宣伝歌の多くもその例で、子供でもすぐ真似ができるほどうたいやすくできている。",
              "citation": {
                "source": "歌詞とその曲",
                "author": "信時潔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
