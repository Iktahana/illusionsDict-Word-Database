    "definitions": [
      {
        "index": 1,
        "gloss": "moving body",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わずかに十六歳の少年は既にこの時分から「運動体の光学」に眼を付け初めていたという事である。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震計の震動体にメルデ実験に相当する作用のあるのが見逃されているのに気付いて、これを無くする考案をしたりした。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち振動体の減衰するエネルギーを弓の仕事で補給する、その補給の回数と適当な位相とを振動体の振動自身が調節するというのである。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓の毛髪と振動体とが複雑な週期的相対運動をしている際に摩擦係数がはたして静的係数と動的係数との間を不連続的に往復しているのか、それとももっと複雑な変化をしているのか、これについてはまだだれも徹底的に研究した人はないようである。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の初等物理学教科書などには弦が独立した振動体であるようなことになっているが、あれも厳密に言えば弦も楽器全体も弓も演奏者の手もおよそ引っくるめた一つの系統として考えるほうがほんとうだと自分には思われる。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勃凸はおんつぁんを流動体のやうに感じた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にその発想の形式は、必然に柔軟可動体なる、メロディアスの自由主義を欲求する。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "取りて持返して透したれば、流動体の平面斜めになりぬ。",
              "citation": {
                "source": "誓之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ人間というやつは、興奮の振動体のようなもので、いつも二十四時間、なにかかにかの興奮に神経を焦がしている。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのころ、今とは違って、先ず外界を視ることに精神を集中しなければならぬと思っていたので、この作品も、その企画の最終に現れたものであるから、人物よりもむしろ、自然を含む外界の運動体としての海港となって、上海が現れてしまった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはアメーバの運動を顕微鏡下で御覧になったことがないかも知れませんが、アメーバは単一細胞から出来た生物で、半流動体の原形質と核とから成り、そこで原形質がいろいろに形をかえて、食物を摂取したり、位置を変えたり致します。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはブルジョア・地主の官憲が、日本プロレタリア文化運動の唯一にして綜合的な活動体である日本プロレタリア文化連盟の具体的な活躍を、どんなに恐怖しているかという明らかな証拠である。",
              "citation": {
                "source": "婦人雑誌の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『近代文学』のグループといえば、ブルジョア民主主義の限界内で、個人主義的な主体性の確立の論議にとらわれていたようだけれども、去年の夏からファシズム反対の積極的な活動体となってきています。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを共鳴現象というが、二つある振動体が同じ振動数をもっているときには、一方を叩くと振動が空中をつたわって他のものを刺戟することとなる。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、別にそっと釣して置いた振動体が寸法のちがうものであっては効果がない。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぞれ合法的な大衆文化団体、作家同盟、音楽家同盟、演劇同盟、美術家同盟等の十三団体を綜合的活動体として日本プロレタリア文化連盟を結成したものであるのに、官憲はその結成を承認しない。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すると、結局君は、この暗合を、｜この人を見よ――と解釈するのかね」「いやどうして、｜それは自然のままにして、しかも流動体なり――さ」と法水はあっけなく云い放って、その突然の変説が検事を驚かせてしまった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると貴方は、八住を刺した兇器を、僕がどこへ隠したと云われますか」「なにも、あの流動体には、隠す必要なんてないじゃありませんか。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理学にいう固形体のものを流動体に変じ、ガス｜体に変ずるがごとく、嵩は大きくなるけれども、つかみどころがなくなりがちである。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は固形体の状態から灼熱、鎔解して流動体となり、さらに光を発するほどの精醇な Morality というものに向かって純なる憧憬を持つものである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう、高速運動体だから、人間の目には見えないというのか。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然そのものには色もなければ、それ自体厳密にいうならば分子構造の運動体の集合にしか過ぎない。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしダンプァーが絃の振動を一瞬間に止めたとしても、ピアノには響板というも一つの振動体がある。",
              "citation": {
                "source": "音楽界の迷信",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃緑の扁平な蛇類は無害にも水泳する硝子の流動体は無害にも半島でもない或る無名の山岳を島嶼の様に流動せしめるのでありそれで驚異と神秘と又不安をもを一緒に吐き出す所の透明な空気は北国の様に冷くあるが陽光を見よ。",
              "citation": {
                "source": "LE URINE",
                "author": "李箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち天地開発に連る国土の自然形成の神話にして、泥土状の半流動体的状態より、次第に凝集固結して、完全具足するに至りしまでの間を、前後四段に分ちて、各の状態を神格化して、其生成力を男女性の両面より、各々一個の神格とし、此の如くにして※生天神四代の系図は、作せらるるに至りしなり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の理論は運動体の光学及び電気学のほとんどすべての知られた現象を、その中にまた今述べたフィゾーの実験をも含めて、全く正しく与えます。",
              "citation": {
                "source": "相対性理論",
                "author": "アルベルト・アインスタイン",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然法則はすべての非加速的体系に関しては同一であると、静止エーテルに関するローレンツの根本仮説は他方に、あらゆる可能な非加速的運動体系のうちで、一定の運動状態のもの、すなわちこの光の媒質に対して静止せる体系を特別に徴しづけます。",
              "citation": {
                "source": "相対性理論",
                "author": "アルベルト・アインスタイン",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つはどこかの大学の学部長か誰かの説明で、卵の内部が流動体であることが一つの理由であろうという意味のことが書いてあった。",
              "citation": {
                "source": "立春の卵",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聖観音には、流動体にもなり得る銅の性質を、まだ十分活かし切らない点があります。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が狐のやうで、わにみたいなどうたいをした、まつ黄色な、きたならしい犬で、そつくりかへつた、へんに大きなしつぽをしよつてゐます。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
