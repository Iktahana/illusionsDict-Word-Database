        "examples": {
          "standard": [
            {
              "text": "救急車のサイレンが近づいてくるときの音と、遠ざかるときの音でドップラー効果を感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "天文学者は、遠方の銀河の動きをドップラーシフトで観測する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このレーダーは、ドップラー効果を利用して物体の速度を測定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ドップラー効果のためテープの音程が上がったり下がったりして、まるで音痴が歌っているような滑稽で耳障りな音楽だ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "前方の星は紫に後方の星は赤に光り、あなたはドップラー効果が正しかったことを目で確認する。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
