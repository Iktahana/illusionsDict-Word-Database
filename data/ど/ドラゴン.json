    "definitions": [
      {
        "index": 1,
        "gloss": "dragon (as depicted in Western myths)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
