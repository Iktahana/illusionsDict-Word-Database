    "definitions": [
      {
        "index": 1,
        "gloss": "fellow student",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このたび、出版業をはじめるさうで、その第一出版を、同門のよしみで、私のこの「パンドラの匣」にしたいと言ふ。",
              "citation": {
                "source": "『パンドラの匣』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう同門下の人たちと先生没後の今日、時おり何かの機会で顔を合わせるごとに感じる名状し難いなつかしさの奥には、千駄木や早稲田の先生の家における、昔の愉快な集会の記憶が背景となって隠れているであろう。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについてはひたすらに読者ならびに同門下諸賢の寛容を祈る次第である。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生けふは三十日――あしたは晦日――今夜でも小布施さんにお金を持つてつてあげないぢや」　小布施は桂子の遠い親戚の息子で、もと桂子が画を習つてゐた時の同門でもあつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不遇傲岸に見える小布施は、案外、時流に神経質で、十六七年も前桂子と同門で矢来町のＹ――先生の画室に預けられてゐた時分から、逐次独立するまで、後期印象派、ダヾ、表現派、新古典、超現実派と、およそ日本で尖端的に見える画風は魁けしてこれを取り入れ、通俗派の方面にぶつかつて行つた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会す　我が　同門の友、言笑　一に何ぞ※ある。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――月府玄蝉――上杉先生が、糸七同門の一人に戯に名づけたので、いう心は月賦で拵えた黒色外套の揶揄である。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……同時に、時々の出入りとまでしばしばでなくても、同門の友輩で知合ってる糸｜的が、少くとも、岡惚れを。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の同門に松浦｜愚という少年が居った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲の主人は、館花浪路と云ふ老人で、井上八段の門下で、幸田露伴先生とは同門だつた。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻もご同門ではあり、芸術家です、どんなに、その愛情が灼熱的であろうか、と期待しましたのに、……どうも冷たい。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが乗り込んできた本流のコンピューター屋が作ったＰＣ―９８０１と同門のガチンコ勝負となって、破れ去った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この霊屋の下に、翌年の冬になって、護国山妙解寺が建立せられて、江戸品川東海寺から沢庵和尚の同門の啓室和尚が来て住持になり、それが寺内の臨流庵に隠居してから、忠利の二男で出家していた宗玄が、天岸和尚と号して跡つぎになるのである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "鄭玄（中国、後漢の儒学者・訓詁学者）は云う、「同門の者を朋と云い、志を同じくする者を友と云う」と、師を同じくして教えを受け、願いを同じくして術芸を習い、道を同じくして学問に従い、志を同じくして徳の向上に努める、このような環境において人は自然と朋友助け合い、切磋琢磨して次第に成長を遂げる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（曽子｜曰く、夫子之道は、忠恕而已矣）　曽子が同門の人の問に答えて、夫子（先生）の道は忠恕のみ、と言われたのである。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはほかでもない惣八郎と甚兵衛とは、兵法の同門であった。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「惣八どのと甚兵衛どのとは、腕前においていずれが上じゃ」などいう懸案が同門の間に、提出せられるたびに、惣八郎は「われらがごとき」といって謙遜した。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "曼舟氏は義足をつけて、同門の人達と一緒に日本アルプスへ写生旅行に立つた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父が若い時分、撃剣の同門の何とかといふ男が、あまり技芸に達してゐた所から、他の嫉妬を受けて、ある夜縄手｜道を城下へ帰る途中で、誰かに斬り殺された。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは芸術の立場が違つてゐるせゐもあつたが、同じくＯ―先生の息のかかつた同門同志の啀み合ひでもあつた。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女中ともつかず、内弟子ともつかず、働く人として弟子入りをした」と同門の令嬢たちが夏子の身分をことこまかに区別して観察しているところを考えれば、弟子というのは、十分な月謝や食費や衣類調度をもって師匠の許におき臥しする令嬢を云い、夏子の父は娘のためにそれだけのことはしてやれなかったのだと思われる。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、花圃に向ってしねくねとしながらの言葉づかいにしろ、同門の先輩への敬意というばかりで、ああいう口調になったのだろうか。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その燃える焔が、日記のなかで有名になっている花圃への罵倒となって迸り、同門の田中という女に、同じけがれとしても万人のすてた此人にせめては歌道にすすむはげましだけはと気負って表現されたりしているのだと思える。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宅花圃と樋口一葉とは、近代日本にとって先駆的な同時代の婦人作家、同門の出身、その上対蹠的な境遇ということから、常に照しあわせ対立してみられて来ている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四のとき、当時米国から帰朝した同門の田村松魚と結婚する迄の俊子は久米八と同座したり川上貞奴の許に出入りしたりして女優生活を送りながら、新しい時代の文学の空気の中に生きていたのであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "且、その當時は、石部金吉の名で通つてゐただけ、同門婦人の間に評判がよく、その一人の如きは、渠が北海道の故郷に歸つたのを追ツかけて來て、慇懃を通じようとしたが、渠にはね附けられてしまつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "また後に莫逆の友となった小島成斎も、夙く市野の家で抽斎と同門の好を結んだことであろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "信階が武氏に学んだ時、同門に豊後国大野郡岡の城主中川修理大夫久貞の医師飯田休庵｜信方がゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "同門の友人｜樺島石梁がこれに銘し、阿部侯｜椶軒が其面に題した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "長孺、仲彜の事は凹巷の五古に、「幸為同門友、一朝接清規、（中略、）有時過我廬、吟興黙支頤、（中略、）憶曾長孺宅、邀君奏、豪爽人倶逝、長孺及仲彜」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
