  {
    "uuid": "a57a0474-47f2-549c-93cd-218bae23ee83",
    "entry": "洞門",
    "reading": {
      "primary": "どうもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cave entrance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "豐室、洞門、連房、飛閣。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左岸の城山に洞門を穿つのである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは洞門に入る。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは引返して、洞門をくぐると、二台の計量機の前に出た。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その洞門のうがたれつつある巌壁の前には黄の菰莚、バラック、鶴はし、印半纒、小舟が一、二｜艘、爆音、爆音、爆音である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日に比して少からず減じた水量のために河中の巌石という巌石は、ことごとく高く高くせり上って、重積した横の、斜の斧劈も露わに千状｜万態の奇景を眼前に聳立せしめて、しかも雨後の雫は燦々と所在の岩角、洞門にうち響きうち響き、降るかとばかりに滾れしきる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "は恠みながらその声をしるべにしてあがって往くと、大きな洞門があって、その前の花の咲き乱れた木の下で、数十人の美女が蝶の舞うように歌い戯れていた。",
              "citation": {
                "source": "美女を盗む鬼神",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "露けく茂りたる蔦の、おほいなる洞門にかゝりたるさまは、カラブリア州の谿間なる葡萄架を見る心地す。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "媼は痩せたる臂さし伸べて、洞門を掩へる蔦蘿の帳の如くなるを推し開くに、外面は暗夜なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには洞門があつて街道が通じてある。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞門をくゞつて行くと平潟の入江に似て更に小さな入江がある。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い洞門をくゞれば直ぐに磐城の国であるといふことが散歩の度に私の興味を湧かせるのであつた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "又洞門が暗い口を向けて居る。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "引つ返して駈けて来ると提灯が洞門の方へ向つて走せる。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞門からも提灯が走つて来る。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も洞門に向つて進んだ。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "下駄の音が洞門の内側に響いてこん／＼と鳴るのを聞いた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は洞門をくゞつて又九面まで行つて見た。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道はこゝで一切のものを蹙めて山を穿つた洞門へ導く。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞門は闇くして且つ恐ろしく長い。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞門を出るとそこには豁然として壯大な出羽の國が展開する。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾個の洞門を過ぎ盡して、磐城に出づ。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おゝ好い」　かう女が言つたので、気が附くと、軌道車は既に美しい鮎返りの瀑を前にして、今しも樋田の洞門にかゝらうとしてゐた。",
              "citation": {
                "source": "耶馬渓の一夜",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そら、そこの洞門の中を歩いて通つて行くんですよ。",
              "citation": {
                "source": "耶馬渓の一夜",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処に青の洞門があり、彼処に羅漢寺があり、またその一方に柿坂のやうな、いかにも山の宿駅らしい部落があるといふ形が面白いのであつた。",
              "citation": {
                "source": "耶馬渓の一夜",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞門の開鑿を統領しているといえば、五十は過ぎているとはいえ、筋骨たくましき男であろう。",
              "citation": {
                "source": "恩讐の彼方に",
