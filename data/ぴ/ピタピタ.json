[
  {
    "uuid": "c8e2d11a-6ff3-50bc-8d48-16a4b7cc42e6",
    "entry": "ピタピタ",
    "reading": {
      "primary": "ピタピタ",
      "alternatives": [
        "ぴたぴた"
      ],
