        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると耳に手をあてゝ、わああと云ひながら片足でぴょんぴょん跳んでゐた小さな子供らは、ジョバンニが面白くてかけるのだと思ってわあいと叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い農夫は、も一度自分の腕時計に柱時計の針を合せて、安心したように蓋をしめ、ぴょんと土間にはね降りました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」三郎が、河原の砂っぱの上で、ぴょんぴょんはねながら、高く叫んだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばしっこい火箸のような、痩せッこつの七五郎が、板の橋を渡って公会堂に様子をさぐりに、ぴょん／＼はねとんで行った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると耳に手をあてて、わああと云いながら片足でぴょんぴょん跳んでいた小さな子供らは、ジョバンニが面白くてかけるのだと思ってわあいと叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると耳に手をあてて、わあわあと言いながら片足でぴょんぴょん跳んでいた小さな子供らは、ジョバンニがおもしろくてかけるのだと思って、わあいと叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一本のくるみの木の梢を、栗鼠がぴょんととんでいました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで鹿はみなぴょんぴょん跳びあがりました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い農夫は、も一度自分の腕時計に柱時計の針を合せて、安心したやうに蓋をしめ、ぴょんと土間にはね降りました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」嘉助が河原の砂っぱの上で、ぴょんぴょんはねながら高く叫びました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ん坊でもちょうど蛙か何かのように足をつかまえてぶらさげてぴょんぴょんとはねさせるのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん　からり　足を踏み違えて橋詰から橋詰までこの音のリズムを続け通させるときは、ほんとにお腹の底から橋を渡った気がして、そこでぴょんぴょん跳ねて悦んだ。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとき私が橋を渡り終えて悦んでぴょんぴょん例の小躍りをしていると、突然その木の蔭から汚ない服装の男が飛び出して私を捕えた。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした又会うぜ」そして片脚で、ぴょんぴょん跳ねて、人ごみの中にはいってしまいました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
