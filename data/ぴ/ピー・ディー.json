    "definitions": [
      {
        "index": 1,
        "gloss": "producer (film, TV, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ＰＤＡと総称される携帯用の機器では、もっぱらテキスト版が読まれている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとはＰＤＡ向けに開発された、青空文庫のルビ記号に対応したビュワーを組み込んだ携帯電話もある。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカリーによれば、アップルは第二のルートから産み出す一群のこうした機器を、パーソナル・デジタル・アシスタント（ＰＤＡ）と呼んでいくという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルは複数の大手家電メーカーと協力して、今後ＰＤＡの開発を進めていくという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に出てくるＰＤＡは、前項の言い訳で触れたニュートンになるようで、これをアップルは一九九三年の一月には売りだしたいと考えている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルはＰＤＡという名前の言い出しっぺになったが、マイクロソフトも同じような観点から家電への進出を狙っている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "80は使用するマイクロコンピューター、インテル社のｉ８０８０のセカンドソースとして日電が作っていたμＰＤ８０８０Ａから付けられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがディジタルイクイップメント（ＤＥＣ）という新興の小型コンピューターメーカーが出したＰＤＰ―８と名づけられた機種は、検査装置のコントロールに用いるのにぴったりだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＣテスター用に導入したＰＤＰ―８には、詳細な回路図が添えられていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "後藤は上司の渡辺に諮って、ＰＤＰ―８を作ることを一時期真剣に検討していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ時期、日本電気のコンピューター部門が同等の性能を持つミニコンピューターを開発したことから、ＰＤＰ―８の自作は実行されなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが後藤はＩＣテスターの開発を通じて、ＰＤＰ―８を自分自身で独占することのできる「パーソナルコンピューター」として徹底的にしゃぶりつくしていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＣテスターを担当していた時期、回路図があるのならと後藤はＰＤＰ―８を作ることを考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＤＰ―８をしゃぶりつくした経験は貴重だったが、製品を一から開発したいという願いはみたされなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテルの８０８０と互換性を持った日本電気製の八ビット・マイクロコンピューター、μＰＤ８０８０Ａを使うことを前提に後藤が設計図を書き、必要な部品を集めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "μＰＤ８０８０Ａを使った組み立てキットは、トレーニングキットを略してＴＫ―80と名付けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "回路図と首っ引きになってＤＥＣのＰＤＰ―８をしゃぶりつくした経験を持っていた後藤は、システムを理解してもらううえで情報の公開がいかに大きな意味を持つかを痛感していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした一行の目の付けどころに彼らがどんなに驚かされ、また喜んだかは、この段階ではまだ遅れ遅れの発行となっていた『ＤＤＪ』の一九七六年五月号に、「ＪＩＰＤＥＣ ＶＩＳＩＴ ＰＣＣ」のタイトルでまとめられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで学校はＤＥＣのＰＤＰ―10を持っていたゼネラルエレクトリックと交渉し、使用時間に応じて料金を支払う契約を結んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイクサイドスクールでは、テレタイプは電話回線を通してゼネラルエレクトリックのＰＤＰ―10に接続され、タイム・シェアリング・システム★によって割り振られたマシンの処理能力を同校から利用できるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＣＣのＰＤＰ―10には面白そうなプログラムがたくさん詰まっていることを発見した彼らは、システム中をしらみつぶしにあたり、使用権のないプログラムに手を出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＤＰ―10のシステムには、こうした脇の甘さやバグが数多く残されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年たちの熱中ぶりに手を焼いたＣＣＣは、もともと弱みを残しているＰＤＰ―10のシステムを徹底的に洗いなおすために、逆に彼らを利用することを考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＣＣはＰＤＰ―10の購入に際して、システムソフトウエアのバグを継続的に発見しているあいだは代金の支払いを猶予するという契約をＤＥＣと結んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年たちは好きなだけコンピューターを使ってよいという夢のようなチャンスをとらえて、ＰＤＰ―10にのめりこんだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでアレンは、大学のＰＤＰ―10を使って８００８の働きをそっくりそのままシミュレートするプログラムを書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲイツはＰＤＰ―10の上に仮想的に再現された８００８を使って、交通データ解析プログラムの開発に取り組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＤＰ―10にはまともな端末装置がつながっており、エディターと呼ばれる編集ソフトもそろっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "地域の電力使用量に対応して、水力発電所の発電量を自動的にコントロールするシステムの開発を地方自治体から請け負っていたＴＲＷは、使用するＰＤＰ―10のシステムソフトウエアのバグに悩まされ、この環境に習熟したプログラマーを求めていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニュアルを手に入れ、アレンが大学のＰＤＰ―10で８０８０をシミュレートするプログラムを書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
