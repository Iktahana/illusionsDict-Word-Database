        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、グリル・チキン、スパゲティ、ピカタ、アントレコット等、行く度に色々食ったものであった。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィルピカタとグリンピース、コンビネーション・サラダ食って出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランチだけでは足りないので、ヴィル・ピカタをとる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴルとオニオングラタンとビーフピカタ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマトクリームスープ、コールド・ラブスター、ヴィル・ピカタ、ゼリー、満腹。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタージュ、ビールピカタ、グリンピースに、アプルパイ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマトのポタージュと、ピカタとドリアを一人前宛とったので、もう皆満腹。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事、ビールピカタ、スライスチキンサラダ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤山と会ひ、食事、にほひがしなくてうまくない、トマトクリームスープ、ピカタ、ピラフにアスパラガス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためコンソメ、ヴィール・ピカタにアスパラガス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタージュ、サワラのグラタン、ヴィルピカタ、サワラのみうまし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "会の後アラスカへ席が取ってあり、ポタアジュとチキンピカタ等食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルネへ行く、定食が、Just My Size で、トマトクリーム、フィレソール・ノルマンディ、ヴィル・ピカタ・ミラネイズ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
