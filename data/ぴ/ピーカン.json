        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが、着いたものゝ、ピーカンなるにもかゝはらず、撮影は無しださうで、何だアといふ感じ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日で僕の出るとこはオールチョンの筈、いゝ塩梅にピーカンの好晴だ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時すぎ出る、ピーカンの好晴。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
