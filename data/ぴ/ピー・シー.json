      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "personal computer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五　すみれ娘　日本の近代映画でも、ＰＣＬの提供するものの中には色々な点で有望な進歩の動向を示しているものがあるように思う。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主役に据えたＮＥＣはその後、16ビットに移ってからもＰＣ―９８００シリーズを大成功させました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その市場独占の経過をたっぷり見てきた後で再刊するのなら、せめて長めの後書きを用意して、ＰＣ―９８０１が市場を制覇する、その後の流れにも触れておきたい。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＰＣ―９８０１の成功の軌跡をさらりと跡づける」くらいの気持ちではじめてみると、話を聞かせてくれたある人が、驚くような手がかりを与えてくれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＰＣ―９８０１にとって社内のライバルのような立場にあったＰＣ―１００という機械を作るときには、「パーソナル・ダイナミック・メディア」を作ろうと、はっきり意識していたと言います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―１００を知らなかったわけではありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の事業の責任者に、「ＰＣ―９８０１にＰＣ―１００と二つの16ビット機がぶつかって、売りにくくはありませんか」と、図式的な質問をした証拠が残っています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "再取材でそのコメントに巡り合って、ＰＣ―１００をＰＣ―９８０１の横に置き、二つの対抗関係を軸に流れを見ていけば、一九八〇年代に起こったことが良く見えるだろうと気付きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "筺体も付いていない、基板むき出しのアップル※の互換機やＰＣ―９８０１、シンセサイザーなどでうまった下宿に、さっそく上がり込んできた元気のいいオヤジは、人なつっこそうな笑顔をはさみながら話し始めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前のきっかけとなったのは、ＰＣ―９８０１用に書いたハイパーカードを動かすための環境でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら自分でと、日本の標準機のような地位を占めたＰＣ―９８０１で、ハイパーカードを見られるようにするソフトウエアを作ろうと考えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―９８０１という日本独自の規格が幅を利かせていたところに、一九九〇年代に入って世界の標準仕様がなだれ込んでくると、日本の企業からはソフトウエアに関する新しい試みがほとんど生まれなくなりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校三年の時、友人の兄がＮＥＣのＰＣ―８００１を持っていると耳にします。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "設計のいろはをここでたたき込まれる一方で、会社に転がっていたＰＣ―８００１を使って収支計算を処理するプログラムを書き、これがきっかけになって、設計のかたわら業務のコンピューター化を仰せつかります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その会社を代表するＰＣ―９８０１は、日本でも大きな勢力圏を築いたＰＣ互換機と同様に、ウインドウズを採用しています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし名前だけはＩＢＭらしく、これぞパーソナルコンピューターとふかしをかまして「ＰＣ」と偉そうなのを付けた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが実際強面には出てみるもので、ＩＢＭ　ＰＣは出した当人も泡を食うほどの大ヒットとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＰＣの大成功が、複数の規格が並立していたパーソナルコンピューターを標準化することになった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが効いて、やがて他社はＩＢＭ　ＰＣと同じ機能を持つ互換機を作りはじめた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字や数字を処理するためのアプリケーション・ソフトの開発はＰＣの採用したＭＳ―ＤＯＳという基盤の上で集中して行なわれ、パーソナルコンピューターは見る間に役に立つ道具に化けていった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ＩＢＭは、ＰＣ　ＸＴという新機種を出し、さらに改良を進めてＰＣ　ＡＴを出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＰＣ　ＡＴの時代になると、アメリカ国内だけでなく日本やＮＩＥＳのメーカーが、よってたかって互換機を作りだした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでＰＣ　ＡＴを捨て、今度はポイントを特許でガードしたＰＳ／２（二番目のパーソナル・システムというわけだ）に切り替えて互換機を振り切ろうという魂胆だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに九千七百円の軽快なＸウイング・ファイターで突入を図り、ＰＣ宇宙の解放を目指すというビル・スカイウォーカー・トッテンは、ではそもそもいずこよりきたりしか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の値段の高い東京のそれでなくても狭いオフィスに、あんな図体のＰＣが何台入るか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
