[
  {
    "uuid": "ca529d55-8540-5544-bf09-72e4286f7b69",
    "entry": "ＰＣ",
    "reading": {
      "primary": "ピー・シー",
      "alternatives": [
        "ピーシー"
      ],
      "is_heteronym": false
    },
    "grammar": {
