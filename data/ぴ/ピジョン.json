        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "プットバリーの講師にレヴェレンド・シメオン・ピジョンと云う人があった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も※に対して、ピジョン氏と同じような経験を有っているからであった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ピジョン講師の説明に拠ると、其昔｜羅馬人が英国へ侵入して来た時に、其一部が戦闘に敗けて此の地方へ逃げ込んで来た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼のピジョン講師の説明した如く、人の目を避けて穴の中に世を送っていたのであろう。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに菓子四十銭、ピジョン一箱で、完全に文無しになりました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飴と煙草―― e.g. 朝鮮専売局の発売にかかるカイダ・マコウ・ピジョンなど・など・など。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピジョン・ホールのような穴へ骨をおさめた。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラシェル、ラシェル、ピジョン！",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらはピジョン・ホールがあり、これは貴族の解放奴隷の遺灰を受け取るためのものである。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
