    "definitions": [
      {
        "index": 1,
        "gloss": "(with a) squirt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
