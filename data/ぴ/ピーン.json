        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しなしなと揺れしなっていた二間余りの細い竹がピーンと張り切って、さながらに鋭利な真槍の如くに、ピタリ、老神主の黒目を狙っているのです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕の出来る者が鳴らすと、同じ鍔鳴りは鍔鳴りであっても、ピーンと冴えて、音が違うのです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "十郎次出家、立たッしゃい」　ぐんぐん引立てて行くと、手もなく投げ込んだと見えて、ピーンと錠前のかかる音がひびき伝わりました。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーン、陶器の割れるその音を、彼はたしかにきいた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば奴は自分ばかりが、そんなにのろのろと草を喰んだり水を呑んだりしてゐるので、私も謀らぬ酔のために喉の乾きに駆られるので、鞍から降りようとすると、直ぐにその気合ひを悟つて、突然ピーンと後脚で跳ねあがつて、メリゴウラウンドの木馬のやうな波型で飛び出したりするので、私は降りる機会さへも見出せなかつた。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これを聴いた松永は、あたしの腕の中に、ピーンと四肢を強直させた。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーンと錠をあけると、鞄が崩れて、ピカピカする手術器械が現れた。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴御殿の玄関に立ち、「ご免」といった声にさえ、ピーンと覇気がみなぎっている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがなア早引、それにしても、ちょっとばかり甘く見過ぎたぜ、お町にかかっちゃア耄碌でも、金の音を聞くとこの島原、ピーンと、一時に正気づくぜ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の胸に、ピーンと響くか響かぬか、それが標準。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "声にのまれて思わずハッとするところへ、右手が後へねじられて、手首がピーンと痺れた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして入口の扉をピタリと鎖し、ピーンと鍵をかけた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーンと壜に割目が入った。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「確かに手応えはあったが、ガーンという音と共に、太刀持つ拙者の手がピーンと痺れて厶る。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると頭上に天地が一時につぶれるような音がして、彼の頭はピーンといった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に綱を握っている手に、ピーンと手応えがあった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くはピーンという高い唸音の世界に迷っていて、なにが何だか分らなかった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッとしてその場にピーンと棒立になったその前を丸まった新聞紙が小馬鹿にしたように、風に煽られて通りすぎた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供「ピーンていった」と小さい声で答えた。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車が小砂利をとばし、車輪に当ってピーンとそのとき鳴ったのだ。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーンと弦音がしたかと思うと、谷底から悲鳴が聞こえて来た。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その火の玉というのは、犯人が被害者の隠している金を探している懐中電燈の光りじゃなかろうか……といったような想像が、直ぐに頭へピーンと来た。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの港に着くまでに石炭が足りるか足りないかといったような問題まで、同時にピーンと来るんだから、あの指針一本がナカナカ馬鹿に出来ないんだ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをやられるとなにかの機勢で腕がピーンと指の先までしびれ、心持が悪いと云ったらない。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り下ろす刃は、ピーンと、弾き返されるような気がした。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
