        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ときに、ペルー名物のピスコ酒およびパルタ果を供せらる。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピスコ酒は砂糖にて製したる焼酎なり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前はエピスコパル教会の地下のふた部屋で、そこにはレコード・プレーヤーと球突き台とがあった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
