        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鴉が下りて来て牛の脊中の赤い紙を牛肉と思ってつつくと、牛は蠅でも追う気でぴしゃりと尻尾ではたく、すると摺粉木の一撃で鴉が脆くも撲殺されるというのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」兵士は、百姓の頬をぴしゃりとやった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大男の張宗昌のぶくぶく肥っている頬ッぺたをぴしゃりとやったれよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからぴしゃりと閉して帰ってきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前編でも同じ人が弟の横顔をぴしゃりとたたくところも同様に、ちゃんと生きた魂がはいっている。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐにまた、ぴしゃりと押入れをしめて、キヌ子は、田島から少し離れて居汚く坐り、「おしゃれなんか、一週間にいちどくらいでたくさん。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いやりもなく荒々しく引戸を開けて、ぴしゃりと締めきると、錠をおろすらしい音がした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、豹吉は雪子に無関心でおれなくなった自分をぴしゃりと横なぐりの雨のように感じて、ふと狼狽した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとあきかけても、またぴしゃりとしまる。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく去来を相手にせず、ぴしゃりと心の扉を閉ざしてしまった。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　笏で、ぴしゃりと胸を打って、「退りおろうぞ。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらぬか、それか、何にしても妙ではない、かようなものを間の内へ入れてはならずと、小宮山は思案をしながら、片隅を五寸か一尺、開けるが早いか飛込んで、くるりと廻って、ぴしゃりと閉め、合せ目を押え附けて、どっこいと踏張ったのでありまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞を膝の上に拡げたままふんふんと聴いていたが、話が唇のことに触れると、いきなり、新聞がばさりと音を立て、続いて箸、茶碗、そしてお君の頬がぴしゃりと鳴った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、私は坂田の青春や自信にぴしゃりと鞭を打たれたのである。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しめた」笑ってると、いきなりぴしゃりとズボンのお尻を叩かれた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鬼だ、鬼だ」　直助は家の内へ飛びこんで、ぴしゃりと雨戸を締めて押えた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、戸をぴしゃりと閉めて、背でそれを押えながら茂作の方を見た。",
              "citation": {
                "source": "雪女",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妖怪に会ったんだい、大変な顔をしてやがったのだ」「へ、大変な顔、どんな大変な顔でござんした」「それがおめえ、恐ろしいの何のって、とても一口にゃ言えやしない」「こんな顔じゃなかったかね」　親爺はぴしゃりと額を一つ打つなり湯気の間から顔を出した。",
              "citation": {
                "source": "狢",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽部は新聞を膝の上に拡げたままふんふんと聴いていたが、話が唇のことに触れると、いきなり、新聞がばさりと音を立て、続いて、箸、茶碗、そしてお君の頬がぴしゃりと鳴った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあと、ホームズが打ち鞭をぴしゃりと当てて、馬車に道をひたすら逆走させる。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズがぴしゃりと言うと、やんちゃ坊主六人は安物の彫像よろしく、横一列に並んだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホープはリヴォルヴァの床尾をぴしゃりと叩く。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚破天窓から押潰すよと、思うに肖ず、二丈ばかりの仙人先生、ぐしゃと挫げて、ぴしゃりとのめずる。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姑さんを貴方の手で、せめて部屋の外へ突出して、一人の小姑の髻を掴んで、一人の小姑の横ぞっぽうを、ぴしゃりと一つお打ちなさい。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都人はこれを料理につかう場合には、生のを茹でて、それを熱湯のなかから取出すと、いきなりぴしゃりと板の間に投げつけるのを忘れない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　与力はいきなりにその横鬢を扇でぴしゃりと撲たれました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、今や肌を入れようとする男の背中を、平手でぴしゃりと叩いたのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "癇癪持ちの教師は平手で横っ面をぴしゃりと食らわすのもあった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども房枝は、直ぐに「青蘭」の二階の気配に気づいてか、キッと敵意のこもった顔をこちらへ向けると、そそくさと立上って窓の硝子戸をぴしゃりと締めてしまった。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、女はきまって、男の膝をぴしゃりと平手で打って、これほど思って苦労しているのにという紋切り形の表情をしてみせた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
