          "literary": [
            {
              "text": "やっぱしピンボケみたいなもの……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝帰りの女の電話を待つのは、ピンボケかポン引ぐらいなもんだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは、『朝日新聞』のコンピューターに関する世界観がピンボケだなどといったいちゃもんも付けようがない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けちくさいのみならず、境遇的ピンボケに思えて残念なり。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざっとよんだだけだけれども、環境の関係か、急所でピンボケのようで、すこし残念でした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ写真機ハレンズガ暗ク、レンジ・ファインダーガ付イテイナイノデ、目測デ写サナケレバナラズ、僕ノヨウナ未熟ナモノガ撮ッタノデハピンボケニナリヤスイ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
