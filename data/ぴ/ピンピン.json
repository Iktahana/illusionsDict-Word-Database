        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼等の細くって長い脚は、強いバネのように、勢いよくぴんぴん雪を蹴って、丘を登っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中津が外から声をかけて門のかんぬきをボーイの王錦華にはずさして、中庭の飛び石を、ひょこひょこやって来る時、窓からそれを見て、やはり、チンバ、チンバと、ぴんぴんはねて笑った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」せつは、畳の上をぴんぴんはねまわって、母の膝下へざれつきに行った。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、ただも一度二本の足でぴんぴん歩いてあの楽地の中の泉まで行きあの冷たい水を両手で掬って呑むことができたらそのまま死んでもかまわないと斯う思うだろう。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑さにもめげずにぴんぴんしたものだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せこの犬ばかりは小十郎が四十の夏うち中みんな赤痢にかかってとうとう小十郎の息子とその妻も死んだ中にぴんぴんして生きていたのだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子兎のホモイは、悦んでぴんぴん踊りながら申しました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで表面はぴんぴんしている。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り駆けたので、体中の脈がぴんぴん打っている。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚さんもわしも同じことをして、わしだけ足がわるくなり、和尚さんはぴんぴんしてゐるぢやねえか。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、濡れてぴんぴんしてゐるえびが数匹はいつてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまが　はげて、くろい　ころもを　きてる　ところは　ジョウフクインの　おしょうさん　そっくりでしたが、まだ　口には　ぴんぴんと　ひげが　はえてたし、ふとい　しっぽも　だらりと　たれて　いました。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも　おひげの　ぴんぴん　はえて　いるのには　きが　つきませんでした。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーブの中に薪がぴんぴんと跳ねているだけだった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその尾が切れて、ぴんぴんとその辺を跳ねまわった。",
              "citation": {
                "source": "首を失った蜻蛉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ阿母でございますか、ええ、ぴんぴんいたしております。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬賊の大将は、がらんとして誰もゐない酒場に、仁王だちになつて、髯を針金のやうにぴんぴん動かしながら『さあ、みんなお金も宝物も出してしまへ。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで大将の首は、家来の首のづらりとならんだ、まんなかで、長い頤髯をぴんぴんと動かして拍子をとつて、にぎやかに合唱をはじめました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚はぴんぴん跳ね、そのあたりの草原をころげまはりました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで大将の首は、家来の首のずらりとならんだ、まんなかで、長い頤髯をぴんぴんと動かして拍子をとつて、にぎやかに合唱をはじめました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこいらから起こる人声や荷橇の雑音などがぴんぴんと君の頭を針のように刺激する。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、大騒ぎしてわいわいと捜していたら、九ツよっぽど過ぎた時分に、腹痛のはずの野郎めがぴんぴんしながらひょっくりと表からけえってきたとこういうんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "午年ゃ景気がぴんぴんはねるというからね、さぞやおひざもともたいした景気だろうと思って、起きぬけに、ちょッくらとばかりないしょでいってみるてえと、――これがどうです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねたを割りゃ、それだけの手がかりさ」　いうと、右門はおれの耳はおまえたちのきくらげ耳とは種が違うぞ、というように、唖然と目をみはっている同僚たちの面前で、ぴんぴんと両耳をひっぱりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "清吉さんはてまえが救い出して、まだぴんぴんしていなさるぜ」「えッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者がぴんぴん歩けるので、看護婦は目を瞠った。",
              "citation": {
                "source": "コレラ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
