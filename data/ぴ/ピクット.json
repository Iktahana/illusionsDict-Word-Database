        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ピクッとかかつたので糸を上げても、どこに魚がかかつてゐるのかも見えなくなつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどとうとうあんまり弟が泣くもんだから、自分も怖くなったと見えて口がピクッと横の方へまがった、そこで僕は急に気の毒になって、丁度その時行く道がふさがったのを幸に、ぴたっとまるでしずかな湖のように静まってやった。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対に動くまいと思いこんでいた不随意筋がピクッと動いたので自分でもびっくりした。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋焼の熱いテンプラを舌の上で、あちこちやっていた河田が、眉毛を急にピクッと動かした。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉は倒れたままちょっとの間ピクッピクッと動いていた。",
              "citation": {
                "source": "人を殺す犬",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ピクッと、ぼろの間から出た男の裸の肩が動いた。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何っ」と先きの男の天秤を持った手が、ピクッと震えた。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "曳金にかかった教授の指が、ピクッと痙攣した。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ピクッと手足をふるわせたようだったが、もろくも、それなり。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "三人目",
                "note": "青空文庫"
              }
            },
            {
              "text": "安積玄心斎……と聞いて、ピクッと耳をたてた。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ご存知なかったんですか」　ピクッと膝を動かした。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お話はよくわかりましたが、あなた方がかんがえていらっしゃるように、そんなに簡単にゆくかしら……」　保羅は、ピクッと神経的に眉を動かして、「こんなところに、三日も四日も僕と一緒に暮らしていたということが評判になったら、あなたのご親族も世間も、正式に結婚することを望むでしょう。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは何か嚊ぎつけてるんじゃないのかァ」　踏絵はピクッと身体を顫わせると急に山木の方へ向き直り、「感づくって、何をさ」「つまり、二人の仲をさ」　踏絵は肩を聳かし、「とぼけるない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
