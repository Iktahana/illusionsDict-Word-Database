    "definitions": [
      {
        "index": 1,
        "gloss": "fixed-gear bicycle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
