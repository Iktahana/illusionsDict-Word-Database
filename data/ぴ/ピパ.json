          "standard": [],
          "literary": [
            {
              "text": "御畳瀬　「ピパ」牡蠣の種類。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば笛のピパに対して弦楽器のピパすなわちビワがあり、弦楽器のタンブールに対して太鼓のタンブールがあるような類である。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラウニングの楽天説は、既に二十歳の作「ポオリイン」に顕れ、「ピパ」の歌、「神、そらにしろしめす、すべて世は事も無し」といふ句に綜合せられたれど、一生の述作皆人間終極の幸福を予言する点に於て一致し「アソランドオ」絶筆の結句に至るまで、彼は有神論、霊魂不滅説に信を失はざりき。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラウニングの樂天説は、既に二十歳の作「ポオリイン」に顯れ、「ピパ」の歌、「神、そらにしろしめす、すべて世は事も無し」といふ句に綜合せられたれど、一生の述作皆人間終極の幸福を豫言する點に於て一致し「アソランドオ」絶筆の結句に至るまで、彼は有神論、靈魂不滅説に信を失はざりき。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの菩提樹は梵語ではピップラといい、ヒンドスタン等ではピッパル、ピパルあるいはピプルと呼ばれるとの事だ。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
