        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その頃の羅宇屋は今のようにピーピー汽笛を鳴らして引いて来るのではなくて、天秤棒で振り分けに商売道具をかついで来るのであったが、どんな道具があったかはっきりした記憶がない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦笛を吹くような声でピーピーと鳴き立ててはベランダの前へ寄って来て、飯の余りやせんべいの欠けらをねだるのである。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電信柱と黒雲夢野久作　電信柱が寒い風にあたってピーピーと泣いておりました。",
              "citation": {
                "source": "電信柱と黒雲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々小鳥のようなピーピーという泣き声を出しながらも負けずにかみつき引っかくのである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小さな頭をあげて、「ピーピー。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「ピーピー。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "『松屋筆記』五に浅草観音に鶏を納むるに日を経れば雌鶏必ず雄に変ず、仏力にてかくのごとしとあるが、霊境で交合したり雛を生み、ピーピー走り廻られては迷惑故、坊主が私かに取り替えたであろう。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたゞ無暗に口笛をピーピーと吹き鳴らして自分で自分をごまかしました。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを両方から押えるから、ピーピーと世間が成り立って行くのだ」　そのつもりで東京人の商売振りを観察して見る。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二ツの理想が彼等を刺戟している間に、彼等はいつまでもピーピー風車でいなければならぬのである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、たゞ無暗に口笛をピーピーと吹き鳴して自分で自分をごまかしました。",
              "citation": {
                "source": "晩春の健康",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、何でもありませんよ、――人間だよ、二十九歳の――」　彼は、庭に眼を放つて、ピーピーと口笛を吹いた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "破壊的とは何かと言うと、われわれはもう既に三十年後の世界最後の決勝戦に向っているのでありますが、今持っているピーピーの飛行機では問題にならない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お前みたいなピーピー銀行員なんか勿論そうだよ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーピーつづけざま呼笛が鳴る。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ耳が潰れるほどキーキーピーピー云うだけですもの。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ピーピーピーピー今日は。",
              "citation": {
                "source": "トントンピーピ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きまりわるさにピーピーピー　トントンピーピーなきだした。",
              "citation": {
                "source": "トントンピーピ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」トントンピーピーのわるとびは、あめにぬれぬれからかさを、さがしたけれど、からかさは、こすゞめすゞめのやぶのなか、やぶのなか。",
              "citation": {
                "source": "トントンピーピ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しくてピーピー泣いてゐました。",
              "citation": {
                "source": "耳長さん　と　あひるさん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも我々は、さてここはよい、一休みと思うところでヒョーローにつまってピーピーしはじめる。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎一度もまともな声を出さず、ピーピーしている。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあの人ピーピーで写真かえなかったでしょう？",
              "citation": {
                "source": "日記",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○大劇場横でピーイピーピー横長いゴム風船を売ってる。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつものデンでいきなりマンマクを張って一家を占領しドンチャカピーピーお祈りをやりだしたから、怒ったのは宿主だ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラ　　さういふ時、お袋の顔をみると、子供はなほさら、ピーピー泣いてみせるもんだ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            }
          ]
        }
