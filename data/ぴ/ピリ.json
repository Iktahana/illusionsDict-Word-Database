      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "period (interval of a game)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アスピリンをどっさり呑めば、けろっとなおるのだが。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「物質的」に「精神的」は圧へられてゐるので、精神はスキマからチヨツピリ呟くから神秘的に見えたりするけれど、もともと東洋で精神は未だ優遇されたことはない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか、仲間が一人来る、二人｜蹤いて来る、岩の上には、黒いピリオドが、一点、二点、三点――視線は一様に、鼠色のそれに向う。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬の山と幾分か軽く視て、雪中の登山服装というほどの準備もしていなかったため、幾重の衣も徹されて、腹から股にかけ、薊で撫で廻されるような疼痛を感じ初めた、唇はピリッとして、亀裂するかと惑われ、その寒さにわなわなと骨髄から震動した。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "またマヤコフスキーとレーニンとピリニヤーク、パステルナックの、新刊書で埋れた。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた何かの小言でも聞くのかと思つて、軍曹の鼻の下にチヨツピリ生えた口髭を眺めてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう場合、嫌疑が、すぐ自分にかゝって来ることを彼は即座に、ピリッと感じた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく今日のいわゆるファイティング・スピリットの旺盛な勇士であって、今日なら一部の人士の尊敬の的になったであろうに、惜しいことに少し時代が早過ぎたために、若きウェルテルやルディン達にはひどく毛嫌いされたようであった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへのアメリカの策動が、どんな意味を持っているか、それは日本人なら、云わずとも、すぐ神経にピリッと来る筈だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唇がピリッとしてからだがブルブルッとふるひ、何かきれいな流れが頭から手から足まで、すっかり洗ってしまったやう、何とも云へずすがすがしい気分になりました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡瓜揉みを命じたところが、怪し気な女が出て来て大皿の中にチョッピリ盛り付けたのが、驚くなかれ代価四十銭。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじく大學の學生で暑中休暇に歸省して、糠鰊……易くて、量があつて、舌をピリヽと刺戟する、糠に漬込んだ鰊……に親んで居たのと一所に、金澤を立つて、徒歩で、森下、津幡、石動。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフェ・ピリケンの前にひとり、易者が出ていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ピリケンの三階にある舞踏場でも休みなしに蓄音機を鳴らしていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピリケンの横丁へ折れて行った。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉が雪子に興味を抱いているらしいことは無論知っていたが、しかし、はっきり豹吉の口から聴いてみると、改めて嫉妬があり、「ただでは済ませるもんか」　という自尊心のうずきが、お加代の額にピリッと動いた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "描かれた人間の肢態がふに落ちず、好奇心でじっとながめていたが、彼等がその画とお君とを結びつけるいまわしい説明をきかせた瞬間、豹一の蒼白い眼は勢一杯の敵意を託されて血走り、やがてピリ／＼と画が破られた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "』エミ子さんは癇癪をピリピリさせて、可哀相なピアニストを叱りつけました。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖の方の水は蒼黒く小さい紆りを立てていて、水温も途中から俄かに変って肌がピリピリする程だった。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここにアスピリンと書いてあってよ――」　こころみに噛んで味ってみる迄もなく、なる程アスピリンに違いなかった。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體父は、余り物事に頓着せぬ、おつとりした、大まかな質でありながら、金といふ一段になると、體中の神經がピリ／＼響を立てて働くかと思はれるばかり、遣口が猛烈となる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉が波打ってピリピリと逆立った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前の電柱に片手を支えると、その掌に、照りつけた太陽の熱がピリピリと泌み込んだ。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は日に焦けた顔にチョッピリと黒い髭を生やして、薄鼠色のインバネスを着ていたが、新しい麦稈帽を阿弥陀に冠り直しながら、昂作の顔を覗き込んだ。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、青春の感激だとか、若人の誇りだとかいう言葉は、聞いて寒気がして来て、とても、あの、ハイスクール・スピリットとかいうものには、ついて行けなかったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
