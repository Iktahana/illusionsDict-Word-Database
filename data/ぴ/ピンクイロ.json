        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シュタイン会社製舞台化粧用の三番ピンク色のパフを、はたいてもはたいても、細い泪が溝をつけてしまいます。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、夕｜靄は、ピンク色。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日の光が靄の中に溶けて、にじんで、そのために靄がこんなに、やわらかいピンク色になったのでしょう。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かに頭をめぐらすと、淡いピンク色のシュミーズ一つで、朱塗りの鏡台を光線の都合を計って、畳の真中に持ち出して、化粧をしている美和子の姿が、ピチピチした新鮮な、一枚の油絵のように眺められた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "このほのかなピンク色の魚鱗、中国の極めて独特な特徴です。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう六十ぢかい太った老紳士の腕を、その横からピンク色の洋装のうつくしく身についた若い女が支えて、ブリッジをのぼってくる。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くも彼女の手には、ピンク色の絹のハンカチーフが丸まって握りこまれていた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "御約束のセンセイの原稿を頂きにまいりました、ハイ」　――それを考えると梅野十伍は自分の顔の前で曲馬団の飢えたるライオンにピンク色の裏のついた大きな口をカーッと開かれたような恐怖を感ずるのであった。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "街頭劇名監督　少々荒療治ではあったが山木断髪令嬢の愛犬｜ＵＴＡを中心として渦巻くピンク色ローマンスの半分は、これで片付いたようなもんだ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家根は黒く車体は緑で、そうして柱はピンク色であった。",
              "citation": {
                "source": "畳まれた町",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は蒼白の顔をして（曾はそれは活々としたピンク色を呈していたではないか。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには思いがけなくもピンク色のワン・ピースを着た背の高い若い婦人が立っていた。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "深山理学士は早くもこのピンク色の物体が発散するものに当惑を感じた。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山桜がいいピンク色にぽうっと山の中腹に目立つようになると、もう三月春分の日は過ぎる。",
              "citation": {
                "source": "山の春",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このピンク色の世界に住むこともずゐぶん苦しいけれど、びんばふだからいざ死なうといふ気にはなれない。",
              "citation": {
                "source": "赤とピンクの世界",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法悦の夢想境　曲目は進んで五彩のスポットをあびて、ピンク色のイヴニングに大輪の紅バラを胸に、メリー大須賀歌手が、艶麗な姿でマイクにころばす、ナイヤガラのメロディー、いつとはなしに暗い客席に合唱となって伝わりくるこの興奮は、かつて見たことのない雰囲気ではないか。",
              "citation": {
                "source": "ジャズ狂時代",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳髱はいつもピンク色であった。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし机の上に小さなピンク色の灰皿があった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "１ポンドの新鮮または保存したイチゴおよびコチニール（＝カルミン：赤色色素）を入れると、ピンク色のシャンパンができる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "７．赤色のうちで61標品は主として有機的なピンク色素のコチニール（Coccus Cacti）で着色されていた。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピンク色に光った鼻は、ごろごろと床をころがっていった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "狩屋愛子は十八になったばかり、新鮮で清潔で、ピンク色のコスモスの花のような少女でした。",
              "citation": {
                "source": "九つの鍵",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピンク色の人絹のワイシヤツ、紫色のネクタイ、繭紬のビヂヤマ、支那の商人が売れても売れなくとも一向自分には関係のない様な顔をして突立つてゐる。",
              "citation": {
                "source": "上海の絵本",
                "author": "三岸好太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピンク色のエヴニングが、朱のバンド、ウエーブした毛が五光のように隈取って、その美くしさというものはありません。",
              "citation": {
                "source": "笑う悪魔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛らしいピンク色の唇が、心持ち顫へてをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "影法師",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピンク色の洋装に、綾糸で編んだ美しい帽子を冠って、心も空に絵を描いていた夫人が、描いた絵と、真物の海とを見比べる積りで、うっかり欄干にもたれて反身になった時――誰も見て居たわけではありませんが、夫人がよく斯んなポーズを取るのを、雇人達や夫の三郎氏が心得て居たのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "第四の場合",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鶴は、次郎のそんな仕草にはちっとも気がつかないで、相変らず草の葉を刻んでは、せっせとそれをブリキ罐の中にためこんでいたが、永いこと陽に照らされて、ピンク色に染まったその頬の上に、鮮かに浮き出したお玉杓子が、次郎の眼には、いかにも血がかよって動いているように見えたのである。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、薄いピンク色のクレプデシンのワンピースの、腰の所を青いエナメルのバンドでグッとしめつけているため、からだの線が急に大人びて見えた。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにですね、家から一町ばかり離れた燒跡の草の中に、芙佐子の着ていたピンク色のワンピースがズタズタに破られて、捨ててあるのを家内が見つけました。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはたぶん赤でなくピンクいろぐらゐのびんばふなのだらう。",
              "citation": {
                "source": "赤とピンクの世界",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
