    "definitions": [
      {
        "index": 1,
        "gloss": "hot-blooded man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
