        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "長い間名主をしてゐたお祖父さんは、酒呑みのれふしがおかみへ納める税金を持つて来ないときに、かういふ顔でねめつけることを栄蔵は知つてゐる。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツンツルテンでよかったな」「交通安全じゃあるまいし、そんなの穿いてたら、一キロさきからだって見つかるね」　ツンツルテンという事実誤認に対する反論は放棄し、慶一は高志のオレンジ色のトランクスをねめつける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真は撮れまいけれど一所に遊ぶことくらいはできるだろうと思って、試みに小さい声で呼んで見るが、恐ろしく眼を円くして、ちょっとねめつけるくらいが関の山で、立ち止って見ようともしない。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "剛兵衛はなんのこの若ぞうがといったようすで、樫棒をななめにかまえてねめつける。",
              "citation": {
                "source": "だんまり伝九",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「留公、ビールだよ」とお秀はしゃがれ声でどなる、「さっさとしねえのかい、のろのろもたついてるんじゃねえよ、わかったかい」「メンチボールつったろう、留」とお秀は眼を三角にしてねめつける、「なんだいこりゃあ、コロッケじゃねえか、まぬけだねえ取っ替えといで」　客がそれでいいと云う。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠居は、気づいて、「汝か、悪戯したのは」　と、白い眼で、城太郎をねめつける。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
