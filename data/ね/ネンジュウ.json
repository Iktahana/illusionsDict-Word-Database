    "definitions": [
      {
        "index": 1,
        "gloss": "whole year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを味はふことなくて、年中ゲエテとダンテでは、実以て何のことやら分らぬのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が年中で一番｜厭な時候が再び来て暗闇阪にはまたやもりを見るようになった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも二年生のとき牛頓祭という理科大学学生年中行事の幹事をさせられたので、それが頭にあったためかもしれない。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹後の濱の大漁踊りみたいな馬鹿騷ぎを年中やつてゐるのが龍宮だなんて陳腐な空想をしてゐたんぢやねえのか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも山の高低や、緯度の如何に随って雪の多少はあるが、高山の麓になると、一年中絶えず雪を仰ぎ視る事が出来る。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間もなくそれが常習的年中行事となると、今度はそれが大きな苦労の種となった。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく我儘であるくせにまた甚だしく臆病な彼は、自分で断然年賀端書を廃して悠然｜炬燵にあたりながら彼の好む愚書濫読に耽るだけの勇気もないので、表面だけは大人しく人並に毎年この年中行事を遂行して来た。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風雪というものを知らない国があったとする、年中気温が摂氏二十五度を下がる事がなかったとする。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は新春の屠蘇機嫌からいささか脱線したような気味ではあるが、昨年中頻発した天災を想うにつけても、改まる年の初めの今日の日に向後百年の将来のため災害防禦に関する一学究の痴人の夢のような無理な望みを腹一杯に述べてみるのも無用ではないであろうと思った次第である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠅がばいきんをまきちらす、そうしてわれわれは知らずに、年中少しずつそれらのばいきんを吸い込みのみ込んでいるために、自然にそれらに対する抵抗力をわれわれの体中に養成しているのかもしれない。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "えい、冷たいままで勝手におれ、年がら年中冷たい雪を冠っておるのがいいのさ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが近年の年中行事の一つになっていた。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐水病の予防　昨年中パリのパストゥール免疫所で狂犬に噛まれた人のために恐水病予防の注射を行うた件数が七百七十三、その中で不幸にして該病のために死んだのはわずかに二人しかない。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年三月七日『東京朝日新聞』）　　　　　　　　　六十六　　　　　　黄金の産額　昨年中の世界各地で採掘された黄金の総額は六百七十四トンで、もしこれを集めて一塊とすればザット一丈四方に高さ九尺くらいになる勘定である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃が悪い悪いと年中こぼしながら存外人並以上に永生きをした老人を数人知っている。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても今年中には帰れますまい。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京から○○方面へ廻るから先ず年中は帰れんだろうと云う噂。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "七分三分、あるいは六分四分に米麦を混合して常食としている農民は、平常から栄養摂取を十分にやっているわけだが、一年中食うだけの麦を持っている者も、組合から配給される平麦を買って、持っている麦があまるならそれは玄麦で売れというのである。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季その折々の風物の移り変りと、村の年中行事を、その時々にたのしめるようになったのは、私には、まだ、この二三年以来のことである。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季折々の年中行事は、自然に接し、又その中へはいりこみ、そしてそれをたのしむ方法として、祖先が長い間かかってつくりあげたもので春夏秋冬を通じてそれは如何にもたくみに配置されているように思われる。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は年百年中働くばかりである。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若かった時分には四月から五月にかけての若葉時が年中でいちばんいやな時候であった。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが年を取るうちにいつの間にか自分の季節的情感がまるで反対になって、このごろでは初夏の若葉時が年中でいちばん気持のいい、勉強にも遊楽にも快適な季節になって来たようである。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも H0 - A がＫより大きいような人ならばその人は年中怒りっぽくまた憂鬱になりやすいし、また H0 + A がＫより小さい人は年中元気がなく悄気ていることになる。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな習俗ももとは何かしら人間の本能的生活に密接な関係のある年中行事から起ったものであろうと思うが、形式だけが生残って内容の原始的人間生活の匂いは永久に消えてしまい忘れられてしまったのであろう。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の学者などの中にはほとんど年中、あるいは生涯貧しい薄暗い家の中に引き籠ったきりで深い思索や瞑想に耽っていたような人もあったらしい。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが持ち出される日は、私の単調な一年中の生活に一つの著しい区切りを付ける重要な日になっている。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにいよいよ今日はという事になって朝のうちに物置の屋根裏から台が取り下ろされ、一年中の塵埃や黴が濡れ雑巾で丁寧に拭い清められ、それから裏庭の日蔭で乾かされる。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような例を挙げると、年中怠けてばかりいる学生が、一年に一日「勉強デー」を設けるのや、あるいは平生悪い事ばかりしている男が、稀に「善行デー」を設けるのと同じような事で、それも一応は誠にいい事だと思われる。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは、一ねんじゅう花がさいていました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
