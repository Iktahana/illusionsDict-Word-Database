    "definitions": [
      {
        "index": 1,
        "gloss": "wildly enthusiastic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
