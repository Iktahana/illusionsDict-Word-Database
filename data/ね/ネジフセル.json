    "definitions": [
      {
        "index": 1,
        "gloss": "to twist someone's arm and throw them to the ground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
