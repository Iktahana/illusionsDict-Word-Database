          "literary": [
            {
              "text": "猫舌のアメリカ人がスープを睨んでいる。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって猫舌とか、鰐口とか、黒手とか赤足とかいったような突飛な名前を持出すと、その一つでも全篇の実感をワヤにする虞がある。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても猫舌のせいでしょうか、お酒なども、日本酒はのみません。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫舌ですから、さましてからたべています。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の部屋へだけ自分で御飯をたいて、いつもあたたかいのを持ってくるから、同宿の猫舌先生がわが身の宿命を嘆いたものである。",
              "citation": {
                "source": "風と光と二十の私と",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大な両眼に燃える蛍光といい、黒ずんだ骨ばった顔といい、まっ赤な猫舌といい、敏捷な身のこなしといい、黒い豹！",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
