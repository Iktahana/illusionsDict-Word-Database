        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "右手の壁の前には、窓に近き処に寝椅子あり。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝椅子の末の処に一枚戸の戸口あり。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（手真似にて姉に、寝椅子を指さし示し、自分も藁の椅子を傍に持ち行き、腰を掛く。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（寝椅子に腰を掛く。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "別室の籐の寝椅子には陳独秀が彫像のように一夜を過した姿があった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやすみなさい、お母さん」三　堯は掃除をすました部屋の窓を明け放ち、籐の寝椅子に休んでいた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔にふるる芭蕉涼しや籐の寝椅子涼しさや蚊帳の中より和歌の浦水盤に雲呼ぶ石の影涼し夕立や蟹這い上る簀の子縁したたりは歯朶に飛び散る清水かな満潮や涼んでおれば月が出る　日本固有の涼しさを十七字に結晶させたものである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の午後、旻は久し振りで、陽の一っぱいに当っている縁先の籐の寝椅子に出て見た。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その室内で非常に目立つ一つのものは、ちょっと見ては何処の国の型かも判らない大型で彫刻のこんだ寝椅子が室の一隅に長々と横はり、その傍の壁を切ったような通路から稍々薄暗い畳敷きの日本室があり、あっさりと野菊の花を活けた小さな床があった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉は寝椅子の上でおみちの手紙を状袋にしまった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉はいつもの生理的な不安な気持ちに襲われ胃嚢を圧えながら寝椅子から下りた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は平生のように起きて、子供たちと一緒に朝飯を喫い、それから二階へあがって机に向ったが、前夜の宿酔のために仕事をする気になれないので、籐の寝椅子によっかかりながら、ガラス越しに裏崖の草藪の方を見た。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに客のあるときは別ですが、客の無いときは半身不随の老主人が寝椅子に横たわって眼をまじ／＼さしているのを見かけます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人、臨終の寝椅子に青み、むかひゐて毒酒を杯に。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは卓子や曲木の椅子や、籐の寝椅子やをその中に据ゑた。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして、余りの眩さに海から眼を外らして前を見ると、つい先刻まで私と話していた若い警官は、布製の寝椅子に凭ったまま、既に快げな寝息を立てていた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻警官の睡った寝椅子に横になると、直ぐに寝てしまった。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板の寝椅子で日記を書いていると、十三四ぐらいの女の子がそっとのぞきに来た。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらを東側の壁にくっついている寝椅子に集めて、その上に腰を下ろしてあぐらをかいて、刻み煙草一オンスとマッチを一箱、目の前に置く。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　シャーロック・ホームズは、寝椅子に男と並んで腰を落ろし、やさしく肩を叩いた。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窓の下にも真紅な天鵞絨を張った寝椅子をはじめ種種の椅子が※に置いてあった。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お天気のよい午後になると、それから彼女は廊下の寝椅子の上に毛布をかけて横になった。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉はそのはかない夢を見つづけて、寝椅子の上にあるのも只しばしである。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "未知の世界へ希望を懐いて旅立つた昔に比べて寂しく又早く思はれた航海中、籐の寝椅子に身を横へながら、自分は行李にどんなお土産を持つて帰るかといふことを考へた。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、支那間の寝椅子をお座敷の縁側ちかくに移して、お母さまのお顔が見えるように腰かけた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銑太郎が、サラセン模様の壁飾りの下に横たへたロココ風の寝椅子に凭つて、そんなことを云つてゐたのを私は覚えてゐる。",
              "citation": {
                "source": "冬物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、類ひ稀なるモロコシ酒の利き目は、盞を傾ければ忽ち羽化登仙、二盞を呑み尽せば王侯貴族の宮殿に主となつて、錦の寝椅子に恍惚としてゐるものを、あの声を耳にするがいなや、真さかさまに元の馬小屋に戻つてしまふと、憤つて、やがてはわたしの帰来と知つても故意に扉を開けようともしなかつた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木さんは小さい方の室に、蔓の寝椅子に長まつて、少し開けてある硝子戸を通して外を見てゐられた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくみは寝椅子の側の物置台へ乳を置く。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "龜は、はらはらして、「ていねいすぎる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
