        "examples": {
          "standard": [
            {
              "text": "夏の暑い夜は、ひんやりとした寝茣蓙を敷いて寝ると涼しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの寝茣蓙は、通気性が良く、日本の夏には欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行先の民宿で、初めて寝茣蓙で寝てみたが、意外と快適だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の父左衛門は、生前、春、秋、冬を、その中に住み、夏は紙帳を畳んで蒲団の上に敷き、寝茣蓙代りにしたが、左門も、春、秋、冬をその中に住み、夏は寝茣蓙代りに、その上へ寝た。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
