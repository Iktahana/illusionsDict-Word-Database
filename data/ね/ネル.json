[
  {
    "uuid": "1cc657bd-73d8-5608-807a-5621fffb2943",
    "entry": "寝る",
    "reading": {
      "primary": "ねる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
