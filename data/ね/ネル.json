    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to sleep (lying down)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "度々のことで面倒だから、今度から止めにして、先へ勝手に寝ることにしろと何度も言うが、妻は婦道に背くと言い、なかなか承知しないので困っている云々（大意）と。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きてから、夜寝るまで。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は僕、枕を高くしてのうのうと寝るぞ！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入りの寝るや小豆の煮える中　という句を作り、さらに春風馬堤曲を作る蕪村は、他人の藪入りを歌うのでなく、いつも彼自身の「心の藪入り」を歌っているのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入りの寝るやひとりの親の側　　　太祇　には、蕪村自身のうら侘しい主観を通して、少女に対する無限の愛撫と切憐の情が語られている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の一室狭けれども今宵はゆるやかに寝るべしと思えば船中の窮屈さ蒸暑さにくらべて中々に心安かり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば野獣も盗賊もない国で、安心して野天や明け放しの家で寝ると、風邪を引いて腹をこわすかもしれない。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう三つ寝ると正月だよ、正月が来ると坊やは五つになるのよ、えいこったろう……木っぱのような餅たべて……油のような酒飲んで……」　姉は自分を喜ばせようとするような調子にそれを唄って、少しかがみ腰に笑顔で自分の顔を見るのであった。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になっても寝ると仕方がないから、なるたけ人中で騒いで居て疲れて寝る工夫をして居た。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう話せば話すほど悲しくなるからとて強いて一同寝ることにした。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きて顔を洗う金盥の置き方から、夜寝る時の寝衣の袖の通し方まで、無意識な定型を繰返している吾人の眼は、如何に或る意味で憐れな融通のきかきぬものであるかという事を知るための、一つの面白い、しかも極めて簡単な実験は、頭を倒にして股間から見馴れた平凡な景色を覗いて見る事である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし不検束な主人はその正規の時間に帰って、正規のおしきせの晩酌で満足して寝ることは稀であった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの本を読んで聞かせる声に賺されて、寝る時は寝るでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が自分の部屋にかえると隣の寝台にカーテンも引かないでペチ・コートのまま仰向けになったアダが、夢うつつにも寝床で寝るトア・ズン・ドルの女を再び見出した。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人とも、寝ることにはあきていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしかはぶつ／＼云い乍らも、為吉が夜なべをつゞけていると、それを放っておいて寝るようなこともしなかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　十三寝ると病院列車に乗って浦潮へ出て行ける。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝る時、蒲団が一畳ずつしかあたらなかった。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、早や、寝る筈はないんだが……」彼はそう思った。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言いますと、あの時分は私も朝早くから起きて寝るまで、学校の課業のほかに、やたらむしょうに読書したものです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『なに僕だって何ともないさ、君が寝るならこれを借りていって読んで見ようと思うだけです。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其外源三郎の臥て居る布団というのは見て居るのも気の毒なほどの物で、これに姉と弟とが寝るのである。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう幾つ寝ると学校や幼稚園が始まるかという事が幼い子等によって毎日繰返されるようになった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "横臥したいと思ったが寝る所がないから机の上に突伏して右に左に頭をもたせてみたが胸苦しさは増すばかりで全身は汗ばんで来た。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時間か四時間だけ自動車を一台やとって、道路のいい田舎へ出かけてどこでも好きなところで車を止めて土が踏みたければ踏み、草に寝たければ寝るということである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕といっても、勿論、寝る時に使うそれではなかった。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（さあ帰って寝るかな。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝るには余り暗い考えが彼を苦しめるからでもあった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本づつ持つて牧野さんを訪ねるといふのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日退屈なるまゝに、ＡはＢを訪ねる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
