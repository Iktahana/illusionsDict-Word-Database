    "definitions": [
      {
        "index": 1,
        "gloss": "Welsh onion (Allium fistulosum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
