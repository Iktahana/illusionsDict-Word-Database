    "definitions": [
      {
        "index": 1,
        "gloss": "hour of the Rat (around midnight, 11pm to 1am, or 12 midnight to 2am)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毎夜｜子の刻迄には屹度して差上げる筈の日課が、ゆうべからの騒ぎで暁方になって仕舞った。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜も既に、十一時すぎ、子の刻か。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思切って船を漕戻したのが子の刻過ぎで、浦近く、あれ、あれです、……あの赤島のこっちまで来ると、かえって朦朧と薄あかりに月がさします。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜の子の刻（午後十二時）にその蝋燭の火を照らして、壁かまたは障子にうつし出される娘の影を見とどけろというのである。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸に一物ある夫婦は寝たふりをして夜のふけるのを待っていると、やがて子の刻の鐘がひびいた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から数えて百日目の夜、時刻はやはり子の刻、お忘れなさるな。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時頃より初めて、詠出、互撰、評語、終れるは子の刻も過ぎつる頃と覚ゆ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豊鑑」には「天正十二年霜月廿九日子の刻ばかりにやおびただしくなゐふりけり、その様いはん限りなし、いにしへもたびたび大なゐふりけると記しをれども、眼あたりかかることなんめづらかなる。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて最後に、羽柴筑前守秀吉であるが、当時、中国の毛利大膳大夫輝元を攻めて、高松城水攻をやっていたが、京都の凶報が秀吉の陣に達したのは、六月三日｜子の刻であるが、五日の朝まで、信長生害の事を秘して、終に毛利との媾和に成功した。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもう子の刻に近い比であった。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠之は縱ひ身の破滅は兔れぬにしても、なるべく本邸で果てたいと云ふので、内藏允が思案して、忠之の駕籠を小人數で取り卷き、素槍一本持たせて、夜｜子の刻に神奈川を立たせた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今村君の『朝鮮風俗集』にまたいわく、上子の日子の刻臼をつけば鼠の種尽くると称し、深夜空臼の音を聞く、昔宮中で小官吏が炬に火を付けて大声に鼠｜燻し鼠燻しと呼んで庭内を曳きずり廻した後、王様から穀物の煎ったのを入れた袋を賜わった事が民間に伝わったものであると。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜の子の刻（午後十二時）にその蝋燭の火を照して、壁か又は障子にうつし出される娘の影を見とゞけろと云ふのである。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸に一物ある夫婦は寐た振をして夜のふけるのを待つてゐると、やがて子の刻の鐘がひゞいた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から数へて百日目の夜、時刻はやはり子の刻、お忘れなさるな。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯が明るくついて、子の刻を過ぎても、醉ひしれたりざれ戯れたりする男や女の聲があちこちにきこえた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "成田邸への襲撃は、その夜の正子の刻と決った。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは暗い町が、今宵は灯が洩れる家が多く、子の刻近くなっても、物音人声などが外へきこえる家が多かった。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "正子の刻には、六人とも集った。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、子の刻が近づくと、ついとろとろした。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、子の刻過ぎまでは、何も顕れては来なかった。",
              "citation": {
                "source": "葬られたる秘密",
                "author": "A DEAD SECRET",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田橋外｜元護寺院二番原に来た時は丁度｜子の刻頃であった。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の刻を過ぎてから、保さんは母と姉とに連れられて伊沢の家を出て帰り掛かった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此巻物は「文政四年冬十一月九日朝より夜の子の刻に至るの間調薬看病の暇に書、名※、字河澄、号京水、一号酔醒、又号生酔道人、仏諡可用宗経」と云ふ奥書があつて、下に華押がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朝より夜の子の刻に至るの間、調薬看病の暇に書」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の刻頃になって、両藩の士が来て、只今七藩の家老方がこれへ出席になると知らせた。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、調伏の証拠を握って――）「こ、今夜、子の刻前に――」　小藤次は、よろめいて立上りながら「広縁で」　深雪は、頷いた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "帛を裂く掛け声　こうして子の刻も過ぎた時ようやく多右衛門は起き上がった。",
              "citation": {
                "source": "日置流系図",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「駆け落ちの日にちと刻限とに、間違いがあっちゃア大変だが」「今日から五日後の子の刻さ。",
              "citation": {
                "source": "怪しの者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の刻を過ごした深夜なのである。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
