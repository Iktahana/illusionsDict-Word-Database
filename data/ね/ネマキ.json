[
  {
    "uuid": "ff8028ef-a254-5e01-a76a-36c7db8f2b57",
    "entry": "寝巻き",
    "reading": {
      "primary": "ねまき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
