    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(on one's) mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然し音楽は片時も念頭を離れなかつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに金のことなぞ念頭にあるやうではやり切れない性質の仕事をしてゐるから、一層金は、金の方で足が付いてやつて来て呉れる方がいいに決つてゐる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "話といふやうなものはてんでないで、話をしてゐても、その話が相手の気に触りはしないかといふことが念頭に浮ぶや、実に手の腹を返すが如く話頭を転ずるのだが、それでまた相手が妙にも思はぬといふ摩訶不思議な有様である。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、順序からいへば、お金儲けも念頭に置くべき日となつた。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――成程、社交以外のことを念頭に置いてゐる人も沢山にありませう。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し社交のことの五分の一程も実感的には念頭に来ますまい。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで肺炎から結核になろうと、なるまいと、そんな事は念頭にも置かなかった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲は歌の議論を為すべきでないから、多くは云はないが、石川君のやうな、歌に対する信念と要求とから出発したものならば三十一字と云ふやうな事を始めから念頭に置かない方が良いのぢやなからうか。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、世界的な珍味佳肴と云はれる支那料理の如きも、その調理法には催欲のためと云ふ事が念頭に置かれてゐるらしい。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武器の押収を命じられていることは、殆んど彼等の念頭になかった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論彼の念頭にこの詩はなかつたのである。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に申しました占星術の如きは仮令幾多の事例が有りましたとて、何で今の人がこれを念頭に上せませうか。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうふうに、連句というものの文学的芸術的価値ということを全然念頭から駆逐してしまって統計的心理的に分析を試みることによって連句の芸術的価値に寸毫も損失をきたすような恐れのないことは別に喋々する必要はないであろうと思われる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は最う、さつきから荷車が唯辷つてあるいて、少しも轣轆の音の聞えなかつたことも念頭に置かないで、早く此の懊惱を洗ひ流さうと、一直線に、夜明に間もないと考へたから、人憚らず足早に進んだ。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "買収云云のことがまだ彼等の念頭に一抹の疑団を残して居るのであつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "買收云々のことがまだ彼等の念頭に一抹の疑圖を殘して居るのであつた。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに思い到りて、白糸はいまだかつて念頭に浮かばざりし盗というなる金策の手段あるを心着きぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当だっかいな」　今晩女郎買いに行く事に決めていた春松はその事を一寸念頭においていった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にその嘲笑する人をも含めて、人間は、お互いの不信の中で、エホバも何も念頭に置かず、平気で生きているではありませんか。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士や教授や勅任官｜抔の事を念頭にかけて、うんうん、きゅうきゅう云っていられるものじゃない。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し彼等が其平和の必要条件として、それとは全く両立しがたい腕力の二字を常に念頭に置くべく強ひられるに至つては、彼等と雖も今更ながら天のアイロニーに驚かざるを得まい。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも其上に前述べた通り、彼我国情の差違並びに批評家の誇張などを念頭に置いて、是からトライチケを一瞥しやうとするのである。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "死は惧ろしくはないが、死へ行くまでの過程に嫌なものがあるという考えがちらりと念頭を掠めて過ぎた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私は眼の前の会席膳の食品の鮮やかさに強て念頭を拭った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ歌などは「雨降るわ、傘持てけ」のたぐひで歌とも何とも云ひやうのないものだが、なぜかそれが、歌を詠まうとするときには、必ず先きに念頭に浮んで詠みはづまうとする言葉の出頭を抑へ、秋成をいまいましがらせた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフィリヤどころでは無い、というのは言いかたが、まずいので、オフィリヤの事も念頭より離れず、それに今度の恐ろしい疑惑が覆いかぶさり、乱雲が、もくもく湧き立ち、流れ、かさなり、僕の苦しみが三倍にも五倍にも、ふくれあがって、ゆうべは、本当に、一睡も出来ませんでした。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古の地獄が、一刻も念頭より離れず、ただ、暗憺たる気持であった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代における思潮の淵源、天堂と食堂を兼備えて、薔薇薫じ星の輝く美的の会合、とあって、おしめと襷を念頭に置かない催しであるから、留守では、芋が焦げて、小児が泣く。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はその御様子じゃ、二十円以内の家は念頭にお置きなさらないように見受けたものですから、いささか諷する処あるつもりで、」　いつの間にか、有名な随神門も知らず知らず通越した、北口を表門へ出てしまった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は最う、さっきから荷車が唯辷ってあるいて、少しも轣轆の音の聞えなかったことも念頭に置かないで、早くこの懊悩を洗い流そうと、一直線に、夜明に間もないと考えたから、人憚らず足早に進んだ。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
