[
  {
    "uuid": "c345670b-79aa-5b4b-8e63-b7987e278d3c",
    "entry": "念頭",
    "reading": {
      "primary": "ねんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
