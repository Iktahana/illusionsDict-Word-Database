[
  {
    "uuid": "3817f074-0f87-550c-9657-9148299a45a6",
    "entry": "眠り薬",
    "reading": {
      "primary": "ねむりぐすり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
