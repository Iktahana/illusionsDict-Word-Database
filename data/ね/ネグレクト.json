        "examples": {
          "standard": [
            {
              "text": "両親からのネグレクトは、子供の心に深い傷を残すことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "社会全体でネグレクトの問題にもっと目を向け、支援の輪を広げる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の動物へのネグレクトは、地域住民の告発によって明るみに出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これは作家として当然なことなのであるが、この当然なことが最近ではネグレクトされていたのだ。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "父母から見ると、Ａのために自分達をネグレクトされると思い、Ａの方から見ると、自分を完愛するために彼等を拒けると云う自惚を起させるかと思うと苦しくなる。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は宗教学的に云うと重大な宗教現象であるが、私が今問題にしている範囲ではネグレクトして構わない性質を持っている。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
