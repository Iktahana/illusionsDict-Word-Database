[
  {
    "uuid": "6bdc3171-ac31-57a1-8c21-32c9497eaf11",
    "entry": "年功",
    "reading": {
      "primary": "ねんこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
