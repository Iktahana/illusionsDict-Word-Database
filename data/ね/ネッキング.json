        "examples": {
          "standard": [
            {
              "text": "若者たちが公園で楽しそうにネッキングしているのが見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パーティーの片隅で、カップルが親密にネッキングしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のワンシーンで、主人公とヒロインがベンチでネッキングする姿が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「今日ハオ爺チャン、ネッキングサセタゲマショウカ」「ネッキングッテ何ノコトダネ」「ネッキングヲ知ラナイノ？",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドウ云ウ風ノ吹キ廻シカ、アトガ恐シイナ」「イヽ覚悟ダワ、ソノ積リデイタライヽワ」「ジャ、ソレカラ先ニ聞コウジャナイカ」「マア兎ニ角、ネッキングヲナサイ」結局予ノ方ガ誘惑ニ負ケタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予ハ二十分以上モ所謂ネッキングヲ恣ニシタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「接吻シテクレヽバ痛イノヲ忘レルヨウ」「足ナンカジャ駄目ダヨウ」「ネッキングデモ駄目ダヨウ」「ホントノ接吻デナクッチャイヤダヨウ」コンナ工合ニ散々駄々ヲ捏ネテ泣キ声ヲ立テ、悲鳴ヲ上ゲテ見タラドウカ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
