        "examples": {
          "standard": [
            {
              "text": "このドレスには、鼠繻子の滑らかな光沢がぴったりだわ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カーテンを鼠繻子に変えたら、部屋の雰囲気がぐっと落ち着いたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このスカーフ、手触りが最高。鼠繻子ってこういう上品な感じなんだね。」と彼女は感心した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "のみならず火の気のない部屋の寒さは、床に敷きつめた石の上から、次第に彼女の鼠繻子の靴を、その靴の中の華奢な足を、水のやうに襲つて来るのであつた。",
              "citation": {
                "source": "南京の基督",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣類は鼠縞の御召縮緬に、茶博多と鼠繻子のくけ合せ帯をしめている。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
