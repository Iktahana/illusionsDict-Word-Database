          "literary": [
            {
              "text": "「虚実の証拠」「遺伝」等の価値については世評半ばしていたようであるが、私は、ネガティブの一票を投じる。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化構成でなくて、プロパーな意味に於て文化統制と呼ばれる限り、それはネガティブであり受身なものだ。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "又批判は実証≪ポジティブ≫に対する消極≪ネガティブ≫を意味するのでもない。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
