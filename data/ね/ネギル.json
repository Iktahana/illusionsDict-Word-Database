[
  {
    "uuid": "426afe6d-9f99-53e6-a560-f87f88755a03",
    "entry": "値切る",
    "reading": {
      "primary": "ねぎる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
