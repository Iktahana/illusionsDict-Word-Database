    "definitions": [
      {
        "index": 1,
        "gloss": "unable to sleep well",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寝苦しい夏の夜も、森と川の面から撫でるように吹いて来る、軽い風で涼しくなった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝苦しい、麹室のようなムンムンする、プロレタリアの群居街でも、すっかりシーンと眠っていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "かますの乾物のように、痩せて固まった彼の母は、寝苦しいものと見えて、時々溜息をついていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆撃でヒビのイツた病室の天井を睨み乍ら寝苦しい夜つれ／″＼に考えた事、酒の席で武山オジサンにでも談して見て呉れ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小児たちが、また悪く暖いので寝苦しいか、変に二人とも寝そびれて、踏脱ぐ、泣き出す、着せかける、賺す。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　寝苦しいか、白やかな胸を出して、鳩尾へ踏落しているのを、痩せた胸に障らないように、密っと引掛けたが何にも知らず、まず可かった。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと寝苦しい、何にも見まい、と目を塞ぐ、と塞ぐ後から、睫がぱちぱちと音がしそうに開いてしまうのは、心が冴えて寝られぬのである。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は寝苦しいので蚊帳を出た。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾夜も寝苦しい思いをした。",
              "citation": {
                "source": "川端康成へ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとびとが宵の寝苦しい暑さをそのまま、夢に結んでいるときに、私はひんやりした風を肌に感じている。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏、寝苦しい夜、軽部の乱暴な愛撫が瞼に重くちらついた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、椙がなに思ってか寺田屋から姿を消してしまったのは、それから間もなくのことだったが、その行方をむなしく探しているうちに一年たち、ある寝苦しい夏の夜、登勢は遠くで聴える赤児の泣声が耳について、いつまでも眼が冴えた。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家の人びとは宵の寝苦しい暑さをそのままぐったりと夢に結んでいるのだろうか、けれども暦を数えれば、坂田三吉のことを書いた私の小説がある文芸雑誌の八月号に載ってからちょうど一月が経とうとして、秋のけはいは早やこんなに濃く夜更けの色に染まって揺れているではないか。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さあ、何時頃だったでしょう――二度めに、ふと寝苦しい暑さから、汗もねばねばとして目の覚めましたのは。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で、真夜中に寝苦しい目の覚めた時です。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝苦しい夜が明けて、少し疲れの残った身体で目覚めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝苦しい一夜を明かすと、あしたは晴れていて朝から暑くなりました。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "興奮と煩悶とに労れた勝平の頭も、四時を打つ時計の音を聴いた後は、何時しか朦朧としてしまって、寝苦しい眠りに落ちていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、俺は外の人に「夜、蒲団があまり重くて寝苦しい時には、この重さが一体何んの重さであるか位は考えてみないわけでもない。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "興奮と煩悶とに労れた勝平の頭も、四時を打つ時計の音を聴いた後は、何時しか朦朧としてしまつて、寝苦しい眠に落ちてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸暑く寝苦しいので、起上つて雨戸を開けて、真闇な植込に出てみた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸暑く寝苦しい夜を送った後なぞ、わたしは町の空の白まないうちに起きて、夜明け前の静かさを楽しむこともある。",
              "citation": {
                "source": "秋草",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜もだいぶ寝苦しい、寝苦しいのも肺炎の特徴らしい、読書でゴマカすより外ない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩寝苦しいのには閉口する、一時間ぐらゐとろ／＼するとすぐ眼がさめる、あやしい夢（といつてヱロチツクぢやないが）をみるのである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月廿九日よい月夜、寝苦しい寝返りを繰り返してゐるうちに、いつとなく夜が明けてしまつた、けさは早起の中の早起だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・白うつづいてどこかに月のある夜みち・寝苦しい月夜で啼いたはほととぎす・てふてふとまるなそこは肥壺・悔いることばかり夏となる・いつでも死ねる草が咲いたり実つたり　五月三十日晴、いよ／＼夏が来た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜も今夜も少々寝苦しい、時々狭心症的な軽い発作、読書しないで思索をつゞけた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも寝苦しい、妙な嫌な夢を見る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれなメグは、ねぐるしい一夜をあかし、おもいまぶたの、いやな気分で床をはなれました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
