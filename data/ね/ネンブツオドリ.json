    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist incantation using chanting, drumbeating, and dancing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "念仏聖の念仏踊りや万歳舞ひを見た事は、島人の踊りの上に非常な動乱であつた。",
              "citation": {
                "source": "沖縄舞踊に見る三要素",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏踊り・万歳の外に立つ唯一のものとして挙げた此ですらも、御覧の通り、其音頭・囃しは極端に念仏であつた。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、収穫を直後に控へて此を祈る行事で、西出雲では、現に今でも念仏踊りと称して居るものである。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、宮に仕へる若者衆が行つた念仏踊りが、更に上覧踊りに変つて行つた道筋を、今少し考へ易くして貰ひたいと思ふ。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏踊りの歌は、盂蘭盆には、新盆を修する家々では、その家庭・座敷・主人の為の褒め詞にも使つて居ります。",
              "citation": {
                "source": "日本芸能の特殊性",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊りは専ら、伊勢踊り・念仏踊り・神送り踊りの類の激しいものになつて行つた。",
              "citation": {
                "source": "舞ひと踊りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫は、念仏踊りの色彩が濃く残つて居る方面では、をしやう（和尚）と称へて居た。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女歌舞妓は、お国の念仏踊りの正系である為に、この呼び名で、主役を示す風を保つて居たものと思はれる。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを太夫と称へ出したのは、念仏踊りにかぶき風が合体した頃からのことである。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山三郎が歌舞妓所作をお国の念仏踊りにつぎ込んだと共に、早歌を供給したことは、既に述べた。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くは念仏踊りを踊つた十王堂や、地蔵堂などで、之を行ふことになつた。",
              "citation": {
                "source": "涼み芝居と怪談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞妓踊りと言はれたものゝ固定して、歌舞妓狂言が出来たその筋道は、今でも出雲のお国が伝へた其故郷の念仏踊りから出たと信じられてゐるから、其を話のひつかゝりとして話して行つて見よう。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一念仏踊りなどより種姓正しく、歴史の古い幸若の「舞太夫」などが多く関係してゐた。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其には、此等の「踊り念仏」自体が持ち伝へた――さうした念仏踊りを行ふ理由――といふより、其を脇芸としてつけて演ずることによつて、念仏の効果を増すものと考へて来た、因縁譚とも言ふべき踊り狂言が昔からあつたものである。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "論より証拠、歌舞妓踊りから真直に歌舞妓狂言に進み入つたお国自身の念仏踊りにも、何時からか、此踊り狂言が行はれて居た。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が、お国の持ち廻つた念仏踊りのれぱあとりいの中に入りこんだものと見える。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした名古屋が、念仏踊りの行く先々の村里の祖先聖霊とは、何の関係もないことは言ふまでもない。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "田楽師はまた村々の念仏踊りにも迎へられる。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此物語は、鎮花祭及び念仏踊りの系統に属する詞章出なのである。",
              "citation": {
                "source": "鸚鵡小町",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮花祭は、近世の念仏踊り・念仏宗の源となり、田楽にも影響を及して居る。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "切明の神事は、旧幕時代には、盆踊りと混同して、七月の十四日に神前で行はれて、名さへ念仏踊りと言はれてゐた。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の出雲のお国が四条磧で興行した念仏踊りも、或は単に念仏を唱へ、数珠を頸に懸けてゐたからだとばかりは定められまい。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "田楽・住吉踊り、或は念仏踊りなど、其間の隔たりは、実に天地の差である。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四一方、魂祭りの方面では、ちようど其頃、念仏踊りがある。",
              "citation": {
                "source": "盆踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此悪霊退散の為の踊りが、念仏踊りである。",
              "citation": {
                "source": "盆踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮花祭の踊りをする中に、其興奮から、一種の宗教的自覚をおこして、念仏宗が出で、其径路に当つて、念仏踊りが現れたのであつた。",
              "citation": {
                "source": "盆踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏踊りは、此様に、段々意味が変つて来て居るが、根本には、魂に係る祭りだと言ふ考へがなくなつては居ない。",
              "citation": {
                "source": "盆踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏踊りの直接の前の形は魂祭りではあるまいが、併しそれ以前、平安朝から、或は奈良朝の頃にも、此魂祭りを考へて居たことは見える。",
              "citation": {
                "source": "盆踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の聖霊が帰つて来る時期に、ちようど念仏踊りを行うた。",
              "citation": {
                "source": "盆踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲のお国の念仏踊りは、ほんとうのものであつたか否かは、疑はしい。",
              "citation": {
                "source": "盆踊りの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
