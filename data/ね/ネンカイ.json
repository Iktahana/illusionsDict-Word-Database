    "definitions": [
      {
        "index": 1,
        "gloss": "conference",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四、五日前役所で忘年会の廻状がまわった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "消防組の赤い半纒を着た人たちや、青年会の連中が邸内のあちこちに眠そうな手で蚊を叩いていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年は村々に青年会などという文化的なものがあるからおそらく昔のような事は見られまい。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　四五年会わなかった知人に偶然｜銀座でめぐり会った。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "声を聞きつけてミシミシと二階を下りてきて「ヤア」と現われたのが、一別以来三年会わなんだ桂正作である。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "村長や、区長や、校長先生や巡査が青年会場に集まって、いろいろに首をひねったけれども、第一、居なくなった原因からしてわからなかった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、娘の親たちへ知らせなければなるまい……というので、とりあえず青年会員が二人、娘のうちへ自転車を乗りつけると、晴れ着をホコリダラケにしたその娘が、おやじに引き据えられて、泣きながら打たれている。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから夜通しがかりで青年会をやり直します。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局　鎮守の森の入口に、村の共同浴場と、青年会の道場が並んで建っていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは会社に出勤、忘年会とか、いちいち社員から会費を集めている。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　相変らずでっぷりして、平目のような頬ぶくれした顔は、六年会わぬが、隣家に住んでいる〆団治だと、一眼でわかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その年も押しつまったある夜、紙芝居をすませて帰ってきますと、今里の青年会館の前に禁酒宣伝の演説会の立看板が立っていたので、どんなことを喋るのか、喋り方を見てやろうと思いながら、はいって聴きました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ忘年会ということにして……」　天辰の主人の思いがけない陽気な声に弾まされて、ガヤガヤと二階へ上る階段の途中で、いきなりマダムに腕を抓られた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、天神様の境内で、恩を謝す心を決して以来、その機会がなかった処、翌年一月、伊予紋で、大学出の人の新年会があった。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと年会費六千円で使い放題と格安の上に、容量がかなり制限されるとはいえ、今度は自分の情報が発信できます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自分に対して、去年会うたときには、某牛舎に寝ておって、うん安藤かといったきり、おきもしなかった。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮に押し詰まって、毎晩のように忘年会の大一座があって、女中達は目の廻るように忙しい頃の事であった。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹羽さんが青年会において『基督教青年』という雑誌を出した。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどここにも学校が建った、ここにも教会が建った、ここにも青年会館が建った、ドウして建ったろうといってだんだん読んでみますと、この人はアメリカへ行って金をもらってきて建てた、あるいはこの人はこういう運動をして建てたということがある。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は午後四時より向島の八百松に新年会ありとて未だ還らざるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年や七年会はんでも私は未だそれほど老耄はせんのだ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いうちに忘年会をやりませうか。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが私は剣舞が好きで、それを青年会や同窓会でよくやりますが、不思議なことには、私が不断借りてつかつてゐる刀、それは言ひ伝へでは、何でも其昔、虎之助さんが先生から譲つて頂いたとか、貰つたとか申すものださうで、真か偽か知りませんが、息子の秀雄さんがさう申しました。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その刀――手紙をよこした青年が、虎之助君の子息から借りて、青年会の席上などで剣舞をやるといふ刀、それは確か関兼英の銘のある刀である。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら、半年会わないうちに、ポールをふって、デイヴィー・ジョーンズに鞍替えしたらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
