          "literary": [
            {
              "text": "――だが、再び、何んなに私達が多くの思慮深い額をあつめて、事を謀らうが、長夜の寄合ひを続けようが、相手が深淵極りなき大海原であり、大ネプチューンの支配下である限り――嗚呼！",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "※ポセードーン（ポセーダイオーン）（ラテン名ネプチューン）ヂュウスの弟、海を司る。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前十時、船客中十余人、仮装して海神ネプチューンの行列をなし、裁判を開き、有罪と認むるものを水中に投ずる古例の祭式を擬し、大いに喝采を博す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　ポセイドン（ネプチューン）と大地ガイアとの子であるアンタイオスのこと。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
