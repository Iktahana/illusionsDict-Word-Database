    "definitions": [
      {
        "index": 1,
        "gloss": "target",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一九〇九年型の女優が一九三四年式のぴちぴちした近代娘に蝉脱した瞬間のスリルがおそらくこの作者の一番の狙いどころではないかと思われる。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「活動の筋書欠乏は久しい話ですが、集まって来る原稿が皆狙いどころをそれているのにも困ります。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アレ、この猿、狙いどころをかえたな。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ざっくばらんに云えば、そこがこの作者の云わば狙いどころとしての成功であり、作品のひとくせあるところでもあるのではなかろうか。",
              "citation": {
                "source": "観念性と抒情性",
                "author": "――伊藤整氏『街と村』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　スタニスラフスキーのオペラは、芝居とオペラとの調和が狙いどころの由、群集をリズム（音楽）に合わせて動かし、イタリーの無駄な遊びを整理しようとして居るところ、セッティングを、四本のコラムをどこまでも利用して居るところ、面白かった。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弓」という奈良時代の背景の作品は、狙いどころの素朴な浄らかさ、生命の健康を求める心はよくわかるが、やはり話しかたに意識された素朴への憧れで、本質は男性的であるとは云えない。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "狙いどころは、さっきとおなじところだ」「よし。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これが左門の狙いどころなのであった。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「普通の捕り物とは違うのだからな」「こっそり引っくくるか叩っ殺してしまえ――というのが狙いどころなんだからな」　しばらく四人は黙り込んだが、先へズンズン進んで行く。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが鷺組の狙いどころ、追い廻しては叩っ切る。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに告発文の狙いどころは、エセックスは恐ろしい計画的な謀叛によって有罪であるという点を示すにある。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな言いかたをしたベエコンの狙いどころは、他にあるはずはない。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "サアそこが犯人の狙いどころでな。",
              "citation": {
                "source": "見えざる人",
                "author": "THE INVISIBLE MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思わせるところにこの画家のこの絵での狙いどころがあたったわけと云うべきか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに妙な、科学の狙いどころと詩の狙いどころとの接近が最近に現われたのであります。",
              "citation": {
                "source": "悦しき知識",
                "author": "――停年講義（昭和三十三年九月十六日）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、無念になって、その心のなかの象を、木彫として現わそうとするだけに過ぎないが、その真摯な狙いどころが、手となり、小刀の先の動きにまでくるあいだに、種々な雑念が、狙うところの心形を散漫に乱してしまう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅門塔十郎も時々、奇功に逸って、分らない指図をするぜ」「いや、あの頭脳のいい先輩のことだから、何か、狙いどころがあるんだろう」「しかし、窮命されているようだな。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッと拾いかかるところを、新九郎はここぞ狙いどころと、その背へズーンと斬りつけたが、敵のからだに刀が当ると、背が返って肉は切れなかった。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて信長の政治方針が招いた世相の悪化の如く見せかけるのが、彼らの狙いどころだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然誰もがひとしく、そう考えるであろうところこそ、この策謀の狙いどころであり、また重要な役割を果たしましょう」「では、蔡和、蔡仲のふたりを用いて、呉へ入れるというのか」「さればで。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるプロ芸術のねらいどころもここに共通点を持っているように思われる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今の科学のねらいどころをどこまでも徹底させて生物界の現象にまでも物理学の領土を拡張しようとする場合には、だれでも当然に逢着すべき一つの観念である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが兼山のねらいどころであったろう。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした処女地を探険するのが今の映画製作者のねらいどころであり、いわば懸賞の対象でなければならない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしユダヤ人というものの概念のはなはだ希薄な日本人には、おそらくこの映画の本来のねらいどころは感ぜられないであろうし、あるいはかえってそのおかげで日本人にはいやみや臭味を感ずることなしにこの映画のいいところだけを享楽することができるかもしれない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人でもこのまねをするあほうがあるが、あれも本来のねらいどころはおそらく一種の「俳諧」であったに相違ない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもちろん風雅の心をもって臨んだ七情万景であり、乾坤の変であるが、しかもそれは不易にして流行のただ中を得たものであり、虚実の境に出入し逍遙するものであろうとするのが蕉門正風のねらいどころである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議に思う人があるだろうが、そこがこちらのねらいどころなのだ。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "よりよく生きるため、より美しく平和に伸びるために必要な積極政策は圧しつけて、一方では考査特別委員会、非日委員会、新聞用紙割当改正、更にあらゆる方法での買収を可能にするような選挙法改正と、多数をたのむいまの政府のねらいどころはどこに向っているのだろう。",
              "citation": {
                "source": "平和をわれらに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その要求する食事をどうしたら病人に害にならずに美味く食べさせるか、それが料理というもののねらいどころだ。",
              "citation": {
                "source": "道は次第に狭し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
