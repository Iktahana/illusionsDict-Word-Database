    "definitions": [
      {
        "index": 1,
        "gloss": "New Year's greetings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
