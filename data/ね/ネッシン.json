    "definitions": [
      {
        "index": 1,
        "gloss": "zealous",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは何も人々が短歌に不熱心であつたといふやうなことではなく、短歌様式そのものが本来さうしたものであるやうに思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて貧困の家に育ち、肉親の愛にめぐまれずして家庭的、環境的の不遇に成長した人々は、そのかつて充たされなかった心の飢餓を、他の何物にも増して熱情するため、後に彼が一家の主人となった場合、その妻子の忠実な保護者となり、家庭を楽園化することに熱心である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした彼は、事実上において熱心な仏教信者でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンが学校に行ってる間、夫人は暇を盗んで熱心に読書をし、手の及ぶ限り、日本の古い伝説や怪談の本を漁りよんだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も新作が出る毎に、僕の意見をよく求められ、自分のデタラメな獨斷批評を、熱心によく傾聽してくれた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もまた、かつては、いや、いまもなお、生きることに不熱心である。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分が教育に熱心な余り……」と復考へた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分が教育に熱心な余り……」とまた出て来て、もうその先は考へる余地がなかつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "不折ほど熱心な画家はない。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中から、舌を拔かれた小雀を搜し出すのは、至難の事のやうに思はれるが、しかし、お爺さんは異樣な熱心さを以て、毎日毎日探索する。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津輕地方のインテリゲンチヤたちも、實にこの「意味」の追及に熱心である。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は帰朝以来、甲府に二回遊んだが、これらの人々の郷土愛の熱心さには、いつも若返る力を身内におぼえる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞編輯者は事実の客観的真相を忠実に伝えるというよりも読者のために「感じを出す」ことの方により多く熱心である。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に「繪を描いて居る男」などは全で問題にならないらしい程熱心に話合つて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした材料を得るための観測施設は個人や小団体の力で出来ることではなくて、結局国家政府の相当熱心な努力によって始めて完備し得ることである。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人北原多作氏のごとき少数な篤学の官吏の終生の努力と熱心によってようやく水産に聯関した海洋調査がやや系統的に行われるようになりはしたが、自分の知る限りでは時々の政府の科学的理解のない官僚の気まぐれなその日その日の御都合による朝令暮改の嵐にこの調査の系統が吹き乱される憂いが多分にあった。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日本では濃尾震災の刺戟によって設立された震災予防調査会における諸学者の熱心な研究によって、日本に相当した耐震建築法が設定され、それが関東震災の体験によって更に一層の進歩を遂げた。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙に関する吾等の知識を増すだけの目的でこんな面倒な仕事を撓まずに続けている学者の熱心を多とすべきものではあるまいか。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋にはこういう事にも熱心な学者が多く、玉突、テニス、砲丸投等の技術を力学的に研究した例は乏しくない。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻はそこへしゃがんで熱心に拾いはじめる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は帯の間からハンケチを取り出して膝の上へ広げ、熱心に拾い集める。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "念の為め主人と私の関係を話して置くと、私の父は幼時に維新の匆騒を越えて来たアマチュアの有職故実家であったが、斯道に熱心で、研究の手傅けのため一人娘の私に絵画を習わせた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして読みながら上着のぼたんやなんかしきりに直したりしてゐましたし燈台看守も下からそれを熱心にのぞいてゐましたから、ジョバンニはたしかにあれは証明書か何かだったと考へて少し胸が熱くなるやうな気がしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その八）此夏もくれて秋は荻の葉に風そよぐ比も過ぎぬ、松川屋敷の月日はいかに流るゝか、お蘭さま作助夫婦、直次の上にも變りたることなく、唯年來熱心なりし醫學の修業をおもひ絶えたるのみぞ此男の變動なりける。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って意外な結果や現象に対しては十分な興味をもってまともに立向かい、判らぬ事は判らぬとして出来る限りの熱心と努力をもってその解決に勉めなければなるまい。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通りの知識と熱心と忍耐と誠実があらば、そうそう解決のつかぬような困難の起る事は普通の場合には稀である。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような要求は研究に熱心な学者としての彼には迷惑なものに相違ないが、彼は格別｜厭な顔をしないで気永に親切に誰にでも満足を与えているようである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず講義講演によって人に教えるという事に興味と熱心をもっているそうである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教界などを見ても、自己の修養をば丸で後廻しとして、社会を救うの、人を教うるのと、頗る熱心にやって居る輩もあるようなれど、自分に人格がなく修養がなくて、どうして社会を教うることが出来るであろうか、己が社会の厄介者でありながら、社会を指導するもないものだ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泊れるでしょう」　お松はこう云って熱心に自分に摺寄った。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
