        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのせいかジョルジュの話をするときに夫人は一番新吉に粘りつく。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦れったいような、粘りつくような時間の前に、ほとんど垂直に、山は、その皮を剥ぎ取られた岩盤を、白く、他の一面の緑の中に浮き立たせて聳えていた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬれた金物がべたべたと糊のように指先に粘りつく事は珍しくない。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔓が絡む、茨の刺は袖を引く、草の実は外套からズボンから、地の見えぬまで粘りつく。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、ねばりねばりと粘りつく。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢田部源七郎はごくあたりまえな顔だちで、どこという特徴もなかったが、身ごなしや言葉のはしはしに、どこやら粘りつくような、芯の強さが感じられた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "びた、びた、と筵へ粘りつく跫音が、忍びやかに良人のいる部屋へ帰って行った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "池野内蔵八は、自ら云うところの、地摺の青眼を構えて、するすると、粘りつくように一刀斎へ迫って来たが、どうしたのか、ぎゃっというと、三足四足、前へよろめいたままどすと重い地ひびきを最後に息絶えてしまった。",
              "citation": {
                "source": "剣の四君子",
                "author": "小野忠明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの厳しい白翁の眼を見たか、まるで御鷹だ、なんであの眼の蔭でお息女にそんな……』　草履の裏に粘りつく黒土によろめきながら、新五左が、強情を張った。",
              "citation": {
                "source": "御鷹",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてそれは讀者の心臟にまで何と執念深くねばりつくのだ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "路々、唐黍畑も、おいらん草も、そよりともしないで、ただねばりつくほどの暑さではありましたが、煙草を買えば（私が。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから何も急いでその一つにねばりつく必要はないと云ふ心の余裕があったことが一つ。",
              "citation": {
                "source": "縁起に就いて",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕をのばす時、びしよ濡れになつたシヤツが肌にねばりつくのだけを感じた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋪道に撒かれた打水の飛沫が、剣尖のように色濃い鋭さを描いて足もとに迫り、歩きつつ矢代は、首筋にねばりつく汗を幾度も拭き拭きした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたきの顔は例の通りの脂のやうにねばりつく無表情で、なんの感情があるとも見えず、×××××××××××××××××××××××××××××××××××××××××××××××××××××××。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪がぬらりと手首にねばりつく。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんです」　宋美齢まがいのママ薯が、ねばりつくような声でいった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "フフ、俺ぁ――（語調が、変にユックリとねばりつくように低くなって来る。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんの目くそばかりの金を用立てて、そいつを枷に友達の想い者を横から取り、文句を云えば旧悪をばらすぞってよ、まるっきりぺてん師のやるこっちゃねえか、おめえさんそれでも侍のつもりかえ」　いかにも下賤にふみ跨がった、ねばりつくような木屋徳の調子は、殆んど聞くに耐えないものであった。",
              "citation": {
                "source": "竹柏記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いるか」　太く濁った、ねばりつくような声である。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネバネバとねばりつく液体のようで、そこから足をぬくことができないのです。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりんは、足の裏にねばりつく畳の音を忍んで、幾間もある奥の一室をさぐッて来ました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
