        "examples": {
          "standard": [
            {
              "text": "植えたばかりの木が、ようやく地面に根付いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その文化は、この地域に深く根付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい習慣が人々の生活に根付くには時間がかかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "蔓が容易にちぎれて残りだけでまた根付くものがある。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、あなたは、そのこがねづくりのけんをくれますか。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
