        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けだしこの地方の材質は、よく各種の建築土木の用途に適し、殊に水湿に耐へる特性を有すると、材木の産出の豊富なると、またその運搬に比較的便利なるとをもつて重宝がられ、年産額八十万石。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農林省の農業総合研究所の北海道支所では、北海道の主要農産物について、年産額の平均偏差を調べている。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもまた副業の年産額に比して高率とは言えぬであろう。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ年産額はかなりな数字に上ります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "輪島のものは塗が手堅いのを以て世に知られ、その年産額は三百万円ほどに達するといわれます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "営業者五百戸、製薬者は八百人近く、年産額二千四、五百万円といわれます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "和紙はこの郡の物産として年産額の最も大きなものであります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年産額は一千万円を超え、二百万｜反余を産し、十万戸の家がこれで生計を立てているといわれます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安部一家の年産額、僅か五千円ほどであつたのが、数年にしてその十二倍、即ち六万円に達した由を聞いた。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
