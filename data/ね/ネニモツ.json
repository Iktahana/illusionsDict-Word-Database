    "definitions": [
      {
        "index": 1,
        "gloss": "to hold a grudge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしたことには山の祖神として自分にわけも気持もあってしたことの解き開きを娘の神にとくと諾かして、根に持つ恨みを雪解の水に溶き流さすまではかの女の傍からは離れられない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっともあれはあれで親切人だから、そのことを根に持つような人柄ではないが、俺は頑固な昔気質だから、どうも寝ざめがようないのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、瑠璃子には相手の心持が、判つてゐる丈、わづかばかりの恨を根に持つて、何処までも何処までも、付き纏つて来る相手の心根の恐ろしさが、しみ／″＼と身に浸みた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度根に持つた感情が、それは決して歳月の流れに流されて子供の腦裏から消え去るものとは考へられない。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことあ、おいら、根に持つてやしねえだよ、ソローピイのお父つあん！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまだ子供の折のことを根に持つて居るといふ訳ではないけれど、何となくお桐を好かなかつた、平三にはお桐は小賢しいおせつかいな負惜みの強い女に見えた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふことに敏感で、特に根に持つ秀吉だから、関白を怖れぬ不届きな奴原、と腹をたてた。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをいつまでもいつまでも根に持つなんて、全くいやらしいですよ。",
              "citation": {
                "source": "入梅",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互い、何ひとつ根に持つことなんかないじゃないの。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "根に持つことはない」「へえ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら断つて置きたいのは、勿論私は岡本君夫妻に対し、あの時の事をさういつ迄も根に持つてゐた訳ではない。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんだ道具に遣はれて、気耻しいとこそ思へ、それを根に持つ、男じやない。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時染吉さんと面白くない事があつても、それを根に持つやうな人ぢや御座いません」　お芳は寧ろ勇太郎に好意を持つて居るらしく、躍起となつて辯解します。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二枚の小判",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋甚助さんが、娘を自分の嫁に欲しいと言つた時、私もツイポンポン斷りましたが、それを根に持つたにしても、あんまりひどい仕打で御座います。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蝉丸の香爐",
                "note": "青空文庫"
              }
            },
            {
              "text": "高木銀次郎は兵法忍術に凝つて三十過まで荻野家の世話になつて居るやうな人間ですが、義兄荻野左仲の眼を盜んで、お紋を執念く追廻し、手嚴しく耻しめられたのを根に持つて、惡事の仲間を語らつて、お紋の素姓を發き立て、到頭荻野家にも居られないやうな事にして了つたのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お紋はそれを根に持つて高木銀次郎を縛らせ、自分が荻野家へ還る筋書を作つたのさ」「親分を引張り出したのは」「錢形の平次の鼻を明かしたい爲さ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の亭主に、冗談にもせよ戀文をつけた相手ですが、それを根に持つて、お茶も出してやらないといつた氣持になれるお靜ではありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼女",
                "note": "青空文庫"
              }
            },
            {
              "text": "格子と雨戸を破つて、部屋の眞ん中に轉げ込んだ石は、いつぞやの羽織を着た石よりは更に大きく、これを土藏の屋根に持つて登るのは、大變なことで、ひ弱い男とその女房の二人では、勿論出來さうもないことです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "正月の香り",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを嗅ぎつけて、お染へしつこく絡みついた佐太郎を、虎松に誘ひ出させて打ち殺させ、――虎松がこれを根に持つて、乞食姿にも恥ぢずに、お染を口説き廻ると油斷をさせて置いて木戸の外へ送つて出た米吉に刺させたのだ」「――」　八五郎も默つてしまひました、あまりのことに、口をきく張合ひもなくなつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒酒藥酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "當主三右衞門は幸ひ赤塚家先代の鑑識に叶つて當家の婿養子となり、赤塚家を繼いで三人の子をまうけましたが、赤塚家の家督を爭つた相手は、それを根に持つて、事毎に當家に仇をし、三十年に亙つて爭ひ續けて參りました」「――」　笹野新三郎も、錢形平次も默つてしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "若樣の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしお狩場の四郎がそんな事を根に持つて、娘を殺すやうな事があつたら――」　六兵衞は何處ともなく睨み据ゑるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "巨盜還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつ、あの芝居の場の狼狽を根に持つ奴が、ならず者を廻したのだろう……と一時はそうも思いましたが、それとは、少しどうも呼吸が違うようだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年前、先妻のお艶に夢中になり、手ひどく彈かれると、それを根に持つてお艶のアラを搜し、主人の金兵衞に告げ口して追ひ出させてしまつた」「――」「姉娘のお里が年頃になると、母親そつくりの美しい娘になつた。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青葉の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰まらないことを何時までも根に持っている男だな」「根に持つ次第でも先刻のアイ※ンホーの仇討でもないが、証明して呉れと頼むから実例に利用したばかりさ。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
