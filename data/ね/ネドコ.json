  {
    "uuid": "6724aaa9-e81d-5016-9e16-47e7b2d9cb97",
    "entry": "寝所",
    "reading": {
      "primary": "ねどこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sleeping place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕は台所へは顔も出さず、直ぐと母の寝所へきた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私いちど、しのび足、かれの寝所に滑り込んで神の冠、そっとこの大頭へ載せてみたことさえございます。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "傑作のお手本、あかはだか苦しく、どうか蒲の穂敷きつめた暖き寝所つくって下さいね、と眠られぬ夜、蚊帳のそとに立って君へお願いして、寒いのであろう、二つ三つ大きいくしゃみ残して消え去った、とか、いうじゃないか。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもなおお爺さんが、苦り切って居るので、「まあ、御めん遊せや」と婆やは頭を一つぺったり下げて、逃げる様にかやの手を引いて、かやと二人の寝所に宛ててある離れ座敷の六畳に続く廊下の方へ出て仕舞った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　かやと婆やの寝所になって居る離れ座敷は、艶の宜い細骨の障子に囲まれて、低い床に、古くはあるが目の積んだ品の宜い畳が落付きよく敷かれてある。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "親子四人もいつしか各々の寝所に入り、安らかな眠りの息を呼吸してゐます。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れも致しませぬ、二十三日の午剋、尼御台さまは御台所さまをお連れになつて御寝所へお見舞ひにおいでになりました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその夜、才之助の汚い寝所に、ひらりと風に乗つて白い柔い蝶が忍び入つた。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがて奥さんも加り、お互ひの子供の事など語り合つて、しんみり、アトフキをやつてゐるうちに、突如、鶏鳴あかつきを告げたので、大いに驚いて私は寝所へ引上げた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れもしませぬ、二十三日の午剋、尼御台さまは御台所さまをお連れになって御寝所へお見舞いにおいでになりました。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じことなら、若夫婦の寝所にしのびこんでみたい、そうして、君、ああ、いやしい！",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし平生からそのすわり所や寝所に対してひどく気むずかしいこの猫は、そのような慣れない産室に一刻も落ち着いて寝てはいなかった。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄英は二人の婢を陶の寝所につけたが、三四年たって一人の女の子が生れた。",
              "citation": {
                "source": "黄英",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気でないばかりか夜中時どき寝所から姿を消して、黎明方でないといないことさえあった。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上様の寝所を覘う怪しい者があると云うから、お前は今晩から寝所の外を見張ってもらいたい」※　六郎はその晩から右大将家の寝所の周囲を警衛することになった。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正月の五日の晩、六郎は平生のように右大将家の寝所の周囲を見廻っていた。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝所のすぐ前の築山の木立の陰に入って、じっと木立の内の暗い処を見廻わしたが別に異状もないので、そこにあった岩へ腰をかけた。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その時、寝所の南縁の月の光の射している雨戸が微かな音を立てて開いた。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ難問なり、余は余の愛するものの失せしより数月間祈祷を廃したり、祈祷なしには箸を取らじ、祈祷なしには枕に就かじと堅く誓いし余さえも今は神なき人となり、恨を以て膳に向い、涙を以て寝所に就き、祈らぬ人となるに至れり。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く内へおはいんなさいよ」　台所から雑巾を持って来て、お君はお絹の足を綺麗に拭いてやって、六畳の寝所の方へいたわりながら連れ込んだ。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜寝所がそこに延べられた。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此処が王の寝所であります。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今更引戻すわけにも行かなかつたので、返事もせずに渋々と寝所の中に進んだ。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜も静かな宵のうち、父君の傍でいろいろと姫は物語などを申し上げて、少しでも父君の憂ひをやはらげようと努めてから、寝所へまで御案内をいたして、それから一人になつた姫は、自分も寝まうと思つたのでありますが、――涙が、――涙がハラハラと頬を流れて、到頭夜の花園に歩みを運んで了つたのです。",
