        "examples": {
          "standard": [
            {
              "text": "かつて存在した猫座は、現在は廃止され、その星々は他の星座に組み込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い天文学の文献には、猫座についての記述が見られることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "星図を眺めていると、かつて猫座と呼ばれた領域に目を奪われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その集団の一つに文学者、美術家、音楽家よりなる「影絵の会」があり、彼等はこれを「黒猫座」と命名したのである。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
