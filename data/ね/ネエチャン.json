    "definitions": [
      {
        "index": 1,
        "gloss": "(one's) older sister",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勝坊長屋の奥を示して、Ｔ「この奥に姉ちゃんと二人で居るんだよ」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「姉ちゃん昨日の巾着切のおじちゃんだよ」　お絹が、えッと驚いた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊尚も、Ｔ「姉ちゃんが！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊が姉ちゃんと泣き出した。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉ちゃん、お見舞いに来たよ。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉ちゃんはもう、とっくに風邪なおって起きちまってるのに見舞いに来るなんて」「でも、来てやったんだい」　蓑吉は、こまごましたおもちゃを並べるのに余念が無い。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ、姉ちゃんのお見舞いに呉れたのね、自分で買って来たの」「ああ」「それを買うおあし、お母さんにいくら貰ったの」「二円だい」　女中がきゅうきゅう笑った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉ちゃんにみんな遣んの嫌だあ」　それから蓑吉は人を賺すときの声を作って「姉ちゃん、これ、いっち好いの、ひとつあげる」　セルロイドのちっぽけなお酌人形だった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉ちゃん、姉ちゃんと蓑吉の呼ぶ声がしたかと思った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美代子をむしってはいやあよお姉ちゃん」　ここに居るのは一番小ちゃい花子の妹でした。",
              "citation": {
                "source": "花子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛い、お姉ちゃん。",
              "citation": {
                "source": "花子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は、姉ちゃん、蕨のある処を教えて下さいな。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私が帽子を取ると斉しく、婦がせき込んで、くもった声で、「ごめんなさい、姉ちゃん、ごめんなさい。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉ちゃん、お父ちゃんが、お父ちゃんが、目が見えなくなるから、……ちょっと姉ちゃんを見てえってなあ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　西行背負の風呂敷づつみを、肩の方から、いじけたように見せながら、「姉ちゃん、大すきな豆の餅を持って来た。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹の道子が女学校を卒業すると、喜美子は、「姉ちゃん、私ちょっとも女専みたいな上の学校、行きたいことあれへん。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お銀姉ちゃん泊まって行くの。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉ちゃんが待ってるぜ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」姉ちゃんだなんて言いやがる。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お滝が、ひょいと、飛んで傍へ来て、「きれいなお姉ちゃん、少しお動きよ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉ちゃん、一口吸わしたげよか」　浴衣をだらんと着たその若い娘は、陽子へ話し掛けて来た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　思わず額をおさえていると、「姉ちゃん、飴あげよか」　チマ子がまた話し掛けて来た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉ちゃん、ブラックガールのわりにきれいな」「ブラックガール……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉ちゃん、うちの頼み、きいてくれはる……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、ここを逃げ出して行くわけにいかないわ」「しかし、姉ちゃんは本当のブラックガールと違うさかい、明日になったら、すぐ出して貰えるわ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちは泥棒したさかい、あかんけど、姉ちゃんは鳩やわ」　飛んで出るから鳩だというチマ子の声の明るさに、陽子もほっと心に灯がともって、「じゃ、ここを出たら、あんたの使をしてくれというわけね」「モチ、コース……」　モチは勿論のモチ、コースはオヴ・コース（勿論）のコース。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "処々どっしりした旧独逸の高級品屋が在り、柵を引しめる棒柱のように見えるので、下品には決して墜さないで、あとは軒並みの戦後独逸の安物屋、街のかみさんや、あんちゃん、ねえちゃんといった処へ、時々素晴らしい毛皮の令嬢奥様も交った調和が、かえって淋しく品の好い高級品屋の店頭より綺麗なのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、ねえちゃんにいいものを買ってきてもらいましょう。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえちゃんもいくの。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえちゃん、いっちゃいやだ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
