    "definitions": [
      {
        "index": 1,
        "gloss": "all year round",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから床の間の掛物は年が年中朝日と鶴。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにどうでせう、妾や子ども等は年が年中、食ふや食はずなんです。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その宗兵衛の顔さえ、年が年中五寸と離れない所にあるので、此頃は何となく鼻に付きかけて居る。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして右の頬には、年が年中、丸い一銭銅貨大の紙が貼ってあった。",
              "citation": {
                "source": "再度生老人",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、彼女は非常な山だしの御転婆で、夏はいつも跣足で歩きまわり、年が年中、髪を結ったことがなく、房々とした金髪は、波を打って肩の上に垂れかかり、頸や腕は、かなりに日に焼けていた。",
              "citation": {
                "source": "誤った鑑定",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "零余子と女流俳人８・30（夕）　鈴木商店の金子直吉氏といへば、年が年中二十日鼠のやうに気忙はしく、金儲けのために働いてゐる外には何一つ持ち合はさない男である。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "年が年中六畳の間に立て籠って居る病人にはこれ位の広さでも実際壮大な感じがする。",
              "citation": {
                "source": "車上の春光",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "年が年中べらぼうに暑いってえじゃありませんか。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "年が年中、しかも六年の間世間も知らずに寐て居た病人の感じは先づこんなものですと前置きして○土佐の西の端に柏島といふ小さな島があつて二百戸の漁村に水産補習学校が一つある。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその蒲団は年が年中敷き流しである。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "年が年中昼も夜も寐床に横たはつて、三尺の盆栽さへ常に目より上に見上げて楽しんで居るやうな自分ですら、麻痺剤のお蔭で多少の苦痛を減じて居る時は、煩悶して居つた時の自分を笑ふてやりたくなる。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその鼻の先が、まるで蜂にでも刺されたかと思うくらい、年が年中恐しくまっ赤なのでございます。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "年が年中女の話ばかりして、此の宿に來て間も無いのに、正にお米は手に入れてしまつた男だ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其為に、江戸の早期から、曾我座とも言ふべきものがあつて、年が年中、招かれゝば何処へでも出向いて行つて、農村を荒さないやうに御霊の一種になつてゐた曾我｜殿原の霊を斎ひ鎮める、――念仏狂言にも近いものを行つて居たものであらう。",
              "citation": {
                "source": "芸能民習",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文士の集まつてゐる東京では、年が年中寄合ひがあつて、賑かな生活をして居るものと推測してゐるらしかつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "先生の忠告",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は柳屋の娘というと黄縞に黒襟で赤い帯を年が年中していたように印象されている。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあどうでしょうお父様と来ては、年が年中｜離座敷ばかりにいて一度として主屋へはいらっしゃらない。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから聞いたら此男は年が年中赤シヤツを着るんださうだ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――意気地がなくって、理窟がわからなくって、個人としちゃあ三文の価値もないもんだ」「だから、どしどし豆腐屋にしてしまうさ」「その内、してやろうと思ってるのさ」「思ってるだけじゃ剣呑なものだ」「なあに年が年中思っていりゃ、どうにかなるもんだ」「随分気が長いね。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから聞いたらこの男は年が年中赤シャツを着るんだそうだ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ年が年中足を擂木にして、火事見舞に行くんでも、葬式の供に立つんでも同じ心得で、てくてくやっているのは、本人の勝手だと云えば云うようなものの、あまり器量のない話であります。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも御尤には違ないが、いくら騎兵だって年が年中馬に乗りつづけに乗っている訳にも行かないじゃありませんか。",
              "citation": {
                "source": "現代日本の開化",
                "author": "――明治四十四年八月和歌山において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつの脳と来たら、年が年中摺鉢の中で、擂木に攪き廻されてる味噌見たようなもんでね。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一定の仕事の無い上に絶えず目算ばかり立派に立てて居る主人は何一つとしてまとまった事にはせず、年が年中貧亡に攻められながら「今に何かやって見せるぞ」と云う二十代からの望みをはたすためにあくせくして居た。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して此夏が年が年中で、正月元日浴衣がけで新年御芽出度も困りものだが、此処らの夏はぐず／＼するとさっさと過ぎてしまう位なので、却ってよいのである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は年が年中｜其処につくねんと立って居るが、全体何をするのだい？",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から晩までさ、年が年中｜其処にぬうと立ちぽかァんと立って居て、而して一体お前は何をするんだい？",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
