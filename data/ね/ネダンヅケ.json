        "examples": {
          "standard": [
            {
              "text": "フリーマーケットでは、店主が手書きで商品の値段付けをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新商品の値段付けは、原価と競合他社の価格を考慮して決定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アンティークショップの店員は、商品の希少価値に基づいて値段付けを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大型コンピューターの世界では、これまでハードとソフトに保守サービスまで加え、全部でおいくらとの値段付けになっていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一度、二月ばかりかかってこしらえた五寸四方ばかりの小袱紗を、私の塾の展覧会に出した事がありましたが二十円という値段付けだったので売れ残ってしまいました。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本屋が來て値段付けが終ると、本屋はリヤカーを取りに行き、打木田は豫想外の額の金をうけ取り、北里にその金を示したが、この變な男はそんなことに氣を奪られてゐないらしく、打木田に持つて行くやうにいつた。",
              "citation": {
                "source": "汽車で逢つた女",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
