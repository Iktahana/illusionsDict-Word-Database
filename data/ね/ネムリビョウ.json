    "definitions": [
      {
        "index": 1,
        "gloss": "sleeping sickness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
