    "definitions": [
      {
        "index": 1,
        "gloss": "to wind (e.g. a watch)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎朝、懐中時計のねじを巻くのが日課だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い目覚まし時計は、毎日ねじを巻かないと動かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "おもちゃのロボットのねじを巻くと、カタカタと動き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ツネちゃんが箱のねじを巻くと、雀は、カッタンカッタンと左右に動きはじめる。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者では、大方ご存じの通りシャーロック・ホームズは死者の時計ねじを巻くことで二時間前にも巻かれていたこと、そしてゆえに故人が寝みについたのはそれ以後だと証明してみせ――この演繹が事件解明にめざましい働きを見せた。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、例のちっぽけな懐中時計を出して、ねじを巻く。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねじをまくと、さっそく、このさいく物の鳥は、ほんものの鳥のうたうとおりを、ひとふしうたいました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "大時計には、そんな穴は、べつにひつようはないのですが、柱時計の文字ばんのねじをまく穴ににせて、そんな穴があけてあるのです。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to give (someone) a good prodding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最近たるんでいる部下に、そろそろねじを巻かないと。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験前なので、子供たちに勉強のねじを巻いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チーム全体のモチベーションが下がっているので、監督がねじを巻く必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
