          "literary": [
            {
              "text": "復讐の女神ネメシスが、逆手に掴んでいるような、短剣の形だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "復讐の女神ネメシスが、逆手に掴んでゐるやうな、短剣の形だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "優善の背後には、もうネメシスの神が逼り近づいていた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "性格の残忍刻薄が主因だったから自業自得といえばそれまでだが、もっと根づよい因果的な、謂わばネメシスの咀いに追及されているような形だった。",
              "citation": {
                "source": "処女の木とアブ・サルガ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（b）おお、ネメシスよ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
