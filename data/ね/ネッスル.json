    "definitions": [
      {
        "index": 1,
        "gloss": "to heat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いかなれば涙を流してかくも黄色く古びたる紙頁の上にわが情熱するものを情熱しつつ寂しき人生を語り續けん。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めにある温度まで熱してやらぬと電気が通らぬから、これを熱するため小さいコイルが附属してある。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めに電流がこのコイルを通ってこれを熱すると、その中にあるマグネシアの線が熱して導体になり光り始める。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばビーカーをアルコールランプで下から熱すると水蒸気が出てそれがビーカーの外側にあたって冷却され、水粒がビーカーに附着する。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また風が速度のために熱するということも考えられている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は象徴にまで灼熱する力も才能もないのを思つて今まで默してゐた。",
              "citation": {
                "source": "詩への逸脱",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で熱する頭を押へて、愼重に詮議する積で、今日まで躊躇してゐたのであつた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま風景は秋晩くすでに枯れたりわれは燒石を口にあててしきりにこの熱する　唾のごときものをのまんとす。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷が白熱するとき言葉は象徴の形式を帶ぶ、あらゆる藝術の至上形式は象徴にあり、然りと雖も形式は結果にして目的にあらず、象徴のための象徴の如きは畢竟藝術上の遊戲にあらずして何ぞや。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は五、六年前から、からだの調子を悪くして、ピンポンをやってさえ発熱する始末なのである。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば長方形の水槽の底を一様に熱するといわゆる熱対流を生ずる。",
              "citation": {
                "source": "とんびと油揚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熾烈な日光が之を熱して更に熱する時、冷却せる雨水の注射に因って、一大破裂を来たしたかと想う雷鳴は、ぱりぱりと乾燥した音響を無辺際に伝いて、軈て其玻璃器の大破片が落下したかと思われる音響が、ずしんと大地をゆるがして更にどろどろと遠く消散する。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷に鋭き眼の光は異く彼を襲ひて、坐に熱する怒気を忘れしめぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "久く会ひませんな」　貫一は愕然として二人の面を眺めたりしが、忽ち身の熱するを覚えて、その誰なるやを憶出せるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもそのはず、裸で居続くるにかかる物を塗らぬと毒虫に螫されやすく、気温が変るごとに感冒発熱するところ多い。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "火と熱する誠意と祈りとをこめて僕はここにこの手紙を封じます。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にでも自分の理想をすぐあてはめて熱するような、そんな若い心がほしくもありますけれども、そんなものはわたしには来はしません……春にでもなって来るとよけい世の中はむなしく見えてたまりません。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤く熱すると云うよりも、白く冷たく而も極度に熱していた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの性質からいっても、家庭の事情からいっても、現在の恋の状態からいっても、はげしく熱するにはまだだいぶ距離もあり余裕もあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何条もってたまるべき、艦も機も敵兵も大感電して、たちまち白熱する一抹の煙になって……。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰りこれは海水を汲み揚げて、それを機關室からの熱い蒸氣で熱するのである。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤く熱すると云ふよりも、白く冷たく而も極度に熱してゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い風が街頭の木々を揺すっておりましたけれど、私は緊張のために、むしろ身体の熱するのを覚えました。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより東京とて同じであるが、ここのは真面目な仕事であるから、一層歓楽が白熱する。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "過勞から發熱するといふこともあるひはあるかも知れないが、此頃は別に過勞などとは云へない。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく人は物事を考えると頭が熱するというけれど、僕はちょうど反対だ。",
              "citation": {
                "source": "自殺か他殺か",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば無駄に読まされた百巻の書籍に対して林のために憤怒し、正しい知識を圧殺する野獣的暴圧に対してプロレタリア作家として血の熱するのを覚える。",
              "citation": {
                "source": "文学に関する感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、スポウツに藉りて白熱する帝国主義！",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験管を焔の上で熱する図などが活々としたフリーハンドで插入されていて、計らずも今日秋日のさす埃だらけの廊下の隅でそれを開いて眺めている娘の目には、却ってその絵の描かれている線の生気に充ちた特徴の方が、文字よりも親しく晩年の父の姿や動きを髣髴させる。",
              "citation": {
                "source": "本棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
