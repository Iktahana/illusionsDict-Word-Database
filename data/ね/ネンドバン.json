        "examples": {
          "standard": [
            {
              "text": "この畑は粘土盤の下に水が溜まりやすい構造になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_ja": "粘土盤は、植物の根の伸長を妨げることがある。",
              "text_en": "Claypan can sometimes hinder root growth.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "土壌の水分調査の結果、浅いところに粘土盤があることが分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
