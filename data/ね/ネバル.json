    "definitions": [
      {
        "index": 1,
        "gloss": "to be sticky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おまけに其の晩は蒸し暑かったので、かれの額や首筋には粘るような気味の悪い汗がにじみ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の靴には膏薬のように粘る軟土が慕いよった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頸と言わず、肩と言わず、降りかかって来ましたが、手を当てる、とべとりとして粘る。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "裳裾のようにパッとひらいた頽廃の夜が、葉鶏頭の花にも似た強烈な色彩に揺れて、イヴニングドレスの背中をくりぬいて見せた白い素肌が、蛇のようにくねると、そのくぼみに汗が汗ばみ、女の体臭を男の体臭が絞り出すような夏の夜の踊りに、体の固い若いダンサーのステップもいつか粘るのだった……。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は小さな手を粘る土に※込んでは兩手の力を籠めて引つ返す。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "恢復しかけた病後の疲勞が夜は粘るやうな汗を分泌させた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとつゝあ」とおつぎは底の粘る草履を捨てゝ激しく呼んで驅け込んだ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "例せば誰も蛇は常に沾れ粘ったものと信ずるが、これその鱗が強く光るからで、実際そんなに沾れ粘るなら沙塵が着き、重りて疾く走り得ぬはずでないか。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その樹皮と葉を駆虫剤とし、葉を乾かして痢病に用い、殊に汗を減ずるに使い、その木を網の浮きとするなど、すこぶる多用な木だが、一番珍重さるるはその実で外部木質、内に少し酸く冷やかな軟肉ありてゴム様に粘る。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が寂光庵に着いた頃は、恰度雷雨の前提をなす、粘るような無風帯の世界であった。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ベタベタと粘る手の掌を肉襦袢にこすりこすり、周章て楽屋の方へ駈けて行った。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "納豆はそのまま混ぜてもよいが、普通に納豆を食べる場合と同じように、醤油、辛子、ねぎの薬味切を加えて、充分｜粘るまでかき混ぜたものを入れるとよい。",
              "citation": {
                "source": "夜寒に火を囲んで懐しい雑炊",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにこんな名のあるのはその嫩の枝蔓の内皮が粘るから、その粘汁を水に浸出せしめて頭髪を梳ずるに利用したからである。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢を挾んでキチンと坐つたところを見ると、年の頃は精々二十五六でせうか、刻みの淺い所謂ノツペリした美男で、物言ひの妙に粘るところなど、何んとかいふ歌舞伎役者の臺詞廻しを眞似して居るのかもわかりません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "水垢離",
                "note": "青空文庫"
              }
            },
            {
              "text": "気に入ったのがあるなら、そんな回りくどいことをせずに、広小路の店へ乗込んで行って、温かい茶一杯で半日も粘る術があるじゃないか」「そう思うのは素人量見で――銭形の親分の前だが、情事にかけちゃ、丹波彌八郎や網干の七平の足許にも寄りつけない」「何んだい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダブダブの茶腹で、夜っぴて米沢町一丁目の路地の奥に粘るんだから、深草の少将は楽じゃありませんぜ」「フーム」「中でも丹波彌八郎は大変で、――苗字がちゃんとあるんだから、これは二本差の子ですがね。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家として粘ること自体がいかがわしい文学の潮流に対してのプロテストであり、今日もし私たちが阿諛的な賞讃など得られるとしたら、それこそ！",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、私はなかなかその点では粘るから、きっとやがて三等賞ぐらいには漕ぎつけるつもりです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな連中でさえそれだけ粘る。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちにそれは出来ないが、しかし、粘るところは、ざらにない力です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しきりに抜こうともがいているうちに、次第にずるずると深みへ引っ張られそうになるんで、ハテな、ガータロに見込まれると水が粘ると云う話だが、こりゃあガータロの仕業だなと気が付いたんです。",
              "citation": {
                "source": "紀伊国狐憑漆掻語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "温かく、重たく、そして粘るように軟らかな妻の躯が、妻の躯の弾力のあるまるみや、厚みが、自分の背中にじんわりと押しつけられるのを感じながら、甲斐はやはり無抵抗に動かなかった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしもサメが来たら、奴も俺もお手上げだ」　奴を相手に俺が粘るように、大ディマジオも魚と長く戦えるだろうか。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、話がつかなけれや、俺たちは、当分、ここへご滞在となるかも知れねえが」四郎の嫌がらせは例によってモチのように粘る。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もうよし、くどい問答は切りあげて、また出直そう」もっと粘るかと思いのほか、四郎は手下を連れて、あっさりと引揚げてしまった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも極めて、一足一足、粘る土でも踏んでいるように、やわらかな若草の崖を、少しずつ、しかし――いつ鷲のごとく飛ぶかも知れない姿勢をもちながら、眼にあまる人数の前へ――というよりは死地へ――近づいて来るのであった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な高坏に、とろりと粘るような手造りの地酒。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのため紅い唇や、蜂蜜のように粘る手や、甘酢い髪の毛のにおいやらが、すぐ頭から去って、彼は、常の彼の身に回っていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の太刀は実によく「粘る」ところに先天的な特色があった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "モチの米という名はすでに『和名鈔』にも見え、モチという言葉は鳥黐も同じに、粘ることを意味したようだが、それだからとて今と同じ餅が、古くからあったとはかぎらない。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
