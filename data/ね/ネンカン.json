        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（年刊『詩と随筆集』第一輯1928年５月発行）-----------------------------------------------------------------　郵便局　郵便局といふものは、港や停車場やと同じく、人生の遠い旅情を思はすところの、悲しいのすたるぢやの存在である。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにあつた安永五年刊の雨月物語を取つて鉢の蓋にした。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八三年刊行、一六号一五一頁。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "後インドではトッケとてわが邦の蜥蜴に名が似て、カメレオンごとく能く変色する蜥蜴、もと帝釈の宮門を守ったと伝う（ロウ氏の説、一八五〇年刊『印度群島および東亜細亜雑誌』四巻二〇三頁）。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九四年刊行『ネーチュール』五一巻八〇頁に出たマレー氏の写真でもよく判る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二一年刊『ノーツ・エンド・キーリス』十二輯八巻拙文「孔雀の尾」）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔大正15年刊『太陽は草の香がする』〕",
              "citation": {
                "source": "山雀",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔昭和２年刊『猫の微笑』〕",
              "citation": {
                "source": "黒猫",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつめ、老人をわやにしよるわい」〔大正15年刊『太陽は草の香がする』〕",
              "citation": {
                "source": "中宮寺の春",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔昭和９年刊『独楽園』〕",
              "citation": {
                "source": "春の賦",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "・河出書房新社『定本　横光利一全集　第四巻』（昭和五十六年刊）を底本とした。",
              "citation": {
                "source": "時間",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "・河出書房新社『定本　横光利一全集　第三巻』（昭和五十六年刊）を底本とした。",
              "citation": {
                "source": "鳥",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋挙編の『惟然坊句集』（文化９年刊）がある。",
              "citation": {
                "source": "風狂私語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三六年版の年刊には、果してどのように成長した時事的作品が短歌の境域に出現するか、見落せない期待のひとつです。",
              "citation": {
                "source": "歌集『集団行進』に寄せて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは天和三年刊行の『虚栗』に出でたる句なり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "只嵯峨｜樵歌の一巻は此年刊行せられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昨年刊行キング氏著『米国人の富及び所得』九六ページ＊）。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "――千九百十九年七月十七日　　東京の西郊中野にて脱稿（『三木清著作集』第一巻所収　一九四六年刊　岩波書店）",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間に異色ある古歌の研究「戀愛名歌集」（昭和六年刊）が成つた。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "全集版：東京創元社『定本北條民雄全集・上巻』昭和五十五年刊　数字は定本のページ数と行数を示す。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "福澤先生は其後「暗誦十詞」を明治六年刊行したと、今は故人たる吉野甫が、明治四十一年昭文堂刊行の「明治詩集」中の新體詩年表に書いたが、それはまだ讀むで居ない。",
              "citation": {
                "source": "新詩發生時代の思ひ出",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人は英雄を待たない、聖人を待たない……』　ユーゴーのは「光と暗」（一千八百四十年刊行）の序全部で、例の如く飽く迄も意識的に自己の抱負を述べたものである。",
              "citation": {
                "source": "新詩發生時代の思ひ出",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Brasse's A Greek Gradus 一八四二年刊行）　漢文學の上に見ると、固有名詞の詩的特權は同じく甚だしい。",
              "citation": {
                "source": "「イーリアス」例言",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "安藤昌益の名が文獻に見はれたのは、寶暦四年刊行の新増書籍目録卷二に、其著書である孔子一世辨記二册と自然眞營道三册とが掲載せられてゐるのが最初であり、又最後であつたらうと思はれる。",
              "citation": {
                "source": "安藤昌益",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "千七百八十二年刊行の本書に著者はルソーの句をかりて「現代の世相を見て余はこの書簡集を公にした」といふ。",
              "citation": {
                "source": "思想なき眼",
                "author": "――「危険な関係」に寄せて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月四日　ちくまち村にて　神西清訳　プーシュキン荘園ものがたり中「ヌーリン伯」　これはシェクスピアの「ルクレチア」（一五九四年刊行）をプーシュキンが、もじったパロディーである。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かたい　けっしん　一休さんは　さいごんじで　四ねんかん。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さいごんじの　おしょうさまに　四ねんかん　まなびました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
