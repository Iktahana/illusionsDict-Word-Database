        "examples": {
          "standard": [
            {
              "text": "ある物質の燃焼熱は、カロリー計算に利用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ロケットエンジンの開発では、燃料の燃焼熱が重要な指標となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この木の燃焼熱は、予想以上に高かったよ。」と彼は報告した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "同じ頃、フィックの義理の兄弟であるイギリスのフランクランドは食物や尿素の燃焼熱を直接に測定する方法を開発していた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに1894年にルーブナーはイヌの尿素生産とガス交換を同時に測定し、熱発生と代謝している食物の燃焼熱が対応していることを示した（17）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
