    "definitions": [
      {
        "index": 1,
        "gloss": "indisposition (e.g. a cold) caused by getting chilled while sleeping",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれどもまず平穏無事に日が経ちますうち、ちょうど八月の中ごろの馬鹿に熱い日の晩でございます、長屋の者はみんな外に出て涼んでいましたが私だけは前の晩寝冷えをしたので身体の具合が悪く、宵から戸を閉めて床に就きました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断すると寝冷えするなどと云いながら、四ツの鐘を聞いて寝床にはいると、その夜なかに半七の戸を叩いて、松吉が飛び込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん寝冷えをしたのだろうというので、今朝ほどは立つのを止めました」「そうですか、それはあいにくでしたね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯今も申す通り、どうも寝冷えをいたしたとみえて、暁方から頭が痛みまして……」「あたまの痛てえのはほかに訳があるだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めは寝冷えぐらいの事と思い居り候ところ、――ですって。",
              "citation": {
                "source": "母",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……宵から此が気にかゝつて、むしやくしやと寝られなんだに――、お中（娘の名）も寝冷えせぬやう、よく著て寝よ。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、寝冷えなんでございますよ。",
              "citation": {
                "source": "幼き日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝冷えもしていて、きょうは両方で休み（仕事もないので）私共三人は（母上・多賀子、私）徳山まで出かけました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝冷えをなさらないようにね八月四日夜　〔巣鴨拘置所の顕治宛　目白より（封書）〕八月四日　　第三十九信　昨夜から書きかけていた手紙があったのだが、それはやめてしまって別にはじめます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝冷えなさらないように。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蚊に喰べられたのでございましょう」「蚊ならよいが」「寝ても暴れて、蚊帳の外へ、ころげますので」「寝冷えさすな」「はい」「疱瘡に気をつけよ」「仰せまでもございませぬ」「夫婦が仲の初の児。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
