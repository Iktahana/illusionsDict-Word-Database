    "definitions": [
      {
        "index": 1,
        "gloss": "day of the Rat (esp. the first day of the Rat in the New Year)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "八重子の日記にはおやつやおかずの事がだいぶ詳しくかいてあった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐頭聞いて、此の橋は昔聖徳太子の日本六十｜余州へ百八十の橋を御掛けなされし其の内にて候よし伝へうけたまはり候、誠にて候や、と言ふ。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば甲子の日曜日は一年に一つあることとないこととあるのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子の日本橋でのあきないは非常に少なかった。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ巻でも「子の日」と「春駒」、「だびら雪」と「摩耶の高根に雲」、「迎いせわしき」と「風呂」、「すさまじき女」と「夕月夜｜岡の萱根の御廟」、等々々についてもそれぞれ同様な夢の推移径路に関すると同様の試験的分析を施すことは容易である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、呟いて仰向けに寝た――妙子の日とは――日曜を意味したのである。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀代子の日頃の勝気そうな顔は頬紅をつけているので、今日はいくらか間が抜けて見えたのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子の日影は、桟をやや低く算え、欄間の下に、たとえば雪の積ったようである。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の柳の散る中に、つないだ駒はなかったが、細流を織る木の葉は、手綱の影を浮かして行く……流に添った片側の長い土塀を、向うに隔たる、宗参法師は、間近ながら遥々と、駅路を過ぐる趣して、古鼠の帽子の日向が、白髪を捌いたようである。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "須磨子の日向訛りが商人に通ぜぬので、用が弁ぜずにすごすご帰ることが多い。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "曽子の日頃の篤学力行は、既に物事にも道理にも十分に充実して、しかも満足することなく、先王の教・孔子の道の奥義を究めようとしている。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど元日が子の日にあたっていたのである。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "『もうよいよい、白状する、いかにもわしは露満国境から帰つてきた許りぢやでな、帽子の日焼がまだとれんで、すぐ○○と判りをるわいハハハハ―』　客と芸妓達は笑ふのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "明なる障子の日脚はその面の小皺の読まれぬは無きまでに照しぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『抱朴子』内篇四に、山中｜寅日、自ら虞吏と称するは虎、当路者と称するは狼、卯日丈人と称するは兎、西王母と称するは鹿、子の日社君と称するは鼠、神人と称するは蝙蝠など多く例を挙げ、いずれもその物の名を知った人を害し能わずとある。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "今村鞆君の『朝鮮風俗集』に、正月の一番初めの子の日、農民争うて田野に出で、野原を燃す。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮でも野鼠殖えて草を荒らす予防に、正月上子の日その蟄伏した処を焼いて野草の繁茂を謀ったので、支那で一月七日に家鼠を饗するを虫焼きと呼ぶも、本この日野鼠を焼き立てる行事があった遺風だろう。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通り蚕室は初子の日初めて掃除したので、子の日を用ゆるは専ら鼠害を厭する意と見える。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "今村君の『朝鮮風俗集』にまたいわく、上子の日子の刻臼をつけば鼠の種尽くると称し、深夜空臼の音を聞く、昔宮中で小官吏が炬に火を付けて大声に鼠｜燻し鼠燻しと呼んで庭内を曳きずり廻した後、王様から穀物の煎ったのを入れた袋を賜わった事が民間に伝わったものであると。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に引いた支那で上子日に家鼠を饗して炒雑虫というを考うるに、最初この日野を焼いて野鼠蟄虫を鏖殺し、その夜家鼠を饗して、汝ら野鼠ごとく焼き殺さるるを好まずば年中音なしくせよ、さすればこの通り饗応しやると、恩威並び行いしより変って鼠の嫁入り祝いとも、子の日の遊びともなったと惟う。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の『譚海』の文に拠れば鼠が神になって大黒天と現じたようだが、『滑稽雑談』二一には、大黒天神は厨家豊穣の神なるが故に、世人鼠の来って家厨の飲食倉庫の器用を損ずるをこの神に祈る時、十月の亥の日を例として子の月なる十一月の子の日を（祭りに）用ゆるなるべしと記す。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "元禄五年板、洛下俳林子作『新百物語』二に金沢辺の甚三郎という商人、貧しくなり、大黒天を勧請して、甲子の日ごとに懇にこれを祀る。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の日の神将名は毘羯羅、これは毘沙門や大黒と別口の神で、中央アジアで支那の十二支をインド出の十二神に配して拵えたものと見える。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "子の日原の喬松、その數千株なるを知らず。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村はもとより一度いい出したらあとへは引かない葉子の日ごろの性分を知り抜いていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪のいと長くなりにたるを見て日を數ふれば、今日は子の日なりければ切らず。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月なれば京の子の日の事いひ出でゝ、「小松もがな」といへど海中なれば難しかし。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある女の書きて出せる歌、「おぼつかなけふは子の日かあまならば海松をだに引かましものを」とぞいへる。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "海にて子の日の歌にてはいかゞあらむ。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "およぐひとおよぐひとのからだはななめにのびる、二本の手はながくそろへてひきのばされる、およぐひとの心臓はくらげのやうにすきとほる、およぐひとの瞳はつりがねのひびきをききつつ、およぐひとのたましひは水のうへの月をみる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
