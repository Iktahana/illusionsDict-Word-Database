[
  {
    "uuid": "c7fad71a-fa7b-57f1-aaae-65d6bf9bdf2a",
    "entry": "年始",
    "reading": {
      "primary": "ねんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
