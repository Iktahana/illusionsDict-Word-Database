    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beginning of the year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "料理人篠村宇三郎、かご入りの青海苔を持って来て、「これは今年始めて取れましたので差上げます。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年始めてイタリアのお寺でこの懺悔をしているところを見ていやな感じがしてから、この仕掛けを見るごとに僧侶を憎み信徒をかわいく思います。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年始めて西洋の土地を踏んだ晩ゲノアの宿屋で夜ふけに窓の下でマンドリンをひきながら歌う者があった、その歌の調子がいかにも感傷的と言うのか卑俗と言うのか妙な感じがしましたがきょうのもやはり同じ感じがしました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校時代のある年の元旦に二三の同窓といっしょに諸先生の家へ年始回りをしていたとき、ある先生の門前まで来ると連れの一人が立ち止まって妙な顔をすると思ったら突然仰向けにそりかえって門松に倒れかかった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはことしのお正月にＫ君と二人で、共に紋服を着て、井伏さんのお留守宅（作家井伏鱒二氏は、軍報道班員としてその前年の晩秋、南方に派遣せられたり）へ御年始にあがって、ちょうどＩ君も国民服を着て御年始に来ていましたが、その時、Ｉ君が私たち二人を庭先に立たせて撮影した物です。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚後一ヶ月目の年の暮から、私をこの海岸の旅館に寄越して置いて、自分は年始廻りやら、正月の交際を済まして五日の日に宿へ来た彼は、割合に荷嵩な手荷物やらゴルフの道具やらを持ち込んだ。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "知って居るところへは旅行をするから年末年始の礼を欠くという葉書を出してあるので客は一人も来ない。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの秋に婚約が出来て、次の年の正月にはじめておまえの家へ年始に行ったときな。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減にこつちもあひしらひしてゐると、こんどはあの婆さんが来て、年始の手拭を何反とかこさへてくれと云ふんだ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "児子家では、この正月から年始の客に酒肴を出しても良いということになった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮肉な年始客である。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子はまだ赤ん坊の顔も見ず、母の妊娠していたことすら知らずにいたのだったが、なるほどそう言えば正月に受け取った時ちゃんの年始状の端に、また妹が一人｜殖えました、どうして家には男の子が出来ないんでしょうなどと書いてあったが、余所事のような気持で、嬉しくも悲しくもなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしのお正月、僕は近所へ年始まわりに歩いたついでにちょっと青扇のところへも立ち寄ってみた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年の元日に虚子が年始に来たから、東北と云う謡をうたったところ、虚子が鼓を打ち出したので、余の謡が大崩になったという一段を編輯へ廻した。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を訪問に出る事はあるが、年始とか盆とかの廻礼などは絶対にしない。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしのお正月には、あなたは、あなたの画の最も熱心な支持者だという、あの有名な、岡井先生のところへ、御年始に、はじめて私を連れてまいりました。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "麹町にも、とんとごぶさただそうだし、私のところへなんか、年始状だって寄こしゃしない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お正月には、斎藤先生の所へ、まっさきに御年始に行こうと思っている。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年前のお正月、僕は草田の家に年始に行った。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、どうして、三年前のお正月に限って、お年始などに行く気になったかというと、それは、そもそも僕自身が、だらしなかったからである。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の年始のお客にも、いちいち僕を「流行作家」として紹介するのだ。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七年始めて仏書を観たもう。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらんだせりに似るこの十字花科植物の一種の風味有つて食ふに堪ふることは、今年始めて之を知つたのである。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツユクサの新芽は今年始めて試みたが、大に推奬するに足りるものである。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一誤解されてもつまらないし、人によっては同性愛なんてけちをつけまいものでもなし――結婚したら年始状以外に私へ文通するでは無いと、結婚前にあれほどくどく言ったじゃないか。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正月に西岡は叔父のところへ年始に来て、屠蘇から酒になって夜のふけるまで元気よく話して行った。",
              "citation": {
                "source": "離魂病",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「多代子さんは一月の十日、自動車に乗って御年始に来てくれました。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に知ってんねんし。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "繋留索は、はじめはとても本艇からはなすことができないほど強いもので、それをたち切ることをだんねんしていたが、テッド隊長はガンマ和尚がいったことばに希望を持ち、隊員をなおも繋留索のところへいかせて、それをたち切る作業をつづけさせた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも事のおこりというのは、長政公が十五におなりになったとし、えいろく二ねんしょうがつと云うのに元服をなされて、それまでは新九郎と申し上げたのが、そのときに備前のかみながまさとお名のりなされ、江南の佐々木｜抜関斎の老臣平井加賀守どのゝ姫君をお迎えなされました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
