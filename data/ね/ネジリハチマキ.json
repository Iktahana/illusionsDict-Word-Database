        "examples": {
          "standard": [
            {
              "text": "大工さんが額にねじり鉢巻きを締めて、作業に打ち込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祭りの参加者たちは皆、威勢よくねじり鉢巻きを巻いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気合を入れるため、私もねじり鉢巻きを締めて受験勉強に臨んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ねじり鉢巻きの男が三人、汗を拭きながら寄って来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集の一部は、素っ裸にねじり鉢巻きをした若い衆を先頭に、警戒を破って、和泉屋の大戸へ接近した。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
