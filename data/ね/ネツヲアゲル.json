        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は新しい趣味に熱を上げて、週末はずっとそれに没頭している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若い頃、彼女はテニスに熱を上げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームは、次の大会に向けて練習に熱を上げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "君が竹さんに熱を上げるのも無理はないと思った。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君があまり、竹さんに熱を上げるので、寝込まれたりしても困ると思って、その後、竹さんに就いての御報告を控えめにしていたが、そんな心配は全然不要だという事が、けさ、はっきりわかった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆から冷かされるのを真に受けてイヨイヨ芝居熱を上げるという超特級の難物である。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふのがあると他の投書家達は無念の歯がみをしながら、よし今度こそは、と投書熱を上げるのである。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
