    "definitions": [
      {
        "index": 1,
        "gloss": "to screw in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "外套の隠しへねじ込むと蜜柑がつかえるから、また片手でしっかりさげて歩き出した。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉が金槌をいじりながら考え込んでいるのを見て夫人は意地悪くねじ込むような声で言った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふところに品物をねじ込むんですよ、今のは器用にすり取ったようだがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆といや、つまり、あれをあべこべに、ふところへ品物をねじ込むんでさあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間的な気持ちを持っていた人たちが、なぜあのような大量破壊兵器の開発に全力で取り組むことができたのか」　監督のジョン・エルスはそう問題を設定し、ねじ込むように対象に迫っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　無雑作に懐へねじ込むのを見て、保子からそう注意された言葉を、彼は上の空で聞き流して、外に出た。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "差し出した巻き奉書をあわただしく、綴じ紙と一緒に懐中の奥へ、ねじ込むと茫然たたずんだ。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ殆ど這うようにして近づいた女房が、ヘギの包みを仙右衛門の懐中にねじ込む）女房　仙衛ムどん、先々で食べて下せえよ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の中へでも水の中でもあっしは飛び込んで行きますよ」　狭い単衣からハミ出す膝ッ小僧をそろえて八五郎は平次にねじ込むのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "小判と駄菓子と一緒に懐ろへねじ込むのは、店中にその小僧の外にはあるまい」「この野郎、――どこから、誰に頼まれて持って来た。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "権八の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸の下に煙草入をねじ込むような物好きな野郎はあるめえから」　ガラッ八はまた尖った口を入れます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が殺されたんだ」「鋳掛屋の権次」「よし、行ってみよう」　平次は十手を懐中にねじ込むと、もう立ち上がっておりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "五つの命",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃちょいと行って来ますよ、親分」　ガラッ八はもう立上がって、懐へ十手と手拭と財布をねじ込むのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "不死の霊薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの晩、お前がお米にねじ込むつもりで二階へ行くと、お米の部屋から、飛出して来るお夏の後ろ姿を月明りで見たはずだ、――廊下に灯はないが、高窓から、月がよく射している――昨夜は月がよかった」「…………」「部屋に入ってみると、お米は殺されている、お前はてっきりお夏の仕業だと思った、――無理もない話さ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二本の脇差",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナイフを傷にねじ込むようなもんじゃ」　しばらく間をおいた。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "――で例の大学教授連盟も、もしこうした一種の威厳業組合か、又は威厳業ギルドであるなら、歌舞伎座へねじ込むのも商売上大いに必要なわけだろう。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ殆んど這うようにして近付いた女房が、ヘギの包みを仙右衛門の懐中にねじ込む。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四千ルーブリまでは数えたけれど、五千ルーブリ目は数えもしないで受け取って、そのままポケットへねじ込むと、あたふた逃げ出してしまった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "不具者は、たれも見る者がないと思ったのか、別段あわてもしないで、包物を拾いあげ、懐中にねじ込むと、急ぎ足に立去った。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、経帷子で指環を小さくくるみ、懐中にねじ込むと、足許にころがっている、素裸体の肉塊を、さも面倒臭さ相に、手と足を使って、新しく掘った墓穴の中へ、落しこんだのです。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウム、もうこうしちゃいられねえ」　あわただしく取ってかえすや否、賭けてあった小判をのこらずかきあつめて、ザラザラとふところにねじ込む。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして弁当を元どおりに包んで腰にさげ、スケッチ帳をふところにねじこむと、こそこそと入り口に行って長靴をはいた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて、松山さんが、にこりともせず、怒ったような口調で、「あア、好きで好きでたまらない、か」と言いざま、二人とも、声のない嘲笑を、ぼくの胸にねじこむような眼付で、ぼくの顔をみながら、ドアをばたんと、乱暴に閉め、足音高く、出て行きました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていったんしまった黄金メダルと絹のきれとを再びとりだし、すばやくズボンのポケットにねじこむと、裏口からそっと外へでた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカでは、きっと日本潜水艦の襲撃をくったものとして、日本政府にねじこむにちがいない。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その新聞をもらって腹掛のなかへねじこむとそのまゝ、空の盤台を引ッかつぎの……というのは、その日酷いシケの日でさかなは何にもなかった。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（無理に父の口にねじこむ。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねじこむというのが、やはり懐の中だから、又笑ってしまう、ねえ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お菰は、ばばの真面目くさった顔に、ぷッとふきだしかけたが、鼻紙のように懐中へねじこむわけにもゆかず、写経を額に当てて、ちょっと拝む恰好をしながら、「ところで」　と、身を交わすように、急に話のほこをすげ替えた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
