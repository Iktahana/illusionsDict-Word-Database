    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indicates emphasis",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
