[
  {
    "uuid": "5ac1174f-6806-542f-b6ab-3bc40d859d29",
    "entry": "念",
    "reading": {
      "primary": "ねん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
