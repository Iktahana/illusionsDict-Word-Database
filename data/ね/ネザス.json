[
  {
    "uuid": "66e0ba04-20b6-5dcd-bc8d-294e3d85802c",
    "entry": "根ざす",
    "reading": {
      "primary": "ねざす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
