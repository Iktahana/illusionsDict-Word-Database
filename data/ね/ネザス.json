    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to come from",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もともと「神が在る」といふことは、私の直観に根ざすのだ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと適確に云ふなら、西田幾多郎の「純粋意識」に根ざすのだ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ嘗て自分の心内乃至身邊に起る事物に對して、その根ざす處如何に深く、その及ぼす所如何に遠きかを考へて見たことのない人である。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、坤軸に根ざすの巌なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち唯一の地心は万木の生命の根ざす所、千態万容の世界の樹木は、其姿こそ各々異なれ、皆同一の生命を営なみつゝある也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其面黒くして洗ふが如く、短木岩隙を求めて根ざすもの點々たり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、扨は、根ざす処があるのであつたか。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからゴアの名物は間男持ちの女で角を切ってもまた根ざすと苦笑いながらの評判だとある。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと深い因果な性癖に根ざすものとしか思はれなかつた。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "濱田廣介君はこゝに見るところがあつてか、郷土と民族とに根ざすことの深いまことの童話を教育に結びつけることを思ひ立たれた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "離愁□人間性に根ざす流浪性□孤立と集合□人間は人間の中□ルンペンの悲哀　四月廿三日　曇――晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば進化はいつも混沌をへなければならないし、改革の第一歩は勇気に根ざすほかはない。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "改革の第一歩は勇気に根ざす、いかに馴化された美でも、古くなり気が抜けては、生気に充ちた時代の気分とは合わなくなってしまう。",
              "citation": {
                "source": "明治大正美女追憶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし月並の根ざすところは長い歴史をもつてゐるだけに實に深い。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも、国民性に根ざす情意の色合を別にして、思惟の形体や表現の形式については、そう云えるであろう。",
              "citation": {
                "source": "文学の曇天",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうでなければ、種々の境遇の變化の中に現れる主人公の性格を強調した心理描寫の筆を揮ふべきであつたと思ふが、浮雲の如く去來する心持は描けても、より深く根ざす心理の描寫は夫人の最も不得手とするところであるから、これは無理な注文として差控へるのが至當であらう。",
              "citation": {
                "source": "貝殼追放",
                "author": "「八千代集」を讀む",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならば泉先生の藝術の偉大さは何處にあるかといへば、それはもつと本質的なもので、即ち作者の經驗する感情――泉先生の場合には主として憧憬と反抗に根ざす――を讀者に移入し、作者の形造る感情世界に全然引入れてしまふ驚く可き魅力にある。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもプラトン以來數多くの大思想家たちがこの許されぬ道に踏入つた事實は、實在者との交はりによつてのみ生は成立つこと、從つて實在者への希求は人間性の最深最奧の本質に根ざすことを教へる。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい現代的通俗劇とは、民衆の趣味と生活に根ざす、あらゆる様式のスペクタクルです。",
              "citation": {
                "source": "演劇漫話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "キュレルが、近代の思想劇に一つの出発点を与へたとすれば、ポルト・リシュは近代人の感受性に根ざす恋愛心理を透して、仏国劇の伝統を継承し、これを次の時代に伝へる最も眼ざましい頂点を占めてゐることになる。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨て、仏蘭西の現代劇を通じて、「昨日の演劇」の余映と、「明日の演劇」の曙光とを、はつきり見分けることが出来るとすれば、前者は、観察と解剖の上に立つ写実的心理劇、並びに論議と思索とを基調とする問題劇であり、後者は、直感と感情昂揚、綜合と暗示に根ざす象徴的心理劇乃至諷刺劇であらう。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それは、みなそれぞれの地方を特色づける文化、風土並に気質に根ざす言葉である。",
              "citation": {
                "source": "「語られる言葉」の美",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて作家の方でも、一方で西洋の戯曲からいろいろのことを学びながら、それが舞台のイメエジとなる場合には、いきほひさういふ俳優たちの演技に結びつく結果、書かれた作品そのものは飽迄も日本演劇の伝統に根ざす、舞台的効果を重要な要素とするやうになる。",
              "citation": {
                "source": "新劇界の昨今",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "度外れた誇張によるとぼけた可笑味、きわどさと露骨さとを撒きちらす愛すべき素朴さ、最も庶民的な感情に根ざす権威の否定、というような点が、まず共通な色調としてあげられる。",
              "citation": {
                "source": "演劇の様式――総論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして根ざすところ極めて浅薄な反動的ファッショ気分なぞが人間そのものに良かれ悪しかれ変化を与へるといふことは全く想像することもできないのだ。",
              "citation": {
                "source": "悲願に就て",
                "author": "――「文芸」の作品批評に関聯して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は前回の批評で、小説は作者の生きた生活に根ざすところがなくとも傑作たりうると述べた。",
              "citation": {
                "source": "長篇小説時評",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、「仮感」とか「仮象」とかいう審美論者の説にも、やはり根ざすところがあるのである。",
              "citation": {
                "source": "リギ山上の一夜",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋の山水画家が人頭よりも大きい紅い丸を幾つも木の枝に画いているのにも、自然写生に根ざすところがあった。",
              "citation": {
                "source": "リギ山上の一夜",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "好戦的にみえるのは、極度の負けぎらひと国民文学の伝統に根ざす戦記風の表現のためである。",
              "citation": {
                "source": "風俗の非道徳性",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
