        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この先、ネズミ捕り（スピード違反取り締まり）やってるから、スピード落として！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ニュースで見たけど、最近ネズミ捕りを増やすらしいね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、やられた！こんなところでネズミ捕りにはまるなんて。」とドライバーは悔しそうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
