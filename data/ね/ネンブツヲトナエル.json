    "definitions": [
      {
        "index": 1,
        "gloss": "to chant the nembutsu",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
