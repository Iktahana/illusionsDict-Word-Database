[
  {
    "uuid": "8f35352b-ea94-5272-aa94-36ea748c7fa1",
    "entry": "根っから",
    "reading": {
      "primary": "ねっから",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "副詞"
      ],
      "ctype": null,
