    },
    "definitions": [
      {
        "index": 1,
        "gloss": "by nature",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まるっきりの、根っからの戯作者だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "根っから儲からねえ役廻だ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "根っから、いけません。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親にも似ねえ猿みたいな顔をした四つの男の子が、根っからの貧乏人の子らしく落ちついて長屋で遊んでいやがる。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌噛ましイな――根っから聴いたことおまへんな。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をいうにも今年十五の色男だすケに根っから他愛がありませぬ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御同様に議員さんが立ち上って、「国家のために政府案に賛成するのだ」　と拳固をふりまわしているのを見ると、「これも役目だから」　という気持がスッカリ鼻の表現をだれさせているために、「国家のため」という言葉が根っから感動を与えないのがあります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "根っから聴いたことないな。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "）しかし、根っからの大阪人である土門に、以前なら知らず、この喜劇の底抜けの面白さがわからぬという筈はなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ若者には根っからの行動力がある、一時力を失うも速やかに立ち直る。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どういたしまして、ええ、水をって申しますと、平時のとおり裏長屋の婆さんが汲込んで行ったと仰有るんで、へい、もう根っから役に立ちません。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢ではないが（これはある種お決まりのレトリックではなく、本当に根っから自慢にはならないのだけれど）、ワードプロセッサーはトタン屋根ぼろバラック程度だったオレの漢字書き取り能力を、完膚なきまでに、根こそぎ地上げ風に破壊してくれた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんと、こいつは根っから大騒ぎが好きな雑誌なんだな。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも根っから面白からぬ話だが、これに関して、いささか面黒い事なきにしもあらず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、同じ日本の俗曲でも、河東節の会へ一緒に聴きに行った事があるが、河東節には閉口したらしく、なるほど親類だけに二段聴きだ、アンナものは三味線の揺籃時代の産物だといって根っから感服しなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤作　根っからかかりゃしまへなんだわ、もうちっと季が過ぎとるけにな。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "根っからの侍共なら、あのように大小を重たげにさしてはいぬわ。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、根っから面白くもないお話で、さぞ御退屈でしたろう。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛松中学校に進むころから、根っからの教育者である母は、西に徹底して学習の機会を与えようと努めるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、脂っ気のないかさかさした指から徐かに指ぬきをはずしながら、「わたしの手は、もう、根っからの働きもんとみえますねえ」と云うて、力のない笑いようをした。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この吝嗇な奥様と根っから始末屋の女中はよく気が合って、いよいよ物おしみするのだった。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "根っから何にもせずに居た所が、十四か十五になって見ると、近処に知て居る者は皆な本を読で居るのに、自分｜独り読まぬと云うのは外聞が悪いとか恥かしいとか思たのでしょう。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "根っからいくじのないのサ。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　見れば根っから乞食の児でもないようであるのに、孤児ででもあるのか、何という哀れな姿だろう。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまで行っても受身で、根っから気焔が上らないで、先を打たれてしまうようなあんばいです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだい、兄貴、こうして坊主持ちも根っから新しくねえ、これから江戸へ着くまで、二人で腕っくらべをやろうじゃねえか、おたがいに出し抜いて、せしめた方が、この刀を物にするということにしようじゃねえか、売り飛ばして山分けにするよりは、その方が柄に合って面白かろうぜ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "生みの親にめぐり逢いてえとか、この世の名残りにせがれに一目あって死にてえとかいうのは、お芝居としちゃあ結構な愁嘆場かも知れねえが、生で見せられると根っから栄えねえものなんだぜ……お前さんも、そこをよく心得ていなくちゃいけねえ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂を聞くと、白骨に籠っているあの一種異様な人たちが、根っからこの冬を動こうともしないらしく、ことにまだお雪ちゃんとその連れである不思議な病者が、ここを去ったということをも気がつかないで、「お雪ちゃん、またこのごろ雲隠れ、お嫁さんにでも行ったのか」なんぞと噂をしているとのことです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねっからの掏摸じゃないんだろう」「誰だって、生れた時から掏摸じゃないわ」「いや、僕の言ってるのは、そんな意味じゃない」　と、鶴雄はもどかしそうに、「――つまり、何といったらいいかな。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も、母も、ねっからの平民でございます。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
