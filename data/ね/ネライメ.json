        "examples": {
          "standard": [
            {
              "text": "今は株価が下落しているが、将来的に上がることを考えるとまさに狙い目だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バーゲンセールで欲しかった商品が半額になっている、これは狙い目だよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "転職を考えているなら、この業界は今がまさに狙い目かもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ようやく漢字の使えるオフコンが出始めていた当時、日本語の処理できる安いシステムの提供は、ジャストシステムの大きな狙い目だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャストシステムが付け込む狙い目は、ここにあった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさにそこが狙い目なのです。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "狙い目がすべて外れた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドン特定地に関する限り、ホルボーン・バイアダクトが狙い目だ。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
