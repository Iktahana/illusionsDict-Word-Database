[
  {
    "uuid": "b1d0ce8c-e72f-5f1b-b314-89d14798106f",
    "entry": "葱",
    "reading": {
      "primary": "ねぎ",
      "alternatives": [
        "ネギ"
      ],
      "is_heteronym": false
    },
    "grammar": {
