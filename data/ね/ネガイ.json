[
  {
    "uuid": "c57e71c5-ab5f-5304-8608-7ad9617f1170",
    "entry": "願い",
    "reading": {
      "primary": "ねがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "desire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "無理なお願いでしょうけれどもお願いしてみます。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の為のお願いではありません。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、御推察を願います。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、持参の結納の品々を白木の台に載せて差し出し、「このたびは、まことに、――」と礼法全書で習いおぼえた口上を述べ、「幾久しゅうお願い申上げます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「は、幾久しゅうお願い申上げます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方八方に、幾久しゅう、幾久しゅうとばかり言うのも、まがぬけているような気がして、こんどは、「末永くお願い申します。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少し親しげな、ぞんざいな言葉を遣って、「よろしく願います。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は久しぶりで先生のお宅へお伺いして、大隅君の縁談を報告し、ついては一つ先生に媒妁の労をとっていただきたいという事を頗る無遠慮な口調でお願いした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の不機嫌顔甚だしきも官線はやはり官線だけの権力とか云うものあるべしと、かしこみて願い奉りようよう切符を頂戴して立ちいずれば吹き上ぐる朝嵐に藁帽飛んでぬかるみを走る事｜数間、ようやく追い付きて取止めたれど泥にまみれてあまり立派ならぬ帽の更に見ばえを落したる重ね／＼の失敗なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その若先生が折々自分の我儘な願いに応じて「化学的手品」の薬品を調合してくれたりした。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高浜さんには礼を失した点も多かろうと思うが昔に免じて御宥恕を願いたい。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか悪しからず御諒察を願います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな取止めもない事では雑誌に載せて頂くのは如何かと存じますが御返事までに申上げます、どうか悪しからず願います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外漢の妄語として御聞き捨てを願います。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何よりも先ず事実の方から確かめてかかる事が肝心であるから、万一読者の中でそういう現象を目撃した方があったらその観察についての示教を願いたいと思う次第である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも衛生学者の研究を願いたい。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもついでに御願いしたいものである。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御厚意を謝します、しかし今一度お考え直しを願いたいことは――もしあれ等がフランス固有の唄も混ぜて唄うとしたらどうでしょう。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松技師は帰りしなに、少し改って「実はお願いがあって参りましたのですが」　と言って、暫く黙っていたが、主人が気さくな顔をして応けているのを見て安心して言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎回断っているとおり、相似の事実を指摘するだけで、なんらの因果関係を付会するつもりはないから誤解のないように願いたい。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者のうちでそれらの誤謬を発見された方は容赦なく示教を惜しまれないように願いたい。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで読者のうちで過去あるいは将来に類似の現象を実見された場合には、その時日、継続時間、降水の形態等についての記述を、最寄りの測候所なり気象台なり、あるいは専門家なりへ送ってやるだけの労を惜しまないようにお願いしたい。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日にゆくとしろ……えいか、そのつもりで小支度して置け」　学校へゆくは固より僕の願い、十日や二十日早くとも遅くともそれに仔細はないが、この場合しかも今夜｜言渡があって見ると、二人は既に罪を犯したものと定められての仕置であるから、民子は勿論僕に取ってもすこぶる心苦しい処がある。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "御飯は勿論茶もほしくないです、このままお暇願います、明日はまた早く上りますからといって帰ろうとすると、家中で引留める。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたに色々御無念な処もありましょうけれど、どうぞ政夫さん、過ぎ去った事と諦めて、御勘弁を願います。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事については『ローマ字世界』の十二月号に詳しく述べるつもりであるから御参照を願いたい。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジァンペートロというバリートンが当時異常な人気を呼んでいて、なんでもある貴族の未亡人から、自分の願いを容れてくれなければ自殺するという脅迫を受けて困っているというような噂が新聞で持て囃されたが、しかしそれは単に宣伝のための空ごとだというゴシップもあった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レビュー見学のノートから脱線してつい平生胸に溜まっていた教科書の不平をこぼしてしまったが、こういう脱線もまた一つのレビュー的随感録の一様式中の一景として読者の寛容を願いたいと思う。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御取捨御自由に願います。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたにも御助力ねがいたい。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
