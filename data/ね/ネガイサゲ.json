          "literary": [
            {
              "text": "ここで舞なぞは願い下げじゃ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく馬は、手に入れて差上げますよ」「でも、よくって、牛みたいなのろくさしたのだったら、願い下げよ。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、営業は願い下げといきたいのに加え、売り込みを図るもの自体も難物である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな御心配はコッチから願い下げで御座る。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『姦し』に一つ足りないなんてもの、まあこちらから願い下げだ」　或る二月の午後、幸子から電話がかかり、朝子も出かけ、この家を見た。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様然らばは、願い下げです」　美代子が戻らないものだから、電話で話し合って、大浦博士がこちらへ訪ねてくれることになっている。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは願い下げにしたいですね。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、もうこれ以上、めそめそした、或は、額に青筋を立てた、「インテリ感傷童子退屈忍耐劇」だけは、お互いに願い下げにしたいと思うだけです。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "身をいれて修業するがよい」「そいつは願い下げにしますが、ま、下僕の方はつとまるところまでつとめることに致しましょう。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしゃ、お前さんの出よう一つで、いつだって願い下げにするんだから」　お駒ちゃんは、縄のしっぽに火がついたように、めらめらめらとしゃべり立てて行くのだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はチフスだけは願い下げですね、忽ちだから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈夫な時ならだけれども、今のようなとき、私はそういう名士は実に願い下げですし、東京では、ともかく命がけの形で、身元もわかった人間になっているのに、あちらでは文化関係もその他のことも見境なしで、あわてた時には、何はともあれ落度なからんこと専一で、どんな待遇になるか、それこそ見とおし不可能です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞやの夏のような苦しさは、二度と願い下げです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに手間がかかっちゃ家庭教師お願い下げだ」「いいえ、結構ですよ」「英語なら確信があるけれど、数学は駄目だ」　と芳夫さんは素より代数の為めに来たのでないし、僕も真の附けたりに過ぎなかったから、そのまま雑談を始めた。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "願い下げだよ、これは。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家にすわることなんかは願い下げにしたい自分なのだが、吉宗が大統をうけて天下にのぞむとなると、自分も少し、何か、して見せなければ男が立たない。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は、どうか、陽なたくさいほうれん草のスープは、ねがいさげにして……」「おいよろこべ」「なんだ、例のスープか。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
