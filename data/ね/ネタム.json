[
  {
    "uuid": "15c1881b-c731-509a-af49-559d79003961",
    "entry": "妬む",
    "reading": {
      "primary": "ねたむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be jealous of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぼくは人を軽べつするかそうでなければ妬むことしかできないやつらはいちばん卑怯なものだと思う。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、妬むにはあらねど、いかなるわけか、成功者の悪口を言う傾向あり。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、妬むなどという気はちっとも起りませんでした。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かずある侍妾のうちに姜氏といううるわしい女があって、特に太祖の恩寵を蒙っていたので、それを妬むものが彼女に不貞のおこないがあると言い触らした。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妬む者の讒言か、それとも本当に覚えのあることか、その噂はまちまちでいずれとも決定しなかったが、ともかくも二人は有罪と決められて、楊は死罪に行なわれた。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妬む、憎む、怨む、羨む、呪う、慕う、哀む、喜ぶ、恐れる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "妬むのはおとなげないとも思い直した。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "権右衛門が何を妬み、誰を妬むのじゃ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思う間もあらせず、今度は親類の人たちが五六人ずつ、口々に小やかましく何かいって、あわれむような妬むような目つきを投げ与えながら、幻影のように葉子の目と記憶とから消えて行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心身共に丈夫な主人の事だから、誰をも妬むには及ばぬ筈なのに。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは他人の出世を妬む心より生ずる言葉にていとあさまし。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　凡婦人の心様の悪き病は、和ぎ順ざると、怒恨むと、人を謗ると、ものを妬むと、智恵浅きと也。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ婦人の心さまの悪しき病は不和不順なる事と怒り恨む事と謗る事と妬む事と智恵浅き事となり、此五の病は十人に七、八は必ずあり、婦人の男子に及ばざる処なりと宣告したれども、此宣告果して中るや中らざるや遽に信じ難し。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "知るや知らずや、其不平は人を謗るにも非ず、物｜妬むにも非ず、唯是れ婦人自身の権利を護らんとするの一心のみ。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方、ジーグフリードの名声を妬むものに、ハーゲンがあって、その二人は、いつか知らず知らぬ間のうち接近してしまった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子よ、汝が聞きたる事の解説は即ち是なり、是ぞ多からぬ年の後方にかくるゝ係蹄なる　九四―九六されど汝の隣人等を妬むなかれ、汝の生命はかれらの邪惡の罰よりも遙に遠き未來に亘るべければなり。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "その勝誇るを妬むなり〔汝の生命は〕かれらは罪の報を受けて亡び、汝は永く美名に生くべし一〇〇―一〇二〔織物〕物語。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "他のものはたちまちそれを羨み妬むの念を生ぜざるを得ぬ。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その僧これを聴いて、かかる賤しい非人の身分にも、やはり運がよいとか、悪いとか、出世するとか、せぬとか云うことがあり、またそれを羨み妬むなど云うことがあるのかと、大いに感じさせられたというのである。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "団結力も強ければ、「麗人族」の生活振りを憎み妬む感情においても、かなり旺盛なものであった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど怨む様子も妬む気色も、一向に見えなかつた。",
              "citation": {
                "source": "化粧",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ないものがあるものを妬むといふ現象を、あなたは避け得られる摩擦と考へられるのか？",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十六　愛好の部二〇九　不相應に相應し、相應に相應せず、實義を捨てて可愛を執取する人は自ら相應する人を妬む。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ千手殿、そなたも、何なりと歌など歌って、酒などおすすめ参らせい」　狩野介の言葉に応じて、千手は直ぐさま、羅綺の重衣たる情なきを機婦に妬む　という朗詠を、くりかえしくりかえし高らかに歌った。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あのお房といふ娘は思ひの外｜確り者だから、結構清次郎を立てゝ行くだらうよ」「お夏はあの弱い浪人と一緒ですかえ」「妬むな／＼、お前にはまだ良いのがあるよ」　平次はカラカラと笑ひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "狐の嫁入",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは老木屋の身上を妬む者の拵へごとで御座いますよ」「何が拵へごとで、何が本當なんだ」「――」　勝藏は口を緘んでしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧糸の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「構はないでくれ、少し話を訊くだけのことだから」「でも、まア、一つ召上つてから――本當に何んといふ惡い奴でせう、あんなひどい惡戯なんかして、つばめは人氣が大變ですから、いづれそれを妬む者の仕業でせうが」　さう言ふお崎は四十二三、亭主の天童太郎を差し措いてまくし立てるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ま、待つてくれ、妬むと言つたところで、一座には外に女藝人も無い樣子だ――外から小屋の中へ潜り込んで、樂屋の天井裏の、綱を切る隙でもあるといふのか」　平次は兎も角この女の饒舌にブレーキをかけました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃江戸中を壓する平次の名聲を妬む色もなく、同じ御用を承はる身の耻を忍んで、斯う智慧を借りに來たのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人形の誘惑",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃江戸中を圧する平次の名声を妬む色もなく、同じ御用を承る身の恥を忍んで、こう智恵を借りに来たのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人形の誘惑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
