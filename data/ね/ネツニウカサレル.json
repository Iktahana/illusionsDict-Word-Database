    "definitions": [
      {
        "index": 1,
        "gloss": "to be delirious with fever",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "高熱で熱に浮かされ、彼はうわごとを言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ああ、まだ熱に浮かされているな…」と看護師は心配そうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は疲労と高熱で、完全に熱に浮かされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "熱に浮かされるような恐ろしい生活の中で小さいゴーリキイの心は自分や他人の受ける侮蔑、苦痛に対して鋭く痛み、人間の生活についての観察を学び、一生を通じて彼の特質をなした真理を求める熱情が既に目覚め始めたのである。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き叫ぶ赤ン坊と、高熱に浮かされる夫の間で、甲斐甲斐しく働く妻を見ると思わず熱い涙がハラハラと溢れるのだ。",
              "citation": {
                "source": "愛の為めに",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ルクレティウス）（a）酒のためには麻痺し混乱するし、病気の熱に浮かされると平静を失う。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to be crazy about something",
        "register": "standard",
        "nuance": null,
