    "definitions": [
      {
        "index": 1,
        "gloss": "sleepy eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "焦れて幾たびか強く叩くと、小僧の寅次が寝ぼけ眼をこすりながら起きて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして半熟先生ここに茫然として半ば夢からさめたような寝ぼけ眼をまたたいている。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に寝ぼけ眼で店の柱時計をふり返って見たら午前七時十分前であった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所近辺の人々は寝ぼけ眼をこすりながら、われ先にと羅生門横町へ駈けつけると、彼等をおどろかす種がまた殖えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうす暗いなかに更にうす暗い二つの影が、まぼろしのように浮き出しているのを見つけた時に、紋作は急に寝ぼけ眼をこすった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方お前の寝ぼけ眼でなにかを見ちがえたのであろうと、冠蔵も始めのうちは唯わらっていたが、水右衛門の人形の額にゆがんだ打ち疵のあとを見つけると、彼は顔の色を変えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "むむ、寝ぼけ眼でか」「寝惚け眼でも猿まなこでも、おれが見たと云ったら確かに見たんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ぼけ眼をこすっているおやじには別に委しい話もしないで、かれはお鉄をうながして橋番小屋を出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　親戚の娘にゆり起こされて、深田君は寝ぼけ眼をこすりながら顔をあげると、かれはいつの間にか蚊帳のなかに寝かされていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼んだことを忘れるな」「承知しましたッ」　それから僕は火事場へ駈けつけると見せて、実は刻々に殖えてくる寝ぼけ眼の弥次馬の間を掻きわけ掻きわけ、どんどん脇道の方へ曲っていった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寝ぼけ眼のせいかしら？",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、嗅煙草を包んだ紙搓のことであるが、眠っていた中学生は、夢うつつのこととて思いきりその煙草を鼻へ吸いこんで、はっと眼をさますなり、跳び起きて、寝ぼけ眼をみはり、馬鹿のように四方八方をキョロキョロと見驃騎兵※が押しこまれていることに気がつくのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして私はみんなの背後から、寝ぼけ眼をこすりながら、その縁側の下まで一ぱいに押し寄せてきている濁った水が、父の手にした蝋燭の光で照らされながら揺らめいているのを、びっくりして覗いていた。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の晩おそく、雨の中をハリッジを出帆して、百五十マイルの航程を七時間、北海の波に揉まれて、それでもどうにか眠ることは眠ったのだが、まだ幾らか寝が足りなかったので、公使館から廻してくれた車を捜すにも寝ぼけ眼だったに相違ない。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜更け、丘田医師が直ぐ玄関へ飛び出して来たところといい、寝ぼけ眼をこすっていたわけでもなく冴えきった眼をしていたことといい、この下駄の泥、洋杖の泥は、丘田医師がどんなことをしていたかすこし見当がつくように思った。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大伍はようやく寝ぼけ眼をこすッて起きてきたから、「私が旦那様に御食事を差上げます」　と大伍のカギをかりで、二階へ夕食を運んだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "右往左往する寝ぼけ眼の敵の中におどりこんで、あたるを幸いと切って切って切りまくる。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ぼけ眼の炊事女が、はだしで水たまりをぱちゃぱちゃいわせながら、木戸をあけに駈けだした。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小圓太さん、あのお師匠さんがお前さんがみえたらね、表のお庭の方を掃除してておくんなさいって」　寝ぼけ眼でおしのどんはいった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ぼけ眼で姉を取囲みながら、何か尋ねてゐる。",
              "citation": {
                "source": "愚かな父",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝間着の若い衆、寝ぼけ眼のおかみさん、おどろいた犬、猫まで飛び出して、長屋はにわかに非常時風景だ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、ソノ、いつお越しになったかも存ぜず、それに、あまり変わった服装をしておいででござりますゆえ、つい、失礼ながら怪しきやつと……」「うむ……なんじの寝ぼけ眼に映じたのであろう？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ている間に一杯一杯一杯と重なって、ついには両人の皿には山盛の砂糖が堆くなって、壺の中には一匙の砂糖も余っておらんようになったとき、主人が寝ぼけ眼を擦りながら寝室を出て来てせっかくしゃくい出した砂糖を元のごとく壺の中へ入れてしまった。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると片手にはランプを提げ、片手にはステッキを持って、寝ぼけ眼よりは身分相応の炯々たる光を放っている。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とど助さん、とど助さん」　とど助が寝ぼけ眼をこすりながら起きあがって、「消魂しい、なにごとです」「落ちついてちゃいけない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "積み込みは夜中の短い時間で行われたので、引っ越し当夜、父は寝ぼけ眼に抑圧された罵り声とばたばたいう足音を聞いただけだった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖を持っている寝ぼけ眼の兵士を引っ張って、ガラス製の『まぐわ』を身をかがめて上から覗き込んでいた。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府勘定方役人の生命も刻々危急に瀕している――　というような情状を、関守氏が自分で集めて来たのと、風聞に聞いたのとを差加えて、お雪ちゃんに説明して話の興がようやく酣わになるところへ、そろりそろりと音がして、その場へぬっと道庵先生が寝ぼけ眼で現われて来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとです」　寝ぼけ眼の男が、今にも叩かれはせぬかと、もう首をちぢめて、おどおどと答えた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨネが、寝ぼけ眼をこすりながら、台所の硝子戸のところへ出て来た。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
