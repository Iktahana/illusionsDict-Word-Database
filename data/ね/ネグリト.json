        "examples": {
          "standard": [
            {
              "text": "フィリピンのネグリト族は、小柄な体格と縮れた髪が特徴的な先住民族である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ネグリトの人々は、狩猟採集を主な生業として伝統的な生活を営んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人類学の研究では、ネグリトの起源と移動経路が重要なテーマとなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ネグリトス人種あり、ハイペルボレアン人種あり。",
              "citation": {
                "source": "世界の日本乎、亞細亞の日本乎",
                "author": "竹越三叉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをしないでおいたならアイヌ語はおろか、ネグリトの語をもってしてもこれを説明することができるかも知れない。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
