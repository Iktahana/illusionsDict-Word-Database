        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "村の町は、夜九時になると死んだやうになる、偶然飛び込んだ旅人を泊める宿屋までも、十時になると眠り込む。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独防共協定のことなぞが、すべての乗客がだらしなく、口をあけ、むんむんとスチームにむされ脂汗を浮べて眠り込むと、思ひにのぼつて来た。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思はず「いけないね、咳をして」と云ふと果して妻は今眼がさめたところ同じ返事をして又眠り込む自分は溜息をついて又本を讀みつゞける。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか聽いてゐる間に眠り込む。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に眠り込む状態に置かれたのは伊曾である。",
              "citation": {
                "source": "青いポアン",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "表――即ち舞台奥を何か罵り騒ぎながら走り過ぎて行く多勢の人の足音、その音に、唯一人残つて眠つてゐた客が目をさましてキヨロキヨロするが、再び眠り込む。",
              "citation": {
                "source": "疵だらけのお秋（四幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
