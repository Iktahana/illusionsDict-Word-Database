        "examples": {
          "standard": [
            {
              "text": "深海探査機は、熱水噴出孔から噴き出す熱水を観測した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "熱水噴出孔の周辺は、地球上で最も過酷な環境の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "生命の起源を研究する上で、熱水噴出孔は重要な手がかりとなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "海底の熱水噴出孔とかああした場所が故郷だ。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "木星の衛星、エウロパだとか、土星の衛星、エンケラドスあたりにだって熱水噴出孔はあるらしい。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            }
          ]
