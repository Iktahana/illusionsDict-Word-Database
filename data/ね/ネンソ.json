[
  {
    "uuid": "24744c33-68c4-5802-b4b2-7bded2056be5",
    "entry": "年租",
    "reading": {
      "primary": "ねんそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "annual tax",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まったく私たちもこまっているんだ」　大石大尉は、ざんねんそうにいいました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島はからになった箱のなかをのぞいて、「なるほど、乙姫さまが、人間のいちばんだいじなたからを入れておくとおっしゃったあれは、人間の寿命だったのだな」と、ざんねんそうにつぶやきました。",
              "citation": {
                "source": "浦島太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "スミス警部はざんねんそうに、鉄水母の浮きしずみする海面をにらんでいた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの知らない合金らしい」　助教授は、ざんねんそうに答えた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは無理だ、息がつづかない」　　　　　５　炭やき爺さんは首をふって、竹法螺でもって、ふもと村へ言葉をおくるのには、とても息がつづかないと、ざんねんそうにいいましたので、これを聞いた一彦少年はちょっとがっかりいたしました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　その子は、ざんねんそうにためいきをついて、さらにかんがえる。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しょうねんたんていだんいんの敏夫くんが、ざんねんそうにいいました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどもかぶとをぬいだよ」　まほうはかせは、ざんねんそうににがわらいをするのでした。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、あれほど、どなっているのに、だれもきいてくれないものだから……」お面をはがれたおまわりさんが、ざんねんそうにいうのです。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくいい事をしたのに、これで昨日の一日一善が零になっちゃった」　と、ざんねんそうに言うのでした。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひとりの警官が、ささやき声で、ざんねんそうにいいました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智探偵は、ひじょうにざんねんそうなようすでしたが、なにぶん犯人が思いもよらぬ手段で、なわめをすりぬけたのですから、刑事たちをせめるわけにもいきません。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智探偵はさもざんねんそうに、無言のままピストルを賊にわたしました。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　明智探偵は、ざんねんそうにつぶやきましたが、まだ、あきらめられないらしく、「ともかく、一度、おりてみよう。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小林少年は、ざんねんそうに、くちびるをかみました。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざんねんそうに、腕をさすっていたのは、朱柄の槍をかついでいる巽小文治で、「ウーン、おれも試合にでてみたい！",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
