    "definitions": [
      {
        "index": 1,
        "gloss": "asleep (in bed)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寝込みを踏み込みやがったな）　彼は、本能的に息を詰めた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから数日後、僕はお酒の飲みすぎで、突然、からだの調子を悪くして、十日ほど寝込み、どうやら恢復したので、また酒を飲みに新宿に出かけた。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一の事があってはならぬから、明日の出発は四、五日延期してはどうかと、断水坊平生の洒ツクにも似ず真面目｜臭って忠告を始めたが、吾輩はナアニというので、その夜はグッスリと寝込み、翌朝｜目醒めたのは七時前後、風は止んだが、雨は相変わらずジャアジャア降っている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　六「魅入られたようになりまして、ぐっすり寝込みました嘉吉の奴。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい寝込みを狙われたにしても、揃いも揃ってぶち殺されて、片っ端から井戸へ抛り込まれてしまうというのは、ちっと受け取りかねる話じゃあねえか」「その虚無僧は、前から寺に泊まっていたんですかえ」「今までは住職と納所ばかりだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は子供の頃から病弱で、よく寝込みましたが、寝ながら、敷布、枕のカヴァ、掛蒲団のカヴァを、つくづく、つまらない装飾だと思い、それが案外に実用品だった事を、二十歳ちかくになってわかって、人間のつましさに暗然とし、悲しい思いをしました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱った、和尚、あの勢で、寝込みはしないか。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その挙げ句に新兵衛が何者にか寝込みを襲われて殺された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくし共が淀橋へ行き着いたのは十日の夜四ツ半（午後十一時）頃、寝込みへ踏ん込んで一度に押え付けようと思ったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀吉は軽い疵でしたが、幸次郎は右の肩を強く撃たれて、それからひと月あまり寝込みました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ本所の子育て観音さまに虫封じのご祈祷がござんしたゆえ、こちらにおいでの糸屋のご新造さんとお参りに行きましてついおそうなり、疲れてそのままぐっすり寝込みましたら、いつとられましたものか、朝になってみますると、ふたりとも坊やたちを盗まれていたのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、江戸屋の親方にしたっても、生まれおちるからの江戸っ子なら、芸ごとのうえで人気負けしたのを根に持って、人の寝込みに水をぶっかけてまわるなんて、そんなけちなまねゃしねえと思うんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぶしい眼をこすりながら、枕もとの煙草盆を引きよせて一服すっていると、その寝込みを襲って来たのは子分の善八であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉は現場を見ていないというので、詳しいことは判りませんが、年造は小刀のような物を持って、次右衛門の寝込みを襲って、思い通りに相手を仕留めて、さてその金のありかを探すと、仏壇の抽斗に百両、ボロ葛籠の底から百両、あわせて二百両だけは見付け出しましたが、残りの四百両の隠し場所がわからない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ早く食事を済まして、女給の寝込みを襲おうではないか」　私たちはやがて自動車に乗ってＨ軒へ駆けつけました。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前の晩に、夫婦で不動の縁日に行って、あちこち歩いて、買物をしたり、蕎麦を食べたりして、疲れて遅く帰って来たことから、翌日朝｜夙く、寝込みに踏み込まれて、ろくろく顔を洗う間もなく引っ張られて行った始末を詳しく話した。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろ子嬢は、私にもすぐに来てくれというのでこれから行くつもりなんだが、君にも御同行を願おうと思つて、いそいで君の寝込みをおそつた次第さ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ君は両手に大火傷してまたもや寝込みました。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後は又寝床に入りまして朝までぐっすり寝込みましてございます」「それから……」「それから朝になりまして、五時半に起きましていつものように朝食の用意にかかりましてございます。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地面の奴、寝込みをあんまり早く叩き起されたんで機嫌を悪くしてゐやがるんだよ。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その母親が、軽い脳溢血で寝込みました。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふだんはそれでお宜しいでしょうが、あなたが病気で寝込みでもなすったら、どうなさいますか。",
              "citation": {
                "source": "絶縁体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が湯河原で寝込みを襲われて捕えられたとき一しょにいた芸者は、弁当や菓子など差入れていたが、ハンストと知って、チリ紙などの日用品を差入れることにした。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まずお控え下されませ」「黙れ黙れ、物を尋ねるなら尋ねるようにして来るがよい、人の寝込みへ踏み込んで、吟味するような尋ねぶり、小癪千万な」　主膳は、甚だしく怒りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大井広介夫人にもその趣きがあるし、ふとっちょの実業家Ｄ夫人（夫人自身がふとっちょで実業家也）は、普通の人がそんなことを口走ると一週間も寝込みそうなことを次から次へと口走ってケロリと忘れているが、お金モウケに忙しいから、てんでこだわらずに年中怖しいことを口走っていらせられるよ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ夜の白々明けという時刻に、刑事は一服投手の寝込みを襲って、捜査本部へ連行した。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は酔っ払いのようにふらふらし、すぐに寝込みそうであった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "内心、いつ来るかと思つてゐたものが、遂に、ある初夏のさわやかな朝、寝込みを襲ふやうにして来た。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる場合は多く下女の所為にて、下女は台所の近くに寝ておるから、かねて昼間に石を拾い集めて隠し置き、夜ふけて人の寝込みたるをうかがい、戸のすきより台所の方へ投げだすのである。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　五月三日の朝早く私は藤枝にねこみをおそわれた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
