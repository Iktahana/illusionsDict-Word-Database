        "examples": {
          "standard": [
            {
              "text": "海外の大学院に留学するため、私は大使館に願い書を提出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この願い書は、土地の所有権移転に関する重要な書類だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "担当者は、提出された願い書の内容に不備がないか確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お所払いご赦免のお願い書の儀お取上げ下さいますよう、お願いでござります！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "願い書を主君の手もとへさし出してから、一年とも経たないうちに、東郷五郎左衛門は、甲相聯合軍の陣にあって、武州の平野戦で討死にしてしまった。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
