[
  {
    "uuid": "cd332f46-b963-58ab-bb63-344805d163a8",
    "entry": "年少",
    "reading": {
      "primary": "ねんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "形容動詞",
