[
  {
    "uuid": "5a009ac4-90a8-5b1b-bfe3-9dfc22d0dea7",
    "entry": "熱性",
    "reading": {
      "primary": "ねっせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "excitable disposition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一八八二年十月に発熱性のリューマチスに罹って数週間出勤が出来なかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜」は無産階級をして、冷かな熱性を覚えさし、無産階級を奮起させる。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて遂に、初期に於ける情熱性は排斥され、ゾラやモーパッサンの開祖でさえ、あまりに感傷的であるとして非難された。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "放蕩なる快楽は飲宴好色なり、着実なる快楽は晏居閑楽なり、熱性ある快楽は忠孝仁義等の目的及び希望なり、誠実なる快楽は家を斉へ生を理するにあり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔と首の表現の誇張感はモヂリアニ一流の人物の手を交叉させることに依つて、完全に画面を調和させてゐる『シュミーズの女』の表情の淫蕩性、『若き娘』の疲れたる愛慾の闘士といつた表情、この絵の胸のあたりのタッチの狂熱性は極度にモヂリアニの熱情を知ることができる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま、このタッチの狂熱性が沈潜して内部的な情熱となつて『裸婦』に現れるとき、豊淳な性や、重厚な性に悩む女を描く。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村の気づいたところは、第一に非常に早乾きがすること、第二に、固まってしまえば鋼のような強い弾力を帯びること、第三に耐熱性に富んでいるらしい非常に優秀な漆喰だった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の人間の本質中に火熱性の元素、寒冷性、乾燥性、湿潤性等の元素がいかに混合されているか、その程度の差によってその人の情操、根性が定まり、また罹りやすい病もきまり、生死も定まるのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "○心臓病には温熱性食物を禁じ全く寒冷の食物を取らしむべし。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルフェンベルグによると広範な潰瘍を伴う膿疱および小水疱が特徴である無熱性の病気であった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この理由で発疹チフスが流行するまで個々の例は認識されないか、はしか、猩紅熱、腸チフス、マラリアまたは古代や中世によく見られた多数の他の熱性疾患と区別できないような形で一般的に記載されたのであろう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "または他の熱性疾患と区別されなかった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "生理学者が今彼の様子を観察したならば、科学上よく知られ類別されてる熱性混迷のしだいに高まる徴候を見て取り得たであろう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "この熱性混迷が苦悩に対する関係は、あたかも肉体的歓楽が快感に対するようなものである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "発熱性の胃腸管カタルにかかった17才の少女は３日のあいだインディカンを含みアルカプトン反応を呈する、放置すると暗色になる尿だけを排泄した。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
