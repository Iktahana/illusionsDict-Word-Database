        "examples": {
          "standard": [
            {
              "text": "子供の頃、魚嫌いな私にとって、鯵の干物はまさに猫またぎだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新鮮でない魚は、猫またぎされるほど美味しくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "父が釣ってきた魚は、猫またぎすることなく皆で美味しくいただいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "けれどあの北尾言い逃れ光司との猫またぎの一戦で、ビガロはそこまでプロモーターの意向にべたべたに合わせてしまう本当に気のいいオッサンであることを満天下にさらし、東京ドームの巨大ドツボにはまってプロレスラーとしての命を絶った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
