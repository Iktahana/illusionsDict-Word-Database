        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "編集局は猫の手も借りたいほどの多忙である。",
              "citation": {
                "source": "入社試験",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の手も借りたいほどの重大な時に当って予備に編入されるとは、よくよく無能と見込まれたものか。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の手も借りたい場合だ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちようどまもなく田植がはじまるという猫の手も借りたいいそがしいときで、どこの家でも、家族一同田圃に出払つていた。",
              "citation": {
                "source": "押しかけ女房",
                "author": "伊藤永之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年目の夏、田の草取りで猫の手も借りたい時分にお豊は男の子を生んだ。",
              "citation": {
                "source": "藪落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の手も借りたいほどで、ヒューバート医師が精一杯対応した。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人選において、これも重ねての失敗だったということは後には分ったが、いまや秀吉の周囲は猫の手も借りたいほど四方八面に事端と劇務をひかえている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
