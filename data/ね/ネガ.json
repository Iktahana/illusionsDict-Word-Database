        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何のことはない妄想家流であつて、ジャズだつてオネガだつてアッターベルヒだつてラヴェルだつてシトラウスだつてマーラーだつて、妄想家流――といつて妥当でなければ幻想家流である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "促音は記号がない故、書きあらわされていない）、ヒ→促音（「冀ひて」がネガテ、「掩ひて」がオホテ）、グ→ウ（「藁沓」がワラウヅ）などは院政時代からあらわれている。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからセネガル地方では米に土を交ぜて食うが、これは単に腹を膨らせるためで味がよいためではないらしい。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚の花　（藤澤桓夫氏）　この作家の從來の作品に於て、これまで私にネガテイヴな價値しか持つてゐなかつたものは、この作品によつてポヂテイヴなものに改められた。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "テフテフハ　花トハ　チガヒマス、オハネガ　アツテ　アチラ　コチラ　トビマワル　コトガ　デキマス。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サテ　コノ　テフテフモ　オハネガ　ジヨウブニ　ナルト　カゼニ　ノツテ　ウマヤノ　ヤネヲ　コエタリ、ヲガハノ　ウエニ　イツテ　ミタリ　シマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "オクビヨウナ　サムライハ　モウ　ハノ　ネガ　アヒマセン。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「オネガヒダ、ワタシニ　キラセテ　クレ。",
              "citation": {
                "source": "サルト　サムライ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガ、カネガ　ナツテ　キヨウシツノ　マエニ　ナラビニ　ユクト、ミツルクンハ　マダ　ナイテ　ヰマス。",
              "citation": {
                "source": "センセイノ　コ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニシロ　オカネガ　アリマセンノデ、キシヤヤ　ジドウシヤニ　ノル　コトハ　デキマセン。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケフハ　ガチヨウサンノ　タンジヨウビデスカラ　オデカケ　クダサイ」「ア、サウデスカ」「トコロデ、イタチサン、ヒトツ　オネガヒガ　アルノデスガ」「ナンデスカ」「アノ、スミマセンガ、ケフダケハ　オナラヲ　シナイデ　クダサイ」　イタチハ　ハヅカシクテ、カホヲ　マツカニ　シマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴作ニツキ、御自身、再検ネガイマス。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネガチヴの気遣いも、骨の折れるものである。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御返信ネガイタク、参銭切手、二枚。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "封書、葉書、御意ノ召スガママニ御染筆ネガイ上候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フネガデルデルカラフトヘ　小樽を出る時、私は小田原の妻子へ、こう打電したものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一神教の裡面は一魔教なり、多神教の裡面は即ち多鬼教なり、一神教には中心の権あるが故に中心の善美あり、是と同時に一魔教にも中心の統御あるが故に中心の毒悪あり、一のポジチーブに対して一のネガチーブあり、多のポジチーブに対して多のネガチーブあるは当然の理なり。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンカ島のマレー人はを古酋長の化身とし、セネガル河辺ではに殺された者、雷死刃死の輩と同じく虹の宮殿に住むとした（コムベス著『ミンダナオおよびヨロ史』一八九七年マドリッド版六四頁）。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオ・アフリカヌスはアフリカのセネガ人馬を得れば塗香の呪言｜誦しながらその馬の全身に塗ると書いた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "君チャンハホットシテ、ネガエリヲウッテ、足ヲチヂメテ、ネルノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "君チャンタチハ、オ母ッチャガ死ヌ四五日モマエカラ、何ンニモタベルモノガナク、目マイガシ、ムネガヒクヒクシ、ペッタリネタキリダッタノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「虚実の証拠」「遺伝」等の価値については世評半ばしていたようであるが、私は、ネガティブの一票を投じる。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが全く逆であること、つまりある条件がネガティヴ的に満足されているということは、一寸面白い問題ではあるまいか。",
              "citation": {
                "source": "科学者と夜店商人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し液が帯電状態にあるものとし、これが普通の状態として非帯電状態に在る鵜烏を見れば、これは明かにネガティヴの電気的歪力がかかっているとも考えられるわけである。",
              "citation": {
                "source": "科学者と夜店商人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から三十年前にボストンで、ジャーネガンという牧師が、海水から金を採る方法を発見したと称して、大会社を建て、附近の大富豪の金を搾り取った話がある。",
              "citation": {
                "source": "錬金詐欺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代工業のおどろくべき進歩は、二十世紀に西洋音楽に深く影響して、オネガやストラヴィンスキーその他の音楽家たちが不協和音を摂取するようになったし、文学でも即物的な要素を加えられた。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽でもオネガーは過渡期の古典となっている。",
              "citation": {
                "source": "ディフォーメイションへの疑問",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり自分の無力や醜劣やを感じてネガチブにばかり、反省せられる時にいるのだと思います」「そうです、しかしそこでとどまってはいけない。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の蛇笏に対する評価はこの時も亦ネガティイフだった。",
              "citation": {
                "source": "飯田蛇笏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
