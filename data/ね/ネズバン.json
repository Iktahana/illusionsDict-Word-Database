        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "不寝番がきめられる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいつなんどき晴れるかもしれないから、だれか一人は交代の不寝番で空を見張っていなければならない。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の疲もあり、蒸々する晩でもあり、不寝番の控室てはとろとろと仮寝の鼾も出ようと云ふ真夜中に、けたゝましいもの音、やにはに飛出した囚人。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その靴音の聞えるのは控兵と不寝番の者ばかりで、同じ衛兵でも衛門や火薬庫を守っている者には全然聞えなかった。",
              "citation": {
                "source": "戦死者の凱旋",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不寝番の男は私たちを奥まった二階の部屋へ案内しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隔日の御番（当番）出仕で、夜半二時迄の不寝番をつとめた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その夜は十畳ばかりの屋敷に十四、五人の武士が不寝番をすることになりました。",
              "citation": {
                "source": "江戸の化物",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "不寝番がおどろいて駈け付けると、男は蒲団から転げ出して死んでいた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お梅が帽子と外套を持ッて来た時、階下から上ッて来た不寝番の仲どんが、催促がましく人車の久しく待ッていることを告げた。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴重品ばかりの所であるから、夜は特別に二人居て交代で不寝番をする事になって居たのである。",
              "citation": {
                "source": "真珠塔の秘密",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱がさがったとき、不寝番になるはずですからね」　と言いながら、ヤンはじりじりマヌエラにせまってくる。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして宿番は宵のうちこそ世子も起きられているがその後寝床へ入られても、小姓は不寝番というをせねばならぬ。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで宿番を宵前、宵後、暁前、暁後と四ツに別けて、代りやって不寝番をする。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不寝番は一人で、他に介というが一人ある。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "世子が夜中厠に行くといわれると、不寝番が、直に寝ている介を起して、二人でその用を勤めるのである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不寝番は、以前はそんなこともなかったらしいが、世子の側に附くものは、文武を励まねばならぬというので、不寝番でも読書することは許された。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "側医師というも一人居て、これは小姓の中へ交って不寝番もせねばならなかった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "外部からの襲撃をうける心配のない人造島では、歩哨も、不寝番も必要がなく、ただ、動力所だけに、機関士が交替に起きているに過ぎない。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "各勢は列を定めて出歩く刻限をきめ、夕暮になると合図して押止り、その場所に篝火を焚いて交替で不寝番を置いた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると各自立止つた地点を動かず篝をたいて不寝番を立て、三十五日を費して、遂に海まで突きぬけた。",
              "citation": {
                "source": "わが血を追ふ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事の始めは極くさゝいなことで会社の不寝番をつとめてゐた十八の若者が勤めを怠って眠っていた為だといふことです。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "御飯を召上りながら、この寒いのに一晩の不寝番は利口なことじゃないが仕方がない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お宅の女中さんの話によりますと、兄さんは失踪直前の夕食中に今夜一晩は不寝番だからカゼをひいちゃいけないな、厚着しようと呟いておられたそうですね。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がけの食事中に呟いたという今夜一晩の不寝番とは、これを指しているのです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして兄さんが庭のどこかで不寝番をして見張っているに相違ないのを推察すると、それを逆に利用する策を立てたのです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "不寝番が油を差しに来た時も、ちょっと驚かされたけれども、やっぱり無事に眠っているものだから、安心して行ってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間に人員交替して、不寝番をたて、夜があけると、またジリジリと一人一歩の列をくずさず前進、夜にピタリと止まって、止まった場所でカガリ火。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺あ　不服だぞお……周章てて起きた初年兵の寝台の上に不寝番は疲れ不貞腐れて寝込むだ初年兵の左手は軍衣袴の釦をいじめ一年兵の上靴を並べて匍いまわる二年兵は不精不精起きあがる二年兵は不機嫌にどなりちらすこの頓間野郎！",
              "citation": {
                "source": "動員令",
                "author": "波立一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
