[
  {
    "uuid": "ecf3938c-1bd4-5040-8ed8-39a642edc4f0",
    "entry": "労い",
    "reading": {
      "primary": "ねぎらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
