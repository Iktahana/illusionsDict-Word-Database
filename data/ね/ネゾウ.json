    "definitions": [
      {
        "index": 1,
        "gloss": "sleeping posture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "母者人は寝相がわるかった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惣助は母者人の寝相を見ないようにして、わざと顔をきつくそむけながら呟いた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝相の悪い隣の男に踏みつけられて目をさますと、時計は四時過ぎたばかりだのに、夜はしらしらと半分上げた寝室のガラス窓に明けかかって、さめ切らぬ目にはつり並べた蚊帳の新しいのや古い萌黄色が夢のようである。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上窓の横幅と寝台の長さが殆ど同じであるから、その寝相までが手にとる如く見えるのである。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼が出るという古廟に泊まると、その夜なかに寝相の悪い一人が関羽の木像を蹴倒して、みんなを驚かせましたが、ほかには怪しい事もありませんでした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だがの、今朝眼がさめて自分の寝相を見ると、乃公の身体が寝台の外に食み出してゐて、まるでワツフル（お菓子）のやうだつたよ、はゝゝゝ……」　人間は時々自分をナポレオンやソクラテスに比べるやうに、お菓子や眼薬の壜にも比べてみる必要がある。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庄は叔父の寝相を真似をしながら、「どうすればあんなに正体なくなるんでしょう。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "布団の中から差出されてる寝相の悪い足先と、汽車の線路のそばに転ってる轢断された足先と、両方を見たことのある者は、這般の消息を解するだろう。",
              "citation": {
                "source": "奇怪な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゼをひかせちゃ、こまるから、コタツをいれようと云うと、ダメなんだ、弟の奴、子供の時から寝相がわるく、なんでも蹴とばすから、火事になる、と兄貴が仰有る。",
              "citation": {
                "source": "無毛談",
                "author": "――横山泰三にさゝぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それにしても、汽車の寝台から、それも下の段ならまだしも上の段から、足をぶら下げるなんて、随分思いきった不作法な寝相だ。",
              "citation": {
                "source": "足",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「種ちゃんはあんなところへ行って、転がってる――仕様が無いナア、皆な寝相が悪くて」　こう三吉は、叱るように言って見て、あちこちと子供の上を跨いで歩いた。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はいつもと同じように右の肩を下に、自分の方を向いて、少し仰向加減に軽く口を結んでいかにも寝相よくすやすやと眠っている。",
              "citation": {
                "source": "寐顔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "血気さかんの連中が、合宿しているのだから、その寝相のわるいことといったらお話になりません。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "古びた蚊帳の中で汗をかきかき前後不覚に眠ってしまった何人かの子供らの入り乱れた寝相と、一人の婆さまの寝顔とが思いやられた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お浜はいま夫の魘される声に夢を破られて、夫の寝相を見ると何とも言えず物すごいのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつであったとしても、あいつが果して、どういう寝相をしている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "布団だと寝相が悪くなるのかな。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さまのこんな寝相はあとにも先にも見たことがない。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の菜種畑の花から、甘いにおいもしのび込む――「むむむ……」昼間は托鉢のために、何里となく歩くので、石念だの定相だの、若い者は寝相がわるい。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな時　※のあをい海のなかで、ついさつきまで、しきりと泳いでゐた子が、もう、やすらかな寝息をたてて、あどけない寝相を、わがかたへに横たへる。",
              "citation": {
                "source": "独楽",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困ったなあ、二本差だけに、うっかり起すこともできない」　亭主は、しかたなく、その寝相を眺め入ってしまった。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがての果ては型の如く、手枕、大の字、思い思いの寝相して、そこの広間に酔いつぶれていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪友か善友かしらぬが、道中などでも、ふたりが痴話に更けているまン中の部屋で、ひとり猪八｜戒みたいな寝相をして、朝の鏡に目をこすり「わるい悪戯をしやあがる」と顔の墨汁をあらい落して怒らぬところもあった男だ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ごめんね、命松さん」　寝相のわるい彼の枕元の下へ、彼女は、宵に書いておいた仮名文の幼稚な置き手紙をしのばせておき、そして勝手口から手さぐりで外へ出た。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭もまろいし、大きなぼんちみたいな寝相である。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ほどなく、もどって来た道誉と茂時は、そこの“うつつなき人”のお寝相に、顔見合せて、たじろいだ。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかは地蔵堂の縁をめぐって思い思いな寝相をえがいていたが、折々には、むくと誰かが首をもたげて耳をたてた。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "石炭入れを　もどして　帰ってくると　あなぐまトミーの　ねぞうが　ちょっと　横むきに　なっていました。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
