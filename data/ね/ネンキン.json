[
  {
    "uuid": "52b0fe78-6bd7-5532-9b01-671a4bcc8eaa",
    "entry": "年金",
    "reading": {
      "primary": "ねんきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
