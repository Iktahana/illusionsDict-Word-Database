        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここで水を飲もうとすると、犬が盛に吠える、「誰だあ、やい」戸の中から寝ぼけ声が聞える。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "『もう寝かけているところだ』と私はなぜか寝ぼけ声を使いました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、李太郎は寝ぼけ声で答えたが、やはりすぐには起き上がりそうもなかった。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翁は枕頭に坐った女房に揺り起されてやっと眼を覚したが、眠くて眠くてしかたがないので、伸ばした右の手の手首を左の指端で掻きながら寝ぼけ声を立てた。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今こんな忌な夢をみたから、息子の部屋へ行って様子をみて来ましょうか」「よせ、よせ」と、王は寝ぼけ声で叱った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三度もつづけて叩く音に、小僧の次八がようやく起きたが、かれも夢と現の境にあるような寝ぼけ声で寝床の中から訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国はまだ何やら、寝ぼけ声で話しかけたが、後は呻吟くように細い声が聞えて、じきにウトウトと眠りに陥ちてしまう。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄の緊金や錆びた螺旋の軋る騒々しい音で、市の反対側の端にいた立番の巡査までが、仮寝の夢を破られて、ハッと鉾を取りなおしざま、寝ぼけ声を張りあげて、『誰だ、そこへ行くのは？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、コン吉が、まだ夢の中なる寝ぼけ声で、「自動車というのは一体どこにあるのかね？",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "合乗り乳母車　――仏蘭西縦断の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻　　（はたと目を覚し、或は目が覚めた風を装ひ、むつくり起き上り、寝ぼけ声で、或は何食はぬ顔で）もう、お風呂沸いてるでせうか。",
              "citation": {
                "source": "明日は天気（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが鎌足は、ひきかづいた夜のものの下から、寝ぼけ声をだしてかう答へた。",
              "citation": {
                "source": "春泥",
                "author": "『白鳳』第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ぼけ声で、こんなふうに、つぶやく。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう起きなさい」　巡査は寝ぼけ声で答えた。",
              "citation": {
                "source": "霧の蕃社",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "不二子は大丈夫か」「ヘエ、お嬢さまでございますか」乳母は寝ぼけ声で答える。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たたきつづけていると、強い睡眠剤の眠りも、さすがに妨げられたのか、部屋の中から、かすかに岩瀬氏の寝ぼけ声が聞こえた。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体どこからだ」　布引氏は寝ぼけ声で女中を叱りつけた。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こら、がきども、起きろ」　寝ぼけ声やあくびが聞こえた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
