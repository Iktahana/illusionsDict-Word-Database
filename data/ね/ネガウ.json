    "definitions": [
      {
        "index": 1,
        "gloss": "to desire",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すべての恋する人々は、自分等以外に全く人影のない離れ小島の無人島で、心行くまで二人だけの生活をし、二人だけの会話をしたいと願うのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日経よむと墓を弔いするで、よろこぶの生きるです』『あなた、ほかの世、坊さんと生れて下さい』『ああ、私願うです』　人間よりも、虫や鳥の方が幸福だと言ったヘルンは、人生について、悲哀の外の何物をも知らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この戦を歌った当時の詩人の歌の最後の句にも「人はその願う事をやがて信ずる」と言っている。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上の日の出がどんなに美しかろうが、海鳥が飛ぼうが、鯨がはねようがそんな事はどうでもよい、一刻も早く目的地に上陸して動かぬ地盤が踏みたいと願う。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　アインシュタインの人生観は吾々の知りたいと願うところである。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霖雨の来らんことをたえず願う。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのもの案じがおなる蒼き色、この夜は頬のあたりすこし赤らみておりおりいずこともなくみつむるまなざし、霧に包まれしある物を定かに視んと願うがごとし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど電磁気学理論の初歩も知らない素人で非常にラジオ通があるのに、三十年来この方面の学問に関係し、しかもそれで生活して来ている人間が、宅のラジオくらいを直すのに、一々ラジオ屋さんの御苦労を願うというのは自分ながら妙なことであると思われなくはない。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄想で自らを卑屈にすることなく、戦うべき相手とこそ戦いたい、そしてその後の調和にこそ安んじたいと願う私の気持をお伝えしたくこの筆をとりました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、「それならばこの新鼎は自分に御譲りを願う、真品と共に秘蔵して永く副品としますから」というので、四十｜金を贈ったということである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お寺へ金を納めて後生を願うのでもそうであり、泥棒の親分が子分を遊ばせて食わせているのでもそうである。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもせめて、これぐらいにでも打ち解けて呉れるといいが、と果敢なくも願うのだった。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、もともと、家庭教師を呼ぶ事には反対だったのですが、沢田先生のおくらしの一助という名目に負けて、おいでを願う事にしていたのであって、まさか、そんな無責任な綴方教育を授けているとは思いも寄らず、毎週いちど、少しは和子の学課の勉強の手伝いをして下さっているものとばかり思っていた様子でした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷、則ち、両翼を開張し、虔しく頸を垂れて、座を離れ、低く飛揚して、疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して唯願うらく、疾翔大力、疾翔大力、ただ我｜等が為に、これを説きたまえ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷、則ち両翼を開張し、虔しく頸を垂れて座を離れ、低く飛揚して疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して唯願うらく、疾翔大力、疾翔大力、ただ我｜等が為にこれを説き給え。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯願うらくはかの如来大慈大悲我が小願の中に於て大神力を現じ給い妄言綺語の淤泥を化して光明｜顕色の浄瑠璃となし、浮華の中より清浄の青蓮華を開かしめ給わんことを。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷｜則ち両翼を開張し、虔しく頸を垂れて座を離れ、低く飛揚して疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して願うらく疾翔大力、疾翔大力、ただ我｜等が為にこれを説き給え。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御家老様、大目付殿、お納戸頭などと十分に御打合わせを願うた上で、お指図を受けねばならぬが……しかし……」　と十内は無念そうに唾液を嚥み込んで、眼をギョロリと光らした。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大友は初めてお正が自分を恋していたのを知った、そして自分がお正に会いたいと思うのと、お正が自分に会いたいと願うのとは意味が違うと感じた。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなら貴様は、自殺を願うて居るのですか。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実を露骨に手短に話しますから、其以上は貴様の推察を願うだけです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど今は貴嬢がわれにかく願いたもう時は過ぎ去りてわれ貴嬢に願うの時となりしをいかにせん。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はわれ貴嬢に願うべき時となりぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮本二郎は言うまでもなく、貴嬢もわれもこの悲しき、あさましき春の永久にゆきてまたかえり来たらぬを願うぞうたてき。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども僕はなんだか臆病になってパパにもママにも買って下さいと願う気になれないので、毎日々々その絵具のことを心の中で思いつづけるばかりで幾日か日がたちました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえこの農場も、諸君全体の共有にして、諸君全体がこの土地に責任を感じ、助け合って、その生産を計るよう仕向けていってもらいたいと願うのです。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの点について読者の寛容をこいねがうものである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、わたくしは、これらのちいさなものがたりの幾きれかが、おしまい、あなたのすきとおったほんとうのたべものになることを、どんなにねがうかわかりません。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかあとの所はみなさんで活動写真のおしまいのありふれた舞踏か何かを使ってご勝手にご完成をねがうしだいであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "路をいそぐと一旦はお斷りなされましたを、無理にねがうて御案内申しました。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
