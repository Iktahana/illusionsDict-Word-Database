  {
    "uuid": "a24ace89-32ac-59ec-aef1-f358dcfc7bac",
    "entry": "年紀",
    "reading": {
      "primary": "ねんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
