          "literary": [
            {
              "text": "しかも根切虫だということは極めて明白です。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりこの稲は根切虫の害によって枯れたのですな。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一「はあ、それで、その根切虫、無ぐするになじょにすたらいがべす。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから浮塵子や根切虫だが、そんねえな無益物の昆虫学とやらの名前も覚えなくつちやなりますめえ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "根切虫あたらしきことしてくれし六月二日　家庭俳句会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
