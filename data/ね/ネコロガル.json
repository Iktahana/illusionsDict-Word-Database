        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "禹徳淳　（俯向けに寝台に寝転がる）またか――うんざりするなあ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（さう捨白を残して、逃げるやうに立ち去る）底野、あつけに取られ、元の位置に帰り、ごろりと寝転がる。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（寝転がる）夫　　傘をさしてか。",
              "citation": {
                "source": "明日は天気（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "小径をぐるぐる廻り、ここという場所を探し、そこで銀貨を「失く」し、踵で押し込み、腹這いに寝転がる。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや処刑を見ようとはせず、目をつむって砂の上に寝転がる人もいましたよ。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、とある木の下の、青あおとした草原にねころがると、そのまま、ぐうぐうねこんでしまいました。",
              "citation": {
                "source": "オオカミと七ひきの子ヤギ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "その土間に足を置いたまま、アーンとアンペラの上にねころがる。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
