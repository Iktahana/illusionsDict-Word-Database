  {
    "uuid": "7c7aa89e-f7ac-5965-9aa0-97b026dd11d3",
    "entry": "粘剤",
    "reading": {
      "primary": "ねり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mucilaginous material used to make washi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浪のうねりと白歯が見える。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等利根川の岸邊に立てば、さらさらと洋紙は水にすべり落ち、いろあかき魚のひとむれ、しねりつつ友が手に泳ぐを見たり。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ものにも捉はれない野蛮人めいた狂暴無智の感情の大浪と、そのうねりくねる所の狂的なリズム。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "三囲の稲荷堤上より拝し、腹まだ治まらねば団子かじる気もなく、ようやく百花園への道札見付けて堤を右へ下り、小溝に沿うてまがりくねりの道を行く半町ばかり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "引きちがえて入り来る西洋人のたけ低く顔のたけも著しく短きが赤き顔にこればかり立派なる鬚ひねりながら煙草を人力に買わせて向側のプラットフォームに腰をかけ煙草取り出して鬚をかい上ぐるなどあまり上等社会にもあらざるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けげんな面持で頸をひねり、「氣のせゐかなあ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その煙が澱んだ空気の中をくねりながら昇る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "前面には阜のような山が二つ、小隆起をしている、赤沢岳頂上の三角点も、大空を指さしている、谷は次第に高くなる、高くなると共に蹙まって来て、雪の蜿ねり方も、波のように烈しいが、嘉門次の語るところに依ると、雪の下は大小の石塊ばかりで、雪解けがしたら、却って歩きづらくて堪まらないということだ。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沢が、濶く、峡間に延びて、峡流の分岐したのが、幾筋となく蜿ねり、枯木が、踏み砕かれた、肋骨のようになって、何本も仆れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "露営地の外では、細長い爬行動物――この谷の主――東俣の川――が、蜿ねりながら太古の森林の、腐れ香に噎んで、どこまで這って行くことであろう。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、見馴れない吾々にはどうもあまりひねり過ぎたと思われるような、あるいは無用に誇張したと思われるような辞句が目に立って、却って感興をそがれるような気のするのもありました。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば敵手の身体の何処を捕えて何処に力を加えるが有効かという四十八手の裏表には数学者のひねり出した力学上の原理が籠っている、力士は知らず識らずこの原理を応用しているのだ。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の錦紗のやや軽薄めいた技巧的感触や西陣お召の厳粛性のやうな感じとは全然ちがふもつと、ち、り、め、ん、といふなまめかしさ、いとしさ、やるせなさ、優しさの含んだ純粋絹をねりにねつてしなとこくとをつけた布地でした。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、ひばりも、あまり美しい鳥ではありませんが、よだかよりは、ずっと上だと思っていましたので、夕方など、よだかにあうと、さもさもいやそうに、しんねりと目をつぶりながら、首をそっ方へ向けるのでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」黒服のほうが薄いひげをひねりながら答えました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心口を鎖してお寢間へ戻り給ひしが再度立つてお菓子戸棚のびすけつとの瓶とり出し、お鼻紙の上へ明けて押ひねり、雪灯を片手に縁へ出れば天井の鼠がた／＼と荒れて、鼬にても入りしかきゝといふ聲もの凄し。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には数百里も遠い大洋のまん中であばれている台風のために起こった波のうねりが、ここらの海岸まで寄せて来て、暴風雨の先ぶれをする事もあります。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねり絲のやうなしめやかな雨が青桐の葉や、芝生や、樹木の若葉をしつとりと濡らして、朝から夜がくるまで降り續けてゐる事があつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は防波堤を掠めて、油を流したやうな穩かな海にうねりを殘しながら進んでゐた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "船と船とが行き合ふと、緩かな汽笛が響いて、よどんだ水がうねりとうねりの間でせせ笑ふやうに白い泡沫を立てたりした。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただきらきらと潮流に乘つて動いて行く浪のうねりが限りなく續いてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足あとは血を引いて、一町ばかり行って、そこで樹々の間を右に折れ、左に曲り、うねりうねってある白樺の下で全く途絶えていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの警戒隊は、大きい銃をかついで街をねり歩いていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平麦のかわりに丸麦を二度たきとして、ねりつぶしてねばりをつけた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "徒に、むつかしい文句をひねりまわしたところで、何等役に立つものではない。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒竜江は、どこまでも海のような豊潤さと、悠々さをたたえて、遠く、ザバイガル州と呼倫湖から、シベリアと支那との、国境をうねうねとうねり二千里に渡って流れていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの中の古老は気象学者のまだ知らない空の色、風の息、雲のたたずまい、波のうねりの機微なる兆候に対して尖鋭な直観的｜洞察力をもっている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
