[
  {
    "uuid": "b709fc13-dea0-5e2c-a31d-239f6d71084a",
    "entry": "値打ち",
    "reading": {
      "primary": "ねうち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
