[
  {
    "uuid": "af79e6dd-f557-59a6-b9f1-e4320791b3f2",
    "entry": "年給",
    "reading": {
      "primary": "ねんきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
