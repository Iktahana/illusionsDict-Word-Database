        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから、真珠のネックレスと、ダイヤやルビーをちりばめた指輪。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は、みごとな真珠のネックレスをかけ、指には、これも、珍しい大粒の真珠の指環をはめてゐる。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫のために出席しなければならない一晩の宴会のために身分のいい女友達から、借りた真珠のネックレスを紛失させ、代りに買ってかえした真珠の頸飾りの代を月賦で払うために、何年間も苦労してやつれ果てた貧しくつましい妻。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘレナ　真珠のネックレス！",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その女の手にはネックレスが……。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、ネックレスの件だ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ、ネックレスを手にした第二の女が出現したあとの話を削除したのか。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ネックレスを手にした第二の女を見てから後の逸話を削ったのは失敗だったな」　ハーコートがニヤニヤして立ちすくんだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤリングヤネックレスヲシテナイトコロガ気ガ利イテルネ」「オ爺チャンナカ／＼分ルノネ」颯子ノ後カラオ静ガ草履ノ箱ヲ持ッテ這入ッテ来、草履ヲ取リ出シテ彼女ノ前ニ揃エル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（地味ナスーツヲ着テイルガ、ブラウスガ派手ナノト、フランス製ラシイ模造宝石ノ五聯ノネックレスヲ頸カラ胸ヘ垂ラシテイル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ種類ノネックレスハ国産品ニモシバ／＼見受ケルガ、背後ノ後頭部ニ附イテイル留金ニイロ／＼ナ宝石ガ鏤メテアッテ、コノ真似ガ国産品デハ出来ナイノデアル）血壓ノ高イ時ハ頻尿ニナル癖ガアルガ、頻尿ニナッタト思ウト、逆ニソノタメニ一層血壓ガ上ル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の段階は異物すなわちネックレス、ブレスレット、リングなどや衣服で身体を飾るようになった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ときに気まぐれによって贅沢な衣服、奇妙な肌着やネックレスなど……主に赤、緑、黄色のような華やかな色を喜ぶ。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "指輪はしたことないし、ネックレスも持ってないし」「あげます」「私に？",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "演台に立つマーサ・ストーナリーは青いニットのウールと真珠のネックレスを纏っていた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
