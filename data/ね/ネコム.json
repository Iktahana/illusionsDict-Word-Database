    "definitions": [
      {
        "index": 1,
        "gloss": "to fall fast asleep",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしていよいよ寝込む頃にはもうだいぶ病気は亢進して危険に接近しているであろう。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を落として何物も出来ないとの事、缶詰を破って腹を癒やし、翌朝八時頃まで怒々と寝込む。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲みすぎると、げっそり痩せてしまって寝込む。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多病でよく寝込むが、それを見舞ふとあはあは笑ふ。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆が高利貸をしていやしまい、主人の留守に十時前から寝込む奴がどこに在る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "安宅先生は寝込むほどではないがとかく身体が弱いので、祖母は先生の小さいときから極寒の季節には磯部の温泉へ、極暑の季節には赤城山の山頂の湖辺に連れて行って自炊宿で療養をさした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにわたしが胃病で寝込むようになってからは、船中のお客様がそれは同情してくださって、いろいろとしてくださるのが、奥さんには大のお気に入らなかったんですの。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉を食うにはもう遅すぎ、ぐっすり寝込むにはまだ早過ぎる中途半端な今の「出来心」を思うと、虫は退屈しのぎの所在なさから、小坊主のような円い頭をひょくりひょくりと振ってでもいるより外に仕方がなかったのだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、あいつをすえたら急に眠くなって、死んだように寝込むというんですよ」「なにッ、眠り灸！",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "講演が無事に済むで、その晩タフト氏は、田舎町の狭つ苦しい旅籠屋に、象のやうな大きな体躯を投げ出して、ぐつすり寝込むだ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り大人気ないので私は、それに対し何も言ったことはなかったが、起床時刻には連隊に出ており、消灯ラッパを通常は将校集会所の入浴場で聞いていた私は、宿に帰れば疲れ切って軍服のまま寝込む日の方が多かったのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　さて山口の一旅館の二階で電報のため眼を覚まさされた私は、愈※来たなと思つたが、電灯を消すとそのままぐつすり寝込むことが出来た。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "断髪の女性にして二、三日風邪で寝込むとその襟足の毛が二、三分延びてくる。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "また風土の方について言えば、彼等は沼地に野営していて、医薬の用意もないので、一週間とたたぬうちに半分の者は病気に罹って寝込むだろう、と先生はその仮髪を賭けて断言した。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな疲れと安心とで、ぐうぐう寝込む。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯英、この数日、毎日の如くはげしい頭痛にて寝込む。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯英、頭痛にて寝込む。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの若者は古狸でも三四年は寝込むようなきびしい悪評の中で、冷静に、動揺することなく、またしても順位戦に好成績をあげ、わずかに木村との最後の挑戦者決定戦に敗れたが、Ａ級順位戦では彼が第一等であったように記憶する。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺あ　不服だぞお……周章てて起きた初年兵の寝台の上に不寝番は疲れ不貞腐れて寝込むだ初年兵の左手は軍衣袴の釦をいじめ一年兵の上靴を並べて匍いまわる二年兵は不精不精起きあがる二年兵は不機嫌にどなりちらすこの頓間野郎！",
              "citation": {
                "source": "動員令",
                "author": "波立一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒を飲み、御馳走をたくさん食べたあとでは、だれでもすぐにぐっすりと寝込むものです。",
              "citation": {
                "source": "神様の布団",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだ六週間ほど流感で寝込むといった不利もあったが、要するに大した金額は集まらなかった。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船、汽車、権利、義務、道徳、礼義で疲れ果てた後に、すべてを忘却してぐっすり寝込むような功徳である。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま飯にしちゃ毒だよ」「ついでに今晩は泊めて下さいな親分、用心棒になりますよ」「お志ざしは有難いが、お前は一杯飲むとウワバミのような鼾をかいて寝込むから、用心棒どころか心張棒ほどの役にも立たないよ」「ヘッ、違げえねえ」　八五郎はピシャリと自分の頬をたたきました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一この私が寝込むような事があれば、小松屋の身上はどうなることでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに私もどっと寝込むようになれば、誰が忠五郎を助けてやることが出来るでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寝込むほど患ったのは、六つの時｜麻疹をやってから、ツイぞ覚えのねえ事さ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "不死の霊薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に天朝の御論もどうとか片づくか寝込むか、なんにしても勤王の間に合い申さず候。",
              "citation": {
                "source": "吉田松陰より某へ",
                "author": "安政六年正月十一日",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるほどのことはない、極めて無事にこれから、高台寺月心院の屯所へ帰って快く、ぐっすりと寝込むばかりだ――　こういうような事情を、斎藤一が山崎譲に向って、橋上で、自分も一杯機嫌に任せていい心持で語るのは、もはや、帰ることも忘れているような様子です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、いずれまた生神場で」「なんなら、それを持ったまま、方角をちがえてさしつかえはない」「ぞッとします、旦那の金じゃ」「寝込むなよ、辻堂で」「大丈夫、あれから鏡坂へ見えてくるお姿を、目を瞠って、お待ちしております」「そうしてくれ。",
              "citation": {
                "source": "八寒道中",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気をして寝込むなんてことも殆どなかった。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
