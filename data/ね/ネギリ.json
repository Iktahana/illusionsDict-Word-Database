        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何じゃ、片仮名をもってキミョウニナオル丸、疝気寸白虫根切、となのった、……むむむむ疝気寸白は厭わぬが、愚鈍を根切りの薬はないか。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁天日向高千穂峯の御来迎日向の高千穂の峯山の肩黝きに風すでに矢羽根切りて響きわたり、空へ翔けぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ芝居や講釈ではかたき討を盛に奨励していますし、世間でも褒めそやすのですから、やっぱり根切りというわけには行かないで、とき／″＼には変った仇討も出て来ました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今は胡瓜や茄子の苗をも植えつけたので、根切り虫に注意してやらねばならぬ。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はひとつ、晩飯をすませるとすぐ、自分はふんどし一つになり、子供に提灯を持たせて畑に行き、十分に根切り虫の退治をやってやろうと考えられた。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると、その間にも畑の植えつけ苗の根を二本でも三本でもあの根切り虫に切られているかも分らないのだ。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大根切りなぞは嘸練習が入るだらうね。",
              "citation": {
                "source": "手品師",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天然記念物のマリ藻で有名な阿寒湖で、根切り虫を餌にして一尺二寸というウグイを釣らせてもらった。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "探険資金が少ないので、セキストン伯爵が、ねぎりにねぎって雇ったこのぼろ船のことである。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかと思ふと、ふられた奴が恋仇の結婚式で祝辞をのべ、死んだ奴が花束の下から首を起して突然棺桶をねぎりだす。",
              "citation": {
                "source": "茶番に寄せて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、ふられた奴が恋仇の結婚式で祝辞をのべ、死んだ奴が花束の下から首を起こして突然棺桶をねぎりだす。",
              "citation": {
                "source": "茶番に寄せて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃ、たかい」　素子が、こごみかかって果物を手にとってしらべながら、ねぎりはじめた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
