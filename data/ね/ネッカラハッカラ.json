        "examples": {
          "standard": [
            {
              "text": "「根っから葉っから、この計画には賛成できない」と彼はきっぱりと言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は根っから葉っから、その提案に耳を傾けようとしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私は根っから葉っから、このやり方には納得がいかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "永のいちんち、猟をしてまわり、これというもの根っから葉っからみつからない。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「こわれ煙突までとっついてるじゃないかいな」永の一晩猟をしてまわり、これというもの根っから葉っからみつからない。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「二つわりにしたその半分きりさね」またもいちんち猟をしてまわり、これというもの根っから葉っからみつからない。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「よくもめちゃくちゃにお針をさしたもんだすな」またも夜っぴて、猟をしてまわり、これというもの根っから葉っからみつからない。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「あいつ、めうしにおきざりされたやつだんね」またもいちんち、猟をしてまわり、これというもの根っから葉っからみつからない。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            }
          ]
        }
