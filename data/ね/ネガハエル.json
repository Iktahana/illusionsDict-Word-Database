        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "一度座り込むと、まるでそこに根が生えたかのように動かなくなる老人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もう、根が生えたみたいにソファに座ってないで、手伝ってよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はこの場所が気に入り、もう根が生えてしまったかのようにそこに住み着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こいつを土に倒しておくと、茎から白い根が生える。",
              "citation": {
                "source": "舞馬",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "其杖から根が生えると、此祭りの唱言が効果を奏して、村の農業生活が幸福になる。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、弓矢でも根が生える様に、変つて考へられて行つたのだ。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "根が生えるじゃないか。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから叔母姪は長火鉢の座蒲団に根が生える。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
