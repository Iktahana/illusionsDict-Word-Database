        "examples": {
          "standard": [
            {
              "text": "「妬ましい気持ちでいっぱいだよ、あの才能が。」と、彼は溜息をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "成功した友人を妬ましいと思う自分に、彼は少し嫌気がさしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「彼女の美貌と富を妬ましいと感じるのは、人間として当然のことかもしれない。」とカウンセラーは言った。",
              "citation": {
                "source": "幻辭AI",
