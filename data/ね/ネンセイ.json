[
  {
    "uuid": "d528a4c5-3f0f-5d07-b78f-dd578a4a5d89",
    "entry": "年生",
    "reading": {
      "primary": "ねんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "nth-year student",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "当時僕は中学の二年生で夏休みだつたから叔母のゐるその教会にゐたのである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の三、四年生の頃だつたと思ひます。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五年、十年生きてゐてもらつて、私が多少でもいゝ仕事をして、お父さに喜んでもらひたかつた、とそればかり思ひます。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられてゐて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の三、四年生の頃だったと思います。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう五年、十年生きていてもらって、私が多少でもいい仕事をして、お父さに喜んでもらいたかった、とそればかり思います。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられていて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常五年生は毎年関東地方の地図を出品するといふことになる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近漸く大學豫科の一年生位に入門して來た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "理科大学の二年生で西片町に家を持っていたその頃の日記の一節を「牛頓日記」と名づけて出したことがある。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも二年生のとき牛頓祭という理科大学学生年中行事の幹事をさせられたので、それが頭にあったためかもしれない。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃自分は大学二年生であったが、その少し前に郷里から妻を呼びよせて西片町に家をもっていたのである。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小學校の三、四年生の頃だつたと思ひます。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと悠くり歩かなけや、父ちやんは附いて行けないよ」「引つ張つて上げようか」　と、一年生の女の児が、私の手を引つ張つて、グイグイと先きに立つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年生なんか授業のとき先生がかはるがはる教室へ持って行くよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもはもう尋常五年生でしたからすらすら読みました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき「もう五年生きていたいのだが」と云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学へはいったらぜひとも輪講会に出席するようにと、高等学校時代に田丸先生友田先生からいい聞かされていたから、一年生の頃からその会の傍聴に出席して、片隅で小さくなって聞いていた。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年生のときにＮ先生の研究の手伝いの傍らそれに縁のあるミラージに関する色々の実験をしたことも生涯忘れられぬ喜びであった。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年生のときはＴ先生の磁力測量の結果の整理に関する仕事の御手伝いをしながら生意気にも色々勝手な議論を持ちだしたりした。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての點に於て、彼は小學一年生のやうな男である。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての人は、小學一年生である時ほど、人生や自然について、最高の深い智慧をもつものはない。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にまた、小學一年生の作文や自由畫ほど、藝術の淳い眞髓に觸れ、祕密をつかんでゐるものはないのだ。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで藝術家が、他の技術や頭腦やの上達にかかはらず、精神の本質點でのみ、いつも永久に小學一年生でゐられたなら、その人こそは眞に「天才」と呼ばれるのである。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星の抒情詩は、あの無心な小學一年生が舌で鉛筆の心を嘗めつけながら、紙の上にごしごしと書いてゐるところの、あの片假名の作文を思ひ出させる。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に「抒情小曲集」と「忘春詩集」の二詩集は就中また小學一年生の作文を典型してゐるが、不思議なことには、それがまた彼の作品中で一番よく、讀者の胸に乘りかけてくる、詩情の最も強いものを高調してゐる。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし他の二つの點で、全くルレーヌの方ではでたらめであり、藝術道の意識など夢にもなく、生涯を通じて酒びたりで、珈琲店の音樂など聽いて悦んでゐたところの、徹底的小學一年生の子供であつた。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の文章は、時に小學一年生のやうに純眞である。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その特殊な文章は、丁度小學校の一年生が、鉛筆の心を舌で嘗めつけながら、一所懸命で紙の上に書きつけてる、あの片假名の作文を聯想させる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中の天狗、Ｔ「汝が非凡の働きにより　我は鞍馬山に退散せん」　と叫んで、Ｔ「そも、そも、我は　巳年生れの天狗なり」　と言って、Ｔ「されば、その娘を　巳年の男に与うべし」　何と？",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
