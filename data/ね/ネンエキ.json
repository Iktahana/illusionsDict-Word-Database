[
  {
    "uuid": "175e6201-553d-58c3-9b28-ad3ef8d06ef3",
    "entry": "年益",
    "reading": {
      "primary": "ねんえき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "annual profit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "如かず十全の日を待ちて、遺憾無く興趣を釣り、悠々塵外の人となりて、神を養ひ身を休め、延年益寿の真訣を得んには。",
              "citation": {
                "source": "研堂釣規",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔宅ハ三遷セズトイヘドモ孟母ノゴトク賢ナリ〕と言うを見ればこの年益斎の母はなお健在であったと思われる。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "小杉さんの行路は院展洋画部創立（大正三年）の頃から、年益々、幅の広いものとなるのだつたが、仕事はいよいよ油絵のアブラくさゝを遠ざかつて、素材そのものも、日本画法によるところが多くなつてきた。",
              "citation": {
                "source": "小杉放庵",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "老来小杉さんは枯淡になつた筆路に、この十年方前からは、打つて変つた緻密な「写実手法」を十分楽しみながら、年益々「日本画法」の堂に参じつゝ、今に及んでゐる。",
              "citation": {
                "source": "小杉放庵",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "当所は先年益田河内様御田屋御坐候事（以上）。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年益子町に御詠を刻んだ石碑が一基建てられました。",
              "citation": {
                "source": "益子の絵土瓶",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "源平時代の見聞を語ること、親しくこれを歴た者の通りであった故に、小野はただちに海尊なることを看破し、就いて兵法を学び、また恭しく延年益寿の術を訊ねた。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
