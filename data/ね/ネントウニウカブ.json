        "examples": {
          "standard": [
            {
              "text": "プレゼンテーションの準備中、ふと新しいアイデアが念頭に浮かんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行先を考えている時、幼い頃の思い出の場所が念頭に浮かんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "難しい問題に直面した時、彼の言葉が急に念頭に浮かんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんな瞬間に限っていつでもきまったように私の念頭に浮かぶのは君のあの時の面影だった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女がいつも東京に在って思いを関西の空に馳せる時、第一に念頭に浮かぶのは蘆屋の家のことであるのは云う迄もないが、何処か頭の隅の方に、折々は此処の店の様子や、親爺の風貌や、彼の庖丁の下で威勢よく跳ね返る明石鯛や車海老のピチピチした姿も浮かんだ。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
