        "examples": {
          "standard": [
            {
              "text": "ハワイは一年中温暖で、典型的な熱帯気候だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "熱帯気候の地域では、一年を通じて気温の変化が少ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は熱帯気候の国に移住し、新しい生活を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "相当規模の発破が地下の秘密を暴き、間口一・五メートル厚さ一メートルばかりのぎざぎざした開口部を通して、熱を帯びた探求者の前に今や石灰岩の浅い空洞が口を開けており、これは五千万年以上前、かつて熱帯気候だったときの地下水が滴下することによって形成されたものである。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
