      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to fall asleep",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "妻がやさしい声で、真夜中だからおとなしくして寝入るやうにと云へば云ふほど、子供は鼻にかゝつた甘つたれ声で駄々をこねだした。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼女はその夜、夫の寝入るのを待って、その離れ家に出かけていって、彼女をそのまま平和にしておいてくれるように彼等を説得しようと努めたんだ。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は夫の寝入るのを待って、それから外へ駆け出して、どうかそっとしておいてくれと頼みに言ったんだ。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時遠洋航海の書を二部枕元に置き日記の筆を執つてゐるが眠さ切りなり、直ぐ寝入るであらう。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると」　といって、ちょっといいよどんで見せて、「十分か二十分ぐっすり寝入るんですのよ……痛みも何も忘れてしまっていい心持ちに……。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼も往生して、私の寝入るまで、ジットそこで我慢し、あとでソウット母の方に行くのであった。",
              "citation": {
                "source": "私の母",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつはさっきから、上手に寝たふりをして、王子が寝入るのをねらっていたのでした。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "王女はさっきから、上手にねたふりをして、王子たちが寝入るのをまっていたのでした。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかすると他に女があって、時どき先方へ往ったり、また女の方からも此方へ来て己の寝入るのを待って、竊に庭あたりで媾曳しているかも判らないと思いだした。",
              "citation": {
                "source": "宝蔵の短刀",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯を食べてから初めて暖い床に入つて、ぐつすりと寝入るのである。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちこっちの監房で身じろぎや、あくび、寝入る前の動きがある。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに一緒になったときは一つの床にもぐりこんで、夜がしらじら明けるころまで情人の噂などを話しながら寝入るのを常としていた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ私は毎晩母の懐に抱かれて、竹取の翁が見つけた小さいお姫様や、継母にいじめられる可哀そうな落窪のお話を他人事とは思わずに身にしみて、時には涙を溢して聞きながらいつかしら寝入るのであったがある晩から私は乳母に添い寝されるようになった。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（また寝入る）二人沈黙。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉交に慣れた男と女とがなんらの著しき感動もなく、いな快楽さえもなく、習慣的に肉交して、互いを辱しめたことも感ぜずに、なまけた、じだらくな心で寝入るありさまを想像してみよ。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝目覚めるときも、夜寝入るときも、無意識から有意識へ、もしくは有意識から無意識へと移り行く間には実に無数の半意識的状態を経過するから、その有様は夜が明けて朝となり、日が暮れて夜になるのと、少しも違わぬ。",
              "citation": {
                "source": "境界なき差別",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてみんな、ぐっすり寝入る。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでよいのだ、生きる者はどんどん育つ方がよいのだと、私は目をつぶって寝入ることにした。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして明日起きてからのことに考えをめぐらすこともせずに、満ち足りた気持でぐっすりと寝入る。",
              "citation": {
                "source": "身辺雑記",
                "author": "――『日本のこころ』を囲って――",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱がない哲学者が皆寝入る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしすやすやと寝入る児に死ぬべき何の科があろう。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫より寝所して寝候処、なまぐさき匂ひはげしく、水を耳へ吹込み、蚊屋、ふとん、臥筵、畳大にぬれしが、其儘無程寝入る。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫よりは舌たわばやとおもふに、だん／＼舌長くなり、歯ぎわ後へ廻り、ほぞの下、うしろにては腰尻残らずねぶり、夫からはちらばへ、それより蚊屋ふせり候へば、天井より青瓢箪さがり、長くなり、又、じるくなり、其内にわれ寝入るなり。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなり臥りしが、枕もとにありし鼻紙、十五枚もつゆにぬれ、所々ちり、其内寝入る。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のあか子、段々あちこち這廻る内にわれ蚊屋釣り寝所へ入しが、其赤子十ばかりが一ツになり、大きなる目玉となる其内に寝入る。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫より寝候へば、庭のはしりの上に棚あり、すり鉢揚げありしが、飛でおり、棚の下、連子に掛たるすり子木、すり鉢の中へ入、所々すりまわりしが、其内に我寝入る也。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其内にわれ寝入るなり。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨垂に枕を叩かせて、うとうとと寝入る兵馬。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮田又之丞は、寝入ると、歯ぎしりする癖があって、よくからかわれた。",
              "citation": {
                "source": "べんがら炬燵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像程汚い部屋ではなかったけれど、悪酔いの苦痛の上に、何かしらムズ痒くて、疲れ切っていながら、寝入ることが出来ず、ウトウトとすれば、何とも云えぬ恐ろしい夢にうなされ、我と我が叫声に目を覚まして、飛起きると、身体中不気味な汗に、ベットリ濡れているといった調子で、つい朝までまんじりともしなかった。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
