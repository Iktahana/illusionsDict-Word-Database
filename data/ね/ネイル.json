[
  {
    "uuid": "765fa65c-a5cd-5bac-968a-a7bd712e7fb1",
    "entry": "寝入る",
    "reading": {
      "primary": "ねいる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
