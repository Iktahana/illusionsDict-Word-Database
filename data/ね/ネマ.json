        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これより寝間に入る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "服は着たるばかりなりと覚しく、手にて皺を熨すように撫で、埃を払うように叩きつつ、寝間の戸を開けて登場。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急ぎて寝間に入る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジェステック・ホテルの一室には、南北戦に於て南軍が明光を占領、定遠の包囲攻撃の報を得て徐州に迫る南軍の総師として戦線に出る蒋介石が、寝間着姿の婚約者と別離の笑談を交していたのが暗に紛れて潜かに租界の安全地帯に逃れた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マジェステック・ホテルの一室には、南北戦に於て南軍が明光を占領、定遠の包囲攻撃の報を得て徐州に迫る南軍の総帥として戦線に出る蒋介石が、寝間着姿の婚約者と別離の笑談を交していたのが暗に紛れて潜かに租界の安全地帯に逃れた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして着ている寝間着の汚いこと、それは話にならないよと言った。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　朝二階の寝間の床の上で目をさまして北側の中敷窓から見ると隣の風呂の煙突が見える。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はそのまま帯を風呂敷に包んで元の所に置き、寝間に還って長火鉢の前に坐わり烟草を吹かしながら物思に沈んだ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして二時間｜経ち、十二時が打つや、蒼い顔のお政は死人のように横たわっているのを見届けて、前夜は盗賊を疑ごうて床を脱け出た自分は、今度は自身盗賊のように前夜よりも更に静に、更に巧に、寝間を出て、縁の戸を一分又た一分に開け、跣足で外面に首尾能く出た。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして二時間経ち、十二時が打つや、蒼い顔のお政は死人のように横たわっているのを見届けて、前夜は盗賊を疑ごうて床を脱け出た自分は、今度は自身盗賊のように前夜よりも更に静に、更に巧に、寝間を出て、縁の戸を一分又た一分に開け、跣足で外面に首尾能く出た。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、そこで酔い倒れてしまったのを、おおぜいで寝間までかつぎ込んだものである。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口は土間の仕事場で、つゞいて東に茶の間があつて、その奥に座敷と寝間とが三つ割になつて間取られてある。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に寝間をのぞいた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "六蔵ニヤニヤと独笑して、「お寝間のお伽もまけにしてと――姉さん、真個かい、洒落だぜ洒落だぜ洒落じゃねえ。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生、こんな鰻の寝間（床）みたいな小っちゃいアバラ屋でっけど、また寄っとくなはれや」　と言った。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "腺病質のこどもだつた時分に、かういふ夜はよく乳母が寝間着の上に天鵞絨のマントを羽織らせて木の茂みの多い近所の邸町の細道を連れて歩いて呉れた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを想ひ出したので、歳子はやはり寝間着の上へ兄が洋行｜土産に買つて来て呉れた編糸のシヤーレで肩を包んで外へ出て見た。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの富籤を、京の家の私の寝間、床柱の根もとの節穴に隠して置きましたが、お願いですから、親爺に用ありげな顔をして私の家へ行き、寝間に忍び込んで床柱の根もとの節穴に指を突き込み、富籤を捜し出して、当っているかどうか、調べてみて下さい。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに私の寝間の、西北の隅の畳の下に色紙一枚かくしてありますから、あれも佐兵衛のところへ持って行ってみて下さい。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、（断）　寝間の窓から、羅馬の燃上を凝視して、ネロは、黙した。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも恋しいと思う時、あなたは少しも来たらず、昨夜はなんですか、あんな大勢家来を連れて来て私の寝間の扉をとんとん叩いて……私、とうとう起きて上げませんでしたとも。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――鰻の寝間みたいな狭いとこでっけど、庭は広おまっせ」　千日前一面がうちの庭だと、「花屋」の主人は以前から洒落の好きな人だった。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんは、何ごとかと、寝間着のまゝでとび出して来ました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の荒川大佐は、軍服や軍刀はいつも寝間に置いてゐる。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二日目の夜の更けた頃に、お元は身拵えをして七兵衛夫婦の寝間へ忍び寄ると、それを待っていた七兵衛は路用として十両の金をわたした。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何人だい、此処へ来て邪魔するのは、彼方へお出でよ、ひとの寝間なんぞ覗きに来やがって」　老婆は驚いてやろうとした手を引込めた。",
              "citation": {
                "source": "狐の手帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし人が尋ねましたならば、ハア、あれは先頃なくなりました。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところがその……僕には神剣なんかつて分り兼ねますのでね……」　彼の皮肉は従兄には皮肉だとも取れなかつたらしかつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家の井戸の底には、埃が溜つてゐる事も何も忘れ去つて、泥んこの水の中を、四つん匍ひになつて匍ひ廻り、こねまはして、「水が飲みたあい」と怒鳴りながら帰つた時は、おふくろが、洗濯を思ひ出さざるを得ない、悪鬼羅刹の形相に化し終つてゐるのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どう考えて見ましてもこのお申出についてはあなたのお顔を立てかねますな。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
