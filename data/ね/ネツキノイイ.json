        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひどく寝つきのいい庄造は、布団へ這入って五分もすれば眠ってしまうのに、そこへ突然氷のような足に触られて、起されてしまうのがたまらないから、お前はそっちで寝てくれろと云う。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人いちばい、寝つきのいい秀吉だが、その夜は、木枕につむりを当てても、なかなか寝入られなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏はあまりねつきのいい方でないので眠りに陥ちたのは二時頃だろうということであった。",
              "citation": {
                "source": "黄昏の告白",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
