          "literary": [
            {
              "text": "かからんには後に懸念無し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "他念無しと云っても、疲労時の茫然としたようなのは忠では無い、一を主として他を忘れ、粛然となって心が一直線となっているようなのが忠である。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は横に臥したる体をすこしもたげながら片手に頭をさゝへ片手に蚊を打つに余念無し。",
              "citation": {
                "source": "夏の夜の音",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "刎起こして下を覗けば、年老いたる法師一人念仏詣りて余念無し。",
              "citation": {
                "source": "稚子法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の座敷は殿方ばかりにて、ビール又は正宗の空壜を作るによねんなし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
