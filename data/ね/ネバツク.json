        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの古着屋の店にだらりと生々しく下って居る小紋縮緬の袷―――あのしっとりした、重い冷たい布が粘つくように肉体を包む時の心好さを思うと、私は思わず戦慄した。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、ねばつく液をぬりつけた二寸幅に三尺もある薬紙を、電燈の処へ吊下げた。",
              "citation": {
                "source": "蠅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はねばつくほどの昏さで降りこめてゐる。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出よう飛ばうとあせつたけれど羽根や手足がねばつくばかり。",
              "citation": {
                "source": "歌時計",
                "author": "童謠集",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、湿っぽいねばつく靄が立って、遠方の高い建築物をぼやかして見せた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
