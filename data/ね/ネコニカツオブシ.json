          "literary": [
            {
              "text": "猫に鰹節といふことを、しなさる人だ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫に鰹節どころぢやない。",
              "citation": {
                "source": "秘密の代償",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎藤はこの偶然を奇なり奇なりと感じたらしく、「貴様、猫か、猫ではあるまい、化け物だろう」と言って、猿臂をのばしてその猫をかいつかんで、己れが膝の上に掻きのせたままで、「近藤に虎徹は、猫に鰹節のようなものだ」　あんまり適切でもない苦しい譬喩を口走っている時に、竜之助が、「拙者も、刀が欲しい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大口の寄附をした旦那衆は嫌がつて駄目、若い奉公人では猫に鰹節で安心がならねえから、あつしに來て見張つてくれないかと――斯ういふ頼みなんです」「お前それを引受けたのか」「まだ引受けたわけぢやありませんがね。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鐘の音",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
