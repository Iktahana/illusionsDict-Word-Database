        "examples": {
          "standard": [
            {
              "text": "一度固まった土を練り返すのは、大変な労力がいる作業だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この計画は一度白紙に戻して、最初から練り返す必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古いアイデアを練り返して、新しい価値を生み出すことも可能だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この糸を出せば出すほど納豆は美味くなるのであるから、不精をしないで、また手間を惜しまず、極力ねりかえすべきである。",
              "citation": {
                "source": "納豆の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれもいよいよむずかしい国へ帰ってきた」　うねりかえす波の穂を眺めながら、山内は大きく息をついた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
