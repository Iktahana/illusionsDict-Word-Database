        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あっしにゃ、今もってあの女を下手人とだんなのにらんだことがわかりやせんがね」　と――右門の顔が少しばかり明るくなったと思うと、ねっちりいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっそりとうしろを振り向きながら、上から下へ名人の姿をじろじろと見ながめていましたが、とつぜん、やぶからぼうに、ねっちりと妙なことをいいだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの妙に黙ったねっちりした態度が気に喰わないや。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "饅頭虎が、咄々と嗄れ声で物を言うのに対して、指無しの権は、ねっちりした、しかし、突き刺すような皮肉な言葉をつかった。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもっともっとねっちりとしなくては駄目ね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの腰をすえて、ねっちり余念なくかからなければかききれず、「海流」のようにせき立った目前の輻輳になるのだわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙を読んでもらう人もよく考えて、ねっちり読む人に頼むことにします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りにしばしばなので、父と烈しいいい合いをして帰って行く日の淋しい姿や、父の留守にやって来て、ねっちりと長居しているこの人に、母が何かと気をつかって密やかな苦労をしぬいていた日のことなど、おぼろに思い出されもする。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "津多女はひきとめなかったし、大学は玄関で、刀自もお年のことだから健康に気をつけるように、もうお眼にかかることもあるまい、などということを、作った慇懃さでねっちりと云った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、近江のやうな早撮りは出来ず、ねっちり来る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
