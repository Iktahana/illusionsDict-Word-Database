        "examples": {
          "standard": [
            {
              "text": "無理に引っ張ったせいで、コードの途中でねじ切れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ペンチを使って、古くなったワイヤーをねじ切る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "強い力でドアノブを回したら、金属が疲労してねじ切れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「面倒だ、打破しっちまえ」　懐中｜鉄梃を取りだし、器用な手つきで錠をねじ切ると、いきなり懐中電燈で抽斗の内部を照らしたが、彼は思わず歓びの吐息をもらした。",
              "citation": {
                "source": "空家",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔de'visser le coco〕（ココ酒の栓をぬく）……首をねじ切る。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠しだてしやがると、素ッ首をねじ切るぞ」「よろいはとうに泰安州へ行ってるさ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人殺しぐらいはキュウリをねじきるぐらいにしか思っていやしねえ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、ついと小戻りをして、治郎吉の袷の袂を、ねじきるようにつかんだ。",
              "citation": {
                "source": "治郎吉格子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
