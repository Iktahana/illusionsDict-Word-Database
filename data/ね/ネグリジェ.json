        "examples": {
          "standard": [
            {
              "text": "彼女はシルクの美しいネグリジェを身につけ、優雅にベッドへと向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外のドラマで見るような、フリルがたくさんついたネグリジェに憧れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特別な日の夜には、少し贅沢なネグリジェを着て過ごすのが楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "フランスにも、エレガンス・ネグリジェといふ言葉がありまして、「身なりをかまはぬやうにみせた身だしなみ」を指すのであります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彼女はソファに腰を下ろし、ネグリジェの脚を組んで、青年のその落着きのなさ、焦立ちを完全に無視していた。",
              "citation": {
                "source": "愛の終り",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐々木ガキャア／＼云ウノヲ聞イテ、颯子ガネグリジェノマヽ駈ケ付ケテ来、「レスリー、コレ！",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「絶対ニ着物ニハ附ケナイ、足ノ裏ダケニ塗ル」ト云ッタガ、シバ／＼失敗シテ足ノ甲ヤネグリジェノ裾ヲ汚シタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
