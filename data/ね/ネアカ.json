        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はクラスの根明で、いつも冗談を言って皆を笑わせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "根明な友人といると、自分まで元気になれる気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はまさに根明で、落ち込んでいるのを見たことがない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
