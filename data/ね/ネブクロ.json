        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "油紙の厚いのと、シャベルと毛布（カモシカまたはトナカイ）の寝袋があればいいと思われる。",
              "citation": {
                "source": "春の槍から帰って",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "大した荷物がある訳ではなし、毛布と寝袋（これはバギオでカーキー地を買ってつくった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコットは寝袋の垂れをはねのけ、最も信頼していたウィルソン博士の胸に片手を載せたまま死んでいた。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一枚の寝袋、共同の一つのコッフェル、フォークのついた五｜徳ナイフ、コップが一つ。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人は、かんたんな日誌をつけおえると、寝袋をとり出して、さっさと寝支度にとりかかった。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯を喰べている間にサッサと寝床を片づけ、寝袋をよくたたいて戸外へ乾す。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして棚の上から、かもしかの毛皮を縫い合わせて作った寝袋を取りおろして、猪の焙肉や、薄焼や、干飯やかち栗、乾した杏子など、それぞれの包みを中に入れて巻き、それを背負えるようにしっかりと括った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから壺胡※を括りつけ、寝袋を背負い、弦をかけないままで弓を取った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐は藪蔭を選んで、斜面のほうを頭にし、寝袋の中にすっぽりと躯を入れ、食糧の包みを枕にして、じっと眼をつむっていた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寝袋は律が考案し、自分で縫いあげた野宿用のもので、寒さも充分ふせげるし、雪ならもちろん、少しくらいの雨にも、濡れずに寝ることができた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐は頭をあげ、寝袋から顔だけ出して、あたりのようすに注意をくばった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐は寝袋から出て、大きく伸びをした。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はさらに一と握りの雪を口に含み、手拭で濡れたところを拭きながら、寝袋の脇に腰をおろした。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "けものを狩り、樹を伐り、雪にうもれた山の中で、寝袋にもぐって眠り、一人でこういう食事をする。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊達藩宿老の家格も要らない、自分には弓と手斧と山刀と、寝袋があれば充分だ。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、音のしないように、手早く食糧を片づけて寝袋に入れ、それをかたく背負いながら、いまなき声のしたほうをうかがった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "背負った寝袋が邪魔になる、しかし解いているひまはなかった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭間道へ着いた彼は、山裾の一段高くなった杉林の中へはいり、寝袋をおろして、食糧の包みをひらいた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳の部屋にはじつに快適な寝袋が置いてあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつの町でひとつの仕事をかかえて生きていくことのつまらなさと対比して考えるとたしかにすばらしい自由な生活で、寝袋さえあれば、栄養失調、性病、皮ふ病、麻薬常用による精神異常や虚脱症などになるのをいとわないかぎり、現金は一銭もなくても生きていける。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのテントのなかに、二人で入れる寝袋がある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝袋のなかに裸で入った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
