    "definitions": [
      {
        "index": 1,
        "gloss": "yearly candlestick",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
