        "examples": {
          "standard": [
            {
              "text": "給与に関するネゴシエーションがまとまり、双方が納得する形で契約更新となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国際会議では、各国の代表者が複雑な問題についてネゴシエーションを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ネゴシエーションのスキルは、ビジネスだけでなく日常生活でも役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この先生が信じているのは人生にはネゴシエーションという軸があって、妥協とか示談という完全な共同作業が成立する。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに女の口説もネゴシエーションです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしセラダのネゴシエーションはやや荒ッぽくなっていました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二世にすらも親友がいないと云われているほどですから、血は同じでも国籍のちがう日本人にはネゴシエーションの席以外には友情をもつ必要を感じていなかったのです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
