    "definitions": [
      {
        "index": 1,
        "gloss": "to bend by twisting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
