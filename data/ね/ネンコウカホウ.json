        "examples": {
          "standard": [
            {
              "text": "長年勤務した社員には、年功加俸が支給される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "年功加俸の制度は、従業員の定着率向上に貢献する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は年功加俸の恩恵を受け、生活が安定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "各小学校の評判や年功加俸の話などが出る。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三や四でもう先の年功加俸だのなにかの計算をして暮らしているような馬鹿の仲間入りをしていたら、人間もたいていやりきれたものではない。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮にそうでないとした処が、あと十年つとめれば十年だけの退職手当の増加もある筈の処、今の計算で之を貰うのでは何のことはない、年功加俸を踏み倒されるようなものだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
