          "literary": [
            {
              "text": "各小学校の評判や年功加俸の話などが出る。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三や四でもう先の年功加俸だのなにかの計算をして暮らしているような馬鹿の仲間入りをしていたら、人間もたいていやりきれたものではない。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮にそうでないとした処が、あと十年つとめれば十年だけの退職手当の増加もある筈の処、今の計算で之を貰うのでは何のことはない、年功加俸を踏み倒されるようなものだ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
