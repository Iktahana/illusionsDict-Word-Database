    "definitions": [
      {
        "index": 1,
        "gloss": "warm (esp. from the fever of a sick person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
