        "examples": {
          "standard": [
            {
              "text": "ネストリウス派は、キリスト教の歴史において重要な役割を果たした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "東方教会の一部には、ネストリウス派の教義の影響が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中国に伝わったキリスト教の一派は、ネストリウス派であったとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それらの東方のクリスチャンの大部分はネストリウス派（景教徒）であり重要な中心の１つはエデッサであり、そこの学習施設は喧伝されていた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "」第37図　ヨアニティウスの Isagoge（In Articella, Venice, 1487）　アラビア人は主としてネストリウス派信者からギリシア医学を学んだ。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネストリウスは三位一體に關して、新しい見解を主張した。",
              "citation": {
                "source": "大秦景教流行中國碑に就いて",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
