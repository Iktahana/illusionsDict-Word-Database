        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかるに現在では細長い日本島弧の上に、言わばただ一連の念珠のように観測所の列が分布しているだけである。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手に燻りかえる安線香の束を持ち、左手に念珠を掛けながら、膝頭をガクガクさせて「南無南無南無」と言うばかり。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは共通な感じを糸にしていろいろの景物を貫ぬいた念珠のような形式である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面には弘法大師の掛軸、その前にお納経の帳面、御燈明、線香、念珠、すべてが型の通りであったが、驚いたことには、右に大形の五十銭銀貨が十枚ばかり並べてあり、左に護摩水の一升罎が置いてあった！",
              "citation": {
                "source": "遍路の正月",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝は太祖の皇孫と生れさせたまいて、金殿玉楼に人となりたまいたれども、如是因、如是縁、今また袈裟念珠の人たらんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆるらかに幾尺の水晶の念珠を引くときは、ムルデの河もしばし流をとどむべく、忽ち迫りて刀槍斉く鳴るときは、むかし行旅を脅ししこの城の遠祖も百年の夢を破られやせむ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆるらかに幾尺の水晶の念珠を引くときは、ムルデの河もしばし流れをとどむべく、たちまち迫りて刀槍ひとしく鳴るときは、むかし行旅をおびやかししこの城の遠祖も百年の夢を破られやせん。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ一飯の御情に預り、御本堂への御つとめ許し賜はらば格別の御｜利益たるべしと、念珠、殊勝｜気に爪繰りて頼み入りしに彼の寺男、わが面体の爛れたるをつく／″＼見て、まことの非人とや思ひけむ、他意も無げにうち黙頭きつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の傍には露肆をしつらひて、もろ手さし伸べたる法皇授福の木板畫、念珠などを賣りたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に〈念珠を見るを悪む。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "常陸の勿來の關（一名菊名の關）、越後界の念珠ヶ關（鼠ヶ關）、及びこの下野界の白河の關は、古來奧羽方面の三關として有名也。",
              "citation": {
                "source": "白河の關",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい肌黒の胡桃の木よ、海草の髮を垂れ、くすんだ緑玉の飾をした女、空の草原の池に浸つて青くなつた念珠、ぼんやりとした愛の咽首を締めてやらうとするばかりの望、よく實を結び損ふ繖形花。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大勢の參籠者の右の角のところに、小さな念珠を右の手にかけて、その白い顏を半群集の中に際立たせながら、じつと本尊の方を見てゐるのは、それはまがふべくもない窕子であつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『有難や……』の聲のあちこちに起る時には、母も娘も共に念珠を繰つて禮拜した。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の間々には、老尼は念珠を手まさぐりつゝ佛の名を唱へた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に敗けて飛びだした、手には念珠を握つてゐる、それをあづけてＴさんから少し借りる、そして酔ひつぶれて、Ｉ館に泊る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅のポストまで出かけた帰途で、念珠玉草を見つけて、一茎持つて戻つて、机上の徳利に※す、幼年時代の追憶が湧いた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "内には寂然として人なきが如く、只々簾を漏れて心細くも立迷ふ香煙一縷、をりをりかすかに聞ゆる戞々の音は、念珠を爪繰る響にや、主が消息を齎らして、いと奧床し。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "内には寂然として人なきが如く、只※簾を漏れて心細くも立迷ふ香煙一縷、をりをりかすかに聞ゆる戞々の音は、念珠を爪繰る響にや、主が消息を齎らして、いと奧床し。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様は信心深くて念珠を手から離したことがない。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えば「こんたつ」と称える念珠も手頸を一巻き巻いた後、かすかに青珠を垂らしている。",
              "citation": {
                "source": "おしの",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九世紀の中葉、十三の少女は、ルールドの洞窟の中で、聖母の姿を見た――白衣をまとい、青い帯をしめ、念珠を帯にさげ、異様な光輝にかこまれていた。",
              "citation": {
                "source": "幻覚記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大名と呼ばれた封建時代の貴族たちが、黄金の十字架を胸に懸けて、パアテル・ノステルを口にした日本を、――貴族の夫人たちが、珊瑚の念珠を爪繰って、毘留善麻利耶の前に跪いた日本を、その彼が訪れなかったと云う筈はない。",
              "citation": {
                "source": "さまよえる猶太人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、黄昏と共に身辺を去来して、そが珊瑚の念珠と、象牙に似たる手頸とを、えもならず美しき幻の如く眺めしのみ。",
              "citation": {
                "source": "るしへる",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　阿闍梨は、手頸にかけた水晶の念珠をまさぐりながら、鋭く翁の顔を一眄した。",
              "citation": {
                "source": "道祖問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こう云って阿闍梨は容をあらためると、水晶の念珠を振って、苦々しげに叱りつけた。",
              "citation": {
                "source": "道祖問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも一度なぞは勇之助が、風か何か引いていた時、折悪く河岸の西辰と云う大檀家の法事があったそうですが、日錚和尚は法衣の胸に、熱の高い子供を抱いたまま、水晶の念珠を片手にかけて、いつもの通り平然と、読経をすませたとか云う事でした。",
              "citation": {
                "source": "捨児",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれど親の代から「ぜんちよ」（異教徒）の輩であらなんだ事だけは、手くびにかけた青玉の「こんたつ」（念珠）を見ても、知れたと申す。",
              "citation": {
                "source": "奉教人の死",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "金襴の袈裟、水晶の念珠、それから白い双の眉毛――一目見ただけでも、天が下に功徳無量の名を轟かせた、横川の僧都だと申す事は疑おうようもございません。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは、一ねんじゅう花がさいていました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
