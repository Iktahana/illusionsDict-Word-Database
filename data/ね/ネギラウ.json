[
  {
    "uuid": "897c0319-aa5d-52cf-bd48-a115cf6217de",
    "entry": "労う",
    "reading": {
      "primary": "ねぎらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to show appreciation for (efforts, esp. by someone of equal or lower status)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　思入って労う言葉。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は、また、久しぶりに、めでたく卒業した、愛する妹が帰って来まして、七条駅まで迎えに行き、昨秋以来の、なつかしい逢瀬の、互いに労う挨拶を交わす時にも、兄妹ともしあわせな心地につつまれました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お帰りかい」　と慰労うように言う祖母さん、母や姉の帰りを待受けていた一郎と次郎、谷中の家の様子を聞こうとする岸本親子なぞが嫂達の側に集った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして労う心地をさえ抑えることができない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大儀であったな」「ナーニ」　米友は眼を外らして横を向いて、能登守の労う言葉を好意を以て受取ろうとしません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、やっとくれや」　と達雄は慰労うように言った。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私に果すべき仕事が無いならば、私はかの有名な死を以て限られている私の生活の――時間の――有限性を思い労う正当な倫理的権利を見出さない。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "折よく定助も他出からもどって風呂に入ったところで、正造の顔をみるとまず長途の旅を労うのだった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく怪しまれなかったね」　ロイド眼鏡が部下を労う様に云った。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "名馬一　あれほど義経に対しては、思慮をめぐらし過ぎるほど気を労う頼朝も、同じ弟でありながら、範頼に対しては、さほどでもない。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くれぐれ軽はずみをさすな、気を労うて帰城をいそぐなと、半兵衛にも伝えおけよ」　卒は槍を立て、騎馬の人々は、彼の前後に立って縦隊を作った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる時はいたずらに、心を労うも及ばぬことだ、ただ天に順じ、一路まどわず急ぐに如くはない」　家康はつかれも知らぬ容子である。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、宥り慰めて事ごとに気を労うふうすら見える。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "御台御迎えの一行が上洛した時、一行の宿泊所と定められている六角東洞院の京都の守護｜武蔵前司源朝雅の第へ着いたが、朝雅は一行をねぎらうために酒を出した。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分で茶を入れて、使に来た輝子をねぎらうようにした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、地上出発以来の乗組員たちの苦労をねぎらうためとあって、食堂はクリスマスのように飾りたてられ、たいへんな御馳走が出た。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "老貴公子は進み出て、ねぎらうように声をかけた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は母の永年の労をねぎらうためと、一九二八年八月一日に三男英男が自分から生命を断った、その悲愁から母の心持を転換させようとこの旅行を企てたのであった。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならやりましょうが、下ろしたあとで、船員たちの労をねぎらう意味で、酒をのませてやってください」　と、新船長さんは、なかなかぬけ目がない。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "キミの労苦をねぎらうためにキミに与えられた仕事だぜ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが家に於ては小生が有金全部失うこと必定とみて、すでに東京に赴いて金策を果し、敗軍の将をねぎらうに万全の用意をととのえていたが、このへんは近来の美談と云うべきであろう。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "話し手は、労をねぎらうための葡萄酒のグラスを唇につけようとしていたが、一瞬静止して、無限の尊敬の意をこめて質問者を見やり、やおらグラスをテーブルにおろし、口を開き、この物語がきわめて論理的に立証しようとすることは、「人生においては、たとえどんな場合でも必ず利点や愉快なことがあるはずです。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉左衛門はそこにいる人たちをねぎらうばかりでなく、自分で自分に言うように、「御苦労、御苦労。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の話は互いの激しい疲労をねぎらうことから、毎日のように目の前を通り過ぎた諸団体のことに落ちて行った。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は荷造りの座員をねぎらうため、酒を買わせて楽屋で酒宴をひらき、明るいうちに大虎になって、みんなと寝こんでしまった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑中は特に八十吉夫婦と竹造ならびに今村を船長室に招待して労をねぎらう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "加十はこれは皇帝が運動して自分を釈放させ、今までの労をねぎらうため饗応でもするつもりでホテルに呼び寄せたのだと思い、ノメノメと安楽椅子に掛けて待っていると、案の条ボーイ長らしいものが入って来て、加十の鼻先に献立表を突付けた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　原文「労之」を民をねぎらう意味に解する説もある。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍首脳部や長老の動きは頻繁で、その代表者は叛軍の説得に赴いたが、その結果はきわめてあいまいであり、しかもその夕方には、叛軍の疲労をねぎらう意味で首相官邸をはじめ、鉄道、文部、大蔵、農林の諸大臣の官邸や、山王ホテル、料亭幸楽等が彼等の宿舎として提供された。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその力は、贈り得る限りのあらゆるもので、彼をねぎらうと同時に、その代償として、常に取り上げるもの一切を、容赦なく彼から取り上げたのである。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
