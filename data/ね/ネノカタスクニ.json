        "examples": {
          "standard": [
            {
              "text": "日本神話では、根の堅州国は黄泉の国と同一視されることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代の人々は、死後の世界である根の堅州国を恐れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は物語の中で根の堅州国への旅に出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "母と言ふ名に囚はれては、ねのかたすくになり、わたつみのみやなりがあり、至り難い国であり、自分たちの住む国の俗の姿をした処と考へて居なかつた事は一つである。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            }
          ]
        }
