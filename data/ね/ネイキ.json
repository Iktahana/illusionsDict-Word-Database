    "definitions": [
      {
        "index": 1,
        "gloss": "breathing of a sleeping person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
