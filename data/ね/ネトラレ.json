    "definitions": [
      {
        "index": 1,
        "gloss": "cuckolding (esp. in pornography)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
