        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのうちに、イーダちゃんの寝る時間になりました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそうしたものを食べながら家人は一時二時までも喋舌って夜をふかすので、私達の寝る時間とては多くてやっと四、五時間しかないのであった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事の後れた如く、寝る時間も順繰に延びてだいぶ遅くなった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、子供達の寝る時間になりましたので、叔母が彼等を寝かしつけてる間、私は二階に上って、叔父の書棚を片附けたりなんかしました。",
              "citation": {
                "source": "影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに電車に乗ったりなんかして、空いた電車を幾台も待ったりなんかして、家に帰る時分には、もう寝る時間になってるという始末なんだ。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そろそろ寝る時間だ。",
              "citation": {
                "source": "首なし",
                "author": "TRUNK-WITHOUT-HEAD",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども夜に入って寝る時間が来るまで御米はそれをわざと延ばしておいたのである。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝る時間を半分にすればいゝのである。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも早く家に帰っても仕様がないので、寝る時間になるまでここに居ようという心理状態になるのだと思いました。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝る時間です」　乃公は寝る時間なんか、尋ねていやしない。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食後、芝居か音楽会に行かない時には、カフェエに陣取って、寝る時間が来るまで、新聞を読む。",
              "citation": {
                "source": "道化者",
                "author": "DER BAJAZZO",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと、早ねの効験がわかったか、と私は大威張りです、はじめの頃、私が夕飯すむと、もう何となし寝る時間を気にしてそわそわしていたのを、寿江子は大分嘲弄いたしましたからね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕入れ先は、高島町の河岸近くで、そのため朝は星のあるうちに家を出るので、殆ど寝る時間は少なかった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり桶屋職人で、酒も煙草も賭博も遊蕩も嫌いであり、食うのと寝る時間のほかは働きどおしに働いた。",
              "citation": {
                "source": "ゆうれい貸屋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、起きていて楽しいときは、もうひとりの自分は寝る時間までちゃんと取っておく」「普通の夢みたいに、無責任でとりとめのない世界ではないんだ」「とてもはっきりしてるよ。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
