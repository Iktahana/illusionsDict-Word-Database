    "definitions": [
      {
        "index": 1,
        "gloss": "dull blade",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「伊勢音頭｜恋寝刃」の中で、一番悲劇らしい、切に胸に来る性格はお鹿と言ふ女郎である。",
              "citation": {
                "source": "辻の立ち咄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪蔵と信三郎と品吉は縛ってあるが、この上どこに寝刃を合せている者がないとは限らない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "柄に籐を巻いた、恐ろしい荒い刃で、おまけに菜切庖丁の砥石でゴシゴシやっている」「すべりを防ぐために、寝刃を合せるということもあるが――」　と平次。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮の浴槽",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜之助は、いまこの刀の寝刃を合せはじめたものであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀の寝刃を合せるには、きっと近いうちにその刀の実用が予期される。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は人を斬るべき今宵という時に、刀の寝刃が合せられるはずのものであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから、刀の寝刃を合せる時には大概の勇士でも手が震うものであります、心が戦くものでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにこの人は平気で寝刃を合せています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、ようやく寝刃を合せ終ったのは二尺三寸、手柄山正繁の一刀でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝刃を合せていることも、巻藁を切るためであったかと思えば、別段に凄いことではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで寝刃を合せ了った竜之助が、手柄山正繁の一刀を取り直した時に、広い座敷、およそ二十畳も敷けるこの一間の片隅にあった古びた長持の蓋がガタといって動きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても、明日これこれの時刻に、陰謀の寝刃を向けられている当の老婆が、全く一人ぼっちでいるという事を、すぐその前日この上なく確実に、いっさい危険な質問や探索なしに突き止めるのは、およそ困難なことに相違ない。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと我れに返る生姜湯の灯も、せつな我れを失う寝刃の闇のこと　かたちでは、眠りについたが、宋江も婆惜も、じつはまんじりともしていない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてそんな内輪話まで知っているのだ」「お前さんも薄々は感づいていましょうけれど、笊組の久八だの、大月玄蕃や投槍の小六などは、いまだに絶えず寝刃を研いで、新九郎さんの隙を窺っているのですよ。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お十夜が恋の仇と寝刃をとぐ彼、そして、お綱の思いあくがれている彼の姿が、江戸の地へ立ったのである。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大塔ノ宮は吉野の孤塁に、千早は敵の重囲のなかで、明日の望みはおろか、一命すらも、いつ北条の寝刃に会うやらと、日々が露の身のおここちだった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでギンは、そのあくる日は、パン粉の、こねたばかりで焼かないままのをもって、まだ日も出ない先に、いそいで湖水へ出かけました。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると沙本毘古のほうでは、いねたばをぐるりと積みあげて、それでとりでをこしらえて、ちゃんと待ち受けておりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、こなひだ他の委員がはねたばかしなんだからね。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "単純な西洋風をまねたばかりでは活動写真の範囲を出ないし、われわれの日常生活の習慣が感情表現に加えている長年の制約を、演技的に止揚することは大切な努力の一つとして将来に期待されることである。",
              "citation": {
                "source": "映画の恋愛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり広くもない三室を連ねたばかりの会場に人は相当這入っていたが、それもうるさいほどではなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうと今日と三時間ほどねたばっかりで私は十六になり今までより以上に改良もし進歩もしなくっちゃあならないかと思うと急に私の肩が重くなった様に思われる。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけなや、何と、それは、やッと当歳か、それとも生れて年を重ねたばかりのむつき児なのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "諭吉は夕がた酒をのんで、いまねたばかりです。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子が……もう早くからねこんでいるかい」「いいえ、つい十五分ほどまえねたばかりです。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此處には何時も人は居ないのか」「夜は滅多に參りませんが、昨夜はまだはねたばかりで、火鉢もそのまゝになつて居たことでせう」　小左衞門は要領よく答へます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "一と目千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここには何時も人は居ないのか」「夜は滅多に参りませんが、昨夜はまだはねたばかりで、火鉢もそのままになって居たことでしょう」　小左衛門は要領よく答えます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "一と目千両",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先生の上京後、二人で懇談を重ねた結果、具体案を作って寄付者に提示したところ、先方では、その根本方針に双手をあげて賛成し、一切を田沼さんの自由な処理に委ねたばかりでなく、事情によっては年々経常費の一部を負担してもいいということまで申し出て来ている。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度ヘヒトに出会ったことがあるけれど、ヘヒトは彼の健康を二、三言冷淡に尋ねたばかりだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、腐ったペンキのにおい、列氏三十度の暑さ、しめ切ったむんむんする空気、人混み、前の日にたずねたばかりの人間が殺された話――こうしたものがいっときに、空腹の体へきたんだからね！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
