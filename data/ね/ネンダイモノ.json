          "literary": [
            {
              "text": "まるで彗星接近時の年代物を一口含んだばかりのワイン通のようだ。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウンターのストゥールにすわった客の背後にあたるスペース、そして年代物の金銭登録機が置いてある一角は、いくつかの商品陳列ケースによって占められている。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年代物の古い広告看板が、とりつけてあったのさ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドン塔は誇るべきだよ、ニューヨークに勝る、うん」　スリム氏が年代物に対して、聞きしに勝るアメリカ人の畏敬の念を込めた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲は年代物のオーク材家具がにぶく輝き、優雅で芸術的な雰囲気に大満足だ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "年代物の革製掛け軸に隠れて、スミス氏とグラントは成り行きを見聞した。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "悦に入って眺めた食堂には年代物の樫壁になめらかな銅版画が掛かり、食台には銀器やグラス、デザートが乗っていた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
