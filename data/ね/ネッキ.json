  {
    "uuid": "d1922d89-9521-5b73-804b-1ed7fc938619",
    "entry": "根っ木",
    "reading": {
      "primary": "ねっき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "children's game in which a wooden stick driven into the ground is dislodged by sticks thrown at it",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私達は驚いて根っ木をやめた。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えて見ると、竹馬も長崎凧も、根っ木も、ブン／＼も、私達子供の頃は皆自分の手で作った。",
              "citation": {
                "source": "四谷、赤坂",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "独楽や凧や竹馬や根っ木やらは棄てられねばならない。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年時代には、誰でも一度は、弄ぶにきまっている、めんこ、ねっき、ばいなどというものにも、ついぞ手を触れることを許されませんでした。",
              "citation": {
                "source": "勝負事",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今度、ねっきりはっきり此っきりで、此は書かなければなるまい。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌っていた子達がそれと見ると、急に丸くなって「ねっきりはっきり、これっきり、あとから来る者入れないぞ」と叫びながらまとまってしまう。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一尺ばかりの木の枝の先をとがらし、ねっきと称えて互いに地面にぶつけ、突きさして、相手のねっきを倒せば取る、少々蛮的で相手に怪我をさせることもある危険性、結局親父に取りあげられて風呂のたきつけにされたもの。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
