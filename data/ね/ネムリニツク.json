[
  {
    "uuid": "d8eb8e7a-0146-5924-a90b-f0a8855f5359",
    "entry": "眠りにつく",
    "reading": {
      "primary": "ねむりにつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
