[
  {
    "uuid": "402a2901-1630-5374-bdd3-776508e162ae",
    "entry": "年礼",
    "reading": {
      "primary": "ねんれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
