[
  {
    "uuid": "649716bc-90d5-59e1-ae07-ef49239e715b",
    "entry": "音締",
    "reading": {
      "primary": "ねじめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tune",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その控室の方に当っては、もはや、午後の演奏の支度にかかっているらしく、尺八に対して音締めを直している琴や胡弓の音が、音のこぼれもののように聞えて来る。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、こうした見知らぬこの北方の夏の夜の雰囲気の何処かで、内地で聴くようなあの三絃の音締めがして、そしてあのエンヤラヤアノヤアヤである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かう話がきまつて、二人は新橋の方へ向いて高架鐵道の下をぬけ、烏森の意氣な圓い大提灯が出てゐたり、三味線の音締めが聽こえたりする横町々々を縫つて行つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　花の詞が切れないうちに、音締の惡い三味線の音がする。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋ゃ、秋、身にしむ恋のつまびきに、そぼふる雨もなんとやら、いっそ音締めもにくらしい、というやつだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがは糸の音締めで名をとった江戸女だよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は古い江戸ッ子がバラック趣味を軽蔑し、オツな喰い物、意気な音締め、粋な風俗の絶滅を悲しんで、イヤになって引っ込んでいる間に、ドンドン彼等の趣味を東京市中に横溢させている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "音締の悪い三味線の伴奏で、聴くに堪えない卑しい歌を歌っている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の部屋の下の道から、ヴァイオリンの音締めの音がときどき洩れて来た。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり広くはない正面の楽師たちに絡りついている真鍮の楽器の管から、しっかりと音締めの利いた音がもう久慈の胸中に吹き襲って来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度撥を取れば、どんなぼろ三味線でも、びーんと男の音締が出る。",
              "citation": {
                "source": "表現論随筆",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の三味線の音締の力強さに驚きもしたが、それよりも一層、彼女の芸が単に精神的にでなしに肉体的にまで彼女を支持してるのに驚いた。",
              "citation": {
                "source": "表現論随筆",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いい音締だな小気味のよい音色だ」　それは呟いているのではなく、大声で喋舌っているのであった。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "始まる時に何等の合図もなく、三曲のうちの何れかの一方が音締めをすると、期せずして他の二人が、それぞれの楽器を取り上げるのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、この近辺は花柳の巷でもあるのか知らん、お雪ちゃんがうっとりしている間に、三味線の音締などが、小さな宮川の小波を渡っておとずれようというものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "後でお医者の方たちはお兄様のお話を喜び、お姉え様の長唄を聴いた者は、その音締に感じ入ったのでした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度二を上げて一撥二撥当てた音締。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に客もないかして、三味線の音締めも聞こえない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "音締めの悪い三味線の音が、座敷のほうから聞こえても来た。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "素晴らしい音締の撥さばきが、若い女の甘いあだっぽい溶けるような唄声と一緒に流れてきた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛嬌のある円顔をテラテラ百目蝋燭の灯に光らせて、性急そうに歌っている父橘家圓太郎の高座姿がアリアリと目に見えてきた、いや、下座のおたつ婆さんの凜と張りのある三味線の音締までをそのときハッキリと次郎吉は耳に聴いた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日から圓朝の家は三たび態を変えて、今度は花やかな三味線の音締が絶えず聞かれるようになった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "お得意の三味線の音締めに掛らうとしてゐたらしい禎子は、楽器を傍に置くとその肥つた体躯を起して、人の好い笑みを湛えながら、縁さきにあらはれて、「光代さん、今晩は。",
              "citation": {
                "source": "水と砂",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　愛想よく言ひながら、禎子は室内に戻つて行つたが、やがて低い音締めがピーンと響いた。",
              "citation": {
                "source": "水と砂",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯の間から撥を取り出して音締にかかる、ヒラヒラと撥を扱って音締をして調子を調べる手捌きがまた慣れたものであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "間の山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛や太鼓の響きも聞えれば、音締も響いて来るし、どうかすると、よいよいと合唱の唄が揚る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "前掲の老芸人の話では春琴の三味線を蔭で聞いていると音締が冴えていて男が弾いているように思えた音色も単に美しいのみではなくて変化に富み時には沈痛な深みのある音を出したといういかさま女子には珍しい妙手であったらしい。",
              "citation": {
                "source": "春琴抄",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん、仲次郎のほうが三味線は上だって云やあがったが、なにょう云やがる」彼は持っている折詰を振った、「世間にゃあ耳のねえ野郎がそろってるから、音締めひとつ聞き分けることもできやしねえ、みやあがれ、仲次郎はたちまちあのざまだ。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のにほひのゆかしさは薄らあかりの鴨の羽、三味のねじめのゆかしさは遠い杵屋の薄あかり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりしっかりしたねじめの三味線の音が響き始めて、およねの歌。",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
