    "definitions": [
      {
        "index": 1,
        "gloss": "beginning of the year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "筆者も今年初夏頃の某誌にもはや充分意を尽したつもりの恋愛論を発表しました故、論筆として諸氏に見える余裕のものを多く持ちません。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい二三年前までは毎年初夏になるとあの感傷的な苗売りの声を聞いたような気がする。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年初めて来たとき、軽井沢駅のあの何となく物々しい気分に引きかえてこの沓掛駅の野天｜吹曝しのプラットフォームの謙虚で安易な気持がひどく嬉しかったことを思い出した。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくたびも生死の境にさまよいながら、今年初めて……東京上野の展覧会――「姐さんは知っているか。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年初めて参詣した時には、墓の所在が知れないので寺僧に頼んで案内してもらった。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、地方の或る高等学校に居た私は、毎年初夏の季節になると、きまつて一つの熱情にとりつかれた。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十三年初秋萩原恭次郎",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この巫女は、当年初に仕えたので、こうされるのが掟だと思って自由になったそうである。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は其柔和な顏に微笑を浮べて『毎年初日の出を拜みに出るのか。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和三年初夏のことであつた。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年初夏、総長の辞任と共に、つづいて校長を引責せしむ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、建久元年初めて上洛し、権大納言右近衛大将に任ぜられたが、直ちに拝辞した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつたくそれは今年初めて見る燕の鳥であつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "或る日の晝餐",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十七年初夏のことであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "東京の郊外を想ふ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルネッサンス期の出版人の名をとって、アルダスと名付ける会社の設立を計画し始めた一九八四年初頭には、どのコンピューター相手にソフトウエアを書くべきか、判断は付いていませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年初め、ワーノックはアップルコンピュータの創業者、スティーブ・ジョブスと再会します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "は「暮春、皆が春服となる好い時節に、今年初めての冠者となった青年五・六人と、童子六・七人を連れて、沂の温泉に浴し、舞※の辺りの涼風に吹かれ、歌を詠じながら帰って来たいと思います。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "花紅紫赤、又、濃き淡きあり、春末初めて発し夏中最も盛り、秋冬凋まず、続々開拆す、四時翫好蕪靡愛すべし、今年初めて禁離に種ゆ、物、地を得て美を増す、数十の名花ありと雖も傍色香なき若し。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダーリヤ　白井博士教示に天保十三年初めて輸入され、初めは蘭名ラノンケルで通用したが、葉花共にやや牡丹に近いゆゑ天竺牡丹と俗称したと、舶上花譜に出づと。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年初めて見る梅である。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つの年初めてお目見得に上って、お茶との御所望があったとき、過ってお膝の上にこぼしたら、ほほう水撒きが上手よ喃、と仰せられた程の殿である。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お奉行さまのところへ年賀に参ったればこそ、この敬四郎も年初めそうそう大役を仰せつかったわ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "年初めそうそう大役を仰せつかったっていうなア、きっとあばたの野郎め、与力か、同心主席に出世しやがったにちげえござんせんぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年初秋の候になると、イーグル・ハウスへ、エイブラム・ストロングといふ人が逗留に來たが、彼は人々の敬慕の的となつてゐた。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年初めて参詣した時には、墓のありかが知れないので寺僧に頼んで案内してもらった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十八年初秋上田敏海潮音燕の歌　　　　　ガブリエレ・ダンヌンチオ弥生ついたち、はつ燕、海のあなたの静けき国の便もてきぬ、うれしき文を。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十八年初秋上田敏ガブリエレ・ダンヌンチオ燕の歌彌生ついたち、はつ燕、海のあなたの靜けき國の便もてきぬ、うれしき文を。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "処々乾きかゝつてゐる赤土の運動場には、今年初めての黄い蝶々が二つ、フワ／＼と縺れて低く舞つてゐる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "處々乾きかゝつてゐる赤土の運動場には、今年初めての黄ろい蝶々が二つ、フハ／＼と縺れて低く舞つてゐる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも事のおこりというのは、長政公が十五におなりになったとし、えいろく二ねんしょうがつと云うのに元服をなされて、それまでは新九郎と申し上げたのが、そのときに備前のかみながまさとお名のりなされ、江南の佐々木｜抜関斎の老臣平井加賀守どのゝ姫君をお迎えなされました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
