        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「どこでしたかね」　自分ながら薄のろい声で彼はこう尋ねねばならなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰒汁とこいつだけは、命がけでも留められねえんだから、あの人のお酌でも頂き兼ねねえ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ駄々を捏ねねえでこちらへござれ。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともからは、波田が以前から、その後頭の左寄りのところにインチ丸ぐらいで深さ二寸ぐらいの穴を「ブチあけ」てやりたい、とつねづねねがっていたセキメーツ（二等運転手）が来た。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく彼の女は、その病院の洗濯婦と、院長の宅の飯炊とを兼ねねばならなかったのである。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "』木曾の棧橋といふところの休茶屋に飼つてあるお猿さんが、そんなことを父さんに尋ねねました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜もねねえでかせいだんなあ何のためだ、ひとう馬鹿にしてけつかる」　オイオイと号泣して、彼女はよろける。",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついこの間までほんのねねさんだと思っていたのに――」　ルイザの後に立つと、彼女は、傍で挨拶をした一人の女を見向きもせず、指環の三つ嵌った手を延して、レースをどけた。",
              "citation": {
                "source": "顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその可哀さうな悪魔にやあ、どうにも地獄が恋しうて恋しうて、首でも縊りかねねえほどふさぎこんでしまつただよ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それはそれとしても、なんだか僕には、逢痴殺しよりも先に、君の親殺しを、訊ねねばならぬ義務があると思うのだよ。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昵懇を重ねねばならぬと思った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ねねっちゃ、不可ねえ、ねね、ねむっちゃいけねえ」　細いこえがうたうようにそう答えていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "義務教育だ――そう言ってそんなむごい両親を突っぱねねばならぬと考えた。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎みを、満腔に忍んで、彼はやがて仇敵どもがすすめる杯を、今夜も重ねねばならぬのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいうのが思い込むと、どんなことでもしかねねえよ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり安心していると、鉄檻でも脱けかねねえ奴――おめえの方も、きびきび行らかす心支度が出来たかな？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃路に帰り来りてうれしけれ黄に透りたる茎漬のいろ　（改造）信濃路に帰り来りてうれしけれ黄に透りたる漬菜のいろは　（アララギ）神経の痛みに負けて泣かねども夜毎寝られねば心弱るなり　（改造）神経の痛みに負けて泣かねども幾夜寝ねねば心弱るなり　（アララギ）　廿一日夕七時ごろ、古実君との問答がある。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺はどうともして田沼めに近寄り、白毛首これで刎ねねば置かぬ」　冬次郎はいいいい金剛杖を、三寸ばかり抜いて見せた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは誰しもさういふもので、だから庄吉が話の途中に急にイライラとシゴキを握つてピンポン台の足にからみつけて、輪をつくり、輪に首を突ッこんでグイグイひいて、これぢやア死ねねえかな、イライラとシゴキを握つて又首をつッこみギュウギュウ腕でひつぱりあげる。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見は更に省察を重ねねばならなかった。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは誰しもそういうもので、だから庄吉が話の途中に急にイライラとシゴキを握ってピンポン台の足にからみつけて、輪をつくり、輪に首を突ッこんでグイグイひいて、これじゃア死ねねえかな、イライラとシゴキを握って又首をつッこみギュウギュウ腕でひっぱりあげる。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンドレイ、エヒミチは歸來早々先づ其住居を尋ねねばならぬ。",
              "citation": {
                "source": "六號室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンドレイ、エヒミチは帰来早々まずその住居を尋ねねばならぬ。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "（父親が黙っているのを見て、片手を振る）またけんかのたねね……メドヴェージェンコ　マーシャ、ぼく歩いて帰るよ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヽ死にたい……死ねねば人でも殺してみたい』と云ふ気が唯起る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "白竜になるのには大へんな修行、大へんな年代を重ねねばならぬ……。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……俺も実あ、女郎と聞いて、いくら何でも程があると怒って見たが……、考えて見ると、あの人は、それ位やりかねねえ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カツとすると隨分人位は殺し兼ねねえ野郎だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美女を洗ひ出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッとするとずいぶん人ぐらいは殺し兼ねねえ野郎だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "美女を洗い出す",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
