    "definitions": [
      {
        "index": 1,
        "gloss": "crafty courtier",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "硬骨漢汲黯が退いた後は、帝を取巻くものは、佞臣にあらずんば酷吏であった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君侯父子を離間しようとする佞臣奴！",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたく其不明を悔い、直に佞臣汚吏を斥けて、鋭意善政を施せり。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は同時に二人の主君に奉事せんことを欲したる二心の佞臣なりき。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忠臣義士は悉く遠退き、残ったは阿諛の佞臣ばかり、金銭財宝もおおかた尽き、ろくに兵備とてなさそうである。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男はまだ三十二三で、主人の大膳正と似寄りの年でしたが、昔将軍｜家治に取入った田沼主殿頭意次のように、美男で弁舌が巧みで、その上これは――古今の佞臣に共通の特色ですが、曾て人と争うことなく、かりそめにも腹を立てるということを知らぬ珍しい性格の持主だったのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "暴君の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七十一回　侍従医の推挙宮中の佞臣　その後前代法王の事などを私の寄寓して居りました前大蔵大臣から聞いて見ますと、涙のこぼれるような事がある。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "「哀」というおくり名があつたほど気が弱くて、佞臣を退けることが出来なかつた人である。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　進藤主計は冷酷な人間として定評があった、奸譎な佞臣とさえ云われた。",
              "citation": {
                "source": "晩秋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂本、渡辺、畑、宮本の四人が、家中の一部から佞臣といわれていたのは事実らしい。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "佞臣どもや獄卒どもをはげませ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佞臣、懲らすべし」　と、一部に義憤の声のあるのは、そのためである。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、佞臣ばらに眼にもの見せてくれん）　彼の大音声に驚いて、次々と出て来た者、六、七名まで斬り伏せられた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "長坂長閑、跡部大炊などが、勝頼を陥しいれた佞臣という云い伝えは嘘である。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の綱吉将軍や大奥や佞臣閥や妖僧などのむらがりのように、下層社会を犠牲にはしていない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの十｜常侍などいう佞臣の端くれだろう。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん媚態派の佞臣からである。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "佞臣の甘言は、若い主君の弱点をついた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり姜維は、面を冒して、諫奏幾度か、「佞臣を排されたい」　と、劉禅の賢慮を仰いだ。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            },
            {
              "text": "義貞と自分との、年来にわたる確執を述べ、つまるところ、このようなはめになったのも、ひとえに佞臣の讒口によるもので、その張本は義貞であるとし、「――願わくば、乱将義貞｜誅伐の勅許をたまわりたい。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに黙っていては、佞臣乱賊の汚名を義貞が自認しているものになる。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
