    "definitions": [
      {
        "index": 1,
        "gloss": "pressing clothes, etc. by placing them under the bedding while one sleeps",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "中学校へはいってからは、校規のきびしい学校でしたので、おしゃれも仲々むずかしく、やけくそになって、ズボンの寝押しも怠り、靴も磨かず、胴乱をだらんとさげて、わざと猫背になって歩きました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「兄さん、ズボンを寝押してあげようか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物は寝押しとか折畳みの手入れのない、外出着らしくないふだんの着物であり、洋服は余り着ていなかったようだ。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "通な人達からは※の腹と言われるピカピカの一張羅、それを寝押して夜昼オッ通して着ているらしく、部屋の中の調度も、田舎芝居の小道屋のようで、何となくケバケバしく見えます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "赤い痣",
                "note": "青空文庫"
              }
            },
            {
              "text": "女将が階下へ下りかける、階子口ですれ違いに、「ゲンコツぁん、お居やすか」「まだ寝んねおしいしまへんのん」　桃龍と里栄が入って来た。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝ子えな、もう寝んねおしか？",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　時ちゃんは、枕元の紅いシクラメンの鉢をそっと押しやると、簪も櫛も抜いて、「さあ寝んねおしよ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、おねんねおし。",
              "citation": {
                "source": "ごみだらけの豆",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よくまあ、ほねおしみをせずにふとったもんだ。",
              "citation": {
                "source": "白ヘビ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
