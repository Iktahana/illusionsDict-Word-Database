    "definitions": [
      {
        "index": 1,
        "gloss": "being still half asleep",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここで水を飲もうとすると、犬が盛に吠える、「誰だあ、やい」戸の中から寝ぼけ声が聞える。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅客が寝ぼけた顔をして、何事にも無頓着な様子で歩き廻つてゐる。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦れて幾たびか強く叩くと、小僧の寅次が寝ぼけ眼をこすりながら起きて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆様の御返事がございませんでしたので、寝ぼけながらあたりを見廻しましたけれど、婆様はいらっしゃらなかったのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は運動会だから、決して寝ぼけずにちゃんと自分で支度をして、みんなを驚かしてやろうとかたく決心をして寝ました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会があるよ」　太郎さんは、寝ぼけてはならぬと、寝床の中で考えはじめました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は寝ぼけていやしない。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「太郎さんはまだ寝ぼけているの。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして半熟先生ここに茫然として半ば夢からさめたような寝ぼけ眼をまたたいている。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『もう寝かけているところだ』と私はなぜか寝ぼけ声を使いました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お由はしずかに揺り起こして、半分は寝ぼけているような若い娘を寝床の上に起き直らせると、かれの黒い影は一方の鼠壁に細く揺れて映った。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゆうべも九つ（午後十二時）を合図におせきの寝床へ忍んで行って、寝ぼけてぼんやりしているのを抱き起して、うちの人が蝋燭をかざしてみると……壁には骸骨の影が映って……。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ぼけた眼で下から見たら、首がするする伸びてるように思うやおまへんか。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、ただ今、靴をはいているところで……文ちゃん、何を寝ぼけたことか、こんなに早々と、おホホホ……。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "……貴様は夜中に寝ぼけたり、小便を垂れたりしはしまいナ」　私は黙ってうなずいた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "序に寝ぼけ眼で店の柱時計をふり返って見たら午前七時十分前であった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お諏訪様は、其処にいるのだよ、蟹を伴れて来ているのだよ」「何処におる、この寝ぼけ小僧」　林田が叱りつけるように云って前へ一足出た。",
              "citation": {
                "source": "放生津物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、李太郎は寝ぼけ声で答えたが、やはりすぐには起き上がりそうもなかった。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おかしいぞ）　しかし、道夫はそんなことよりも早く下宿へ帰って、寝ぼけている婢にはかまわず、台所から酒を持って来て己で燗をして飲みたかった。",
              "citation": {
                "source": "馬の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っ張ってもじゃもじゃの赤毛を取り外すと、そこに、寝台に起き直ったのは、青白い悲しげな顔の、品のある男で、黒髪につるつるの肌、目をこすって寝ぼけて戸惑いながらもホームズの方をじろじろと見る。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翁は枕頭に坐った女房に揺り起されてやっと眼を覚したが、眠くて眠くてしかたがないので、伸ばした右の手の手首を左の指端で掻きながら寝ぼけ声を立てた。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ起きたばかりで半分寝ぼけているお滝には、何がどうしたのか判らなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所近辺の人々は寝ぼけ眼をこすりながら、われ先にと羅生門横町へ駈けつけると、彼等をおどろかす種がまた殖えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きろ、起きろ」　二、三度呼ばれて、多吉は寝ぼけまなこをこすった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうす暗いなかに更にうす暗い二つの影が、まぼろしのように浮き出しているのを見つけた時に、紋作は急に寝ぼけ眼をこすった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方お前の寝ぼけ眼でなにかを見ちがえたのであろうと、冠蔵も始めのうちは唯わらっていたが、水右衛門の人形の額にゆがんだ打ち疵のあとを見つけると、彼は顔の色を変えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "むむ、寝ぼけ眼でか」「寝惚け眼でも猿まなこでも、おれが見たと云ったら確かに見たんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今こんな忌な夢をみたから、息子の部屋へ行って様子をみて来ましょうか」「よせ、よせ」と、王は寝ぼけ声で叱った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれだけの事実でも、主人の寝ぼけている顔を洗うには十分の冷たい水であると彼は考えていた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度も三度も呼ばれて、綾鶴はようように寝ぼけたような声を出した。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
