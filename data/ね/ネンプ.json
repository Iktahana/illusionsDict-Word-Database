    "definitions": [
      {
        "index": 1,
        "gloss": "chronological record",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このように、故勾当の名も、その日記も、大正四年、正孫の葛原※氏が、その祖父君の遺業を、写真数葉、勾当年譜、逸話集等と共にまとめて見事な一本と為し、「葛原勾当日記」と銘題打って、ひろく世に誇示なされる迄は、わずかに琴の上手として一地方にのみ知られていただけのものでは無かったかと思う。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は、私が人名辞典やら、「葛原勾当日記」の諸家の序やら跋やら、または編者の筆になるところの年譜、逸話集、写真説明の文など、諸処方々から少しずつ無断盗用して、あやうく、纏めた故葛原勾当の極めて大ざっぱな略伝である。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外の年譜を調べてみると、鴎外はこの時、四十八歳である。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　略年譜作成にあたり、『日本の詩歌　3』（中央公論社）所収の上田三四二氏による年譜を参照させていただいた。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　略年譜作成にあたり、『小熊秀雄全詩集』（思潮社）に収録されている遠地輝武氏による年譜を参照させていただいた。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて水野仙子年譜によるとお貞さんは、明治二十一年十二月三日、福島縣岩瀬郡須賀川町に生れた。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に一九三一年迄の年譜が附されている。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて簡単に記されている年譜ではあるが、作家山本有三を理解する上には大切な役割を示している。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三一年で終っているその年譜の最後の項は次のように結ばれているのである。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川さんは、大学の制服の膝をきちんと座布団の上に坐って――確にあれは制服だったが、でも、大学を一体芥川さんは何年に出られたのかと思って、今、年譜を調べて見たら、大正五年七月英文科を卒業とある。",
              "citation": {
                "source": "田端の坂",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "如今以這篇年譜為最後工作。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十三歳だった藤村が最初の長篇小説「破戒」をかきはじめたのは明治三十七年で、年譜をみると、「日露戦争に際会した。",
              "citation": {
                "source": "作家と時代意識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "露伴の弟子となって露英という号で処女作「露分衣」という作品を『文芸倶楽部』に発表したのが三十六年と年譜に記されているのをみれば、それは俊子が十九歳ごろのことであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふ場合を書く時、一目に見わたしの付くやうに、私は平八郎の年譜を作つた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大塩平八郎年譜寛政五年癸丑（一七九三年）　大塩平八郎後素生る。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "附録二　著者年譜（但し逆編年順）大正十四年二月、「泣菫詩集」を上梓す。",
              "citation": {
                "source": "人及び芸術家としての薄田泣菫氏",
                "author": "薄田泣菫氏及び同令夫人に献ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "（これは勝峯晉風氏も「芭蕉俳句定本」の年譜の中に「洞の一字を見落してならぬ」と云つてゐる。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "十余年我が書き溜めし草稿のあとあるべしや学院の灰　作者の新訳源氏物語の出たのは與謝野寛年譜によると大正元年になつてゐるが如何ももつと前のやうな気がする。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前に書いた小伝にも根拠があって二十三と書いたのだが、この稿をはじめる時、あまり他の年譜を信じすぎて、自分の思いあやまりかと諸説にしたがい、末年を十九にとったために、年に無理が出来て来た。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "清の呉榮光の『名人年譜』にも、民國の張惟驤の『疑年録彙編』にも、すべて司馬遷の生年を登録してない。",
              "citation": {
                "source": "司馬遷の生年に關する一新説",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "年譜宮本百合子-------------------------------------------------------【テキスト中に現れる記号について】：入力者注　主に外字の説明や、傍点の位置の指定（例）けいれんがあらわれはじめた。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお話をもととし、それを自分の記憶で補ひながら、且つは手もとにあつた故人の著作を參照しつつ、いま假りに、堀がおほよその年譜を作成しておいたのである。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために年譜とは云ひながら、かういふ大ざつぱなものしか作成できなかつたことを遺憾とする。",
              "citation": {
                "source": "萩原朔太郎",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝには、たゞ年譜式に、彼女の一生の重要事項を列記して、讀者の參考に供するにとゞめることゝする――　父はパトリック・ブロンティ、愛蘭土の貧家の出、立志傳的苦學を續けて劔橋大學を卒業して牧師となる。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "解説",
                "note": "青空文庫"
              }
            },
            {
              "text": "清岡卓行については略年譜および一八七ページ（注）四参照。",
              "citation": {
                "source": "初期詩篇",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「余が言文一致の由来」は、改造社版「現代日本文学全集第十巻」「二葉亭四迷集」から抄録したもので、同集の年譜によると、この談話は――二葉亭のした談話の筆記で、明治三十九年五月の雑誌「文章世界」に載せられたものである。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "春のやの「書生気質」と矢崎嵯峨のやの作品　幾つかの年譜によると、「書生気質」は明治十八年から分冊として刊行され、十九年一月に完了した。",
              "citation": {
                "source": "言文一致",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、演劇年譜であるが、少壮篤学の士中田耕治君に、非常に骨の折れる草案を作ってもらい、山田肇君に校訂をおまかせした。",
              "citation": {
                "source": "『演劇』あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
