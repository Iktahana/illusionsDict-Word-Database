        "examples": {
          "standard": [
            {
              "text": "水族館で初めて猫鮫を見た。意外と動きが俊敏で驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本近海に生息する猫鮫は、特徴的な頭の形をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日のダイビングでは、海底の岩陰に隠れている小さな猫鮫を発見した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "併し、あの物凄い『猫鮫』だけは当館第一の怪物です。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "『猫鮫』みたいな醜怪なる化物を、この世で初めて、エミ子もお雄坊も見せつけられたのです。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛悪な形相の猫鮫、虎鮫が、血の気の失せた粘膜の、白い腹を見せて、通り魔の様にす早く眼界を横ぎり、時には深讐の目をいからせてガラス壁に突進し、それを食い破ろうとさえします。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
