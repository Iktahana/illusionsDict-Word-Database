    "definitions": [
      {
        "index": 1,
        "gloss": "cat (esp. the domestic cat, Felis catus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それかあらぬか、猫の瞳孔が紋むやうに、海は急劇に曇つて来て、今にも時化でもやつて来さうだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポマードは生え際ばかりに厚く塗つたくつてあつて、その太い首が動くたびに山猫か何かの感じがした。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶は雪のふる都會の夜にしづかな建築の家根を這ひまはるさびしい青猫の影の影記憶は分身のやうなものだ。",
              "citation": {
                "source": "記憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大風の吹く城の向うで化猫草の穗のゆらゆらとうごいてゐてなにものかかなしい追憶の敵が笑つてゐる。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンはまた猫が特別に好きであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "松江に居た時も焼津に居た時も、道に捨猫さえ見れば拾って帰り、幾疋でも飼って育てた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人と結婚して間もない頃、雨でずぶ濡れになった小猫を拾って帰り、その泥だらけのままの猫を懐中に入れて、長い間やさしく暖めていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで結構なんです」　言い終えたところは山猫の檻のまえであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山猫は青い眼を光らせ、脊を丸くして私たちをじっと見つめていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹はしずかに腕を伸ばして吸いかけの煙草の火を山猫の鼻にぴたっとおしつけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい猫脊で、とんとせむし、――君、ちょっと眼をつぶってそんなふうの男を想像してごらん。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこへ二階からドヤドヤドヤと降りて来た良子の義理の兄さんが、便所に行かうとして椽側に出ると、其処に猫の食べ物を入れてやるお皿が置いてあるのを見ると、お祖母さんの眼を怖い顔で見ながら、そのお皿を庭の方へ蹴り棄てた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　猫のお皿は一寸の間に、雨でキレイに洗はれて、真ッ白になつてゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お祖母さん、猫どーこ？",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍなんて、兎に角今の中学校なんかが猫のやうな善良さで押し通せる奴つたら、延膸が大脳の割合に発達してゐないで、大脳が一通り悪い意味のエゴイスチックな発達をした奴だ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「グランドに無雑作につまれた材木　――小猫と土橋が話をしてゐた　黄色い圧力！",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "２猫が鳴いてゐた、みんなが寝静まると、隣りの空地で、そこの暗がりで、まことに緊密でゆつたりと細い声で、ゆつたりと細い声で闇の中で鳴いてゐた。",
              "citation": {
                "source": "曇つた秋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人夫婦の外には二十二、三の息子らしい弱そうな脊の高い男と、それからいつも銀杏返しに結うた十八、九の娘と、外には真黒な猫が居るようであった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊屋の裾には黒猫が顔を洗っている。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが『猫』の寒月君の話を導き出したものらしい。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして杖にすがったまま辛うじてかがんだ猫背を延ばして前面に何物をか求むるように顔を上げた。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一望千里の滿洲の赤土の原、あかあかと夕燒にてらされ、ひとり馬で歩いて居る猫背の乃木將軍のすがたが、この眼に見えるのだ。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酉樣の熊手の裝飾、まねき猫、あんな幼い、悲しくやりきれないものを感じました。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波うつ毛の猟犬見えなく、猟師は猫背を向ふに運ぶ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが猫眼石のように、慌だしく変る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、猫入らずまで混ぜてあったのだが、兎に角私は、滅茶苦茶に甘いものに飢えていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "セコンドメイトの猫入らずを防ぐと同時に、私の欺され易いセンチメンタリズムを怒鳴りつけた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも母のきものをなほしたねんねこだつたからそれよりずつとむかし、明治二十年前後の織物だつたかもしれない。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのねんねこで若いきれいな守女におぶさるのがうれしかつた。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
