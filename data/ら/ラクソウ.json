    },
    "definitions": [
      {
        "index": 1,
        "gloss": "coming up with an idea",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "御寺に光を放たせて、都の上に照りわたらしむるは、いとめでたき意匠にて、コルレジヨオが不死の夜の傑作も、これよりや落想しつるとおもはる。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "『石彫獅子の賦』は、大阪横堀に近い、何とかいふ町の石彫工塲で落想を得た作品でした。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつかしく云えば落想とでも云うのかなあ。",
              "citation": {
                "source": "里芋の芽と不動の目",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画には落想の滑稽な漫画がある。",
              "citation": {
                "source": "近藤浩一路氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "名高い自殺｜倶楽部の話なぞも、ステイヴンソンがあの落想を得たのは、誰かが見た夢の話からだと云ふ。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "文人は年を取るにしたがって落想が鈍くなる。",
              "citation": {
                "source": "田舎",
                "author": "マルセル・プレヴォー　Marcel Prevost",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに面白い女か、どんな途方もない落想のある女かと云うことが、段々知れて来るのである。",
              "citation": {
                "source": "世界漫遊",
                "author": "ダウィット　Jacob Julius David",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に實行とならぬ思想は無價値だと云ふ主張が、單に力――心理的の力である物理的社會的の效果を惹起す可き力ではない――力のない思想、遊離せる思想、空華なる落想を拒斥するだけの意味ならば、固よりその主張は正當である。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の考察は、白鳳天平の仏菩薩像を眼中に置いて、これらの像の作者がいかなる人体の美を生かせて彼らの「仏」と「菩薩」とを創作したかについての、一つの落想から出発する。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなく形而上学（従って又観念論）をこう規定することは、唯物論の歴史に於ては決して新しい着想や落想ではない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代に於ける唯物論をシェーラーやヤスペルスの落想哲学と並置するのに較べれば、之を現代の日本主義と並置する方が、まだしもコクのある真面目な見解なのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "この労作の蓄積とその方向とを無視して、徒らに、思い思いの落想のように、日本文化のあれこれの探究（？",
              "citation": {
                "source": "科学的精神とは何か",
                "author": "――日本文化論に及ぶ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "週刊との執筆契約は、終戦直後のことだし、「新・平家」の落想とて、つい近ごろの機会主義な外国の都合だの、日本政府の日和見から出たケチくさい応急策などよりは、ずっと以前に熟慮もして書き始めたつもりである。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう際涯のない考えなども、各地の平家部落など訪ね歩いているうちに、自然、自分の胸中に落想されてくるもので、われながら、時には、自分の欲望と構想の果てなさを、余り丈夫でない肉体と一しょに、持て余してしまう思いがする。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく秋成は西行と同じように、白峯へのぼり、崇徳院の御陵をとむろうて、保元、平治のむかしを松風に偲び、そしてあの好短篇を落想したのではあるまいか。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヘルン夫妻の奇妙な会話が、おそらくそういう種類のものであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『吹くのが面白いものだから、自分でわざと火を消しては、やたらに吹いた』と、夫人が追想談で話しているが、おそらくそういう場合、ヘルンの筆が行き渋り、感興が中断した時であったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『立像』の詩はおそらくそういう風な、常套の言葉で現わしにくいものを表現しようと狙っているのではないかという気がしました。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それらの一つ一つの各作家に於いても、あまりに重要でない作品に対して吟味を与えることは、恐らくそう必要ではなかろう。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在がそうであり、未来もおそらくそうであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして忙しい蜜蜂はおそらくそういう注文者を笑ったりそしったりする暇すらないであろうと思われる。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと南のほうの損害のひどかった町村ではおそらくそう急には回復がむつかしいであろうが。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしここでもわれわれが、あるいは私が、テンポのゆるやかすぎると感じるところは、ロシアの農民の多数にはおそらくそうは感じられないであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの上に多大の苦心をしていわゆる立体映画がようやく成功したとしても、その効能はおそらくそう顕著なものではあるまいという気がする。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しばらくそうしていらっしゃい。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは先生も笑いながら、ま、あなたがそう思っているのなら、しばらくそうしておきましょう。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "故芥川龍之介の自殺については、色々な動機が臆測されているけれども、或る確かな一説によれば、あの美的観念の極度に強い小説家は、常に自分の容貌のことばかり気にして、老醜を曝すのを厭がっていたということだから、あるいはおそらくそうしたことが、有力な動機になっていたかも知れないのである。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくそうさしといて、やがて景子が口に出して声をかけようとする時、宮坂は眼をポックリ開いて、さも決心したらしい顔付きで言った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おそらくそうであるかもしれず、そうでないかもしれないよ、ドクトル」と、彼は言った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おそらくそうだろう、ワトソンくん。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
