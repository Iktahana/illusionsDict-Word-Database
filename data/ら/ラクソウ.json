[
  {
    "uuid": "1f4a8eba-2d7c-5b2b-a625-7463de8c1b24",
    "entry": "落想",
    "reading": {
      "primary": "らくそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
