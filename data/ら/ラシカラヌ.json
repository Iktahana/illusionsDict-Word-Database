        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "プランクはこの人に対していつもわざとらしからぬ敬意を表しているように見受けられた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりＳの性癖にまで、何かの貴族組らしからぬ、肌の合はないものがあつたのである。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍らしからぬ冬野のさま、取り出でゝ云ふべくはあらねども、折からの我が懐に合ふところあり。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は利得の故に教会に結び、或は逆遇に苦しみて教理に帰依す、是の如きは今日の教会にめづらしからぬ実状なり。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車が七個所の引込線中の一に進入したるやも知れずとの考えは、おそらく最高の程度において事実らしからぬことなり。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "従て吾人は、この「事実らしからぬこと」を次の三引込線に帰せんとするものなり。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは事実らしからぬことに見えて、実は決して事実らしからぬことにあらず……………吾人はここに確信をもって会社に忠告し、もって、会社が該引込線と、その終点に働く労働者等につき、全力を傾注して探査せんことを希望するものなり云々。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに伊太利の澤池にめづらしからぬ藁小屋一つあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさに思ったことが、『あれは、回路上オレの頭の中にはいっているもの以外いらねエ』（笑）」　だが自らの才能を思う存分ふるって計算機の設計に取り組んだ池田は後に、コンピューターの開発にあたって自由な発想を封印するという最も池田らしからぬ選択を行なった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、人間らしからぬ生活に追いまくられていることを知っていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女は、全く、どの患者にでも、兄妹のように、わざとらしからぬ親切さでもって、接するんだ！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊楠案ずるにスエーデンで同心結（コンヌビァル・ノット）を結ぶ内、新婦が婿より前に進みまたわざとらしからぬように手巾を落すと婿が拾ってくれる。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つの奇遇をわざとらしからぬやうに表現する技倆もなければ、友人の妻もはつきりと描かれてゐなかつた。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その象眼は、何と云う女らしからぬ、鋭い意匠だろう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母の貴婦人らしからぬ言葉遣いが、美奈子の心を傷ましめた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は色々な人間らしからぬ別のものになる虞れがある。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじっか知識階級の家などは、出入や室の中を一眼見ただけでも、其処に「世の常の人」らしからぬ空気を鋭敏に感じてしまうからである。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その象眼は、何と云ふ女らしからぬ、鋭い意匠だらう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母の貴婦人らしからぬ言葉遣ひが、美奈子の心を傷ましめた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六といふ齡には少し老せて居るが、限りなき愛嬌を顏一杯に漲らして、態とらしからぬ身振が人の氣を引いた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六といふ齢には少し老せて居るが、限りなき愛嬌を顔一杯に漲らして、態とらしからぬ身振が人の気を引いた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "智恵子は其手を口の辺へ持つて来て、軽く故意とらしからぬ咳をした。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "智惠子は其手を口の邊へ持つて來て輕く故意とらしからぬ咳をした。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃の彼は、敢て珍らしからぬ「ものの道理」が、實生活のなかで、一つ一つ確認されて行くのを見るとき最も感動し、新鮮な喜びを感じるのであつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞かぬ氣で考へたことをぢつと腹に持つてゐるといふやうなところがあるが、それも何かギスギスした少女らしからぬものに支へられてゐるといふのでは無い。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白さが読者大衆から要求されているということを、すぐエロティックなものだのチャンバラだの、くすぐりと見なすのは大衆の感情そのものを実際知らないものであるし、作家らしからぬ粗笨さである。",
              "citation": {
                "source": "今日の文学に求められているヒューマニズム",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "贈らん誰に」と女は態とらしからぬ様ながらちょと笑う。",
              "citation": {
                "source": "一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸ツ子よばはりをして江戸ツ子らしからぬ処は岩野清子氏と同じです。",
              "citation": {
                "source": "妾の会つた男の人人",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞食にも見放された家、さういふ家がある、それは貧富にかゝはらない、人間らしからぬ人間が住んでゐる家だ、私も時々さういふ家に立つたことがある。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
