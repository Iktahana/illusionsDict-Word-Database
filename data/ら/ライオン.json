    "definitions": [
      {
        "index": 1,
        "gloss": "lion (Panthera leo)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
