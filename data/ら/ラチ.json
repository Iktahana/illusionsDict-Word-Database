    "definitions": [
      {
        "index": 1,
        "gloss": "bare ground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この草には別にこれといって目だった特徴もなく、ただ温室の床の裸地を隠すために植えてあったのでした。",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう茅処続きで、所どころに表土を鋤き取ったのではないかと思わせるような、黒い地肌を露した可なり広い、小石交りの裸地がある。",
              "citation": {
                "source": "初旅の大菩薩連嶺",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有難かったのは、標高千五百メートル以上の高山性裸地帯の積雪である。",
              "citation": {
                "source": "雪は資源である",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸地の広場が現れた。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる無地裸地の焼物を深く見詰めるのは「日本の眼」の一つの特徴といえる。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）５　私が彼を訪問した時、私が訴へんとするすべてのことを、彼は前からちやんと知つてた。",
