[
  {
    "uuid": "ee77e81e-8f83-50b4-a3db-367a99f3dc0e",
    "entry": "拉致",
    "reading": {
      "primary": "らち",
      "alternatives": [
        "らっち"
      ],
      "is_heteronym": false
    },
    "grammar": {
