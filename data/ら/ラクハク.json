[
  {
    "uuid": "48d3ae0e-c39b-58c9-8610-587d4afd6b32",
    "entry": "落魄",
    "reading": {
      "primary": "らくはく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
