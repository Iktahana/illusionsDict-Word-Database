      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being reduced to poverty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人事みな落魄して、心烈しき飢餓に耐へず。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落魄れた館へ帰って行った、　二三日経って女はまた湧玉の水のほとりで、男と会った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幼い時よくそれを口に入れては父母に叱られたものだが、その幼時のあまい記憶が大きくなつて落魄れた私に蘇つて來る故だらうか、全くあの味には幽かな爽かな何となく詩美と云つたやうな味覺が漂つてゐる。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを見ながら、落魄した男の姿を感じた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人品が好くって、痩っこけて、心配のありそうな、身分のある人が落魄たらしい、こういう顔色の男には、得て奇妙な履歴があるものです。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人は苦と身悶えして、仰向に踏反返り、苦痛の中にも人の深切を喜びて、莞爾と笑める顔に、吉造魂飛び、身体｜溶解け、団栗眼を糸より細めて、「夫人、こりゃ是非お助け遊ばせ、きっといい人の落魄たんです。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして些と娘の方を見て、「ですから私等も、一とつ頃は可成に暮してゐたものなんですが、此う落魄ちや糞ですね。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と少し苛々したやうな調子で、「あゝ孤獨と落魄！",
              "citation": {
                "source": "虚弱",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな季節のながいあひだぼくの生活は落魄してひどく窮乏になつてしまつた家具は一隅に投げ倒され冬の　埃の　薄命の日ざしのなかで蠅はぶむぶむと窓に飛んでる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな季節のながいあひだぼくの生活は落魄してひどく窮乏になつてしまつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一旦兄さんがつまらない心を起して返り討ちにあつてから、落魄の一途を辿りはじめた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "リサは子供っぽい詩と罵ったが今の自分としてはどうしても巴里祭の人込みの中で、ひょっとしたら十何年目のカテリイヌ――恐らく落魄しているだろうが――にめぐり遇っていつか自分を順致して奴隷のようにして仕舞った巴里に対する憎みを語りたい。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "色｜蒼く垢じみて、筋で繋いだばかりげっそり肩の痩せた手に、これだけは脚より太い、しっかりした、竹の杖を支いたが、さまで容子の賤しくない落魄らしい、五十｜近の男の……肺病とは一目で分る……襟垢がぴかぴかした、閉糸の断れた、寝ン寝子を今時分。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "落魄れた華族のお姫様じゃと言うのもあれば、分散した大所の娘御だと申すのもあります。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "作意で略其の人となりも知れよう、うまれは向嶋小梅業平橋邊の家持の若旦那が、心がらとて俳三昧に落魄れて、牛込山吹町の割長屋、薄暗く戸を鎖し、夜なか洋燈をつける處か、身體にも油を切らして居た。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺の身元は巷のベッガーでね、」すると賢夫人も気さくに笑って「えゝ／＼また落魄れたらいつでも二人でお菰を着て門に立ちますよ」。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとかしたらわたくしはこのまゝ落魄れて、川のほとりに乞食女となってしまおうかしらん。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六国の相印を一人の身に帯び車駕の数は王者を凌ぐと称せられて居た合従の策士蘇秦は日に日に落魄の運命に陥り新に秦の宰相であり連衡の謀主である張儀の勢力が目ざましく根を張って来た。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れぬ風土の寒風はひとしおさすらいの身に沁み渡り、うたた脾肉の歎に耐えないのであったが、これも身から出た錆と思えば、落魄の身の誰を怨まん者もなく、南京虫と虱に悩まされ、濁酒と唐辛子を舐めずりながら、温突から温突へと放浪した。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども自然は吾人をして「失望落魄」の極、遂に甘んじて自然の力に服従し了するまでに、吾人を困窘せしめざるなり。",
              "citation": {
                "source": "人生に相渉るとは何の謂ぞ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "吁、当年豪雄の戦士、官軍を悩まし奥州の気運を支へたりし快男子、今は即ち落魄して主従唯だ二個、異境に彷徨して漁童の嘲罵に遭ふ。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "在郷の同志が、身動きもならぬ程貧乏し、落魄している顔付きを思い出すに連れて、十円もする帽子を大得意で帰って来る自分の心理状態が恥かしくて、たまらなくなりましたから、汽車が博多駅に着く前に折畳んで懐に入れて、知人に会わぬようにコソコソと只今帰って参りました。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも睾丸にシラミが湧いたから剃るのだ……といったような事を話していたから、余程、落魄して帰って来たものであったらしい。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝるなりはひする女子の習として、財を獲ること多しといへども、隨ひて得れば隨ひて散じ、暮年の計をおもはねば、その落魄もいと速なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "作意で略その人となりも知れよう、うまれは向嶋小梅業平橋辺の家持の若旦那が、心がらとて俳三昧に落魄れて、牛込山吹町の割長屋、薄暗く戸を鎖し、夜なか洋燈をつける処か、身体にも油を切らしていた。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十九　それもしばらく、米屋町は米の上り下りで人間の相場が狂い、妾宅の主人は大失敗で、落魄して、最後に一旗という資本がないので、心まで淋しくなり、蝶吉の母に迫って、その落籍しただけの金員耳を揃えて返せという。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　お冬は武家の出で、本所に落魄れた旗本か、ごけにんの血を引いている。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　妨害運動　これより先、郷里の両親らは福田が渡韓の事を聞きて彼を郷里に呼び返すことのいよいよ難きを憂い、その極｜高利貸をして、福田が家資分産の訴えを起さしめ、かくして彼の一身を縛り、また公権をさえ褫奪して彼をして官途に就く能わざらしめ、結局｜落魄して郷里に帰るの外に途なからしめんと企てたり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し養家の落魄は痛く私を悲ましめました。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "落魄の身を故郷に曝すことが堪へなかつたのと、一つは私を見ることの機會があるといふ心の慰藉があつたからであります。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
