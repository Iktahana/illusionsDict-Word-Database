    },
    "definitions": [
      {
        "index": 1,
        "gloss": "scholar of Western sciences (by means of the Dutch language; during the Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は昔の日本の蘭学者のエレキテルなどというような言葉を思い出して覚えず微笑せずにはいられなかった。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして日本の維新の思想が、日本の一群の蘭学者に依って、絶大の刺戟を受けたという事実を知った。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治維新史に依ると、当時の蘭学者の大部分も医者であった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、明治の御維新は決して蘭学者たちに依って推進せられたのでは無い、と言いはじめた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴司山治氏の戯曲「洋学年代記」には、学者としての良心と達識とのために国法にふれた幕末蘭学者の一群と間宮林蔵の運命とが扱われた。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚質の母は蘭学者前野｜良沢憙の女である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の蘭学者は和漢の学力を以て蘭書に臨まなくてはならぬと云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛軒は先づ桂川桂嶼と所見を同じうして、晩出蘭学者の飜訳書に由つて彼邦医方の一隅を窺ひ、膚浅粗漏を免れざるを刺つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧藩時代からの蘭学者の家柄とか申しておりましたが」「ウムウム、中々の物識りという話じゃが、あの男がこの間、避病院の落成式の時にこげな事を話しよった。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が自分で不便利を感ずる通りに、今の蘭学者は悉く不便を感じて居るに違いない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台藩の留守居役を勤めて居た大童信太夫と云う人があって、旧幕府時代から私はその人と極、懇意にして居ました、と云てその人が蘭学者でもなければ英学者でもない、けれども兎に角に西洋文明の風を好み洋学書生を愛して楽しみにして居る所は、気品の高い名士と申して宜しい。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭学者がその始め蘭書を翻訳したときの困難は勿論非常なものであったが、明治の初年における法政学者が、始めて法政の学語を作った苦心も、また実に一通りではなかった。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "本草学者か発明家か、それとも山師か蘭学者か？",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃肥前長崎に、平賀｜浅草という蘭学者があった。",
              "citation": {
                "source": "柳営秘録かつえ蔵",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕末に、オランダ語の自由といふ語が初めて飜訳の必要にせまられた時、当時の蘭学者は訳語に窮したばかりでなく、自由とは何か、その意味からが判らなかつた。",
              "citation": {
                "source": "私の小説",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鷹匠ばかりでなく、三宅侯の邸内にはあの画技に勁烈な意気と共に軽妙な写生の一面を拓き、現実に早くから目を醒ましていた蘭学者の渡辺崋山が住んでいたのである。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "箕作阮甫、杉田成卿なぞの蘭学者を中心に、諸人所蔵の蕃書の翻訳がそこで始まっていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な蘭学者の宇田川榕庵先生は、彼の著『植学｜啓源』に、「花は動物の陰処の如し、生産｜蕃息の資て始まる所なり」と書いておられる。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで土井利位の仕事も、蘭学の系統に属していたにはちがいないので、当時既にかなりすぐれた蘭学者であったところの泉石の助力がよほどあずかって力あったものと考えられるのである。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きいて見ると、泉石は家老として非常にすぐれた人であったばかりでなく、蘭学者としても立派に一家をなしていたらしい。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその時代に古河藩の河口信任なる蘭学者がいて、泉石はその系統であった。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから見ても河口信任が蘭学者としてかなり非凡な人であったことが分るが、その門下の泉石の蘭学も、相当に進んだものであった。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の一般の蘭学者は、多くは医家であって、医書を通じて外国の事情を知り、国を憂うるに至った人が多かったが、泉石は家老の家に生れ、若い時から北辺防備に思いを致して、その故もあって、蘭学を学んだものと思われる。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹見家にも、達夫児様という宛名の手紙があり、和蘭学者との文通の手紙も沢山遺っている。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけても、江戸の蘭学者たちの力はどれほどのものであろうか、それをしっておきたいとおもいました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、島村鼎甫という蘭学者をたずねてみました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所割り下水、もと御典医の蘭学者｜相良玄鶯院の隠宅方来居で、水藩高橋一派の会合があるという。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭学者｜新宮凉庭が、長崎から帰って、ここに順正書院という塾を開いたとき、自分が先に立って弟子たちといっしょに加茂河原から石を運んで、流れや池を造ったのだという。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる（二字不明）多で、新思想を導いた蘭学者にせよ、局面打破を事とした勤王攘夷の処士にせよ、時の権力からいえば謀叛人であった。",
              "citation": {
                "source": "謀叛論（草稿）",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
