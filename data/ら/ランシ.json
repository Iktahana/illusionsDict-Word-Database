    },
    "definitions": [
      {
        "index": 1,
        "gloss": "astigmatism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おれは乱視だから仕方ないさ。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（あっ、ああ、なる程乱視。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱視とか聞いたが、あの目にちよつと魅力がある。",
              "citation": {
                "source": "彷徨へる",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、軽い乱視眼であるせゐか、稍ともすると削りたつたやうな神経の嶮しさが露骨で、感情的だつた。",
              "citation": {
                "source": "裸虫抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの斜視や乱視や色盲のような見方をして、錯覚や幻覚を起こしている連中は、いずれも皆「顛倒の衆生」であります。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "老眼、近眼、あるいは乱視といって物がいくつにも見える。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼は近くなり乱視の状態にまでなりましたが、私は毎日図書館通いをして乱読暴読しました。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそんなことが気になりだしたか、自分でもよくは覚えてはいませんし、またあたしは、近眼に乱視なので、遠くがよくみえませんけれど、たしかに、物影からあたしの方をじっと見てる人があるんです。",
              "citation": {
                "source": "千代次の驚き",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し小首を傾げ、乱視めいた眼付で、口をとがらした、その笑顔は、昔の通りだった。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして対座していると、次第に、彼女のとがった口付に愛嬌が出て来、乱視めいた眼付に色艶が出て来て、それと共に、太い頸筋が目立ち、しゃがれた声がなおかすれて、この二三年すっかり堅くしてるという、その肥った世帯じみた様子に、何か濁った汚ならしいものが浮んできた。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから幾年になるかしらと云って、胸の中で指折り数えて、この頃あなたのことをよく思い出すわと、乱視めいた眼で昔のような可愛い笑い方をした。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "額のせまい、丸顔のたちで、美しくはありませんが、歯がきれいで、そして何よりも、眼が……黒目のうわずった、見つめると近視か乱視めいた愛嬌をつくって、変に妖しい色をおびてきます……。",
              "citation": {
                "source": "肉体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、目が悪いから、目のところへかう捧げてクッツケないと見えなくて危いからですよ」「乱視だな。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして近眼で乱視だと……。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い入り組んだ小路、小さな硝子の小窓から至る処に覗いてる無数の女の顔、物に憑かれたように飄々とうろついてる多くの男の影、その中にあって、軽い斜視の……近視の……乱視の……彼女の眼は、一種の美を持っていた。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて出て来たナポレオンはというと、低い鼻のうえに、コン吉の乱視の眼鏡がかけられてあったのである。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "乱視の奈翁　――アルル牛角力の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして強度の乱視となった。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼賀川市長は強度の不時症乱視患者である。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人に近眼と乱視の多い理由を、日頃から文字のタテヨコの混乱が影響しているのではないかと思います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも揺れながら子供のうちからものをよんで乱視になったらしいから）読まず。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の方はやっぱり 2.0 でいいというわけで、もとのしらべでは左右同じな度に少し乱視の度がついていて、右が 0.5 左が 0.25 ついていたの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その乱視の度はとってしまって、単純な近視 3.0 と 2.0 となったわけです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眼の方は、きょう左の方に乱視の度の入っているのを入れかえて見ました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり右の方にだって、乱視の度がなくては、きっと害があると思いますし、その変化は、やはり前に見て貰った人にたのむ方が比較されていいわけですから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして眼鏡も度が測定出来て左が 2.5 の近視に 0.5 の乱視。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "右が３の近視に 0.5 の乱視ということです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のレンズは３ですが乱視はついていないの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は眼は近眼だの乱視だので、去年みたいなさわぎもいたしますから、随分大切にしています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ普段から左右がチンバな乱視で困っていたから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し、体全体が恢復したら、目の方の検査もして、恐らく、乱視の度が進んだでしょうから、それをはっきりさせます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
