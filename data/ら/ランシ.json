  {
    "uuid": "c6170b22-a623-5179-a241-c8a36734991f",
    "entry": "爛死",
    "reading": {
      "primary": "らんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
