[
  {
    "uuid": "ebe47129-7ee8-52de-ab3e-cd22ba7d5e59",
    "entry": "乱視",
    "reading": {
      "primary": "らんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
