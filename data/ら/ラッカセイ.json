        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "単に分析表を見て牛肉と落花生と営養価が同じだと云って牛肉の代りにそっくり豆を喰べるというわけにはいかない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも心は汚れてはゐなかつたので、榧の実の一つや、落花生の二つを、良寛さんの鉢の中へ入れてくれた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "水平に近く頃には、ちやうど八月の青草の中に一つ開いた落花生の花のやうな黄ろい燈をともしたのである。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ、南瓜も飛び出せ、牛蒡も踊り出せ、枝豆、隠元、ささぎ豆、なた豆、落花生に胡麻の種、莢がはぢけた、赤ちやけた、化猫、雉猫、かま鼬、粟が尻尾を黄に垂れた。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」新子が、重ねて注意をしようと思う間に、美和子はもう、バーテンからウィスキイの壜とリキュールと落花生とをのせた銀盆を、すまして前川の席へ運んで行った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　銀盆に落花生とカクテルとを載せて、運んで行くと、「貴女は？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "石を敷いた路の右側には白いアセチリン瓦斯の燈があって、茹卵や落花生を売る露店が見えていた。",
              "citation": {
                "source": "女の首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落花生の殻を投げることもある。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "落花生の殼を投げることもある。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "棉花を積んだ船、落花生を満載した荷船、コークス、米、石炭、粘土、籐、鉄材、それらの間に交って、フィリッピン材の紅と白とのラウアンが、鴨緑江材のケードルや、暹羅材の紫檀と競いながら、従容として昇って来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道路では一人の子供が、アスファルトの上で微塵に潰れている白い落花生の粉を、這いつくばって舐めていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖岸の平地には、果樹が植ゑられ、玉蜀黍、落花生、甘藷などがつくられてゐます。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて徐和が、水瓜の種と落花生とを盛った皿と、グラスを、銀の盆にのせて持って来ますと、曹新は彼を自分の横に坐らせて、ウイスキーをついでやりました。",
              "citation": {
                "source": "碑文",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の床には、水瓜の種の皮や、向日葵の種の皮や、落花生の皮や、梅の実の種や、鶏の骨などが、あたりに散らばり、また誰かが結婚式の残りのものを持って来たと見えまして、五色の切紙やテープが散乱していました。",
              "citation": {
                "source": "画舫",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "○バターには牛乳より製したるものと豚脂の如き動物性脂肪と落花生油の如き植物性脂肪を混じて製したるものと二種あり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "落花生が炙れて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「落花生は大好きですから、私が炙りましょう」と云うて女が炙ったのそうな。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "米も、落花生も作つて見たが、之は全然失敗に終つた。",
              "citation": {
                "source": "百姓日記",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼は、昨晩のうちに胃の腑へ収めた莫大な量の落花生と、同じく莫大な量の煙にした煙草と、これらが往々にして人間の頭に重大な影響を及ぼすといふことはもう、忘れた。",
              "citation": {
                "source": "四人",
                "author": "芥川多加志",
                "note": "青空文庫"
              }
            },
            {
              "text": "この支那人の躯と、反物包みと、伸子の手のひらにのせてくれた落花生の小さな支那菓子とからは、つよく支那くさいにおいがした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落花生｜喰ひつゝ読むや罪と罰十月十六日　発行所例会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落花生、さつま人参、朝鮮茄子、葡萄、蓴菜、そのほか薬草、食糧、染料などの資になる植物などもみな、老公が学問を学問するに止まらず、農民の生活と、藩の生産を考え合せて、実政策に具現したものであった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦も粟も唐芋も落花生も砂糖黍も食う。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし嘉治さんは紳士だし、杉本画伯は賤しからざる風貌だし、Ｏさんは優等生タイプときているので、中に挟まって、落花生も食べにくい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
