    "definitions": [
      {
        "index": 1,
        "gloss": "llama (Lama glama)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに、ラマルチーヌの、サント・ブーヴの、モンモランシイの、レカミエ夫人の、ミシュレの友情を招来したのだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "高原地方のアトモスフィアを、これほど鮮明に、印象強く、しかもパノラマ的展望で書いた俳句は外にない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面の視野が広く、パノラマ風であり、前に評釈した夏の句「鮒鮓や彦根の城に雲かかる」などと同じく、蕪村特有の詩情である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が初めて讀んだド氏の小説は、例の「カラマゾフの兄弟」であつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにはまたカラマゾフ以上に感激させられた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パノラマ館には例によって人を呼ぶ楽隊の音面白そうなれば吾もまた例によって足を其方へ運ぶ。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西郷像の方へ行きたれども書生の群多くてうるさければ引きかえしパノラマ館裏手の坂を下る。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も陳列所前の砂道を横切って向いの杉林に這入るとパノラマ館の前でやっている楽隊が面白そうに聞えたからつい其方へ足が向いたが丁度その前まで行くと一切り済んだのであろうぴたりと止めてしまって楽手は煙草などふかしてじろ／＼見物の顔を見ている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の雨でぐじゃぐじゃになった新開街路を歩いているとラジオドラマの放送の声がついて来る。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果を一九一〇年に発表したが、彼の説は後にラマン等の研究によって訂正された。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラマンク張りの絵が沢山出ている。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴォアラ、ネスパ、セッサ、ムシュー、アラマディ、プレンプアン、ラタヽパン。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近の米国雑誌によれば、この種の測量にパノラマ写真機を用うれば最も簡便だという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地の事は少しも分りません、早慶戦でＫＯが勝った事を一週間ばかり前に同盟通信のカメラマンに聞きました。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドラマチカルでないと云うのですよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球の地下室では切開された、メロ・ドラマの開演のベルがけたたましく鳴りひびくのだった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび、都会がパノラマのように彼女の眼前に展けてきた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、淫書の扉がひらくと、濛々とした紫煙のなかの客間から、現実の微細な享楽地帯が眼前にパノラマのようにあらわれた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの卓子の一隅にはパラマント・オン・パレードで男前を見せたかのマツイ翠声がお可笑な顔をしてスープをすすっていた。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあまりたいした成効とは思われなかったが、しかしともかくも人間のドラマのシーンの中間に天然のドラマの短いシーンをはさんで効果を添えるということは、従来よりももっともっと自由に使用してよいわけである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラマウント・ニュースのようなものの組み合わせは場合によっては、偶然ではあるが、前述の連句的の効果を持ちうる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カワラマツバの小さな四弁花は弁と弁との間から出た雄蕊がみんな下へ垂れ下がって花心から逃げ出しそうにしている。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍事連鎖劇キネオラマ、　　寒天光のたゞなかに、　　ぴたと煙草をなげうちし、上等兵の袖の上、　　また背景の暁ぞらを、　　雲どしどしと飛びにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ぐろとした杉林がパノラマのように廻って私の行手を深い闇で包んでしまっている。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家はこの方角だ」　自分は友人と肩を並べて、起伏した丘や、その間に頭を出している赤い屋根や、眼に立ってもくもくして来た緑の群落のパノラマに向き合っていた。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このパノラマ風の眺めは何に限らず一種の美しさを添えるものである。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "末遠いパノラマのなかで、花火は星｜水母ほどのさやけさに光っては消えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海と雲と平野のパノラマがいかにも美しいものに思えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子供といい、そのパノラマといい、どんな手品師も敵わないような立派な手品だったような気がした。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
