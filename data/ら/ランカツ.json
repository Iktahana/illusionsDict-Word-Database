          "literary": [
            {
              "text": "殊に卵割のとこなど面白かりし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "此にも母様は少し口籠つておいでゝあつたが、（鳥ぢやないよ、翼の生へた美しい姉さんだよ）何うしても分らんかつた。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『さうすると貴殿は小學校以外の教育はお受にならんかつたのですか。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治が、黨派と黨派との爭ひだといふことぐらゐ、何ぼわしかて知らんかつたわけではないが、わしは何ものにも掣肘されたくなかつたし、それに社會の大多數の常識の上に立つてゐる自分は、たとへ一人でも事を行へぬ筈はないと考へてゐた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉野の家にあんたのやうな息子さんがあるとはついぞ知らんかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は最初、あまりいゝ顔をしとらんかつたぢやないか？",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と袋をかぶつて踊つてゐる姿を認めて、ノコノコ近付いて来て見てゐる）あれえ、こん爺さんだよう、篠町からこつち車の後さぶら下つちや、賃金半額にしろと云ひ通してとうどう乗らんかつた人！",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
