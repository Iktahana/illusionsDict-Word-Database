          "literary": [
            {
              "text": "武田の滅びた天正十年ほど、徳川家の運命の秤が乱高下した年はあるまい。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "米と株券と商品の相場は、刻々に乱高下している。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "時によって乱高下があるという大蔵大臣の説明であります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "物品によっては時に値段に乱高下ありまた値段の定まらんような物もありますから、なかなか統計を取るのがむつかしいです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
