          "literary": [
            {
              "text": "藤田画伯は生来仙人の趣があったが、伴氏はむしろアベコベの天性のように思われる。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方それは坊さまじゃからだろうというこってありますよ、あとからあとからとぶらいせんならんからのう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしくらいせんさくぎらいで、ひとのことに無関心なものはちょっとないであろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
