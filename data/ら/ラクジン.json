    "definitions": [
      {
        "index": 1,
        "gloss": "carefree person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ミニオンの伊太利人は、路傍楽人にならねばならぬのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏帽子直垂とでもいったような服装をした楽人達が色々の楽器をもって出て来て、あぐらをかいて居ならんだ。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔明治音楽界などの演奏会で見覚えのある楽人達の顔を認める事が出来たが、服装があまりにちがっているので不思議な気がするのであった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はこの前、ひとりでここへ来たとき、一つの夢を思い付いたのだ」　夢という言葉は慶四郎の口癖で楽人仲間では有名であった。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが天稟の楽人ならば、われも不羈の作家である。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その後当分の間、邯鄲の都では、画家は絵筆を隠し、楽人は瑟の絃を断ち、工匠は規矩を手にするのを恥じたということである。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口でちょっとためらい、ちらとそのあたりを見廻してから、「今日は」　と、はいって行くと、「おいでやす」　文楽人形のちゃり頭のような顔をして格子のうしろに坐っていた丁稚が、君枝の顔を見るなり、「電話のお方が来やはりましたぜエ」　奥へ向って、大声をだした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽部は小柄なわりに顔の造作が大きく、太い眉毛の下にぎょろりと眼が突き出し、分厚い唇の上に鼻がのしかかっていて、まるで文楽人形の赤面みたいだが、彼はそれを雄大な顔と己惚れていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "王族広間の上のはてに往着き玉ひて、国々の公使、またはその夫人などこれを囲むとき、かねて高廊の上に控へたる狙撃聯隊の楽人がひと声鳴らす鼓とともに「ポロネエズ」といふ舞はじまりぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "王族広間の上のはてに往き着きたまいて、国々の公使、またはその夫人などこれを囲むとき、かねて高廊の上に控えたる狙撃連隊の楽人がひと声鳴らす鼓とともに「ポロネエズ」という舞はじまりぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽部は小柄な割に顔の造作が大きく、太い眉毛の下にぎょろりと眼が突き出し、分厚い唇の上に鼻がのし掛っていて、まるで文楽人形の赤面みたいだが、彼はそれを雄大な顔だと己惚れていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "晋国の巡撫から十人の女の楽人を餽ってきた。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽人は殿上役人からも地下からもすぐれた技倆を認められている人たちだけが選り整えられたのである。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十人の楽人が吹き立てた楽音に誘われて吹く松の風はほんとうの深山おろしのようであった。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ宮廷付きの中でのよい楽人に参考になることを教えてもらいなどしただけです。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽人、十列の者もきれいな男を選んであった。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼうとぶきみにまたたいている燈明のあかりの下に、楽人たちの姿は見えるが、肝心の信者の姿は、舟で消えたあの女たちの姿は、ひとりも見えないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽人　建康に二人の楽人がありまして、日が暮れてから町へ出ますと、二人の僕らしい男に逢いました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽人らは一生懸命に楽を奏していると、もう酒には飽きたから食うことにすると言い出しました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも自分たちが飲んだり食ったりするばかりで、楽人らにはなんにも宛がわないのです。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜がしらじらと明ける頃に、この宴会は果てましたが、楽人らはもう疲れ切って、門外の床の上にころがって正体なしに眠りました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には楽人の資格を備えている種類もあった。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口へ行く、湯田で一浴、そして一杯、もつたいないことだ、私は「天下の楽人」であらうか！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽日の行楽人、善哉、善哉。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でそんなに息切らしてんのや」「走って来たんやわ」「なあ、ヘェ、桃龍はんちゅうたら、あての手無理こ無体に引っぱってどんどんどんどん走らはるのやもん……」　桃龍は、文楽人形のようなグロテスクなところがどこにかある顔で対手を睨むような横目した。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは楽人｜陳某に寄せる詩であった。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽人陳某は鞠問を受けたが、情を知らざるものとして釈された。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後二時に楽人たちが参入した。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になって楽人たちの退散していく時に紫の夫人付きの家職の長が下役たちを従えて出て、纏頭品の箱から一つずつ出して皆へ頒った。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
