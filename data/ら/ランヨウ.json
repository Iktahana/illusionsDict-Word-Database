[
  {
    "uuid": "14b3d856-d886-5ad1-a0a2-1d56d45929fd",
    "entry": "乱用",
    "reading": {
      "primary": "らんよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
