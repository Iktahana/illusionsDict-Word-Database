    "definitions": [
      {
        "index": 1,
        "gloss": "celebration of the completion of a temple or shrine's construction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
