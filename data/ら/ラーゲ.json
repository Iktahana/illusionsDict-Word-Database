        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゲメンゲラーゲさながらを、　　焦げ木はかつとにほふなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は東京の蘭国公使館書記官ステッセル博士の請に任せ、一九一〇年発行『フラーゲン・エン・メデデーリンゲン』へ出した拙稿の大意である。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本における外国文学翻訳の現状、プラーゲ旋風の不当、日本翻訳家協会設立等について各国代表の理解が求められたそうである。",
              "citation": {
                "source": "ペンクラブのパリ大会",
                "author": "――議題の抜粋についての感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、あなたのラーゲリでは音楽グループは、どんなことをしていたでしょう。",
              "citation": {
                "source": "結論をいそがないで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽に関する翻訳権問題は数年前の「プラーゲ旋風」の時に一応の国際基準がたてられた筈であった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私が日本に帰ってから、東京を始め日本で「お蝶夫人」をうたいますと必ずプラーゲという人が著作権のお金を取りに来る。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初プラーゲがどんな権利があってお金を取るのか判らないので断りますと、差押えをするといって脅かすのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んでみますとプラーゲに対する委任状で、それにはアントニオ・プッチーニと署名がしてあるのでびっくりしました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "シールケから間もなくエレント、それから間もなくブラウンラーゲを通つた。",
              "citation": {
                "source": "キフホイザー",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラウンラーゲの村を出ると、昨日から顏なじみの樅の樹林がまた道の兩側に黒黒と列んで、下の芝草も手入をしたやうに美しく、ブロッケンのやうに大きな岩石が散亂してないので、いかにも地貌の柔和な印象を與へられた。",
              "citation": {
                "source": "キフホイザー",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月九日　水「ラーゲリ・バウマニェツ」へ出かけて、十二時頃から夜七時頃までぶらついた。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その当時心理学といえば、ロッチェ、フォルトラーゲ、フォルクマンの著書論文のようなものがその主なるものであったとのことである。",
              "citation": {
                "source": "ヴィルヘルム・ヴント",
                "author": "川合貞一",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽壇人でも「プラーゲ旋風」と云う名前だけは知っていようが、其の正体を理解している人は少ないようである。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラーゲ旋風が果して国難的旋風であるか、楽壇啓蒙の薫風であるか――それとも国辱的旋風であるか――の正体を掴み、其の捲き起こる原因を究明して、之に対処していたならば、今頃は旋風一過して太陽の慈光が遍照していよう筈なのに、旋風が益々力を加えつつある所を見ると、日本楽壇に人無きの嘆に堪えぬ。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　プラーゲ旋風とは　修正ベルヌ条約に対する音楽的著作権に関する留保が昭和六年七月十五日外務省告示第六〇号を以て抛棄されて以来、ドイツ人のドクトル・プラーゲが欧米各国の外国著作権の日本に於ける管理者として、外国著作権の保全と実行のため、縦横無尽に活躍を始めた。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来外国著作物を縦横無尽に利用していた楽壇人にとっては、之が重大な脅威と為り、何時の間にか之にプラーゲ旋風なる尊称？",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　無軌道蹂躙戦法　プラーゲ旋風を如何にして退治しようかと苦心した結果、楽壇人とジャーナリストが提携して実行したのは、無軌道の蹂躙戦法であった。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽壇人が一致してプラーゲ管理の楽曲に対し一文も使用料を支払わず、滅茶苦茶に其の権利を侵害することにすれば、プラーゲも兵糧が欠乏して日本国を退去するであろうと云う、非日本的な楽壇人の脳味噌から捻出された策戦であった。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで東京音楽協会では、昭和九年になってから、プラーゲとの従来の協定を破棄し、プラーゲの権利を否認すると云う態度に出て、会員に対して其の旨の指令を発した。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事協会で責任を持つからプラーゲの権利を否認せよとの指令を出すものだから、プラーゲに挑戦したら、一たまりもなく惨敗の苦杯を喫した。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　白旗を掲げた読売新聞　プラーゲの旋風退治に最も勇敢なのは読売新聞であった。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽壇人の「無軌道蹂躙戦法」に相呼応して、読売新聞は昭和九年三月十五日の其の紙上に、プラーゲはパリの著作権聯盟（カルテル）の真正の代理人に非ずして贋者なりとの趣旨の記事を掲載して、楽壇人の著作権侵害を声援し且つ煽動した。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラーゲから名誉毀損の告訴を受けるに及び、百方手を尽して応戦していたが、遂に万策尽きた。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京音楽協会からパリの著作権聯盟に対し、プラーゲの代理人たることを拒否する旨を打電したが、パリからは、プラーゲは日本に於ける唯一の代理人なりとの返電があった。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでさしも鼻息の荒かった読売新聞も、昭和九年十一月八日の紙上に、「ドクトルプラーゲは法定代理人」と云う見出しで次のような記事を掲載した。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
