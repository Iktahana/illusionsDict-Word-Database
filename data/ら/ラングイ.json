[
  {
    "uuid": "d80656ad-3d7b-557f-833f-988bf480eefd",
    "entry": "乱杭",
    "reading": {
      "primary": "らんぐい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
