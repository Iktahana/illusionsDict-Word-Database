        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "風が出て晴れさうだが、たうとう風雨になつた、ラクダ色の山が山に、ごつ／＼そびえてゐる。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラクダ色のセエータの下に真白い清潔なシャツをつけており腕時計をはめていた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "着古した、玉ラシャのオーヴァ・コートに貧苦のやつれを見せたサト子が、豪勢なラクダ色の七分コートを、ふかふかと着こんだ大矢シヅに傘をさしかけられ、沈んだ顔で、街路樹の下を歩いている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は柔かい灰色アンゴラのファーつき外套を着、もう一人はラクダ色の外套を着て自分たちをむき出しに広場をかこんで止っているトラックの上からの環視にさらしたまま、佇んでいる伸子と素子。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "健の好きなラクダ色の毛糸の洋服であった。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
