    "definitions": [
      {
        "index": 1,
        "gloss": "discouragement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "衣食住さへ足りればいゝ人達は、不景気にも関らず、昔日よりも元気でこそあれ落胆してゐるとは思はれぬ。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団だけは今晩荷を解かなければならないと思ふことが、異常な落胆を呼び起すのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎が伝え聞いたらどんなに落胆するであろう。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　日本語の分る時以礼は、人のよげな、いくらか顔にしまりがない、落胆した、恨めしげな王を指して、兵士達に話した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に、云ひ出しにくいからといふのでもない云つて却つて、落胆させてはと思つたからでもない、なぜかしら、云はずじまひであつたのだ。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は時に落胆したり、時に怒ったりしたが、しかし、結局は現実の老僧たちの態度よりも馬翁の許の虫干で拾った「禅関策進」の中に書いてある文字上の歴史の人々の事蹟言行を信じた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それだけの用意をしながら、秀吉が雪の朝にとうとう来ずにしまっても利休はちっとも落胆はしなかったでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではまず第一に自分を救う、すなわち自分の不平、不安、失望、落胆、恨み、呪い、……などを征服するには、どうしたら良いでしょうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、そこには不平不満や失望落胆などは決して起りません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんだ間違いが起きたり、失望落胆が来るのが通例です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえにも若しそんなことがあっても決して落胆おしでないよ。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人ながら落胆して、とある木蔭に腰を卸して、「どうしたんだろう。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかしまだそう落胆するには及ばない。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き終った文彦は落胆したように、「ああ折角ここまで苦心しながら、残念な事をしたなあ。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い弁護人は彼等の失望、落胆が忿懣に変じ、若くは自棄となつて、どんな無分別を起さぬとも限るまいと思つたから、慰藉とある希望とを与へたいと考へて、静に被告の席近く進んだのであつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "刎ねられ方は簡単だけれど、今度は昨夜より落胆した。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "御方の失せさせたまいし上は、最早この世に望みは無し、と下枝は落胆気落ちして、「もう聞とうない、言とうない。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やっぱり時計が見着からないのだと想って、落胆しているだろうさ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は取附く島も無く、落胆して、「ああ情ない、我あ素手では帰られましねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "親まさりの爪尖尋常に白脛を搦んだまま衝と横に投出した、肩肱の処々、黒土に汚れたるに、車夫等が乱暴のあとが見えて、鈴かと見える目は清しく、胸のあたりに張はあるが、落胆り疲れた様子である。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "落胆して、お腹が空いたと申して、勝手でお茶漬を掻込んでおるでござりますが、な。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「あの、それですけれど……安心をしましたせいですか、落胆して、力が抜けて。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は落胆した。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの爺さんは、いまごろはきつとひどく落胆して、山に柴刈りに行く気力も何も無くなつてゐるでせうから、私たちはその代りに柴刈りに行つてあげませうよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことにばかりくどくかかずらっている母親にかの女は落胆して、もうどうでもいいと思った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩方、お部屋から出ていらっした時、私があなたがおいでになったのを申上げると、とても、落胆なすっていらっしゃいました。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」たのもしい私の案内者は別に落胆した様子も見せず、「それぢや、ここでちよつと休ませてもらつて弁当を食べるか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は勇次郎の戦死の通知があって以来、老妻が非常に落胆していたので、ついすると発狂したかも判らない。",
              "citation": {
                "source": "母親に憑る霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という細君の言葉は差当って理の当然なので、主人は落胆したという調子で、「アア諦めるよりほか仕方が無いかナア。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいていの捕方だったら、品物が品物だからおそらくたんすか長持ちといったような貴重品の入れてある家財道具に着目すべきところを、右門は例のごとくその逆のからめてをたどって、なるべくなんでもなさそうなところ、くだらないちょっとしたところというような個所にばかり、鋭い視線を働かせていきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
