[
  {
    "uuid": "02a76b06-b8f7-58c8-abb1-e4d42c21ca22",
    "entry": "落胆",
    "reading": {
      "primary": "らくたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
