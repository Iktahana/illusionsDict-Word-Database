    "definitions": [
      {
        "index": 1,
        "gloss": "ground stone tool from the late Jomon period",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
