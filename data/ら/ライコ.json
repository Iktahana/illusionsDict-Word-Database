        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "直ぐは蒲団の上に仰向きになれなくて、暫くは枕に肘を突いてゐたが、つらいことだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士駅附近へ来ると極めて稀に棟瓦の一、二枚くらいこぼれ落ちているのが見えた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうにどんなつらいことでもそれがたゞしいみちを進む中でのできごとなら峠の上りも下りもみんなほんたうの幸福に近づく一あしづつですから。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何、別に用事はないのだから明日一日くらいここで暮らしてもいいんです。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『村に出た時はもう日が暮れて夕闇ほのぐらいころであった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分くらいこの状態が続いたか分らないが自分には恐ろしく長いものに思われた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "刹那に、躍り出た仲間は娘を車中へさらいこむ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い所から深いドン底へ墜落するのは何というつらいことだろう！",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えたことをみんな言わないでいることは大へんにつらいことなのだ。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だまっているということは本統につらいことなのだ。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにどんなつらいことでもそれがただしいみちを進む中でのできごとなら峠の上りも下りもみんなほんとうの幸福に近づく一あしずつですから。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙をきらいこわがる人はかなりたくさんある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、」家内は平気で、「三十分くらいこうしていると、汗がたらたら出てまいります。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにどんなつらいことでもそれがただしいみちを進む中でのできごとなら、峠の上りも下りもみんなほんとうの幸福に近づく一あしずつですから」　燈台守がなぐさめていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうにどんなつらいことでもそれがただしいみちを進む中でのできごとなら、峠の上りも下りもみんなほんたうの幸福に近づく一あしづつですから。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕だってつらいことはいくらもあるんだい。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨にぬれた緑のどてのこっちをゴム引きの青泥いろのマントがゆっくりゆっくり行くといふのは実にこれはつらいことなのです。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか臭いようで、その塩からいこと夥しい。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えらいことをしやべつたな」と云つたら、真顔になつて、「だつて私は貴方の御意見に雷同したんですもの」と云つた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "春着をこしらえるなら拵えるように、せめて手付けの一両ぐらいこっちへ預けて置いてくれなけりゃあ、どこの呉服屋へ行ったって話が出来ませんよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉の傍へ寄って来ると、「兄貴、えらいこっちゃ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三郎公、えらいこっちゃ、銭がない」「えっ……？",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それはいかにもつらいことです。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "木にしてみれば、じつにつらいことなのです。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、悲しい、つらいことでした。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ、えらいことになったぞ。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気やなんか治すよりも、もっともっとえらいことが出来るんだぞ」　これを聞くと、無茶先生と一緒にお酒を飲んでいた豚吉も威張り出しました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、きょ年の夏、兵太郎君と川あそびにいって、川からあがったばかりの、ぴかぴか光るおたがいのはだかんぼうを、おいしげった夏草の上でぶつけあい、くるいあって、たがいに際限もなくわらいころげたことだった。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはたいへんつらいことでありました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな、つらいことでも、どんな、くるしいことでも、こらえる。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
