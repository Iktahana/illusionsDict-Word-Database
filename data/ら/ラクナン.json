    "definitions": [
      {
        "index": 1,
        "gloss": "south of the capital",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "柴田氏は古く幕府に仕へて、林家の文集に東皐元泰、竹渓元岱の墓誌があり、大槻磐渓の寧静閣集に洛南元春の墓誌がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此年乙卯に榛門の柴田常庵の同族、三十間堀の洛南柴田元春が歿した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "正雄、字は君偉、号は洛南である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都市南部、洛南――。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の土佐隠棲、京都移住、越中流離、洛南幽居等、生活上の変転はいろいろあつたけれども「人間経」以来の歌境は、なほ今日までつづいてゐるといつてもいい。",
              "citation": {
                "source": "老境なるかな",
                "author": "吉井勇",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十歳のとき道元は、洛南深草の安養院という廃院に移った。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もこの春、洛南の羅刹谷で会うたきり、足利殿には、ついぞお目にかかっておりません。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "こことはちがい、洛南洛西方面の様相は、きのうも今日も、激烈をきわめていた。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なる強度の望遠鏡でも窺う事の出来ぬような遠い天体の上に起る些細な出来事も直ちに地球上の物体に有限な影響を及ぼすとなれば、人間の見た自然の運動にはおそらくなんらの方則を見出すことも出来ないだろう。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がおそらくなんの実験にもよらずしていかにしてこの落体に関するアリストテレスの誤謬を認め得たかはわからない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十中八九は実際おそらくなんらの目立った果実を結ぶことなく歴史の闇に葬られるかもしれない。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもその前の弥次のけんかと見物の群集とがなかったら、おそらくなんの意味もないただの写真としか見えないであろう。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　慶次郎ははじめて崖を見たらしくいかにもどきっとしたらしくしばらくなんにも云いませんでした。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この終わりの自殺者と、前の図書館屋上の人とはおそらくなんの関係もないかもしれないが、しかし自分の頭の中では前後四人の「屋上の人」がちゃんと一つの鎖でつながれている。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　慶次郎ははじめて崖を見たらしくいかにもどきっとしたらしくしばらくなんにも云ひませんでした。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分しばらくなんですもの、私だって逢いたいわ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたから見ると、私は、きっとキザに気取って、おろかしい瞑想にふけっているばあちゃん女史に見えるでしょうが、でも、私、こうしているのが一ばん、らくなんですもの。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした型の男はおそらくなんでもまめによく仕事をしまた世話のできる人であろう。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地さん、あなたにはこれまででさえいいかげん世話をしていただいてなんともすみませんですが、わたしども二人はお打ち明け申したところ、こういうていたらくなんです。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになつたつて結局はおんなじことと、一應はおもつてみますけれど、おそかれ早かれきまらずにゐないことは、やはり早く片づいてくれたはうが心もらくなんです。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「糸子さん、こう云う体たらくなんですから。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそういう演技をやるにしても、この次に田村君は恐らくなんの破綻も見せないだろうと、僕は思つている……。",
              "citation": {
                "source": "俳優と現代人の生活（対話５）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりイワノフ博士の人造人間エフ氏の実験をたいへん長いこと見せてくれたんだが、あの日は、人造人間エフ氏の身体と僕の身体との間になんだか怪しい火花をぱちぱちとばせてさ、急に目まいがして、しばらくなんだか気がぼーっとしてしまったんだよ」「まあ、ひどいわね。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が悟りをひらくなんて、考えられることだろうかと。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠山にも同じことを指摘されたし、よしんば誰の助けもない自分一人の判断だけでも、恐らくなんの疑惑もなく同じ確信がもてた筈だ。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "作陶上に必要な教養をなにほど修めておいたか、またどれくらいの作陶経験を有していたか、私は率直にいってみるが「諸氏はおそらくなんの用意もまったくなかったのではないか」と、この点については諸氏の固有する才能そのものが自己を打つところの、持った棒となりおわったのではないか。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "えらくなんぞみえなくつたつて……。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "だつて、もうしばらくなんだもの……」「しばらくつて……それがわからないでせう。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも塩ぶたがかかっていたかぎが目にはいったが、そこにはもう長らくなんにもかかってはいなかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなこと、ひとつもつらくなんかないわ。",
              "citation": {
                "source": "待っている女",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
