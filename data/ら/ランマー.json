          "literary": [
            {
              "text": "これは大僧正クランマーである。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィリアムは四男四女の三番目で長男だったので、グランマー・スクールも中途でよして店の手伝いをさせられた。",
              "citation": {
                "source": "シェイクスピアの郷里",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年一月、英国に到着、最初ウォールミンスターのグランマー・スクールに入り、その後、倫敦のユニヴァーシチー・カレッジの法科へ移った。",
              "citation": {
                "source": "湖畔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "グランマーとはよく仰云ったこと。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
