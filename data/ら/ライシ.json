[
  {
    "uuid": "c2e53e0e-305c-5829-9bbc-202c6b9f97be",
    "entry": "来旨",
    "reading": {
      "primary": "らいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gist of what someone else said",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私の友人は、ほんの数えるくらいしか無い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何台目かに来た浜町行に乗込んだら幸いに車内は三、四人くらいしか乗客はなくてこの頃のこの辺のバスには珍しくのんびりしていた。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンからの便りでは、新聞や通俗雑誌くらいしか売っていない店先にも、ちゃんとアインシュタインの著書（英訳）だけは並べてあるそうである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京辺と四国の南側の海岸とでは満潮の時刻は一時間くらいしか違わないし、満干の高さもそんなに違いませんが、四国の南側とその北側とでは満潮の時刻は大変に違って、ところによっては六時間も違い一方の満潮の時に他の方は干潮になる事もあります。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Tofts の新居に実験室を造ろうと考えてマクスウェルの知慧を借りたりしたが、結局ここにはわずかに四箇月くらいしか居ないことになった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈はその村に来ているが、私の家は民家とかなりかけ離れた処に孤立しているから、架線工事が少し面倒であるのみならず、月に一度か二度くらいしか用のないのに、わざわざそれだけの手数と費用をかけるほどの事もない。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に肝心な研究費はいつでも蟻の涙くらいしか割当てられない。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の長さは五割も長くなり、トン数は三倍の余に達し、機関の馬力は五倍に届いたが、ただ速度のみはこの割に増す事が困難で二割五分くらいしか増していぬ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし筋肉を運動させていれば一割強くらいしか増さぬ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで色々試験をしてみた結果だというのを聞いてみるに、普通下水溝渠のごとき汚水中では精々四日間くらいしか生きていぬが、水が清浄なほど永く生きているそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処まで来た以上早く支那の土を踏ンでせめて小便ぐらいしてやりたいと思います。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとアダがくすくす忍びわらいして可笑しさがこみあげると、私の脚を嫌というほど蹴って、それからくるりと後向きになるとアダはセルビア戦争で使用したような鼻を鳴らして部屋から飛出してしまった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スマ子女史が苦わらいして立あがった。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六歳になったばかりの娘は、せいも、身体のはゞも、メリケン兵の半分くらいしかなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "発育ざかりの私の二人の子供は、一日一升五合くらいの飯を平らげてまだなにかほしそうな顔をしているのだが、外米の入った飯になると、かわいそうなほど急に、いつもの半分くらいしか食わなくなって悄げこんだ。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの仕事には、まだ自分が三分くらいしか出せていなかった気もする。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客は亮の兄弟と自分らを合わせて四五人ぐらいはあったが、映画技師、説明者が同時に映画製造者を兼ねるのみならず、肝心のガラス板がやっと二枚ぐらいしか掛け替えがないのだから亮の骨折りは一通りでなかったろうと思われる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概やっと一字、せいぜいで二字くらいしか読めない。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども陸羽一三二｜号のほうは三｜割ぐらいしか浮く分がなかった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大堰の水もまるで四｜寸ぐらいしかない。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　校長はその黄色な証書をだまって小わきにはさんだまま、ポケットに手を入れて、にがわらいして斯う云った。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらのだいたい同じくらいの年ごろの女の子が皆同じ制服を着ているからちょっと見ると身長の差別と肉づきの相違ぐらいしか目につかないようである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまた野ねずみのこどもときたらまるでけしごむのくらいしかないのでゴーシュはおもわずわらいました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『お前はどうして』と問われてお絹ためらいしが『叔父さんとよく相談してと生返事をして置きました。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにこの天をまなざしうとく望みて永久の希望語らいし少女と若者とは幸いなりき。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年の目と少女の目と空に合いし時、少女はさとその面を赤らめ、しばしはためらいしが急に立ちあがりかの大皿のみを左手に持ちて道にのぼり、小走りに駆け入りしは騎馬隊の兵士が常に集まりて酒飲むこの街唯一の旗亭なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎は極端な満員、××は二三人ぐらいしかいないものを示す。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっぽど刈ったつもりでも、立ち上がって見ると手のひらぐらいしか進行していないのにがっかりした。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一部というのは愚か、針で突いた穴よりの光ぐらいしか覗けません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君、大がいな場合、お嬢さんには深切ぐらいしか起らないよ」　自宅の少し手前で青年は婦人の手を曳いて自動車から降りた。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
