    "definitions": [
      {
        "index": 1,
        "gloss": "trumpet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "街道を折れて、少し下り坂になる道をスタコラと歩いてゆくと、街道でしてゐた豆腐屋の喇叭の音は急に聞えなくなり、道の傍の、森の葉擦の音に私は淋しくなるのであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時の楽隊の騒がしい喇叭のはやしはまだ耳に残っている。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅の白猫の顏に少し似てゐるが、あの喇叭のやうな恰好をして、さうして禿頭のやうな色彩を帶びた鼻面はセンシユアルでシユワイニツシである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新発明の耳喇叭　スウェーデン政府の電話局で近頃発明された耳喇叭は交換手の耳にさし込んで通話をするためのものであるが、これはまた耳の遠い人のためにも重宝なものであるそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い、歯糞のついた歯が、凋れた唇の間からのぞき、口臭が、喇叭状に拡がって、こっちの鼻にまで這入ってきた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに先刻の手早き藝當が其效果を現はして來たので、自分は自分と腹が定まり、車窓から雲霧に埋れた山々を眺め『走れ走れ電車、』　圓太郎馬車のやうに喇叭を吹いて呉れると更に妙だと思つた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の注文通り、喇叭の聲で人車は小田原を出發た。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　自分は如何いふものかガタ馬車の喇叭が好きだ。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の野路をガタ馬車が走る、野は菜の花が咲き亂れて居る、フワリ／＼と生温い風が吹ゐて花の香が狹い窓から人の面を掠める、此時御者が陽氣な調子で喇叭を吹きたてる。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが小田原から熱海までの人車鐵道に此喇叭がある。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ二｜臺の三｜等車、次に二｜等車が一｜臺、此三｜臺が一｜列になつてゴロ／＼と停車場を出て、暫時くは小田原の場末の家立の間を上には人が押し下には車が走り、走る時は喇叭を吹いて進んだ。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "喇叭も吹く、斯くて棧道にかゝつてから第一の停留所に着いた所の名は忘れたが此處で熱海から來る人車と入りちがへるのである。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　隨分長く待たされたと思つたが實際は十｜分ぐらゐで熱海からの人車が威勢能く喇叭を吹きたてゝ下つて來たので直ぐ入れちがつて我々は出立した。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将になった坊っちゃんのあとにはボール紙を円く巻いて口にあてがった、喇叭卒がつづいていた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つの洋車は、ぽそぽそと喇叭もならさず、人ごみの中を引いて行かれた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食喇叭が鳴り渡る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そのうしろから、ふいに送話器の喇叭状の金具をめがけて、急激に、ドシンと突きつけられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の中央は、鼻梁が真中から折れて、喇叭の型に円く窪んでしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は、ビンから喇叭のみにして、八人の口から口にまわった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、鉱脈の拡大しているのに従って、坑道を喇叭状に掘り拡げた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "池があったのですが、それも潰されてしまって、変ったと言えば、まあそれくらいのもので、今でも、やはり二階の縁側からは、真直に富士が見えますし、兵隊さんの喇叭も朝夕聞えてまいります。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御者は今一度強く鞭を加へて喇叭を吹き立たので躯は小なれども強力なる北海の健児は大駈に駈けだした。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車は喇叭の音勇ましく此間を駈けた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中には雨は小止になつたと思ふと、喇叭の音が遠くに響く。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の審判の喇叭でも待つように、ささやきもせず立ち連なった黄葉の林。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの飴屋が、喇叭も吹かず、太鼓をトンとも鳴らさぬかわりに、いつでも広告の比羅がわり、赤い涎掛をしている名代の菩薩でなお可笑い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるかに馬車の影が見えてテートーと喇叭を吹けば、これ我等がためにマーチを吹くなりと称して痛快に馳け出し、忽ちにして追い越してしまう。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十回　月夜の大海戰印度國コロンボの港――滿艦の電光――戰鬪喇叭――惡魔印の海賊旗――大軍刀をブン／＼と振廻した――大佐來！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大佐一顧軍刀の鞘を拂つて、屹と屹立つ司令塔上、一｜令忽ち高く、本艦々上戰鬪喇叭鳴る、士官の肩章閃めく、水兵其配置に就く、此時、既に早し、既に遲し、海賊船から打出す彈丸は雨か、霰か。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚なんといふものは鼻がらっぱになってゐる。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
