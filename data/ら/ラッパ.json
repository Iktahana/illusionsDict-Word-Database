[
  {
    "uuid": "5d24d54e-e15c-5015-914d-795567aea9b2",
    "entry": "喇叭",
    "reading": {
      "primary": "らっぱ",
      "alternatives": [
        "ラッパ"
      ],
      "is_heteronym": false
    },
    "grammar": {
