    "definitions": [
      {
        "index": 1,
        "gloss": "comfortable rest or sleep",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「身に覚なきはおのづから楽寝｜仕り衣裳付｜自堕落になりぬ。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小用を足して来てから――楽寝としょうか。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれやあ引、さの、せえい、せえい、せえええい、三浦三崎は女の夜業、男｜後生楽寝てまちる、ようい、ようい、よやさのせえい。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽寝のできるのは子供らの学校へ行っている間だけである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからすぐに起きては早いと思ったのと、主人の留守に幾らか楽寝する積りであったのとで、庄五郎が草鞋をはいて出るのを見送って、女房は表の戸を閉めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんちきめ、尋ねる人は、もうとッくに楽々と、蒲団の中で楽寝をしていらあ――あばよ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そこで最後には、ほかの事はどうともするから、ただ安々と楽寝がさせて貰いたい。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日曜になると、宗助は例の通り一週に一返の楽寝を貪ぼったため、午前半日をとうとう空に潰してしまった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲み物も食い物もフンダンに用意させましたが、人が来ることは誰にも話させず、下女のお駒も、宵のうちから床へ入れて楽寝をさせ、佐吉一人、淋しく待っているところへ、八五郎が行ったのですから、佐吉の喜びというものはありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句を味うためには、どうしても蚊帳の中に楽寝をしている作者の姿を念頭に浮べる必要がある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして巣の中へはいって、しばらくねころんでいましたが、どうもおもしろくなくて、おもしろくなくて、たまりません。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはわたくしの映像に向って、「しばらくね、おなつかしゅう」　と挨拶しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の玉のような奴で、東京中の床屋という床屋、一軒残らず手を焼いてしまったんで、どこへ行っても店口から水をぶッかけて追い出すッて工合ですから、しばらくね、消えました。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "くくっている枝は、幹からくねりと下回りに曲がって、川の上に二間近くも突き出た場所でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まア、参木さん、しばらくね。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくねむることにしよう。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、こっちもしばらくねむるとしようか」　学士は、ひとりごとをいって、椅子にこしをかけ、配電盤のまえの机に両ひじをつき、顔を腕のうえにのせました。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の方でも番台を間に兼太郎の顔を見るといかにも不審そうに、手にした湯銭をそのまま暫く土間の上に突立っていたが、やがて肩で呼吸をするように、「まあお父さんしばらくねえ。",
              "citation": {
                "source": "雪解",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなら大丈夫だというので、二本目からは東京へ出かけ、丁度文理大の藤岡君のお母さんが、慶応に入院していたので、その病室の隅を借りて、しばらくねかせてもらうことにして、注射をつづけて行った。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなところに、隠れこんでいようなんて、考えもしなかったわ……あのとき、ご挨拶もしないで帰ってしまったけど、怒っているわけでもないでしょう……しばらくね、握手ぐらい、しましょうよ」　サト子は、途方にくれながら、おずおずとカオルの手を握った。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく、ぐらいのことは言ってほしいよ」「しばらくね」「毎日、待っていたんですぜ、遊びに来てくれるっていうことだったから……おっと、こんなのんきな話をしていられない。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、あがってちょうだい」　へどもどしながら、じぶんの部屋へ案内して、窓ぎわの椅子にかけさせると、しばらくね、とか、ほんとうによく来てくれたわね、などと思いつくかぎりのお愛想を並べたてる。",
              "citation": {
                "source": "キャラコさん",
                "author": "ぬすびと",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎にも角にも、後の世の歌麿、清長、豐國にもない、それは不思議な嬌態で、等身大の極彩色の美女が六人、滿身の媚を傾け、その魅力を鬪はせ、前から後ろからくね／＼と觀る者に呼びかけるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "浮世繪の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まア、お品さん、しばらくねえ、さア、どうぞ――」　取次のお静は、手を取らぬばかりに、石原の利助の娘で、年増っぷりの美しいお品を招じ入れました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "富籤政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "分りました、あなたの頼みは承知しました、――しばらくね。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあしばらくね、と机に向うわたし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時刻にもかかわらず、省線は猛烈にこんで全く身動きも出来ず、上の子をやっと腰かけさせてかばっていた間に、背中の赤ちゃんは、おそらくねんねこの中へ顔を埋められ圧しつけられたためだろう、窒息して死んだ。",
              "citation": {
                "source": "石を投ぐるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「恐らくね」ラスチニャックが答えた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみは、じつにすばやく、頭がはたらくねえ。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
