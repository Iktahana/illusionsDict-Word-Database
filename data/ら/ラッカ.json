          "standard": [],
          "literary": [
            {
              "text": "岸に沿ひてベルヒの方へ漕ぎ戻すほどに、レオニの村落果つるあたりに来ぬ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "落果てた拙者だが、お茶だけは贅を言つて居るよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "三軒長屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ作者の句に「初雪や桐の葉はまだ落果ず」というのがあるが、これは桐の梢がまだ幾葉もとどめていることを現したのである。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちヒロシマ族の網膜から消えることのないあのあさのらっかさんがふうわりと雲のかげであそんでいる。",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもお神さんが別嬪さんなばかりで苦労しらずの武家出ときているから、そういうとき間へ入って何ひとつとりなしてくれず、おしまいまでほったらっかしッ放しだ。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
