[
  {
    "uuid": "555f67ea-da5a-5218-ba1d-cd9d7c3b6622",
    "entry": "落下",
    "reading": {
      "primary": "らっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
