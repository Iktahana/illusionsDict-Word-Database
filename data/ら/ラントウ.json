    "definitions": [
      {
        "index": 1,
        "gloss": "confused fight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あッ」　石松、深傷に弱りながら一味と乱闘。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝棚倉宅　三次は襖や障子等手当り次第に投げては振り廻し大乱闘。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝遂に三四郎乱闘の中へ飛び込んだＴ「棚倉伝八逃がさぬぞ」　で立廻り。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉「よーしＴ「汝等、よう開けぬ　のなら、俺が　斬って落すぞ」　と叫んで太刀大上段に振り上げ、Ｔ「此村大吉が　柳島の妙見に　一大乱闘の幕　切って落すぞ」　と叫んで一同の中へ斬り込む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵、懸命の乱闘、　波と乱闘の交響楽だ！",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代俳壇の乱闘場裏に馳駆していられるように見える闘士のかたがたが俳句の精神をいかなるものと考えていられるかは自分の知らんと欲していまだよく知りつくすことのできないところである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、議会の乱闘なぞとは全然正反対の意味に於けるアラワレなので……しかもその目的が利欲の観念を含まぬ、純粋な意味の勝敗のみに限られているだけに、吾々の日常生活や戦争なぞよりもはるかに高潮した肉体と精神の純真純美さを、あらゆる刹那に発揮し得るように出来ている。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大阪曾根崎署では十九日朝九時、約五十名の制服警官をくり出して梅田自由市場の煙草販売業者の一斉取締りを断行、折柄の雑沓の中で樫棒、煉瓦が入れ交つての大乱闘が行はれ重軽傷者数名を出した。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（目撃者の話）――この乱闘現場の情景を目撃してゐた一人、大和農産工業津田氏（仮名）は重傷に屈せず検挙に挺身した同署員の奮闘ぶりを次のやうに語つた。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「流血の検挙をよそに闇煙草は依然梅田新道にその涼しい顔をそろへてをり、昨日もまた今日もあの路地を、この街角で演じられた検挙の乱闘を怖れる気色もなく、ピースやコロナが飛ぶやうに売れて行く。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "排他、脅迫、防禦、突進、乱闘、流血、　ぎゃお、わお、がお、うわアああ、わお、お、お、　ハーレムとは一の成牡（ブル）を中心として成る成牝（カウ）の多くは百頭三百頭の集団である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冥々、闇々、　　　　咆哮、　　　　　悲鳴、――血、血、血、　あ、蒼白い月光、たちまち、　薄らぐ霧、　　　　　海獣、海獣、海獣、　　　　　　　肉迫、乱闘、乱噬、　　　ぐわう、ぐわう、がおかお、　　　わわわわ、わおわおわお。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　砂上、黒雲の影、いよいよ盛んなる乱闘、　幾千の成牡（ブル）入り乱れてまさに修羅場の壮観となる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱闘数刻ののちようやく執拗な敵を撃退しえたが、確かに今までにない難戦であった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い中で敵味方も分らぬほどの乱闘のうちに、李陵の馬が流矢に当たったとみえてガックリ前にのめった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、突然の不注意な一発の偽砲から、忽ち乱闘に変じ、本ものの戦争になった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "血河の乱闘　近藤勇は玄関から、「主人は居るか、御用改めであるぞ」　と、堂々と声をかけて、上り込んだ。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の出る様な乱闘が続いた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々の焼け野原でよく乱闘が行われた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう運動をやるようになった動機とか、スパイ三人を向うにまわして、鉛のパイプを持って大乱闘をやったことがある話とか、どん底の生活をしている可哀相な女が時々金を自分に送ってきてくれる。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、聴衆は場外にあふれて、所々に乱闘騒ぎを起した。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実「僚友会」で乱闘をやってから、須山は極度に危くなっていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、溝の上を棒切で叩いたり、石ころを投げつけたりする騒ぎといつしよに、伝は調子を合せて百舌のやうに口笛を鳴らし、庄は不思議にこましやくれた音声を張りあげて、何かの乱闘の場面でもあるらしい浪花節を唸つた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人も吻つと息を入れて、さつきの演劇の凄絶さに見震ひしてゐたが、話の模様で察すると、二人の武者修業者が狼（マル）と闘つてゐるところに、天上から烏天狗が飛び降りて来て、大乱闘が始まるといふやうなものであるらしかつた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また忠弥の注進によれば、杉窪の里の乱闘の際姉の君尾を取り返そうと、袴広太郎という一人の義士が、追っかけて行ったということだが、その時の袴広太郎と、この袴様とは同一人なのか？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「杉窪の里の大乱闘、傾城塚の愛欲地獄、そうしてここの木地師たちのくらし！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄の中のような乱闘と悲鳴。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……馬を飛せて、あの卑劣な男の館へ飛び込む、彼奴の眉間を目がけて猛烈な拳固が飛ぶ、乱闘――そんな光景ばかりが、パラ／＼と目眩しくフラッシュするだけであつた。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、何物にも屈伏することを好まない青年の自尊心を感じることの出来る者達程、此の日の二人の乱闘の原因も、所詮酒の上の、「箸で突いた」程度のことから始まったと自然な洞察を下して、また酒盃をとり上げた。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所じゅうを　ぶたいに　大らんとう。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
