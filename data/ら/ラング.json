        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ラングストと云っている大きな蝦の味は忘れかねる。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝蝦より稍々大きいラングスチンと呼ぶ蝦は鋏を持っている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さなブーメラング形の翼の胚芽の代わりにもう日本語で羽根と名のつけられる程度のものが発生している。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブーメラングや毒鎗が。",
              "citation": {
                "source": "どらが鳴る",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が出る時｜桟橋に立った見送りの一組が「オールド・ラング・サイン」を歌った。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ピーター・プラングル、ザ、プリックリー、プラングリー、ビーア、ピッカー……」といふ種類のを早口で云はせたりした。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このドンニソープと云う町は、ブロートの田舎、ラングメルの北方にある小さな村なんだ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "このドニソープというのは、湖や沼の多いブローズ地方にあって、ラングミアのちょうど北方に位置する小さな集落だ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "エイモニエーの『安南記』にはオラングライー族の村に虎入りて人なり犬なり豕なり一頭でも捉わるると直ぐ村を他処へ移すと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時王の使｜喚いて彼を海へ追い込み、牝馬を伴れ帰って介抱すれば、海馬生まると（一八一四年版ラングレー仏訳『シンドバード航海記』一二頁）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの世離れた崎の港、スラングのわるく際立たない島の娘の群、自然に見事な海門の形を成してゐる西郷の港、島前の出口から烏帽子岩、冠岩等を隔てゝ遙かに島後の大満寺山を眺めた形。",
              "citation": {
                "source": "隠岐がよひの船",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ難かしいものであるのに加へて、スラングといふことがある。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最新式避姙法」の書物　マリーストーブとかブラングエンとかいう人々の著書の和訳、又は「性」という文字を標題に取入れた雑誌は、記者が街頭の書物屋で見ただけでも十種近くある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレオパトラやマクベス夫人に扮して名を売つた英吉利の女優ラングトリ夫人が、まだ若盛りの頃ある宴会で、その頃ちやうど倫敦を訪れて来た阿弗利加の或る王様と一緒になつた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでアンドリウ・ラング（Andrew Lang）に言わせると、『諸神話は一方では原始的な宗教的観念に基づくと同時にまた他方では当て推量によって得られた原始的の科学に基づいたものである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルシノアからの帰途、自動車は「北欧リヴィラ」の名ある坦々たる海岸の道を走るんだが、スネッケルステンからニヴァ、ラングステッドからスコッズボルグと宿場を縫ってドライブしてくると、間もなくクラッペンボルグという小さな村へさしかかる。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラングィンがヴェニスの景色をごく色彩的な効果で描いたのをもっていて、それなど愛しておりました。",
              "citation": {
                "source": "写真に添えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲーテはシュトゥルム・ウント・ドゥラングの運動を経験した。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、ろくろ首にしたり、鉄棒を持たせたり大入道にして、ラングイヒゲを生やしたりすると一層滑稽になる。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにたどればビッグ・ブラザーはジョージ・オーウェルの『一九八四』から、ザ・ホールディング・カンパニーはマリファナを持っているという意味のスラングからきている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラングボムの研究所にも行つて、加野君にも逢つてやりたいと思つてゐます……」　富岡はぼそりと、そんな事を云つて、さつさと先に応接間へ戻つて行つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧田氏が急に旅立つたので、富岡のランハン行きは延びたが、五日ほどたつた或日、トラングボムから加野久次郎が、ひよつこり安南人の助手を一人連れてダラットへ戻つて来た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、トラングボムから戻つて来たばかりで、ゆき子に惹かれる気持ちは、これは慾情だけなのかと、加野はちらりと、その思ひにかすめられたが、現在をおいては、他に此の女を得る機会がないやうな気がしてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君も、トラングボムへ帰る迄に、一度、サイゴンへ行つて、さつぱりして来るンだね……」「サイゴンか……。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "林業試験所のある、トラングボムで一寸降りて、そこで、富岡と加野は、それぞれの用事を済ませて、また、自動車は、もの淋しい鉛色のうねうねとした官道を、すくんすくんと音をたてて走つて行く。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラングトンから、水母から、貝殻から、甲足類から、彼等は人間を目的にしないでやつて来た。",
              "citation": {
                "source": "釣れない時",
                "author": "君は何を考へるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラングル・ド・ボオマノワアルといふ侯爵議員は、「監督は巡査で沢山だ」と叫ぶなど、なかなかの騒ぎ。",
              "citation": {
                "source": "仏国議会に於ける脚本検閲問題",
                "author": "――ゴンクウルの『娼婦エリザ』――",
                "note": "青空文庫"
              }
            },
            {
              "text": "タラカン島へ米軍が、ラングーンヘ英軍が上陸している。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンの汽船会社の重役室では、社長ラングレー氏が首脳部をあつめて協議を進行させていた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
