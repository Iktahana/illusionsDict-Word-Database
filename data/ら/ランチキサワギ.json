    "definitions": [
      {
        "index": 1,
        "gloss": "boisterous merrymaking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
