              }
            },
            {
              "text": "「柴山君、しばらくじゃ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さ凌ぎに昨夜出先で風呂を貰い、お神がもう冷めているかも知れないから、瓦斯をつけようというのを、酔っていた彼女はちょっと手を入れてみて、まだ熱そうだったので、そのまま飛びこみ、すっかり生温になっていることが解ったが、温まろうと思い、しばらくじっとしているうちに、身内がぞくぞくして来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんらくじにて、もりかねの、うたざらゑあり。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくじっとしていて、「よし、わかった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ自分が帰って行って、「たからくじ」の秘密をはじめて打ち明ける。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造は草の上に倒れたまま、しばらくじっとしていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そら、なめろ」　牛は、おりの上に首をさげて、しばらくじっとしていました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう考へると、義雄はかの女が迷はしの術中に全く落ちた初めての犧牲である氣がして、興ざめた目を鋭く見開らき、眼がねをとほして、暫らくじツとかの女の妖相を見詰めてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が立停ってしばらくじっとしていると、蟹どもの逃走も止む。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、一度口の中に入れたものを、思い出したようにしては噛み、またしばらくじっとしていて、思い出したようにしては、また噛むのだった。",
              "citation": {
                "source": "狂馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今朝も煙草を買っていったんですが、今朝はなんでもなかったようでしたよ」「なにしろ、そこの鏡の前に立ってしばらくじっと鏡を見詰めていましたよ。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくじゃないか？",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀久子はそれを取ってしばらくじっと見詰めてから、なおもそこに弾丸の残っていることを確かめると、唇を噛み締めながらそのピストルを自分の帯の間に差し込んだ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ホームズは黙ったまま、しばらくじっとしていた。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
