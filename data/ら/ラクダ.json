[
  {
    "uuid": "0774c07f-61fe-5f9a-a051-9e3bcd1938ba",
    "entry": "駱駝",
    "reading": {
      "primary": "らくだ",
      "alternatives": [
        "ラクダ"
      ],
      "is_heteronym": false
    },
    "grammar": {
