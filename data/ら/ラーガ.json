        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "々　敬具小甥イワン・シュポーニカワシリーサ・カシュパーロヴナ叔母様※ブラーガ　白色を帯び、ビールに似た、下等な酒精飲料。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、ビール醸造用の麦芽汁の醗酵したものもブラーガと呼ぶ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "一三〇四年軍をボヘミアに進め、その同士を蹂躙す〔筆〕神の筆（生命の書に書き入るゝ）〔プラーガの王國〕プラーグ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラーガを首都とする王國即ちボヘミア一一八―一二〇〔者〕フランス王フィリップ四世（淨、七・一〇九―一一註參照）。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月七日（金曜）　朝Ｙのところからアルバートへ行ってプラーガその他見たが、なかなか細かい趣味のあるもの尠し。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は米から醸造した飲料で、私の考ではラーガー・ビヤより強くはなく、我々が麦酒に使用する半リッタア入りの杯の代りに日本人は酒を小さな浅い磁器の盃から啜る（図29は酒の盃実物大）。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラーガア麦酒〔貯蔵用ビール〕の醸造場が一つあって、すぐ使用する為の、最上の麦酒を瓶詰にしている。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頭にはラーガア麦酒が二箱積まれ、他の一頭には標本を入れた、大きな四角い柳行李が二個つけてあった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
