    "definitions": [
      {
        "index": 1,
        "gloss": "Zen monk's waistcoat (short, informal kasaya)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まことに久しぶり行乞の旅である、絡子をかけることを忘れたほど、あはてゝいそいだ（これは禅坊主として完全に落第だ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目先生が帰ってからすぐに筆をとってこの端書をかき、そうして、おそらくすぐに令妹律子さんに渡してポストに入れさせたのではないかとも想像される。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると二階で「汽船が見えました」と御竹の声。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしばらくすると、急に家中がしんとして、大風の後のやうな靜穩が此の山腹全體を支配するやうに感ぜられた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると真赤な血のような色の何とも知れぬものが暗黒の中に現れる。",
              "citation": {
                "source": "赤",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども少年はしばらくすると機嫌を取直す。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに地震のために水道が止まったり、暴風のために電流や瓦斯の供給が絶たれて狼狽する事はあっても、しばらくすれば忘れてしまう。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と始めには考えたが、しばらくするとこの考えは少し変って来た。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し彼の全集一卷を通じてよめば、恐らくすべての讀者が、彼の中に流るる眞の作家的モチーフを發見することができるだらう。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがしばらくする中に、諸君はうたた寝の夢から醒める。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎のあぜみちに坐つてゐると、おほなみのやうな土壌の重みが、わたしの心をくらくする、土壌のくさつたにほひが私の皮膚をくろずませる、冬枯れのさびしい自然が私の生活をくるしくする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は黙々として寝台の枕もとに立っていましたが、しばらくすると寒さのために震えながら私の××に這入ってきました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも兎は、草叢があったあたりからちょか／＼走り出して来ては、雪の中へ消え、暫らくすると、また、他の場所からちょか／＼と出て来た。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、暫らくすると、彼は頭痛がすると云いだした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、暫らくするうちに、二人の元気な男は、怒りに頸すじを赤くした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくするうちに、二人のワイシャツはへと／＼に疲れ、棒を捨てて、首をぐったり垂れてしまった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒れた兵士は、雪に蔽われ、暫らくするうちに、背嚢も、靴も、軍帽も、すべて雪の下にかくれて、彼等が横たわっている痕跡は、すっかり分らなくなってしまった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると、右の手が煙草箱の方へ動いてその太い指が煙草を丸めだした。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『しばらくすると朗々な澄んだ声で流して歩く馬子唄が空車の音につれて漸々と近づいて来た。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると山神が出て来て舞い始める。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくすると、それが、這入った石畳の小路から引っかえしてきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくすると、再び森の樹枝が揺れ騒ぎだした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　だが、しばらくすると浜田は、米が這入った飯盒から、折り畳んだものを出してきた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼はまたしばらくすると路を崖下の町へ歩きはじめた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくするとまた歩き出す。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、あらわに言ってみれば、「自分もしばらくすればあの男のように闇のなかへ消えてゆくのだ。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その路はしばらくすると暗い杉林のなかへは入ってゆくのだったが、打ち展けた平地と大らかに明るい傾斜に沿っているあいだ、それはいかにも空想の豊かな路に見えるのだった。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると彼らはお互いにきつく抱き合ったまま少しも動かなくなってしまった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとしばらくすると水の中やら石の蔭から河鹿がそろそろと首を擡げはじめる。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると彼はまた突然に合唱のリズムを紊しはじめた。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
