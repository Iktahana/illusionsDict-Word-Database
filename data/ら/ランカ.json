        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "リップが山に入りて、仙人の遊戯を見て、銃の朽ちしを覚えざりしとの説話と、全くその趣を一にするものは、所謂爛柯の故事なりとす。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「爛柯亭」と記した奎堂伯の書で、「御賜鳩杖」の関防が捺してあるのだが、「奎堂」が誰であるかも知らない幸子は、ただ「爛柯亭」の三字を読んだだけであった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「熊野君」「はあ」「君は我輩の爛柯を見たね？",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『爛柯の図』だ」「さあ」「覚えていなければ話にならない。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの爛柯が○○伯爵家の売立に出ていたんだよ」「はゝあ」「同じ元信でも我輩の持っている方が余っ程好い。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伯爵家のは存じませんが、社長のは実に名画でございました」「元信はよく爛柯を描いたものらしい」「爛柯ってのは仙人の名前でございますか？",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先刻も言った通り活動写真なんかばかり見ていて日本人としての精神修養を怠っちゃ駄目だよ」「はあ」「爛柯ってのは碁のことだ」「はゝあ」　と松本さんが受けた。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "承わって見れば、意味深長な故事でございますな」「以来碁に耽ることを爛柯と称する」「お蔭さまで好い学問を致しました」「ヘボ碁は打たないことだよ」「はあ」「万年筆が朽ってしまう」「これは利きました」「ハッハヽヽ」「将棋は如何でございましょうか？",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殖民地時代でしょう」「それじゃ爛柯の伝説を盗んで焼き直したんだろう」　と因縁をつけた丈けで、社長は別段異存も唱えなかった。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに大金持になるのに、わからんか！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはいつか私に、おれは淋しいんだ、孤獨なんだよ、親も兄弟も無い、この孤獨の淋しさが、お前、わからんかね、なんておつしやつてたぢやないの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下流のまっ青な水の上に、朝日橋がくっきり黒く一｜列浮び、そのらんかんの間を白い上着を着た騎兵たちがぞろっと並んで行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様はもえる宝石のように東の空にかかり、あらんかぎりのかがやきを悲しむ母親の木と旅にでた子どもらとに投げておやりなさいました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝霧ゆふ霧のまぎれに、声のみ洩らして過ぎゆくもをかしく、更けたる枕に鐘の音きこえて、月すむ田面に落らんかげ思ひやるも哀れ深しや。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星を知らんか！",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつに一晩ぢう唸られた日には、その間はあらんかぎりに金屬の音を響かせても、どうすることも出來なかつたので。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと取調べにゃならんかもしれん。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなことを喋って居るか、それは、ちょっと諸君が傍へ近よって耳を傾けても分らんかもしれん。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、なお行きにくい」「嘘言え、横着をしてもっと上流の方を廻らんからだ」「大人、行ったことがない。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうところは見つからんか、そこへ出りゃ、すぐイイシへ行けるんだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またよき人の説ならんからに多くの中には誤りもなどかなからん。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただお父さんが可哀そうだったの、始めて済南へ連れて来る子供とそれから花嫁さんにまでこんなことをさせなけりゃならんかと思ったら、お父さんが可哀そうで、涙がこぼれたわ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、そんなに、おこらんかてええやないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人は、はっきり分らんか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、これからさき、幾年、こんなところで土を掘りつゞけなけりゃならんか分らない。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「馬鹿々々しい上ッつらの体裁ばかり作りやがって、支柱をやらんからへしゃがれちゃったんじゃないか！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、俺ら、初めからそんなこた皆目知らんじゃが、なんとかならんかいのう。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　ガドルフはあらんかぎりすねを延ばしてあるきながら、並木のずうっと向うの方のぼんやり白い水明りを見ました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（誰でもないよ、バキチだよ、もと巡査だよ、知らんかい。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎はもうあらんかぎりの力を出してそこら中いちめんちらちらちらちら白い火になって燃えるやうに思ひながら楢夫を肩にしてさっきめざした方へ走りました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
