    "definitions": [
      {
        "index": 1,
        "gloss": "coming of a visitor to one's home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今朝より君が来宅までわが近郊の散歩は濁水暫時地を潜りし時のごとし。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですので、明日ご来宅なさる際には、もぬけの殻でございましょう。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵機なお頭上に在りて年明くる　　ちらちらと敵弾燃えて年明くる　　焼夷弾ひりし敵機や月凍る◯伊東福二郎君来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "気にしまいとすれどもきょうの吹雪かな◯「富士」編輯局の木村健一氏が来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "※◯昨夜吉岡専造君が来てくれ快談中、第二の珍客山田誠君が来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦之友の安居氏来宅中に警戒警報が出て、十一時半空襲警報となる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯昨日、日大山田君来宅、過日陸軍軍需本廠研究部へ売却した技術科学書及び雑誌代として、金四百六円七十銭を届けてくれた。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十八日◯井上（康文）、鹿島（孝二）君来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十九日◯村上（元三）君来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯朝、村上君来宅ありし。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯過日より清水市の安達嘉一君、鴨の綿貫英助先生、福島県の河野広輝君、長野県の小栗虫太郎君来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は清宮博君も来宅、麻雀をす。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃旧友の来宅ひんぴんたるは、戦争終了の事態をはっきり反映し、うれしともうれし。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月二十日◯昨日は山田誠君来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯その前に木々高太郎氏来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯岸本大尉始めて来宅、徹ちゃんの奮戦ぶりをちょっぴり伺う。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯「光」の丸尾君来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "村上先生毎日三度来宅、懇切なる手当をつくされ、その甲斐ありて十日目には血痰も消えたり。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯帆苅氏来宅、「報知新聞」が来る八月十三日より夕刊新聞として復活の由にて、連載物語を書いてほしいとの事。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯偕成社の矢沢氏来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯時代社の中村さんが来宅、第一回の「鬼火族」の稿料を届けて下さる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯田久保氏（元海軍少佐、青葉二分隊長）来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯きょうは午後から武田光雄君が来宅せらるる旨、昨夜電話があった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この項二十六日なり）◯夜、若林国民学校の根本先生（昌彦の先生）来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯福田義雄君と吉水君来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田機司氏の句に、　　女みなはらんだ終戦一年目◯福田義雄君来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯おひる頃に橋本茂助氏と三男君来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯エホンの稲垣さん来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯ふじ書房の近藤氏来宅。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "病んでも片手にしっかりと真鍮の喇叭を握りしめたままでいるという話を聞くにつけても（この校正中、本人、まったく回復、元気来宅した）。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
