    },
    "definitions": [
      {
        "index": 1,
        "gloss": "optimism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "広東香港間の電信が切断されてその後の消息は不明なのですが、恐らく明日は外国人は南方に於ける商業上の前途を楽観して、交易所では支那へ夥しい投資が行われるでしょう。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の悪い人は前途に霧がかかっているためにかえって楽観的である。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまとまらない考察の一つの収穫は、今まで自分など机上で考えていたような楽観的な科学的災害防止可能論に対する一抹の懐疑である。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし考巧忠実な店員に接し掌をさすように求める品物に関する光明を授けられると悲観が楽観に早変わりをする。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「六国史」を読んでいると現代に起こっていると全く同じことがただ少しばかりちがった名前の着物を着て古い昔に起こっていたことを知ってあるいは悲観しあるいは楽観するのである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年十一月岡本かの子第一課　悲観と楽観　悲観も突き詰めて行って、この上悲観のしようもなくなると楽観に代ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの感情の道を辿って行っても真面目に突き詰めて行けばきっとその弾機に行き当るのでしょうか、必ず楽観に弾ね上って来ます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲観の極の楽観と同様、せっぱつまった時の落ちつきです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "被告等の公判に於ける陳述を聞いて居ると、どうやら楽観的の気分にもなつて、之れなら大丈夫かも知れないと心に喜悦を感じて法廷を出る。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分戦争でもすめば、日本の財界はすばらしい景気になり、自分のもっている不動産も桁はずれに値があがり、世界戦以上の黄金時代が来るものと楽観しているであろうか。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、お名前は、まえから母に朝夕、聞かされて、失礼ですが、ほんとうの兄のような気がして、いつかはお逢いできるだろう、と奇妙に楽観していたのです。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "篋の内に朱書あり、之を読むに、応文は鬼門より出で、余は水関御溝よりして行き、薄暮にして神楽観の西房に会せよ、とあり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰ぞと見るに神楽観の道士｜王昇にして、帝を見て叩頭して万歳を称え、嗚呼、来らせたまえるよ、臣昨夜の夢に高皇帝の命を蒙りて、此にまいり居たり、と申す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもここに書かれてある言葉全部が、なんだか、楽観的な、この人たちの普段の気持とは離れて、ただ書いてみたというような感じがする。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜の町をはだしで歩いていたというだけでも、疑われるのは無理もないと諦めていたが、しかし、警察へ行けばすぐ釈放されるだろうと、楽観もしていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその頭の中には、極めて楽観的な写象が往来している。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女の浅はかな性質としては、もう、国府津に足を洗うのは――はたしてきょう、あすのことだか、どうだか分りもしないのに――大丈夫と思い込み、跡は野となれ、山となれ的に楽観していて、田島に対しもし未練がありとすれば、ただ行きがけの駄賃として二十円なり、三十円なりの餞別を貰ってやろうぐらいだろう。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれは順が廻って来ると楽観的に考えてもいたし、又、二年前涙と共に別れた・そして今やつれ果てて帰って来た老先輩への同情もあった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを逆に観察致しますと、こうした運命に支配されて、或は悲観し、或は楽観し、又はこれに対抗して行く意志や感情や信念は積り積って行く中に、更にその人の性格を作って行くものであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も氏政にしてみれば徳川家康がその親戚であるから、まさかの時は何とかして呉れる位には楽観して居たのだろう。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、あまり楽観してはならない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあまり楽観してはならない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "……楽観し過ぎてはならないね」　彼は考え深そうに、その足を前後にゆすりながら、しばらく黙っていた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は甚だ事態を楽観しているのである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、彼が楽観し過ぎていなければいいがと思う。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は戦争の将来に就いて楽観している。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽観論やら悲観論やら、肩をそびやかして何やら演説して、ことさらに気勢を示している人たちを岸に残して、僕たちの新時代の船は、一足おさきにするすると進んで行く。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
