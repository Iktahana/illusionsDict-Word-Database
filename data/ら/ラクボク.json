    "definitions": [
      {
        "index": 1,
        "gloss": "tree that has dropped its leaves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
