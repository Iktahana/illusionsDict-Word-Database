[
  {
    "uuid": "659f95d4-80c7-5962-8109-4beff5340044",
    "entry": "落日",
    "reading": {
      "primary": "らくじつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
