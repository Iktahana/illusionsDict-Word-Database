  {
    "uuid": "0b58bdc4-5e47-5087-ad11-ffca7949a153",
    "entry": "楽日",
    "reading": {
      "primary": "らくじつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "last day of a tournament",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十月廿五日　晴、行楽日和だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日曜の祭日、絶好の行楽日だけれど、お天気が思はしくない、何だか気の毒に思ふ、嘆くなかれ、むろん悔いるなかれ、人々具足、ほどよく楽しめ。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽日和、掃除日、風の日。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽日和、学校には運動会が開かれ、山野には子供を連れてのハイカーが多い。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はどうやら雨らしい、せつかく行楽日、降らなければよいが。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋季皇霊祭――彼岸の中日――行楽日和。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽日の行楽人、善哉、善哉。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節は初夏ながら是れが大連の春祭であり、在留の邦人に取つて今年最初の行楽日である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "参詣した時に奏する当座の神遊びもあるが、大社には貴人との約束で、定祭以外に、年中行事となつた奏楽日もある。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕ははね起きてしばらくじつと頭を押へて居ると今夜の僕の心は非常に澄み切れる事を感じた。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから診察室へ歸ると、兩方の目へ注し藥をされて、目の内側の角をどちらとも人差指で押へさせられつゝ、ソーフアに倚けて、さうしたまゝ少らくじつとしてゐなければならなかつた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はさう気がつくと、しばらくじつとそのそぶりを見てゐた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその栗の木に手をかけたままで、しばらくじつとしてゐると、その埃りのまだ消え去らぬ間に、また何處か遠くの方で閑古鳥の啼くのが聞えてきた。",
              "citation": {
                "source": "生者と死者",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　二人は、顔を見合つたまゝ、しばらくじつとしていた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
