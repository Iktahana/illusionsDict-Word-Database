        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "加ふるに此時に当りて西海に走れる平軍は、四国の健児を麾いて、瀬戸内海の天塹に拠り、羽林の鸞輿を擁するもの実に十万余人。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "出でて頼朝と戦はむ乎、水島室山の戦ありてより連勝の余威を恃める平氏が、竜舟錦帆、八島を発し鸞輿を擁して京洛に入らむとするや、火を見るよりも明也。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮門の出入には鸞輿に乗り、法王宮職が設けられ、政は自ら決した。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子と同じ月料と、天子と同じ食服と、鸞輿を与へ、法王宮職をつくつて与へた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "烈風に乗じて火を内裏に放ち、中川宮および松平容保の参内を途中に要撃し、その擾乱にまぎれて鸞輿を叡山に奉ずる計画のあったことも知らねばならないと言ってある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その機会のための大和行幸が八月十二日になって、二十七日｜鸞輿出発の予定と発表された。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "六波羅討伐の挙兵の際には、主上比叡山へ鸞輿を巡らさる。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子と同じ月料と、天子と同じ食服と、鸞輿を与え、法王宮職をつくって与えた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "都に還ると、献帝はいよいよ彼を怖れ給うて、自身、鸞輿に召して、凱旋軍を迎え、曹操を重んじて、漢の相国蕭何の如くせよと仰せられた。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――天皇の鸞輿は、もう今しがた、二条の里内裏をお立ち出でと、沿道ではつたえていた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "院司の上奏あって、すぐ乱声（雅楽部の合奏）のうちに、鸞輿は、さらに中門へ進められた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色の大鳳が屋根に翼をひろげている鸞輿ともよぶあの御輿である。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一と足さきに失敬できると思うたら、愉快でたまらんよ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、危険なところへ行かなけりゃならんようにしたのは、貴様等二人だぞ！",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君自身が、たまにあたらんように用心し給え！",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、「彼奴高慢な顔をして、出来も仕無い癖にエラがって居る、一つ苦しめて遣れ」というような事ですから、今思い出すとおかしくてならんような争い方を仕たものです。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、――ほんたうのことは、大庭でなくちやわからんよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にもわからんように行て来たつもりじゃが」「何でもない事。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私にも解らんよ」「そうで無えだ、先生のような人は誰でも可愛がりますぞ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親に早く死に別れて、たった二人の姉弟ですから、互いに力にしていたのが、今では別れ別れになって、生き死にさえわからんようになりました。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "気まぐれだから送り狼に化けぬとも限らんよ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野の奴がたくらみやがったことだ」「おいガンベ、そんなに泣き泣き物をいったって貴様のいうことはよく分らんよ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ははは……（彼はやたらに涙を拭った）俺にもわからんよ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一人の腹だ、そうは入らんよ」　　　　　　　　　五　国太郎が、この僧を自宅に屈請して教えを乞うたのは勿論である。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊手は預けて行くぞ、誰も他のものに売らんようになあ、と云われましたが、諸君。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この憐むべき盲人は肩身狭げに下等室に這込みて、厄介ならざらんように片隅に踞りつ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻木海軍大佐は打笑みながらも、聲爽かに『日出雄少年は鐵工となるより、立派な海軍士官となる仕度をせねばならんよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどその金がすず子さんの労役を救ふ目的に使用されると云ふのなら、僕は考へねばならんよ。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどその金がすず子さんの勞役を救ふ目的に使用されると云ふのなら、僕は考へねばならんよ。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて座敷で介抱して、ようよう正気づくと、仁右衛門は四辺を※し、あまたたび口籠りながら、相済みましねえ、お客様、御出家、宰八｜此方にはなおの事、四十年来の知己が、余り気心を知らんようで、面目もない次第じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
