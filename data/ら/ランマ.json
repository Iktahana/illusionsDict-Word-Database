[
  {
    "uuid": "bc889d39-515e-55ae-826f-3e9cf74159c7",
    "entry": "欄間",
    "reading": {
      "primary": "らんま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
