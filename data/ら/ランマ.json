    "definitions": [
      {
        "index": 1,
        "gloss": "transom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "美しい毛氈がいつでも敷いてあって、欄間に木彫の竜の眼が光っていた。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄間としても櫛形よりも角切を択ぶ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも建ちは割合に高くて、簡単な欄間もあり銅の釘隠なども打ってある。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私と忠蔵がお供でやしたが、若奥様がね、瑞巌寺の欄間に舞つてる、迦陵頻伽と云ふ声でや、　――あの夏になると、此の辺に常夏が沢山咲きませうね――　へい、其の常夏を知らねえだ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　二階の階子壇の一番上の一壇目……と思ふ處へ、欄間の柱を眞黒に、くツきりと空にして、袖を欄干摺れに……其の時は、濃いお納戸と、薄い茶と、左右に兩方、褄前を揃へて裾を踏みくゞむやうにして、圓髷と島田の對丈に、面影白く、ふツと立つた、兩個の見も知らぬ婦人がある。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなら干ぼしになったら、すぐ羽にかわって欄間を飛ぶだろうと思ったほどです。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄間も、壁も、襖も、古く、どっしりして、安普請では無い。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」幸吉は、私と卓を挾んで坐ってから、天井を見上げたり、ふりかえって欄間を眺めたり、そわそわしながら、そんなことを呟いて、「おや、床の間が少し、ちがったかな？",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、庭が白いと、目に遮った時は、スッと窓を出たので、手足はいつか、尾鰭になり、我はぴちぴちと跳ねて、婦の姿は廂を横に、ふわふわと欄間の天人のように見えた。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "銑吉は御堂の格子を入って、床の右横の破欄間にかかった、絵馬を視て、吻と息を吐きつつ微笑んだ。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家屋は日本風であるが海に向つて開いた玄関、廊下、翼家の欄間には流石に紅や黄の窓硝子が箝められ、庭の隅々にはまた紅い松葉菊を咲かしてあるといふ風に、如何にも異国趣味の瀟洒な住宅であつた。",
              "citation": {
                "source": "雲母集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お岩はそれを取られまいとして争っているうちに、どうした機か刀が飛んで欄間の下へ突きささった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の途端に欄間の上から大きな鼠が猫を咬えて出て来たが、すぐ畳の上へ落とした。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてはと愈々心して欄間の五百羅漢像をかへり見るに、これ亦一つとして仏像に非ず。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はちょっと考えた後で、弓を持ってそこの柱へすらすらと登って、欄間から梁の上へ往った。",
              "citation": {
                "source": "申陽洞記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズはその冷い痩せた指を私の手首にまいて、天井の高い下をぐんぐん進む、私は朧にドーアの上に、欄間窓を見止めた。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖師堂は典正なのが同一棟に別にあって、幽厳なる夫人の廟よりその御堂へ、細長い古畳が欄間の黒い虹を引いて続いている。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞け――時に、この虹の欄間に掛けならべた、押絵の有名な額がある。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "面影も、色も靉靆いて、欄間の雲に浮出づる。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄間にござる天女を、蛇が捲いたような、いや、奥庭の池の鯉を、蠑※が食い破りましたそうな儀で。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　二階の階子壇の一番上の一壇目……と思う処へ、欄間の柱を真黒に、くッきりと空にして、袖を欄干摺れに……その時は、濃いお納戸と、薄い茶と、左右に両方、褄前を揃えて裾を踏みくぐむようにして、円髷と島田の対丈に、面影白く、ふッと立った、両個の見も知らぬ婦人がある。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓子台の上は冬の花野で、欄間越の小春日も、朗かに青く明るい。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子の日影は、桟をやや低く算え、欄間の下に、たとえば雪の積ったようである。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄間から、薄もみぢを照す日影が映して、大な番火桶には、火も消えかゝつて、灰ばかり霜を結んで侘しかつた。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、横の襖に、それは欄間に釣って掛けた、妹の方の明石の下に、また一絞りにして朱鷺色の錦紗のあるのが一輪の薄紅い蓮華に見えます。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で欄間に三枚つづきの錦画が額にして掛けてある。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三依は二三十戸の小村であるが、材木と葺草とに不自由の無い爲めか家の構造は頗る大きく且つ岩疊で、戸袋や欄間には意外な裝飾が施してあるが、之に對して障子が煤けて破れたり座敷が埃だらけの樣子だから可笑しい。",
              "citation": {
                "source": "痍のあと",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "愉快な奴じゃないか、こんなに沢山の人間が居るのに、知らんまに這入ってきて、×くだけ××を×いたら、また、知らんまに出て行っちまって居るんだ。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兇徒あり、白刃を揮いて背後より渠を刺さんか、巡査はその呼吸の根の留まらんまでは、背後に人あるということに、思いいたることはなかるべし。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのうえおかしいことに、大きい目は、美しい、なごやかな、てんしんらんまんな心をのぞかせているのに、小さい目は、いんけんで、ひねくれていて、狡猾なまたたきをするのである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
