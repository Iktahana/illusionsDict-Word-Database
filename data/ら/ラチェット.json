        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてラチェットのところへ行って、鼠を二十八匹売った。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜酒場でラチェットさんに会ったら、丁度いい機会だと思って、貴様が鼠を幾匹売りつけていったかと訊ねたんだ。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は老人レッドから盛んに鼠を買いあげるラチェットなる人物は、この軍用鼠の研究家であった。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "真珠の密輸は、生れつきの密輸趣味者レッドが鼠をラチェットに売る片手間にこれに托して真珠密輸を企てたのであって、その所得は悉くレッドのものとなっていた。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラチェットはその真珠事件に無関係であった。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
