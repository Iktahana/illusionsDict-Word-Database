        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "タマラナイ興奮と、恐怖のために全身ビッショリと生汗を流しながら、身動き一つ出来ずにいた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔が一つ一つにタマラナイ程引き歪められているのは、死人の腥い臭気に鼻を撲たれているせいばかりではなかった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――オマエハ、バカダカラ、シラナイノダ。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドウ　シタノデセウ」「マダ　ネンネシテルノカシラ」「ワタシタチガ　モウ　オメメヲ　ヒライタ　コトヲ　シラナイノカシラ」「モウ　ハルガ　キテルノヲ　シラナイノカシラ」　ソコデ　花タチハ　マダ　ヒラカナイ　ツボミヲ　オコシニ　カカリマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オ前タチ、デンデンムシノ　ウタ　シラナイカ」ト、オソバノ　モノニ　キイテモ、「シリマセン」ト　イツテ　クビヲ　カシゲテ　ヰマス。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナンダ　カナヅチカ、オンナジヤウナ　カタチヲ　シテ　ヰルガ、フエハ　ヨイ　オトヲ　タテヽ　ナルノニ、カナヅチハ　ナンニモ　ナラナイ。",
              "citation": {
                "source": "カナヅチ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「フーン」小サイ　デンデン蟲ハ、オカアサマデモ　ワカラナイ　フシギナ　トホイ　ソラヲ、ホソイ　メヲ　一パイ　ノバシテ　イツマデモ　ミテ　ヰマシタ。",
              "citation": {
                "source": "デンデンムシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワタシハ　ワタシノ　カナシミヲ　コラヘテ　イカナキヤ　ナラナイ」　ソシテ、コノ　デンデンムシハ　モウ、ナゲクノヲ　ヤメタノデ　アリマス。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソウダ、コノ　キノドクナ　ヒトビトヲ　タスケテ　ヤラネバ　ナラナイ」　ヲトコハ　アチラ　コチラノ　ムラニ　ノコツテ　ヰル　ヒトビトヲ　ヒトトコロニ　アツメマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミチコサン新美南吉　ミチコサンガ、コトリヤノ　マヘマデ　クルト、シラナイ　オバサンガ、ウバグルマノ　ナカノ　ニモツヲ　ナホシテ　ヰマシタ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫ガ病人ニナッテシマッタノダカラ残念デタマラナイノダガ、君ノ手紙ヲ見テ西洋ヘ往タヨウナ気ニナッテ愉快デタマラヌ。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "フウセンハ、「ボク　シラナイ」ト　イヒマシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ボク　ドコヘ　イクンダカ　ワカラナイカラ、テフテフサン　モウ　オカヘリヨ」ト　フウセンダマハ　イヒマシタ。",
              "citation": {
                "source": "ツイテ　イツタ　テフテフ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマキチ　ハ　コマッテ、ボク　ハ　ヤマニ　ソダッテ　オヨギ　ハ　シラナイ。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト　モウシマス　ト、サカナタチ　ハ、サモサモ　バカ　ニ　スルヨウニ、ワラッテ　オヨギ　モ　シラナイデ　ウミ　ニ　クルナンテ、キミ　ハ　オオバカサンダ　ト　イッテ　アイテ　ニ　シテ　クレマセンノデ、ヤマキチ　ハ　コンド　ハ　ナミ　ニ　ムカッテ、ボク　ヲ　オヨガセテ　クダサイ　ト　タノミマシタ。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "理窟ではなく、アヽツマラナイナアといふ腹の底からの感じ）一切の努力を抛棄して了ふのだ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のかがやき、太陽の黄色い臭気なぞ……それは今思い出してもウンザリして唾を吐きたくなる位ですが、そうした太陽の下のタマラナイ感じの数々を、私はソックリそのまま「白昼夢」の中に発見したのです。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそうした諸般の演出物は、或は芸術的の迷妄に陥り、又は民衆に媚びて堕落し、又は儀礼的に高踏し過ぎて、芸術的の迷妄や行き詰りに陥りつつも、何かしらより高尚な、より充実した……或るタマラナイ表現慾を満足させ得べき芸術……すなわち能を生み出すべく、生みの悩みを続けていたものらしい。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろＡは私という奇妙な人間を発見して、タマラナイ好奇心を挑発されて行くうちに、いつの間にか悪魔的な、残虐趣味の世界へ誘い込まれて行ったもの……と考えてやった方が早わかりする事です。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに畳ボートを押し出して、危険を犯しながら激流の中を探しまわりました、そのうちに、どうしても私の死骸が見付からない事がわかりますと、今度はタマラナイ空恐ろしい気持になって来ました。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンナツマラナイ素描帳ヲ見テクダサイト言ウノハタイヘンツライノデス。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシ私ハイツワラナイデ始メタ時カラノヲ全部送リマシタ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……二ヶ月分の間代、食費、薬価、牛乳屋の払ひ……それ位ひは済しても大丈夫余裕はあるとは思つたが、何だかそんなツマラナイ物の為にむざ／＼幾分でも金を傷けることが……いや、それよりも此愉快な空想を実現さすべき道程にそんな不快な時間を差挟むのが面倒な気がして。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると件の書生は、先生の序文で光彩を添えようというのじゃない、我輩の作は面白いから先生も小説が好きなら読んで見て、面白いと思ったら序文をお書きなさい、ツマラナイと思ったら竈の下へ燻べて下さいと、言終ると共に原稿一綴を投出してサッサと帰ってしまった。",
              "citation": {
                "source": "露伴の出世咄",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "女車掌というものがドンナに嫌らしい、淋しい、恐ろしい、ツマラナイ運命を持っているものかおわかりになって？",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコヘ上ルノニ、トチュウデ何ンベンモヤスンデ、イキヲ入レナケレバナラナイノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "君チャンノオ母ッチャハネタキリデ、目アナガウントヒッコンデ、ダマッテミテイルト、イキヲスルタビニウゴイテイタフトンガ、ダンダン分ラナイグライニナッテキタノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "アル日、オ母ッチャガ、君チャンニ、マイバン目ヲサマシタラ、オ母ッチャヲユリオコシテミテクレ、イツソノママ死ンデルカ分ラナイカラ、ト云ッタ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
