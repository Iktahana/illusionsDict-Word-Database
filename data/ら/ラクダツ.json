          "literary": [
            {
              "text": "帰宅したとてもお勢の顔を見ればよし、さも無ければ落脱力抜けがする。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時すでに繍糸の落脱したところもあって亀甲にしるされた繍文の解読に苦心をはらうほどだったが、まだその原形をそこなうまでには至らなかった、併し、徳川中紀の頃には已に今日みるような小断欠になってしまっていた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくだつたのう。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙酔楼君と逢ふ、まことにしばらくだつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩釜様のお山の杉の樹々は下の谷からまつすぐに空を被ふやうにそびえてゐたが、坂道はなだらかで昇りはらくだつた。",
              "citation": {
                "source": "東北の家",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しばらくだつたなア。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            }
          ]
