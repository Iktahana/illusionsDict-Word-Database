    "definitions": [
      {
        "index": 1,
        "gloss": "lampoon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "落首の中に「比類なき名をば雲井に揚げおきつやごゑを掛けて追腹を切る」と云うのがあった。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化のころの落首にも『春の夜の闇はあぶなし槍梅の、わきこそ見えね人は突かるる』とか、又は『月よしと云えど月には突かぬなり、やみとは云えどやまぬ槍沙汰』などというのがありました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はもう落首どころじゃありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "落首というものは、古来、愛すべき民衆の集団的発言の形式であったし、零細な、鋭い可能性把握の一例であった。",
              "citation": {
                "source": "ペンクラブのパリ大会",
                "author": "――議題の抜粋についての感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先達っての選挙のとき、無効になった投票に多くの落首めいたものがあったという噂も、文学の問題としてやはり見落せない事実なのではなかろうか。",
              "citation": {
                "source": "ペンクラブのパリ大会",
                "author": "――議題の抜粋についての感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彌次というものを、庶民的な短評の形、川柳、落首以前のものとして考えれば、その手裏剣めいた効果、意味、悉く否定してしまうことは出来ないけれども、その形そのものが、徳川時代のものであって、彌次馬ほどこわいものはなし、に通じる要素をも持っていることは、やはり考えさせられるものがあると思う。",
              "citation": {
                "source": "待呆け議会風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の徳川末期、町人階級はそれを川柳・落首その他だじゃれに表現した。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど『美』はＡＲＴにはないものと見えます」と、徳川時代の町人文学の一つであった川柳、落首の様式を踏んでいる。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八つ時分三味線屋からことを出し火の手がちりてとんだ大火事」と云う落首があった。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此文書は何者の手に出でたか、同志の干り知らぬものであつたが、其文章を推するに、例の落首などの如き悪戯ではなく、全く同志を庇護しようとしたものと見えた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時の落首ともいふべき、※鼓驚天動地來。",
              "citation": {
                "source": "支那猥談",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが文禄年間になると、「きかぬものたばこの法度銭法度、玉のみこゑにげんたくの医者」と云ふ落首が出来た程、一般に喫煙が流行するやうになつた。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又五郎を旗本の安藤四郎右衛門――講釈の阿部四郎五郎――が隠匿して池田公に喧嘩を吹掛け、　此度は備前摺鉢底抜けて、池田宰相味噌をつけたり　と云うような落首まで立つ位になったから意地として池田｜忠雄公は又五郎を討たずにおれなかった。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この類の禁令はとかくに行われにくいものと見えて、その頃の落首に、　きかぬもの、たばこ法度に銭法度、　　　　　　玉のみこゑにけんたくのいしや。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この類の禁令はとかくに行われにくいものと見えて、その頃の落首に、きかぬもの、たばこ法度に銭法度、　　　　　玉のみこゑにけんたくのいしや。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果がこの頃｜流行の、落首となって壁や塀に、田沼の横暴と世相の乱脈とが、深刻に穿って書かれ貼られた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田沼の忰意知めが、佐野善左衛門に討たれた時に、市中へ張られた落首ではないか」「御意、その通りにござります。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田が沼と、濁る浮世に、ごもつとも、天も変るぞ、地には妖し」「何んだそいつも落首ではないか。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅間山が爆発いたせし際に、田沼を罵って作られた落首だ」「御意、その通りにござります。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天変地妖の起こったをさえ、田沼様の咎にいたしまする、よき例の落首にござりまする」「それがいったいどうしたというのだ？",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これやこの、酒も料理もへらされて、へるもへらぬも、お湯漬の腹」「これも落首にござります」　貝十郎は自分でいった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「柳営より諸役人へ賜わるお料理、老中、若年寄はお湯漬けにてよろしく、お側衆、評定衆の面々は、一汁一菜香のものにて結構と、田沼様おきめ遊ばされました際に、お城坊主が作りました、勤倹令嘲笑の不届きの落首で」「その通りじゃ、それがどうした？",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の頃の落首に「本所に過ぎたるものが二つあり津軽大名炭屋鹽原」と歌にまで謡われまして、十万石のお大名様と一緒に喩えられます位になる其の起源は、僅かの端銭から取立てまして、五代目まで続きました。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに我々の立場はといへば、怪我の功名でも良いし、落首を拾つてゞも天下に名を成したいといふ野武士のやうな魂胆で、少しぐらゐ不純だつて世間に受ければ良いぢやないか、といふサモしい量見をかくしてゐる。",
              "citation": {
                "source": "処女作前後の思ひ出",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "主をきり聟をころすは身のをはり、昔は長田、今は山城　というのが、当時の落首だ。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く江戸時代から時世諷刺御政道を云々したり、時局を痛憤揶揄したりした落首的のものが多い。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "五渡亭国貞は「歌川を疑はしくも名乗り得て二世の豊国｜贋の豊国」の落首に諷刺せられしといへどもとにかく歌川派の画系をつぎ柳島と亀井戸とに邸宅を有せしほどなれば、当時の地位は国芳の上にありしや明かなり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑稽諷刺の意をあらはさんとするやたまたま落首の一変体ありしといへどもいまだ完全なる一形式をなすに至らざりき。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう時には何か一首｜巧い落首でもやって内所でそっと笑っているが関の山で御座います。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「落首といえばそうそう、昨夜先生がお帰りになってから鶴屋の旦那に聞いた話で御座りますが、あの和泉町の一勇斎国芳さんが今度の御政事向の事をばそれとなく「源の頼光御寝所の場」に譬えて百鬼夜行の図を描き三枚続きにして出したとかいう事で御座ります。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
