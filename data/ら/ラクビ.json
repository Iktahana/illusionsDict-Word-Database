        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十月廿五日　晴、行楽日和だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日曜の祭日、絶好の行楽日だけれど、お天気が思はしくない、何だか気の毒に思ふ、嘆くなかれ、むろん悔いるなかれ、人々具足、ほどよく楽しめ。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽日和、掃除日、風の日。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽日和、学校には運動会が開かれ、山野には子供を連れてのハイカーが多い。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はどうやら雨らしい、せつかく行楽日、降らなければよいが。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋季皇霊祭――彼岸の中日――行楽日和。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽日の行楽人、善哉、善哉。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節は初夏ながら是れが大連の春祭であり、在留の邦人に取つて今年最初の行楽日である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "参詣した時に奏する当座の神遊びもあるが、大社には貴人との約束で、定祭以外に、年中行事となつた奏楽日もある。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると猫の子供らは、しばらくびっくりしたように、顔を見合わせていましたが、やがてみんな一度に立ちあがって、「なんだい。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは、自らくびれて、甲斐なき命絶ち、四、五日、人の心の片端、ひやとさせるもよからむ。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓子の中央は両側からくびれていて、そこにふたりの取締人―― Croupier が向い合って座を占める。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アアア私は何て幸福なんだろう、私はどうしてこううれしくなれる心をもって居るんだろう」　ほほ笑みながらくびをふってはね上る様な心になって居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さア左様いう風でございますのに、また一人お若さんが出来て、子供までつれてお出なされたんですから、鳶頭の驚きまするは当然で、幾らくびを曲げ眉毛に唾をつけましても、その理由はわかりません。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやねえ、お通夜みたい……」七　額ぎわからくびすじへかけて、ぐつしよりの汗を、康子は、無造作にハンカチでふきながら、「あゝ、いゝ気持だつた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "松岡は蝋燭の火かげで、ずるずると長い影を引いたものが、階段裏からくびれているのを目に入れた。",
              "citation": {
                "source": "三階の家",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからくびすを転じて、帰途についた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若い牝鹿がさきに渡り、あとからくびじろが、それを追って渡ったです」「西からか東からか」「東からこっちへです」「いつだ」「今日の八つさがりです」　甲斐は「よし」と頷いた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが鞘がないと、君たちは恐らくびた一文も払わないだろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
