[
  {
    "uuid": "aa0eaf2c-9194-591d-b299-c4675b83110c",
    "entry": "拉薩",
    "reading": {
      "primary": "ラサ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
