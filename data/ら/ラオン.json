        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なお見ていると、小さな石一つ、沢の上から落ちて、豆太鼓でも鳴らすような、カラカラ音をさせると見ると、砂煙がぱッと立って、二、三丈ばかりの砂夕立が降る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がなかったので、その一つ一つが、いかにものんきに、フラフラ音もさせずに降っていた。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "花見の折からで「サクラ音頭」なる囃子が隆盛を極めてゐた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "花見の折からで「サクラ音頭」なる囃子が隆盛を極めていた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は和尚さんもうかれ心になって雪駄を買って、チャラチャラ音をさせて、明るいにぎやかな春の町を歩いたという。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にガラガラ音をさせて、上が箱型になつた荷車を引いて來たものがある。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉蘭なぞはバラバラ音がした。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の房々した髪は櫛の歯があたるたびに、パラパラ音をたてて空へ舞い上った。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上半身をズーッと下げて、下の板間に敷いた紙にサラサラサラサラ音を立てながら素早い手付きで髪を梳いて居る姿、湯上りの輝いた顔を涼風に吹かせて凝り固った様にして居る様子等は、皆重三に自分とはまるで異った美くしいものだと思わせた。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、水に近い楊の枯枝が船の屋根に触れて、それを潜り抜けて行く時にはバラバラ音がした。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上のものはガラガラ音がするし、どうも大股でわざと音を立てているらしい。",
              "citation": {
                "source": "純粋の声",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩の風化作用に抵抗する力が比較的弱い所為か、崩壊甚しく、ガラガラ音を立てながら絶えず落下している岩屑は崖の下に堆く積って、凄惨な光景を呈出している。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう暮れきっているのに白々と明るい庭一面の雪の上へ、まだサラサラ音立てて雪が降っている。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中から四｜枚、金貨をつかみ出して、食卓の上にならべ、わざとらしくチャラチャラ音をさせた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き耳を立てて、砂利道を走る馬車のガラガラ音を恐れているようだった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "初期の郵便飛行機に乗っているくらいなプロペラ音と震動である。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
