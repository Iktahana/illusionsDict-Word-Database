[
  {
    "uuid": "7c0ca180-3297-51cc-99d5-7108f25f32a3",
    "entry": "乱立",
    "reading": {
      "primary": "らんりつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
