    "definitions": [
      {
        "index": 1,
        "gloss": "pattern made from chrysanthemums with disordered petals (esp. used on family crests)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
