        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アメリカン・レビューにはそういう古典的な意味での音楽などはない代りに、オリンピックのグラウンドや拳闘のリンクに見らるる活力の鼓動と本能の羽搏きのようなものをいくらかでも感ずることが出来るのであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十一回目のラウンドで、審判者はＴＫＯの判定を下してベーアの勝利となったが、素人がこの映画を見ただけでは、どちらもまだ何度でも戦えそうに見え、最後に気絶して起きられなくなるようなところはこの映画では見られなかった。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "りんごをかじりながら街頭をあるくよりも、環視の中でメリーゴーラウンドに乗るよりもむしろいい事かもしれないのに、何かしらそれを引き止める心理作用があって私の勇気を沮喪させるのであった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画を見た晩に宅へ帰って夕刊を見ると早慶三回戦だかのグラウンドの写真が大きく出ている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかおおぜいで先生を引っぱって浅草へ行ってルナパークのメリーゴーラウンドに乗せたこともあったが、いかにも迷惑そうではあったが若い者の言うなりになって木馬にのっかってぐるぐる回っていた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に於て、作者は成るべく自己の生活をバツク・グラウンドに追ひやつて、世相を輕い熱度を以て取扱つて、そこに作家の哲學をほのめかさうとしたやうに見える。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野球は其樣な災難が無いから、毎日／＼盛んなものだ、丁度海岸の家から一｜町程離れて、不思議な程平坦な芝原の「ゲラウンド」があるので、其處で「アウト」「ストライキ」の聲は夕暮の空に響いて、審判者の上衣の一人黒いのも目立つて見える。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ光線　電車会社の大きなベースボールグラウンドが、村外れの松原を切り開いて出来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに負けまいとメリーゴーラウンドの台が浪を打って廻転する。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次から次へと球を渡しながら、十人ばかり横に並んだのが一斉にグラウンド一杯に走り出して、パススィングの練習をはじめた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラウンドに続いた丘を少しのぼると、そこには小さなプウルが出来ていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸行無常のメリーゴーラウンドに乗っているこどもです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も人生を諸行無常のメリーゴーラウンドと感じて、楽みを恣にするときの人間の哀れさを胸に覚え出したためでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いランニングシャツを着た男が、グラウンドのほの暗い電燈の光を浴びて、自転車の稽古をしている。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなしやメエリイゴラウンド、さみしや手品の皿まわし、春の入日の沈丁花がどこやらに。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一はひとけの無いグラウンドに突っ立って紙幣を便箋からはがしてポケットへねじこんだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラウンドの隅に建っている寄宿舎はわりに静かだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗いグラウンドに佇んでいると、いきなり肩を敲かれた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄宿舎を出ると、豹一は新築校舎の二階にある自分の教室へ行き、グラウンドに面した窓から仮装行列を見た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金でパンを買って、皆んなでグラウンドへ担いで行き、グラウンドを一周してから代表者がそのパンを養老院へ持って行って寄附することにすれば、下手な仮装よりもぴりッと利いて面白く有意義ではないだろうかと、半なにか偽善者のように思われやしないかと心配しながら、一人一件という義務通り提案したのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画女優の村口多鶴子がキャバレエ「オリンピア」のラウンドガールになったという、いまならさしずめ黙殺されるか、扱うにしても遠慮して小さく扱われそうな記事なのだが、当時はこんな記事が特種として、あらゆる新聞の三面に賑かに取扱われていたのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラウンド・サーヴィスするだけの報酬が、一晩何百円だと新聞に報ずるところも、満更誇張とは思えなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "送信前のデータ圧縮時には他の仕事を受け付けないが、一応バックグラウンドで送受信可能である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこれらをバックグラウンドで処理してくれるという寸法である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラウンドに現れた選手は身振りよろしく空を蹴つて、グルグルと飛び回る、ボールを奪ひ合ふ様がある、一勢に脚をふまへて縦にそろつて、脚から脚の間を球をうけ渡して行く様がある――それツ！",
              "citation": {
                "source": "舞踏学校見物",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベース・ボールの選手が乾燥したグラウンドに各自その膂力を振つて居る外屋外に人を見ることが少なくなつた。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、水の中に入らねばしのげないという日盛りの暑さでもないのに、夕方までグラウンドで練習していた野球部の連中が、泥と汗とを洗い流し、且つは元気をも誇るために、例の湖へ出かけて泳いだ。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、代々木の練兵場ほども広いグラウンドに出た。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラウンドには眼をさえぎる何物もない。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
