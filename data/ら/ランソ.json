    "definitions": [
      {
        "index": 1,
        "gloss": "excessive or unreasonable legal action",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
