    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rug",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「議論するなら勝手にしやれ、あとでゲンコの雨が飛ぶ」――茲に、低俗プラグマチックの、象徴がありはしないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年の暮にサント・ジュモンが始めて成効した時に飛んだ距離はわずかに二十五メートルであったが、この頃ファーマンやドラグランジュの飛行した距離は二万メートルに近く、すなわちわずか二年の間に飛行距離は八百倍になった訳である。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ラグビーを見ているときだけ男の魅力を感ずる。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "万々　「メム」は沼またラグーン。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一片の麩を争う池の鯉の跳躍への憧憬がラグビー戦の観客を吸い寄せる原動力となるであろう。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名利観に限らず、この著者は色々な点で人間の人間らしい人間性というかあるいは弱点というか、そういうものを事実として肯定した上で、これに対するプラグマチックな処世道を説いているようなところがある。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間でも内耳の病患で三半規管に故障が起るとグラグラして直立歩行が出来なくなる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等學校ではラグビーをやつてゐたことがある。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ラグビー争闘の場合の靴の跡を刺繍され、……野球における華美な盗塁と、……水球のときの潜水と、……ミニチュア、ゴルフの墜死と、……ボクシングにおける残酷な、……マットの中の死を。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スマラグド色の眼と石竹色の唇をもつこの雄猫の風貌にはどこかエキゾチックな趣がある。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうものの中でもファラデー、ヘルムホルツ、マッハ、ブラグなどのものはすぐれた例である。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが左右にグラグラ揺れ動きながらやって来る。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによって自分の本然の仕事がいくぶんでも能率を上げることができれば、少なくも自身にとっては下手な芸術や半熟の哲学や生ぬるい宗教よりもプラグマティックなものである。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がグラグラするほど酔っていたことを記憶している。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラグラと頭をシャンデリアの方向に仰向けて、健康そうな、キラキラ光る白い歯を見せた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は今日のようなグラグラ政府には飽きられただろうと思う、そこでビスマークとカブールとグラッドストンと豊太閤みたような人間をつきまぜて一鋼鉄のような政府を形り、思切った政治をやってみたいという希望があるに相違ない、僕も実にそういう願を以ています、しかし僕の不思議なる願はこれでもない。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも曲の体裁を知るためと思って我慢して聞いていると、店員が何かぐあいでも直すためか、プラグを勝手に抜いたりまたさしたりするのでせっかくのシンフォニーは無残にもぶつ切れになってしまった。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一パイ飲んだらしく、赤い顔をピカピカ光らして、二人の前の椅子にドッカリと腰をかけると、酔眼朦朧とした身体をグラグラさせながら、いろんな事を尋ねては帳面につけた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生畜生……二人で夜の眼を寝ずに働いた養蚕の売り上げをば……いつまでも渡らぬと思うておったれば……エエッ……クヤシイ、クヤシイ」　しかしいくら小突かれても若い主人はアヤツリのようにうなだれて、首をグラグラさせるばかりであった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に茶道の如きは、日常起臥の生活を直ちに美化しようとするのであって、芸術的プラグマチズムの代表であり、日本人の Life に対する極端な現実的観念を、最もよく語っている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二はい飲んでグウラグラ。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フウラフラのグウラグラ。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちが焼酎を一升飲んでグウラグラになった、ちょうどあれくらいの気持で、この女類という生き物が、まじめな顔つきをして買い物やら何やらして、また男類を批評などしているのではないのかね。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラグビイの方でも見に行ったのであろう。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "………三　ラグビイの選手達はもうみんな引揚げてしまって、運動場には誰もいなかった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八九日あたりの月がラグビイの球に似た恰好をして寒空に冴えていた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の所を煩悶解決所と心得て一人で喋舌って帰るのでね」　なぞとズバズバやるので、相当気の強い連中でもグラグラと参ってしまう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺あ西洋洗濯の宣伝かと思うた」「立てて云うけに俺あ立って聞きおったら、気の遠うなってグラグラして来た。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
