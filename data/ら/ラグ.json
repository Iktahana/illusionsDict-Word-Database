[
  {
    "uuid": "0d23be2e-6fcb-53b5-9a71-d9eb4adaa86b",
    "entry": "ラグ",
    "reading": {
      "primary": "ラグ",
      "alternatives": [
        "ラッグ"
      ],
      "is_heteronym": false
