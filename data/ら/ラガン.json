    "definitions": [
      {
        "index": 1,
        "gloss": "bare eyes (i.e. without glasses, contact lenses, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
