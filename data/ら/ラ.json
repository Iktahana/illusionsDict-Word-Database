  {
    "uuid": "dcc62d30-22b5-5fc7-9d62-daf9f439f615",
    "entry": "羅",
    "reading": {
      "primary": "ら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
