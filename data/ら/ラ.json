    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Latin (language)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
