        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして十月の七日の朝、大きな石を入れる時に、その石と一緒に、クラッシャーの中へ嵌りました。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでもいいけど、北尾の茶番のお相手なんかやっちまったクラッシャー・バンバン・ビガロよ！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラッシャー・バンバン・ビガロの死を悼み、合掌。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプトン・シンクレアは、その小説「資本」のなかで、主人公ゼッド・ラッシャーを方々へ引張り廻して、吾々に種々の社会面を見せてくれる。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして主人公ゼッド・ラッシャーは、作者の単なる傀儡にすぎない。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして主人公のジャン・ヴァルジャンもゼッド・ラッシャーも、作者の頭脳的傀儡であって、人間としての生きた心臓はごく僅かしか持たない。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くのカバの樹の梢の枝さきにブラウン・スラッシャー――赤ツグミと呼ぶのをこのむ人もある――が朝じゅう鳴いている。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロモーターたちがもっともおそれていたのは、ただで会場に入ってしまうゲイト・クラッシャーたちだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな交差点で、小川のＣＢ４００は、左のフラッシャーを出した。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園の近くまで来て、小川のＣＢ４００は、フラッシャーを出してとまった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カワサキの、前後左右のフラッシャーがつきっぱなしになっていることに、ぼくは気づいた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
