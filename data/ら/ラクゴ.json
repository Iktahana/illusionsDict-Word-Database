[
  {
    "uuid": "e0503c36-311b-555b-a528-66b3d7fdb9e7",
    "entry": "落伍",
    "reading": {
      "primary": "らくご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
