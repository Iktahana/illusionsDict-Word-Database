    "definitions": [
      {
        "index": 1,
        "gloss": "straggling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、この矛盾に堪えぬものは現代の落伍者である。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "落伍者だと云つて世人から冷罵を浴びせかけられて居る人があるが、俺もその落伍者になつて居るらしい。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "大家とか先輩とか云ふことは、俺の様な落伍者を葬る誄詞なんだ。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本には、いま、ビールどころか、米も芋も食べられない人間がどれだけいるか知っていますか」「知ってるわよ」「知っていて、よくビールが、しかも白昼女だてらに飲めますね」「だって、その人達は結局落伍者じゃないの。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの時代にも落伍者はいるわよ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活能力のない落伍者のことまであたしたちはいちいち考えなくちゃいけないの」「みんな同じ日本人じゃないか」「だって……」　と、宮子は鶴雄のむきになるのが面白いらしく、「――ひとのことは放って置いたらどう……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一羽遅れた鳥が、落伍しまいとして、一生懸命に追ひすがつてゆくのが見られた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民学校の先生になるという事はもう、世の中の廃残者、失敗者、落伍者、変人、無能力者、そんなものでしか無い証拠だという事になっているんだ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この辺で懐中心細くなり、落伍する者もある。",
              "citation": {
                "source": "禁酒の心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワッショイ、ワッショイ」　と表の往来へ走り出した、生魚を陸上るのと、おんなじ呼吸でどこを当てともなくエッサエッサと走り出したので消防組と市場の体験のある者以外は皆バタバタと落伍してアトにはイキのいいピンピンした連中ばかりが残って了った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅沼山に勢揃するに一人の落伍者もなく着いた。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春から第一回の公演として、アンリ・ルネ・ルノルマンの「落伍者の群」を、やるやると歌に唄いながら、結局学校の休暇を待つよりほかなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊手にした指で、ふさふさ落ちかかって来る髪の毛を、しきりと後へ高く掻きあげながら、眼の玉をくるりとむき、唇をとがらせて、「これじゃ我々自身が『落伍者の群』になりそうじゃ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（だって、「落伍者の群」の「彼女」は、貞操まで、お金に換えてしまうんだもの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "出し物のうち、ルノルマンの「落伍者の群」は、稽古が足りない恨みがあるが、どこか新鮮な力の溢れている演出だ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「落伍者の群」なら、新子も読んだことがある。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "雌雄の数が同一でない場合に配偶者をもとめそこねた落伍者の運命はどうなるか。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政界の落伍者の集まりである浪人の多い席であるから、話の落ちて往く処は現代の政党の攻撃であった。",
              "citation": {
                "source": "雨夜続志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落伍した雲の一団が全速力で追っかけていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかのぼって申せば音楽の天才の出た家筋ですが、京官から落伍して地方にまで行った男の娘に、どうしてそんな上手が出て来たのでしょう。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い批評家や作家が、日本画の封建性伝統性を否定することが強くて、肯定する力をソロバンに入れない場合の、所謂、先輩、大家の仕事に対する、無理解は、早晩十畝氏ではないが、マラソン競争の三十周位から、ボツボツと落伍を始めるのであらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木だけが落伍するなんて。",
              "citation": {
                "source": "祝盃",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通二三十人も山路を上るとすれば、必ずや脚健なるものは早く進み、脚弱きものは遙に後れて、ちり／″＼ばら／＼になるべけれども、さすがに軍隊教育を受けし人達なるだけに、歩調一致し、わざ／＼號令せずとも、おのずから一團となり、急進者もなければ、落伍者も無し。",
              "citation": {
                "source": "箱根神社祈願の記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう落伍者は無かるべしと思ひの外、息を切らして走りくる少年あり。",
              "citation": {
                "source": "千葉夜行記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "……わたしはあれから落伍者です。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日では何も昔のように社会の落伍者、敗北者、日蔭者と肩身を狭く謙り下らずとも、公々然として濶歩し得る。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの図書館へ来る幾百幾千という青年が、多少の落伍者はあるとして、それぞれ目的を達して、世の中へ打って出るにもかかわらず、あの爺は永久に下足番をしている。",
              "citation": {
                "source": "出世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の世に希望を失った人生の落伍者が、あてどのない八つあたりの不平と自己嫌悪とに気を腐らして、人生の行路さながらの吹雪道を無目的に歩いているように見える。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでしばらくごそごそしている様子だった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟子はおじぎを一つして、となりの室へ入つて行つて、しばらくごとごとしてゐたが、まもなく赤い小さな餅を、皿にのつけて帰つて来た。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
