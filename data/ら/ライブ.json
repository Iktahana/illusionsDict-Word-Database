        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いかめしい城郭のようなライブラリーも柔らかで憂鬱な霧の薄絹に包まれている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者のＭ君は積分的効果を狙って着実なる戦法をとっているらしく、フランス文学のＮ君はエスプリとエランの恍惚境を望んでドライブしているらしく、Ｍ夫人の球はその近代的闊達と明朗をもってしてもやはりどこか女性らしいやさしさたおやかさをもっているように見えた。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下に挙げてある頁数は、エヴェリーマンス・ライブラリーの中のこの書物の頁数である。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物客が、ドライブしてやって来る。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、昨年の夏であったか、ある日｜丸善の二階であてもなくエヴリーマンス・ライブラリーをあさっているうちにLucretius: Of the Nature of Things. A Metrical Translation by William Ellery Leonard.というのが目についた。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンローの第三巻はこの人の対語訳で、同じものがボーンのポピュラー・ライブラリーの中にも出ているそうであるが、自分はまだこの訳を読んでいない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、これら眼前の問題に対していくらかでも知識を得たいと思ってライブラリーを渉猟しても満足な答解を与えてくれるものはまれである。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お医者様の御診察ではその前にお二人で××にドライブをなすったのが悪かった……ナル程。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校で教わっていた「クライブ伝」や「ヘスチング」になんの興味も感じることのできなくてかわき切っていた頭にあたたかい人間味の雨をそそいだのであった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国の空想小説家は何百年間眠り続けた後に目をさました男の体験を描いているうちにその時代のライブラリーの事を述べている。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其奴引捕へて呉れようと、海陸軍を志願で、クライブ傳、三角術などを講じて居る連中が、鐵骨の扇、短刀などを持參で夜更まで詰懸る、近所の仕出屋から自辨で兵糧を取寄せる、百目蝋燭を買入れるといふ騷動。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか自動車で、ドライブして、搜して囘るほどの金はなし……縁の切れめか、よし原すゞめ、當分せかれたと斷念めて居ると、當年五月――房州へ行つた以前である。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋室の二方にはライブラリ型の棚があり、其処には和洋雑多な書籍が詰っていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは根崎海岸のドライブ道で、道幅もかなり広いし、それに障碍物がないので、運転手はいい気もちになってスピードを出していた。",
              "citation": {
                "source": "焦土に残る怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車は夕暮に迫つて菖蒲が濱から歌が濱へと走つたが、この間のドライブは實に愉快である。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからの人々は自動車ぐらゐは自分で操縱して、遊覽旅行の一程にドライブの一項を※入するやうにならうと想つた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある大衆作家は「新婚ドライブ競争」というような題の小説を書くほどの神経の逞しさを持っていながら、座談会に出席すると、この頃の学生は朝に哲学書を読み、夕に低俗なる大衆小説を読んでいるのは、日本の文化のためになげかわしいというような口を利いて、小心翼々として文化の殉教者を気取るのである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、遠足、日本酒、オートバイドライブ。",
              "citation": {
                "source": "回答",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいたましい変事の記憶がまだ世人の記憶に新しいのに、今度はまた新しい皇帝が皇后とスイッツルの湖畔をドライブしていたとき、不慮の事故を起こして、そのために若く美しいアストリード皇后陛下はその場で崩御され皇帝も負傷され、ただうしろの座席に乗っかっていた運転手だけが不思議にかすり傷一つ負わなかった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年、アップルは初めてマック用のＣＤ―ＲＯＭドライブを売り出しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "国立国会図書館は、保護期間を過ぎた書籍のページ画像をインターネット経由で提供する、「近代デジタルライブラリー」プロジェクトを進めている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "受付をすませ、広めのライブハウスほどの会場に入ろうとした記者や業界関係者は、のっけからビールやウイスキーを手渡された。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "メモリを五百十二キロバイトに拡張した第二世代機に、プリンターと外部フロッピーディスク・ドライブ一台をくっつけたバンドル特価（言うまでもなくアップル用語で、特別に高いという意味だ）は、百万円を越えていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベースとドラムの視線が火花を散らしてドライブがかかったり、ギターの泣き節にピアノがすがったり、ボーカルのためが崩れる一瞬を全員が息を呑んではかったりと、メンバーの鼓動が重なりあう瞬間こそがオレにとっては音楽だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者アンションは宗教上の意地より生国フランスからドイツへ脱走し、プロシャで重用され教育上の功大いに、また碩儒ライブニツと協力してベルリン学士会院を創立した偉人で、その玄孫ヨハン・アンションも史家兼政治家として人物だった。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｉ――の家のパツカードで鎌倉までドライブしたことがあつたけがな。",
              "citation": {
                "source": "老苦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くシーショア・ライブラリーという十銭本だった。",
              "citation": {
                "source": "黒岩涙香のこと",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初ボンス・ライブラリの訳と次に古いフィロゾフィッシュ・ビブリオテークのロルフェスの訳で読んだ。",
              "citation": {
                "source": "読書",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハウプトマン、ズウデルマン、カルル・ブライブトロオなどがこの上もない好い伴侶となつたのである。",
              "citation": {
                "source": "『蒲団』を書いた頃",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の頭の中の歴史的探偵小説に関するライブラリーからオルチー夫人の作品を取り除いたならば、丁度、むかし基督教徒に掠奪されたアレキサンドリアの図書館のようにがら明きになってしまうからである。",
              "citation": {
                "source": "歴史的探偵小説の興味",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
