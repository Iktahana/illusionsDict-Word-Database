    "definitions": [
      {
        "index": 1,
        "gloss": "live (broadcasting, music, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
