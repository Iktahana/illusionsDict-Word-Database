        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シャンゼリゼエ、ボア・ド・ブウロンニュ、モンマルトル、カルチェ・ラタン、……学校の裏山に寝ころんで空を流れる雲を見上げながら幾度僕はそれらの上に思いを馳せたことでしょう。",
              "citation": {
                "source": "十年",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同じくアンドロメヤ属に隷く、小木ラタンカットは北インドに産し、その若葉と種子は牛や羊を毒すといえば、日本の馬酔木もしっかり研究せば、敵の軍馬を鏖殺すべき薬科を見出すかも知れぬ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜のメインディッシュはグラタンだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、グラタンは好きだが、冷えかかったグラタンは好きじゃないな、と考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スプーンから、盛りすぎたグラタンが崩れて落ちた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルチェルラタンを歩いていると、日の暮れかかっている中を、極右の売子が胸に新聞を横にあてつつ叫んで行く。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、ブリュヴァールから河を越え、オペラへ出て、マデレーヌの前をサントノレの方へ曲り、サンゼリゼーからカルチェルラタンまで歩いてみた。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食をとるのに困った揚句五六里も歩いたわけだが、頼みにして来たカルチェルラタンのイタリアの食事場も、主婦がにっこり笑って駄目だと云う。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんば俳諧師でなかつたにしたところで、文部留学生の洋画家が、昼間はカルチエル・ラタンの居酒屋と球突屋で暮し、夜になつて漸と絵具箱を担ぎ出すのが多いのを見ると、蕪村にしても夜｜画をかいたかも判らないのだから。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナムカラタンノウトラヤヤ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の妻で、知名なダンサーであるラタン・デビーのことなどをきいているところへ、女中が名刺を取次ぎ、一人の客を案内して来た。",
              "citation": {
                "source": "思い出すこと",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ハーレー・グラタン氏の調査）日本の軍部は、太平洋戦争で百八十五万人を死なせた。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第八巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝湯――殊に温泉――は何ともいへない心持だ、湯壺にぢとしてゐる時は無何有郷の遊び人だ、不可得、無所得、ぼうばくとしてナムカラタンノウトラヤヤ……。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後からまた左翼、右翼と、続続とつづいて通るあわただしい夜のカルチェ・ラタンである。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢代はパリにいるとき、カルチエ・ラタンで久慈と食事中、傍にいたアンリエットが突然、匂いの強いセロリの茎をぽきりと折って、「ああ、横浜へ行きたい。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は夕飯後によく有名な「リラの庭」と云ふラタン区のキヤツフエエへ行く。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ自動車の中に落ちてゐたなら、自分でそれを持つてゆかずに、仲間の一人に、はい私がどこそこで拾ひましたといつて届けさせ、懸賞の十万フランを山分けにしないのだ」　　　　　　　　　　★　そこは、カルチエ・ラタンの一隅、パストゥウルの並木道だ。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は貴女の詩をあのカルチエ・ラタンの小さなカフエーの詩人達の集りに読み聞かせてやりたい。",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女方がカルチェ・ラタンといふあたりの屋根裏にくすぶつてゐる変屈な若い哲学者に就いて想像したことがおありでしたら、この男が幾らか似たところがあるでせう。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルチエー・ラタンにいる画家とか詩人とかいう人は、特種の職業の人だからという訳で許されているとはいうものの、そうした人達でさえも、劇場はじめ公衆の集る場所へ行く時には、やはり身じまいをしている。",
              "citation": {
                "source": "独居雑感",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の身は今如何に遠く、東洋のカルチェエ・ラタンから離れているであろう。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏奇館斜陽甚しければ、この日園丁に命じて窗前にプラタン樹両三株を植ゆ。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、昼、私一人で、村上さんのいられた、セラタン町の宿舎へ行ってみました。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お昼は昨夜のチキンの残りをきざんで、マカロニのグラタンにしておくれ。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはタラタンの木で糖尿にもいいし胃にも腸にもよい、また神経痛にもよい。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず胃にいい、腸にいい、それから刻んで風呂に入れると神経痛に宜しい、それでタラタン湯と号して飲薬にも薬湯にも用いております。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をしながらラタン町へ上っていった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その格好でグライドはマラタン墓地へ急いだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が｜カルチェ・ラタンの男であるようにお前はカルチェ・ラタンの猫なのかい？",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
