      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "attendance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "又珍らしいことに荻原守衛も来会した。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宴会は病的な人物ばかりを以て催された物であつたから、何れの来会者を見ても、異様な感じを人に与へる代物ばかりで、知らない人が見たら悪魔の集会の如く見えたのであるが、其中でも殊に此青年詩人の唇が自分には眼に着いた。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "右大臣は源氏の君にも宮中で逢った日に来会を申し入れたのであるが、その日に美貌の源氏が姿を見せないのを残念に思って、息子の四位少将を迎えに出した。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三彼女は来会者をながめ知人や好意のもてる人には強く意味ふかい視線を送る。",
              "citation": {
                "source": "託児所をつくれ",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその二輯に、メソジスト派起りてほどもなく、ブリストル辺でその教会に詣る者しばしば一犬遠くより来会するを見た。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "来会の途で、ちょうど寺院から帰る子供に逢うごとに、罵られ石を抛げられた。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その心配が飼い主の変死で無になったので、さっぱり来会しなくなったのだと言ったと載す。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "……幸いに曇天で、……来会者は男女合せて百五十余名の多きに達した。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "園内の数ヶ所で始まっている余興は、それ／″＼に来会した人々を、分け取りにしているのだろう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸へでも行って、少し静養したら何うだと云うのだがね、そう云われると、俺も此の七月以来会社の創立や何かで、毎日のように飛び廻っていたものだからね、精力主義の俺も可なりグダ／＼になっているのだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中氏の一字一句いやしくせぬ訳筆と相まって近来会心の書物であった。",
              "citation": {
                "source": "ルヴエルの『夜鳥』",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "各期生会も全面協力することになり、おまえら馬鹿野郎に裏方やれとはいわねえけどよ、当日は卒業生諸兄姉のご来会を切にお願いするしだいであります。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "来会者もこれで揃ったという時に、青蛙堂主人は一礼して今日の挨拶に取りかかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "開会の辞",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしと前後して、各社の諸君も大抵来会したのであるが、主人側の家橘が顔をみせない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "園内の数ヶ所で始まつてゐる余興は、それ／″＼に来会した人々を、分け取りにしてゐるのだらう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸へでも行つて、少し静養したら何うだと云ふのだがね、さう云はれると、俺も此の七月以来会社の創立や何かで、毎日のやうに飛び廻つてゐたものだからね、精力主義の俺も可なりグダ／＼になつてゐるのだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸米あたりの山々を眺めては休む、周二居についたのは五時前、酒はお断りしてライスカレーを頂戴する、暮れて樹明君も来会、奥さんやお嬢さん方もいつしよに句作する、そして最後は御馳走になる、まことにしめやかな会合ではあつた、私も甘やかされて健の話をした、息子自慢が出来るオヤヂではないのに！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は柿の会第二回句会を開催する、来会者は六名――一洵、月村、柳女、布佐女、和蕾、無水――だけだつたが、親しみのある会合であつた、夕方一先づ散会、一洵無水和蕾の三君は居残つて、朱鱗洞の句碑建設について相談した。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "来会者も寥々としていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後はこの部屋で、三八九会第一回の句会を開催した、最初の努力でもあり娯楽でもあつた、来会者は予想通り、稀也、馬酔木、元寛の三君に過ぎなかつたけれど、水入らずの愉快な集まりだつた、句会をすましてから、汽車辨当を買つて来て晩餐会をやつた、うまかつた、私たちにふさはしい会合だつた。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "……夜は句会、敦之、朝雄二句来会、ほんたうに親しみのある句会だつた、散会は十二時近くなり、それからまだ話したり書いたりして、ぐつすり眠つた、よい一日よい一夜だつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも有名なのは、天平宝字二年二月、式部大輔中臣清麻呂の宅で宴会のあつた時、来会者の大伴家持らが目を山斎に属して作つた歌三首であるが、それは芸術的に見ても馬酔木の感じを立派に出してゐるものだ。",
              "citation": {
                "source": "あしびの花",
                "author": "土田杏村",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百、保、矢島｜優、陸、水木、比良野｜貞固、飯田｜良政らが来会した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾に左袒する者は、檄の至るを待ち、叡山に来会せよ。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "来会者に蘭軒の門人多き所以である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "来会者は各数行の文を書して榛軒に寄せた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは来会者へ纏頭に出される衣服類、主賓の大臣への贈り物の品々等である。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "花散里夫人、明石夫人なども来会した。",
              "citation": {
                "source": "源氏物語",
                "author": "御法",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえはうずのしゅげはすきかい、きらいかい」　蟻は活発に答えます。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のおさらいかい」「馬鹿なことを云わずに早く出て来たまえ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
