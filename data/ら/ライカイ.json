[
  {
    "uuid": "e6076b94-d45e-5669-b4bb-8afe44aa757b",
    "entry": "来会",
    "reading": {
      "primary": "らいかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
