    "definitions": [
      {
        "index": 1,
        "gloss": "(sexually) immoral",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
