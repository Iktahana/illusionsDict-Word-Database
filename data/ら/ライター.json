    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lighter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "老妓は船の中の仕切りに腰かけていて、帯の間から煙草入れとライターを取出しかけながら「いい景色だね」と云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機や潜航艇の所在を探知する方法について絶えず軍務当局から相談を受け、また一方では国民科学研究所と航空研究顧問委員会の軍事的活動の舞台でも主役を勤めていたので、その頃の彼の書斎は机の上も床の上もタイプライターでたたいた報告書類などで埋まっていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "発信機の方はピアノの鍵盤のようなものにアルファベットが書いてあって、それで通信文をたたいて行くと受信機の方ではタイプライターが働いて紙テープの上にその文句をそっくりそのままに印刷して行く仕掛けである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、タイプライター刷のような事務的な男の言葉がつづいた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイプライターと、夕刊新聞のタクシーと、自転車で疾走する給仕の金ボタンと、江東一帯の工場地から聞える仕事始めのサイレンの音響と人物の交錯のなかを、太田ミサコは小肥なボッブの昨夜の女記者の太い脚がアスハルトの道路をふんでやってくるのを認めた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "有閑者がこの街を自分の調査機関のようにたえまなく往来して、記憶をタイプライターで刷りあげると、不生産的な、非社会的な報告書しかつくれないような愚な街であった。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからチョッキのかくしからライターをぬき出して顔の正面の「明視の距離」に持って来ておいてパチリと火ぶたを切る。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気が悪かったり、食堂がきたなかったり、騒がしかったり、また食事がまずいような場合には、同じライターの同じ炎の中に同じような星が輝いても決してこうした幻覚が起こらないから不思議である。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイプライターの音は機関銃にも、鉄工場のリベットハマーの音にも類しうる可能性をもっている。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の壁に添った棚には、黒いタイプライターのようなものが三列に百でもきかないくらい並んで、みんなしずかに動いたり鳴ったりしているのでした。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、回転椅子に掛けて、つかぬライターをしきりにカチカチさせていた男、世界文学社の若い社長で小田と同窓だったという島野二三夫がいきなり、「云われたよって、誰にだ……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小郷を殺してから、財布を盗んだと……」　と、司法主任は小田にライターの火を貸した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライターの石がなくなっちゃったもんだから……」　少年らしい虚栄だった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊都子の用事とは、日本橋の某商事会社でタイプライターを購入すること。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人にも一本勧めて、それからライターで二人の煙草に火をつける。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋座の手紙は、タイプライターで打たれている。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス人のブローカーが彼の居間に自由に出入して殖民地の一獲千金的紙上利益をタイプライターが創造しているだけの計画書を示し、彼に荘重な約束手形の署名をさせるようになった。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "声も若かったが、木崎がライターの火をつけると、まだ大人になり切らない娘の顔が、ぱっと白く浮び上り、十七か八であろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　貴子がダンヒルのライターをつけようとしている間に、章三はもうマッチを擦っていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンヒルのライターには、マッチを擦った時のぽっと燃える感じがない。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "シナリオ・ライターも同様で、日本の映画が見るに堪えぬ最大の原因は彼等の書く科白のまずさである。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから悠々と金口煙草を一本出してライターを灯けた。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いって夫人は、自分の赤革のケースから、スリー・キャッスルの細巻を出して、青年がライターをつけてくれるのを待った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばタイプライターをたたいたり、ピアノをひいたりするような動作でもどうかするとひどく胃にこたえる事がしばしばあった。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は今もう少しであなたをタイプライターを打ってる人と間違えるところでしたが、もちろんあなたは、音楽家ですな。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「タイプライターも人間の筆跡同様、個々によってまったく異なるものなのです。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はこのところ、別のささやかな論文を書こうと考えてまして、それはタイプライターとその犯罪との関係についてです。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにタイプライターの癖には気づいていたから、職場の住所宛でこの男本人に手紙を送って、ここに来られるかと訊ねた。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりあえず出版社に入ればライターになる段取りが見えるだろうと考え、求人広告を見つけては履歴書を送りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
