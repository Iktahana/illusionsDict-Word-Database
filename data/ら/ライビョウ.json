        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「らい病のことを紀州ではさう云ふてる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひとはらい病だと聞いていたけれど、そんな事はどうでもいい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうお年寄りのことどすさかい、この間からえらい病気でむつかしい言うて息子はんたち心配してはりますところへ、知った人さんから頼まれて私が付添いに来てますのどす。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前なんか子供は二人とも大学を卒業するし、少しぐらい病気になったって、申し分はないんだ。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それくらい病中の余は自然を懐かしく思っていた。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはえらい病気でとても助かるまい。",
              "citation": {
                "source": "夢と文芸",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "が直ぐどうなるかと思うくらい病的にわなわなと震え出した。",
              "citation": {
                "source": "香爐を盗む",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁はらい病に冒されたようである。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
