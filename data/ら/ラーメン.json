[
  {
    "uuid": "e798315f-25c8-51e2-a223-09f238d3c43f",
    "entry": "拉麺",
    "reading": {
      "primary": "ラーメン",
      "alternatives": [
        "らーめん",
        "らあめん"
      ],
      "is_heteronym": false
    },
    "grammar": {
