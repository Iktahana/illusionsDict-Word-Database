[
  {
    "uuid": "78986756-4360-5b39-be35-a1802a338a03",
    "entry": "卵巣",
    "reading": {
      "primary": "らんそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
