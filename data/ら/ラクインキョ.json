    "definitions": [
      {
        "index": 1,
        "gloss": "comfortable retirement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
