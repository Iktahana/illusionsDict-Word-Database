        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おそろしい程深い蒼い川で、ライン川とはこんなのではないかしら、と私は頗る唐突ながら、そう思いました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時その群れの一つがヨーロッパに出かけて、ドイツという国を流れているライン川のほとりまで参りました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛唐がライン川をドイツの木曾川とも蘇川峡とも呼ばないかぎりはね。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライン川とマイン川の合流点に位置するこの町は、古くから交通の要衝として栄えたといいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリ、モンペリエ、ドイツ、ケルン、ウィーン、の紳士諸君、およびライン川とドナウ川に養われた人たち。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライン川上流の100マイル以内のバーゼルで有名な印刷業者フロベニウスが病気にかかっていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族はヴェーゼル（ドイツのライン川沿い）から移住していたので地名をラテン語の形容詞にしてヴェサリウスと呼ばれるようになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戦争が始まるとライン川とオーデル川のあいだのすべての領土では広範で強力な反乱が起きる。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライン川地方の医師ラーデマッヘルはパラケルススの教えをシステムにして「実験医学」と名付けた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペストは数年のあいだフランドルに留まり次いでウェストファリア（ドイツ北西部）、ライン川を下り、ノルマンディに入り、スイスおよびオーストリアには1668年に到達した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に感染は「ペルシアからライン川の岸まで」世界のすべての隅まで広がりガリア族やゲルマン族まで及んだ。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤痢は赤い軍として「自由、平等および友愛」に味方しプロイセン軍は実働の３万人だけが残ってライン川に沿って後退した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　ヘルグラインがわくわくして待っていると、四、五日してインデアナから返事が来た。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
