          "literary": [
            {
              "text": "八月二十四日（水曜）　きのう学習院から手紙で、どうしても来学期から来て呉れるようにと云って来る。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "よつぽど来学期うけなほさうかと思つた。",
              "citation": {
                "source": "転校",
                "author": "平山千代子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾は明日帰るではないか、明日帰れば来学期にならないと彼の顔を見ることが出来ないのである。",
              "citation": {
                "source": "愛か",
                "author": "李光洙",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう間もなく夏休みだから、どうせ来学期さ。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「来学期だ」「それじゃ、一緒に出られないのか？",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
