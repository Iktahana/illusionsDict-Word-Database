    },
    "definitions": [
      {
        "index": 1,
        "gloss": "line",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ふたたび私は、すごすご出発点に引返して、全身くたくたに疲れ、ぜいぜい荒い息を吐きながら、スタートラインに並んだ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイヤーの講義はザクセン訛りがひどく「小さい」をグライン「戦争」をグリークという調子で、どうも分りにくくて困った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道幹線から分れた田舎廻りの支線、いわゆるクラインバーンの汽車の呑気なのに驚いたのはこの時である。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンチ絵のクラインバーンにはきっと豚や家鶏が鉄路の上に遊んでいるように描いてある、その通りである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾川を下って、白帝城に擬せられた犬山城があるために、日本ラインの名を、（好むにせよ、好まざるにせよ）いかに適切にひびかせるであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "シー、ピー、スクラインがパミールの岩山の奥に「幸福の谷」を発見した記事を読んだときに所謂武陵桃源の昔話も全くの空想ではないと思つたことであつたがその武陵桃源の手近な一つの標本を自分は今度雨の上高地に見出したやうである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シー・ピー・スクラインがパミールの岩山の奥に「幸福の谷」を発見した記事を読んだときにいわゆる武陵桃源の昔話も全くの空想ではないと思ったことであったが、その武陵桃源の手近な一つの標本を自分は今度雨の上高地に見出したようである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にはマクス・ラインハルトの名も交じっていた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　ファシストはアルプスを愛し、リベラリストはラインやエルベの川の景色を、マルキシストはツンドラや砂漠の景色を好むかもしれない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水平線に赤いラインが鬼火のように明滅しだすと機関室からエンジンの廻転が響きだす。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時下宿の老嬢フロイライン・シュメルツァー達と話していたら、何かの笑談を云って「エス・イスト・ヤー・マノーリ」というから、それは何の事だと聞いてみると、「馬鹿げた事だ」という意味の流行語だという。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　ラインハルト・ゲエリング――「海戦」（海戦の中の第五の水兵は叛乱の志を持っている。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何だか、もの欲しさうに、川をラインとか呼ぶのから見れば、この方が遥にをかしい。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの弱そうなフロイラインＷは重いリュクサックの紐に両手をかけて俯向きがちに私の前を歩いていた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不自由な環境によって生み出された不自然な現象の一つとして一人の女生徒マヌエラと一人の女教師フロイライン・フォン・ベルンブルヒとの間の不思議な関係が生じ、それがこの映画の演劇的な部分のおもなる骨子となっている。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハイデルベルヒの学生歌」（俗名、若きハイデルベルヒ）でも窓下の学生のセレネードは別として、露台のビア・ガルテンでおおぜいの大学生の合唱があって、おなじみのエルゴ・ヴィヴァームスの歌とザラマンダ・ライベンの騒音がラインの谷を越えて向こうの丘にこだまする。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクラインの「シナ領中央アジア」という本の中にある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる基線（ベースライン）が土台になって、その上にいわゆる一等三角点網を組み立てて行く、これが地図の骨格となるべき鉄骨構造である。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそろしい程深い蒼い川で、ライン川とはこんなのではないかしら、と私は頗る唐突ながら、そう思いました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその杉木立の中にポツネンと立っている南堂家の図書館というのは、五｜間に四間ぐらいの二階建の鉄筋コンクリートに茶褐色のタイル張りで、上等のスレート屋根の下に緑色に塗った鉄のブラインドが並んでいる。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑色の鉄のブラインドには赤錆が吹き始めた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのベデカはちゃんと一度下調べをしてところどころ赤鉛筆で丁寧にアンダーラインがしてあった。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時その群れの一つがヨーロッパに出かけて、ドイツという国を流れているライン川のほとりまで参りました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "末の妹のカロラインが、つきまとわるサン・ベルナール種のレックスを押しのけながら、逸早く戸を開けると、石油ランプの琥珀色の光が焔の剣のような一筋のまぶしさを広縁に投げた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファニーとカロラインの眠る時が来た。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブロンドの巻髪を持ったカロラインはもう眠がった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カロラインは飛んで帰ってきて私と握手した。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服の着代えをしようとしてがんじょう一方な木製の寝台の側に立っていると、戸外でカロラインと気軽く話し合うファニーの弾むような声が聞こえた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カロラインがかかげていたエープロンをさっと振り払うと、燕麦が金の砂のように凍った土の上に散らばった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれを一つ一つ大事そうに取り出して、カロラインと何か言い交わしながら、木戸を開いて母屋の方に近づいてきた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
