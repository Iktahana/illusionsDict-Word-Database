    "definitions": [
      {
        "index": 1,
        "gloss": "next month's issue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "では来月号からその詩を訳載しよう。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "許して下さい、来月号か、その次あたりに書かせて下さい、と願ったけれども、それは聞き容れられなかった。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月号を飾らせていただきたく、お礼｜如此御座候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "△十一月号に書いた「青白き公園」は、あれはたゞその前置で正月号から改めて私が計画してゐる新しい童話の方法で先づ書き初めるつもりで、で、その本筋の第一は来月号から順当にする考へなのですから左様御承知下さい。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして間もなくペンを執り始めた――その物語りが幸に脱稿出来たらば、皆さんは屹度来月号の誌上で「勇敢なる七郎の姿」に接することが出来るでせう。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "生田｜長江氏の「超人の哲学」、阿部次郎氏の「三太郎の日記」は来月号できつと紹介いたします。",
              "citation": {
                "source": "編輯室より（一九一五年三月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "この償ひとして来月号には本当に一生懸命に書くつもり。",
              "citation": {
                "source": "編輯室より",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに来月号はもう少し一生懸命にやります。",
              "citation": {
                "source": "編輯室より（一九一四年一一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "□哥津ちやんから何か頂ける筈でしたが今月は駄目でした来月号には屹度おかき下さるさうです。",
              "citation": {
                "source": "編輯室より（一九一四年一一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のお守りの時間を利用して書くのですからなか／＼まとまつたものも書けません、来月号には屹度この編輯が済み次第書いて置くつもりです。",
              "citation": {
                "source": "編輯室より（一九一四年一一月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "委しいことは来月号に書きます。",
              "citation": {
                "source": "編輯室より（一九一四年一二月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月号は哥津ちゃんも久しぶりで書いて下さることになつてゐます。",
              "citation": {
                "source": "編輯室より（一九一六年二月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "□来月号からは、今月内には皆様のお手許に届く位に早く編輯いたしますつもりです。",
              "citation": {
                "source": "編輯室より（一九一六年二月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月六号でこれを書くつもりにして居りましたけれどもつい書けさうもありませんから来月号には沢山一緒にかくことに致して御許を願ひます。",
              "citation": {
                "source": "編輯だより（一九一五年九月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "防府まで出かけるつもりだつたが（いふまでもなく金策のために）、頭痛悪寒がするので、床をとつて寝た、読むに層雲（今月は早くて来月号が今日来た）があるのはありがたい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、敏感な文壇の人々や劇評家、芸術家の中には「呉服橋劇場を救え」とか「邪妖劇と都会人」とか「怪奇劇と女優」とかいったような「クレハ嬢礼讃」を中心とする文章を来月号の雑誌に投稿すべく、熱心に執筆していた人々も、実際に居たのであった。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月ももう七日とすると、来月号の締切り日は――弔辞などを書いている場合ではない。",
              "citation": {
                "source": "文章",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に記者は、では来月号に執筆する確約をうけとると、やっと座を立った。",
              "citation": {
                "source": "芥川の原稿",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あら、私としたことが、申し遅れまして、あの私は○○雑誌社の者ですが、今日のお話を訪問記事に致しまして、来月号の○○誌に掲載させて戴き度く思います。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
