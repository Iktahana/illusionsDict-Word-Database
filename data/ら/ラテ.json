[
  {
    "uuid": "e7d5fd71-88bb-5909-b564-cd687a6771b8",
    "entry": "ラテ",
    "reading": {
      "primary": "ラテ",
      "alternatives": [
        "ラッテ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "latte",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼に於て、自分は正にギリシャ人の、ストイック教徒の、ソクラテスの、藝術至上主義の山頂的な哲學を見る。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　ソクラテスからジイド迄、いやもつと前からジイド迄かも知れぬ、僅々七十年間に、一とわたり読破した我が日本の力といふものは、世にも恐ろしい力である。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧の通りに僅々七十年間に、ソクラテスからジイド迄読破することが出来たといふのは、もとより負けじ魂に由るものであるが、注意すべきは、その負けじ魂といふよりかも、我等が粗朴であつたからである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学証書と云ったような幅一尺五寸｜長二尺ほどの紙に大きな活字で皇帝や総長の名を黒々と印刷したものを貰ったが文句はラテン語で何の事か分らない、見ていると気の遠くなるようなものであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ベルリン」までがラテン化しているのでまた少し驚いた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう一枚哲学部長の署名のあるこれもラテン語の入学免状を貰った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京帝国大学の卒業証書も検閲のために差出したが、この日本文は事務の役人にとって自分の場合のラテン語以上に六かしそうであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、流石にラテン語の學名は略してある。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処か寂然として、瓢逸な街路便所や古塀の壁面にいつ誰が貼って行ったともしれないフラテリニ兄弟の喜劇座のビラなどが、少し捲れたビラじりを風に動かしていたりする。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラテン語の caesar とドイツ語の Kaiser との意味内容は決して同一のものではない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラテンで「あるいはＡあるいはＢ」という場合に alius A, alius B とか、alias A, alias B とか、また vel A, vel B という。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年四月、鉄塔）三　春（ハル）のラテン語が ver であるが、ポルトガル語の 〔vera:o〕 は夏である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはラテンの autumnus から来たに相違ないが、このラテン語は augeo から来たとの説もある。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "露語の zima は霜（シモ）や寒（サム）や梵語の hima（雪）やラテンの hiems（冬）やギリシアの cheimon（冬）やまたペルシア語の sarmai（寒い）にも似ている。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス語の冬 hiver はラテンの hibernum であろうがこれを「冷える」と比べてみるのも一興である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラテン系の mons, monte, montagne, mountain 等は明白な一群を形成していて上記とは縁が遠く見える。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の円頂閣 cupola はラテンの cupa（樽）から来たそうであるが、現在の流義では同一群に属する。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもし生徒が文学的の傾向があるなら、それにはラテン、グリーキも十分にやらせて、その代り性に合わない学科でいじめるのは止した方がいい……」　これは明らかに数学などを指したものである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてもラテン文法の練習などではめったに出逢わないような印象と理解を期待する事が出来るだろう。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言ふソクラテスの有名な逆説は、かうした場合に於て特に適切である。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟ソクラテスの説く如く、一切の惡とは無智の謂に外ならない。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ時爺いさんは紋に Constantia et fidelitas といふラテン語の鋳出してある、銀の控鈕の附いてゐる、古い、地の悪くなつたリフレエ服を着て、痛風で曲がつた指に、寛い白麻の手袋を嵌めて出て来る。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にはラテン文の筆記帖が一ぱい載せてある。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――　少年は帰途になると、まだせずに置いたラテンの宿題の事を思ひ出した。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上のラテンの筆記帳の上には、小さい手紙が一本ある。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「まじなう」という「まじ」という語は、世界において分布区域の甚だ広い語で、我国においてもラテンやゼンドと連なっているのがおもしろい。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしだんだんにこの調子であさって行くと、おしまいにはギリシア、ラテンはもちろん現在行なわれている西欧諸国の語にもやはり同程度の類似が認められる。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
