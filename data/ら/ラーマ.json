    "definitions": [
      {
        "index": 1,
        "gloss": "Rama (Hindu god)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
