        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蘭和対訳の二冊物で、大きい厚い和本である。",
              "citation": {
                "source": "サフラン",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その並び方も日本で作られた蘭和辭書などと同じで、一方が鉛活字の歐文に、その脇ツ腹へ頭をおつつけて縱書に、つまりねた形の、それと同じ式である。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わからんわからん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜のように連出されては、こりゃならんわい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような鳥は、知らんわい！",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれじゃ若夫婦もたまらんわい」　と云ったり、それから後、深良屋敷のラジオがピッタリと止んで、日が暮れると間もなく真暗になって寝静まるのを見た人々が、「あれは一知がラジオの械器を毀したのじゃないらしい。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お暑さが堪らんわい。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、そんな事を取上げた日には、これ、この頃の画工に頼まれたら、大切な娘の衣服を脱いで、いやさ、素裸体にして見せねばならんわ。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三町四方に蚤の飛ぶのも聴えるこの耳に、うるそうてならんわい」　と、言いざまに、煙の如く消え去り、さらばじゃという声は、遙か天井より聴えたが、それから毎夜乾の方に星の流れる頃には、必ず現われて、まず蝮蛇の頭をペロペロとくらったあと、鳥人の術の伝授に掛り、三年掛った。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "場割りが済んで、さあ店を張ろうとおもたら、降って来やがったさかい……夜店出しもこう雨が多かったら、さっぱり売にならんわ」夜店出し、露地の中へ入ってゆく。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気予報の名人やと自称しとるらしいが、満更当らんわけでもない。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶屋は「捕れたかい、このごろはなんぼ捕れても、みんな蒸気で上へ積み出すからこちらの口へははいらんわい」とやけに桶をポンポンたたく。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、両方の窓枠についている弾機が同じだと想像すれば、両方の釘に、あるいは少なくともその釘のさしこみ方に、相違がなければならんわけだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鯛だぞ、鯛だぞ、活きとるぞ、魚は塩とは限らんわい。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういい加減にしてくれとのどまででかかってもやはり、「マックス・ヘッドルーム」は見にゃならんわで、本当に一九九〇年の十月はあっというまに舞台にあふれかえった登場人物をみんな引き連れて飛ぶように去っていったのであった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "単漢字変換のイージーワード　１・０版は「これじゃ売り出しても勝負にならんわ」というわけでデビューには至らず、一九八五年九月、五百字までの一括変換をサポートするバージョン２・１で初めて発売となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "でこの場合、女将の証言はあれはみなうそだとやッつけるためには、なぜうそだと云うその証拠――つまり、女将と被告達との間にそれぞれナニかの特別な関係があったとか、或はまたその他に、ナニか女将がそんなうそを云わねばならなかったようなこれまた別のわけがなくっちゃアならんわけです。",
              "citation": {
                "source": "あやつり裁判",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり宇宙艇から設計を始めなければならんわけです」　歎息が聞える。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうするって、こちゃ知らんわ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぢやたまらんわ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、地下足袋ぢや滑つて危なうてどもならんわ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿にだつて、何もたづねてもみもせんで、ただわからんわからん云うとるんやけに。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か先に立つて云ひ出すものがありや、理の當然だによつて、案外安々とその通りになるんぢやが……みんな腹ぢや思つてゐながら、お互ひに人におつつけおつつけしとるんぢやけに、どもならんわ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなな紙きれの文字讀めるもの部落には一人も居らんわ。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五俵とることもそりやでける、けどそれにやもちつと金肥も入れにやならんわ。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれにや借金をせにやならんわ。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こなひだ、芝耕の芝居を見て、すつかり感じたもんやさかい、ちよつくら真似てみたが、なか／＼出来よらんわい。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これではどむならんわい。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからは一心に金を取り返さなならんわい。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「衲にはてんで読め居らんわい。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
