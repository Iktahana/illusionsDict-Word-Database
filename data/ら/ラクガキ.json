[
  {
    "uuid": "ac1caf8d-5601-5a9a-a0c9-39e3f2eb8bad",
    "entry": "落書き",
    "reading": {
      "primary": "らくがき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
