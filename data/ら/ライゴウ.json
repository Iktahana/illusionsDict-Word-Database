[
  {
    "uuid": "6548d3e3-8b07-527d-bddd-b1eddf1879a0",
    "entry": "来迎",
    "reading": {
      "primary": "らいごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
