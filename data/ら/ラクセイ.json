    "definitions": [
      {
        "index": 1,
        "gloss": "completion (of a building)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小学校の新築が落成した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年前から取りかゝっていた学校の新築は落成した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この橋は、おおむかしの慶長七年に始めて架けられて、そののち十たびばかり作り変えられ、今のは明治四十四年に落成したものである。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると或地方で小学校新築落成式を挙げし当日、廊の欄が倒れて四五十人の児童庭に顛落し重傷者二名、軽傷者三十名との珍事の報道である。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "校舎落成のこと、その落成式の光景、升屋の老人のよろこぶ顔までが目に浮んで来る。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自首した後での妻子のことを思い、辞職した後での衣食のことを思い、衣食のことよりも更に自分を動かしたのは折角これまでに計営して校舎の改築も美々しく落成するものを捨て終うは如何にも残念に感じたことである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどでなくても、たとえば議院新築落成式の日に、過去の議会におけるいろいろな故人の演説の断片を聞くことができても多少の感慨はあるであろう。",
              "citation": {
                "source": "ラジオ・モンタージュ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○新富町守田座、新築落成して、十月三日より開場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○七月、芝新堀に河原崎座の新築落成して開場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月、新富座の本建築落成。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、猿若座は猿若町を去って、浅草西鳥越町に移転し、新築落成して十六、十七の両日開場式を行う。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八年（乙酉）　一八八五○久松座の再築落成して、千歳座と改称し、一月四日より七日まで開場式を行う。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一年（戊子）　一八八八○一月、猿若町市村座の新築落成し、八日より三日間、開場式を行う。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○歌舞伎座新築落成して、十一月二十一日より開場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十二月、春木座の新築落成して、四日より開場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○四月、浅草猿屋町に沢村座の新築落成し、沢村訥子、沢村田之助ら出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、市村座の新築落成して、十日より開場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月一日、日本橋区久松町に新築中の明治座落成して、その舞台開きを行い、左団次、権十郎、小団次、米蔵、福助、団十郎ら出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○七月、市村座の再築落成して、十四日より開場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○川上音二郎の創立せる神田三崎町の川上座、新築落成して七月二日より開場。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、神田三崎町の東京座、新築落成して十日より開場し、団十郎の国姓爺、好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
