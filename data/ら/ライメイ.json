[
  {
    "uuid": "7f087441-f190-59f6-bdc1-3482f4c82b37",
    "entry": "雷鳴",
    "reading": {
      "primary": "らいめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
