    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thunder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この侘しく灰色なる空の下に私たちの心はまづしく語り　孤獨になやみて重たくよりそふ少女よあの遠い空の雷鳴をあなたは聽くかかしこの空にひるがへる浪浪の高いひびきをあなたは聽くか。",
              "citation": {
                "source": "眺望する",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神鳴り」というのは、一人が雷神になって例えば障子の外の縁側へ出て戸をたたいて雷鳴の真似をする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯の準備をしているうちに、驟雨が一としきりあって、雷鳴が近くに聞えたが、夜に入って、星が瞬いた……かと思うと、淡い、軽い霧が、銀河のように空に懸る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷鳴の時に蚊帳を釣ってもぐり込むのは誰が考えた事か知らぬが、ただの迷信とちがって存外理窟に合っている。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠方の雷に伴う電光が空に映るのだが、雷鳴の音は距離が遠いのと空気の温度分布の工合で聞えぬのである。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分にこの臆病な私の胆玉を脅かしたものの一つは雷鳴であった。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして雷鳴に対する神秘的の恐ろしさがなくなりはしたが、たぶんその恐ろしさの変形したものと思われる好奇心と興味とはかえって増すばかりであった。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで雷鳴のする度ごとに私は厭かずに空を眺めては雲の形態や運動、電光の形状、時間関係、雷鳴の音響の経過等を観察するのが無上の楽しみになって来た。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷鳴の音の波の振幅は多くの場合に耳の近くで雨戸を繰る音に比べて大きなものではないのに雷の音は著しく大きいと考えるのはやはり直接の感官を無視して音響の強度の距離と共に感ずる物理的方則を標準としているのである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また雷鳴の音響の生因について種々の考えがあげてあるが、この問題については現在でもまだ種々の異説があるくらいである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドカン、ドカドカ、ドカーン」といったような不規則なリズムを刻んだ爆音がわずか二三秒間に完了して、そのあとに「ゴー」とちょうど雷鳴の反響のような余韻が二三秒ぐらい続き次第に減衰しながら南の山すそのほうに消えて行った。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもコンナにお涼しくなりましてから雷鳴入りの夕立なんて可笑しな時候で御座いますなあ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "点滴の音によってその室の広さを感じ、雷鳴の響きによって山の近さを感じることも可能になるであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷鳴に、殆ど聾ひなむとした人々の耳に、驚破や、天地一つの聲。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて然う云ふ空合の時には雷鳴があるのだから、いつもはかつぐのに、其の時は、そんな事を言つて居る隙はなかつた。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "音を綯交ぜに波打つ雷鳴る。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷電、雷鳴、これで梅雨もあがるのだらう、今日から盛夏。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀びとよあの遠い空の雷鳴をあなたは聽くかかしこの空にひるがへる波浪の響にも耳をかたむけたまふか。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せん子、お茶でも持つて来ておくれ」　茶室造りの畳の根太の下に響いて、やゝ烈しい雷鳴が一つしたあとは、ずつと音響が空の遠くへ退いて行つた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三日、己酉、天晴、夜に入つて雷鳴、同時に御所の南庭に、狐鳴くこと度々に及ぶと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日、辛丑、霽、申刻甚雨雷鳴。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四日、庚午、晴、酉剋地震、戌剋地震、同時に雷鳴す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿六日、壬午、亥刻、雷鳴数声、降雹の大なること李子の如し。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は雷鳴を最も忌み恐れる。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奸譎な老人は、占卜者を牛角杯二｜箇でもって買収し、不吉なシャクの存在と、最近の頻繁な雷鳴とを結び付けることに成功した。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "某日、太陽が湖心の真上を過ぎてから西岸の山毛欅の大樹の梢にかかるまでの間に、三度以上雷鳴が轟いたなら、シャクは、翌日、祖先伝来のしきたりに従って処分されるであろう。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の午後、ある者は四度雷鳴を聞いた。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奸譎な老人は、占卜者を牛角杯二箇で以て買收し、不吉なシャクの存在と、最近の頻繁な雷鳴とを結び付けることに成功した。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉堂はん、眼鏡かけてる思て威張りなや」「ははは……」　左手で太いセルロイドの眼鏡を突きあげながら、橘玉堂はさむらいめいた笑い声を立てて、「――なにが僕が刑事なもんか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ジョンは、すこしぐらいめいわくをかけてもいいと思ったらしく、満足そうに、「ぼく、いつか報いられるかどうか、うかがいたいのです。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
