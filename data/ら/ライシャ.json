[
  {
    "uuid": "56d46465-bace-53b7-9361-e7baadcd608e",
    "entry": "来社",
    "reading": {
      "primary": "らいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "visit to a company",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人間は元来社交動物に出来てるのだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンダルーシアの犬」と称する非現実映画（往来社版、映画脚本集第二巻）になるともはやそういう明白な主題はない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち三重県の合併はもっともはなはだしく、昨年六月までに五千五百四十七社を減じて九百四十二社、すなわち在来社数のわずかに七分一ばかり残る。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、変事のあるすぐ前にタイピストに書かせた山田貿易商会へ宛てた手紙の終わりには、『明朝十時にご来社くだされたく、お示しの条件については拝顔の上ともかくご相談いたしたく候』と書いてありますね。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス革命により本式に採用せらるるに至った散兵戦術の指導精神は、フランス革命以来社会の指導原理となった「自由」である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういう妻及び母としての女の負担は、現代に生きる自分たちの生涯を貫いての献身と努力とで将来社会的に軽減され得るものである。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲目者の外は何人も見遁すことのできない、将来社会の大勢を形づくりつつある。",
              "citation": {
                "source": "生の拡充",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "足下は元来社会主義者というわけではない。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中心的な箇条の一つは、知識人の社会的評価に関するもので、従来社会的にも文学的にも知識人一般というものが抽象的にこの世の中に在るのではなくて、歴史と社会の層に属して現実を生きつつあるものだと云われ、従って歴史に対する知識人の進歩的な態度、保守の態度というものが、作品の問題にも常に触れて来た。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉が本来社会的実践的であるということを理解するのは、ロゴスとともにまず第一に論理あるいは理論を考えることに慣れている今の人々にとって極めて大切である。",
              "citation": {
                "source": "マルクス主義と唯物論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "★『マインドストーム』（シーモア・パパート著、奥村貴世子訳、未来社、一九八二年）　教育の場でまったくコンピューターに触れた経験を持たず、管理と支配の象徴としてこの装置に漠然とした敵意を抱いていた筆者がこうしたテーマの原稿を書くようになったのには、いくつかきっかけがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "古往今来社会的環境などは一度も清閑を容易にしたことはない。",
              "citation": {
                "source": "解嘲",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "西村伊作氏といえば、去年以来社会に愛読された『楽しき住家』の著者として、特にその名を知られていますが、氏は稀に見る多能な人で、画家、建築家、工芸美術家、詩人であると共に、更に熱心な文化生活の研究家であることは、友人のひとしく認めて驚いている所です。",
              "citation": {
                "source": "文化学院の設立について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる主観は、それが個人的自己と考えられようと超個人的自己と考えられようと、どこか世界の外にあって孤立的であるに反して、主体は主体に対して主体であり、従って元来社会的である。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉は本来社会的なものであるとすれば、すべての言葉は本性上修辞学的でなければならぬ。",
              "citation": {
                "source": "解釈学と修辞学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉は元来社会的な行為に関するものである。",
              "citation": {
                "source": "解釈学と修辞学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠者は、古来社会の制度外である。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来社会に出て戦うべき生活の自信を得たのは何より感謝するところである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして将来社会的に劣弱者となって、自らが求めた快楽さえも得られないという、あわれむべき状態に堕ちる恰好の原因となるものだ。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした行為をする者が将来社会に出て何を企てるであろうか。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アス御来社下さい。",
              "citation": {
                "source": "集団見合",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはその通りで、一般に芸術論というものの幼稚な発達しない時代に於ては、ただに俳優ばかりでなく、すべて芸術家というものに対して元来社会はそんな見方をしていたのです。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会的関心を持たなかったばかりでなく、生来社交的でなかった。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会的関心を持たなかつたばかりでなく、生来社交的でなかつた。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が入社した五、六年は、まだ大隈伯が頗る元気で、毎年暮れになると社の会議室へ姿を現わし、社員を集めて一場の訓話を施す例になっていたが、大隈さんが来社するほんとうの用向きは、報知新聞から毎年定まって贈るところの金十万円のお歳暮を取りにくるのであるという話であった。",
              "citation": {
                "source": "入社試験",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスでは元来社会のどの階層にも田園の風習が強くしみわたっているので、ひとびとは昔からいつも、祝祭や休日で田園生活の単調さが途切れるのを喜んだ。",
              "citation": {
                "source": "クリスマス",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして個人間のみがかような次第ではない、人間は元来社交的の動物でつねに団体を形造って生活しているが、団体間の関係も全くこのとおりで、やはり剣によらねば何事も成就せぬ。",
              "citation": {
                "source": "戦争と平和",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の生活は本来社会的のもの、その意味で集団的のものではあるが、近代文明の世界においては、その集団が特殊の性格と形態と規模とを具え、従ってその力が甚しく強大になった。",
              "citation": {
                "source": "歴史の学に於ける「人」の回復",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり吐いてしまって、暫く塀に凭れてしゃがんでいると、不思議なくらいしゃんとして来た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育課長は、煤煙禁止運動の必要について約一時間くらいしゃべっていたが、教師たちは完全に全部居眠りしていた。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
