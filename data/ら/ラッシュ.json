            },
            {
              "text": "慶一の脳裏で光が走り、爆発的なフラッシュバックが起こった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラッシュへ入れる指先の力の工合で発色が異って来るのだ。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の全面をあげて、現代はゴールド・ラッシュの時代である。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッ、パッ、と二つも三つもフラッシュが焚かれて、現場の写真が撮られて行った。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頭髪に爽快なローションをふりかけ、ブラッシュでぎゅうぎゅうとかきあげた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂ラッシュアワアであった。",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪はきれいに截った上、御丁寧にブラッシュをかけるという始末です。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……馬を飛せて、あの卑劣な男の館へ飛び込む、彼奴の眉間を目がけて猛烈な拳固が飛ぶ、乱闘――そんな光景ばかりが、パラ／＼と目眩しくフラッシュするだけであつた。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "町はラッシュアワアだったが、秋の侘びしい光線が一層この十字街を無秩序なものにしていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての雑誌の表紙は刺戟的なグラビア版で赤や黒のフラッシュのついた文字で彩られているようなのであるけれども、そうかといって単純にキングと文芸春秋とは全く等しい傾向をもって、戦時特輯をしているかと云えば、そうでないことは自明である。",
              "citation": {
                "source": "微妙な人間的交錯",
                "author": "――雑誌ジャーナリズムの理想性と現実性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一日の十一月四日、法廷にはニュース映画のカメラ、ラジオの録音の機具まで運びこまれ、まぶしいフラッシュの閃きの間に赤坊の泣声がまじり、十二名の被告が入廷するという光景であったことが、各紙に報ぜられた。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
