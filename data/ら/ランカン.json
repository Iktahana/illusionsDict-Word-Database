[
  {
    "uuid": "4cab3111-604f-57ae-9ebb-f91022992834",
    "entry": "卵管",
    "reading": {
      "primary": "らんかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
