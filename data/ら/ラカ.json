[
  {
    "uuid": "2ed6405a-5ef5-522e-8bfe-e8e1f5804119",
    "entry": "らか",
    "reading": {
      "primary": "らか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞",
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "諸君は僕を、「ほがらか」でないといふ。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そんな定規みたいな「ほがらか」なんぞはおやめなさい。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほがらかとは、恐らくは、悲しい時には悲しいだけ悲しんでられることでせう？",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、気持は、そこで一先づ安らかとなつたが、作品が熟してゆくといふことは、時日を要することであるし又、漸次のことであるから今分つたからといつて、すぐに今迄よりも好いものを書いてみせろと期待されても、六ヶ敷い。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに芸術にとつてそれから恐らく人間性にとつても不幸な世の中なのであらう。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなそれぞれ理由のある所であらうが、原因はいざ知らず、見渡した所感情が喪失されてある状態であること明らかであるやうである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろこちらから云へば、都の人が没個性的であるのでもあるのです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全くだ」とＡも思ふ、「しかしま、お手柔らかに」と、表情以て友達甲斐を発揮する。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品が存在の姿を持つためには、なんらか書かうとする前に書かんとする作品の全的な予想といふものがハツキリとしてゐなければならぬ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長がもし人望のよい人である場合は、文部省によつて、アツサリ放校が取消されたにしても、何らか校長の顔を立てるためには生徒の方に臨時の損が振りかけられたに相違ありません。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌リュテースを編輯してゐたレオ・トレズニカは、アムール・ジョーヌと『歎き』（ラフォルグの詩集）の作者との明らかな類縁に驚いて、コルビエールに肩を持ちながら両者を比較してラフォルグを荒だてたのであつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕としてたゞまだ塵芥箱もないことだし、隅ッコに暫時捨てたわけで、おまけにそこらに前ゐた人が捨てて行つたのだらう、ボール箱や新聞紙のキレが相当散らかつてゐたので、そのお説教が始まつた時は全く意外であつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳述、私は明治四十年四月の末に生れ、その年十一月三日に郷里を母と母方の祖母と三人で立ち、四日乗船、六日大連着、そこで父に出迎へられ、（その父も今は亡き数、――安らかなれかし！",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　あたしが此の間片附けて帰つてから、まだ三日ばかしにきやならないんだけれど、まあまた散らかつたわね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　だけどあたしあの時帰つてからかう思つたわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（女の顔を見入りながらからかふやうな眼付になる）コーカサス型で以て、鼻筋だけは独逸女のやうに何処かかうキリツとしたところのある顔、と言へば好いのかな。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　社交ダンスなんて、金を貰つたつて閉口だけれど、奥さんは持ちませうかね、何処からか探して来てね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　（からかふ）好い台詞だなあ、近来の傑作だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "東雲ちかい汽車の寢臺で友よ　安らかに眠れ。",
              "citation": {
                "source": "別れ",
                "author": "旅の記念として、室生犀星に",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄目です』などと夫人にからかわれ、『あ、どうしよう、私この鼻』など言って悄気返り、『真ッぴら、真ッぴら』と、今おぼえたばかりの日本語を面白がって使ったりして、夫人や女中たちを大笑いさせたりしているのだが、その後で、『しかし、よく思うて下さい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あなたの鼻高い、あなたの眼大きい』などという時、夫人はいつも指でヘルンの顔を突ついたりして、子供を扱うようにして戯れからかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあまり部屋が乱雑に散らかるので、夫人が折を見て掃除に行くと、『あなた、いつも掃除、掃除、掃除。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて大久保の新居に移った時は、春の麗らかな日であって、裏の竹藪で鶯がしきりに鳴いてた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この芥川君の言は、いくらか犀星の感情を害したらしい。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私が此處まで考へてきた時、始めてあの鵠沼における悲壯な會話が、言語の隅々まで明らかに解つてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場は音たかく舌打ちして、「おい佐竹、からかうのはやめろ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとを平気でからかうのは、卑劣な心情の証拠だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "罵るなら、ちゃんと罵るがいい」「からかってやしないよ」しずかにそう応えて、胸のポケットからむらさき色のハンケチをとり出し、頸のまわりの汗をのろのろ拭きはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それから五六日して、上野動物園で貘の夫婦をあらたに購入したという話を新聞で読み、ふとその貘を見たくなって学校の授業がすんでから、動物園に出かけていったのであるが、そのとき、水禽の大鉄傘ちかくのベンチに腰かけてスケッチブックへ何やらかいている佐竹を見てしまったのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
