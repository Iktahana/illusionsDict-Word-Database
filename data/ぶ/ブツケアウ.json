    "definitions": [
      {
        "index": 1,
        "gloss": "to knock (ideas) against each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女はどこにいて、何をしていても男に用があると呼ばれないでもそばへ行き、「二つの口から始終同じ一つの言葉をぶつけ合う」ような霊的交流をもって生活したが、やがて男はそのみこのような霊力の女をすてて、別の女と結婚し、死ぬ。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作業の目的は、互いに意見をぶつけ合うことにあるのではない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘に対して多計代もゆずらなかったし、朝子も娘だからという理由だけでゆずるべきところはないと思ったし、仕舞いには両方ともが泣きながら、激しい言葉をぶつけ合うような場合も起った。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩や平手をぶつけ合う小ぜりあいが、さらにはじまった。",
              "citation": {
                "source": "なぐり合い",
                "author": "WIE JAPPE UND DO ESCOBAR SICH PRUGELTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にぶつけ合う生命と生命の響きだった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はべつの愛、けものどうしの闘いのように、おたがいが裸の全身をぶつけあう清潔な関係をのぞんでいた。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
