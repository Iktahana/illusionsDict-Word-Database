[
  {
    "uuid": "8bcdd185-77a4-5db7-bdbe-23681474e55f",
    "entry": "分野",
    "reading": {
      "primary": "ぶんや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
