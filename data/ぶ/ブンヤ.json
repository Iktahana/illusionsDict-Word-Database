  {
    "uuid": "b0741da7-5228-572d-9aeb-69c9f5560942",
    "entry": "ブン屋",
    "reading": {
      "primary": "ぶんや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "newspaper reporter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ブラウンならボブの言い成りになってそいつを出所させるだろうし、さもなきゃブン屋に書き立ててもらってもいい。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブン屋さんの前では。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブン屋が情報を求めて、もうやって来た。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいどういう目的で歩いているのだろうと考えてみたが、たぶんやはり食うためだろうとしか思われなかった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんやはりその時の句に、「※駝呼んでつくばい据えぬ梅の花」というのがあった。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女　　おかあさん、よし坊はずいぶんやせたね。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "石の冷たい河原で寝ることは好いとしてちょっと休んでいてさえ、数多の蚊がぶんぶんやって来る程だからとても寝ることはだめです。",
              "citation": {
                "source": "提灯",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貯金の宣伝は紙芝居でずいぶんやったし、それに私の経歴が経歴ですから、われながら苦笑するくらいの適任だと言えるわけですが、しかしたった一つ私の悪い癖は、生れつき言葉がぞんざいで、敬語というものが巧く使えない。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "石の冷たい河原で寝ることは好いとしてちよつと休んでゐてさへ、沢山の蚊がぶんぶんやつて来る程だからとても寝ることは駄目です。",
              "citation": {
                "source": "提燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、その病院と往来とのあいだにはかなり高いさくがあって、ふとい鉄の棒が、まあ、ずいぶんやせこけた志願助手ででもあったらむりにもぬけられそうな、というくらいの間をおいて並んでいました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに彼女は、ふだんはずいぶんやさしいおとなしい女であるのだが、それでいて、なかなかに意地もあり張りもある女である。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの家庭はずゐぶんやゝこしい、寄合世帯ぢやないかと思ふ、爺さんはガリ／＼、婆さんはブク／＼、息子は変人、娘は足りない、等、等、等、うるさいね。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "身軽のまま、ぐんと縮こまってから思い切って跳ぶんや」　二つ年下にもかかわらず兄のような口ぶりでそう説教をくれる西の言葉は、古川の耳にむしろ新鮮に響いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその顔を眺めた時、思わず「ずいぶんやせましたね」といった。",
              "citation": {
                "source": "滝田哲太郎君",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶはもう逃げることができなくなって、羽ばかりあいかわらずぶんぶんやっていました。",
              "citation": {
                "source": "一本のわら",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "未亡人は保一くんがかわいかったため、金銭上のことはずいぶんやかましい人であったけれど、保一くんのためにかなりの金額を支出してやりました。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕などは医者と言う職業上、ずいぶんやかましくも言っているんだが………」「それは斬罪があるからだけさ。",
              "citation": {
                "source": "湖南の扇",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧三　いつもため息をついたり、泣きはらしたような目をして控えの間などに出たり、庫裏で考え込んだりしているものですから、ほかの弟子衆の目にもあまるらしいかして、ずいぶんやかましく申しています。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリにはずいぶんやられたが、ヨタモノにやられたのは一度しかない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、武術は好きで、ずいぶんやるにはやりましたよ、自慢ではないが、まあ、大抵の喧嘩には負けません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もずいぶんやってみたが、うまくいかんものだ……。",
              "citation": {
                "source": "美味放談",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "長身で化粧をしない顔は、いくぶんやせてはいるが、わたしからなにかを聞き出そうとして一生懸命になっているらしい。",
              "citation": {
                "source": "梅にうぐいす",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ぼくらにとって火山ってのはずいぶんやっかいなことをする。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お皿をじゃぶじゃぶ洗わせ、テーブルをごしごしふかせ、じぶんやむすめたちのへやをめいっぱいそうじさせました。",
              "citation": {
                "source": "シンデレラ",
                "author": "CINDERELLA, OR THE LITTLE GLASS SLIPPER",
                "note": "青空文庫"
              }
            },
            {
              "text": "この郵便局ができてからは、捕鯨船の船員は、島に船をよせると、すぐに上陸して、かめの甲羅の下の郵便箱をさがして、じぶんや、じぶんの船にあてた手紙を見つけだす。",
