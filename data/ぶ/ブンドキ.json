        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "樽野の机の上には、大型の地球儀が据り、分度器やコンパスが散らかつてゐた。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然大きい分度器が一つ上から大股に下って来る。",
              "citation": {
                "source": "誘惑",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京から買って来たお土産の分度器と巻尺が五助をたいへんよろこばせた。",
              "citation": {
                "source": "雪魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば物体の長さ重さ等は標尺又は分度器という物体によって物理的に規定される。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、ちっとじぶんどきがはずれているが、いつもおかわいがりくださる伊豆守様だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
