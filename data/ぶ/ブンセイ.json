      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "educational policies or administration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大阪の天王寺の五重塔が倒れたのであるが、あれは文化文政頃の廃頽期に造られたもので正当な建築法に拠らない、肝心な箇所に誤魔化しのあるものであったと云われている。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、文化文政の美人の典型も元禄美人に対して特にこの点を主張した。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当世顔は少し丸く」と西鶴が言った元禄の理想の豊麗な丸顔に対して、文化文政が細面の瀟洒を善しとしたことは、それを証している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化文政には正式な髪は丸髷と島田髷とであった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、文化文政の遊士通客は縞縮緬を最も好んだ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、宝暦、明和ごろから縦縞が流行し出して、文化文政には縦縞のみが専ら用いられるようになった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦縞は文化文政の「いき」な趣味を表わしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは文政十二年の序文でありますからその時に出来た書物であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸でも慶長寛永寛政文政のころの記録がある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "耽奇漫録によると文政七年の秋降ったものは、長さの長いのは一尺七寸もあったとある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政十二年三月二十一日、早朝より、乾の風烈しくて、盛の櫻を吹き亂し、花片とともに砂石を飛ばした。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが江戸の話は文政末期の秋の宵の出来事である。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは下町の町人の娘で、文政四年生れの今年十三になるのであるが、何ういふわけか此世に生れ落ちるとから彼女は明るい光を嫌つて、いつでも暗いところにゐるのを好んだ。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政四年十一月には、岩代の地震。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政にはまた十一年十一月に越後の地震があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそれよりも、真珠の首飾見たようなものを、ちょっと、脇の下へずらして、乳首をかくした膚を、お望みの方は、文政｜壬辰新板、柳亭種彦作、歌川国貞｜画――奇妙頂礼地蔵の道行――を、ご一覧になるがいい。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政の初年には竜池が家に、父母伊兵衛夫婦が存命していて、そこへ子婦某氏が来ていた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政五年に竜池の妻が男子を生んだ。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそ死んだら、ずゐぶんせいせいするでせうねえ」「そら、つまんないや。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
