    "definitions": [
      {
        "index": 1,
        "gloss": "to hit hard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　ぶん殴るぜ、こんちきしょう。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっこめないと、ぶん殴るぜ。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "告げ口したら、ぶん殴る。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの時勢に、くるしいなんて言って、酒をくらって、あっぱれ深刻ぶって、いい気になっている青年が、もし在ったとしたなら、私は、そいつを、ぶん殴る。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "躊躇せず、ぶん殴る。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ・タキノは、どんな議論も不得意で、怒ればただ口惜し紛れに「馬鹿ア」とか「畜生奴」とか、「外へ出やがつたらぶん殴るぞ！",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一遍云つて見やアがれ、ぶん殴るぞう。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、彼女を押し倒して、押えつけて、ぶん殴るか、暴行するか……抵抗してくれればいいが……いや、たぶん、なま温い泥沼に一緒に転げこむばかりだろう。",
              "citation": {
                "source": "失われた半身",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と、どっかにぶっつけた肘をこすっている）栄二　傍に寄るとぶん殴るぞ！",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "存八が悶絶してもまだぶん殴ることもある。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりボクが使い走りにでるとぶん殴られる怖れがあるし」「誰がぶん殴るんですか」「政界官界財界のボスのコブンだな」「社員ならぶん殴られないのですか」「そうでもないらしいがね。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央公論の藤川親昌君が、一ヵ年の牢獄――実は留置場から出てきたが、警官はむやみにぶん殴る。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主は人の頭を遠慮なくぶん殴るという話で、三十棒といったりして、ひとつふたつと違うから、出発に際して、充分に覚悟をきめる必要などがあったのである。",
              "citation": {
                "source": "勉強記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやく香具師へ銭を投げてやらんと、ぶん殴るぞ」　毛の生えている魯達の拳骨を見ては、もうおしまいだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんぶるわけぢやないけど、修業中だけはお謹みなさいね」「馬鹿々々々々々々……ぶんなぐるぞ」「なぐれると思ふならなぐつて頂戴、さ」　勃凸は本当にその芸者の肩に手をかけてなぐりさうな気勢を示した。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば、ぶんなぐる口調で書いてあります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかは、あいつを、ぶんなぐるつもりで居ります。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここんところを箒でぶんなぐると、チュウといって直ちに伸びてしまう。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とか、ぶんなぐるぞウ！",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは役場の助役の子で阪井巌というのがかれを見るとぶんなぐるのである。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きゃつは一体生意気だからぶんなぐるがいいよ」　と浜本という剣道の選手がいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "女同志の真剣な掴み合といふものを始めて見たのであつたが、めくら滅法ぶんなぐる、さういふものとは根柢的に趣きが違ふ。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にこの「人造犬」の発明者が現われて犬の尻尾を棍棒でぶんなぐると、犬を動かしていた電気のスイッチが開き、猛犬は仰向けにゴロンと引繰りかえり、身体のなかからゼンマイや電池や電線がポンポン飛び出す――という大活劇であった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "オトメは小坂主税という人のところへおヨメにいったが、主税はノンダクレで、給金も親の遺産ものみほしたあげく、酔ってオトメをぶんなぐる癖があった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも、くらえ」　よってたかって、こづきまわす、ぶんなぐる。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ来たブツクサ婆さんさえ赤い旗を持って立ってる軍隊から帰って来た庄吉は利ぎすました鎌を持ってる　唐竿の柄をぶったぎっても竹槍にあなるだろう「山からぴょろこでも切って来い」「やつらあ聞かなきゃそいつでぶんなぐるべ」「さあ地主の家さ押しかけろ！",
              "citation": {
                "source": "飢えたる百姓達",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "よけいな口きくとぶんなぐるぞ」とおせきはやっと我にかえって勝をたしなめた。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでの話だが、海軍で新兵をぶんなぐることが多い。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「その一方、われわれの大多数、百中の九十九までが、野蛮人みたいな暮しをして、何かといえば――すぐぶんなぐる、罵倒する、ひどい物を食って、息のつまるような汚ない所に寝て」）どこもかしこも南京虫と、鼻をつく悪臭と、ひどい湿気と、道徳的腐敗ばかりです。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は手に余るほどの丸太ん棒を捜してきては、「日向で眉毛を剃りおとして笑つてゐる」――とでも云つた風の、無邪気な白豚の、まんまるく四角い弾力に富むだお尻を、力まかせにぶんなぐるのでありました。",
              "citation": {
                "source": "測量船拾遺",
                "author": "三好達治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
