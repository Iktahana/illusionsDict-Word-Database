          "literary": [
            {
              "text": "」　宮田は二三歩引きさがった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "金六は家の方へ二三歩引き返した。",
              "citation": {
                "source": "悲しめる顔",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等が、実際の思想よりも数歩引き下がれば、ちょうどこの要求にもっともよく応ずるものになる。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだ者の怨みの声」を聞き「眼に見えぬ執念の手」に触れられるこの世の外の世界へ、一歩一歩引き込んで行く。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野は数歩引き返して、彼を呼んだ。",
              "citation": {
                "source": "秦の憂愁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪子は二三歩引き下がりて、余儀なく顔をあげたりしが、例の黒水晶の目にひたとみつめられて、わき向きたり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い掛けない事なので、呆れて目を※いて、丁度電にでも撃たれたように、両腕を物を防ぐような形に高く上げて一歩引き下がった。",
              "citation": {
                "source": "鴉",
                "author": "シュミットボン　Willhelm Schmidt-Bonn",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩引き返して見たが、あんまりだと気を取り直して、のそのそ長屋へ這入った。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は団員がどこへ行くかとの問に対して東大久保四十八番地に行きますと答えて通り抜けようとすると、いきなり後ろからえりをつかみ待てと大喝しながら五、六歩引き戻し、帽子を取らせ提灯をつきつけて五、六人の団員がかわるがわる顔を検査する。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "余吾之介はその魍魎をかきのけるように、思わず二三歩引き退きました。",
              "citation": {
                "source": "十字架観音",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルパンは云いしれぬ不安を感じてきたので知らず知らず二三歩引き返した。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
