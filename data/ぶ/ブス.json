        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そら、ばけものはチブスになって死ぬだろう。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会幹事として彼はウィラード・ギブスの酬われざる貢献を認めこれを表彰したいと望んだが、化学方面の評議員が「あれは化学じゃない」と云って承知せず、ケルヴィン卿までも反対した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以前にギブスがレーリーに送った手紙に「自分でもこの論文は長過ぎるのが難だと思う。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロンブスの銅像の前で、陽気に恋を語りました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一刻後、太田ミサコはグリーブスな武者わらいをして、ハンド・バッグに一枚の紙片の重さを感じながら支那ホテルの階段に榴弾の音をたてて下降した。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は重い膓チブスに罹つて、赤坂の或る病院へ入院した。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "チブスで危い處を助かつたんですつて。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上十六歳の時には重いチブスで八十日近く入院して瀕死の境から救はれた。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腸チブスだったのである。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は、リザ・リーブスカヤのことを思い出して、どぎまぎして「胸膜炎で施療に来て居るからそれで知っとるんです。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "志村の畫題はコロンブスの肖像ならんとは！",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上ならず、馬の頭と髭髯面を被ふ堂々たるコロンブスの肖像とは、一｜見まるで比べ者にならんのである。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『馬も佳いがコロンブスは如何だ！",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『コロンブスは佳く出來て居たね、僕は驚いちやツた。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "志村の画題はコロンブスの肖像ならんとは！",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上ならず、馬の頭と髭髯面を被う堂々たるコロンブスの肖像とは、一見まるで比べ者にならんのである。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬も佳いがコロンブスは如何だ！",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「コロンブスは佳く出来ていたね、僕は驚いちゃッた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか数｜浬の遠さに過ぎない水平線を見て、『空と海とのたゆたいに』などと言って縹渺とした無限感を起こしてしまうなんぞはコロンブス以前だ。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "峻は腸チブスではないかと思った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が来て、やはりチブスの疑いがあると言って帰った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌の苔がなんとかで、と言って明瞭にチブスとも言い兼ねていた由を言って、医者も元気に帰って行った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "残りの大多数の人たちは、そういう少数の信用ある批判者の批判の結果だけをそのままに採用して、そうしてその論文のアブストラクトと帰結とだけを承認することになっている。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて虔十はその秋チブスにかかって死にました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋、僕が蕎麦団子を食べて、チブスになって、ひどいわづらひをしたときに、あれほど親身の介抱を受けながら、その恩を何でわすれてしまふもんかね。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、ばけ物はチブスになって死ぬだらう。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋、僕が蕎麦団子を食べて、チブスになって、ひどいわずらいをしたときに、あれほど親身の介抱を受けながら、その恩を何でわすれてしまうもんかね。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなお世話でサア……文科の生徒さんなんかは、試験前にチョイチョイ来て、アノ棚の上の大きなウエブスターの辞書だの大英百科全書を抱え下して、入り用な字を引いちゃってから、そのまま置きっ放しぐらいは構いませんが、ノートに控えるのが面倒臭いんでしょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時亮の家には腸チブスがはいって来て彼の兄や祖母や叔父が相次いで床についていたので、彼の母はその生家、すなわち私の家に来て産褥についた。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
