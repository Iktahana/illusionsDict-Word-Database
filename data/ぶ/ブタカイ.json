          "literary": [
            {
              "text": "こゝ半年ばかり、健二は、親爺と二人で豚飼いばかりに専心していた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人は、皆な豚飼いに早替りしていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先夜なども、今まで読んで居た本が却って目ざわりだと云って、さっさと片づけにかかりましてその代りの夜なべ仕事に近所の百姓達を呼びまして豚飼いの相談を始めました。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
