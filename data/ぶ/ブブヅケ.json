          "literary": [
            {
              "text": "未だに覚えてゐることだが、酒の後で飯になる時、幹彦君はきつと「ぶぶ漬けをおくれやす」と云ふ。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の「ぶぶ漬け」が腹が立つた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思つて私は、幹彦君が「ぶぶ漬け」と云ふと、負けない気になつて「お茶漬け」と云つた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
