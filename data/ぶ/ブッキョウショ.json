          "standard": [
            {
              "text": "古本屋の片隅で、明治時代に出版された珍しい仏教書を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "悩んでいた時期に、友人から勧められた仏教書を読んで心が救われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "大きな書店の宗教コーナーには、入門書から専門的な仏教書までずらりと並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "監房に備えつけてある書籍というものは、二、三冊の仏教書で、しかもそのいずれもが表紙も本文もちぎれた読むに堪えない程度のものであったから。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
