    "definitions": [
      {
        "index": 1,
        "gloss": "characteristic way of speaking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
