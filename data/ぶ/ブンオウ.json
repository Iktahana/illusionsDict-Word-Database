          "literary": [
            {
              "text": "文応元年七月十六日、屋戸野入道に付して、古最明寺入道殿に進め了んぬ。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日蓮が去ぬる文応元年勘へたりし立正安国論、すこしも違はず符合しぬ。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この法印は文応二年三月五日六十九歳にして念仏往生を遂げた。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            }
