          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "何気なく買った年末ジャンボ宝くじでまさかの一等に当選したと知って、あまりの驚きに一瞬心臓が止まるかと思うほど肝がぶっ飛んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
