[
  {
    "uuid": "d43fea6d-9cab-5033-92fe-fe0208504abd",
    "entry": "分封",
    "reading": {
      "primary": "ぶんぽう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
