    "definitions": [
      {
        "index": 1,
        "gloss": "death (of a person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あかね社の新井声風氏著『明治以降物故新派俳人伝』第壱輯の寄贈を受けて、当然出るべきものが出たことを喜ぶと共に著者の労を考えた。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の里の犬養老人でも丈夫ならば、差詰め世話をやくところだが、それは存亡不明であるが、多分既に物故してゐたらしい年頃である。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイテル博士に聞合せば判つた筈だが、熊楠、右の話に初めて氣付た時、聞合せに手懸りなく、其後彼人、物故したと聞て其儘打過て居ました。",
              "citation": {
                "source": "再び毘沙門に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "実業界に徳望高い某子爵は素と八兵衛の使用人であって、先年物故した夫人はタシカ八兵衛の遺子であった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳は物故する前二、三年、一時｜千束に仮寓していた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉岡は水産局の技師として十五、六年前に物故したが、東大出身の化学専攻の理学士であった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十六年の冬、紅葉が物故して以来硯友社の団結はまた旧の如くならず、あまつさえ自然主義が勃興して創作の権威が他の集団に移ったので、硯友社は漸次に凋零して今では全く過去の夢物語となった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前｜物故した細川風谷の親父の統計院幹事の細川広世が死んだ時、九段の坂上で偶然その葬列に邂逅わした。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "新帰元とあるからには、いずれ最近に物故した新仏だろうとは思われましたが、このころもこのころ、仏はふたりともに、寛永十六年十二月十二日没、すなわち去年の師走の同じ日にそろってなくなっているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石川は関東大震災の前後に物故した。",
              "citation": {
                "source": "唖娘",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに物故した松居松翁君は二十七年の十月頃から『中央新聞』に入社して、わたしと一緒に芝居を観にゆくことになって、社の編集局でも机をならべていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは研究法の方の話であるが、其の他に先達物故された法學博士、文學博士有賀長雄君の先祖有賀長伯一家の歌學といふものがある。",
              "citation": {
                "source": "大阪の町人と學問",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし進み行くべき針路は定っている」太陽をめぐる天体の運行が形容の例にとられ、そのような「拘束でない節制」を文化にもたらす組織として成立し、事業を物故文芸家慰霊祭、遺品展覧会、昨年度優秀文学作品表彰、機関誌『文芸懇話会』の発行とした。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると又、第十九世紀の後半になって自然科学が驚くべき発達を遂げ、有名なダーウィンの進化論や、細胞学説などがあらわれ、機械説が復活されて今日に至って居りますが、先年物故した大生理学者ヂュ・ボア・レーモンなどは、どちらかというと生気説に傾いて居りました。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私というような顔触れであった（京都の方で鋳金家の秦蔵六氏も当日お呼び出しになるはずであったのであるが、ちょうど数日前に物故されてこの日出頭が出来なかったのであるということを後に到って承りました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "帝室技芸員の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年物故した或る作家の遺族の話が出た折、ある事情に通じたひとが「こんなになる位なら、早く結婚させてやるのだった」云々という意味のことを云い、その、させてやる云々という言葉づかいのうちにある重い、家長権的な表情を、私は一人の女として苦痛と恐怖なしにきくことが出来なかった。",
              "citation": {
                "source": "鴎外・漱石・藤村など",
                "author": "――「父上様」をめぐって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、前者がその校内の文學會に於いて朗讀した長篇の脚本的新體詩を、他校學生の招待席から足踏みして妨害した者の仲間に、その後文學博士となつて物故した文藝批評家もゐたと同時に、北劍も亦その一人であつたことが分つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京での帝展見物のついでに、物故作家の遺作展を見てまいりましたが、婦女風俗としての絵は殆どなかったと思います。",
              "citation": {
                "source": "虹と感興",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "田能村竹田は秋水が此書を出して示した時の事を記して、「去年壬辰九月廿三日に頼山陽物故す、此年の閏十一月に内人（りゑといふ）より秋水の夫人におくられたる書を、秋水出ししめす」と云つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "成田竜玄昨夜物故、今日葬送、徳代参遣す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "初元結といえば、ずっと前に、もう物故ってしまった朱絃舎浜子が、これが、初元結だといって、一束の菊の苗をもってきてくれた。",
              "citation": {
                "source": "紫式部",
                "author": "――忙しき目覚めに",
                "note": "青空文庫"
              }
            },
            {
              "text": "女流小説家として有名な、故一葉女史は、その前年明治廿八年末に物故されている。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間自然｜淘汰で佐兵衛さんも物故した。",
              "citation": {
                "source": "勝川花菊の一生",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の級に英語を教えていた、安達先生と云う若い教師が、インフルエンザから来た急性｜肺炎で冬期休業の間に物故してしまった。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩の事業の隠れたる後援者であった山内正俊閣下が、去年の十一月に物故されて以来、吾輩が木から落ちた猿同然、手も足も出なくなっている事を、彼奴等はチャンと知っていやがるんだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時のＲ署員は悉く転任してしまっているし、犬田博士も物故している今日、筆者としては再び探り出す便宜がないようである。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はもう物故してゐた。",
              "citation": {
                "source": "漱石山房の冬",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "能勢五十雄は、中学を卒業すると間もなく、肺結核に罹って、物故した。",
              "citation": {
                "source": "父",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、私の酒飲み相手の芸妓が、今は物故しているが十一谷君を知ってる叔父をもっていて、その叔父を通じて十一谷君と面識があったので、私はその芸妓と飲む時には屡々十一谷君を連れだした。",
              "citation": {
                "source": "十一谷義三郎を語る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "支倉事件に関係した神楽坂署員のうち大島司法主任は既に支倉の訊問半にして斃れたが、当時老練の誉高く事件に活躍した根岸刑事は先年物故した。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
