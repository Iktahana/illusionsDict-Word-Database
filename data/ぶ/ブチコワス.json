    "definitions": [
      {
        "index": 1,
        "gloss": "to destroy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを家内が、どういうものだか、仙台平だとばかり思っている様子だから、今更、その幻想をぶち壊すのも気の毒で、私は、未だにその実相を言えないで居るのである。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで資本主義がどうのこうのと云ったところで、ぶち壊す資本主義がどこにあるというのだ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角の読者の感興をぶち壊すようなものじゃありませんか？",
              "citation": {
                "source": "奇遇",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は自分で毒瓦斯説を提唱しておいて、こんどは自分からそれをぶち壊すのかい。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり酷い悪口を云うと、この掛け小屋をぶち壊すぞ！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその考えている時間が、すでに自然をぶち壊す道具になって、せっかくの問が間外れになろうとしたので、とうとう口へ出さずにやめてしまった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "レマンの岸の朝ぼらけを自動車で、しかも変てこな女づれで、ぶち壊す奴は外にあるまい、がその宿のドゥ・モン・ブロンは気に入った。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "破裂すれば、自分で自分の見識をぶち壊すのと同じ結果に陥いるのは明暸であった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "本文末尾の「呆れす」は、原文では「A Kill-Ease（安らぎをぶち壊す者）」です。",
              "citation": {
                "source": "亀がアキレスに言ったこと",
                "author": "What the Tortoise said to Achilles",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は却って孔子の教育方針をぶち壊すことになってしまうかも知れない。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三〇、夜一〇時）　新居もまた余の落着きをぶち壊す。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "善いにせよ悪いにせよ、何かぶち壊すということは、時によると、やはり愉快千万なものである。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか他処の船がおまえのをぶち壊す、その船は行ってしまう、どこの船だか分らない、そこでおまえは大長丸だっと云う……こういうことだってできるからな」「そりゃあ旦那、旦那……」　銀太郎は愕然と目をつぶった。",
              "citation": {
                "source": "お繁",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前日になると「古河が銅山の鉱夫を多数会場へ送りこんで演説会をぶち壊すそうだ」そんな風説を伝えるものがあった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人が、なにかいうと、「だまれっ」と、呶鳴ったり、「ぶち壊すぞっ」と、檻車のなかで、暴れたりするのである。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやそれよりも、折角、犬千代が手をひき、親の又右衛門も、その後、考え直して来て、寧子と自分との結婚の工作が、このところ好転しかけているものを、自分でぶち壊すような結果を招来する惧れもある。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、自分ひとりの正義感が、他人の平穏な家庭生活を滅茶滅茶にぶちこわす事もあります。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金と、肉体だけが、女のよろこびだと、どこから聞いて来たのか、ひとりできめてしまって、おかげで自分が、ずいぶんあくせく無理をして、女のほうでは、男のそんなひとりぎめを、ぶちこわすのが気の毒で、いじらしさに負けてしまうのね。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの可哀そうな、可愛らしいウェッシントン夫人が自分自身の運命以外に、他の人間の運命をぶちこわすなどとは、まったく考えられないことではないか」　私はこの男の最後の言葉を大きい声で笑ったが、その笑い声に自分でぞっとした。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正史をあむということは、偉人を世の中へ出すことではなく、偉人をぶちこわすことでござる」老人の声が聞こえてきた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶちこわす方から足を洗って、造り出す方へ向かったんだからね。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "容太郎さん」お信のささやきを彼はぶちこわすように、「罰だ、罰だ！",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり野蛮人のみならず、進歩したる今日の社会においても、ややもすれば乱暴に破壊する力を逞しゅうする者が最も強いように信ぜられ、何かぶちこわすことが偉いことにされている。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれ共せっかく丸くなった気分を下らない事でぶちこわすでもないと思って奥の臼歯でかみくだいてそのまんまのんでしまった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋、いや全世界の文明力を破壊し、世界人類の幸福をぶちこわすおそろしい陰謀なんだ。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく手に入れた操縦器をぶちこわすのは、残念だが、どうも仕方がない。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その爆弾をおとされると、丸ビルの十や二十をぶちこわす事なんざ、何でもない。",
              "citation": {
                "source": "空襲下の日本",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……永年のいいつきあいを、今さらぶちこわすこともないじゃないか。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争はどこまでいろんなものをぶちこわすんでしようね……」「すべては、無条件降伏ということにあるのです。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は十字架を作ってはそれをぶちこわす遊戯に快感を感じ、切支丹と指をさされる者には石をぶっつけた。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
