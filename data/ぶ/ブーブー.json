    "definitions": [
      {
        "index": 1,
        "gloss": "bugling (sound)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幻想的なといへば幻想的な、子供だましのポンチ繪には、土瓶が鉢卷をして泳いでゐたり、日の丸の扇で踊つてゐたりするのがあるが、ブーブー唸つて走つてゐる自働車などを見れば吹き出したくなる位だ。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそのとき一台の自動車が来かかってブーブーと警笛を鳴らした。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車台の数も多く、盛にブーブーやっている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに木が雪で凍っているので、ブーブーとくすぶった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全弁があんなに白いスチームを吐いているだろう……ブーブーいってるのが聞えるかい。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして間もなく病院の前の曲り角で、二三度ブーブーと鳴らしながらピッタリと止まった。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブーブーと鞴でコークスの火を燃やして、その中で真赤にした鉄を鉄床の中に鋏で挟んで置いて、二人の男がトッテンカンと交る交る鉄鎚で叩いていた。",
              "citation": {
                "source": "贋紙幣事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そいつはね、入ろうと思う家の前でそいつをブーブーやって『今晩は！",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桑のかたい芽のついたのや、まだ茶色な樹木が、風に押しつけられてブーブー吼って居るのはこわいほどである。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ、今日はカンジンの日だのに、とか何とか、ブーブー云ってる。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかっているくせに、自分できめた予定がくずれるとブーブー云う。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の更けてから弟のそばに、ついておきて居たら黒い大きな猫が迷い込んでかやのすそに首を入れようとしながら「キャーゴー、ブーブー」とうなった。",
              "citation": {
                "source": "日記",
                "author": "一九一三年（大正二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎右手の工場で電気のエンジンを廻し出し、そのブーブーという音頭に響きやり切れず。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの電気の下に集まって、毛脛をあぐらかいて、骨ごつな指を、ギゴチなく一イ、フウ、三イ、とたどらせて行く父親をかこむ子供達が、その強張った指と、時々思い出した様に、ジーブッ、ブーブーと響く音とから、大奇籍でも現れ出そうな眼差しで、二つならべた膝に両手を突張ってかしこまって居る。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖水の西北のはずれ、リムマートの水の、落ち口に建てられたツューリッヒの街に着いたのが二時少し前で、通りに出ると、驚いた、何の御祭りだか知らないが、人波に埋められた大通りは、国旗や花で飾られて、あっちでもこっちでもブーブー楽隊がはやし立ててるんで面喰らった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "表でヤケに自動車をブーブー鳴らす奴があるのです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "このドサクサに自動車を売りとばす必要があったらしく、テクでやって来ましたが、その翌日の夕方にはもう別の立派な自動車で乗りつけて、例によってブーブーとやけに鳴らしておいてから重々しく乗りこんできました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろいたことには、金も乏しいくせに、二三日目にはまた自動車をブーブー鳴らしてやって来ました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブーブーブーと景気よく自動車が鳴りたてました。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかでブーブーと、サイレンがなりひびいている。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻っぴの、おでこの、ガニ股の、ブーブー野郎の、デクノ棒野郎の、蛆虫野郎の、飴玉野郎の、――ソノ大間抜け、口惜しかったらここまでやってこい。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなブーブーいったが、どうにもならず、一生懸命にバンカを追った。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとこの鼓子は、鼓のようにポンポン打つもんではなくて、ブーブーと吹き鳴らす器である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句をやってほととぎすへ投書をしたり、新体詩を明星へ出したり、間違いだらけの英文をかいたり、時によると弓に凝ったり、謡を習ったり、またあるときはヴァイオリンなどをブーブー鳴らしたりするが、気の毒な事には、どれもこれも物になっておらん。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ブーブー言わないの、」とアリス、「ものを言いたいのならちゃんとはっきり。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　赤ちゃんはまたもやブーブー、そこでアリスはいぶかしげに顔をのぞいてね、何かあったのかと思って。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かわいそうにその小さいのはまたもや泣いて（というかブーブー、と言っていいものやら）、しばらくは何も言わずに進んでいってね。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」するとそのときまたブーブーとうるさくするので、顔をのぞきこんでちょっとびっくり。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
