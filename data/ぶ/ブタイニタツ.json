[
  {
    "uuid": "37a3db09-f392-5f11-9010-ab7cd6ad393b",
    "entry": "舞台に立つ",
    "reading": {
      "primary": "ぶたいにたつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "Godan verb with 'tsu' ending"
      ],
      "ctype": null,
