        "examples": {
          "standard": [
            {
              "text": "祖母は毎月欠かさず観音様への仏詣を続けており、家族の健康と平穏を祈願している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "春のうららかな陽気の中、ご近所の方々と連れ立って遠くの札所まで仏詣に出かけるのが彼女の楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "年末年始の慌ただしさが落ち着いた頃、静けさを取り戻した本堂へ一人で仏詣に訪れ、手を合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "刎起こして下を覗けば、年老いたる法師一人念仏詣りて余念無し。",
              "citation": {
                "source": "稚子法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
