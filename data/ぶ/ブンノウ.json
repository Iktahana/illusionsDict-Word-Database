    "definitions": [
      {
        "index": 1,
        "gloss": "installment payment (instalment)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
