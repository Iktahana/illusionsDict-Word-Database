    },
    "definitions": [
      {
        "index": 1,
        "gloss": "brooch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まるで、腕輪か、ブローチのように、キラキラかがやいたからです。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お京さんへの土産に買って来た伊太利フローレンス製の大理石のモザイクが小さな箱に納まったブローチとなって加奈子のポケットへ忍ばせてあった。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにとりわけ、フリーメイソンの厳格な規律に背いて、身分を表す円弧とコンパスのブローチをつけていらっしゃいる。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "地味な黒い平服を着て銀のブローチを胸に垂れた深谷夫人は、まだ四十を幾つも越さぬらしい若々しさだ。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "両前のコートの袖と襟にはアストラカン毛皮が広く付いていて、肩から羽織った濃紺のマントは裏地に炎色の絹を使い、首留めはきらびやかな緑柱石のブローチだった。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィクトーリア女皇が贈ったブローチを白レースの襟の上に飾ったナイチンゲールの肖像は世界の隅々にまで流布した。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手の壁にそれでも一枚、大きなブローチをつけた西洋の婆さんの写真が吊下げてある。",
              "citation": {
                "source": "部屋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "箪笥の上には高価な指輪が二つと、ダイヤ入りのブローチが一つ、元のままに載っていて、陳列｜玻璃函の中の骨董品にも手を触れた形跡がなく、室の中は整然となっていたそうです。",
              "citation": {
                "source": "ペルゴレーズ街の殺人事件",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　冗談にまぎらせてそう呟くものの、事実矢代は氷河の尾根を軽軽と乗り越す千鶴子に疲労の様子の少しもないのを見ては、振り向く度びに胸に光る彼女のブローチの金具が腹立たしかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜母上御木本からブローチのいいのを買っていらっしゃった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰り際になると、私は女執事からこのような立派なダイヤ入りのブローチを貰いました。",
              "citation": {
                "source": "奇賊は支払う",
                "author": "烏啼天駆シリーズ・１",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり三日間の勤務に対する代償だというんです」「いいブローチですね」「かねて烏啼天駆は、掏摸といえども代償を支払うべしとの説をかかげていたのですが、彼はそれを自ら実行しているのですよ。",
              "citation": {
                "source": "奇賊は支払う",
                "author": "烏啼天駆シリーズ・１",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の三日間の窒息しそうな勤労に対してこのブローチ一箇が代償なんです。",
              "citation": {
                "source": "奇賊は支払う",
                "author": "烏啼天駆シリーズ・１",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは天駆があなたの令夫人に対して贈ったものですから、そちらへお収め下さい」　といって探偵猫々はその土産のブローチを苅谷氏の手に握らせた。",
              "citation": {
                "source": "奇賊は支払う",
                "author": "烏啼天駆シリーズ・１",
                "note": "青空文庫"
              }
            },
            {
              "text": "また指環や、ブローチや、耳飾や、腕環などもあつた。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はブローチの一本や二本にこだはる人間ぢやねえよ。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にも彼は、隅の金庫を開いて中から取出した貴金属細工のついた帯留や指環の箱、宝石入りのブローチの箱、腕環の箱などをその鞄の中、ほどよきところへ押込んだ。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い衣にマッカのルビーのブローチをして、水色のバンドをしめた女は若い詩人の頬に頬をよせて小さいふるえた声でささやくように云いました。",
              "citation": {
                "source": "無題（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪をカールし、いい香りの白粉をぬりこみ、唇にさんご色の口紅をぬり、空色のドレスを着せ、腕環、首かざり、ブローチなど、装身具でかざりたてました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、おかあさんも満足そうにいって、今しがた娘たちが胸にとめてくれたブローチをなでました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦長に連れられて死体のそばへ寄ったとき、一人一人のあどけない顔に涙はあふれたが、最後に山下秀子のそばにしゃがみ、皮は焦げてむけながら、おでこや丸い鼻など生きていた先刻の面影さながらなのを見、ちぎれ飛んだ防空服のわずかに胸に残った小犬のブローチを手にしたとき、おのずから声に出でて泣き出した私であった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、ブローチにしてこれも胸を飾る。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部には係の者数名が、青年たち自らの手によつて撰びとられた、バッヂとブローチを、めいめいの胸につけてやる。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、あたしも、それを想ひ出してゐたの」　一人の少女が、いま胸につけてもらつたブローチを気にしながら、歩いて来る。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "真珠のブローチを貰つた日に、エレーヌにぶつかつた、あの少女である。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "真珠のブローチを忘れてゐない。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の入口まで来て、ふと、胸に眼をやると、ブローチがない、どこかへ落して来たのである。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "静江とお高さんが、ブローチを探しあぐねて帰つて来る。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "静ちやん、ちよつと、いらつしやい」　縁側に静江を待たせて、梅代は、例の小函から、形はちがふが、ま新しい一つのブローチを取り出す。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのブローチには、いつの間にか、例のカンザシになつてゐた大粒の真珠がついてゐる。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
