    "definitions": [
      {
        "index": 1,
        "gloss": "education",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "故松田文相の外来語排撃の旗印は文教の府の首班として確かに卓見であった。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに我国の文教の枢府ではこの事実に無神経である。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子のよいときの武帝は誠に高邁闊達な・理解ある文教の保護者だったし、太史令という職が地味な特殊な技能を要するものだったために、官界につきものの朋党比周の擠陥讒誣による地位（あるいは生命）の不安定からも免れることができた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "式を挙げるに福沢先生を証人に立てて外国風に契約を交換す結婚の新例を開き、明治五、六年頃に一夫一婦論を説いて婦人の権利を主張したほどのフェミニストであったから、身文教の首班に座するや先ず根本的に改造を企てたのは女子教育であった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田内閣は自分の文部省の手で文教改革の骨組を決めてしまうことに努力した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し友人はまだ某女學校の國語漢文教師であつて、僅かの俸給によつて、夫婦に子供ふたりの生計を立てて行く人――交際も狹からうし、また義雄一個がその生計の一部分に影響しては、苦しい事情があるかも知れない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "辭書は文教のもとゐたること、論ずるまでもなし、その編輯功用の要は、この序文にくはしければ、さらにも言はず。",
              "citation": {
                "source": "ことばのうみのおくがき",
                "author": "大槻文彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの侯伯には、食前方丈侍妾數百人をはぶきて、文教の助けとある浩瀚の書を印行せしもありき、今の世にはありがたかり。",
              "citation": {
                "source": "ことばのうみのおくがき",
                "author": "大槻文彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは廃れたるを起し、新しきを招かれたそればかりでなく、音楽や芸術のたぐいにとりてばかりでなく、すべての文教のために、忘れてならないお方でおわしました。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつまた、文脩まれば武備もしたがって起り、仏人、牆に鬩げども外その侮を禦ぎ、一夫も報国の大義を誤るなきは、けだしその大本、脩徳開知独立の文教にあり。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の學者は多く之によつて彼を人道の敵、文教の仇と信じて居る。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "反非予以文教定民之本心矣。",
              "citation": {
                "source": "支那人辮髮の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "文教の職にあたった政治家は、たくさんあるけれども、なんらの功績を残さぬ者が多い。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年出た本誌の論文――「現代口語文の缺點について」――などは、實はもつと國語・國文教育者が、反省してもよい筈だつたと思ふ。",
              "citation": {
                "source": "詩と散文との間を行く發想法",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一例として、幼年学校の教育綱領とでも云ふべきもの、中に、作文教授の方針を規定して、「小説的なるべからず」といふ一項目が掲げられてゐたことを記憶する。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまた、近頃の政治家には珍しい声明であつて、国民はこの見識のもとに生れる将来の文教政策には満幅の期待を寄せていゝと思ふ。",
              "citation": {
                "source": "一国民としての希望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、文教に関する新事業が決して不急事業に非ざることを戦時予算の面にはつきり表はしてほしい。",
              "citation": {
                "source": "一国民としての希望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国の文教が「哲学的に」考察され、支配され、再建される希望が、今日はじめて「降つて湧いた」といふことは、国民にとつて、何といふ仕合せであらう。",
              "citation": {
                "source": "一国民としての希望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞や雑誌の膝をくづした記事にさへも、おほかたわが文教の府の声色がそのまゝ使はれてゐるのに驚くくらゐである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治の領域で、文教政策の占める地位といふものが、日本では、いつの間にか、ほかとの釣合がとれなくなつてゐるのである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は師も文教の上にあるいは神社行政の上に、この御一新の時代を導く年老いた水先案内である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを中央に見ても、正香のいわゆる「政治を高めようとする」祭政一致の理想は、やがて太政官中の神祇官を生み、鉄胤先生を中心にする神祇官はほとんど一代の文教を指導する位置にすらあった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには文武共に今日改造の途上にあることを一応考慮しないではないが、ひとまず文教をあと回しにする、この際は断然武政を布いて国家の独立を全うするためには外国と一戦するの覚悟を取る、それが国を興すの早道だというのである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと言っても、以前の神祇局は師平田鉄胤をはじめ、樹下茂国、六人部雅楽、福羽美静らの平田派の諸先輩が御一新の文教あるいは神社行政の上に重要な役割をつとめた中心の舞台である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし文部省は文教の府だけに済々たる学者の淵藪でもあれば、必ず理のある我輩の言に耳を傾ける事がないでもなかろう事を期待している。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ可笑しいことは、作文に常に落第点を附けられて居た私が、その後に書いた文章が、今日の中学校や、高等女学校の国文教科書の中に名文の例として幾つも載せられて居ることである。",
              "citation": {
                "source": "落第と退校",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて徂徠派の病弊を指摘し、その偏見を道破し、汎く支那歴代の文教を一般に渉って批判攻究すべきことを説く新しい学派が勃興した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川氏の天下を治めたる文教の力｜与りて大ならずとせず。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧んぞ知らんや、この文教なるものは封建制度を寸断する危険なる分子をその中に含まんとは。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "文教を楯として天下を治めんとしたる徳川政府は、早くも文教を箭として、己に向い弓を挽くものを見出しぬ。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
