[
  {
    "uuid": "97722702-f3e4-5844-ba97-2a9984450d73",
    "entry": "分乗",
    "reading": {
      "primary": "ぶんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
