  {
    "uuid": "13d3ab43-a64f-5498-ac27-c62d79c07ba4",
    "entry": "ブギ",
    "reading": {
      "primary": "ブギ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "boogie-woogie",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軍歌に変って流行歌があらわれ、それは映画の主題歌から最近ではアメリカ流行のブギウギの真似までがある。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天のワカ彦が天照大神の返し矢で胸を射ぬかれて死んだのは藍見川の左側ですが、両面スクナのヒダ伝説によると、彼がミノへ出陣して矢で負傷して敗退した地点はブギ郡の下保で、実に藍見川をはさんでちょうど右と左なのです。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクナは敵軍来るときいて、ミノのブギ郡の下保へ出陣したとあるが、そしてその辺がたしかに両面神の最も主要な戦場を暗示しているのは事実であるが、ケサ山千光寺の所在地をヒダの丹生川村｜下保という。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代においては俗悪な、そして煽情的な実用品にすぎないジャズやブギウギが、やがて古典となって、モオツァルトやショパンのメニュエットやワルツと同じ位置を占めるようになるものなのだ。",
              "citation": {
                "source": "“歌笑”文化",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "アベックや壺坂に出た男の人はみな原さんたちパレスの役員で、「買い物競争」には場内の電蓄から笠置シヅ子の「買物ブギ」の※おっさんおっさんこれなんぼ――の唄が軽快に流れてきたのも、時にとっての一興だった。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、神田を発ったのは遅かったにしても、馴染があるとか何んとか、仲間の者に誘われて、高輪で宿を取ってしまい、『おいとこそうだ』に『炭坑節』『トンコ節』から『東京ブギ』の類いまで踊ったり唄ったり、あらゆる酔態を見せた一行の、オンド取りの八五郎が、お六に甘く見られたのも無理のないことでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、神田を發つたのは遲かつたにしても、馴染があるとか何んとか、仲間の者に誘はれて、高輪で宿を取つてしまひ、『おいとこさうだ』に『炭坑節』『トンコ節』から『東京ブギ』の類ひまで踊つたり唄つたり、あらゆる醉態を見せた一行の、オンド取りの八五郎が、お六に甘く見られたのも無理のないことでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビル・ヘイリーの一九五二年のレコード『ロッカビーティンブギー』には、「ロック、ロック、ロック、エヴリバディ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときすでに、ジャズはよりブラックなジャズと、よりホワイトなジャズとにわかれていて、たとえばジャズにとっての最終的な楽器だと考えられていたピアノがつくるジャズに、ラグタイムとブギウギとができ、ラグタイムは様式の音楽、ブギは自由なアドリブの音楽として、わかれたままつづいていった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブギのリズムにウォーキング・ベース、ギターのソロ、コーラス、リード・ヴォーカル。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャック・フィナの『バンブル・ブギ』を覚えました。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめに聞いたのは、ブギウギのピアノです。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてレコード仕込みのブギウギやら与太を飛ばしたりしてお客のぼくたちに、お愛想のつもりか、しきりに皆を煙に捲く。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
