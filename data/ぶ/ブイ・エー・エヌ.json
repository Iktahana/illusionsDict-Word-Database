        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "慶一はあわてて、いま閉めたロッカーの鍵をあけ、ＶＡＮの白いスニーカーをひっぱりだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡辺との激しいつばぜり合いの末にＰＣ―９８０１を立ち上げた浜田俊三は、ＰＣ―９８０１のアーキテクチャーを完成させるＶＭ★の発表の直前、一九八五（昭和六十）年七月にＶＡＮ販売推進本部本部長に異動となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "京宝前の伴淳三郎の店ＶＡＮで冷コーヒーをのみ、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日ビル地下で、まづい食事をして、ＶＡＮでコーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＶＡＮに寄り冷コーヒーのみて出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀井と出て、ＶＡＮでコーヒーを飲み、座へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "町へ出ようと思ったら、夕立――ＶＡＮへ入りコーヒーのむ、夕立長く一時間半もとぢ込められた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから伊東とハマムラで、シウマイ、中華丼に雲呑を平げて、ＶＡＮへ寄り、みつ豆とコーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房と京極へ出る、太智吉瀬戸物屋を見たが欲しいものなく、ＶＡＮへ寄り、冷コーヒーとみつ豆食って、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
