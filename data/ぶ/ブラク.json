        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若山牧水の生地の直ぐ隣りの部落に友人がゐて、来いといふ。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "急坂を登り切らうとする所、村の部落外れに、荒ら屋がある。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水無川を越えて山腹にかけ山民の部落があった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は容貌も美しかったので、かかる才能と共に、輩下の部落の土民の間で褒めものにされた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしに、さっぱりそんな慾はなくってよ」　捨てるともなく誇りと励みに背中を向けかけると、ふた親が説く、山の祖神の偉さというものより部落の間の噂に遺っている山の祖神の偉からざる方面のことが女には懐しまれて来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし部落の土民たちがこれを語るときに現す、山の祖神に対する親しげな面貌よ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伯母さんなんかに遇ったってつまんないじゃないか、もう帰ろうよ」　部落の土民の間では、こういういい慣しがあった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の生き方は、どんな憂き艱難をしても、野に山に、街に部落にさすらって歩くのがその性質に合う生き方なのでした。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高原のへりから、四方に出たいくつかの谷の底には、ほんの五、六｜軒ずつの部落があります。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春になると、北上の河谷のあちこちから、沢山の馬が連れて来られて、此の部落の人たちに預けられます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の部落がずっと下に見え、達二の家の木小屋の屋根が白く光っています。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スマトラのドラゴイア人の中で病人が出来ると、その部落の魔法使いを呼んで来て、その病気が治るか治らないかを占わせる。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のいる温泉地から、少しばかり離れた所に、三つの小さな町があった、いずれも町というよりは、村というほどの小さな部落であったけれども、その中の一つは相当に小ぢんまりした田舎町で、一通りの日常品も売っているし、都会風の飲食店なども少しはあった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの語るところによれば、或る部落の住民は犬神に憑かれており、或る部落の住民は猫神に憑かれている。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした特異な部落を称して、この辺の人々は「憑き村」と呼び、一切の交際を避けて忌み嫌った。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にこの種の部落の一つは、つい最近まで、この温泉場の附近にあった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の諸国にあるこの種の部落的タブーは、おそらく風俗習慣を異にした外国の移住民や帰化人やを、先祖の氏神にもつ者の子孫であろう。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは多分、もっと確実な推測として、切支丹宗徒の隠れた集合的部落であったのだろう。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの裏日本の伝説が口碑している特殊な部落。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　半里ばかり向うの沼のほとりに、鮮人部落がある。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼は、それと同じことを、鮮人部落の地理や、家の格好や、その内部の構造や、美しい娘のことなどを、執拗に憲兵隊で曹長に訊ねられたことを思い出した。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復一里もあるその部落へその女は負い籠を背負って行ったそうだが、結果がどうなったかは帰って来ても喋らない。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川添いの小さい部落の子供達は、堂の前に集った。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　隣部落の寺の広場へ、田舎廻りの角力が来た。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落一帯の田畑は殆んど耕されていなかった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主の坊ちゃんは、部落の子供達を集めて、それぞれ四五尺の棒を手にして、猫を追っかけてぶん殴りに来た。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年猪の子に旦那の家から部落中に配ってくれる団子は、その年に限って、おりくの家へだけは呉れなかった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ユフカ村から四五露里｜距っている部落――Ｃ附近をカーキ色の外皮を纏った小人のような小さい兵士達が散兵線を張って進んでいた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』このときに渡の媼呻ぶらく。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、まだ私は、家でしずかにして、ぶらぶらくらしている年ではない、と思いました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            }
          ]
        }
