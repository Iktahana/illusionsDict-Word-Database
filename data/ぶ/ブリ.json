[
  {
    "uuid": "171a387e-dd63-5dc0-b354-42ef64e4bcd9",
    "entry": "振り",
    "reading": {
      "primary": "ぶり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "校長がもし人望のよい人である場合は、文部省によつて、アツサリ放校が取消されたにしても、何らか校長の顔を立てるためには生徒の方に臨時の損が振りかけられたに相違ありません。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬や小鳥やの動物は、単に鼻を嗅ぎ合うとか、尾を振り合うとか、目をちょっと見合すとかいうだけで、相互の意志が完全に疎通するのに、人間は廻りくどく長たらしい会話をして、しかもなお容易に意志を通じ得ない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ととさまえのう、と泣いて慕う子を振り切って、宗五郎は吹雪の中へ走って消えます。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、振りかえりざま、叫ぶようにして言った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎょっとして振りむくと、馬場の右脇にコバルト色の学生服を着た背のきわめてひくい若い男がひっそり立っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文楽は学生時代にいちど見たきりで、ほとんど十年振りだったものですから、れいの栄三、文五郎たちが、その十年間に於いて、さらに驚嘆すべき程の円熟を芸の上に加えたであろうと大いに期待して出かけたわけですが、拝見するに少しも違っていない。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、振り向きもせず、さうかな、惡くなつたかな。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い、情に溺れ易い、好紳士に限って、とかく、太くたくましいステッキを振りまわして歩きたがるのと同断である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂家の玄関に於いて颯っと羽織を着換え、紺足袋をすらりと脱ぎ捨て白足袋をきちんと履いて水際立ったお使者振りを示そうという魂胆であったが、これは完全に失敗した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は五年振りで東京へ来て、謂わば興奮をしているのだろう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、また大隅君にとっては、この五年振りで逢った東京の友人が、相変らず迂愚な、のほほん顔をしているのを見て、いたたままらぬ技癢でも感ずるのであろうか、さかんに私たちの生活態度をののしるのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の実業家らしいのですが、財産やら地位やらを一言も広告しないばかりか、名誉の家だって事さえ素振りにあらわさず、つつましく涼しく笑って暮しているのですからね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "棟方志功氏の姿は、東京で時折、見かけますが、あんまり颯爽と歩いてゐるので、私はいつでも知らぬ振りをしてゐます。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "棟方志功氏の姿は、東京で時折、見かけますが、あんまり颯爽と歩いているので、私はいつでも知らぬ振りをしています。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論私は茲で多く読まれる少なく読まれるの問題には関係なく、小説と、通俗小説との、通念としての確立振りを問題にしてゐるのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母さんが台所に這入ると、小僧は天秤棒を担ぎあげて、「ありがと、存じました」といふや、赤い手を振りながら、さつき良子が隠れた、あの通路の方へ行つた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "良子は机の上に振り向くと、家の中は暗くつて、机の上に池の中の鯉や舟を、縁に立つて見てゐる二人の男の子の描かれた挿絵がボンヤリ出てゐる。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の背後の方の戸が開く音を聞くと直ぐ彼は振り返つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「前はお父さんとお祖母さんだけだつたのに……」と言ふ母の言ひ振りを祖母は勿論、父も次の室で聞いてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことは三四年振りだつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「その頃の生活」を離れてから六ヶ月振りの事だ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「久し振りだつたなあ……、他所に行つてるとズルケられて好いだろ」　ポツカリ此の春までの同級生に出遇つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の屋蔭の苔むしたる井筒に、新調の洋服涼しげなる若人二人、巴里形の麥藁帽子見よげにかぶりて、細き櫻のステツキを手すさびに振り上げ、花もまだきなる紫陽花の葉を叩きつ、あやめを隔ててこなた、うちまもり給へるなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『芳……芳ちやん』群集を振り返た時にはおろおろ聲で眼が血走つて居る。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は父の机の前に足と投出したままで無心に華車な浴衣の後姿から白い衿頸を見上げた時、女は肩越しにチラと振り向いたと思う間に戸をはたとしめた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "振りむいたとき見ると荒物屋の娘であった。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネルンストの「物理化学」もひやかしに一、二度聴いたことがあったが、西洋人にしては脊の低いずんぐりした体格で、それが高い聴講席をふり仰ぎながら活溌に手を振り身体を動かし頸を曲げてゼスチュアの賑やかな講義をして見せた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "村外れの茶店で昼飯を食った時に店先で一人の汚い乞食婆さんが、うどんの上に唐辛子の粉を真赤になるほど振りかけたのを、立ちながらうまそうに食っていた姿が非常に鮮明に記録されている。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェスヴィオ行きの準備をして玄関へ出ると、昨日のポルチエーが側へ来て人の顔を見つめて顔をゆがめてそうして肩をすぼめて両手の掌をくるりと前に向けてお定まりの身振りをした。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下のは絶えず右に左にからだを振り動かしている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
