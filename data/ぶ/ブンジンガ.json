    "definitions": [
      {
        "index": 1,
        "gloss": "style of Southern Chinese painting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "叙事は謂はば文人画風の型を作り、かくて人間的心情は所謂美――私にとつてはデコレイション――とその余りの部分とに分裂した。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "文人画の元祖である中華民国でも、美術の本場であるフランスでも、一般人士の間にはたして日本の老幼男女に共通な意味でのよい景色を賞観する心持ちがあるかどうかわからない。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く死んだ青年の父は、天才の素質を帯びている不遇な文人画家であった。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この縁側の附いている八畳の間には、黒塗の太い床縁のある床の間があって、黒ずんだ文人画の山水が掛っている。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳のある土手へ白堊塗りのそり橋がかかってその下に文人画の小船がもやっていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボートの上にカンバスをかまぼこ形に張ったのが日本の屋根舟よりはむしろ文人画中の漁舟を思い出させた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし渓流が処々に山村を点綴して、白堊の土蔵あり、田舎籬落あり、時にはトンネル、時には渓橋、時には飛瀑、時には奇岩といふ風に、行くままに、進むままにさながら文人画の絵巻でも繙くやうに、次第にあらはれて来るさまは、優に天下の名山水の一つとして数ふるに足りはしないか。",
              "citation": {
                "source": "耶馬渓の一夜",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ふうの黒いシタミや白い壁や大きい栗の木や柿の木や井字形の井戸側やまばらな生垣からは古い縁側に低い廂、文人画を張った襖などもあきらかに見すかされた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　四条に居た時分、私の十幾つ位のときで、まだ絵を習はなかつた時分に、南画を、文人画といつて四条派よりも狩野派よりも、さかんに世上にもてはやされて居りました。",
              "citation": {
                "source": "思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも私の十二、三の頃に、すでに文人画がはやるのだといふことを、よく聞きおぼえて居ります。",
              "citation": {
                "source": "思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "また文人画の修業に京都に来ているという画学生から、竹や蘭の絵をもらったこともありました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "南宗は文人画で主任が巨勢小石先生。",
              "citation": {
                "source": "画学校時代",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ田能村直入だとか明治年間には南画――文人画が隆盛だったので、百年先生もその影響をうけて南画風のところが多少あったように記憶している。",
              "citation": {
                "source": "三人の師",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに宗十郎の実弟には、評判の高い田之助があったし、有明楼は文人画伯の多く出入した家でもあったので、お菊はかなりな人気ものであった。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "振返ると背面の入江は幾百の支那ジヤンクを浮べて浅黄色に曇つたのが前面の忙しげな光景と異つて文人画の様な平静を感ぜしめる。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖の草枯れ黄み、この喬木の冬枯した梢に烏が群をなして棲る時なぞは、宛然文人画を見る趣がある。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男俊蔵は御先手組の与力で文人画を善くし霞舫と号した。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはこれをば室内の光景扁額書幅の題詩などと見くらべて屡文人画の様式と精神とを賞美した。",
              "citation": {
                "source": "砂糖",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治初年西田｜春耕と云う文人画家は嗜口小史を著して当時知名の士の嗜み食うものを説明した。",
              "citation": {
                "source": "砂糖",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは昭和三年に「パンの会」の油絵を描いたが、パンの会は明治四十年代早々に催された文人画家交歓の会合で、木下杢太郎氏あたりが主唱となり、メムバーは相当広範囲に渉つて、谷崎さんも出席したし、永井荷風さんあたりも顔を見せたやうだ。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い時分だから池の中はただ薄濁りに淀んでいるだけで、少しも清浄な趣はなかったが、向側に見える高い石の崖外れまで、縁に欄干のある座敷が突き出しているところが、文人画にでもありそうな風致を添えた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はこれでは何だか簡単過ぎるようだなと考えていたが、ええ面倒臭い、文章は御廃しにして、銘だけにしろと、筆を十文字に揮って原稿紙の上へ下手な文人画の蘭を勢よくかく。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者は大和絵と文人画と御舟と龍子との混合酒を造ってその味の新しきを誇り、ある者はインドとシナの混合酒に大和絵の香味をつけてその珍奇を目立たせようとする。",
              "citation": {
                "source": "院展日本画所感",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文人画の趣味がこういう景色に培われて育ったことはいかにももっともなことである。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵画においては、平安朝の絵巻やその後の宋画・文人画・浮世絵、あるいは琳派の装飾画に至るまで、種々の方面にこの巧さを生かせている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか大正四年の紅葉のころで、横浜の三渓園へ文人画を見に行ったのである。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんその関係であろうと思うが、そのころにはしきりに文人画の話が出た。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい文人画を見た記憶などを漱石はいかにも楽しそうに話した。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三渓の蒐集品は文人画ばかりでなく、古い仏画や絵巻物や宋画や琳派の作品など、尤物ぞろいであったが、文人画にも大雅、蕪村、竹田、玉堂、木米などの傑れたものがたくさんあった。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
