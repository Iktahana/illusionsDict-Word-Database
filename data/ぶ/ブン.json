[
  {
    "uuid": "86ab9a3b-2e9b-5380-b07a-55ade2805f07",
    "entry": "分",
    "reading": {
      "primary": "ぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
