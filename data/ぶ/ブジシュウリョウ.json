        "examples": {
          "standard": [
            {
              "text": "大きなトラブルもなく、三日間にわたる大規模なイベントが無事終了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "システム移行の作業が深夜に無事終了し、プロジェクトチームの間に歓声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "本日の業務はすべて無事終了いたしましたので、これより戸締まりをして退社します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いよいよほんとうに、試運転は無事終了らしい。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで試運転は無事終了ということにしよう。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大會の決議は折衷的な評議員案が成立して無事終了しましたが、黨そのものが禁止されたので、いささかとびに油揚をさらはれた形になりました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "保は、二十日間のドイツ語講習会を無事終了。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お産が一月かですから、それが無事終了までは宿題を夫婦でかかえているようなもの故本当にほっとはしないのでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの風邪、どうぞ無事終了のように。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が家中の総大将という憫然なことになってしまって、其でもどうやら無事終了。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
