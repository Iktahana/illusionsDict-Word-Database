[
  {
    "uuid": "a5ec9232-bb76-51c5-853a-bc2c86c7dcee",
    "entry": "橅",
    "reading": {
      "primary": "ぶな",
      "alternatives": [
        "ブナ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese beech (Fagus crenata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "従つてセンチメンタリズムに堕することからあぶない所で脱かれてゐる。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれは喜ぶなが影の、すがたの海に跳び入りて、眼に腕にかい抱き、それな固有のざはめきに、なれがこゝろはなごむなり、抑へがたなきはた荒き、浪の歎きのかの響き　もはや眺めてはゐられなくなつた、跳び込んで、眼に腕にかい抱き、それな固有のざわめきに、なれがこころはなごむのだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶない事はありません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人の踊りは見ていてちっともあぶなげがない。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真偽はとにかく、彼女からこういううぶな態度を見たいためにも、若い女たちはしばしば訊いた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはあぶなく声をあげて泣き出さうとしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急だぞ、草、この木は細いぞ、青いぞあぶないぞ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶなく渡る、二人がわたる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそのおしまいの一足だけがあぶないぞ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、どうもあぶないと僕も思った。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私が挨拶しましたらその人は少しきまり悪そうに笑って、「なあに、おうちの生徒さんぐらい大きな方ならあぶないこともないのですが一寸来てみたところです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもあぶないじゃないか。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此坂を下りてあしこへ行きて暫時やすまん、つかれては話しも厭やなればと仰せあるに、さらば歸りたまふか、厭々、今しばし遊ばんとて、苔なめらかなる小道を下らるゝに、おあぶなしと言へば、氣のどくなれど其肩をかし給へとてつと寄りて此處を下りぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぶな恋も野暮である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また例えば、清元の「十六夜清心」のうちの「梅見帰りの船の唄、忍ぶなら忍ぶなら、闇の夜は置かしやんせ」のところも同様の形をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い覚悟で行った札幌は暖かすぎて、下手なあぶなっかしい講演をやっていると額に汗ばんだ。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池があぶないあぶないと思っていながら、何という不注意なことをしたんだろう。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶないといっていながら、なぜ早く池を埋めてしまわなかったか。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "充実したつもりで空虚な隙間だらけの器物はあぶなく、有為なつもりの無能は常に大怪我の基である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりした景色のなかで、白いくるまやさんの足はいそげども、ゆくゆく車輪がさかさにまわり、しだいに梶棒が地面をはなれ出し、おまけにお客さまの腰がへんにふらふらとして、これではとてもあぶなさうなと、とんでもない時に春がまつしろの欠伸をする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてそこには人知れぬ非常な苦心｜骨折があり、ひよつとすると命のあぶないやうな危險にも出會はなければならず、世間の人達からは妙に無氣味らしい眼を向けられると云ふやうな譯で、可成りつらい、厭やな仕事です。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
