  {
    "uuid": "f4f060e3-7181-589d-a36b-631c2bcee4b8",
    "entry": "ブナ",
    "reading": {
      "primary": "ブナ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Buna",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ママサマ、少シモアブナイ事ハアリマセン。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士山中で、大宮口の森林として、もっとも名高いモミ、ツガ、ナラ、モミジ、ブナなどの、夏なお寒い喬木帯を通過する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａは彼女の白い足裏に、焚火の残りの消炭か何かで黒く、（アブナイ！",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七夜「波打ちぎわにそって、カシワの木とブナの木の森がひろがっています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れ故郷のオーデンセは、ブナの木の林のあいだに麦やウマゴヤシの畑がかぎりなく続いているフューン島という美しい緑の島にあった。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルト海のほとりの、デンマークの、ブナの木の森のそばに――』『すばらしいはじまりだなあ！",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の国のデンマークでは、春になると、たった一晩のうちに、ブナの森が、いっせいに、みどりの芽を出すことがあります。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "アブナイアブナイ」　とヒョロ子に獅噛み付きました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゼサンヤンドクレパパノオフネアブナイヨ　汽車が停った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクリブナー誌連載中の「難破船引揚業者」第二十三章書上げ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本一アブナイ運の神様ですが、迷うておりました私は大喜びで、そこへボンヤリ這入って来た、今の話のツン州という若者と三人で久し振りに前祝を一パイ遣って、夜汽車に乗って長崎へ来ました。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋冬ブナやカシの下の地中に生ず。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　アカシヤやブナやハクヨウが一面に深くしげつて、わけて行く草道は、ともすれば人の肩を没するほどそれほど深かつた。",
              "citation": {
                "source": "草道",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌麿からずっと後になって江戸浮世絵の最も官能的描写に成功したあの一勇斎國芳の画いたアブナ絵が眼の前に生命を持って出現したかのような情景だった。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "床脇はシロコの地板、サビタ瘤の地袋ばしら、ヤチダモ根の木口包み、オンコの上棚板、ブナの下げづか。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルキスには家来のアブナアが護衛兵の先頭に立つて女王を救ひに来たのが見えた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "アブナアは三度バルキスの足下に拝伏して、それから女王を迎へる為に用意した輿を持つて来させた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時アブナアの側に立つてゐた魔法師のセムボビチスと宦官のメンケラとが、おそろしい叫び声をあげた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都へは一週間ほど前に、伯父の病気がアブナシとの電報があつたので母はもう老齢で行けないし、自分独りで葬式に参列するつもりで発つたのである。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ　立山二月九日　曇　九・二〇千垣　一〇・〇〇芦峅　一〇・一五藤橋　二・二〇材木坂頂　四・〇〇ブナ坂避難小屋　藤橋の手前でスキーを履く。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか深山らしき大森林なり（ブナ帯）笹原を下り、平湯に出ず（十時半）十一時同所出発、鉱山跡を通り乗鞍大滝を見ながら上る、非常に大きな滝なり。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤橋十一時昼食をなし、草鞋を買い出発、川を渡りて急峻を攀じ高原へ出でブナ小屋にて休む。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥前畑へ下る前に眺望開けて扇ノ山と立山すなわちブナの木の尾根あの雄大な高原が見える。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中ブナの木も樹氷で綺麗に飾られていますし、ボサも殆んど雪の下なので気持よく歩けました。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上の少し手前で森林に入り、それを抜けるともう後の方に三ツヶ谷を越して扇ノ山が見え三ツヶ谷と仏ノ尾の鞍部にブナノ木ノ尾が現われてきました。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山は私が肥前畑の人から聞いてブナノ木ノ尾という山だと言いましたが、これは間違いで実は煙がヅツコーと言うのだそうです。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山にブナ乱という鞍部があるからそれで間違ったのだろうと宿の人が言っていました。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千垣駅午前九時十分、芦峅寺着九時四十分、出発十時四十分、藤橋十一時五十分着、昼食、午後一時出発、ブナ小屋五時弘法小屋着九時。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇〇〇メートルくらいからスキーを履き、一三〇〇メートルくらいまで登ってから、雪が堅いのでスキーその他不要のものをブナの木の根に置いて行く。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
