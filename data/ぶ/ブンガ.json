    "definitions": [
      {
        "index": 1,
        "gloss": "elegant or refined style",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "斯様いう性格で、手厳しくもあり、打開けたところもあり、そして其能は勇武もあり、機略もあった人だが、其上に氏郷は文雅を喜び、趣味の発達した人であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇も文雅の道にいたく御心を寄せられたこととて、露は濃やかにして　緩く語る　園花の底、月は落ちて　高く歌ふ　御柳の陰。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢の御笥作り内人土屋氏は昔槌屋と称え、豪富なりしを悪み数十人囲み壊りに掛かりかえって敗北した時、荒木田守武の狂歌に「宇治武者は千人ありとも炮烙の槌一つにはかなはざりけり」、蛆虫を宇治武者にいい做したのだ（石崎文雅『郷談』）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の外曾祖父というのは戯作好きでも書物好きでも、勿論学者でも文雅風流の嗜みがあるわけでもないただの俗人であったが、以て馬琴の当時の人気を推すべきである。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り名文ではないが、喜兵衛は商人としては文雅の嗜みがあったので、六樹園の門に入って岡鹿楼笑名と号した。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に江戸文化の爛熟した幕末の富有の町家は大抵文雅風流を衒って下手な発句の一つも捻くり拙い画の一枚も描けば直ぐ得意になって本職を気取るものもあった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この絢尭斎というは文雅風流を以て聞えた著名の殿様であったが、頗る頑固な旧弊人で、洋医の薬が大嫌いで毎日持薬に漢方薬を用いていた。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁田の家の中で目に付くものは古び、廃れて行く物質の中に活き残る品と礼と文雅との光であった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに安政中より維新に至るまでの間に、狩谷従之と云ふものがあつて、文雅人名録の類に載せられてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "主水は兄の庄八郎やまた長兄の惣蔵が武勇一図の人間であるのと大いに趣きを異にしてきわめて文雅の人物であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家元の藤舎芦船といった加藤某は、世をすねて、風流文雅に反れた士である。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢学の深浅を論ぜん歟、下士の勤学は日浅くして、もとより上士の文雅に及ぶべからず。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより私の見方は、文章の上から見てのことばかりだが、後に多くの文雅の士がさうした書きかたをしたのを見ると、これを學んだのでないかと思ふほどだ。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の他親友の相憐を得るが為めに、少しく文雅に耽ることを得たり。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもなほ文雅に耽つたばかりか、蒹葭堂コレクシヨンさへ残したのはそれ自身豪奢の俗悪なる所以を示してゐるものと言はなければならぬ。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして其等の人々と文雅の交りをしてゐる内に、此まで考へなかつた高い理想が、持ち来されたのであつた。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大司馬車騎將軍王音奇其文雅。",
              "citation": {
                "source": "楊雄と法言",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "やせて背は高く、面長で、容貌の凛々しいことはドイツ人に似、起居振舞はゆっくりではあるが、またきわめて文雅な感じのある年老いた人がそこに彼らを待ち受けていたという。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも享保のむかし服部南郭が一夜｜月明に隅田川を下り「金竜山畔江月浮」の名吟を世に残してより、明治に至るまで凡二百有余年、墨水の風月を愛してここに居を卜した文雅の士は勝げるに堪えない。",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒹葭は秋より冬に至って白葦黄茅の景を作る時殊に文雅の人を喜ばす。",
              "citation": {
                "source": "向嶋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし白髯さまのあたりが寺島村だという話をきくと、われわれはすぐに五代目菊五郎の別荘を思出したものであるが、今日たまたまこの処にこのような庭園が残ったのを目にすると、そぞろに過ぎ去った時代の文雅を思起さずには居られない。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕山｜躬らも後年『安政文雅人名録』の序をつくる時「余年十九、五山詩仏諸老ノ間ニ周旋シ早ク微名ヲ得タリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによってお玉ヶ池の地は久しい間東都文雅の淵叢となっていたが、度々の火災に二家の旧居も蕩然としてその跡なく「都門の文雅も遂に寥落を致す。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十四年刊行の『文雅人名録』にも「服部南梁名元彰芝森元町二丁目三番地」としてある。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池は『安政文雅人名録』に「儒。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし明治十五年出版の『文雅都鄙人名録』を見るに仲御徒町三丁目七十一番地となっている。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "新約聖書の原文が「コイネー」と呼ばれる当時の民衆語で記されて、文雅語でなかった事実から考えても、聖書が本来民衆の書であったことがわかる。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "当主は文雅を好、吟詠にも富り、雅名を正樹といふ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "由良の助に扮しは余が旅中文雅を以識人なり、年若なればかゝる戯をもなすなるべし。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロ／＼と遊ぶんが好きで、見つけられては母におこられた。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
