        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ストライクブレーカーはおあいにくであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやおや女房連中が、ストライキ・ブレーカーになって、おれたちの市長排斥に反対しやがる、妙なことになった」と心配している。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いナイロンのウインド・ブレーカーを、邦子はシャツの上にはおった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このウインド・ブレーカーも、邦子は気にいっていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインド・ブレーカーの落ち着いた黒、ブルージーンズの淡いブルー、そしてテニス・シューズの白と紐の淡いピンクが、ぜんたいとしてよく調和していた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインド・ブレーカーのポケットに両手を入れ、ややうつむきかげんに、邦子は歩いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインド・ブレーカーのポケットから両手を出した邦子は、走りはじめた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインド・ブレーカーのポケットにふたたび両手を入れ、窓枠にもたれて邦子は外に視線をのばした。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の土手の頂上に立ち、ウインド・ブレーカーのポケットに両手を深く入れて、邦子は海岸と海とを見渡した。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインド・ブレーカーのポケットから彼女は両手を出した。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニス・シューズにチノをはいた邦子は、長袖のポロ・シャツの上に黒いナイロンのウインド・ブレーカーを着ていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインド・ブレーカーのポケットには、小さなカメラを入れていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
