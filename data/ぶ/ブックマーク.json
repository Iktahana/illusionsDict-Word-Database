          "literary": [
            {
              "text": "今見ている場所のＵＲＬは、ブックマーク（しおり）という機能で記録できる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがリンクを仕込んだ先のＵＲＬは簡単に書き出せても、かんじんの今見ているページに関しては、ブックマークの形でしか記録できない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと「ブックマークがあるから、そこまでする必要はない」と考えてのことだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デスクトップにピンを並べ、一つの動作で直接目的地に飛んでいく、一皮むけたブックマークとして使っても良い。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
