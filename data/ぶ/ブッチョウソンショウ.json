          "standard": [
            {
              "text": "祖母は仏頂尊勝の陀羅尼を毎日読誦して、家族全員の健康を祈願している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "仏教美術の博物館で、仏頂尊勝が細部まで緻密に描かれた美しい仏画を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "座禅会の後に、仏頂尊勝陀羅尼経が教える功徳について和尚様から講話を聴いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "和田仁十郎以下の門人達は白衣を着て、その旛の下、壇の周囲に坐して「大威怒鳥芻渋※儀軌経」、「仏頂尊勝陀羅尼」、「瑜伽大教王経」、「妙吉祥平等観門大教主経」等の書巻を膝の上にもって、黙読していた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
