    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist family chapel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
