[
  {
    "uuid": "156bf4d6-d853-574e-a443-31828cff4b44",
    "entry": "仏堂",
    "reading": {
      "primary": "ぶつどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "temple building enshrining a statue of Buddha",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "廿二日、丙午、御持仏堂に於て、聖徳太子の御影を供養せらる、真智房法橋隆宣導師たり、此事日来の御願と云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日、丙申、御持仏堂に於て、聖徳太子の聖霊会を行はる、荘厳房以下、請僧七人と云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日、辛未、霽、将軍家の御持仏堂の御本尊、運慶造り奉り、京都より渡し奉らる、開眼供養の事有る可し、信濃守行光奉行として其沙汰有り。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿八日、壬午、晴、姶めて御本尊を御持仏堂に安置す、即ち供養の儀有り。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝になってお岩は持仏堂の前に坐ってお題目を唱えていた。",
              "citation": {
                "source": "四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚六の家では屠蘇を汲み雑煮を祝おうとしたところで、持仏堂の中が怪しい音を立てて鳴りだした。",
              "citation": {
                "source": "一緒に歩く亡霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わるい悪戯をしやあがる」　日がくれてから七兵衛は葺屋町の家を出て、浅草の念仏堂の十夜講に行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにその郷里の人は更らに月夜野村に一仏堂を築いて千日の供養をし、これを千日堂と称えたが、千日はおろか、今日に到るまで一日として供養を怠らなかった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "開基は了誉上人、始祖家康の生母がここに葬られているために、寺領六百石を領して、開山堂、弁財天祠、外久蔵主稲荷、常念仏堂、経堂、無縁塚坊舎が三カ寺、所北寮が百軒、浄土宗関東十八｜檀林中の随一を誇るだけあって、広大壮麗言うばかりない大伽藍です。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが只今、観音堂の背後の念仏堂に確か飾ってあると思います。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "浅草の大火のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずしも仏の前に菊を供へたるにもあらず、必ずしも仏堂の側に菊の咲きたるにもあらず、強ひて場所の関係を言はば菊も古仏も共に奈良にあるまでの事なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "未完成でした仏堂の装飾などについて、いろいろ指図を要することがありまして、昨夜はそれに時を費やし、また今日はそれを備えつけるのに吉日でしたから、急に宇治へ出かけたのでした。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏堂の地と客堂の地とが高く二段になつて居て、一つの井が上の段からも下の段からも汲まれるのは珍しい。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち仏堂を毀ち、学校を興し、瘠土を開拓して膏腴の地となし、暗礁を除いて航路を開き、農兵を置き、薬草を植え、蜜蜂を飼い、蛤蜊を養殖するなど、鋭意新政を行って四民を裨益したことは頗る多かった。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "又村に由緒ある仏堂に練り込んで、「行道」や「新盆の家」などではせなかつた仏事や芸能までもそこで演じた。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は持仏堂に走り込んで、泣くばかり大きな声で、この邪念を払はせたまへと祈つた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくその地にあつた仏堂の本尊の名の、顕れた為にさやう訓んだものだらうとせられてゐる。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくその地にあった仏堂の本尊の名の、顕れた為にさよう訓んだものだろうとせられている。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は内道場の持仏堂の仏前に端座し、もはや仏罰を怖れなかつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛護は、父の再婚の由を聞いて、持仏堂に籠つて、母の霊を慰めてゐる。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かの槍持奴をはじめ仲間ども、そのあとには鈴喜の家の主人雇人までがくっついて、ちょうど三仏堂の前まで来た時、その声を聞いて米友が、屹と後ろを振返りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言わぬばかりに宇治山田の米友は、九尺柄の十文字の槍を地に突き立て、三仏堂の前に蟠りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや」　見ている者が面の色を変えた時に、宇治山田の米友が地団駄を踏んで、「ただはやれねえやい、この槍が欲しけりゃ、代りの品を持って来いやい」　こう言って米友は、三仏堂の縁の前へ飛び上りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見るや米友は横っ飛びに飛んで、三仏堂の縁の上へ飛び上ったかと思うと、扉を押して堂の中へ身を隠し、素早く中から扉を閉して閂を締めました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかの群集は徒らに三仏堂のまわりを取巻いて、わいわい噪いでいるばかりです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎はどうも解せないことだと思いながらも、尋ねて見るのも億劫でその日は帰り、その後また訪ねた時に法然は持仏堂にいて四郎は大床に伺候して云うことに、「どうもやつがれのような無縁の者は都には居られないようですから、相模の国河村という処に知っている侍がありますから、それを頼んで下って見ようと思います。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な無信心者がどういう気で持仏堂など建てたのか。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はまた食うあてがなくなり、以前よりいっそうみじめな境涯に堕落して、安衆房の散所で人にいえぬようななりわいをしてかすかに命をつないでいたが、国吉はその冬、馬宿と喧嘩して殺され、泰博は翌年の春、応天門の外でこれも何者かに斬られて死に、二男と三男は泰文の望みどおりに持仏堂の下の墓へ入った。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
