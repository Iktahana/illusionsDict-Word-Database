    "definitions": [
      {
        "index": 1,
        "gloss": "postcard-sized photographic portrait of a celebrity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
