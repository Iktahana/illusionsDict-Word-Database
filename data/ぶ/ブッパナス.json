    "definitions": [
      {
        "index": 1,
        "gloss": "to fire (a gun)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これらの映画を見ることはすなわち観客みずから踊り歌い、放縦な高速度恋愛をし、やたらにピストルをぶっ放すことなのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで鉄砲を持って来てぶっ放すぞ。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピストルも一発だけ申し訳にぶっ放すが結果は街燈を一つシャボン玉のようにこわすだけである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "みると薄暮の中庭で、女房と店の主人が並んで立って、今しも女房が主人に教えられ、最初の一発を的に向ってぶっ放すところであった。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近よれば、ぶっ放すぞ」　といわんばかりである。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっはっ……だから俺あサヤマをぶっ放すのを延期したよ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり海面と防潜網との隙間を行くものではあるが、こいつを何千何万｜隻とぶっ放すと、彼岸に達するまでに、彼我の水上艦艇に突き当るから、直ちに警報を発せられてしまう。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "サッサと降りて来ないと、ぶっ放すぞ」　本気にぶっ放すかも知れない警官の意気ごみだった。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "命令をきかねば、毒矢をぶっ放すぞ」　もう仕方がなかった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつを藪のそとからぶっ放す……檻のなかの獣を撃つより楽なもんです。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、わしの荘園におった闘牛師の仕出しが喰らい酔いよって、何を思ったか細身をぬいてそこらじゅう刺し廻る、ピストルをぶっ放す、どうも危なくて近寄れません。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "乱視の奈翁　――アルル牛角力の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつと目差した船があると、まずその進路を要扼し、ドンと大砲をぶっ放すのだ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで相手が停まればよし、もしそれでも停まらない時には、今度は実弾をぶっ放すのだ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "拳銃を五、六発ぶっ放す。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切っ先をもって敵を攻めて、出ずれば突くぞ退けば追うぞ、避けたら踏んでぶっ放すぞと、竹刀先をもって挫くのである。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にも黒船が品川の海へ攻め寄せて来て御本丸へ大砲をぶっ放すことの、いや、それより先に江戸に大戦がおっぱじまるのと、寄るとさわると物騒な噂ばかり。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄砲をぶっ放す兵隊を直接｜握っているのは下級将校だからね。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外は騒然と湧き立ち、庭に立っている十数名の監視兵たちは必死の面持ちで銃口を収容所の方へ向けて、身動き一つするものがあったらすぐさまぶっ放すぞという態勢を示しはじめた。",
              "citation": {
                "source": "十三夜",
                "author": "――マニラ籠城日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく平和に戦後の生活を建設しようと努力している世界の人々を、強大な破壊力をもった新兵器をつくり出して、気にいらなければいつでもそれをぶっ放すぞという風におどかしている者があるとすれば、そのような狂気こそ世界の人類の理性の力で、とりしずめなければなりません。",
              "citation": {
                "source": "願いは一つにまとめて",
                "author": "――平和のために、原子兵器の禁止を――",
                "note": "青空文庫"
              }
            },
            {
              "text": "動くとぶっ放すぞ※」　壮太は吃驚して跳びあがった。",
              "citation": {
                "source": "骸骨島の大冒険",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんな四辺に注意しろ、怪しい者が見えたら構わずぶっ放すんだ」　船長は喚きながら死体の側へ跼んだ。",
              "citation": {
                "source": "流血船西へ行く",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれもお前がぶっ放すのは知ってるよ、まるで可愛いい野獣だ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "一発ぶっ放すとレングル警官の右耳たぶに当たり、その場に子牛のようにドタンと倒れた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "容赦なくぶっ放すぞ。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "火縄銃を取っては、あてずっぽうにぶっ放す。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の右手には思わせぶりなピストルが、スワと言えばぶっ放すぞと、威嚇するように光っていた。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふた手になって、「見つけたら、鉄砲をぶっ放すのだ、それを聞いたら、一所へ駈けて来い」　いきまいて追って行った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "是信さんは、正午の梵鐘をつきながら、鐘の音の数だけ、屁をぶっぱなすことができるということである。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "脳が乾き切った海綿のようになにやかやを吸収する時期、広島カープの連敗の合間をぬってやくざがピストルをぶっぱなすだけの文化不毛の地で、オレが触れえたのはメディアを通した演芸のみだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験と称して、大気中で米ソがドンパチぶっぱなす原水爆への不安に真正面から取り組んだ作品で、これが実に重苦しい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
