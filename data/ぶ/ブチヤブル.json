        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが、ぼくたちが海岸に出たとき、ぼくは、せっかくサムにいいきかせた掟を自分でぶち破るようなことになった。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「扉を開けろ、さもないとぶち破るぞ」クリナーンが出てきて言った。",
              "citation": {
                "source": "クリナーンの御殿",
                "author": "THE COURT OF CRINNAWN",
                "note": "青空文庫"
              }
            },
            {
              "text": "高嶺夫人が提琴のような違った楽器で、本当の音を出すことが出来るとは信じられぬので、私は、どんな耳をぶち破るような演奏が始るのかと心ひそかに考えた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから飛び降りて頭をぶち破るか、おとなしく繩を受けるかだ。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、年暮の三十日には、炭倉へ千俵の炭を送り入れますから、その時、馬子や百姓の中に交じって、柵の内へ筑波の兵をお入れになれば、内と外との両攻めに会わせて、難なく、ぶち破ることができましょう」　子春丸は、欲に目がくらんで、羽鳥方に内通し、ついに、こんな計略の手先を働くことになった。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬に鎖かたびらを着せた三千騎の連環馬軍さえぶち破る策を考えれば――」　と、お互い、なぐさめ合ってはいたものの、泊中をつつむ悲愁の気、宛子城の一帯をおおう敗色の深刻さ、それだけは、どうにもならない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "強って組掟を楯にとるならこのほうは領主｜重喜公の御名をもってこの荷つづらの錠をぶち破るがどうじゃ！",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんじょうな戸じゃから、ぶちやぶることもでけん。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
