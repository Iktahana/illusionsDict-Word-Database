    "definitions": [
      {
        "index": 1,
        "gloss": "breath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だいぶ馴染もついたからというので新吉が通って居た建築学校教授ファブレス氏が新らしい生徒だけを自宅の晩餐に招いたのである。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「メイ・ヘッケル・アンド・ジャッケル・ブレス・アス・オール」　祈りを捧げて、ワラがプレイ・ボタンを押した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はただ頭部に軽傷を負っただけで一時は腰を抜かさんばかりに驚いて、ぼんやりしていたが、やがて気を取り直して、警察に急を報ずると、警察からは時を移さず、ブレスナンという探偵が、警察医と二人の部下を従えてやって来た。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、探偵ブレスナンは、問題の箱を検査した。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブレスナン探偵はそれ迄に、エリオット・フィッシャー会社製のタイプライター二百個を調べ上げたが、求むる機械に出逢わなかった。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さく切ったのは、薬品をつめて、田舎へ行って、無煙火薬の実験をするつもりでした」　探偵は一先ず訊問を打ちきって、探偵局に帰ると同時に、区役所に人を走らせて、ヘンリーの事務室のタイプライターを調べさせると、果して、それは、ブレスナン探偵が長い間捜し求めていたものであった。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "全般の形勢は連合側に不利であったが、英国の斡旋で大王は六月十一日墺軍とブレスラウの講和を結び、シュレージエンを獲た。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カールは再戦を辞せぬ決心であったが、ザクセン軍は志気阻喪して十二月二十五日遂にドレスデンの講和成立し、ブレスラウ条約を確認せしめた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしシュレージエン方面の状況が甚だ切迫して来たのでただちにこれに転進、途中ブレスラウの陥落を耳にしつつ前進、十二月五日有名なロイテンの会戦となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王はこの頃激烈なるリウマチスに冒されブレスラウに病臥中、カール十二世伝を書いて彼の軽挙暴進の作戦を戒め、会戦は敵の不意に乗じ得るかまたは決戦に依り、敵に平和を強制し得る時に限らざるべからずと述べている。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、ロイテン会戦ロスバハに仏軍を大いに破ったフリードリヒ大王は戦捷の余威を駆って一挙に墺軍をシュレージエンより撃攘せんとしブレスラウに向い転進した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "石膏模型、骨の見本、マリアは僅かの間にジュリアンのアトリエで一番技術をもったブレスロオという娘を唯一の競争相手とするところまで突進した。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一言、鰯に似た塩づけの魚で、ブレスリンという怪物がある。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は思わず、真心をこめてＡをエムブレスした。",
              "citation": {
                "source": "小さき家の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかえ、カテリーナ、俺が＊ブレストの猶太人からぶんどつて来た蜜酒さへ飲まないんだよ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ブレスト　正しくはブレスト・クヤフスキイと言ひ、波蘭ワルシャフスカヤ県下にある猶太人町。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶丸善へ行つて見たら、イバネス、ブレスト・ガナ、デ・アラルコン、バロハなぞの西班牙小説が沢山並べてあつた為め、こんな事を記して置く気になつた。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その中であのブレスラウ大学の先生が、予審判事にこういう警語を発しているのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの日、マタ・アリは、長距離電話でブレスト町を呼び出していた。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただちにブレストから、オランダのロッテルダムへ電報が飛んだ。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "電文は、ブレストの一カフェが鰯の罐詰を註文している文章だった。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前も、普通のアカハラといふのは止して、英語でレッド・ブレストと愛稱してやつてゐる。",
              "citation": {
                "source": "巣立ち",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "或朝なんぞ、彼女が窓からそのレッド・ブレストの餌をあさつてゐるのを見ると、何か細長いものを嘴に啣へて、それをしきりに一息に嚥み込まうとしてゐた。",
              "citation": {
                "source": "巣立ち",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "メムフィス創始の年代は半ば伝説的で正確なことはわからないけれども、メネスのエジプト統一が（ブレステッドに従って）紀元前三四〇〇年頃だったとすれば、メムフィスは今から五千三百年以前に開けた都だということになる。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブレストの軍港が近いので、その邊には艦隊が集まつてゐたらしい。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男と女が現れ、クロール、ブレスト、バタフライ、水泳をまねた踊りをはじめた。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは中止したけれど、茂太郎のブレスがこの時は、もう歌をうたうようになっていたのですから――そこで直ちに出直して、二人行けど行き過ぎ難き秋山をいかでか君が独り越ゆらん　ゆっくりと、うらさびしく歌い出しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "千八百八十二年（明治十五年）独逸ブレスロオの Gierke 教授｜伯林の Kunstgewerbemuseum（工芸美術館）においてその所蔵せる日本画二百点を陳列しき。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンダアソンに次いで、ブレスロオの教授ジルケは千八百八十二年伯林工芸美術館においてその所蔵品を陳列するに当りこれが目録を編纂しぬ。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
