        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "巴里の中でもブラス・ドゥ・オペラ（オペラの辻）は巴里の十字路といわれている。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから水兵服の船員がブラスのてすりを拭いて来る。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西はシエラネヴァダ山脈から東はネブラスカ、北はイエローストーン川から南はコロラドまでの、荒廃した無音の地だ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてね、それからね、あのセル……セルブラスのお話をしてくれたの。",
              "citation": {
                "source": "青い顔かけの勇士",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「美術部」「ブラスバンドにしない？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "２いい場所を教えてやろうそこへいけば夜中の二時をまわっても音楽が聴けるんだ〈アット・ザ・シーン〉デイヴ・クラーク・ファイヴ　柾生をブラスバンドのメンバーにはできなかったが、すべてが新しく、しかも一年生しかいないのは、ほんとうに素晴らしい、と慶一は思っていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一が所属する、ブラスバンドの打楽器セクションは、階段教室で練習する管楽器セクションとはわかれて、四階の音楽室で練習することが多い。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみは部員ではないと、浅井がいっていたが」「ええ、ブラスバンドに籍がありますから」「ブラスバンドか……。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日の午後もひと泳ぎし、三時からは音楽室でブラスバンドの練習だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高志にさ、きみをＫＷＴＳに入れろって、一所懸命いったんだけど……」　中央階段に近づくと、ブラスバンドの音が大きくなった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫と白のユニフォムをそろへた「Ｗ」、海老茶と黄の「Ｐ」、そして緑と真紅の「Ｈ」大学の選手団は、夫々の出場口から、ブラス・バンドを先頭に、国旗席の前に整列して、大統領の握手を待つた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラス・バンドが先に立って行進した組合もあった。",
              "citation": {
                "source": "正義の花の環",
                "author": "――一九四八年のメーデー――",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜米利加ネブラスカ州から小さな錦を飾っていま故郷の土を踏もうとしている移民の一家族。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽サークルの種類は合唱、ハーモニカ、ギター、ブラスバンドなどが多い。",
              "citation": {
                "source": "ソヴェト同盟の音楽サークルの話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "各労働組合の文化部はブラス・バンドや合唱隊、軽音楽団などを持ちはじめた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユウゴオの「リユイ・ブラス」をムネ・シユリイが演じる相談の時に文豪は自分の前で朗読して見て呉れと云つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムネ・シユリイの朗読を最初の中は全く沈黙して聴いて居たが、三幕目の中程、皇后ドナが「なぜ君は神様の様にそんなに偉大に、そんなに怖ろしく見えるのでせう」と云ふと、リユイ・ブラスが「其れは自分が君を恋慕ふからだ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けると、彼女はショールを頭にかぶりブラスコム医師の許へ馳せつけて、エフィが何だか急に変な容態になったと告げて来診を頼み込んだ、彼女が医師を伴って家へ戻って来ると、近所の人々は早くも集って、最寄りのヘンリイ・ケイシイ巡査を連れて来ていた。",
              "citation": {
                "source": "目撃者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりぁ自然死ではありませんな」　ブラスコム医師は診察を了わると云った。",
              "citation": {
                "source": "目撃者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏原　　こゝがブラス・バンド……こつち向きがいいだらう。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "College とこのブラスに打ってある。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスク※・オーブラスチナヤ・コンフェレンチア〔モスクワ州代表者会議〕。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士はメスを置いて、こんどは高圧ブラストで、甲板の破片を海中へ吹きとばした。",
              "citation": {
                "source": "不沈軍艦の見本",
                "author": "――金博士シリーズ・10――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラスコ・イバネスの『五月の花』の如きをその一例とす。",
              "citation": {
                "source": "小説作法",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のネブラスカの大豊原は、そのころ「大亜米利加沙漠」だった。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関車の食糧節限――一馬力当りの石炭消費率の減少を可能にしたスチーム・ブラストの発明（スティーヴンソン、一八一五年）がはじめてストックトン＝グーリントン鉄道（一八二五年）を旅客用にも貨物用にもひとしく「経済的」に完成させたのである。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸のスチーム・ブラストに対応する海の技術的転回は同じく高圧蒸気と容積縮小を実現した複式エンジンの発明（一八五六年）で、石炭消費量はおよそ半減した。",
              "citation": {
                "source": "黒船前後",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "じめじめした草原で、チゴザサ、アブラススキ、ヤマイ、ミズガヤツリなどが一面に叢生している。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにかまわず自分たちのブラス・バンドを先頭に立てて来る列もある。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
