    "definitions": [
      {
        "index": 1,
        "gloss": "book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが、それから五六日して、上野動物園で貘の夫婦をあらたに購入したという話を新聞で読み、ふとその貘を見たくなって学校の授業がすんでから、動物園に出かけていったのであるが、そのとき、水禽の大鉄傘ちかくのベンチに腰かけてスケッチブックへ何やらかいている佐竹を見てしまったのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのうしろに立ったままで暫くもじもじしていたが、やがて決心をつけてベンチへ腰をおろし、佐竹のスケッチブックをそっと覗いてみた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嘘ですよ」一陣の風がスケッチブックをぱらぱらめくって、裸婦や花のデッサンをちらちら見せた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ルフラン附きの文章か」つまらなそうにそう言って、スケッチブックをぱちんと閉じた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "有田については陶器よりも別な珍奇なものが頭の中のスケッチブックに記録されている。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや新聞に「ブック・レヴュー」とか「ホーム・セクション」とかいう欄が設けられているのは私には全く不可解である。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の書架には学生中のノートブックがあり、ストークスの講義の筆記もその中にあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つ切りくらいのスケッチブックへ鉛筆で簡単なスケッチをしたが、それは普通の意味の似顔としてはあまりよく似てはいなかった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国文学では流行していたアーヴィングの「スケッチ・ブック」やユーゴーの「レ・ミゼラブル」の英語の抄訳本などをおぼつかない語学の力で拾い読みをしていた。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリジナルは児童用の粗末な藁紙ノートブックに当時｜丸善で売っていた舶来の青黒インキで書いたものだそうであるが、それが変色してセピアがかった墨色になっている。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い電気の下で兄は、私にあちこちの引き出しをあけさせ、いろいろの手紙や、ノオトブックを破り棄てさせ、私が、言いつけられたとおり、それをばりばり破りながらめそめそ泣いているのを、兄は不思議そうに眺めているのでした。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、私たちが持っていたものは、一本のエンピツと、ナイフと、一冊のノートブックと、一個のムシメガネと、水を入れた三本のビール瓶と、小さな新約聖書が一冊と……それだけでした。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十五年の夏の末頃｜逗子鎌倉へ遊びに行ったときのスケッチブックが今｜手許に残っている。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーヴィングの「スケッチブック」が英学生の間に流行していたのもそのころであったと思う。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際何十巻ものエンチクロペディーやハンドブックを通読できるわけのものではないのである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだったか、先生がどこかから少しばかりの原稿料をもらった時に、さっそくそれで水彩絵の具一組とスケッチ帳と象牙のブックナイフを買って来たのを見せられてたいそううれしそうに見えた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "象牙のブックナイフはその後先端が少し欠けたのを、自分が小刀で削って形を直してあげたこともあった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　散策子は答えに窮して、実は草の上に位置も構わず投出された、オリイブ色の上表紙に、とき色のリボンで封のある、ノオトブックを、つまさぐっていたのを見たので。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "餅屋が構図を飲込んで、スケッチブックを懐に納めたから、ざっと用済みの処、そちこち日暮だ。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは知らない、と答えると、マダムは、奥へ行って、三冊のノートブックと、三葉の写真を持って来て私に手渡し、「何か、小説の材料になるかも知れませんわ」　と言った。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」麻川氏「ブックの間から偶然出て来たんですよ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言ってノオトブックを僕の鼻先に突きつけた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と僕は、ノオトブックの問題を、ろくに見もせずに言ったら、「だって、あんたは大学へはいったんでしょう？",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クオレ」「少公子」「ジャングル・ブック」「家なき子」「ピイタア・パン」などは、面白いこと無類で、これをよむとよまないで、子供の性格や情操に差違が生じはしないかと思はれるほど、強い感銘を与へるものだと思ふ。",
              "citation": {
                "source": "「小学生全集」について",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は、新子が傍にいることなどは、すっかり忘れたように、スリー・キャッスルの細巻を吸いながら、綺麗なファッション・ブックを漫然とながめているのだった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、今ごろ本屋でスコットの「湖上の美人」やアーヴィングの「スケッチブック」やニーチェの「ツァラツーストラ」でも探すとしたらすぐに手に入るかどうか心もとないような気がする。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、きちんとして、小ぢんまりしているという言葉が自分の頭にある四方太氏の風貌ときわめて自然に結びついて、それが自分の想像のスケッチブックのあるページへ「坂本四方太寓居の図」をまざまざと描き上げさせる原動力になったものらしい。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紙片は、ノートブックから離し取ったもので、鉛筆で次のような象形が画かれてあった。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "トテムとは、一人また一群一族の民と特種の物との間に切っても切れぬ天縁ありとするその物をトテム、その信念をトテミズムと名づくる、その原因については諸大家の学説｜区々で今に落着せぬ（大正二年版『ゼ・ブリタニカ・イヤー・ブック』一六〇頁）。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うにあるのはイスレーゼン、ホットホルム、ケイルドヘルム、スアルヴェン、ブックホルム。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
