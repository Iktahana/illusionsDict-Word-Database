        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぶるぶるふるへてゐるぢやないか。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、よだかでないただのたかならば、こんな生はんかのちいさい鳥は、もう名前を聞いただけでも、ぶるぶるふるえて、顔色を変えて、からだをちぢめて、木の葉のかげにでもかくれたでしょう。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原や林にねむっていたほかのとりは、みんな目をさまして、ぶるぶるふるえながら、いぶかしそうにほしぞらを見あげました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手はぶるぶるふるえた。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし」校長は云ひながらぶるぶるふるえた。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢のそばに寝ていた猫が起きあがって一度垂直に伸び上がってぶるぶると身振いをする。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめには負傷者の床の上で一枚の獣皮を頭から被って俯伏しになっているが、やがてぶるぶると大きくふるえ出す、やがてむっくり起上がって、まるで猛獣の吼えるような声を出したりまた不思議な嘯くような呼気音を立てたりする。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして傍にあった一升徳利を引き寄せると、重さでぶるぶる手を震わせながら茶椀の中へ注ぎ込んだ。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶるぶる身慄いして、馬は、背の馬具を揺すぶった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家が焼ける火を見ると子供達はぶるぶる顫えた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のような岩の大塊のかげに、蒼白にぶるぶる顫えている幽霊のような顔が二ツ三ツちらちらしたばかりだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして背嚢から小さな敷布をとり出してからだにまとい、寒さにぶるぶるしながら階段にこしかげ、手を膝に組み眼をつむりました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」タネリはこわくてもうぶるぶるふるえながらそのまっ暗な孔の中へはい込んで行きましたら、ほんとうに情けないと思いながらはい込んで行きましたら犬神はうしろから砂を吹きつけて追い込むようにしました。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）タネリはぶるぶるしながら入口にとまっていました。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大烏はもう怒ってぶるぶる顫えて今にも飛びかかりそうです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はぶるぶると身を震わせ、鞠のごとくに竦みつつ、「たまりません、もし旦那、どうぞ、後生でございます。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人はあんまり心を痛めたために、顔がまるでくしゃくしゃの紙屑のようになり、お互にその顔を見合せ、ぶるぶるふるえ、声もなく泣きました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室はけむりのように消え、二人は寒さにぶるぶるふるえて、草の中に立っていました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片っ方の翅をひらいたり、片脚でぶるぶる立ったり、枝へ爪を引っかけてくるっと逆さになって小笠原島のかうもりのまねをしたりしてゐました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてやっぱり心配さうにぶるぶるふるへて待ちました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "童子さまの脳はもうすっかり疲れて、白い網のようになって、ぶるぶるゆれ、その中に赤い大きな三日月が浮かんだり、そのへん一杯にぜんまいの芽のようなものが見えたり、また四角な変に柔らかな白いものが、だんだん拡がって恐ろしい大きな箱になったりするのでございました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とかわるがわる叫びながら大よろこびで門をはいって来たのでしたが、ちょっと教室の中を見ますと、二人ともまるでびっくりして棒立ちになり、それから顔を見合わせてぶるぶるふるえましたが、ひとりはとうとう泣き出してしまいました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉助はぶるぶるふるえました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから金だらいを出して顔をぶるぶる洗うと、戸棚から冷たいごはんと味噌をだして、まるで夢中でざくざく食べました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片っ方の翅をひらいたり、片脚でぶるぶる立ったり、枝へ爪を引っかけてくるっと逆さになって小笠原島のこうもりのまねをしたりしていました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
