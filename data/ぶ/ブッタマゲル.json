        "examples": {
          "standard": [
            {
              "text": "宝くじの当選番号を確認したら、一等が当たっていて本当に心臓が止まるかと思うほどぶっ魂消た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "普段はおとなしい彼女が、カラオケでマイクを握った途端にヘビメタを熱唱し始めて、みんなぶっ魂消たよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "突然、押し入れの中から猫が飛び出してきて、あまりの驚きに思わずぶっ魂消て尻餅をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ただねえ、こんな風になったお前を、お豊が生きていて見たら、ぶったまげるだろうと思ってな。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
