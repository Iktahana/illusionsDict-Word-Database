    "definitions": [
      {
        "index": 1,
        "gloss": "first Japanese invasion of Korea (1592-93)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
