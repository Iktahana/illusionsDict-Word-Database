    "definitions": [
      {
        "index": 1,
        "gloss": "Bunroku era (1592.12.8-1596.10.27)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "太政大臣｜公相は外法のために生首を取られたが、この人は天文から文禄へかけての恐ろしい世に何の不幸にも遭わないで、無事に九十歳の長寿を得て、めでたく終ったのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文から文禄の間の世に生きていて、しかも延喜の世に住んでいたところは、実に面白い。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "永禄あるいは文禄年間に琉球から伝わった蛇皮線を日本人の手で作りかえた、それがだんだんポピュラーになったものらしい。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九年の九戸乱にも兵を出し、文禄二年四月上洛して秀吉に謁し、又近衛家に謁え、牡丹花の徽章を用ふるを許さる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の逸話は措いて、氏郷が天正二十年即ち文禄元年朝鮮陣の起った時、会津から京まで上って行った折の紀行をものしたものは今に遺っている。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天正二十年即ち文禄元年、彼の朝鮮陣が起ったので、氏郷は会津に在城していたが上洛の途に上った。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "某は文禄四（三）年景一が二男に生れ、幼名才助と申候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明けて文禄元年正月、太閤秀吉は海陸の諸隊に命じて出発の期日並びに順序を定めた。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "文禄二年（明暦で云えば万暦二十一年）の正月元日、この三脇の大軍は安州城南に布陣した。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮役の前役即ち文禄の役中に於ては、この二つが最も大きい戦争であった。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時政利が用いた刀に羅山銘を作りて南山と名づく、周処が白額虎を除いた故事に拠ると出づ、『菅氏世譜』に政利寛永六年五十九歳で歿したとあるから、文禄中虎を斬った時は三十四、五の時だ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "文禄五年筆『義残後覚』四に、四国遍路の途上船頭が奇事を見せんという故蘆原にある空船に乗り見れば、六、七尺長き大蛇水中にて異様に旋る、半時ほど旋りて胴中｜炮烙の大きさに膨れまた舞う内に後先各二に裂けて四となり、また舞い続けて八となり、すなわち蛸と化りて沖に游ぎ去ったと見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "文禄二年三月、その当時、小早川隆景は朝鮮に出征していて、名島の城には留守をあずかる侍たちが残っていた。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからずっと後の天明年間に書かれた橘｜南渓の「西遊記」にも、九州の深山には山童というものが棲んでいるの、山女というものを射殺したという記事が見えるから、その昔の文禄年代には、ここらにどんな物が棲んでいなかったとも限らない。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「故国」の訳に波羅葦増雲とあるは、文禄慶長年間、葡萄牙語より転じて一時、わが日本語化したる基督教法に所謂天国の意なり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "正信は文禄四年に生れ、寛文十年十二月二日に七十六歳で歿した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方とも、文禄慶長の頃、天草や長崎で出た日本｜耶蘇会出版の諸書の文体に倣つて創作したものである。",
              "citation": {
                "source": "風変りな作品に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この老人の算盤は、文禄、慶長の生残りでな。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が朝鮮の活字が日本の文禄の役に分捕物になつて日本に傳はつて、慶長・元和時代の印刷に利用せられて、我が國の文運に貢獻したことは御承知のことで、事新しく茲に申し述べる必要がありませぬ。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "戰國時代とて、間もなくこの舶來の新武器が日本全國に採用されて、五十年後の文禄征韓の頃には、我が國の尤も有力な武器となつたのであります。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "文禄の役に我が軍が勝利を得た原因は、種々ありますけれど、よく鐵砲を使用したことが、確にその重なる原因の一つと申さなければなりませぬ。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百年前の弘安の時には、我が國は蒙古・高麗の聯合軍の爲に、鐵砲で散々惱されたが、三百年後の文禄の時には、同じく鐵砲で朝鮮・明の聯合軍を打ち惱まして、首尾よくさきの仕返しをいたした譯であります。",
              "citation": {
                "source": "東洋人の發明",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文十二年に新式鐵砲が我が國に傳來してから、五十年經つた文禄元年（西暦一五九二）になると、豐太閤の朝鮮征伐が始まる。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に文禄征韓の頃になつても、舶來の新式鐵砲は、中々支那内地に行渡つて居らぬ。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "文禄征韓の役に我が軍が勝利を得た原因は、種々あるであらうが、この新式鐵砲を利用したことが、確にその主要なる原因の一と認めねばならぬ。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百年前の弘安の役には、日本は蒙古高麗聯合軍の爲に、舊式の鐵砲で散々に苦しめられたが、三百年後の文禄の役には、竹篦返へしに、新式の鐵砲で明と朝鮮の聯合軍を散々に打ち破つた。",
              "citation": {
                "source": "東西交通史上より觀たる日本の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが文禄年間になると、「きかぬものたばこの法度銭法度、玉のみこゑにげんたくの医者」と云ふ落首が出来た程、一般に喫煙が流行するやうになつた。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は最後の試みとして、両肥及び平戸天草の諸島を遍歴して、古文書の蒐集に従事した結果、偶然手に入れた文禄年間の MSS. 中から、ついに「さまよえる猶太人」に関する伝説を発見する事が出来た。",
              "citation": {
                "source": "さまよえる猶太人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、それを調べたが、当家の異国方軍制――武田流の軍法――によると、文禄までは、千人として士分の騎馬五十人、徒歩五十人、弓足軽三十人、槍足軽三百人、鉄砲足軽七十人、残りが小者、輸卒だが、主力は槍であった」　名越は、困った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
