    "definitions": [
      {
        "index": 1,
        "gloss": "gang of rowdies",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
