          "literary": [
            {
              "text": "わたしは岸辺に生えた、普通は実をむすばない、丈の高いブルーベリーの茂みがこういう状態のもとでたくさん実をつけたのを見たことがある。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "またブルーベリーを思わせるベリーを見たが熟してはいなかった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、コーヒーとブルーベリー・タルト。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
