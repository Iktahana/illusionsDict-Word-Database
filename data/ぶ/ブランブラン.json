        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "｜釜右ヱ門は、穴のあいた鍋をぶらんぶらんとふりながら、また村にはいっていきました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、高いところで、ぶらんぶらんしていました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は、この坂道と戦うための用意に自分のとゼーロンのと、一束にした草鞋と一歩一歩踏み昇る場合の足場を掘るためのスコップとを鞍の一端に結びつけて来たのであるが、今、それが私の眼の先で、ゼーロンの跛の脚どりにつれてぶらんぶらんと揺れているのを眺めると胸は鉛のようなもので一杯になってしまった。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ある日の午後、例によって、ベッドから、脚をぶらんぶらんさせ、トランクを台にして日記を書いていると、いま外に出たばかりの松山さんと沢村さんが、カッタアシャツ一枚で、ぬッと入って来ました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の人が町に買物に行って来たように、風呂敷包みを、ぶらんぶらんさせて歩いていた。",
              "citation": {
                "source": "火星の魔術師",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体をぐるぐる巻きにされた一人の人間が、崖から横にでている電柱のような長い棒の先から吊り下げられ、ぶらんぶらんと揺れているのであった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、棒の先に吊り下げられて、ぶらんぶらんしていた人間は、机博士にちがいなかった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "両脚――いや両のズボンに重い靴をくっつけたのが、ぶらんぶらんと振子運動をつづけている。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹をうごかすと、火はぶらんぶらんとゆれるから、鬼火らしくなる。",
              "citation": {
                "source": "骸骨館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして束ねた髪の毛のように、ぶらんぶらんゆれていた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の重みで、傘はぶらんぶらんとゆれています。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先についている錨のおもさで、麻綱はぶらんぶらんとゆれています。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は己の懷中時計をぶらんぶらんと振る。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうとう　おもたいのか　てから　ぶらんぶらん。",
              "citation": {
                "source": "ばにばにきょうだいのはなし",
                "author": "THE TALE OF THE FLOPSY BUNNIES",
                "note": "青空文庫"
              }
            },
            {
              "text": "フックから　つるせば　あなぐまトミーの　頭上で　バケツが　ぶらんぶらん、　まどごしに　ひもで　あやつると　いっちょ　シャワーの　できあがり　というわけです。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤茶けた髪を蓬々とふりみだして、銅色をした太いバナナのやうな乳房をぶらんぶらんさせながら、婆さんは棍棒をはすに構へて、甲高い声で何やらわめいた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "用尿の折はその鍵を外してこれを行うのだが、相当に重いこの鍵はぶらんぶらんしていて、錘に似ていた。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山の果てから本所の果てまで、又ぶらんぶらん歩いて帰った。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "至極のん気に、夜靄のさまよいを愉しみつつ、夜明け近くまでに、ぶらんぶらん菊川町の工場へ帰りついた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "休み時間に、運動場で遊べぬ少年少女たちは廊下を駆けまわったり、或はＹやＮのように、廊下の端に腰をかけて、両足をぶらんぶらんさせながら、灰色の空を物足らなそうに眺めたりしていた。",
              "citation": {
                "source": "記憶ちがい",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "治兵衛の顔にも能の面に似た一種の味わいはあるけれども、立って動いている人形は、長い胴の下に両脚がぶらんぶらんしているのが見馴れない者には親しみにくく、何もしないでうつむいている小春の姿が一番うつくしい。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか舞台一杯に暴れ廻る太兵衛も善六も、見馴れたせいか両脚のぶらんぶらんするのが前の幕ほど眼ざわりでなく、だんだん自然に見えて来るのも不思議であった。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は両足をぶらんぶらんさせながら、片手を私の肩にあてがって、やっと満足したように、息を凝らして絵の方を視つめる。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアズキに混ったコハゼを、アズキと一緒に俺は、血でべとべとする手で握りしめながら、「あ、は、は、は」　穴の底で笑いつづけるその俺の頭上に、首をぶらんぶらんさせた※公の身体が落ちてきた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは、何がなんだかわけがわからず、喜多村も不二夫君も、キョロキョロそのへんを見まわすばかりでしたが、やがて気がつきますと、今のさわぎでめくれたカーテンのはしに、一ちょうのピストルが、ひもでくくって、ぶらんぶらんとゆれながらさがっていました。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二本の足が、まどの上の方に、ぶらんぶらんと、ゆれているのです。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下には馬がなん匹もつながれ、一方のかこいのなかには、大きなゾウが、鼻をぶらんぶらんと、動かしています。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケット小僧は、おもわず逃げごしになりながら、木のあいだをすかして見ますと、五、六メートルむこうの暗い森の中に、なんだか黄色いようなものが、ぶらんぶらんと、ぶらさがっているのが見えました。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
