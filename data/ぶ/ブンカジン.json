        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これから文化人は、いそがしくなると思う。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津輕地方にも、いまはおびただしく所謂「文化人」がゐる。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで救世軍等の宗教が、いかに街頭に太鼓を鳴らし、百度酒の害を説いたところで、文化人であるところの僕等藝術家が、一向にそれを聽かないのは當然である。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化人気分の多い栗栖とは違って、言葉数も少なく、お世辞もなかったが、どこかのんびりした地方の素封の坊っちゃんらしい気分が、気に入っていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の夢の中に理智が現はれ、文化人としての記憶が表象されるのは、おそらく數千萬年の將來に屬するだらう。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが夫は毎朝飲むコーヒーだけは、自分で挽いて自分でいれる器用な手つきだけのところに、文化人らしい趣を遺すだけで、あとは日々ただの村老に燻んで行った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化人とは恐らくこの二壮年などをいふのであらう。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は近代の文化人とはあまりに知性が冴え返るその寂しさと、退屈をいつも事務か娯楽で紛らしてゐなければならないといふことを十分承知して、そして実際それをやつてゐるほどの文化人だつた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり私は、津軽には文化なんてものは無く、したがって、津軽人の私も少しも文化人では無かったという事を発見してせいせいしたのである。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろの所謂「文化人」の叫ぶ何々主義、すべて私には、れいのサロン思想のにおいがしてならない。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化人でいらっしゃる。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあなたを、もっと濶達な文化人だと思っていた。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナブウ神の熱烈な讃仰者で当時第一流の文化人たる大王にしてみれば、これは当然のことである。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ――学園の校長さんは地方の素封家出の文化人で、子供が多いところから一つ自分の手で思うような教育をしてみようと思い立ったのが始まりで、世間の子女たちも預る学校に発展さしたのですが、通って来る講師には著名の芸術家なども多く、男女共学なども行って一風変った学校でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人間は文化人の頂上でもあれば現実には滅ぶる人間だ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学、法律、道徳といったような八釜しい条件に縛られながら生きている事を、文化人の自覚とか何とか錯覚している馬鹿どもの世界には、夢にも帰りたくなくなったのです。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮彼は一箇の文化人である。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのでんで文化が進歩したって、人間が幸福になれると思うのは、大間違いだ」かつての自分の意見を否定し、おまけにその口調がふざけたものになってしまった、「文化人になりたいか？",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "評論をやることで文化人で――、消費組合の土台をヱンヤラヤット打ち込む手伝ひをすることで階級人である新居格は河馬のやうな格好で人生をはにかんでゐる。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "当局も文化と民衆との接触がその作用の大きさに於て、見逃すことの出来ないことを認めてゐる今日、当局が今後文化人に対する奉仕の求め方も強くなつてくるものとみていい。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時は猫も杓子も有頂天になって、場末のカフェでさえが蓄音機のフォックストロットで夏の夕べを踊り抜き、ダンスの心得のないものは文化人らしくなかった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれは、一面、文化人種滅亡の真原因とも見られるのであるから、思い切って書くことにした。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもはただ自然人としての自分のみを見ずして、文化人として、さらに宗教人としての自分、いやほんとうの人間としての自分をかえりみなければなりません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "反ファシズム人民戦線運動がおこったときも、日本の文化人はその重要さを理解しないで、ファシズムと戦争反対との人民的階級の根拠をまっ殺しました。",
              "citation": {
                "source": "心から送る拍手",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ光線をあてると、野蛮人か文化人か分らぬ様々な顔が、どちらを向いているのでもなく、あぐらをかいてえへらえへらと笑っている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は驚くべき文化人である。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "法律によつて著作権を保護し、文化人の生活を擁護することは文化政策の重要なる根幹をなすものであるが、我国の著作権法は極めて不完全なものであり、しかもその不完全なる保証さえ、実際においてはしばしば蹂躙されてきた。",
              "citation": {
                "source": "著作権の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の日本における社会事情の裡で、正当な意味で人間性を護り、知性を擁護し、次第に強調されつつある日本の伝統を発展的に嗣ぎすすめてゆくために、文化人はいかなるモラルを持つべきであるか。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
