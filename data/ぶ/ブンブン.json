        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かぶとむしやびらうどこがねは列になってぶんぶんその下をまはってゐる。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、蛇はひがんで、のたのた這い廻るし、蛙はがあがあ騒ぐのだし、蜂はぶんぶん腹立ちまぎれに螫しに来るし、狼や獅子は、鋭い牙を研ぎ出したのだよ。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、蜂が、ごらん、さっきからぶんぶんふるえているのは、月が出たので蜂が働きだしたのだよ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで軽便鉄道づきの電信柱どもは、やっと安心したように、ぶんぶんとうなり、シグナルの柱はかたんと白い腕木を上げました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが丁度｜幸に花のたねは雨のようにこぼれていましたし蜂もぶんぶん鳴いていましたのであまがえるはみんなしゃがんで一生けん命ひろいました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだそれよりか、毒虫のぶんぶん矢を射るような烈い中に、疲れて、すやすや、……傍に私の居るのを嬉しそうに、快よさそうに眠られる時は、なお堪らなくって泣きました。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶんぶんという鳴弓の声、戞々という羽子の音。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、母親が糸をつむいでいる間じゅう、この子はいつまでもそこにすわって、ぶんぶんいう紡錘と、ぐるぐるまわる車とをながめているのでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのみすぼらしい部屋の中の男の子が紡車をまわしたと同じ数だけ、もっと大きな年の車もぶんぶんとまわったのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブヨはダンスをし、コガネムシはぶんぶん歌をうたいました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三匹の黄色いあしながばちが、ぶんぶん言つて飛んでゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きんのは朝から耳ん中で蠅が一｜匹ぶんぶんいってやがって、いっこう聞こえんだった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "へ、」　とのめずるように頸を窘め、腰を引いて、「何にもいわねえや、蠅ばかり、ぶんぶんいってまわってら。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなぶんぶんを、バットの箱にいれて、その虫のあがく足音、かさかさというのを聞きながら目を細めて、これは私のオルゴオルだ、なんて、ずいぶん悲惨なことである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなぶんぶんが、次から次と部屋へはいって来て、どうも落ちついて書けませぬ。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶんぶん言って疾進してゆく、自動車の奥隅で、あっ、あっと声を放って泣いていた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石の冷たい河原で寝ることは好いとしてちょっと休んでいてさえ、数多の蚊がぶんぶんやって来る程だからとても寝ることはだめです。",
              "citation": {
                "source": "提灯",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のろまのお医者蚊の声ぶんぶん。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖い棗、盗んだ棗、お手々に入れて、袂に入れて、帰つて寝たら、棗がぶんぶん鳴り出した。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "虻がどこからかとんできて、ぶんぶんその周圍をめぐつて騷いでゐました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "石の冷たい河原で寝ることは好いとしてちよつと休んでゐてさへ、沢山の蚊がぶんぶんやつて来る程だからとても寝ることは駄目です。",
              "citation": {
                "source": "提燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに奥さまは目をめらめらさせて通りを下ってきて、猫背の男が街灯のそばに立って、怒り狂うかのように握り拳を宙でぶんぶんしているのが見えました。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちとやそっとの、ぶんぶんなら、夜具の襟を被っても、成るべくは、蛍、萱草、行抜けに見たい了簡。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、すごすごと寝床に引き返しあたまからすつぽりとかひまきを引き被り、冷たく細い膝を抱き蜂のやうに小さくなつてぶんぶんとうたをうたつてゐた。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、調子に乗つて、凧のやうに翼を煽ると、妻君も真似をして、唇にぶんぶんとぷろぺらの唸りを発しながら、小屋の窓から糸をたぐり寄せられてゐる通りに、一直線に騒ぎの方へ吸ひ込まれて行つた。",
              "citation": {
                "source": "心象風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎の前の海棠の花からは、終日長く蜂のぶんぶん唸つてゐるのがきこえて来た。",
              "citation": {
                "source": "不思議な鳥",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊がぶんぶんと攻めかけて来るのも忘れたようだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども蚊がぶんぶん来る。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶんぶんという鳴弓の声、かっかっという羽子の音。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
