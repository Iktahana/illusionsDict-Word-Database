        "examples": {
          "standard": [
            {
              "text": "英語の構文解析プログラムを作るため、文を主語とVPに分割するアルゴリズムを実装している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "言語学の講義で、この複雑な文におけるVPの境界をどこに引くべきかについて議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "生成文法において、VPは通常、動詞とその目的語や補語から構成される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
