    "definitions": [
      {
        "index": 1,
        "gloss": "formal opening of a new theater (theatre)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "旭座の舞台開きも見に行きました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時の俳優組合規約によれば、大歌舞伎の俳優は小芝居へ出勤することを許されないにもかかわらず、彼は神田の三崎座の舞台開きに出勤したので、東京に身を置き兼ねる破目に陥ったのである。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台開きの狂言は「松栄千代田神徳」にて、団十郎、菊五郎、左団次、仲蔵、半四郎ら出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○久松座の舞台開きに、大阪の尾上多見蔵上京して出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台開きの狂言に、団十郎は北条高時の天狗舞を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台開きには左団次、小団次、米蔵、家橘、権十郎、秀調ら出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月一日、日本橋区久松町に新築中の明治座落成して、その舞台開きを行い、左団次、権十郎、小団次、米蔵、福助、団十郎ら出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎のことは前に書いたが、わたしが五代目菊五郎という人を舞台以外で初めて見たのは、明治十八年の一月、久松座が改築して千歳座と改称した舞台開きの時であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村座は舞台開きに、団十郎が「高時」を演じたところで、櫓の由緒も正しい大劇場であったが、近年とかくに客足が付かないで、余りいい顔触れの登場も見なかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎座の舞台開きの当時、私は父と一所に団十郎の部屋へ遊びにゆくと、丁度わたしと同年配ぐらいの美少年が団十郎の傍に控えていて、私たちに茶を出したり、団十郎の手廻りの用などを足していた。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治になつてからは、年の始めと、新築の舞台開きとだけしか演らなくなつたが、江戸時代までは、興行日数のある限り、毎日これを演つたのである。",
              "citation": {
                "source": "能楽に於ける「わき」の意義",
                "author": "「翁の発生」の終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治五年｜新富町の劇場舞台開きをなせし時、新柳二橋の歌妓両花道に並んで褒詞を述べたる盛況は久しく都人の伝称せし所なりけり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋は舞台開きには六代目（尾上菊五郎）がきたといわれる昔の関谷座で、今東宝劇場とかいっています。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍なのは市川鼻升の「勧進帳」、常盤座の舞台開きに堂々と演じたが、幕外の六法は例の緞帳、花道はほんの斜めに六、七尺、よんどころなく後ずさりに舞台上手まで逆戻り、いざ六法で金剛杖を取り直すと、緞帳の綱に引っかかって新規やり直し、馴れぬ舞台の飛六法は弁慶一期の大難儀。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
