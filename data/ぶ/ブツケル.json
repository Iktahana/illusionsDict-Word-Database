      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to hit (e.g. one's head)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　とお房は、おふくろに打付けるやうにいふ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは舟の上に立っていて、御台場に打付ける浪の荒れ狂うような処へ鉤を抛って入れて釣るのです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ今夜は此の弁天堂へ通夜をして、夜が明けたれば出立しようと心得て居ると、どう／＼ッと松ヶ枝に中りまする風音、どぷり／＼という春の海では有りますけれども、岸へ打付ける海音高く、時はまだ若春のことで、人ッ子一人通りません。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてお繼が、繼「おのれ親の敵覚悟をしろ」　と鉄切声を出した時には不意を打たれて驚きましたが、太「これ何を致す、人違いをするな」　と云いながら傍に有りました今戸焼の蚊遣火鉢を取って打付けると、火鉢は山之助とお繼の肩の間をそれて向うの柱に当って砕け、灰は八方に散乱する。",
              "citation": {
                "source": "敵討札所の霊験",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん山間の溪流に沿うて降って行きますと、奔流の岩に激して流るるその飛沫が足もとに打付けるという実に愉快なる光景であります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こわせこわせ」「たたきこわせたたきこわせ」　という声がやがてあちらからもこちらからも起こって、しまいには一人が石をなげますと一人はかわらをぶつける。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん撞木に勢がついて来たところで、最後の一振りを大きく振ると、体もともにぶつけるやうに撞木と一緒に走つて、一つきついた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小取り廻しの利かないわたくしは、何の所作もなく、ただ魂をば、愛をば体当りにぶつけるよりしかたなかった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その動きに続いて、我々全員の体重を扉にぶつける。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型コンピューター用パッケージ・ソフトの販売とサポートで独立系ソフトハウスの最大手の地位を築いてきたアシストが、パーソナルコンピューター用に九千七百円の優しい文房具シリーズをぶつけるに至った経緯にはすでに触れた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてパーソナルコンピューターと真っ向う勝負を挑むこうしたマシンを気合いを込めてぶつけるにあたっては、日本サンは既存のコンピューターの階層構造にうまく折り合いを付けるいい子では、もはやいられなくなるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョンに石ぶつけるなんて！",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルに頭をぶつける、なんてドジを踏まないようにと注意したまでは上出来だったが、ギターを立てかけてあったのを忘れていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "男性への爆弾というとき、我々若きジェネレーションは、女から女独特の爆発力を加えて装填した爆弾を男に只ぶつけるのではなくて、男にそれを確かと受とめさせ、とって直して、男と女との踵に重い今日の社会的｜羈絆から諸共に解放されようとする、その役に立てるものの意味として理解するのである。",
              "citation": {
                "source": "昨今の話題を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の拳固で殴った位では自然が巧妙に大切にこしらえてくれた頭はこわれないからと云って、壁へ向ってその頭をぶつけっこして、よりつよくぶつけるのが偉いように誇る人間もいると云えば、人々はその愚かさを笑うであろう。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから――それからがいけなかつた、徹宵飲みつゞけた、飲みすぎ飲みすぎだ、過ぎたるは及ばざるにしかず、といふ事は酒の場合に於て最も真理だ、もう酒には懲りた、こんな酒を飲んでは樹明さんにすまないばかりでなく世間に対しても申訳ない、無論、私自身に対し、仏陀に対しては頭を石にぶつけるほどの罪業だ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある特定のマシンのベーシックに縛られない、より商品性の高いアプリケーションをより大きな市場にぶつけるために、一部のソフトハウスはＣＰ／Ｍに対応させてプログラムを書きはじめていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神の御名は讃むべきかな……」　さう云ふ語がまだ完らない中に、蛇の頭がぶつけるやうにのびたかと思ふと、この雄辯なる蛙は、見る間にその口に啣へられた。",
              "citation": {
                "source": "蛙",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」自分はぶつけるやうに云つた。",
              "citation": {
                "source": "饒舌",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前で遊んでいると、町の子が石をぶつける。",
              "citation": {
                "source": "遺産",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "只肝癪のあまりに、いつぶつけるともなしに打つけて仕舞つたのだ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ肝癪のあまりに、ついぶつけるともなしに打つけてしまったのだ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく門前で休息して、この敲子の下端をこつこつと戸板へぶつけると、内から開けてくれる。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱暴を奨励するわけではないが、日本にも役者がヘマをやつたら、梅干か蒟蒻ぐらゐぶつける習慣があつたら面白いだらう。",
              "citation": {
                "source": "焼き林檎を投げる",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に述べた「足踏み」はもとより、「口笛」、「声入り欠呻」、「中途退場」その他、「大根引込め」式半畳はまだ生優しい方で、少し前までは、「焼き林檎」をぶつけるといふ念入りの不満表示法が行はれました。",
              "citation": {
                "source": "新劇の観客諸君へ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのソブキノのズブコボイ〔音声〕のように Но　Живёт〔しかし、生きている〕とパッ、パッ、一コマずつぶつける出しかた或は非常によい。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりこの鼻づらへダアンと握りこぶしをぶつける。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻君は太った身体をドシンドシンと扉にぶつける。",
              "citation": {
                "source": "空気男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうをひょろひょろ飛んでいく怪塔ロケットに、この飛行機をぶつけるまでは、おれはどんなことがあってもスピードをゆるめないぞ。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井が低いから、頭をぶっつけないようにしたまえ」「なに、頭をぶつけるなというのか」　帆村と小浜は、ついその言葉に釣られて、はっと上を見た。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
