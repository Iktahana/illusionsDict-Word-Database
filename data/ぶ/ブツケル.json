[
  {
    "uuid": "10e128e7-89c6-5859-99c1-19b50fcee664",
    "entry": "打付ける",
    "reading": {
      "primary": "ぶつける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
