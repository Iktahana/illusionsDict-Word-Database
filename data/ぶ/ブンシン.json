[
  {
    "uuid": "8161c9b0-76ca-5cd9-bc72-731fc0b8ecdc",
    "entry": "分身",
    "reading": {
      "primary": "ぶんしん",
      "alternatives": [
        "ふんじん"
      ],
      "is_heteronym": false
    },
    "grammar": {
