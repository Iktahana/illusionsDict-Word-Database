  {
    "uuid": "dbf3db56-13e9-5ce5-b3b0-8373b97e9dc4",
    "entry": "文臣",
    "reading": {
      "primary": "ぶんしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "civil official (esp. dealing with literary matters)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "されば事に任ずる者、口に藉くことを得て、殿下文臣を誅することを仮りて実は漢の呉王の七国に倡えて晁錯を誅せんとしゝに効わんと欲したもうと申す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "偕に是れ文臣なりと雖も、今武事の日に当り、目前に官軍の大に敗れて、賊威の熾んに張るを見る、感憤何ぞ極まらん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは主人がずいぶんしんぼう強いのでおどろいた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
