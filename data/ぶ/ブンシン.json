      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "other self",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "記憶は雪のふる都會の夜にしづかな建築の家根を這ひまはるさびしい青猫の影の影記憶は分身のやうなものだ。",
              "citation": {
                "source": "記憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七分身、やはり少し。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "西国にて知れる限りの山々を翁はみな自分の分身のように感じられた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それへも骨肉を分けて血の縁を結んだなら自分の性格の複雑さも増す思いで、分身を雲の彼方にも遺す思いで、自分はどのようにかこの世に足り足らいつつ眼が瞑れることだろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして心の中で、わが眷属は、分身は、性格の一面は、と想った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ自分はかれ等を分身と思い做され、総ての上に臨んで自分は山の祖神であったのだが、いまこの山の娘の神に向ってはまるでそういうこともそうすることも覚束なくも思われる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神としては、この分身によって自分にも豊かさという性格を附け加え得られ、眷属の繁栄を眼に見ることである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "布団から半分身を乗り出して、子供を寝かしつけて居た彼は、妻でなければ子供が承知しないのだと云ふことを簡単に告げて、床の中にもぐり込んだ。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は谷川の水を掬って飲ませると、彼は僅に眼を※いたが、警官の姿を視るや俄に恐怖と狼狽の色を現わして、頻に手足を悶いていたが、何分身動きも自由ならぬ重傷である、彼は呻りながら又倒れた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "出産によつて、今や彼等はその分身を、生存競爭の鬪爭場に送り出し、かつて自分等が經驗した、その同じ地獄の試練に耐へさせねばならないのだ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜといって人間が分身術の魔法でも知らない限りは、自分で自分から離れるなどいう奇態な業が、実際にできる筈がないからだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "始終七分身の態度で、款待しつづけ、決してかの女の正面に面と向き合わない夫人の様子に、かの女は不満を覚えて来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにたゞ單に其の法律には盲從せずして、造化の其の法律の精神を體得し、其の法律の如何なるものであるかを知りて之を運用し、被治者の地位たる野猿山羊の羣より超越して仕舞つて、漸やくにして治者、即ち造化の分身たる地位に到達せんと欲して居るのが人類の情状で、古來の賢哲は皆幾分か其の望を達し得て居るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして造化は造化が人類に與へた野猿山羊的の形骸及び機能等、即ち一般動物の有すると同一なる低級約束に對しては、或程度の自由を得て之を辭し之を脱するを得ることを許容して居るし、一方には又野猿山羊等の與かる能はざる高級權利、即ち造化の分身たり得る權利を人類に與へて居るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "衞氣行篇を見れば衞氣の行くことを説き、日の行くこと一舍にして、人の氣の行くこと一周と十分身の八と説いて居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――此列車は、米原で一體分身して、分れて東西へ馳ります。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其枕頭には魔除けの為めに曩日の鍾馗の画像が立てかけられてあり、わたくしは二十幾年ぶりかに、ゆくりなくも此分身に邂逅したことがあつた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "式台で声をかけると、女中も待たず、夕顔のほんのり咲いた、肌をそのままかと思う浴衣が、青白い立姿で、蘆戸の蔭へ透いて映ると、すぐ敷居際に――ここに今見ると同じ、支膝の七分身。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この列車は、米原で一体分身して、分れて東西へ馳ります。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "映り返された二面の鏡その一つ／＼も、また再び意趣返しでもするように、映し返して来た鏡に向っても、また、共に映し返された鏡に向っても傍杖に苦渋な姿を何十何百かの分身の映像まで伴って反撃的に映り返して行く。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡の中の分身また分身、唾棄からは吐息が生れ、嘲笑からは悲憤が生れ、威嚇からは憂愁の限りない嗚咽が生れる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれ等の幾百千の分身は悉く自分の敵ではありながら、また自分自身なのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見詰めるのに堪えないで、自分がわき見をすればそれ等もわき見をして、そこにまた新なる眼の焦点に新なる分身の苦渋な姿が、自分よりも鋭く、自分を見詰めて来る。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花中にいくつかの分身が秘められていて、花体危しと見れば弁尖は花を吹き出し、その花からまた噴水を咲かせます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなたにも、こなたにも分身また分身、消えれば塗り、失えば生ずる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより俺は、娘の友達が言ってるように、自分の娘が月光の中で走るところを見たくなったよ…………俺の分身がね、そんなところで走ってるのをね」「まあ、あんたまで変に好奇心を持ってしまって。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほのかに白い白帝城を、私の小さい分身の子供が、立って停って仰いでいる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは主人がずいぶんしんぼう強いのでおどろいた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
