  {
    "uuid": "40852f0b-d52b-5497-917f-0b2f993973b5",
    "entry": "聞見",
    "reading": {
      "primary": "ぶんけん",
      "alternatives": [
        "もんけん"
      ],
      "is_heteronym": false
    },
    "grammar": {
