        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "information",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「今日の新聞見た――？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やア、今日の新聞見ましたか」「いいえ、見ません！",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝の新聞見ないの？",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっさんら新聞見ても、新聞やのうて珍ぷん漢ぷんやろ？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……あなた今日の××新聞見て？",
              "citation": {
                "source": "嘘をつく日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ただちに自由を主張す、しかして日本人は史蹟において古来専制の政に慣れいまだ自治の事を聞見せしことなく、かつまた事実においてその能力を自信するあらず、彼ただちに平等を主張す、しかして日本人は史蹟において永く貴賤階級の風習に染みかつ事実においても賢不肖の差はなはだしきを知る。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに聞見の寡陋を恥ぢたりと云ふ。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手に欺されて、海に連れて行かれたと書いてあります」「けれども、お亡くなりになったとは書いてございますまい」「……ははは……あなたその新聞見ましたか」「はい……」「けれども貴女は今……クレイ・ジョージが志村のぶ子と一緒に天国へ行くと……」「はい……。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その実は、天道にしたがって徳を脩め、人の人たる知識・聞見を博くし、物に接し人に交わり、我が一身の独立をはかり、我が一家の活計を立ててこそ、はじめて万物の霊というべきなり。",
              "citation": {
                "source": "中津留別の書",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また人の見識、品行はただ聞見の博きのみにて高尚なるべきにあらず。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえにいわく、人の見識、品行は玄理を談じて高尚なるべきにあらず、また聞見を博くするのみにて、高尚なるべきにあらざるなり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "風俗を美にせんとするには、人の智識聞見を博くし、心を脩め身を慎むの義を知らしめざるべからず。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、官の学校にある者は、親しく政府の挙動を聞見して、みだりにその是非を論ずるの弊あり。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その智識聞見は、あるいは西洋流の文明に近き人あるも、徳教の一段に至り特に出色の美なきは、我輩の遺憾に堪えざる所なり。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を拒まざるのみならず、其擧を聞見して心に悦の感を生じ、共に之を助けんとする者こそ多からん。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "不然、徒貪聞見而已、則或恐長傲飾非。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずして、徒に聞見を貪るのみならば、則ち或は傲を長じ非を飾らんことを恐る。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "金峰以西の山に就ては二、三の聞見した所が無いでもないが、それは本文の補正と共に他日実査の上に譲って、茲には案内者のことを一言して筆を擱くことにする。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さん」「いゝよ、いゝよ、ほつといてくれ、もう学校へもどこへも行かれん、いやだい、いやだい、みよ子は今日の新聞見たかい？",
              "citation": {
                "source": "父の帰宅",
                "author": "小寺菊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがあの人は度胸がいいと後で噂に出るだろうが、そんな外聞見栄を望んでいるのは、種と仕掛けがあったなら、びくともせずにいられるのが不思議ではない。",
              "citation": {
                "source": "奇術考案業",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼の友達と云うよりもむしろずっと後輩に当る男の艶聞見たようなものであった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新聞見てでありましょう？",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉吉造氏来る、新聞見ない方がいゝと言った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞見ると、渡辺はま子・小野巡・静ときわ・児玉好雄等がビクター脱退、今日の大会へ出ないと出てた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
