[
  {
    "uuid": "c9dd8bfc-f41b-5106-a927-83e3b70118ea",
    "entry": "ブル",
    "reading": {
      "primary": "ブル",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
