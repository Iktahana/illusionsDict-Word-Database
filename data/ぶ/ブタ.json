[
  {
    "uuid": "f103f507-d1be-5a31-a62f-999db54204a1",
    "entry": "豚",
    "reading": {
      "primary": "ぶた",
      "alternatives": [
        "ブタ"
      ],
      "is_heteronym": false
    },
    "grammar": {
