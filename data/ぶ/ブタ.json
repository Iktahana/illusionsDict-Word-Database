      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pig (Sus scrofa domesticus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さて、俺は何時死ぬるのか、明日か明後日か……――やい、豚、寝ろ！",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "河豚汁の宿赤々と灯しけり　と、冬の街路に炉辺の燈灯を恋うる蕪村は、裏街を流れる下水を見て易水に根深流るる寒さかな　と、沁々として人生のうら寒いノスタルジアを思うのだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンチ絵のクラインバーンにはきっと豚や家鶏が鉄路の上に遊んでいるように描いてある、その通りである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定をすませ丸く肥え太りたる脊低き女に革鞄｜提げさして停車場へ行く様、痩馬と牝豚の道行とも見るべしと可笑し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この豚存外に心利きたる奴にて甲斐々々しく何かと世話しくれたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る小驛で停り合はせた荷物列車の一臺には生きた豚が滿載されて居た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "車内が上下二段に仕切られたその上下に、生きてゐる肥つた白い豚がぎつしり詰まつてゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の豚どもはみんな殺されに行く途中なのであらう。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛や豚の殘骸はあれでも自然の斷片である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚のびっくりするような大きいチョコレート菓子可愛ゆい麦粉菓子のヒヨコ、馬鈴薯が本物かと思ったらやっぱり何かを練ってつくったお菓子なのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は豚の脂を食べやうと思ふ。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窓の外には海豚のかたちももう見えなくなって川は二つにわかれました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向いている豚の尻を鞭でたたけば南へ駆け出し、北向いている野猪をひっぱたけば北へ向いて突進する。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にして多くの文明の利器は時々南向いた豚さえも北へ向かせるように出来ているのが多い。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃彼の父は彼に農業の趣味を養うために郷里で豚を飼わせ、その収入を彼の小使銭に充てた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚とその習性に興味があった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生ぬるい水中へぎゅーんと五体がただ一つの勢力となって突入し、全｜皮膚の全感覚が、重くて自由で、柔軟で、緻密な液体に愛撫され始めると何もかも忘れ去って、小初は「海豚の歓び」を歓び始める。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで海豚は眼を細めている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女達が私に身を委せるとき、彼女達の感受性から海豚の粘々した動物性をうける。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり彼女も海豚なのだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　この夕ぐれを門司の港では木の橋の上で天主教の司祭様が新世界の魚、河豚を釣りあげていられるのであるが、この糸の垂れこめたなかには、鼠取の仕掛けになっていて餌に、触るたびに上から落ちてくる豚に河豚は頭を挟まれてしまうのである。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "スークル・カ・バッチャ、この豚の子奴！",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」仏国ポール商会代理店　太田ミサコ　日比谷街　36と、記された花模様の名刺を太い手首に丸めこむと、かの女は豚のように空中に跳ねた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪胆で殺伐なことが好きで、よく銃剣を振るって、露西亜人を斬りつけ、相手がない時には、野にさまよっている牛や豚を突き殺して、面白がっていた、鼻の下に、ちょんびり髭を置いている屋島という男があった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が二人の間には、膝から下を切断し、おまけに腹膜炎で海豚のように腹がふくれている患者が担架で運んで来られ、看護卒がそれを橇へ移すのに声を喧嘩腰にしていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "養鶏をしている者、養豚をしている者、鰯網をやっている者もある。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "体臭にまで豚小屋と土の匂いがしみこんで居る。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豚群」とか「二銭銅貨」などがその身体つきによく似合って居る。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、森林帯に入るとさすがに涼しい、中でもシャスタ樅と呼ばれる喬木の一種は、この山、特有とまでゆかなくても、この山の産として最も名高いのであるが、富士の落葉松を、富士松と呼ぶたぐいであるかも知れない。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍艦とは浮ぶために造られたのか、沈むために造られたのか！",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
