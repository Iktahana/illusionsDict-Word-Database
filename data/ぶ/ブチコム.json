[
  {
    "uuid": "bb9da1cf-445d-5e83-ac98-b6773e791e2c",
    "entry": "ぶち込む",
    "reading": {
      "primary": "ぶちこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
