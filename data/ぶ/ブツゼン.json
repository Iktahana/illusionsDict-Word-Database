    "definitions": [
      {
        "index": 1,
        "gloss": "(before a) Buddhist altar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
