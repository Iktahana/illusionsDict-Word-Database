        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高志が身につけているのは、ブルージーンズだけだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志がブルージーンズだけ穿いて、慶一のとなりに黙って腰をおろした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリピン系の女性は、膝の上で切った古いブルージーンズに、リーヴァイ・ストラウスの赤いマークをプリントしたＴシャツを着ていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の落ちたスリムなブルージーンズ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いＴシャツの上に長袖のシャツを着て、ブルージーンズをはいた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインド・ブレーカーの落ち着いた黒、ブルージーンズの淡いブルー、そしてテニス・シューズの白と紐の淡いピンクが、ぜんたいとしてよく調和していた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルージーンズをはいたその少年は、四角い凧をひとつ持っていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルージーンズをはき、なんの特徴もないジャンパーを着た少年がひとり、砂丘の頂上に立っていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「撮ってやろうか」　おにぎりをたいらげたぼくは、ブルージーンズの太腿で手をよくこすり、コダックをうけとった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくのブーツにブルージーンズ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、ブルージーンズにダンガリーのカウボーイ・シャツだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときも、ブルージーンズにダンガリーのシャツだった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、あの女は」「友だちだ」「俺とおまえだって、友だちだ」「くらべものにならんなあ」　はき古したブルージーンズに着かえ、ミーヨが降りてきた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "関西に本社のある大きな繊維会社が、ブルージーンズの部門を新設し、さらに、サブ・ディヴィジョンのようなかたちで、ジーンズを主体にした子供服のブランドをつくり、製作と販売に乗り出している。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
