        "examples": {
          "standard": [
            {
              "text": "時代劇のオーディションに向けて、俳優たちは熱心に武者言葉の特訓をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼の書く歴史小説は、登場人物のリアルな武者言葉が読者を物語の世界へ引き込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "『いざ尋常に勝負しろ』など、子供たちがアニメの影響で武者言葉を真似て遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……オオなるほど、世も変ったが、おぬしがかような所におろうとは、さてさて時の流れは、思いがけないことになるのう」二「まず上がれ」と、西仏は遠来の旧友に、昔の武者言葉を出して、「師の上人もご在室、ゆるりと昔語りもしよう」先に立って、いそいそ奥の室へ案内して行く。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
