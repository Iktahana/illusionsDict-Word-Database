        "examples": {
          "standard": [
            {
              "text": "塗料の溶剤として、ブチル系の化合物が使われていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "実験で合成した有機化合物の構造を分析したところ、ブチル基が含まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "工場の廃液から基準値を超えるブチル化合物が検出され、操業停止となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もっとも、ブチル・アルコールの蒸気が、雪の結晶形を支配することはわかっていたが、ついうっかりしていたわけである。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
