    "definitions": [
      {
        "index": 1,
        "gloss": "to dash (water, etc.; on someone or something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「洋服を着て通りゃあがると、あたまから水をぶっ掛けるぞ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洋服を着て通りやあがると、あたまから水をぶっ掛けるぞ。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "馭者はもちろん、かの青年も僕も手伝って、近所の農家の井戸から冷たい水を汲んで来て、馬に飲ませる、馬のからだにぶっかける。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい奴はどこからか水を持って来て、侍の顔へぶっかけるのがある。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりそれは、夢みがちな二十歳前後の若者が芝居の帰り道に、スペインの街や夜や、額に捲毛をたらしてギターをかかえた素晴らしい女の姿などを胸に描きながら歩いている時、いきなり熱湯でもぶっかけるように、浴びせられる言葉なのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨蛙にもお湯をぶっかける。",
              "citation": {
                "source": "チンコッきり",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤番者はよく失策をしたもので、かの蕎麦屋で蒸籠へ汁をぶっかけること等は、少しも珍しい事ではなかった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒をぶっかけるわよ。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人、硫酸をぶっかけるぞと云って脅迫する由。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに昼過ぎのせいなのか、尾根ほど風のあてないためか帽子の縁をつたわって、残念ながらどうも冷汗らしい奴が、頬にじとじと滲むのが、顔の皮に稀硫酸でもぶっかけるようにびりびりする。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒でもぶっかけると元華族になる、子爵のなれの果てというようなひどい意味であったかも知れません。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "七分づきの御飯は食堂からとりよせるのであるが、この上にぶっかける黄色なカレーの汁の中には、いろいろなものがはいる。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "変なまねをしていると、今に頭の上から、毒ガスをぶっかけるぞ」　帆村と一彦の頭の上からふってきたのは、それは破鐘のような大きな声でした。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく呆れた女だよ、お前さんは、鍋がそこにないからって、火の中へ柄杓にいっぱい水をぶっかけるとは、ずいぶん思いきったことをするじゃないか。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後には、書割りの家があって、亭主が酔っぱらって帰ってくるとお神さんが二階から水をぶっかけるという喜劇をやるのだ。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある法医学博士は、青酸を舐めるのは、沸り返って居るボイラーへ水をぶっかけるようなものだ。",
              "citation": {
                "source": "死の予告",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その焼石に、いきなり水をぶっかける。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蒸風呂で、スラヴの汗とあぶらをしぼるのだが、焼石に水をぶっかける時、こつがある。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たいエセックス上りの僧侶から十字架を盗むということと、料理店の壁にスープをぶっかけることと、どういう関係があるのか？",
              "citation": {
                "source": "青玉の十字架",
                "author": "THE BLUE CROSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし港に行ったら、あとをつけて、汚水をぶっかけるから、そう思いな。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに水をぶっかけるように私はわざといってみる。",
              "citation": {
                "source": "一つ身の着物",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　奇声とともにあたかも手につまんだものを私の顔にぶっかけるみたいに、パッと指を開くのだった。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホースで、あいつに水をぶっかけるんだよ。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして槍を出す、岩石を落す、油をぶっかける、材木を転がして来る。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこうごくなッ」　と、大声に、吾を忘れておどり立ちましたから、伊兵衛は元より阿佐ヶ谷｜神楽の連中も、あっと、総立ちに仰天して、たれの気転か、酒やら水やらザッと燃え火へぶっかけるなり、てんやわんやに逃げ散りました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
