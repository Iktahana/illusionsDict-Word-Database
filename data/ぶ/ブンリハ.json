        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それはマリイ夫人の寝床の下から発見された鍵束でヤット開かれたものであったが、超モダンな分離派式タイル張の三坪ばかりの部屋の天井と四壁に、贅沢にも十数個の電球と、合計七個の大小の鏡を取附けた馬鹿馬鹿しいとも形容さるべき構造で、ロスコー夫妻の頽廃的な趣味を露骨に裏書きしたものであった。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父｜様、こんな家よしちまって、郊外に大きい分離派かなんかの文化住宅を、お建てなさいよウ」紅子が、ボッブの頭を振り振り云った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ住吉区の天下茶屋三丁目に、ちかごろ近所の人の眼を奪っている分離派風の明るい洋館があった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "分離派信者が、ユダヤ人と一つ鎖につながっているかと思えば、ポーランド人とタタール人の二人三脚もある。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等ガ牧師ノ一人タルろばとぶらおんノ勧メニ従ヒ、英国教会ヲ離レテソノ同志者トナリケレバ、人呼ンデ、彼等ヲ『分離派』若クハ『ぶらおん派』トナセリ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに、あなたはあの男が分離派教徒なのをご存じですか？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや分離派教徒というでもないが、何か別派の教徒なんですよ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓なら逃げるでしょう、近ごろはやりの分離派教徒なら逃げるでしょう――他人の思想の奴隷なら――なぜってそんな連中は、海軍少尉補のドゥイルカみたいに、ただ指の先をちょっと見せさえすれば、なんでも好きなものを、一生涯信じさせることができるんですからな。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
