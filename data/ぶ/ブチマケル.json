    "definitions": [
      {
        "index": 1,
        "gloss": "to dump (e.g. onto the floor)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "更に明確にぶちまけるならば、この小品の原作者 HERBERT EULENBERG さん御自身こそ、作中の女房コンスタンチェさんの御亭主であったという恐るべき秘密の匂いを嗅ぎ出すことが出来るのであります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」実相をぶちまけるより他は無い。",
              "citation": {
                "source": "市井喧争",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがもしまた見つけたら、そのときはすべてをぶちまけるぞ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "既存のパーソナルコンピューター用ソフトをぶちまけるトッテン社長のアシストは、日本の三千六百万人のデスクワーカー、二千四百万人の学生、児童、四千万人の主婦、つごう一億人を市場としうる商品にアプリケーションを大化けさせることを目指す。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶちまけるような夕立が飛沫を吹いて降り込んで来るので、みんなも手伝って方々の戸を閉めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれが瓶をぶちまけるように降り出して、すぐに、ごろごろぴかりと来るんだからたまりません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼はすべてのことを思うままにぶちまけることのできない自分をその時も歯痒ゆく思った。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩馬は荷が軽るくなると鬱積した怒りを一時にぶちまけるように嘶いた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志の書置きに目を走らせるやいなや、ポップコーンをぶちまけるように、ワラは、ありとあらゆる単語を、ひとまとめにして慶一に投げつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "（長吉はわざとその茶を播磨の前にぶちまける。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の音かはしらぬが、カーンカンと金物を打つ鋭い音が冴々と聞えるかと思うと、またザザザーッと物をぶちまけるような高圧蒸気の音がするのであった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に土工たちは、身軽にトロッコを飛び降りるが早いか、その線路の終点へ車の土をぶちまける。",
              "citation": {
                "source": "トロッコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は羊の肋肉を半分、自分の皿へぶちまけると、それをすっかり食ってしまい、最後の骨の一本までがりがりやって、きれいに平らげてしまった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はいまだに目に見えるように、顔の赤い水屋の爺さんが水桶の水を水甕の中へぶちまける姿を覚えている。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に土工たちは、身軽にトロツコを飛び降りるが早いか、その線路の終点へ車の土をぶちまける。",
              "citation": {
                "source": "トロツコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "田原がむきになつて車輛會社に對する不平不滿をぶちまける事と想像し、如何に慰めなだめようかと考へてゐた三田は、意外に陽氣な座敷の景色に安心して、蟒の差しつけるコツプを受けた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸の思いをぶちまけるためにまッ直ぐに長官邸に乗りこんで行った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も熱情をぶちまけるように昂奮して来た。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこれまで吹きまくった手前、今更がたがたのおんぼろ自動車のことをぶちまけるわけにもいかなかった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなくても、一般からは事件の捜査や裁判が遅すぎると非難ごうごうたるものですからなあ」　大寺警部はいよいよ独特の奇声をふりしぼって不満をぶちまける。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は、肥桶を宴席に担ぎ込んで、畳の上にぶちまけるので、其汚物の中には蛙・蟇などが数多く為込んであつて、其がぴよん／＼跳ね廻つて、婚礼の席をめちや／＼にする。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけ云っても、まだムニャムニャ寝言の続きを云うようだったら、この冷たいビールを襟首へぶちまけるがどうだ！",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那さまぐらい燻製ものに理解がおありになり、そして燻製ものをお好みになる方は世界に只お一人でございますわよ」　と、鉛華も遂に本当のことをぶちまける。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は、燻製料理を持って伺いましたが、実はルーズベルトの特使でございまして……」　と、臆せず底をぶちまけるアメリカ流に、博士は驚くかと思いの外、「分っとるよ。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、君たちの感じ易い心は君たち独特のもので、指導者を信じる信じないに拘らず、少しの自由を与へられさへすれば、それがどういふこととも知らず、従つて、なんの躊躇もなく、単純に、生な感情をぶちまけるやうなことがある。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「釜の湯を地面へぶちまけなされ」　云われるままにぶちまけると、ポーッと立った白い湯気、プーンと芳香が四方に匂う。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえね、あっしもよっぽど黙ってようかと考えたんだが、あんまり姐御がかわいそうだから思いきってぶちまけるだけでね、何も姐御にこんな嘘をついたっておもしろおかしくもなかろうじゃありませんか。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜそういうことに今まで気がつかなかったか」　いつになく殊勝らしいことを言っておいて、「こうなったら正直にぶちまけるが、今のお前さんの話を聴くまでは、鮨売にばかり眼をつけて、ほかのことはかんがえて見るひまがなかった。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "小鰭の鮨",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直にぶちまけると、あたしああんたが好きだ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
