        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "葡萄棚もあり、枝折戸もあり、何よりも値が安く、六圓五十錢なので、それが嬉しかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社前の茶店に葡萄棚がある。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも耳を澄ませば遠きかなたの林をわたる風の音す、はたして風声か」同十四日――「今朝大雪、葡萄棚堕ちぬ。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもだ、縁の先には大きな葡萄棚があって、来年新芽を吹きだしたら、俺は王侯の気持になれそうだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋の廂から葉の厚い葡萄棚を冠った通路を一筋隔てて、自然木に彫刻をした柱などで凝った風に建てられた湯殿は、先代からの遺物として、かなり古めかしいものであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ葡萄棚だけが繁りに繁ツて、小さな薄暗い家を奥深く見せてゐた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄棚は畑の東南の隅にあつて、十坪ぐらゐの大きさにひろがつてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏手は極疎らな垣根で小川に接して居る許りであるが、そこには欅、樫、櫻、無花果などの樹がこんもりと繁つて居り、低い葡萄棚の下が鷄の小屋になつて、始終鷄の聲がしてゐる。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏手には葡萄棚や壞れかけの鷄舍があり、井戸があり、金魚の池があり、白鵞鳥があさり、また山茶花や椿が咲き、小さな畠には柿が落葉し、食用菊が霜に痛んだ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏手には葡萄棚や壊れかけの鶏舎があり、井戸があり、金魚の池があり、白鵞鳥があさり、また山茶花や椿が咲き、小さな畠には柿が落葉し、食用菊が霜に痛んだ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄棚には失敗した。",
              "citation": {
                "source": "中秋の頃",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏は思ふやうに行かずに、一年ほど飼つて、すつかり他所にやつて了つたが、その小舎が葡萄棚の代りになるのは、面白いなどと私は言つてゐた。",
              "citation": {
                "source": "中秋の頃",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はよく葡萄棚の下に緑いろの日の光を浴びながら新らしい紙の匂ひに親しみ、赤い柿の實の反射にぼやけた草艸紙の平假名を拾つては百舌の啼く音をきき耽つた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の葡萄棚、打捨てて手を入れようともせぬ庭の雑草の中に美人草の美しく交って咲いているのも今更に目につく。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い夏を葡萄棚の下に寝て暮らそうという人もある。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の裏には葡萄棚があって、凉しい朝の日影がこぼれ落ちている。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄揺れつづけてゐた葡萄棚の蔓は靜まつて、垂れ下つた葡萄の實の先端からまだ雨の滴りがゆるやかに落ちてゐた。",
              "citation": {
                "source": "妻",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は起きると直ぐ葡萄棚の下へ行つて仰いでみた。",
              "citation": {
                "source": "妻",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた葡萄棚の下へ戻つて來た。",
              "citation": {
                "source": "妻",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、これには理由のある事、清方氏は輝方氏とは同じやうに築地で育つた人で、子供の時分には互に顔は見知らなかつたものの、清方氏の家には葡萄棚があつて、夏になると美しい房が鈴生に生るので、腕白者の輝方氏は近所の鼻つ垂しと一緒に、いつも盗みに出掛けたものだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯場は新開の畠に続いて、硝子窓の外に葡萄棚の釣ったのが見えた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏、田舎に行き、青々と葉を重ねた葡萄棚の下に、真黄なカナリアの籠の吊してあるのを見た。",
              "citation": {
                "source": "小鳥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄棚の下に拵えた私共の涼台に、すぐ薄縁の敷るほどの雨量しかなかった。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口の庭には葡萄棚があり裏には野菜｜畠のあるような田舎風の家で、岸本は巴里の方から来た主婦や主婦の姪と一緒に成った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の子供の煩さかったことは、葡萄棚に近く窓のある食堂で岸本等が楽しい夕飯に有付いた時にも石垣の外から覗きに来るものがあるくらいであった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔓の延びて来ている葡萄棚を越して窓の外にはバビロン新道が見えた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「復た好い画が一枚出来ましたよ」　エドワアルはそれを岸本に言って見せ、入口の庭にある葡萄棚の下あたりを歩いている主婦にも言って見せた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分等葡萄棚の涼台で、その号外を見、話をきき、三越、丸の内の諸ビルディング　大学　宮城がみなやけた戒厳令をしいたときく。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉よ、あなたはいる、葡萄棚の下のしたたる朝露のもとに。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのへんから裏山へかけては、なだらかな傾斜になっていましたから、わたしも細い道を楽しみにして、枝のたれさがった夏なしのかげ、ぶどうだなのもと、またゆり畑の間などを歩き回り、年とった百姓を相手に木曾福島の風俗、祭の夜のにぎやかさ、耕作の上のことなどを語りながらいなかのふぜいを味わいました。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
