[
  {
    "uuid": "fb9025b8-6470-5c96-99a3-ff40b3701138",
    "entry": "武将",
    "reading": {
      "primary": "ぶしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
