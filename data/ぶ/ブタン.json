          "standard": [
            {
              "text": "カセットコンロのガスボンベには、液化されたブタンガスが充填されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "冬場の寒い屋外では、ブタンは気化しにくくコンロの火力が落ちてしまうことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "100円ライターの透明なプラスチック越しに、液体のブタンがチャプチャプと揺れているのが見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ふたつのストーブに、炭や予備のブタン・ガスのカートリッジや食器、調味料、そして米やソーセージなどを、ぼくと小川が用意した。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
