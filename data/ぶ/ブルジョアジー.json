    "definitions": [
      {
        "index": 1,
        "gloss": "bourgeoisie",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
