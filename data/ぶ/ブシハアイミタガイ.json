        "examples": {
          "standard": [
            {
              "text": "困った時はお互い様だ、武士は相身互いだから遠慮せずに頼ってくれ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "同じプロジェクトで苦労している仲じゃないか。武士は相身互いで助け合おう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "資金繰りが苦しいと聞いて支援を申し出た。武士は相身互い、恩に着ることはないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "万一かたきが勝った場合には、その藩中で腕におぼえのある者が武士は相身互い、義によって助力するとかいって斬って来る。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナーニ武士は相身互いでさあね」才蔵はすっかりいい気持ちだ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
