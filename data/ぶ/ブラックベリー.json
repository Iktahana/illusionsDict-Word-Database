[
  {
    "uuid": "96cb99f0-94f9-5f1d-a587-5f0f23d1bdc4",
    "entry": "ブラックベリー",
    "reading": {
      "primary": "ブラックベリー",
      "alternatives": [
        "ブラックベリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "blackberry (esp. the common blackberry, Rubus fruticosus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例えばクロウメモドキ・シロップはクロウメモドキ（rhamnus catharticus）の実のジュースから調製するのではなく、ブラックベリーをつけるアルダー（ハンノキの類）やノイバラの実のジュースから作る。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "クロウメモドキの実、ブラックベリーをつけるアルダーやノイバラの実、は医療ハーブの商人たちによって公然と売られている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "形は我国のものの二倍位でブラックベリーのように艶があり、種子は非常に小さく、香はラズベリーで味は野生的な森林を思わせるもの。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
