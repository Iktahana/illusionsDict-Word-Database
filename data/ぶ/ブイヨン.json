        "examples": {
          "standard": [
            {
              "text": "スープのベースとして、丁寧に取ったブイヨンを使うと風味が格段に良くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このコンソメスープは、上質なチキンブイヨンで作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "風邪をひいた時は、温かいブイヨンを飲むと体が楽になる気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "フランスの家庭では、胃腸を悪くするとよくブイヨン・ド・ポアロー（ねぎの煮出し）をのませる。",
              "citation": {
                "source": "ブイヨン・ドンゾール",
                "author": "――十一時の肉の煮出し――",
                "note": "青空文庫"
              }
            },
            {
              "text": "北極廻りで雲の上ばかり飛び、あっという間に羽田から十八時間でパリの近郊のオルリーにつく戦後の日本人は、ほとんど知るまいが、横浜マルセイユ間一カ月の海路では、日本、フランス、イギリス等どの国の客船でも、「ブイヨン・ドンゾール」（十一時の牛肉の煮出し）をのませた。",
              "citation": {
                "source": "ブイヨン・ドンゾール",
                "author": "――十一時の肉の煮出し――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあブイヨンの時刻ですね」と顔を見合せて、微笑する面白味はフランス船でないとわからない。",
              "citation": {
                "source": "ブイヨン・ドンゾール",
                "author": "――十一時の肉の煮出し――",
                "note": "青空文庫"
              }
            }
          ]
        }
