[
  {
    "uuid": "c2387396-8db7-5e62-9538-25e17f051dac",
    "entry": "武家時代",
    "reading": {
      "primary": "ぶけじだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
