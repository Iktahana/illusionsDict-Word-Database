        "examples": {
          "standard": [
            {
              "text": "海外の医療機関で不審な症状を訴えたところ、VDの疑いがあるとして血液検査を受けるよう指示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "保健所では、匿名かつ無料でVDの検査と相談を受け付けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "専門のクリニックで処方された抗生物質を服用し、VDの治療に専念している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
