        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "徳望｜素より隆んにして、一時の倚重するところとなり、政治より学問に及ぶまで、帝の咨詢を承くること殆ど間無く、翌二年文学博士となる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が、将来文学博士にでもなるやうな事を、親類のものまでが信じてゐた。",
              "citation": {
                "source": "世に出る前後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、かねて或る文学博士のすすめで私達の郷国の風土誌の編纂にたづさはつてゐたのである。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二面には富口という文学博士が「最近日本におけるいわゆる婦人の覚醒」という続き物の論文を載せていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坪内君が世間から尊敬せらるゝのは早稲田大学の元老、文学博士であるからで、舞踊劇の作者たり文芸協会の会長たるは何等の重きをなしていないからである。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の文学士は今の文学博士よりは十層倍の権威があったものだ。",
              "citation": {
                "source": "明治の文学の開拓者",
                "author": "――坪内逍遥――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、わが大槻文学博士が著書「言海」に述べてゐるところを開いて、面白さうに読んだりしたのである。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "星野｜恒博士９・12（夕）　昨日亡くなつた文学博士星野恒氏は、国史の事にかけたら活字引と言はれる程、物覚えの良いので聞えた人であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板博士と新聞紙10・28（夕）　文学博士黒板勝美氏は、職業柄よく奈良へ出掛けて来る。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "内田博士の時計４・17（夕）　今度欧米漫遊をする事に定つた京都大学の諸教授のなかに、文学博士内田銀蔵氏がゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜田博士の笑顔５・26（夕）　文学博士喜田｜貞吉氏は国史の専攻学者である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠と罰金９・26（夕）　文学博士芳賀矢一氏は、酔つ払つてよくいろんな失敗をする。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "狩野博士の門違ひ１・15（夕）　文学博士狩野｜直喜氏は洛東田中｜町に住んでゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "内田博士の敏感７・22（夕）　茶話子の敬愛する文学博士内田銀蔵氏が胃潰瘍で危篤を伝へられるのは、学界のために痛惜に堪へない次第である。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "取繕はないといふのは、何も虫の食つた古本や、蝙蝠傘をいふのではない、文学博士｜喜田貞吉氏がそこに相住居をしてゐるのを言ふのである。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は座敷に案内せられると、京都には久しい以前早稲田で自分達を教へてくれた文学博士Ｆ氏がゐる事を思ひ出した。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月三日の夜、ＮＨＫの報道放送で文学博士和辻哲郎は、天皇制護持の哲学上の基礎づけを行った。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波書店出版の雑誌『世界』三・四月号に文学博士津田左右吉の天皇制護持の立場からする皇室論があらわれた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、四十行の短文にして末に、明治三十四年四月文学博士｜重野安繹撰、と書けり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "関係者が現存する為に彼の功績はいつこう世の中に発表されないけれども、それでも牛込の老婆殺しの事件、清川侯爵邸の怪事件、富豪安田家の宝物紛失事件、蓑川文学博士邸の殺人事件などは、人々のよく知る所となつていると思われる。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体誰がこんな事を書いてゐるのかと巻首を見たら、文学博士久保天随訳解としてあつた。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果「親は面白半分に吾々を作りし者也」と解決を付けた奴は取敢えずアメリカあたりの文学博士になる奴で、「故に吾々は親に対して責任無し」と結論する奴はソビエット直輸入の赤い法学博士の卵だろう。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑛子は、どうして女に医学博士はあるのに文学博士は出ないだろう。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるにしても、このほど帰国の船中｜蘭貢において、テレーズが再帰熱にて死去したるは哀れとも云うべく、また、皮肉家大鳥文学博士がこの館を指し、中世堡楼の屋根までも剥いで黒死病死者を詰め込みしと伝えらるる、プロヴィンシア繞壁模倣を種に、黒死館と嘲りしこそ可笑しと云うべし――。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この尼僧寺は、婦人の身で文学博士の肩書を持ち、自ら盤得沙婆と号する工藤みな子の建設に係わるものであって、あまねく高識な尼僧のみを集め、瑜伽大日経秘密一乗の法廓として、ひろく他宗に教論談義を挑みかけていた。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二二　法服の制定　法官および弁護士が着用する法服は、故文学博士黒川真頼君の考案になったものである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜を出帆する際、親類を見送りに来られた文学博士遠藤隆吉君に甲板上で遇うたら、同君が『社会及国体研究録』の第一号を手渡しつつ「デモクラシーは国体と相反するような考を抱く人があるので誠に嘆かわしいから、今度このような研究録を出して大に世の惑を釈こう」といわれた。",
              "citation": {
                "source": "平民道",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが世間に向ってはただ医学博士、文学博士、法学博士として通っているからあたかも総ての知識をもっているかのように解釈される。",
              "citation": {
                "source": "道楽と職業",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
