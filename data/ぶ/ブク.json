    "definitions": [
      {
        "index": 1,
        "gloss": "mourning clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私の正面の壁に子供の小学校の霜降の服と、糊でビリビリの日覆をかけた小学帽とが掛かつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しもし此の新体詩様式の困難が、次第に征服されてゆけば、其処に始めて詩歌は「生活の傍ら的なもの」から、「その中で生活の出来る詩歌」に迄到達することだと思ふ。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "前二者が注射や服薬ならば、之は神経衰弱や軽微な肋膜の療養に似て、呑気にブラブラすることを要請してゐるのである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでＢはＡに不服を唱へ出す。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても我が国婦人の服装たるやなんと脆い感じのするものだらう。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に神経を使はなくては、何時も綺麗でキチンとしてゐるとはいくまい婦人の和服といふものは、段々改良されてはゆくのであらうか、なぞとそのうち僕は考へ始めたものである。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れ易く、破れ易く、着くづれし易く、こんな服装を讃へなければならない我々日本男児は、なんとなく不幸であるやうに思へる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は服を着、怯々しながら隣の部屋にゐる友人の弟に金を借り、――でも、この月曜からは勉強しよう、浪費しまいと、そのやうなことを偶々思つた翌々日であつてみれば、私は読みかけのシュニッツラー選集を一冊持つて出掛けるのであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホオ……と僕はお道化てゐるんだがまだ見ぬ先生に意地の悪い気持を抱いてゐるんだが、煙草をまづく感じ出すと、飛行機のみならず、洋服掛にまで、異常な好奇心を覚ゆるのであつた――とにかく御幸福なお方であらせられるよ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が枡に足を蹈み込んだばかりに、肥つた四十年配の女が二人、飛び込んで来て、「ああよかつた、端ッこでもあつてこそよございました、もう五分早ければよございました、惜しいことをしました、私は今朝から一服もしません、ええでも一幕見てから一服することにいたしませう」なぞと、イキセキ切つて云ふのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生の詩に就いて、特に私の敬服に耐えないものは、その独創あるすばらしい表現である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも和服――特に浴衣を好んだ――を着、畳の上に正坐し、日本の煙管で刻煙草を詰めて吸ってた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから座敷へ上ると、妻が洋服をぬがせて和服に着かえさせてくれる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの趣味はすべてにおいて庶民的で、儀式ばったことが嫌いなので、フロックコートなどの礼服を非常に嫌い、常に野蛮人の服と称し『なんぼ野蛮の物』と言っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで学校に式のある時など、他の教師は皆礼服で列席するのに、ヘルンは一張羅の背広で押し通していた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上に参るの時、あなた、シルクハット、フロックコートですよ』などと、子供をだますようにして説き伏せられ、やっと礼服を新調したけれども、やはり少しも着ようとしない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう語つたあとで、顏も洗はず衣服も換へず、朝寢姿で訪ねたことの非禮を謝罪した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の詩について――新しい詩壇の詩について――芥川君が聰明な理解と見解をもてることは、前述べた如く自分の常に敬服する所である。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその「批判」に敬服してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも自ら毒を服して、嚴然と持し、精神のストイックな安靜を失はないで。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、その事に就いても感服している。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん痩せ細っているようであったけれども身丈は尋常であったし、着ている背広服も黒サアジのふつうのものであったが、そのうえに羽織っている外套がだいいち怪しかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は実にしばしば服装をかえて、私のまえに現われる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまの背広服のほかに、学生服を着たり、菜葉服を着たり、あるときには角帯に白足袋という恰好で私を狼狽させ赤面させた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは学生服をきちんと着て、そのうえに、ぶくぶくした黄色いレンコオトを羽織っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生殺しにして、なぶつて、なぶつて、さうして最後は泥舟でぶくぶくである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "散々あぶく銭を男たちから絞って、好き放題なことをした商売女が、年老いて良心への償いのため、誰でもこんなことはしたいのだろう。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはそのときばけものの胃ぶくろのなかでこの網をだしてね、すっかりかぶっちまうんだ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや下ぶくれで唇が小さく咲いて出たような天女型の美貌だが、額にかざした腕の陰影が顔の上半をかげらせ大きな尻下りの眼が少し野獣じみて光った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
