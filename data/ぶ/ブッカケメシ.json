        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "深夜の夜食に、残り物の味噌汁をご飯にかけたぶっかけ飯を食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "疲れている時は、簡単なぶっかけ飯で済ませるのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "漁師町で食べた、新鮮な魚介が乗ったぶっかけ飯の味が忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "貝を肴に酒を飲ませるのと、盛りのいいぶっかけ飯が自慢で、かなり遠い町内にも名が知られていた。",
              "citation": {
                "source": "夜の蝶",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄二はそれを疑いもしなかったが、さぶは金杉のほうの屋台店で、安いぶっかけめしを喰べ、おすえは残っためしを雑炊や粥にのばし、おかずも生味噌か塩を舐めて済ましていた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
