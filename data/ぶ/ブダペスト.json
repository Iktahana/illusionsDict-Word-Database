        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昨年の晩秋、ヨオゼフ・シゲティというブダペスト生れのヴァイオリンの名手が日本へやって来て、日比谷の公会堂で三度ほど演奏会をひらいたが、三度が三度ともたいへんな不人気であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の晩秋、ヨオゼフ・シゲテイといふブダペスト生れのヴアイオリンの名手が日本へやつて來て、日比谷の公會堂で三度ほど演奏會をひらいたが、三度が三度ともたいへんな不人氣であつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズー・イン・ブダペストって、活動見に行かない？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勝館で、美和子は「ズー・イン・ブダペスト」はお終いまで、神妙に見たが「ジェニイの一生」になると、中途まで見て、「ねえ、出ましょうよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルザスからドイツのミュンヘンへ入り、チロルからウイン、ブダペストと延びて、ダニューブ河の河岸のホテルへ著いたときには、ハンガリアの曠野は、真紅の葵の花盛りだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパの中で、一番に美しい都会は、パリーとブダペストといわれている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリアの都、ブダペストは、街も自然も人も美しい。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月廿二日　ブダペストへ出発。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後六時ブダペスト着。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ヨーロッパへ来てどこが一番面白かったかという話が出る度に、異口同音にブダペストと誰も云う。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパスでヨーロッパに円を描くと、中心がブダペストの上に刺さる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブダペストには、一町四方もあろうかと思われる大カフェーの名前にジャパンというのがある。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブダペストの郊外の地中から、二千年前の遺跡が近年発見された。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　最近｜匈牙利のブダペストで珍しい事件があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の十二月、ブダペストで開かれた世界民主婦人連盟の第二回大会では、日本のわたしたちが心をうたれるいくつかのスナップ写真がとられている。",
              "citation": {
                "source": "人間イヴの誕生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本からの代表の影はブダペストのこの大会に見えなかった。",
              "citation": {
                "source": "人間イヴの誕生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くもたれようとしているアジアの国際婦人民主連盟の大会でわたしたち日本の女性は、自分たちと世界の災厄をふせぐために、ベトナムの若い代表婦人が、ブダペストから世界の良心にアッピールしたように、アッピールする機会をもたなければならないと思う。",
              "citation": {
                "source": "人間イヴの誕生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海がかつて国際犯罪都市であったように、ブダペストが国際スパイ都市であるように。",
              "citation": {
                "source": "指紋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブダペストから来た埃及人の医学生。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり繊細に、そして音律的に足が動くので、そのうちに私は、じつは彼女が、咽喉の奥で唄う高速度曲に合わせてブダペスト風の踊りを真似してるのであることを知った。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "匈牙利の首都ブダペストから四哩程離れた田舎に、ツインコタという風光明媚な避暑地がある。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "このツインコタ町へ、今いった見慣れぬ男が、若い綺麗な細君を伴れて首府のブダペストから移り住んで来ている。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人のベラ・キスは、一週に一、二回ブダペスト市へ出て行く。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人のベラ・キスがひとりでブダペストへ出る時も、その自動車を自分で運転して行った。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブダペストの画家で Paul Bihari という情夫があった。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "キスが留守になると、このパウル・ビハリが、ブダペストからやって来て、附近にはアカシアの森が多い、そのアカシアの森を二人で恋人気取りで散歩したりする。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビハリは眼鼻立ちのくっきりした美青年で、ブダペストでは先ず知れている画家である。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "七個月程経った或日の夕方、キスがブダペストから帰って来ると、家に錠が下りていて這入れない。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その頃、ツインコタからブダペストへ行くアカシアの森で、偶然若い女の屍体が発見された。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度ブダペストから維因納の友達へ手紙が来たきりで、毛皮商のほうでも実家でも内々捜しているところだった。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
