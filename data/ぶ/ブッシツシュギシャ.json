        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "妾は徹底した物質主義者です。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの物質主義者の医学士は？",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "或物質主義者の信条「わたしは神を信じていない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は勿論物質主義者ですから、真面目に宗教を考へたことは一度もなかつたのに違ひありません。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もチヤツクは物質主義者ですから、死後の生命などを信じてゐません。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はもちろん物質主義者ですから、真面目に宗教を考えたことは一度もなかったのに違いありません。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともチャックは物質主義者ですから、死後の生命などを信じていません。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教上の無神論者、哲学上の物質主義者……」　夜更けの往来は靄と云うよりも瘴気に近いものにこもっていた。",
              "citation": {
                "source": "彼　第二",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は元来物質主義者だ。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は医師の話を聴く一ぽう、いつもの癖で自分のおきまりの尺度を彼に当てて見た――物質主義者、理想主義者、金、群棲本能、等々。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に、厳格な宗教家と物質主義者とは明らかに世界が異なる。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "したが、たまには、野獣のような、物質主義者に出合うことがあります。",
              "citation": {
                "source": "共産主義者の犯罪",
                "author": "THE CRIME OF THE COMMUNIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心理学はコチコチの物質主義者のそれで――どちらかというとお笑い種だ。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
