    "definitions": [
      {
        "index": 1,
        "gloss": "Bunna era (of the Northern Court; 1352.9.27-1356.3.28)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北朝の文和、北朝の年號に文和と云ふのがあります、十四世紀の頃、彼の文和の頃に權少僧都成俊が萬葉集の奧書をしました。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯員の一人は、片手で髭を引っぱりながら熱心に露文和訳をしていた。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一月六十円の月俸を貰ひ、昼は英文和訳を教へ、夜はせつせと仕事をした。",
              "citation": {
                "source": "身のまはり",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月四日（火曜）　入学試験 Conversation と英文和訳と Dictation があった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "英文和譯等に於いて少しも原文の意味、脈絡に留意することなく、唯所謂逐語譯を施して能事終れりとする傾向が多く見受けられる。",
              "citation": {
                "source": "ベーシック英語",
                "author": "高田力",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スパイとおっしゃると、つまり、間者ですな」　などと、てれかくしに古風な言葉に英文和訳したが、このへんが渉外部長のあさましいところ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし怨みをふくんでランランたるツル子の瞳を見ると、ノンキに英文和訳などしている時ではないことが分った。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十年三月七日關口存男識獨文和譯和譯P.51　６. zwischen den Zeilen lesen（眼光紙背に徹す） hineinlesen（勝手な意味を捏造して讀むこと）46P.52　【１】ａ．仕事は一週間後に始めて仕上がる。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十二国人物図絵、虞書暦象俗解、天文議論、日本水土考、天文和歌注、町人｜嚢、長崎｜夜話草、水土解弁、ええとそれからまだあったな。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田先生から教へられたのは英文法と英文和譯、譯の教科書はアチック・フィロソファーとイナックアーデンとであつた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも文和の昔、後芬陀利花院さま（一条｜経通）御在世の砌、折からの西風に煽られてお屋敷の寝殿二棟が炎上の折にも、幸いこの御秘蔵の文庫のみは恙なく残りました。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも文和の昔、後芬陀利花院さま（一条｜経通）御在世の砌、折からの西風に煽られてお屋敷の寝殿二棟が炎上の折にも、幸ひこの御秘蔵の文庫のみは恙なく残りました。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいはひ英文和譯には解らない單語はなかつた。",
              "citation": {
                "source": "受驗生の手記",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにその内容はなんといっても、例のメモが骨子になっているだけに、いかにも英文和訳の臭味から脱し切れない。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて例をあげれば文化文政年間の名人本因坊文和があるけれど、秀哉名人が明治から大正、昭和にかけて戦つたたくさんの争い碁を調べてみても、その特色ははつきりしている。",
              "citation": {
                "source": "本因坊秀哉",
                "author": "野上彰",
                "note": "青空文庫"
              }
            },
            {
              "text": "連歌に関する家集・撰集・作法心得、古文和歌の註釈は頗る多いが、歌の方では『万葉集宗祇抄』『古今集両度聞書』『百人一首抄』『種玉庵宗祇歌集』などがある。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者諸君は近頃「英文和訳の秘伝」だの「和文英訳の秘伝」だのという小冊子が続出するのに気がついているだろう。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆を取っては「英文和訳の秘伝」や「和文英訳の秘伝」の外に能がない。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目下又々「新英文和訳」というのを編纂中、集めて置いた材料の中から次の一節が現れたのである。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "失敗が後進の参考になるなら、私には英文和訳よりももっと材料がある。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠し婆は古くは子取尼などともいって、実際京都の町にもあったことが、『園太暦』の文和二年三月二十六日の条に出ている。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしおいぼれがいやだなんて云ったらぶんなぐっても連れていくよ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶんな対照だとその時にちょっとおかしかった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国、仏蘭西、独逸とずいぶんながいごったごたした旅行を続けておしまいにウィーンへやって来る。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また鏡で反射させた風景へ望遠鏡を持って行って、望遠鏡の効果があるものかどうかということを、吉田はだいぶんながい間寝床のなかで考えたりした。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家に同年輩の娘子供はずいぶんないでもなかったのにこれらとはとにかく遊ばなかった。",
              "citation": {
                "source": "雪ちゃん",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくぶんなげやりであつて、これぞといふ目的をも持たぬ犧牲の魂。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清作はもうとびだしてみんなかたっぱしからぶんなぐってやりたくてむずむずしましたが、画かきがちゃんと前へ立ちふさがっていますので、どうしても出られませんでした。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私を見てずいぶんな高声で言ったのです。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このぶんなら東京の町中でもどうやら写生ができそうな気もした。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
