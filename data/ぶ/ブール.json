[
  {
    "uuid": "f2815b01-5507-524f-9821-6d691aef5bd8",
    "entry": "ブール",
    "reading": {
      "primary": "ブール",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "boule (round loaf of white bread)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近頃の流行語で云えば彼は代表的のブールジョア理学者であったかもしれない。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリストクラシーないしブールジョアジーと芸術とのある関係を想わせる。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスタンブールで恋人はその身を果敢なんで、死んでしまったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはブールヴァールを歩く貴婦人のように悠々と歩く。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三町出るとブールバール・デジタリアンの大通りです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側にあるのがクリミヤから持ってきたいわゆるセバストポールの鐘、右側のがここのブールドン目方が幾キログラムある、中にさがった舌がいくらいくらと説明する。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は今日のようなグラグラ政府には飽きられただろうと思う、そこでビスマークとカブールとグラッドストンと豊太閤みたような人間をつきまぜて一鋼鉄のような政府を形り、思切った政治をやってみたいという希望があるに相違ない、僕も実にそういう願を以ています、しかし僕の不思議なる願はこれでもない。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞を最も必要と感ずる人の種類を考えてみると、それは、広義における投機者であり、また一種特別な意味でのブールジョアである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば笛のピパに対して弦楽器のピパすなわちビワがあり、弦楽器のタンブールに対して太鼓のタンブールがあるような類である。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "セーヌ河畔の釣り人や、古本店、リュクサンブールの人形芝居、美術学生のネクタイ、蛙の料理にもどこかに俳諧のひとしずくはある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しばらく」　きれぎれに投げ散らされるブールヴァル言葉が、足音のざわめきにタクトされつつ、しきりなしに乱れ飛ぶ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョッキとアフガンに従軍し、キャラシァブ、シャープール及びカブールに駐屯したる事あり。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その日の夜にはふたりしてブリュッセルまで行き、そこで二日過ごしてから、三日目にははるばるストラスブールへ移動した。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストラスブールの食堂の席に着きながら、この件を半時間語り合ったが、その晩には二人旅を再開、順調に道行きを進めてジュネーヴへと至った。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ近所のデュブール街の貸廐に置いてあるのです。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世武士が軍陣に犬とともに臥して寇敵を予防する風盛んに、その後婦女が犬を寵愛する事普通になりしより、犬が殊に墓碑に刻まるるに至ったので、スペインブールホスの大寺にあるメンシア・デ・メンドザ女の葬所なる臥像はその裙に狆を巻き付かせある。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカンダールブール砦を立てた時梵種一人とヅサード族の娘一人を牲にした。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その社会的位置に相応する堂々たる生活をしていたので、濁富でないまでも清貧を任ずるには余りブールジョア過ぎていた。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　ブールジエの芸術は、ナチユラリズムの人達の行つたところとは余程趣を異にしてゐる。",
              "citation": {
                "source": "J. K. Huys Mans の小説",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブールジエは無論その心理派に属してゐたんであらう。",
              "citation": {
                "source": "J. K. Huys Mans の小説",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルクサンブール公園のすぐ傍なので、「地獄」に出て来る公園もここの公園であろう。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学者の彫像の多いのはルクサンブールの公園である。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはルクサンブール公園の外郭に沿った、オーグスト・コント通りだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルクサンブールの公園の中へ這入り、冷たい鉄の椅子に腰かけ、暮れかかっていく空を見上げながら、東京のあれこれを考えていると、不意に婆さんが肩を叩いて、腰かけ料をくれと云う。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルコ駐在のドイツ大使フォン・パーペンがドイツに帰る途中、イスタンブールで新聞記者にドイツの戦争目的如何という質問を受けた。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭渕橋、河原のブールバール。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでゲーテはニーブール風の歴史的批評が破壊的であるといふ故をもつて、これを軽蔑した。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "boules (game)",
        "register": "standard",
