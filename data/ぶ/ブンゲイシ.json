        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "担任として彼女を指導し、〈著者〉として『綴方教室』を世に出した大木顕一郎と清水幸治は、児童文芸誌『赤い鳥』を主宰した鈴木三重吉に、強い影響を受けていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上秋剣の名で、中学文壇その他の文芸誌に、詩や文章の選、また小説評論も書いておられた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで我々が通常従っていた定石というのが、月刊文芸誌の体裁をとる、というものだった。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
