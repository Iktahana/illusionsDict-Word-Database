    "definitions": [
      {
        "index": 1,
        "gloss": "punishment by Buddha",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "手前はあまりな婆さんの仕打を見てまして、仏罰を恐れないのか、なんと云う後生の悪いことをする婆さんだ、と、怒るよりは、空恐ろしい思いをしましたところで、婆さんの頭は突き戻されるようにお駕籠の中から出るとともにその体は背後へよろよろとなりました。",
              "citation": {
                "source": "尼になった老婆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "善因善果、悪因悪果、悔い改めよの、心を入れ換えよの、やれ神罰の、仏罰の、天の怒り地の祟り、親罰、子罰、嬶罰のと、四方八方からの威し文句の宣伝ビラが昔から到る処ふり撒かれておりますが、近頃の人間は頓と相手にしなくなりました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "百日のあいだは我が姿を人にみせるなというお告げにそむいて、みだりに奥をうかがう時は、仏罰によって眼が潰れるか、気が狂うか、どんなわざわいを蒙らないとも限らない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえ方はおそろしい禍いを避けるために、護摩を焚き、祈祷を行なっていながら、却って仏罰を蒙るようなことを仕出かして、どうする積りか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが幸いに図にあたりまして、三、四年のあいだはなかなかの繁昌で、賽銭そのほか収入もござりました」「その延光という役僧はどうしました」「あるいは仏罰でもござりましょうか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "松蔵のような悪い奴に魅こまれましたのも、やはり仏罰であろうかと思われます」　祥慶は数珠を爪繰りながら暫く瞑目した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏に仕える者が、生臭なぞいただいたのでは仏罰が当たりましょう？",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪魔立て致すとは何を暴言申さるるか、霊地の庭先荒さば仏罰覿面に下り申すぞッ」「控えさっしゃい。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今日まで、仏罰にもあたらず暮らしてきた。",
              "citation": {
                "source": "死体蝋燭",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月廿六日　晴、徒歩六里、二日市、和多屋（二五・中）気分も重く足も重い、ぼとり／＼歩いて、こゝへ着いたのは夕暮だつた、今更のやうに身心の衰弱を感じる、仏罰人罰、誰を怨むでもない、自分の愚劣に泣け、泣け。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏罰覿面、痔がいたんで歩けないので休養、宿の人々がまたよく休養させてくれる、南無――。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「仏罰恐るべし恐るべし。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏罰が当りますぞ……と叱って返しました……が……お千世殿が帰られてからタッタ一人になりますと扨、何とのう心配になって参りましたので、コッソリと本堂に参りまして、勿体のうは御座いましたが、御本尊の弥勒様をゆすぶり立てて見ますると、成る程コトコトと音が致します。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲に発表しても、さして仏罰はあたるまい。",
              "citation": {
                "source": "「沈黙」の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに仏罰を蒙ろうぞ。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗「あゝ悪い事をした、お竹さんが此様な怪我をする事になったのも畢竟我が迷い、実に仏罰は恐ろしいものである」　と思ったので宗達はカアーと取逆上せて、お竹が持っていた合口を捻取って、「お前一人は殺しはせん、私も一緒に死んで、地獄の道案内をしましょう」　と云いながら我腹へプツリ。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は内道場の持仏堂の仏前に端座し、もはや仏罰を怖れなかつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、仏罰を思はなかつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "神罰もくだりましょう、仏罰も当りましょう、それもよく心得ております。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "神罰もくだりませう、仏罰も当りませう、それもよく心得てをります。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "が寺僧は、そういう冒漬をあえてすれば仏罰立ちどころに至って大地｜震い寺塔崩壊するだろうと言って、なかなかきかなかった。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は我が国でも物を大切にするよい習慣がありまして、米一粒でも粗末にすると仏罰が当るといってやかましく戒めて居たのでありますが、近頃ではかような立派な考えは全く地を払った様であります。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何を言う――御主人、内儀が出刃庖丁を持って石の蓋をした井戸の中で死んでいたのは何んのせいだと思う」「――――」「嫉妬に眼がくらんで、お竹殿――いや生身の大日如来を刺そうとした仏罰じゃ」「金助が死んだのは？",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "お竹大日如来",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お竹殿の閨を犯そうとした為じゃ、――仏罰の恐ろしさは、ひしと身にこたえたであろう。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "お竹大日如来",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、銭形の親分、ちょうどいいところだ、――仏罰の恐ろしさ、これを見て下さい」　優曇法印は立ち上がって、護摩壇の前を指します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "欄干の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなるのも、仏罰で致し方もない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "欄干の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次がこの馬鹿馬鹿しい仏罰の夢物語を、どんなに骨を折って打ち壊したことでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "欄干の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "叶屋重三郎が慾に目が眩んで、もったいなくも不動明王の尊像を抵当に取ったから、仏罰が当ったに違えねえというので、不動堂の講中が、浪人くずれの大垣村右衛門を先頭に、叶屋に乗り込んで、お祭のような騒ぎですぜ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "仏敵",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　女房のお徳はガラッ八が言った火箸のような細い冷たい身体に、燃え立つような狂信者の情熱を持った四十近い女で、思い詰めたら随分ひどいことでもやり兼ねない気性らしく、夫重三郎の非業の死を、仏罰と思い込んだものか、さして悲しむ様子もなく、二人を離屋に案内しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "仏敵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
