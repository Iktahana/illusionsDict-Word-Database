          "literary": [
            {
              "text": "またずいぶんしばらくみんなしぃんとして待った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人どもはだんだん向うの方へはんの木の間を歩きながらずいぶんしばらく撒いていましたが俄かに一人が云いました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば、寒雀もずいぶんしばらく食べなかったな、と悶えても、猛然とそれを頬張る蛮勇は無いのである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あのぶんしょうは、ずいぶん下手だべ。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎はきのどくになって、「さあ、なかなか、ぶんしょうがうまいようでしたよ。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずゐぶんしばらく行かなかったのだからことによったら樺の木は自分を待ってゐるのかも知れない、どうもさうらしい、さうだとすれば大へんに気の毒だといふやうな考が強く土神に起って来ました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴っぽいラクシャンの第一子がずゐぶんしばらく光ってからやっとしづまって斯う云った。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またずいぶんしばらくみんなしいんとして待ちました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶんしばらく行かなかったのだからことによったら樺の木は自分を待っているのかも知れない、どうもそうらしい、そうだとすれば大へんに気の毒だというような考が強く土神に起って来ました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴っぽいラクシャンの第一子がずいぶんしばらく光ってからやっとしずまって斯う云った。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またずゐぶんしばらくみんなしぃんとして待った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中西の宿はずいぶんしみったれているが、彼奴よく辛抱して取り換えないね。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ来て見るとわれわれの世界もずいぶんしずかだね。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人どもはだんだん向ふの方へはんの木の間を歩きながらずゐぶんしばらく撒いてゐましたが俄かに一人が云ひました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから僕は心配だから、ネリの処に番しようか、ペムペルについて行こうか、ずいぶんしばらく考えたけれども、いくらそこらを飛んで見ても、みんな看板ばかり見ていて、ネリをさらって行きそうな悪漢は一人も居ないんだ。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あのぶんしやうは、ずゐぶん下手だべ。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎はきのどくになつて、「さあ、なかなか、ぶんしやうがうまいやうでしたよ。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだい、ずいぶんしゃがれた声だろう。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはぼくのために、お墓をはんぶんしか、ほってくれませんでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「したいと思ったことでできなかったこともあるが、まあ人に較べたらずいぶんした方だろう」「この辺で節季の勘定を済すかな」笑いながらそういった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄酒のブランデーとかいう珍しい飲物をチビチビやって、そうして酒癖もよくないようで、お酌の女をずいぶんしつこく罵るのでした。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに奥さまは目をめらめらさせて通りを下ってきて、猫背の男が街灯のそばに立って、怒り狂うかのように握り拳を宙でぶんぶんしているのが見えました。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車がレディングを過ぎてずいぶんした頃、最後のひとつを座席の下に突っ込むと、葉巻入れをこちらに差し出した。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれがあの人だったらずいぶんしあわせな人間だろうな。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶんしあわせだったんですねえ。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、ずいぶんしあわせだったのね、もみの木のおじいさん。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、ずいぶんしけてなくって？",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
