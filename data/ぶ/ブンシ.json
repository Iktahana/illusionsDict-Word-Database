[
  {
    "uuid": "ecae9ccd-0f2f-58f1-87b6-5e0a9a91f730",
    "entry": "分子",
    "reading": {
      "primary": "ぶんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
