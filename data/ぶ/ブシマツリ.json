    "definitions": [
      {
        "index": 1,
        "gloss": "traditional festival in Kiryū City, Saitama",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
