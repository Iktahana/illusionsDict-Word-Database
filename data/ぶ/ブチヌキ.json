    "definitions": [
      {
        "index": 1,
        "gloss": "removing a partition (wall)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
