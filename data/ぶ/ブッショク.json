[
  {
    "uuid": "c6fcb904-97eb-5581-ba89-0cbd991b9f91",
    "entry": "物色",
    "reading": {
      "primary": "ぶっしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
