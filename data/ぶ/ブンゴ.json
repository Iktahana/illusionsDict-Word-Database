[
  {
    "uuid": "6e416c47-9cf2-5822-938f-f67fed918c48",
    "entry": "文語",
    "reading": {
      "primary": "ぶんご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
