    "definitions": [
      {
        "index": 1,
        "gloss": "with a plunge (of something sharp into something soft)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところがあるばん、さいくどりに、せいいっぱいうまくうたわせて、皇帝はね床の中でそれをきいておいでになるうち、いきなり、鳥のおなかの中で、ぶすっという音がして、なにかはぜたようでした。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶすっという水の音が聞えたきりである。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おはようございます」　なかの一人がふり向いてそう云ったきり、みんなぶすっとしている。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、同時に、ぶすっという音がして、土俵へ弾丸が当ったらしかった。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして空に耳許に、頭上に、弾丸の唸りが響いていて、立木へ、土地へ、砂嚢へ、ぶすっぶすっと時々弾丸が当った。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊川はぶすっとした顔で、「ふしぎなひとがあらわれた」　とか、なんとかいいながら、バーテンにジン・フィーズをいいつけた。",
              "citation": {
                "source": "川波",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が、『おやすみなさい』　と云って去ろうとする刹那、ぶすっというような異様な音が室内からきこえた。",
              "citation": {
                "source": "正義",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、師匠のお嬢さん、お袖様のかわりだと思え」　次に送った一本は、ぶすっと、かの女の乳ぶさに立った。",
              "citation": {
                "source": "野槌の百",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それが逆なんですよ」　フクさんは以前はぶすっとした無愛想な女で、タバコ商売はそれで通ったけれど、酒やおでんの商売ともなると、適当に相槌なんかも打たなきゃならない。",
              "citation": {
                "source": "凡人凡語",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸太小屋の中にはぶすっとしたカナカ族の囚人が六人収容されていた。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この条件に同意するか」「わかった」　ぶすっと返事があった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが見事な景色だと言えますか」　ホークスがぶすっと言うことに、ちっとも変だと思わない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリタイアが、ぶすっと振り向いた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――おやじ、強いのはねえか」　ぶすっとそんなことを云って、濁酒に焼酎を入れたのを取って、それをすぐには飲もうともせず、蒼黒いような疲れた顔を俯向けて、なにかぶつぶつ独りで呟いたり、なんども深い太息をしたりする。",
              "citation": {
                "source": "嘘アつかねえ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御苦労だった、すっかり済んだか」「大体のところ済ませて来た、けれど、……不愉快な話を聞いて来た」　甚十郎は、香苗の進める茶には手も出さず、色の黒い角張った顔に、深い皺を刻みながらぶすっとした調子で云った。",
              "citation": {
                "source": "城中の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶすっとして去ってゆく二人の姿には、不満と怒りがあらわれているようであった。",
              "citation": {
                "source": "ちくしょう谷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠太はぶすっとした顔で、自分の盃を市三に差そうとし、気がついたのだろう、途中でやめて、こんどは燗徳利を渡そうとした。",
              "citation": {
                "source": "源蔵ヶ原",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその夜また泊っていったが、例のようにぶすっとして余り口をきかず、蓬臭い莨をふかしては、怖いような眼で部屋の中を見まわしていた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らずぶすっとして、あまり口もきかず莨ばかりふかしている、ときに幸太郎を抱いたりしても、なにやらぶきようで自分で当惑するという風であった。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らずぶすっとした顔で蓬臭い莨をふかし、怖いような眼で家の中を眺めまわしたり、おせんの付けている絵解きのような帳面を退屈そうにめくってみたりする。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒で蒲団を押したような手ごたえが、ぶすっと突き抜けると、真っ赤なものが、花火のように顔へ噴いたので、露八は、「あっ！",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足のつま先から少し離れた所へ、ぶすっと一本の矢が立った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "現場にいたかどうかですな」　ビンセントが不機嫌にぶすっと言った。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "分かったか、バカ者、青白い顔で、ぶすっとしよって。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっといて」　リッチフォードがぶすっとした表情で出て行った。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉のところで藩王がぶすっと突っ立ち、煙草をくわえた口元には、黄ばんだ強力な歯並みがあった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "リッチフォードはぶすっとして、自暴自棄だ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしや……」　レスブリッジがぶすっと言った。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔がこわばり、ぶすっとなり、主人に向けた目には反抗心があった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶすっとした顔がライトに照らされた時、してやったりのマーシが見えた。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
