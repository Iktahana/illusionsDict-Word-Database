[
  {
    "uuid": "4247c818-2768-5363-9f93-37fee6cbba55",
    "entry": "分掌",
    "reading": {
      "primary": "ぶんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
