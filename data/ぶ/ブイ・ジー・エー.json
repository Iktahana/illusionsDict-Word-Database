        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本ＩＢＭの発表によれば、ＤＯＳ／Ｖは六四〇×四八〇ドットのビデオ規格、ＶＧＡ（ビデオ・グラッフィックス・アレイ）に対応したＭＳ―ＤＯＳであるという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＤＯＳ／ＶのＶは、ＶＧＡのＶ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが日本のユーザーには、まずこのＶＧＡというやつがわからない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてここで登場してきたのが、六四〇×四八〇で十六色のＶＧＡだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＶＧＡ互換ボードが他社の手によって開発され、業界標準であるＰＣ　ＡＴ互換機に組み込まれた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして世界の標準は、ＥＧＡに代えてＶＧＡを組み込んだＰＣ　ＡＴ互換機へと移った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまあＶＧＡが何物であるかは分かっても、日本のユーザーにはまだＤＯＳ／Ｖに納得が行かないはずだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日本ＩＢＭのＶＧＡへの後退、妥協に、果たして何の意味があるのか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "対象マシンは、ＶＧＡを備え拡張メモリを積んだＰＣ　ＡＴとＰＳ／２。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はしだいにブランドへのこだわりを捨て、訳の分からないマシンに訳の分からないＶＧＡボードを差して、ＤＯＳ／Ｖを走らせることになる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
