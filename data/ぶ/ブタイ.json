[
  {
    "uuid": "98ec3aff-8b65-5af9-9b87-827f52a0362a",
    "entry": "舞台",
    "reading": {
      "primary": "ぶたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
