    "definitions": [
      {
        "index": 1,
        "gloss": "clumsy (work)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
