        "examples": {
          "standard": [
            {
              "text": "密教の歴史ある寺院で、色鮮やかな仏頂尊の曼荼羅を拝観する機会に恵まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "今年の前厄の祈祷で、僧侶に仏頂尊の真言を力強く唱えてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "境内の奥にあるその古いお堂には、ひっそりと仏頂尊が祀られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "和田仁十郎以下の門人達は白衣を着て、その旛の下、壇の周囲に坐して「大威怒鳥芻渋※儀軌経」、「仏頂尊勝陀羅尼」、「瑜伽大教王経」、「妙吉祥平等観門大教主経」等の書巻を膝の上にもって、黙読していた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
