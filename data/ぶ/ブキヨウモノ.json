        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "畢竟芝居上手が人間で、己れっち見たいな不器用者は虫なんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開いて見て元の箱に納めようとすれば、本には薄い包紙が着けてあるので、私のような不器用者にはなかなかうまく這入らず、ともすればその包紙を破ってしまう。",
              "citation": {
                "source": "書物の倫理",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご承知の通り私の兄は、あの通り上手でございますのに、どうしたものかこの私は、音に出すことさえ出来ないという、不器用者でございましたところ、さああれはいつでしたかな、月の良い晩でございましたが、ぼんやり船の船首に立ち、故郷のことや兄のことを、思い出していたのでございますな。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹田は自分ほど才のない不器用者はないとしてゐる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『絵なぞ描けるくらいなら、何も粋狂に、こんな山ん中で泥棒なんぞしている奴があるもんか、このがさつ者の不器用者にゃ、とても、とてもよ』『そんな事はない』　老画師は、真面目である。",
              "citation": {
                "source": "人間山水図巻",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さほどの不器用者なら失うも悔いとはせぬ）　と、奔河のなかへ、子を投じた。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ鈍物に生れて、生涯一度か二度という時に、一生の働きをいちどにして、あとは不器用者といわれていたほうがいい」　近ごろ四十にも近くなると、甘糟三平も、時々そんな愚痴をこぼした。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この高氏は不器用者です。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
