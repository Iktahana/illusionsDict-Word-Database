[
  {
    "uuid": "9a245db2-d6e6-5c28-a413-56c0f04edc22",
    "entry": "文案",
    "reading": {
      "primary": "ぶんあん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
