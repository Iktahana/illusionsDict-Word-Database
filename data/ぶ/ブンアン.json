        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "draft (of a document)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちらしや広告の文案も助手を使って引き受けていた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時その役に当ったのは加藤という少年だったが清逸は加藤の依頼に応じて答辞の文案を作ってやった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの一室で、立続けに電話をかけたり、紹介の文案を書いたり、訪問記者と折衝したりして、深い疲労と、極度な喫煙で、どろんとした顔付きになっている逸作は、強いて事もなげに言った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに以言の草稿をも飽足らず思召して、其果に此の匡衡に文案して欲しいとの御頼みなのだ。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、製薬会社が広告文案係を求めているのを見て、広告文案など作れそうにもなかったが、とにかく三つばかり文案を作って履歴書と一緒に送ったところ、一週間ほど経って面会の通知が来た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "文案がパスしたと思うと嬉しくて、俺に文才があるのだろうかと、ふと赤井が三高の「嶽水会雑誌」へ小説を投稿して没にされたことを想い出したりした。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日の新聞に、その会社の広告文案募集の広告が出ていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "裔一のお父様はお邸の会計で、文案を受け持っている榛野なんぞと同じ待遇を受けている。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、このマッチは、レッテルの文案に「関東煮」としてあるだけで、充分に東京の料理店のマッチでない事は判る筈だ。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、不良少年少女のは、大抵慣れた奴が文案したのを本人が書き直して出すので、芸妓や女郎のと同じねうちしかない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文案は桜痴居士であったらしい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――またアメリカのＦに出す手紙の文案を二日も三日も考へて、断念したり、静岡のお蝶を訪れて大遊蕩を試みようなどと思ひ、秘かにその資金の画策を回らせたり、アメリカ行の夢に耽つたり、時には小説家を装つて、家人を退け、近所に間借りを求めて、物々しく机の前に端坐して、顔を顰めたり、した。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六句集（幸にして刊行がめぐまれるならば）孤寒抄の広告文案┌業やれ／＼└業だな／＼　一月十六日　晴――曇。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "更けて良い月夜になつた、いつまでも睡れなかつた、どうしても寝つけなかつた、選句や文案を練つてゐるうちに、たうとう夜が明けてしまつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "重役は青くなって今も協議中ですが、会社の建造方針や、相良技師長苦心の設計事情について、直ちにステートメント発表の文案を起草中だそうです」「そうか。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "事項は『ホトトギス』募集文案、蕪村句集秋の部輪講等。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれに本づいて文案を作って、徳に筆を把らせ、家内の事は細大となく夫に報ぜさせることにしたのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし故参の文案に批評を加えることは出来ないので、色を和げていった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文案はこれからはこんな工合に遣るが好い。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでチチコフはその人に宛てて委任状を書いてくれと頼んで、余計な手数をはぶくために、自分で文案を考えたりしたほどであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "代書人などに一文だって余計な金を取られたくなかったので、彼は登記の書類も自分で文案をつくり、自分で認ため、自分で写しを拵らえることに決めた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "処々に韻を践んであったり、熟字の使い方や何かが日本人離れをしているところなぞを見ると、やっぱりその名付親の勃海使が芬夫人の譚に感激して、船中の徒然に文案を作ってやったのを、芬夫人が浄書したものではあるまいかと思う。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "福沢先生これに答ふる為めにとて、生｜等に嘱して文案を草せしむ。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はあらかじめ文案をしていたとみえ、ペンを執るとすらすらと手紙を書き終わってそれを懐にしまい、鏡台の前で顔を直しているところへ、カフェの経営者の海保が入ってきた。",
              "citation": {
                "source": "宝石の序曲",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやおや、これが三下り半といふ奴かと思つてゐると、さうぢやなくて、美人女給募集といふ新聞広告の文案だ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの宿六はたゞ金銭の奴隷なのだから千客万来がモットーで、ちらと見た広告の文案も美人女給「数名」とある。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、あなた」「ぢやア、お前すぐ新聞社へ行つてこい」「あら、あなたよ」　宿六は委細かまはず、広告の文案を書いて女房につきつけて、「すぐ行つてこい」「イヤ」「行かないか」　たまりかねて、五ツ六ツ、パチパチとくらはせる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふん」　と、豹吉のまずい洒落を鼻の先で笑って、「――たぶんあんたに会いに来たンでしょう。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、あのひとが間者であったということも一つの憶測にすぎず、あのひとが間者でなかったということも一つの解釈にすぎず、そのどっちかがかたちの上ではっきりしていたらたぶんあんなとりみだしかたはなさるまいと存じます。",
              "citation": {
                "source": "蜜柑の皮",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
