[
  {
    "uuid": "ff6a8629-2e77-5a27-bf13-6da5c0eea1b6",
    "entry": "仏殿",
    "reading": {
      "primary": "ぶつでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
