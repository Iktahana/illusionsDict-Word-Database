    "definitions": [
      {
        "index": 1,
        "gloss": "Bunkyū era (1861.2.19-1864.2.20)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
