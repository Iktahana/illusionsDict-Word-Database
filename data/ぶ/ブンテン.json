  {
    "uuid": "1ad0f076-97a2-5825-b173-badf4942b077",
    "entry": "文展",
    "reading": {
      "primary": "ぶんてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
