    "definitions": [
      {
        "index": 1,
        "gloss": "Bunten exhibition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「文展へ行つて見ろ、島村觀山とか寺岡廣業とか、あゝいふのはみんな大家だぜ、こんなのとはちがわあ」「あれでも何處かへ持つて行きあ、三十圓や五十圓にやあなるんだよ」などといふのも聞こえた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年の文展や院展を見に行ってもこういう自分のいわゆる外道的鑑賞眼を喜ばすものは極めて稀であった。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年文展が帝展に変った時には大分色々の批評があった。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば文展や帝展でもそんな事があったような気がする。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文展へ行って見ろ、島村観山とか寺岡広業とか、ああいうのはみんな大家だぜ、こんなのとはちがわあ」「あれでもどっかへ持って行きゃあ、三十円や五十円にゃあなるんだよ」などいうのも聞こえた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或年の夏、それは上野に博覽會があつてそれから愈文展が開催されるといふ頃であつた。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも博覽會の審査員に成つて居たのが、更に文展の審査員も囑託されるらしいが受けてよいかどうか相談に來たといふ。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから創作、古美術、名所、旧跡、文展、新画風、生活、自然と、案外｜論理的に運ばれた。",
              "citation": {
                "source": "小川芋銭",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年文展の「菖蒲」を見給へ、セザンヌの境地に到つてゐる――』と、ひやかしてやりたい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年文展「菖蒲」の空間的に成功してゐたのは、画題の選択の上で、先づ成功してゐたといふことと結びつけることが必要である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "福田氏の文展二回の『青柿』には作品に怖るべき質的昂揚があるのである、しかも吉岡氏の作品にも、同系列の質的昂揚のある作品が少くないことも注意すべきである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に芸術ではそうです」「私は嘗て文展に能のお面を出して落選しました。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文展や院展に出す絵のモデル代、旅行費、絵の具代、間借り代、その他の生活費は、つまらぬ絵を二三十枚描く辛棒さえあれば訳なく取れる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この反面に所謂官僚は電車の車掌も郵便配達も、文展側の畫工すらも、そりかへつて威勢を張つてゐる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、文展の第一回の展覽會であつたか、白馬會であつたか、利根川の上流をかいたべらぼうに大きな畫や、變な顏の赤白い女が花の前に立つてゐる畫が評判であつたが、あんな感覺も表情もない畫がどうして好いのかわからなかつた。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "文展審査員当時も、出品をじろりと一｜瞥して「拙いな」と顔を顰めて吐き出すやうに言ふが、さういふ口の下から、落款の「石井柏亭」といふ文字が目につくと、打つて変つたやうに「だが、よく見ると好いね。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆猿10・13（夕）　文展がまた開けた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、豆猿の好きなのは使ひ残しの墨汁の事で、文展に落選した女画家の涙までも嘗めて呉れるか、何うかは請合はれない。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」如来の失敗10・16（夕）　文展の彫刻部に『瓢箪鯰』を出品した米原雲海氏は、この頃｜夜の眼も眠らないで、せつせと仁王さんを刻んでゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "石碑と文展10・25（夕）　むかし唐の欧陽詢が馬に乗つて、ある古駅を通りかゝると、崩れかゝつた道つ端に、苔のへばりついた旧い石碑が立つてゐるのが目についた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "文展には色々の大家名家が数知れず出品してゐるが、ある批評家は、あのなかを唯四十五分で見歩く事が出来ると自慢してゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "典型的な文展に対して、大阪が同情し、後援すべき画風がありとすれば、それは独創を尚び、研究の自由を唱道し、兼ねてまた反抗的精神に富むでゐる美術院一派でなくてはならぬといふのが、会の主人側の意見であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幸満谷が今度の文展に出してゐる那奴を売りにかゝらう。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "文展出品の『源泉』は、やつと嫁入先を見つける事が出来たのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうしてポプ天倶楽部の連中は、陽気に関西旅行に出掛ける事が出来たが、困つたのは文展の洋画審査で、予め十九日と定めてあつたのを、満谷氏の旅行のため、止むを得ず二十一日に繰延べる事になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋麦僊氏が若い同士達と一緒に、文展を出て、別に国画創作協会を組織するといふ噂が伝はつた時、それを聞いた関雪氏は黙つてゐなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さういふうちに、関雪氏は選ばれて文展の推薦になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから文展は駄目だといふんだ、関雪が推薦になるやうぢやね。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと真実の事をいふと、文展向きの絵になる景色を捜しに来たのである。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
