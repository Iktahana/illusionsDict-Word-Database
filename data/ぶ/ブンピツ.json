          "literary": [
            {
              "text": "そこへ行くと、町人の中には隨分筆まめな人もある。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "林は「青年」第二篇において幾分筆致を引しめて書きすすめているが、第一篇に現れた基本的欠陥は克服されていない。",
              "citation": {
                "source": "文学に関する感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分筆がいいので、書くのに骨が折れてね。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら当分筆を執るまい。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分筆者は、その、思いの外うら若く、残んの色香を墨染の袖に包んでいる尼と狭い一室に膝をつき合わせ、彼女の孤独を慰めたり自分の無躾を詑びたりしながら、少しずつ身の上話を手繰り出すようにしたのであろう。",
              "citation": {
                "source": "聞書抄",
                "author": "第二盲目物語",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
