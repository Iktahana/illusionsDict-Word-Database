[
  {
    "uuid": "f46b4000-bb28-5f45-a3fe-10bbb8c3b091",
    "entry": "分地",
    "reading": {
      "primary": "ぶんち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
