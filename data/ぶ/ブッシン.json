[
  {
    "uuid": "ead0b733-4bb4-5373-ba78-0ff1196da625",
    "entry": "仏心",
    "reading": {
      "primary": "ぶっしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
