[
  {
    "uuid": "7bba1f19-0c26-55ab-be0a-7e3e6056dd29",
    "entry": "不格好",
    "reading": {
      "primary": "ぶかっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unshapely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "犀というものがどうにも不格好なものである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうしてこれが他の多くの動物よりもより多く「不格好」という形容詞に対する特権を享有することになるのか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物でも、なんとなしに不格好に見えるのはやはり現在の地球上に支配する環境の中で生活するのに不便なようにできているのではないかと思われてくる。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行手の堤の蔭には不格好に尨大な黒ずんだ建物がごつちやになつて平らな麥畑の中に建つてゐた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの甲羅はこんなに不格好なのだらうか。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車は後戻りすべく、夜更けの空気のなかに爆音を響かせて、不格好に迂回しはじめた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなく不格好に、しかし非常に熱心に踊っているのがおかしいようでもあったが、ハイカラでうまく踊る他の多くのダンディよりこのほうが自分にはいい気持ちを与えた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの龍のような不格好な老樹が、もし滑々した肌をもっていたら、それはとても見られたものではないでしょう。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身上だって財産だって、潰れてしまうのあたりめえだ……」　彼女の継母は、祖父のこの呟きを、快く聞き流しながら、背中に小さな子供を不格好に背負い込んで囲炉裏で沢山の握り飯を焼いていた。",
              "citation": {
                "source": "緑の芽",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彰子の友人達の、立派な指のためにピアニストを志したという人達の指さえ、ピアニストになりきった現在では、常にワン・オクタアブを敲いているような、ひどく不格好な骨張った指になっていた。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着ているのは長い寝間着のみで、ふくれたくるぶしと不格好な足がその下から硬直したまま突き出ている。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校生活についての私のいちばん古い思い出は、霧のかかったようなあるイングランドの村にある、大きな、不格好な、エリザベス時代風の建物につながっている。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵にこんな物はなかった筈だがと思いながら、彼はそれを手に取ってながめると、虎は急に眼がさめたように不格好な首を左右にふらふらと揺がした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどんなに粗末な不格好な、いでたちであろうとも、女は自分以外の女の服装をながめなければ満足できないものだと葉子は思いながらそれを倉地にいってみたりした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水剪紅羅、すこし不格好だが、白鳥の頸のやうにむくむくした※毛がある。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "其家にも、此家にも、怖し気な面構をした農夫や、アイヌ系統によくある、鼻の低い、眼の濁つた、青脹れた女などが門口に出て、落着の無い不格好な腰付をして、往還の上下を眺めてゐるが、一人として長く立つてるものは無い。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "詣づる人又人の手に撫でられて、其不格好な頭は黒く膏光りがして居る。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とか云つて、幾度も幾度も杖で此不格好な頭を擲つたものだ。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは宮の周囲にはえた不格好な樹立と、そしてちょろちょろと落ちる谷水を見ていると、何とも言えない欠乏の感じにうたれました。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦力頭の女房らしいビンツケで髪を固めているような、不格好な女がマントウやら葱やら唐黍の粥のようなものを土器のような容れものに盛って、五分板の上に膳立てをしていた。",
              "citation": {
                "source": "苦力頭の表情",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "須田町で九段両国の電車に乗り換えると、不格好な外套を被て、この頃見馴れない山高帽を被った、酒飲みらしい老人の、腰を掛けている前へ行って、瀬戸がお辞儀をして、「これからお出掛ですか、わたくしも参るところで」と云っている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一、臍問答、二、風や海や空、三、瘰癧のある人生、四、不格好な女、五、鍛冶屋同士の耳打話と、どうだい、どれだって面白そうじゃないか、それなのに、これが一本の酒手にもならんというのだから不思議だよ……」　卓子には徳利が七本になった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして所所に幾つかの不格好な胴像がどれも痛痛しく手を失ひ、脚を断たれて、真白な胸に黒い血をにじませながら立つてゐる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い曲がった一本の小枝、と言うよりはむしろ小枝に似たある不格好な細長い物体の上に、一人の――まるで形式を無視した、醜い盲人が斜めに身を支えている。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラザルス",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、ほんとに岩さんが来る」山吹は周章てて叫んだが、「来たら返してやるばかりだね」「ははあ、不格好なあの男がそれじゃ岩という男ですな」多四郎は鼻を鳴らしながら、「私の家の庭男にも当たらぬ」　牛丸はさもさも嬉しそうに、「俺ら岩さんを迎いに出てやろう」彼はそとまで走って行った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、太陽はずんずん昇っていって、塀にうつる影法師は小さな不格好なものになりましたので、長者の子供一人のだけで、他のは写し取れませんでした。",
              "citation": {
                "source": "影法師",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お礼のしるしに、これからあなたの黒馬は百倍の力になりますよ」　ぴょこんと不格好なおじぎをして、傷のなおった尻尾を打ち振りながら、宙に飛びあがったかと思うまに、悪魔の子はどこへともなく飛び去ってしまいました。",
              "citation": {
                "source": "天下一の馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、義足に趣味を持ち出すと医局からくれる不格好なのでは承知出来ないので、義足造りの所へ行つて足にあはせて造つて貰ふ。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな不格好な髪の薄い頭をして、訛音のひどい言葉でブツ／＼と女中に何か云つてることもあつた。",
              "citation": {
                "source": "哀しき父",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "目はぞうのように小さく、しょぼしょぼしていましたが、それにひきかえ、鼻とてのひらが、人一ばい大きく、そのうえぶかっこうでした。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
