    "definitions": [
      {
        "index": 1,
        "gloss": "breast",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いいかえ、カテリーナ、俺が＊ブレストの猶太人からぶんどつて来た蜜酒さへ飲まないんだよ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ブレスト　正しくはブレスト・クヤフスキイと言ひ、波蘭ワルシャフスカヤ県下にある猶太人町。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶丸善へ行つて見たら、イバネス、ブレスト・ガナ、デ・アラルコン、バロハなぞの西班牙小説が沢山並べてあつた為め、こんな事を記して置く気になつた。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの日、マタ・アリは、長距離電話でブレスト町を呼び出していた。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただちにブレストから、オランダのロッテルダムへ電報が飛んだ。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "電文は、ブレストの一カフェが鰯の罐詰を註文している文章だった。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前も、普通のアカハラといふのは止して、英語でレッド・ブレストと愛稱してやつてゐる。",
              "citation": {
                "source": "巣立ち",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "或朝なんぞ、彼女が窓からそのレッド・ブレストの餌をあさつてゐるのを見ると、何か細長いものを嘴に啣へて、それをしきりに一息に嚥み込まうとしてゐた。",
              "citation": {
                "source": "巣立ち",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブレストの軍港が近いので、その邊には艦隊が集まつてゐたらしい。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男と女が現れ、クロール、ブレスト、バタフライ、水泳をまねた踊りをはじめた。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "この土用浪の砕けて沸き返る赤黒い潮の中へ、パッと飛込んだ美奈子は、暫らく得意の綺麗なブレストを見せておりましたが、やがて沖から小山のように押し寄せて来た巨大な浪が、数十尺の真黒な屏風を押し倒したように、あっという間もなく、美奈子の上へ崩れたのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから彼はブレストの隊へはいるために立つて行つた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　二週間この方、シル※ストルは、ゴオドのその若い相談相手は、ブレストの隊へはいつてゐた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は氷島に於ける如く、ブレストでも同じ振舞ひをしてゐた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてまた、彼等は腕を組み合はせて、ブレストの町中を、いろ／＼な店の飾りつけを見て歩いた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何物にも氣をとめないで、彼はブレストの町を横切つた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがブレストで屡※聞き馴れた『ちよいと、貴郎』といふ言葉に似てゐた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブレスト発の列車がレンヌ駅に著いた時、その一貨車の扉の破壊されているのが見出だされた。",
              "citation": {
                "source": "探偵小説アルセーヌ・ルパン",
                "author": "EDITH AU COU DE CYGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきな仕立てのダブルブレストの新しい服を着て、ブライヤのパイプを口から離さなかった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後で聖マロとブレストの病院で医学を学び次いで海軍外科医となって英国と戦い、ときには政府の船、ときには個人の船に乗船した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "このオリオン号というのは、後にはブレストで練習艦として用いられたが、当時は地中海艦隊のうちに編入されていたものである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体として一つの戦闘艦を形造っているその巨大なる構造のおおよその概念を得んと欲するならば、ブレストかツーロンの港の七階の高さほどもある屋根のついたドックの一つにはいってみれば十分であろう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にとってもっとも得意な泳ぎかたは、ブレスト・ストロークだった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いつやつやした髪をオールバックにして、派手な縞のダブル・ブレストを着ている。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしいのです」　スクリーンで見たと同じ、あの凄艶といってもよいほど美しい、ダブル・ブレストの青年が映写機のそばを離れながら、青い顔をして答えた。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
