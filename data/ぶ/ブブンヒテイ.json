          "standard": [
            {
              "text": "「全員が賛成したわけではない」という文は、賛成した人もいることを含意する部分否定の典型的な例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "英語の授業で、「not always」や「not completely」などの副詞を伴う部分否定と、完全否定の違いについてテストに出ると念を押された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は相手の意見を真っ向から否定するのを避け、「必ずしもそうとは言えませんね」と部分否定を用いて柔らかく反論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
