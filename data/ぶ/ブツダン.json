    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist (household) altar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
