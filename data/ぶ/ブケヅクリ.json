        "examples": {
          "standard": [
            {
              "text": "鎌倉市内の史跡公園には、当時の図面を元に復元された立派な武家造りの館が建っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "寝殿造りから発展した武家造りは、実用性と防備を重視した簡素で力強い構造が特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "大河ドラマのセットは、専門家の監修のもとで細部まで忠実に武家造りの建築様式を再現している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "近頃建てた武家造りの門は、往來から少し引つ込んだところに、木の香がまだ新らしかつた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "武家造りの母屋と、それに続く道場は茅葺きで、門人や召使たちの住む長屋は※葺きであった。",
              "citation": {
                "source": "月の松山",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
