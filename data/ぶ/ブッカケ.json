[
  {
    "uuid": "04c5342b-b622-5d3f-b367-f732b2637871",
    "entry": "ぶっ掛け",
    "reading": {
      "primary": "ぶっかけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dish made by pouring broth over something (esp. bukkake soba)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　私は頭から、ひや水をぶっ掛けられたような気がしました。",
              "citation": {
                "source": "嘘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洋服を着て通りゃあがると、あたまから水をぶっ掛けるぞ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洋服を着て通りやあがると、あたまから水をぶっ掛けるぞ。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……また来やがったか、汝懲りずに」　喚いて脇差を引っこ抜き、振り舞わしたが多勢に無勢、すぐに脇差は叩き落とされ、それに博労の喧嘩上手、土を掬うとぶっ掛けた。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わッ、た、大変ッ」　下女の上ずった声が、次の間から響くと、恐ろしい予感に、騒ぎは水をぶっ掛けたように鎮まりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "麝香の匂い",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どッと、孫兵衛の狂気じみた影が、十数｜間も先へ駆けぬけてから、うしろにあたって、今さらのように、ヒイーッとたまげる声がして、歓楽の人渦はぶっ掛けられたような血を見てさわぎあっていた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "鳴門の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな逆説めいたことを口走って、サイダアを一瓶、頭から僕にぶっかけて、きゃっきゃっと気ちがいみたいに笑った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バケツ一つだけで弥生町門外の井戸まで汲みに行ってはぶっかけているのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかに、たとえば、飲んだくれの亭主が夜おそく帰って来て戸をたたくと女房のクサンチペがバルコンから壺の中の怪しい液体をぶっかけ、結局つかみ合いになるという活劇をもわずかな小道具と背景を使って映し出して見せた。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　馬が日射病にかかって倒れる、それを無理に引ずり起して頭と腹と尻尾を麻縄で高く吊るし上げて、水を呑ませたり、背中から水をぶっかけたりしている。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺に納められ、石油をぶっかけられた彼等の肉体は、火葬竈の中で、くさい煙となって消えて行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて先生を呼び出して病人をかつぎ込んでから顔へ水をぶっかけたり大騒ぎをした。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と附添の者が叫んで、それを抱き上げ、私の見ている窓の下に連れて来て、用意の手桶の水を、ざぶりとその選手にぶっかけ、選手はほとんど半死半生の危険な状態のようにも見え、顔は真蒼でぐたりとなって寝ている、その姿を眺めて私は、実に異様な感激に襲われたのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つ、なんでも幼い夏目先生がどこかの塀の上にあがっていて往来人に何かぶっかけて困らせたと云ったようなことがあったような気がするだけである。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼のさきに見える気にくわないものに、水をぶっかけて、天窓から洗っておやんなさるので、いつでもこうだ、極めていい。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "気絶した按摩は担ぎ出されて、水をぶっかけられるとすぐに蘇生したので、あとから駈けつけた駐在巡査に引渡された。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとしごとできると、こちらもむこうもいっしょになって、どぼんどぼんと池にとびこみ、いっしょに、水をぶっかけあって遊びました。",
              "citation": {
                "source": "草",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "塚本虎二氏の、「内村鑑三の思い出」を読んでいたら、その中に、「或夏、信州の沓掛の温泉で、先生がいたずらに私の子供にお湯をぶっかけられた所、子供が泣き出した。",
              "citation": {
                "source": "作家の像",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子に揮発油をぶっかけて、マッチで点火したら、それは大いに燃えるだろうが、せいぜいそれくらいのところしか想像に浮んで来ないのであって、あんな、ふとい大黒柱が、めらめら燃え上るなど、不思議な気がする。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おじょうちゃんは、口をとがらして、湯を書生さんにぶっかけました。",
              "citation": {
                "source": "赤とんぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "馭者はもちろん、かの青年も僕も手伝って、近所の農家の井戸から冷たい水を汲んで来て、馬に飲ませる、馬のからだにぶっかける。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝起きるときまりきった味噌汁をぶっかけた飯を食ってセオドライトやポールをかついで出かける。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鶏にかけちゃ、この界隈にゃ、且那に及ぶ者はねえってごったから……」「雛鶏だってなんだって、斯う松埃をぶっかけられちゃね。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼はこんどはいきなり冷水をぶっかけられたように、ゾッとしはしたが千二百十三、千二百十四と、数珠をつまぐるように数え続けた。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "食いかけの飯に湯をぶっかけて、夢中ですすり込んでしまった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その穴へ、ふたりは、代る代る酒をぶっかけた。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、江戸屋の親方にしたっても、生まれおちるからの江戸っ子なら、芸ごとのうえで人気負けしたのを根に持って、人の寝込みに水をぶっかけてまわるなんて、そんなけちなまねゃしねえと思うんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい奴はどこからか水を持って来て、侍の顔へぶっかけるのがある。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵兵はこの電波をぶっかけられると、たちまち身体が強烈なる電気振動に包まれ、第一にやっつけられるのは心臓です。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその土瓶を高く振りあげたかと思うと、中のお茶を竹内目がけてぱっとぶっかけました。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
