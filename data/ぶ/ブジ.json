[
  {
    "uuid": "0e17603b-d11d-526d-9955-5734a7bf4099",
    "entry": "武事",
    "reading": {
      "primary": "ぶじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
