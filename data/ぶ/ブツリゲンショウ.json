    "definitions": [
      {
        "index": 1,
        "gloss": "physical phenomenon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
