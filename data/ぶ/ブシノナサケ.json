    "definitions": [
      {
        "index": 1,
        "gloss": "samurai's compassion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
