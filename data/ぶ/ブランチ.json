[
  {
    "uuid": "7e306e5c-fcb8-5bdb-9673-c9149ad50682",
    "entry": "ブランチ",
    "reading": {
      "primary": "ブランチ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "branch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ギリシアではかかる時その人立ち駐りて兎を見なんだ人が来て途を横ぎるを俟ちて初めて歩み出す（コラン・ド・ブランチー、前出）。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、二隻の船は、例に依ってモウルス信号灯を掲げて会話を始めようとしたのだがゲルフ号の船橋で信号をしている三等運転士ブランチャアドは、何うしても相手の信号を読み取り得なかった。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ブランチャアドはこの事を航海日誌にも記さなかったのだが、ナタアル港へ着いてからワラタ号事件のことをきき、思い出してこの事実を報告したのだけれど、これも何うやら、他の船だったらしいと言われている。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兒狗のやつまで一緒になつて、　トレイも、ブランチも、スウィーハートも、　　こんなに、わたしに吠えつくのだ。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――小犬どもまでいっしょになって、　トレイも、ブランチも、スウィートハートも、どうだ、みんなわしにほえかかって来るわい」と、ブレースブリッジは大声で言って、笑った。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときレッドブランチの党派は血に浸っていた。",
              "citation": {
                "source": "女王スカァアの笑い",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどこの時、コルマック・コンリナスは再びコノール及びレッド・ブランチ党を援けるために帰国しようと決心したのであったが、琴手クレーヴシンの妻に対する深い愛を捨てかねて、彼女と二人、クレーヴシンのために焼き殺されてしまった。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "レッド・ブランチの名誉はどこにあると。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノール　（心が混乱したように）レッド・ブランチ！",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "……レッド・ブランチ！",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめても、せめてものこと、レッド・ブランチだけは残っておる！",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの二人とレッド・ブランチの三分の一の人たちはあなたから背き去りました、ウラァの族の第一の勇将ファガスと、あなたのお子の中の第一のお方、未来の王であるべきコルマック・コンリナスとが！",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "コルマックとファガスとレッド・ブランチ党の三分の一の人たちは女王メーブに味方しました、女王は全軍を集めてあなたを滅し、あなたの誇りであったイメーン・マカを滅したとおり、ウラァをも滅そうとしております。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "レッド・ブランチの光栄はどこにあります？",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはレッド・ブランチだ。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人等　（剣や槍を叩いて）レッド・ブランチ！",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛国者側で二名が仆れ、ルーサー・ブランチャードが負傷しただけだ！",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリストテレスの『倫理学』がそれ自身原理的に哲学の一ブランチであったと同じに、そのポリティカは、哲学の原則的な一ブランチだった。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから科学は一方に於て、総括的な唯一の単数名詞であると共に同時に又複合名詞でもあるのであるし、他方に於ては、諸科学の体統に於ける夫々の任意のブランチが、夫々一個の独立な科学となることも出来る。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の午後には、マクドナルドやケンタッキー・フライド・チキンのローカル・ブランチも、風情のようなものをなんとか獲得する。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
