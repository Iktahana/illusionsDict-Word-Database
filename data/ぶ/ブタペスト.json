        "examples": {
          "standard": [
            {
              "text": "ハンガリーの首都はブダペストですが、発音しにくいのか「ブタペスト」と間違えて覚えている人が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "友人が「ブタペスト旅行に行く」と言っていたので、正しくは濁点がつくとこっそり教えてあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "昔の旅行ガイドブックには、誤植でブタペストと書かれているページがいくつかあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ひとり、ミルク入りコオヒイを飲みながら、新聞の為替欄を読みふけつてゐるのが、昨日、ブタペストから寄り道をして来た日本の某名士と、その秘書である。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は同時にマルセーユと天津、ブタペストとホノルルとの婚約の成立ったのを見ました。",
              "citation": {
                "source": "耳香水",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
