    "definitions": [
      {
        "index": 1,
        "gloss": "bluish skin tone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
