        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "港で荷揚げ作業をしている筋骨隆々のブ男たちに混ざり、彼も汗を流しながら巨大なコンテナを次々と運んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祭りの神輿を担ぐのは、町内でも評判の力自慢のブ男たちばかりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "用心棒として雇われたのは、見るからに腕っぷしの強そうなブ男だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
