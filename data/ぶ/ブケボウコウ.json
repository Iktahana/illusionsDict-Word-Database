    "definitions": [
      {
        "index": 1,
        "gloss": "service with a samurai family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
