[
  {
    "uuid": "0932e083-de4f-5106-8ac7-25276b0c0f8e",
    "entry": "不祝儀",
    "reading": {
      "primary": "ぶしゅうぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
