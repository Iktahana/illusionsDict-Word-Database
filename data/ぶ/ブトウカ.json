    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dancer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本画家、洋画家、彫刻家、戯曲家、舞踏家、評論家、流行歌手、作曲家、漫画家、すべて一流の人物らしい貫禄を以て、自己の名前を、こだわりなく涼しげに述べ、軽い冗談なども言い添える。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋もさなかの、殊に薄霜のおりた朝などに、誰かが窓から覗いてみたら、召使という召使が、どんな達者な舞踏家だって、舞台の上でもやらないような恐ろしい勢いで跳ねまわっているのが眼につくことだろう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "困っているとお弟子さんが舞踏家の東勇作さんから楽譜を借りて来てくれました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "この他石井漠、伊藤道郎、高田雅夫、南部邦彦といった後年の名舞踏家やハリウッド俳優も「その他大勢」で出演しました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の舞踏家として実に珍しい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、英国王女が舞踏家と恋に落ちたとしましょう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
