          "standard": [
            {
              "text": "政府は国内の防衛産業を育成するため、特定の国に対する武器輸出の制限を一部緩和した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その企業はドローンの技術を軍事転用し、中東への武器輸出で巨額の利益を上げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "野党は「平和主義に反する」として、政府が進める新たな武器輸出の方針を強く非難した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "時計工、宮廷音楽教師、新貴族、武器輸出業、水道事業の発案者そして、そのうえに劇作家を兼ねたピエール・カロン事ボーマルシエがその代表的な一人であり、そのボーマルシエの空想に浮んだ一英雄、伯爵お抱えの理髪師フイガロがまた、その典型の一ヴアリエーシヨンに外ならぬ。",
              "citation": {
                "source": "秘伝の名訳",
                "author": "――ボーマルシエ、辰野隆訳『フィガロの結婚』",
                "note": "青空文庫"
              }
            }
          ]
        }
