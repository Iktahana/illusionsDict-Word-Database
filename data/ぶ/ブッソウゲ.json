        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……　植物園では仏桑花、ベコニア、ダリア、カーネーション、それにつつじが満開であった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隣では仏桑花の燃ゆるように咲き乱れた門口でシャツ一つになった年とった男が植木に水をやっていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねむの花のような緋色の花の満開したのや、仏桑花の大木や、扇を広げたような椰子の一種もある。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "台北の官舎では芭蕉や仏桑花、蘭など沢山植えてあったが、私のまっ先に思い出すのは父が一番大切にしていた一株の仏手柑である。",
              "citation": {
                "source": "朱欒の花のさく頃",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙がはうようにのびてくる仏桑花。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄の植物にはその外に仏桑花がある。",
              "citation": {
                "source": "暴風への郷愁",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜舌蘭や蘇鉄は別として、福木とか梯梧とか仏桑花とかは、暴風にやられてそこらじゅうに青い葉をまき散らした。",
              "citation": {
                "source": "暴風への郷愁",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
