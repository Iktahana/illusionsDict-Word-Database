    "definitions": [
      {
        "index": 1,
        "gloss": "above one's means (station)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "愛想も盡かさず、こいつを病人あつかひに、邸へ引取つて、柔かい布團に寢かして、寒くはないの、と袖をたゝいて、清心丹の錫を白い指でパチリ……に至つては、分に過ぎたお厚情。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも東京生れの、言葉使いの歯切れよい、分に過ぎた女房であったが、千恵造は兄の命ずるまゝに従った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速出かけて來て見ると、分に過ぎた大きな邸であつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "木槿の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其とも此様なのが実際に幸福なので、私の考へてゐた事が、分に過ぎたのかも知れぬ。",
              "citation": {
                "source": "背負揚",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「和尚様、五百両と申しましたところで、当山におかせられましては何のお役にも立ちますまいが、私にとりましては聊か身分に過ぎた寄進かと存じまする。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主に思われるに決まっていると、旦那様から分に過ぎた御祝儀を頂いた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "地位としては大した役人ではなかった様子であるが、この中條政恒という人の畢生の希望と事業とは、所謂開発のこと、即ち開墾事業で、まだ藩があった頃、北海道開発の案を藩に建議したところ若年の身で分に過ぎたる考えとして叱られた。",
              "citation": {
                "source": "明治のランプ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そは時頼の分に過ぎたる仰せにて候ぞや。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来が分に過ぎた仕事であったために、やせ馬が重荷を負うて山坂を上るよう、休み休みしてようやくここまでたどって来たが、もうこれで峠も越した。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "保雄には幾分でも自分の感化を受けて然う云ふ青年文学者の出るのが唯一｜図に嬉しいので、永年の苦労も、分に過ぎた負債も、世間の自分に対する悪評も然程苦には成ら無かつた。",
              "citation": {
                "source": "執達吏",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "また奥州より出て来たあの田舎武士が、御大将の眼前で晴れの武術を示すなど分に過ぎたる果報者だと羨んだものもあったろう。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "分に過ぎたる野望であるかも知れません。",
              "citation": {
                "source": "今日の感想",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "前もつて歩くのは駄目だと断つておいたので、かゝる分に過ぎた待遇を許されたのであつた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生はなるべく安い原料を美味く食べる工風にして身分に過ぎた贅沢をせんが、その代り僕の家では毎月一度ずつ無類上等の御馳走を拵えて一家団欒して食べる事に極めている。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、この二人の者の身上で、一羽の鳥とはいえ禽類の王者の子を手飼いにしようとは、分に過ぎた扶持方だと、この時、はじめて観念せざるを得なくなったに相違ありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う云ふ譯で、大師は韓方明の筆法を受繼がれて來たと云ふことは明かで、古來の傳説は貴いものであつて、私が本を能く讀まぬで彼是れ言つたのは分に過ぎたことで、申譯がないと思ひます。",
              "citation": {
                "source": "弘法大師の文藝",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の人達にでも洩らそうものなら、その人達はいうだろう、街道筋の馬子風情が、油屋の板頭と契るとは、分に過ぎた身の果報だ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私には分に過ぎた大望かも知れないのであるが、しかしさういふ心持で俳句界に臨んでゐる人が今の処絶無であるから瑰より始める積りで私は其方針を取つて居る。",
              "citation": {
                "source": "進むべき俳句の道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法皇は、「昔から朝敵を平げた者には、国の半ばを与えることになっておるが、頼朝の申すところ、いささか分に過ぎた願いと思う」　と仰せられたが、公卿たちは、頼朝のいうところにも一理あるからお聞き入れ願いたい、としきりに申し上げたので、法皇もついにお許しになった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなものがお宮に祀られるというのはたしかに分に過ぎたことで、私自身もそれはよく承知しているのでございます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女は船へ歸ると、余の傷よりも、楊弓の矢の心配をした、――眼から拔いて側へ置いた血だらけな矢を隱さうとしたのぢや」「殿樣」「一年越し世話をした女だ、分に過ぎた事もしてやつてある。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝等ごとき蛆虫が分に過ぎた言い分だ。",
              "citation": {
                "source": "お小姓児太郎",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「現に、背中を斬られた時は、分に過ぎた見舞を下すったし、昨日も主人が相談に行くと、焦がした羽目板を直せと言って、頂いたお金が五両――」「…………」「もっとも、娘のお民は出羽屋さんでお世話になって、奉公人と言っても、お客分同様、近いうちに、若旦那と娶合せて下さるという、内々の話もあります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お民の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女は船へ帰ると、余の傷よりも、楊弓の矢の心配をした、――眼から抜いて側へ置いた血だらけな矢を隠そうとしたのじゃ」「殿様」「一年越し世話をした女だ、分に過ぎた事もしてやってある。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大村兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び切りに立派では之を支配する人間のユニフォームの方が成立しなくなるだろうし、又あまり分に過ぎた制服は彼等の社会的野心を不当に煽動するだろう。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞと云って功績のない自分が分に過ぎた社会的待遇を受けていることが感激に堪えないので、せめてこの一万円を学問の進歩のために使って貰いたいというのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "四寸の強馬は分に過ぎたものに違いないが、しかし乗って面白いのは、やはり少々分に過ぎたものを乗りこなすところにあるようじゃ」「左様でございますとも、そのお心がけさえおありなされば、どのようなお馬にお召しなされてもお怪我はあるまいと存じまする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
