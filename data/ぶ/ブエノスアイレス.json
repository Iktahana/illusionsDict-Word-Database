        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これはラプラタ川（＊ウルガイとアルジェンチンの間の大河：河口にブエノスアイレスがある）を遡行する船で何回も岸と何かの連絡がなされる前に出現した。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵側惨虐宣伝反攻策昭　十九、三、十八参謀本部駿河台分室第一案　看護婦大谷しな殺人事件ノ攻撃　ブエノスアイレス丸ハ昭和十八年十一月廿七日米空軍ノ不法爆撃ニヨリ沈没、乗組看護婦約五〇名ガ端艇ニテ漂流中、十二月一日米機来襲赤十字旗ヲ認メ得ル高度ヨリ掃射セリ。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま総裁チャーチ博士は、南米の積雪調査の指導に、ブエノスアイレスに滞在していたからである。",
              "citation": {
                "source": "国際雪氷委員会のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後十時、汽船ロンドン号に移乗して、アルゼンチン国首府ブエノスアイレス市に向かう。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "六六、アルゼンチン首府ブエノスアイレスの実況　二日、晴れ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁窓ようやく明らかなるとき、ブエノスアイレス市の光景に接す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　リオデジャネイロを遼城と訳せるに対し、ブエノスアイレスを舞城または舞埃城と訳せり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブエノスアイレス市をリオに対照するに、山水の風景の秀霊なるは、後者の独占するところなり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブエノスアイレス市の将来の発展は驚くべきものならん。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その陳列品はブエノスアイレスのものよりも整頓せりとの評あり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして、その中心はブエノスアイレス市なり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地はブエノスアイレス市と異なりて、衣食住ともに質素を守り、華奢に走らず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の労働者はブエノスアイレス市には三百人も入り込みおるというに反し、当地には一人を見ざるほどなり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンデス横断鉄道は昨夏より全通し、ブエノスアイレス午前八時二十分発、バルパライソへその翌日午後十時四十分着。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとき設置は、南米においてブエノスアイレスを除くほかには、いまだ見ざるところなり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブエノスアイレスの警視庁から招かれまして、このロザリオを連れまして……一カ年ばかりの予定で亜留然丁へまいることになっておりますのです。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜留然丁の警視庁顧問として現在ブエノスアイレスにいるはずです。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも今ブエノスアイレスの大学に英国からケネディ博士という羅馬古代史の学者が来ているからね。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブエノスアイレス直通は、バヒア・ブランカ中継で二回線増してありますそうですから、なるべくこの方の御利用を願いまァす」一九　マクドナルド博士の話「さて、ケネディ博士のお話が済みまして、これから私が調査の結果を申し上げる番なのでありますが」と、マクドナルド博士が代って口を開いた。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう、来月早々ブエノスアイレスへ、おいでになる？",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそれはもう十幾年も昔のことであろうが、来月初めにはブエノスアイレスの大使館員に嫁いでいる娘さんを訪ねて、亜爾然丁へ出掛けるという。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
