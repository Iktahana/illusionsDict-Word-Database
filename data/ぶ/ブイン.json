[
  {
    "uuid": "0bde1231-8e03-5fee-8738-d84eabe044d4",
    "entry": "部員",
    "reading": {
      "primary": "ぶいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
