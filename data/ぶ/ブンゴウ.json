[
  {
    "uuid": "2fd7e000-1cc2-5bfc-9c5d-fae6bd719d59",
    "entry": "文豪",
    "reading": {
      "primary": "ぶんごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "literary master",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "世界の文豪である大トルストイが、救世軍的人道主義者として擔がれたり、通俗モラルのセンチメンタリストとして、女學生の涙劇的ヒロイズムの對象であつたりしたことを考へると、今から考へて全く馬鹿馬鹿しく滑稽である。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「惜別」の意圖太宰治　明治三十五年、當時二十二歳の周樹人（後の世界的文豪、魯迅）が、日本國に於いて醫學を修め、以て疾病者の瀰漫せる彼の祖國を明るく再建せむとの理想に燃え、清國留學生として、横濱に着いた、といふところから書きはじめるつもりであります。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "原品の肖像画は、「紀行文豪」たる、あるいはたりし記念として、家蔵としている。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ杜撰なディレッタントの囈語のようなものであるが、一科学者の立場から見た元禄の文豪の一つの側面観として、多少の参考ないしはお笑い草ともならば大幸である。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も偶然に津田君の画とこの露文豪のある作品との間に共軛点を認めさせられている。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大文豪などはほとんど大剽窃家である。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じように「何もしないがえらい人」とか「作品はあまりないが大文豪」とか「研究は発表しないがえらい科学者」とかいうものもやはり一種の透明不可視人間かもしれないのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや先生が大文豪になろうがなるまいが、そんなことは問題にも何もならなかった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七〇課　知られざる傑作　フランス十九世紀の文豪、バルザック（西暦一七九九年に生れ、一八五〇年に歿す）の有名な作品の中の一つに、「知られざる傑作」というのがあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以後いまだ百年もたっていないのに、多くの大家が文豪と称せられ、古典の仲間入りをして、文学の祭壇にまつりあげられ、この人たちの片言隻句はまるで文学の神様のような権威を与えられて、大正昭和の文学を指導して来ました。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」母は笑いながら、「文豪も、風邪をひいている時には、いい考えが浮びません。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある武士的な文豪は、台所の庖丁でスパリと林檎を割って、そうして、得意のようである。",
              "citation": {
                "source": "豊島與志雄著『高尾ざんげ』解説",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "押しも押されもせぬ文豪のおもかげがある。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊蕩青年からすぐこの文豪の風格を備へた著書を生んだその間の系統の不明なのに、他の国文学者たちは一致して不思議がつて居る。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的な文豪を以て任じている人は、それくらいのところが無くちゃいけない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治大正を通じて第一の文豪は誰か。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九世紀のヨオロッパの文豪たちも、幼くしてこの絵を見せられ、こわき説明を聞かされたにちがいない。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かれこそ、厳粛なる半面の大文豪。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス文学では、十九世紀だったらばたいてい皆、バルザック、フローベル、そういう所謂大文豪に心服していなければ、なにか文人たるものの資格に欠けるというような、へんな常識があるようですけれども、私はそんな大文豪の作品は、本当はあまり読んで好きじゃないのです。",
              "citation": {
                "source": "わが半生を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それら文豪以外のひとは問題でないのである。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文豪以外は、問題にせぬというその人の態度は、全く正しいのである。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、また、考えてみると、それは、読者諸君が、これから文豪になるために、ちっとも必要なことではない。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに文豪をこころざして、失敗して、そのとき第一の通信。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公はもはや第一の通信を受けとるまへに、文豪になりそこねて痛い目に逢つてゐるのだから。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文豪として名高くなることは、いまの彼にとつて、ゆめのゆめだ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藏から父の古い人名辭典を見つけだし、世界の文豪の略歴をしらべてゐた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公はもはや第一の通信を受けとるまえに、文豪になりそこねて痛い目に逢っているのだから。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文豪として名高くなることは、いまの彼にとって、ゆめのゆめだ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
