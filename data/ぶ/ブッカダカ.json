    "definitions": [
      {
        "index": 1,
        "gloss": "high prices of commodities",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
