        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして我々の心が物心一如の境地に到達しなければ言葉は我々の生命となり得ないのである。",
              "citation": {
                "source": "俳句に於ける象徴的表現",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "△転ぜられるところが転ずるところ、そこは物心一如、自他不二だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句作家の覚書、――色心不二、物心一如の心境、――即物即心。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "物心一如論はただ性欲と肉交との間には象徴的関係があることのみを主張する。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして物心一如の思想より、より深く実相を語るものはないであろうから。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物心一如であるといい得ないであろうか。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物心一如であると云ひ得ないであらうか。",
              "citation": {
                "source": "雑器の美",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
