        "examples": {
          "standard": [
            {
              "text": "彼の哲学の根底には強い物理主義があり、人間の意識や感情も脳内の化学反応に還元できると主張している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "物理主義の立場をとる彼女は、心身二元論のような魂の存在を真っ向から否定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "心の哲学の講義で、物理主義に対する代表的な反論である「クオリア」の問題について議論を交わした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あれは唯物主義者でもない虚無主義者でもない、物理主義者なんです。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は唯物主義者の一歩進んだ物理主義者の集団です。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
