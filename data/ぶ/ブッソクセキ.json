    "definitions": [
      {
        "index": 1,
        "gloss": "footprint of the Buddha carved in stone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
