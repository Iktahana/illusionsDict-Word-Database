[
  {
    "uuid": "1a65fd73-30a6-5d8d-9869-430a997e4e74",
    "entry": "ぶら下がり",
    "reading": {
      "primary": "ぶらさがり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
