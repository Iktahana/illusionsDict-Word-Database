        "examples": {
          "standard": [
            {
              "text": "戦後の焼け跡の中で、笠置シヅ子の歌う明るいブギウギのメロディが多くの人々を勇気づけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "バンドのメンバーたちは、アップテンポなブギウギに合わせて楽しそうにセッションを繰り広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ラジオから流れてきた懐かしいブギウギの曲に合わせて、母は台所で小さく口ずさんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "軍歌に変って流行歌があらわれ、それは映画の主題歌から最近ではアメリカ流行のブギウギの真似までがある。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代においては俗悪な、そして煽情的な実用品にすぎないジャズやブギウギが、やがて古典となって、モオツァルトやショパンのメニュエットやワルツと同じ位置を占めるようになるものなのだ。",
              "citation": {
                "source": "“歌笑”文化",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときすでに、ジャズはよりブラックなジャズと、よりホワイトなジャズとにわかれていて、たとえばジャズにとっての最終的な楽器だと考えられていたピアノがつくるジャズに、ラグタイムとブギウギとができ、ラグタイムは様式の音楽、ブギは自由なアドリブの音楽として、わかれたままつづいていった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめに聞いたのは、ブギウギのピアノです。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてレコード仕込みのブギウギやら与太を飛ばしたりしてお客のぼくたちに、お愛想のつもりか、しきりに皆を煙に捲く。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
