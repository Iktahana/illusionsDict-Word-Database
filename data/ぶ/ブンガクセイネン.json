        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みんなが何を話したか別段記憶しないが、ともあれみんな文学青年が先輩を詣でた式のことで、主人は間もなく退屈した。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（茲で一寸断つて置くが、ホンの少しの事が分ると、分つたことが当人にとつて余りに珍しいので却つて書けるといつたあの生々しい文学青年をも「書いてゐる奴」の中に入れて話してゐるのではない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際文壇に出ることが容易になつた此の頃は、さういつた文学青年も少くないことで、一知半解の故に却て元気がいいといつた風の元気が、本当の元気と間違へられる風景は、毎日のやうに見受けられることである）。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しき男といふのは文学青年で、――尠くもその頃まで――本を読むと自分をその本の著者のやうに思ひ做す、かの智的不随児であつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も文学青年なのだが、彼はまだ別に何にも書いてゐない。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはたいてい垢じみた着物をきて、頭を乱髪にした地方の文学青年だった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも用件で来るのは好いのだけれども、地方の文学青年なんかで、ぼんやり訪ねて来られるのは最も困る。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年四月『文学青年』）",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ屋｜喫茶店にいた文学青年給仕のＭ君はよく、銀座なんか歩く人の気が知れないと言っていたが、考えてみれば誠にもっとも至極なことである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの社へ、原稿を持ち込んで来た文学青年だ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだから、文学青年は、いやさ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだから、僕は、文学青年ってものは苦手なんだ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学青年と逢えば、文学青年。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）大体われ／＼の文学が軽佻で薄っぺらなのは一に東京を中心とし、東京以外に文壇なしと云う先入主から、あらゆる文学青年が東京に於ける一流の作家や文学雑誌の模倣を事とするからであって、その風潮を打破するには、真に日本の土から生れる地方の文学を起すより外はない。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学青年じみているのは、ロマンティストとしてこの上なく恥しいことです。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋画家や文学青年も入り込んだ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院でも文学青年が幾人かおり、寄ると触ると外国の作品や現代日本の作家の批評をしたり、めいめい作品を持ち寄ったりもして、熱をあげていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはたいてい垢じみた着物をきて、頭を乱髪にした地方の文学青年だつた。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕だって文学青年だったこともあるもの、何も不思議がりはしませんよ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この物語によつて彼の和漢の文学に対する通暁さ加減は、尋常一様の文学青年の造詣ではない。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」白面の文学青年、アンドレ・ジッドに与う。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴は所謂文学青年では無い。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネオ・ボンタージンの発明者、しかも永遠の文学青年、白石国太郎先生でありますぞ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような大へんな秘密を、高橋の呼吸が私の耳朶をくすぐって頗る弱ったほど、それほど近く顔を寄せて、こっそり教えて呉れましたが、高橋君は、もともと文学青年だったのです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つのとき『毛谷村六助』を買って貰ったのが、文学青年になりそめです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の悲歎を思えば神崎の如き文学青年の生活も出来ないし、一つには会社員と云う生活もしてみたかったのです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
