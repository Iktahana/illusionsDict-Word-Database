          "standard": [],
          "literary": [
            {
              "text": "あに、はい、墓さ苞入に及ぶもんか、手間｜障だ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下ではなお呼ぶもんだから、おばあさんが私のかわりに返事をなすって、（可いから、可いから。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたの喜ぶもん見せたげよ」「どんなもん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの喜ぶもんて……」「黙って随いといぜ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　次郎はちょっとがっかりしたが、ふと想い出して、「そや、あんたの喜ぶもん見せたげよ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎ぼんであろうが、太郎ぼんであろうが、若い娘が男とべらべら遊ぶもんと違う。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が生きるためには、どんな苦痛でも忍ぶもんだわ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ふと、弟は「厭だ／＼、もう兄さんとは遊ぶもんか。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「子どもは日が暮れてからひとりで遊ぶもんじゃねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ころぶもんもありゃあ、這くるものもあり、いやはや散々じゃったが、せどの仁助どんばっかりゃあ、胆のすわった子供だったと見えて、ちゃんと、によを拾って逃げたこっちゃ」八月十一日（木曜）　寺が中心になって居ること驚べし。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私みたいに独りぼっちで苦労して居なくっちゃあならないものには斯うした御家のあるのがこの上もない事なんですもの……」「親しくして呉れる人のふえるのってのは誰だってよろこぶもんですワ」「でも貴方みたいに皆から可愛がられて居る人はそうひどくは感じないでしょう？",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの桜の名は何んというかと言うとそれは緋寒桜と呼ぶもんだ。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、悪口をいうか、なぐりつけるのが関の山で、とし子さんも、「だれが遊ぶもんか。",
              "citation": {
                "source": "春の日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "男優Ｄ　　子供は玩具をやらなくつても遊ぶもんだ。",
              "citation": {
                "source": "職業（教訓劇）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし……」「そうさ、わかってるとも、星が飛ぶもんか」　海月に用心しなければならない。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "運命は不可思議な魔力で可憐な青年を弄ぶもんだと云う事が分る。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もう次郎ちゃんなんかと遊ぶもんか。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "行つて見るに及ぶもんですか。",
              "citation": {
                "source": "板ばさみ",
                "author": "オイゲン・チリコフ　Evgenii Nikolaevich Chirikov",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてもうちょっと用あるよって」と、追い立てるようにしなさるのんで、常時のことですよって腹も立てんと、「そんなら先｜行ぬわ」いうてその宿屋のろうじ出ましたら、小声で「お姉さん」と後から呼ぶもんあるのんで、振り向いて見たら綿貫ですねん。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火あぶりにされた人は水を求めて叫ぶもんだというが、彼は娘を求めて叫んでいる」「中止だ」主任医師が外科医に言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう絵は、外国船の下級船員たちが、非常によろこぶもんですって」「だから、わしが買うよ」「いいえ、売らないと言うんですよ。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
