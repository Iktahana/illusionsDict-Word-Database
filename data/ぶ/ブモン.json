    "definitions": [
      {
        "index": 1,
        "gloss": "military family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "菊五郎の原田重吉が玄武門破り、不評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先頭に進んで行き、敵の守備兵が固めている、玄武門に近づいて行った。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の受けた命令は、その玄武門に火薬を装置し、爆発の点火をすることだった。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎廻りの舞台の上で、彼は玄武門の勇士を演じ、自分で原田重吉に扮装した。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその芝居は、重吉の経験した戦争ではなく、その頃｜錦絵に描いて売り出していた「原田重吉玄武門破りの図」をそっくり演じた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金鵄勲章功七級、玄武門の勇士ともあろう者が、壮士役者に身をもち崩して、この有様は何事だろう。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度昔、彼が玄武門で戦争したり、夢の中で賭博をしたりした、憐れな、見すぼらしい日傭人の支那傭兵と同じように、そっくりの様子をして。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "往昔、兵馬｜倥※武門勇を競い、風流まったく廃せられし時と雖も、ひとり茶道のみは残りて存し、よく英雄の心をやわらげ、昨日は仇讐相視るの間も茶道の徳に依りて今日は兄弟相親むの交りを致せしもの少しとせずとやら聞及申候。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗が陳弁は此等諸方面との取合いの起った事情を明白に述べて、武門の意気地、弓箭の手前、已むに已まれず干戈を執ったことを云立てて屈しなかった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に彼等の思想も自から一種の特色を具備し得て、隠然武門の思想と対峙せんとするが如き傾きを生じたり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府は盛に能楽と謡曲とを奮興して、代々の世主厚く能楽の大夫を遇し、而して諸藩の君主も彼等を養ひて、武門の士の能く謡曲を謳ふこと能はざるは恥辱の如き隆運に向へり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことや平民と雖、もとより劣等の種類なるにあらず、社界の大傾向なる共和的思想は斯かる抑圧の間にも自然に発達し来りて、彼等の思想には高等民種に拮抗すべきものはなくとも、自ら不覊磊落なる調子を具有し、一転しては虚無的の放縦なるものとなりて、以て暗に武門の威権を嘲笑せり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のシバルリイは「我」を重んじて、軽々しく死し軽々しく生きず、我がシバルリイは生命を先づ献じて、然る後にシバルリイを成さんとするものゝ如かりし、己れの品性は磨くこと多からずして、他の儀式礼法多き武門に対敵して、反動的に放縦素朴に走りたり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏北条氏の時代に於ては、政権は既に大方武門に帰したりと雖、なほ文学宗教等は王室の周辺にあつまれり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑も当時武門の権勢漸く内に衰へて、華美を競ひ遊惰を事とするに及びて、風教を依持す可き者とては僅に朱子学を宗とする儒教ありしのみ。",
              "citation": {
                "source": "粋を論じて「伽羅枕」に及ぶ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "君ならでは人にして人に非ずと唱はれし一門の公達、宗徒の人々は言ふも更なり、華冑攝※の子弟の、苟も武門の蔭を覆ひに當世の榮華に誇らんずる輩は、今日を晴にと裝飾ひて綺羅星の如く連りたる有樣、燦然として眩き許り、さしも善美を盡せる虹梁鴛瓦の砌も影薄げにぞ見えし。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は治承の春、世は平家の盛、そも天喜、康平以來九十年の春秋、都も鄙も打ち靡きし源氏の白旗も、保元、平治の二度の戰を都の名殘に、脆くも武門の哀れを東海の隅に留めしより、六十餘州に到らぬ隈なき平家の權勢、驕るもの久しからずとは驕れるもの如何で知るべき。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにても武門の恥と心付かぬか、弓矢の手前に面目なしとは思はずか。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぎ越せし六十餘年の春秋、武門の外を人の住むべき世とも思はず、涙は無念の時出づるものぞと思ひし左衞門が耳に、哀れに優しき瀧口が述懷の、何として解かるべき。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓矢の上に天下を與奪するは武門の慣習。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あに、はい、墓さ苞入に及ぶもんか、手間｜障だ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下ではなお呼ぶもんだから、おばあさんが私のかわりに返事をなすって、（可いから、可いから。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたの喜ぶもん見せたげよ」「どんなもん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
