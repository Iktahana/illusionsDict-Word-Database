[
  {
    "uuid": "71dbdd6a-123d-56af-94ef-716ee312a054",
    "entry": "仏僧",
    "reading": {
      "primary": "ぶっそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
