    "definitions": [
      {
        "index": 1,
        "gloss": "selling separately",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんなものは当分売れまいと思っていたら、豈計らんや。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると男や少年も多分売買されるのに相違ない。",
              "citation": {
                "source": "日本の女",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る人から手紙で知らせて来たンだが、大分売り飛ばしてるつて本当かね？",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の代りには堅いから十四日晦日に作料を取れば直ぐにチャンと払いまして、今度又借りて飲むよと云うから、何時でも棟梁さん宜しいと云われ、随分売れた人でした。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでは大部分売り払ってしまったから、ほんの僅か残っているばかりであるというのであるが、それでも一ヵ月や二ヵ月では調べ終わるわけのものではあるまいと思われるのだ。",
              "citation": {
                "source": "増上寺物語",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "破格廉価大特売　（卸売の部）南針峯………………………三〇〇｜法ドーム・ド・グウテ………………二〇〇法モン・ブラン………………………五五〇法ビオナッセエ針峯…………………一八〇法緑の針峯……………………二五〇法　（小売の部）分売は一〇｜米につき二〇法也。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "中根六遍と加治わたるの絵は大部分売れ残り、三堂微々のみは僅かに、問題の絵一枚を除いて悉く売約済。",
              "citation": {
                "source": "喧嘩上手",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "野見　　当分売らないで下さいよ。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "当分売らないことにしますから、家賃だけ、少し、入れて下さいよ。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "『雪の研究』以後の写真も大分集まったので、増補でもしたいところであるが、ハーバード大学出版部から出した英文版が、まだ大分売れ残っているので、当分のところは見込みがない。",
              "citation": {
                "source": "南極・北極・熱帯の雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『え、大分売りました』と憂への高調も少し過ぎて笑子はやつと顔を上げて栄一の顔を見入る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のうしろにある、大部分売り物にならない枯木と、池から引きあげた流木とはわたしの燃料のおぎないとなった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "半分愛して半分売るなどということはありえない。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分売れにくいのは事実だろう。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに分売を許さず読者を繋縛して数十冊を強うるがごとき、はたしてその揚言する学芸解放のゆえんなりや。",
              "citation": {
                "source": "読書子に寄す",
                "author": "――岩波文庫発刊に際して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に分売を許さず読者を繋縛して数十冊を強ふるがごとき、果して其揚言する学芸開放の所以なりや。",
              "citation": {
                "source": "岩波文庫論",
                "author": "岩波茂雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し此の分なら大分売れてるかな、とニヤリ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
