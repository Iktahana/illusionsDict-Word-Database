    "definitions": [
      {
        "index": 1,
        "gloss": "a woman being reborn as a man (in order to qualify for Buddhahood)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
