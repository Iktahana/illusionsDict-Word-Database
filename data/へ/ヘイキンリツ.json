  {
    "uuid": "f36f213f-0508-5731-b140-67679d786012",
    "entry": "平均律",
    "reading": {
      "primary": "へいきんりつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
