    "definitions": [
      {
        "index": 1,
        "gloss": "to lose heart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "罹災でへこたれるような人じゃない。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かが頭をおさえつけているようで、私はまだまだへこたれるものかと口につぶやきながら、当もなく軒をひらって歩いていると、バスケット姿が、オイチニイの薬屋よりもはかなく思えた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "成金になりたい理想も、あんな大きな数字でへこたれるようでは一生駄目らしい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいでも、北海道から来たお父さんの手紙には、御難つゞきで、今は帰る旅費もないから、送ってくれと云う長い手紙を読んだ、寒さにはじきへこたれるお父さん、どんなにしても四五十円は送ってあげよう。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故だか私自身にも分らないが、父を思うと必ず私は、この通り立派に働いて暮しています、とそう父に云いたい気がしたし、どんなことにもへこたれるものか、という勇気が湧いてくるのだった。",
              "citation": {
                "source": "父母に対する私情",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだそれ位の事でへこたれるな、しっかりし給え」などいわれると病人の機嫌はよろしくない。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、へこたれるといふことは私は嫌ひだ。",
              "citation": {
                "source": "一九三六年回顧",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁談を拒絶されても、下男の存八に不覚の頭突きをぶちかまされて気を失っても、へこたれるような寺田ではなかった。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことで、おれがへこたれるものか。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことでへこたれるには及ばない。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "クログスタットの手紙がまだ郵便受にあつた時は、私はあなたがまさかあいつの申し出しにへこたれるやうな考へをお起しなさらうとは思はなかつたのですよ。",
              "citation": {
                "source": "人形の家",
                "author": "ET DUKKEHJEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにへこたれるのは、いつもの自分らしくない、とセエラは意外に思いました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "唇一つの工合で私はもうハアとなってへこたれることがあるのを。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、東京へ国が来るための切符が又候出来ず、座席もない汽車にわたし一人乗って行くのもへこたれるので待ち合わせ、明日一緒にということになりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そんなことで、へこたれるような八五郎でない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれをこきつかう分はかまわんが、兄に、ひどい陰口をいうには、へこたれる。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "証拠のないおどかしなんかに、へこたれるおれじゃないぞ。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだへこたれるには少し早いぞ。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だが、そんなことでへこたれる俺だと思うか」　もうぐずぐずしてはいられぬ。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "このくらいのことで、へこたれるものではありません。",
              "citation": {
                "source": "青銅の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
