[
  {
    "uuid": "4ea860df-b1a6-5154-9a15-247a9ead84ec",
    "entry": "返上",
    "reading": {
      "primary": "へんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
