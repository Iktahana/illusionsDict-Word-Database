        "examples": {
          "standard": [
            {
              "text": "古代ギリシャの哲学において、キュレネ学派は徹底したヘドニズムを主張したことで知られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼の小説の登場人物たちは皆、行き過ぎたヘドニズムに溺れて最終的に破滅していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "経済の急成長に伴い、この国全体に物質的なヘドニズムの風潮が蔓延し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "然るに文人に強うるに依然清貧なる隠者生活を以てし文人をして死したる思想の木乃伊たらしめんとする如き世間の圧迫に対しては余り感知せざる如く、蝸牛の殻に安んじて小ニヒリズムや小ヘドニズムを歌って而して独り自ら高しとしておる。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘドニズムの疑うことの出来ない根拠は全くここにある。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
