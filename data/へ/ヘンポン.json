    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fluttering (flag, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "後白浪に海の方、紅の母衣翩翻として、青麦の根に霞み行く。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空の中に翩翻として橙色の旗が翻っているマキアベリイ理想映画会社について。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の裏山には、我々が曾て空想した通りの、橙色の旗が翩翻として青空に翻っています。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の科學博物館がある近所で、その高い屋根の上には、赤地に白く PANORAMA と書いた旗が、葉櫻の陰に翩翻としてゐた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手首からすぐ丸い掌がつき、掌から申訳ばかりの蘆の芽のような指先が出ているかの女のこどものような手が、意外に翩翻と翻って、唄につれ毬をつき弾ませ、毬を手の甲に受け留める手際は、西洋人には珍しいに違いなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行啓の名残で、黄や赤や紫や青やの万国旗が此処でもまだ翩翻としているその下を、薄い翅のかがやく蜻蛉や蝶々の番いが、地にすれすれに流れたり縺れ飛んだりしていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場に　街頭に私は太鼓をとどろと鳴らす紅い上衣を着て私の行くところ頭上にリボンは翩翻と靡く。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてまた団子坂の景況は、例の招牌から釣込む植木屋は家々の招きの旗幟を翩翻と金風に飄し、木戸々々で客を呼ぶ声はかれこれからみ合て乱合て、入我我入でメッチャラコ、唯｜逆上ッた木戸番の口だらけにした面が見える而已で、何時見ても変ッた事もなし。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何よりも――眠れる獅子王の傍に咲く牡丹花のような容顔、春風になぶられてうごく雄獅子の髭に戯むれ遊ぶ、翩翻たる胡蝶のような風姿、彼女たちの世界の、最大な誇りをもって、昂然と嬌坊第一にいた。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目につかないようにすべき筈の洗濯物が、家根の上に翩翻とひるがえっています。",
              "citation": {
                "source": "エスキス",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、夜が明けかかり闇が白みはじめたころ、私は、菩提樹の梢をとおして、暁にふるえるユニオン・ジャックの翩翻たるを見たのである。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ向からかかれば払って退け、突いて来れば搦み落とす、翩翻自在の構えである。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さあさあ乗り込め、まず妾から」女ながらも一党の頭、隙のない手配りを云い渡したが、やがて土塀へ手をかけると、翩翻と向こうへ飛び越した。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の軽いを取り柄にしてただ翩翻と飛び廻るばかりだ。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ははあ……」　これも拍子抜けの体で、改めて、翩翻とひるがえる旗印を見直すと、丸に立波、そう言われてみれば、紛う方もない、これは勘定奉行の小栗上野介殿の定紋。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "倨然たる戦車の後尾に樹てられし旗竿には、ああ、南仏の春風に翩翻と翻る日章旗。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の瞬間に見えたものは、翩翻と返って来た長紐と、鳥居の一所に静止して、キリキリ廻っている独楽とであった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鞍壺へ手を掛けると甚内は翩翻と飛び乗った。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、男の影法師であろうが、翩翻と背後へ飛び返ると、二度ばかり白光をひらめかした。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翩翻と姥が身をかわしたのである。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――エーッ」　と裂帛の掛け声掛かるや、大いなる蝙蝠天井に向かって翩翻として飛んだかと見えたが、これぞ上州｜花隈の城主戸沢山城守直伝の秘法すなわち天狗飛切りの術。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳰鳥の身の軽さ、胡蝶のように翩翻と、右に左に前に後ろに、眼にも止まらず駈け廻わった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その実通路を見出そうとしてあせっているのであろうが、われ等の眼には少しもあせっている容子は見えず、翩翻として広い中庭に乱舞しているように見える。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川向うの茫洋たる砂漠には、成吉思汗軍の天幕、椀を伏せたように一面に櫛比し、白旄、軍旗等｜翩翻として林立するのが小さく俯瞰される。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……蝶は、たとへば影の海から日向の沙漠へ、日向の砂浜から再び影の水そこへと、翩翻として、現実の隙間に、季節と光線の僅かな煌めく彫刻を施しながら、一瞬から一瞬へ、偶然から偶然への、その散策の途すがらに、彼の檻の一隅をも訪れたのである。",
              "citation": {
                "source": "測量船",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大して暑くもないのに、胸のあたりでハタハタと白扇を使うと、ボヘミアン襟飾が翩翻として宙に泳ぎます。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "第四次元の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十人の会員の約三分の一は婦人ですが、その婦人達が一人残らず顔を隠して、翩翻として舞い、喃々としてお喋舌をするのです。",
              "citation": {
                "source": "法悦クラブ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八方に篝を焚いて、湧き起る唄と音楽の中を、翩翻として踊りに踊る処女の大群は、全く前代未聞の不思議な観物でした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "暴君の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時半月旗の影のダニウーブ河畔に翩翻たりし時には、全欧州民族に顔色が無かったでないか。",
              "citation": {
                "source": "現代の婦人に告ぐ",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがいかにも、僕を田舍者らしく感じさせ、世間を離れた空の上で、旗のへんぽんたるものを感じさせる。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
