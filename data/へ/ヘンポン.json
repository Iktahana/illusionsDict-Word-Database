[
  {
    "uuid": "d1b2c30f-e4f2-5182-9d00-de5dc2a1877b",
    "entry": "翩翻",
    "reading": {
      "primary": "へんぽん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
