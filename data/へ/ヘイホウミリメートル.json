        "examples": {
          "standard": [
            {
              "text": "コンピュータのCPUは、わずか数平方ミリメートルのシリコンチップ上に数億個のトランジスタが搭載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "電線の断面積を計算すると、およそ二・五平方ミリメートルであることがわかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "顕微鏡で観察したその微生物の大きさは、一平方ミリメートルにも満たない極小サイズだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "短冊形に切った朱｜唐紙の小片の一端から前歯で約数平方ミリメートルぐらいの面積の細片を噛み切り、それを舌の尖端に載っけたのを、右の拇指の爪の上端に近い部分に移し取っておいて、今度はその爪を書物のページの上に押しつけ、ちょうど蚤をつぶすような工合にこの微細な朱唐紙の切片を紙面に貼り付ける。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、角の上の一平方ミリメートルにも足らぬ場所の争奪戦をやっている。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの親類の蝸牛の、あの角の上に一平方ミリメートルにも足らぬ空間があるのじゃが、その所有権を主張して、毎日、毎日、ああやって騒動をしているのじゃ。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
