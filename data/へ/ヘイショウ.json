      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beloved concubine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若しや形のない死神が卿の色香に迷うて、あの骨ばかりの怪物めが、己が嬖妾にしようために、此黒闇に蓄うておくのではないか知らぬ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "察するところ、三十人もの嬖妾が互にアラ捜しをし合っている奥御殿のことであるから、親子は人に後指をさゝれないように、殊更睦じい様子を見せもしたのであろう。",
              "citation": {
                "source": "聞書抄",
                "author": "第二盲目物語",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
