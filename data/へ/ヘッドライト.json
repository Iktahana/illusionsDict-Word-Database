    "definitions": [
      {
        "index": 1,
        "gloss": "headlight (on a vehicle)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
