  {
    "uuid": "c166d937-530c-56f1-a078-9efad5665f4b",
    "entry": "返事",
    "reading": {
      "primary": "へんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
