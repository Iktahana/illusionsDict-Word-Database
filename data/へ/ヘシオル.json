        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これ同居人の鼻をへし折る機会なり。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の枝をへし折る音、四肢をときどき慄はして眠つてゐる犬、腹を干した岸のボート、ぼつりと一つ芝生の上に見えるキャムプ。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒をへし折るようなバリッという音がした。",
              "citation": {
                "source": "孤独",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その愚かな奴らは陸へ上るや否や宝に蹴躓いて向脛をへし折るくらいに思っていたに違いない。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ名乗らねえと、あとで見つけて、素っ首をへし折るぞ。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕁麻でもへし折るがいい。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはどんなふうにやられるつもりか知りませんが」　へし折るように言葉尻をおさめると、高腕を組んで薄陽を流す内港の風景を漠然と眺めやった。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い娘にしては心得たもんだ……頸骨をへし折るように作業するのは、縊死のもっとも完全な方法なんだな。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――肩の骨をへし折るほど強くもんでやるんだよ。",
              "citation": {
                "source": "疵だらけのお秋（四幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年、夜行で京都から帰って来た朝、伸子は二階のはしごの上から下まで滑りおちて、階段下の板をへし折るほどからだをうった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのごろでは仲人に立つ人がその話にかかると、「あ、そのことでしたら私はもう結婚はしませんから」と、ろくに話も聞かずに鼻先をへし折ることさえある。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "前言を取り消さないと、首をへし折るぞ」　エイビスが、謝るようなことをもごもご言うと、ハースコートがまた冷静に続けた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手なごまかしをしたら、お前のよぼよぼの骨をへし折るぞ」　イズリアルスも詰問した。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、諭吉のそのてんぐの鼻をへしおるような、たいへんなことがおこったのです。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
