    "definitions": [
      {
        "index": 1,
        "gloss": "quite unconcerned",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
