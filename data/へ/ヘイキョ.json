[
  {
    "uuid": "4e07a310-10e7-5b43-8f5f-a669b159fd15",
    "entry": "屏居",
    "reading": {
      "primary": "へいきょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
