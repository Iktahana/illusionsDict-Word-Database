        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "香水、クリイム、ピン、水白粉、油、ヘアネット、摺り硝子の扇形の壜、ヘチマ形の壜。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、窩棚の向うの兵営のそのさきに、英吉利人のヘアネット工場ある、私の妹、そこの女工、毎日、ふけとゴミばかり吸う」と、時以礼はつづけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘアネットの髪、田舎の辮髪者の髪、三銭か四銭で切らして、仲買人、公司へ持って来て売る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夏中庭の花壇にこの花を作ったとき、一日試みに二つのうつ向いたつぼみの上方にヘアピン形に折れ曲がった茎を紙撚りのひもでそっと縛っておいた。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、掛け値なしのロングヘアといってよい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "変態性欲とヘアピン　或る米国帰りのドクトルは記者にこんな話をした。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近来、若い婦人は様々の形をしたヘアピンを挿しているが、最近では若い夫人でもよく用いるようになった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに自分は、彼の鬼のような、獣の頭のような、又は異形の鋸のようなヘアピンを見ると、ゾッとするのを禁ずる事が出来ない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、震災後、彼のヘアピンで傷つけられた男を二人程手当をしてやったからである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその傷から私は察して、兇器はヘアピンであると思った。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの式のヘアピンは閨房に於ける婦人の唯一の武器らしい。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のヘアピンの形は、婦人のヒステリー性や、サジスムス性を象徴した形をしている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり詳しく書くと方法を教える事になるから差し控えるが、棒に捲いて銀紙を冠せてチョコレートに見せかけたもの、ヘアピンにナイフで彫り込んだものなぞいう念の入った手紙を、警察に引かれた少年少女が持っていたという。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "▲備考　この傾向は紐育のような大都会になると一層烈しいので、同市の自殺原因の統計の中には、朝牛乳瓶が割れたためとか、ヘアピンをなくしたためとか、又は学校に遅刻したためとかいうような物凄いのが驚くべき多数に上っている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍔広の黒い帽子、よれよれのズボン、白いネクタイに親切そうな笑顔、慈悲深く世話焼きな風貌、いずれをとっても名優ジョン・ヘアに負けず劣らずだ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、村松正俊氏がギリシア語の用で来訪、玄関に入ると鼻を突くヘアトニックの香と春帽の鼠色と靴の様子で、大体の風采の想像がつく。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆撃手は、照準鏡のクロス・ヘアーに、丸の内の中心部が、静かに動いてくるのを待った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして照準望遠鏡のクロスヘアをのぞきながら、連動ハンドルを、ぐるぐるまわすのであった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホントニ、コノ前アナタノ十家ヘアガッタ時ハ、ヒドイ御病気デ、トウ／＼アナタニアフコトガ出来ナクテ、ザンネンデシタ。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大は反物、オムツカバー、メリヤスシャツの類からポマード、オシロイ等の化粧品、シャボン、ブラシ、鋏、ナイフ、ヘアピン等の日用品一切にわたって売り歩く。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと　こんなに　ちいさい　おみせなのに、　ほとんどなんでもが　かえるのです　――　あわてて　ほしくなるようなものは　ないことも　ありますけど　――　たとえば　くつひもとか　ヘアピンとか　マトンチョップとか。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペレス・ヘアといえば、火山学の教科書には、必ず出ているくらい、非常に珍しい標本である。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "網棚へ小道具の入ったスーツ・ケースを載せると、灰銀のフラノのワンピースに緋裏のついた黒のモヘアのストールという、どこかのファッション・モデルのような恰好で車室を流して歩き、知った顔がないかと物色していたが、三つ目の車でロケハンにでも行くらしい楠田という助監督の一行を見つけた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰銀のフラノのワンピースに緋裏のついた黒のモヘアのストール、パンプスの靴とナイロンの靴下が入っていた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディア・サー、ムシュー、ゲーター・ヘア、ツチェヌイー・パネ、と書くことができます。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手は見えなかったが、もう一方は私のヘアブラシの象牙製の背に乗せていた。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカラ座ヘアラン・ドロンノ「太陽ガイッパイ」ヲ見ニ行クノデアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は独りでビスマルク将軍と論争しながら、古畳の上に落ちていた細いヘアーピンを拾いあげ、それがなんであるかも気づかずに土間へ投げやると、仰向けにひっくりかえってしまった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日、先生はまた古畳の上から、いつかと同じヘアーピンを拾いあげ、こんどは不審そうに、つくづくとそれを眺めた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "良さんは腕のいい刷毛作りで、刷毛といってもヘアー・ブラッシなのだが、問屋でも彼の作った物は高級品として扱い、一流化粧品店とか洋品店、百貨店などへ納入していて、けれども仕事がのろく、数があがらないので、「ごうがにえる」と云われた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
