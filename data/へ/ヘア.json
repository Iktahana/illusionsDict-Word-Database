    "definitions": [
      {
        "index": 1,
        "gloss": "hair (on the head)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
