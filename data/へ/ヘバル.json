        "examples": {
          "standard": [
            {
              "text": "夏の炎天下での部活の練習で、開始一時間ですっかりへばってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "引越しの手伝いで重い段ボールを運び続け、もう体がへばって動かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "先輩たちは平気な顔で山を登っていくが、運動不足の私は中腹で完全にへばってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分二階の上り下りでへばる。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑くてへばる（二階が）お盆の買物に出たりしたことなど。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お汝ら、へばるにはまだ早いぞ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
