    "definitions": [
      {
        "index": 1,
        "gloss": "to abate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誇張の気分を少し減らすとおもしろいところもないではないが。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "売ったっていくらにもならないし、こうして減らすんです。",
              "citation": {
                "source": "物を大切にする心",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって品物を減らすと店が貧相になるので、仕入れを少なくするわけにも行かず、巧く捌けないと焦りが出た。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが生命をすり減らすであろうとの懸念は、何処かへ置忘れられた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって品物を減らすと店が貧相になるので、そうも行かず、巧く捌けないと焦りが出た。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのやることといったら、診察室で椅子をすり減らすことだけです。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "『書物の出現』によれば、初期の印刷本はじょじょに行間を広げ、略記法を減らすなどの変化を見せていきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経を擦り減らすこうした作業は、当然編集プロダクションに回ってくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まあ、こんな下駄の減らしやうて、ありませんわ、上手に減らすもんですよ。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は内心、いま／＼しく感じ、　――下駄を減らす男は純情さ。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『雑宝蔵経』八に下女が麦と豆を与り居ると、主人の家の牡羊が毎度盗み食い減らすから主人に疑わるるを憤り、羊を見る度杖で打ち懲らす。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫が、輪切りにした椰子の実でよごれた甲板を単調にごし／＼ごし／＼とこする音が、時というものをゆるゆるすり減らすやすりのように日がな日ねもす聞こえていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ淡島屋の身代は先代が作ったので、椿岳は天下の伊藤八兵衛の幕僚であっても、身代を作るよりは減らす方が上手で、養家の身代を少しも伸ばさなかったから、こういう破目となると自然淡島屋を遠ざかるのが当然であって、維新後は互に往来していても家族的関係は段々と薄らいで来た。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "馳走費をたった七百両に減らすし、わしに慣例の金子さえ持って来ん。",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こちらの話はよく雑誌や新聞に載っているから略するが、こんなのが高じて良心を喪うと詐欺をやり、恐怖心を磨り減らすと恐喝までやる事になる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髮店の店は、其頃兎や角一人前になつたノロ勘が讓られたので、唯一軒しか無い僥倖には、其間が抜けた無駄口に華客を減らす事もなく、かの凸凹の大きな姿見が、今猶人の顏を長く見せたり、扁く見せたりしてゐる。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪店の店は、其頃兎や角一人前になつたノロ勘が譲られたので、唯一軒しか無い僥倖には、其｜間が抜けた無駄口に華客を減らす事もなく、かの凸凹の大きな姿見が、今猶人の顔を長く見せたり、扁く見せたりしてゐる。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前ら自家の財産減らすことより考えやせんのや。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、彼は、日本におれば、日本の食物をそれだけ減らすにちがいなかった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "木堂と湖南４・25（夕）　自党の政党員を減らす事にかけて、一種の天才を持つてゐる犬養木堂も、書物だけはどんどん買ひ殖やす事が好きらしい。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして更にそのような人間としての惨苦を減らすための努力に歩み出さざるを得ない気持に高められ、統一されるものなのである。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ル・キューなどの小説には時折いまだ知られてない恐ろしい黴菌のことなどが書かれてあるが、黴菌のことを知らない読者は本当にして面白く読むが、かかる小説はどうも興味を減らす虞がある。",
              "citation": {
                "source": "科学的研究と探偵小説",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銀は困っているその子守の家族の口を、一人でも減らすのを功徳のように考えていたが、それも長くは続かなかった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、変質者、中毒患者、悪疾な病人等の断種は、実際から見て、この世の悲劇を減らす役に立つと信じる一人である。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは持ち運びのために重量を減らすつもりで、切り倒したその場でやった仕事だが、これがかえって仕事の邪魔になって大変面倒だったのです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "栃の木で老猿を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "人為的な作家の産業別わりあては、或る種のオッチョコチョイな作家が工場から工場へと鉛筆をもって飛びまわるという厄介を減らすかもしれない。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また行手を塞がうとする障碍物が現れて来たのだが、石炭が足りなくて汽車を減らすといふことは、何か人を慄然とさすのだつた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかしても少し減らすように、あなたからおっしゃいって云われたわよ。",
              "citation": {
                "source": "悪魔の弟子",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしか、そうであったと仮定すると、昔は腹を張らせるために使用された球が今では腹をへらすために使われている勘定になる。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "感情の激昂から彼の胸は大波のやうに高低して、喉は笛のやうに鳴るかと思ふ程｜燥き果て、耳を聾返へらすばかりな内部の噪音に阻まれて、子供の声などは一語も聞こえはしなかつた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
