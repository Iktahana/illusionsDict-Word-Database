[
  {
    "uuid": "78c8135b-d372-5927-8dc6-a95141238dd7",
    "entry": "辺鄙",
    "reading": {
      "primary": "へんぴ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
