    "definitions": [
      {
        "index": 1,
        "gloss": "editor (in publishing, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
