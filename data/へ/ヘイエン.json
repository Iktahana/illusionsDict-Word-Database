        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬の間、この植物園はメンテナンスのために一時閉園となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "閉園時間が近づき、蛍の光のメロディが園内に流れ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "赤字続きだった老舗の遊園地が、ついに来月末で閉園することが決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし閉園時間の午後五時になっても帰って参りません。",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉園近い時刻になっても園長は帰って来られません。",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その象牙のような形をした塔の奥には、閉園と再開を繰り返すラクテンチも見えた。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
