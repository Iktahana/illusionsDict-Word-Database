    "definitions": [
      {
        "index": 1,
        "gloss": "sponge gourd (Luffa aegyptiaca)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかもお提灯より見っこのねえ闇夜だろうじゃねえか、風俗も糸瓜もあるもんか。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯殿の西の窓の細い障子が少し開けてあって、廂へ搦んだ糸瓜の黄な花と青黒い葉と蔓との間から真赤な夕焼雲の端と、鼠色の暮空とが透いて見える。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛生も糸瓜もあったものではないが、こんな蛮勇には病魔の方から御免を蒙るのだから、途中腹を下すような弱虫は一人もなく、牛の歩みも一歩一歩黒羽町に近づき、この前途もう半里ばかりという処まで来かかると、ここにも飴ン棒など並べて一軒茶屋。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "金時は頭を掉り、「なに鬼や土蜘蛛なら、糸瓜とも思わねえ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、婆々どのの言うことに――やや親仁どのや、ぬしは信濃国東筑摩郡松本中での長尻ぞい……というて奥方、農産会に出た糸瓜ではござらぬぞ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥方、農産会に出た、大糸瓜の事ではない、はッはッはッ。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャカジャカと引鳴らせ、糸瓜の皮で掻廻すだ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は固く拒みて、「思し召しはありがとうございますが、規定の賃銭のほかに骨折り賃を戴く理由がございません」　世話人は推し返されたる紙包みを持て扱いつつ、「理由も糸瓜もあるものかな。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸瓜も大きいのが七、八本ぶら下って、そのなかには二尺を越えたのもあった。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸瓜を植ゑる、五本生えたが三本は虫に喰はれた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "……・あんなが来てくれる大根もふとうなつてゐる（緑平老に）・腹がいたいみんみん蝉・夕焼しづかな糸瓜に棚をこしらへる・死にそこなつた、こうろぎがもうないてゐる　七月五日徹夜読書、腹が空つたので、大山さん持参のうどんを茹でゝ食べる、やさしくてうまかつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "・朝風の青草食みつつ馬は尾をふる・日影ゆるゝは藪ふかく人のゐて・炎天の機械がうごく人がうごく（アスフアルトプラント）　　　　□　ひらいてゆれてゐる鬼百合のほこり・朝からはだかで雑草の花　糸瓜さいて垣からのぞく　殺された蚊でぞんぶんに血を吸うた蚊で・風が吹きとほすまへもうしろも青葉　七月廿日　土用入。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸瓜がちいさくぶらりとさがつてきた。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "山家に高くかゝげてある出征の日の丸、ぶらりと糸瓜。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "三風居・街のひゞきも見おろして母子の水入らずで　　　淡々居・松に糸瓜も、生れてくる子を待つてをられる　　　阿弥坊居・カンナもをはりの、秋がきてゐる花一つ　十月二日　十一月一日行乞のつかれと酒の酔とでぐつすり寝た。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規は死ぬ時に糸瓜の句を咏んで死んだ男である。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから世人は子規の忌日を糸瓜忌と称え、子規自身の事を糸瓜仏となづけて居る。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が十余年前子規と共に俳句を作った時に　　長けれど何の糸瓜とさがりけりという句をふらふらと得た事がある。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸瓜に縁があるから「猫」と共に併せて地下に捧げる。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく瓜と云う字のつく所を以て見ると南瓜も糸瓜も親類の間柄だろう。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "親類付合のある南瓜の句を糸瓜仏に奉納するのに別段の不思議もない筈だ。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "理屈も糸瓜も有ったものでは無かった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぎといふものは、みんな天の川の砂が凝って、ぼおっとできるもんですからね、そして始終川へ帰りますからね、川原で待ってゐて、鷺がみんな、脚をかういふ風にして下りてくるとこを、そいつが地べたへつくかつかないうちに、ぴたっと押へちまふんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天下の名勝」もへちまもあったものじゃない。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そういう気持になるかと思うと、ええい、恋のへちまのと、上品ぶったまだるッこいことは面倒だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、恋のへちまのと、べちゃくちゃ喋るのが面倒だった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川原で待つてゐて、鷺がみんな、脚をかういふ風にして降りてくるとこを、そいつが地べたへつくかつかないうちに、ぴたつと押へちまふんです。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうがおの種も播き、へちまの棚も作った。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百円よりも、支那料理よりも、私には、あなたが、この家のお庭に、へちまの棚を作って下さったほうが、どんなに嬉しいかわかりません。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八畳間の縁側には、あんなに西日が強く当るのですから、へちまの棚をお作りになると、きっと工合がいいと思います。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
