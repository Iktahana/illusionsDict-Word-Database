        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "病院にいると、親が養われへんそうや。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "場内騒然）〈司会〉会場が大へんそうぞうしゅうございまして、お話がききたい方の耳に届かないと思います。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつ、きっと、二十めんそうがへんそうしているんだよ。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにいた六人のけいじと、小林くんと少年たんていだんいん六人がまもっていたのですが、それが、みんな、二十めんそうの子分のへんそうしたにせものだったのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "このかいじんは、へんそうのだいめいじんで、四十もちがったかおをもっているというので、四十めんそうとあだ名されていたのです。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、二十めんそうが、どんなものにでも化けられる、へんそうの名人だったことを思い出したのです。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、表門やうら門の外までしらべましたが、木村さんにへんそうした二十めんそうのすがたは、どこにも見えません。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは、へんそうの名人だ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "13マンホール　二十めんそうは、大きなとらにへんそうして、木村さんの家のそばにある、こうしゅう電話の中ににげこみました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは、さっき、木村さんのおし入れの中にかくれたとき、そこに用意しておいたふくや白いつけひげで、ろうじんにへんそうしたんだ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろうじんにへんそうした二十めんそうは、そのへやへ上がっていきました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、みんなに追っかけられたので、いろんなへんそうをして、うまくにげてきたのだ。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも、へんそうしているんだからね。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
