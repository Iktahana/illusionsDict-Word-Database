        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "こんな難しいパズルも、彼にかかれば平ちゃらで解いてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重い荷物を持って階段を登るのも、体力のある若者には平ちゃらだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毎日10キロ走るなんて、私には無理だけど、彼なら平ちゃらだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
