  {
    "uuid": "cceb8679-487e-5eee-a70c-d2b87d401eae",
    "entry": "弊社",
    "reading": {
      "primary": "へいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
