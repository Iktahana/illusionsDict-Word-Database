[
  {
    "uuid": "cb510a6b-59af-5f69-bd0d-a184472016e5",
    "entry": "偏重",
    "reading": {
      "primary": "へんちょう",
      "alternatives": [
        "へんじゅう"
      ],
      "is_heteronym": false
    },
    "grammar": {
