        "examples": {
          "standard": [
            {
              "text": "「へぶし！」と大きなくしゃみをした後、おじいちゃんは恥ずかしそうに鼻をすすった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "埃っぽい屋根裏部屋を掃除していたら、急に鼻がムズムズして「へぶしっ」と派手なくしゃみが出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「へぶし！あーあ、誰か私の噂でもしてるのかな」と、彼女はティッシュを探しながら冗談めかして言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "たまたまに、灯さす格子はあれど柩うつ槌の音ただにせはしく、煉瓦つむ空地には、あはれ誰が子ぞ、心中の数へぶし拙なげながら音もうるむ連弾のかなしきしらべ、いつになく旅人の足をとどめて、灯は青く柳立つ闇にともりき。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
