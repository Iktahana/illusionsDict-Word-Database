[
  {
    "uuid": "1e07405c-d9fb-5130-b9b1-ca0c0fc40397",
    "entry": "変種",
    "reading": {
      "primary": "へんしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
