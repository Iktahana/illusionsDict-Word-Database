        "examples": {
          "standard": [
            {
              "text": "彼は地面に平つくばって、許しを乞うように頭を下げ続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い写真には、殿様の前で平つくばる農民たちの姿が写っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あまりの恐ろしさに、彼はその場に平つくばって一歩も動けなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "はてな……」　と大総督は、椅子の蔭に平つくばる密偵司令官ハヤブサと、おどろきの眼と眼とを見合せた。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちみんなが、金持も貧乏人も一様にありがたがって、へいつくばる物なんか皆、ぼくにとっちゃこれっぽっちの権威もない。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            }
          ]
        }
