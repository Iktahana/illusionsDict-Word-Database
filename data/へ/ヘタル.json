    "definitions": [
      {
        "index": 1,
        "gloss": "to fall on one's backside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
