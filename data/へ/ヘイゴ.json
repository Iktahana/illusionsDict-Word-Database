    "definitions": [
      {
        "index": 1,
        "gloss": "everyday language",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "匂があり色ある言葉、節約し廻転さし弛緩さし圧重し昂騰せしむるリズム、それらは座談の平語とは異ふ。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし芭蕉の個人力は、貴族歌人嘲笑のもとにあつたこの俗談平語の俳諧を、悲壯なる氣魄と全身全靈をかけての苦鬪によつて、遂に最高至上の藝術とし、哲學としたのである。",
              "citation": {
                "source": "一人の芭蕉の問題",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あるや」は児童の平語でないだけに、自然には生まれなかったもののように思われる。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが一般の概念だと、その史嶺は源語や平語の時代よりもなにかはるか遠くにかすんで見えるのであるらしい。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「盛衰記」「平語」など諸書一致しているが、このへんには複雑な敗因がべつにあることはいうまでもない。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "義仲が、前関白基房の姫を取って、聟に押し成ったという、盛衰記や平語の記事には、否定説がつよい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな詮索などはしないで、原話のままの方が、勇ましいことは勇ましいにちがいないが、この小説は、平語のように、琵琶へのせて語るものではないから、現代の読者には、なんとも古典のままではお目にかけられない。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トゥロットは、それをそつと、へいごしにおとなりのお庭の中へなげこまうとおもつて、手をうしろへふり上げました。",
              "citation": {
                "source": "かたつむり",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、へいご蜂をな！",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を殺した覚えはないか」「へいございます。",
              "citation": {
                "source": "少年",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
