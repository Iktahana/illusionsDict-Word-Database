    "definitions": [
      {
        "index": 1,
        "gloss": "military term",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明治時代の翻訳家たちは、西洋の近代的な軍隊のシステムを導入する際、適切な日本語の兵語をゼロから作り出すのに苦労した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖父が遺した古い日記には、当時の陸軍で使われていた難解な兵語が頻繁に登場しており、現代の若者には意味を汲み取るのが難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ミリタリー系のFPSゲームを海外のプレイヤーとボイスチャットで遊んでいるうちに、英語の専門的な兵語をすっかり覚えてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一方政府側が、「北支の明朗」という軍隊用語から思いついて、政情の明朗という声明を出すと、他方政友会側は「南京政府の擬装」という兵語から借りて来て、擬装挙国一致と来る。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "トゥロットは、それをそつと、へいごしにおとなりのお庭の中へなげこまうとおもつて、手をうしろへふり上げました。",
              "citation": {
                "source": "かたつむり",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、へいご蜂をな！",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を殺した覚えはないか」「へいございます。",
              "citation": {
                "source": "少年",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
