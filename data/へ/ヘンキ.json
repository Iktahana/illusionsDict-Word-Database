    },
    "definitions": [
      {
        "index": 1,
        "gloss": "eccentricity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は實にその偏奇な高潔さが好きだ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のように偏奇な風流餓鬼の相手になって自分から健康な愛情の芽を二度と吹かして呉れようとする無垢な少女。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その影響で、ぼくは別荘の坊ちゃんとしての我儘なしたいほうだいを止めて、執偏奇的な宗教家、神秘家になりました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは偏奇な、又は虚構的な文学の使用を忌む。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "身は偏奇館、あるいは葷斎堂に住して、病を愛撫し、「身を落す」自傷を愛撫し、しかしそれらを愛撫するわが芸術家魂というものをひたすらに愛撫する荷風は、ある意味では人生に対する最もエゴイスティックな趣味家ではあるまいか。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア作家が狭い「私」的環境に止められて、僅かな感情冒険だの偏奇の誇張などにエネルギーをついやしている時、少くとも現在民主的作家は、政治的活動の分野を解放されているし、経営内の文化活動に直接ふれることができるし、労働者・農民の闘いに観察者であるばかりでなく、協力者となり得ます。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはソヴェトの五ヵ年計画と――刻々に前進する社会主義の社会の現実とメイエルホリドが独特性としている芸術理解の特色＝極端な様式化と構成派風な偏奇さ、誇張、一種の病的さなどが労働と互にどういう関係において発展してゆくかという問題だ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏奇な趣味の対象としては、蜘蛛は余りに多くのものを持っていると、蜘蛛好きな私は勝手な考え方をしたいのである。",
              "citation": {
                "source": "蜘蛛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、中世楽器や福音書写本、それに古代時計に関する彼の偏奇な趣味が端緒となったものであるが、その――恐らく外部からは手を尽し得る限りと思われる集成には、検事が思わず嘆声を発し、唖然となったのも無理ではなかった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもならそれを背にして、彼の最も偏奇な趣味である古今東西の大火史を、滔々と弁じ立てるのだが、その日は法水が草稿を手に扉を開くと、内部は三十人ほどの記者達で、身動きも出来ぬほどの雑沓だった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その想像力はやや偏奇的で、過剰の気味を呈し、そこから人のしないことをしようといふ天邪鬼的性向と、誰にも出来ないことをしようといふ冒険的精神と、更に、人の思ひつかない推断を敢てする妄想症が発生し、そして常に物の裏書に意をくばる皮肉な習癖が附き纏ふ。",
              "citation": {
                "source": "紀州人",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "手軽な、ときには封建的であり、偏奇的である人間らしささえみとめるのは。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が麻布の偏奇館を訪ねるのはたいてい一緒で、都合で白井が先に行くやうな時は電話で時間を打合せて私が後から伺ひ、三人揃つてお宅を出、道源寺坂を下り、今井町の通りから市電に乘つた。",
              "citation": {
                "source": "來訪者のモデル",
                "author": "木場貞",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、僞物をさげて偏奇館へ箱書きをたのみに行つたのが、誰あらう筆者である白井自身なのだから振つてゐる。",
              "citation": {
                "source": "來訪者のモデル",
                "author": "木場貞",
                "note": "青空文庫"
              }
            },
            {
              "text": "名づけて偏奇館といふ。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏奇館西南に向ひたる崖上に立ちたれば、秋になりて夕陽甚しかるべきを慮り、夕顔棚を架せむと思ふなり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏奇館の窗に倚りて対面の崖を眺むるに、新樹の間に紫陽花の蒼白く咲き出でたる、又枇杷の実の黄色に熟したるさま、田家の庭を見るが如し。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈下偏奇館漫録を草して新小説に寄す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹田屋の主人写真機を携来りて偏奇館書斎を撮影す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜偏奇館漫録を草す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏奇館漫録を春陽堂に送る。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏奇館斜陽甚しければ、この日園丁に命じて窗前にプラタン樹両三株を植ゆ。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏奇館漫録の草稾を春陽堂に郵送す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏奇館漫録第三を春陽堂に郵送す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏奇館漫録を春陽堂に郵送す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "戯に偏奇館画譜を描く。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十年｜乙亥秋八月於偏奇館、荷風散人｜識",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "因って偏奇館と名づく。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "偏奇館甚独居に便なり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大へんききめがあった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
