        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五トンぐらいのものがらくにもちあがるヘリコプター（竹とんぼ式飛行機）を一台至急ここまでまわしてくれるように、航空商会の千代田支店に頼んだ。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十分ほどすると、空から一台のヘリコプターがゆうゆうと下りて来た。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "着陸したヘリコプターの貨物庫の中に、金属球を入れた。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターは間もなく離陸して、東京へ向った。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターをチャーターして一気に山頂に到達するよりも、システムを組む過程で理解と発見を積み重ねていった方が、よほど楽しいのではないかとの思いは禁じえなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "水をひくこと、太陽熱を利用すること、電気栽培のこと、通信機を備えつけること、運搬用の自動車やヘリコプターを備えつけることなど、これを一つ一つ説明していったら、たいへんな紙数がいるので、ここにはくわしくのべないことにする。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷博士は、機械人間の操縦装置が破壊された時、屋上からヘリコプターによる脱出を考えたのである。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターだった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターは、宙に浮いたように前進を停止し、上下に自由に上ったり、下ったりできる飛行機である。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようなヘリコプターが、夕闇がうすくかかって来た空から、とつぜんまい下りて来たので、春木少年はおどろいた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターが、なに用あってまい下りてくるのであろう。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸倉老人が、恐怖していたのは、そのヘリコプターであろうか。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターは、垂直に下ってきた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターが探照灯を、地上へ向けて照らしつけたのだ。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は、なんとはなしに危険を感じ、しずかに身体を右の方へ動かして、ヘリコプターの探照灯からのがれようとした。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターから、とつぜん、だだだだッ、だだだだッと、はげしい機関銃が鳴りだした。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときヘリコプターは、戸倉老人のま上まできた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると、作業衣の男は立上って、手をふって、上のヘリコプターへ、合図のようなことをした。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターの胴の窓からも、一人の男が上半身を出して、下へ手をふって合図した。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが合図のように、ロープはぐんぐんヘリコプターの方へ巻きあがっていった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターは、宙に浮いて、じっとしている。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「柿の木の上で、目はみえず」　ヘリコプターの音が遠のいていったのが分ったとき、牛丸は、ひとりごとをいった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターで救助作業をやったのかもしれないが、しかしその前に、はげしい銃声のようなものを聞いた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、重傷の戸倉老人を拾っていった、ヘリコプターに乗っていた者は、何者であったろうか。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、あのヘリコプターは、戸倉老人のためには敵手にあたる連中が乗っていたものであろうか。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "六天山塞　さて、戸倉老人をさらっていったヘリコプターはどこへ飛び去ったか。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターは、暮色に包まれた山々の上すれすれに、あるときは北へ、あるときは東へ、またあるときは西へと、奇妙な針路をとって、だんだんと、奥山へはいりこんだ。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "約一時間飛んでからそのヘリコプターは、闇の中をしずしずと下降し、やがて、ぴったりと着陸した。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
