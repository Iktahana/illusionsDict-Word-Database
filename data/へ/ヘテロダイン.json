        "examples": {
          "standard": [
            {
              "text": "ラジオの受信機では、アンテナで捉えた高周波信号をスーパーヘテロダイン方式で中間周波数に変換している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "レーザー干渉計において、ヘテロダイン検波を用いることで微小な変位を高精度に測定できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古いアマチュア無線の機材を開けて、ヘテロダイン回路を構成する真空管を丁寧に掃除した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "予モ亦ラジオヲ以テ長年ノ趣味トスルモノニシテ、予ガ組立テタル愛機『スーパーヘテロダイン』ヲ携エテ今回｜此途ニノボレリ。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴局ノ送受信機ハ何処ヨリ手ニ入レタルヤ」相手「予ガ携帯シ来リタルスーパーヘテロダインハ没収セラレタリ。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
