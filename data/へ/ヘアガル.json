    "definitions": [
      {
        "index": 1,
        "gloss": "to rise",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それですから、あなたとわたくしとが押掛けて行けば、こつちで何にも云はなくつても先方は脛に疵で顫へあがるんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　阿見がケージをたゞ一人で占領して上へあがると、びっこの爺さんが笑い出した。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の見へあがると、この界隈を覆っているのは暗い甍であった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまやの角をすぎて、お花畑から、麦畑へあがる草の土手の上で、虫をふせました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし基音からすぐに長三度へあがるのと短三度へ上がるのとではそれこそ全く春と秋とちがうほどの差違を感ずるであろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくのいいなずけは、寝室へあがる、小さい裏ばしごを知ってるのさ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二疋以上の動物が長いあひだ向ひ合つて居るのを見るときに、私は奇怪な恐怖からまつ青になつてふるへあがる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまやの角をすぎて、お花畑から、麦畑へあがる、草の土堤の上で、虫をふせました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその陋屋に立派な物は、表の格子戸と二階の物置へあがる大｜階子とであった。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小八は座敷へあがるなり婢が来て湯に入れと云うので、云うなりに湯殿へ往って湯に入り、濡れた手拭で顔を拭き拭き己の室へ帰るとすぐ主翁が来た。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、上へあがるが好い」と、主人は己で上へあがりながら、伴れて来た二人にも、「さあ、あがってくれ」と云いました。",
              "citation": {
                "source": "死人の手",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰐も陸へあがることがある。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日のやうにとほつた谷町から箪笥町の通りや、箪笥町と今井町との間の市兵衞町へあがるだら／＼坂や、我善坊の細い通りも、何だか物珍らしい。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "或朝、そこから直ぐ學校へ出勤して、二階の教員室へあがると、義雄に最も多く同情を持つて呉れてゐる專任教諭が、「田村君、ちよツと」と、渠をさし招いて、そとの廊下に出た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "三左衛門が上へあがると皆が前へ集まって来た。",
              "citation": {
                "source": "竈の中の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関へあがると昨夜の肖像があるだらうかと思つて眼をやつた。",
              "citation": {
                "source": "あかんぼの首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青い服の右側には、其所の二階へあがる石のやうな白い階段が見えてゐた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいつつもあればだ、ほぼ疑いなく、その人物は火のついた獣脂を始終取り扱っている――夜中、上の階へあがるとき、片手に帽子、もう一方の手に揺らめく蝋燭。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、みんなそろって広間へあがると、かわいいお小姓たちが、くだもののお砂糖漬だの、くるみのこしょう入りのお菓子だのをだしました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "糟谷が芳輔を抱いて奥へあがるとざる碁仲間の老人がすわりこんでいる。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端で水を汲んでいるうちに、手桶をさげたまますべって転んで、これも膝っ小僧を擦り剥いたと云って跛足を引いているもんですから、わたしが代りに二階へあがると又この始末です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "きたないところですが、どうぞこちらへ……」「じゃあ、ちっと邪魔をするぜ」　若い岡っ引が草履をぬいで内へあがると、文字春は小女に耳打ちをして、近所の仕出し屋へ走らせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃあ都合がいい」　案内されて二階へあがると、小さい机の上には位牌が飾られて、線香のうすい煙りのなかに燈明の灯がまたたきもせずに小さくともっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は一と風呂あたたまるとすぐに揚がって来て、着物を肌に引っ掛けたままで二階へあがると、熊蔵もあとからそっと付いて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒だがその伊勢屋とかいう質屋へ行って、金のほかに何を奪られたか、よく訊いて来てくれ」　こう云い置いて二階へあがると、火鉢の前にお吉がぼんやり坐っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のあいだは二階へあがる客もないので、半七は煙草をのみながら唯ひとりつくねんと坐っていると、春の寒さが襟にぞくぞくと沁みて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤へあがると、うすら寒い風はいつしか凪いで、紫がかった箕輪田圃の空に小さい凧の影が二つ三つかかっていた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「内へあがると長くなる。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
