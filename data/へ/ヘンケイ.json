[
  {
    "uuid": "c111b5c2-789b-5d74-a951-67b9ef20aa5a",
    "entry": "変形",
    "reading": {
      "primary": "へんけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
