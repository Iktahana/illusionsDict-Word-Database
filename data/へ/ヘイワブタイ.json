        "examples": {
          "standard": [
            {
              "text": "彼は大学卒業後、平和部隊の一員として中央アジアの農村で教育支援に従事した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "平和部隊のボランティアたちは、現地の言葉を学び、住民の生活に深く溶け込んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "灌漑施設の整備を指導するのが、今回派遣された平和部隊チームの主な任務だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ニューフロンティアという架空の国（現実には、アメリカがドルで支配することを考えている海外の諸国）では平和部隊のような費用のかからないことしかできず、国内には軍事費の半分以下の予算しかふりむけることができなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
