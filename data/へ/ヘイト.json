        "examples": {
          "standard": [
            {
              "text": "SNS上で無関係な他人にヘイトをぶつける行為は、決して許されるべきではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は理由のないヘイトに晒され、精神的に大きなダメージを受けてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ネットニュースのコメント欄には、しばしば特定の個人に対するヘイトが溢れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "猿ニ似テ非ナル猿面冠者ハオノガ立身出世ノタメニハ、主人ヨリ猿々ト呼ビ捨テラレルモ、ヘイヘイト追従笑ヒナド泛ベタルハ、即チ羞恥ヲ知ラザル者ト言フガ如シ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
