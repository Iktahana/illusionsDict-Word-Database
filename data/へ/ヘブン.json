        "examples": {
          "standard": [
            {
              "text": "高級スパでの2時間のアロママッサージは、あまりの心地よさにまるでヘブンにいるかのような気分だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ロックフェスの最前列で大好きなバンドの生演奏を浴びて、「ここはヘブンだ！」と友人と顔を見合わせて叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "仕事の締め切りをすべて終えて、冷えたビールを飲みながらソファに寝転がるこの瞬間こそが私にとってのヘブンだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "幾度聞いてもだめだ、すぐに忘れる」「ヘーヤーヘブン」と母はたちどころに言った。",
              "citation": {
                "source": "地球儀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ヘーヤーヘブン。",
              "citation": {
                "source": "地球儀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私の父が前の年にアメリカ・フエーヤーヘブンの或る田舎の中学を卒業した時の記念品だつた。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスのジエップ駅とイギリスのニューヘブン駅との間の海峡は、汽船をもって連続す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヘブンにて税関の検閲を経てさらに乗車し、七時後、ロンドン・ビクトリア駅に着す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
