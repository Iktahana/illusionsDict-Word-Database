          "literary": [
            {
              "text": "ヘッドランプの光を頼りに一坪テラスまで行くことにした。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘッドランプの光でハーケンをさがす。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前部にはカウ・キャッチャーが装備してあり、煙突の前、ボイラーの突端には、ランタンのようなヘッドランプが乗っていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もうひとり帰ってくる、と言っただけさ」　小川が言いおえるかおえないうちに、むこうの闇のなかに、ヘッドランプがひとつ、見えた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
