        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "嵐が去った後の夕暮れ時、空には美しい碧雲がたなびき、神々しい景色を見せていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山頂の寺院から見下ろすと、谷底に広がる碧雲がまるで波打つ海のように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その淡い碧雲の隙間から、夕闇に染まる三日月がひっそりと顔を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "碧雲寺を背景にして支那服を着て立っている写真。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧には蕪村または夜半亭の雅名を用うれど、画には寅、春星、長庚、三菓、宰鳥、碧雲洞、紫狐庵等種々の異名ありきとぞ。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧には蕪村または夜半亭の雅名を用うれど、画には寅、春星、長庚、三菓、宰鳥、碧雲洞、紫狐庵等種々の名異名ありきとぞ。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雪峰巍立碧雲間、鎮圧閻浮幾万関、鶴林一夜煙散後、空留唯我独尊山。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
