        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "パスポートの申請書に記入する氏名のローマ字は、必ずヘボン式で書かなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "小学校で習ったローマ字は訓令式だったが、駅の看板などはヘボン式で表記されていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「し」を「shi」、「つ」を「tsu」と綴るのがヘボン式の大きな特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ローマ字問題雑感」はヘボン式に対する日本式ローマ字論の優越を証言したもので、一寸才気に充ちたものだ。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘボン式によるか訓令式によるかが一例だ。",
              "citation": {
                "source": "素人圖書館人の手記",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "米國の圖書館協會の部會で日本圖書についてヘボン式による旨を決定した。",
              "citation": {
                "source": "素人圖書館人の手記",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
