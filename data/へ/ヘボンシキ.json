    "definitions": [
      {
        "index": 1,
        "gloss": "Hepburn system (of romanizing Japanese)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
