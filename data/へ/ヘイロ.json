[
  {
    "uuid": "f8bc1c2a-92f5-56db-b07b-a15efa47b16a",
    "entry": "閉路",
    "reading": {
      "primary": "へいろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
