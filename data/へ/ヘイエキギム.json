          "standard": [
            {
              "text": "男子のみに兵役義務を課す現行法は不当だとして、訴訟が起こされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "建国以来、この国では国民の兵役義務が安全保障の要とされてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「兵役義務を果たすことは国民の誇りだ」と教育の場で強調された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "兵役義務ノ爲メニ不具廢疾トナレル者ノ國家扶養ノ義務ハ別ニ法律ヲ以テ其ノ扶養ヲ完ウスベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二年」は当時の兵役義務年限。",
              "citation": {
