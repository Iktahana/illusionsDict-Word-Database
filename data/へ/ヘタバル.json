    "definitions": [
      {
        "index": 1,
        "gloss": "to be exhausted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三人は、へたばるように、くた／＼と地べたに膝をついた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へたばるまで歩いて下宿へ歸り、歸つてからはこの思想共を一匹宛出して來て一匹宛演舌させてやらう。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "へたばるまで歩け」　私は残酷な調子で自分を鞭打った。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が描くから……とも子　またうなりを立てて、床の上にへたばるんじゃなくって。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの嘴で丹念に、這奴我が胸、我が腹の毛を殘りなく※り取つて、赤裸にした處を、いきみをくれて、ぬぺらと出して、葉隱れに……へたばる人間をぎろりと睨んで、噴飯す由。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩に躓ずき、葛に引っからまり、山中をかけずり回り、身体綿のごとくなってへたばる。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」力に任して突飛ばせば、婆々へたばる、三吉｜遁る、出合頭に一人の美人、（木賃宿のあの人の）宵月の影｜鮮麗なり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "練習を張り切ってやれぁ、だめな奴はへたばるし、いいやつは残るだろうしさ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、九月、十月、十一月の十五日まで、御坂の茶屋の二階で、少しづつ、少しづつ、仕事をすすめ、あまり好かないこの「富士三景の一つ」と、へたばるほど対談した。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮里さんが、きいてみると、ロボット先生は一日喋りつづけたので、すっかりへたばってしまったのだそうで、無限精力のはずのロボットが、へたばるなんて、面白いなと大笑いをしたことであった。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もうお前、へたばるが。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あの人は、あのくらいの傷で、へたばるようなことはないよ」　と云った。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、交互に襲ひ来る希望と絶望との前にへたばるやうな気持であつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れをしてゐないといふ事が、君の真実なら、それを頼りに、逢ひに行くと書いて下すつた、貴方のお手紙にすがつて、私、やつと生きてゐたのよ……」　ゆき子は、そこへへたばるやうに坐つて、富岡に云つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥へ逃げこむ者、その場にへたばる者、わめきちらす者のある中を、一郎は、自分の家の庭に生えている大きい欅の樹を見当にして、まっしぐらに走りだした。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンと投げたは袋様の物で、ベッタリ地上へへたばると、何んと生あるもののように、ムクムクと背中を持ち上げたではないか。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し仕事に負けて途中でへたばるようなら、それはそれで仕方がありません。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "散々に殴り、血にまみれ、喘ぎながら小左衛門の牛小屋に辿りつくと、へたばるやうにもぐりこんで藁をかぶつて寝てしまつた。",
              "citation": {
                "source": "わが血を追ふ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、もう舷側をこえる元気さえなくなって、甲板上にへたばるものさえ出てきた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "筵の向こうへ犬を抛り込み、「範覚殿、贄あげました」　云いすてると、その男は引っかえして来て、そこに寝ていた娘の横へ、へたばるように坐り込んだ。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……儂あ、へたばるまで、この道てくってこの月眺めるだよ。",
              "citation": {
                "source": "蕎麦の花の頃",
                "author": "李孝石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと頂上まで登れないで必ず途中でへたばるということです。",
              "citation": {
                "source": "木曾御岳の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから、若松屋と磯屋はかたき同士、ひとつ小判で張り合って、どっちが立つかへたばるか、智恵くらべをしようと、な」「はい。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "根がこう言った残酷な労働をするように生れ落ち、慣らされて来た、鉄のような血統を受けているのですから、大抵の労働には、へたばることなく、したがって苦痛は増すばかりでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彦一　二人で東海道を歩いて上つて来る途中、ロクに飯が食えねえもんだから、俺がへたばる――ミル　まあ、東海道を歩いて？",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなことをしたって、誰がへたばるものか。",
              "citation": {
                "source": "なぐり合い",
                "author": "WIE JAPPE UND DO ESCOBAR SICH PRUGELTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ああ、意気地無し、もうへたばるのか』と代議士は嘲笑した。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女は、こうして行けばひとりでに白山へも登れるし、金沢へも出られると心得ているらしいが、さて、明日からの旅の実際の味を嘗めさせられてみると、へたばるのはわかりきっている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あいてのダッタン人はおそろしく力の強い男で、めったにへたばるようなやつじゃない。",
              "citation": {
                "source": "百姓マレイ",
                "author": "フョードル・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、そういう方面のことはよくわからぬが」　博士は淡々としてごく無造作に話しているのであったが、聞いている一同は今度ばかりはへたばることも忘れて博士の顔を瞶めていた。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
