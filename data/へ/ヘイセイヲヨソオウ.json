        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十八の豹一をつかまえて、洗いざらい恥さらししなければならぬ自分を安二郎はさすがに情なく思い、つとめて平静を装うのだったが、既に豹一は安二郎の苦悩が隅々まで読みとれる男になっていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなら「市販のモデルに肩を並べる世界初のミニコンピューターキット」という『ポピュラーエレクトロニクス』の謳い文句が、本物になってしまうとはしゃぎ回るロバーツのかたわらで、アレンは興奮を抑え平静を装うのに苦労した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し表面は飽くまでも平静を装うていた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人ともつとめて平静を装うてはいるが、ひどい昂奮と緊張が明らかに見られる。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
