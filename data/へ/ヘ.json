  {
    "uuid": "d0bd11ad-e5a5-515e-8192-0ad2143be28f",
    "entry": "ヘ",
    "reading": {
      "primary": "ヘ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "6th (in a sequence denoted by the iroha system)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "筆者がかつて評論した、有名なヘルンのエッセイ『ある女の日記』も、校本に拠るところがあるとは言いながら、実はその愛妻節子夫人を、半面のモデルにしたものと言われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくヘルンはその時初めて心の隅に、幸福という物の侘しい実体を見たのであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラフカジオ・ヘルンの場合も、またその同じ例にもれなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めからボヘミアンであったヘルンは、晩年においてもなおボヘミアンであり、永遠に故郷を持たない浦島だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に老いの近づいたヘルンは、自分の死後における妻子の地位を考えた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが日本人の抒情的な言葉で、あきらめと呼ばれるものであることさえ、おそらくヘルンは知ったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京｜帝国大学の招聘に応じて、松江や熊本の地を去ったことも、同じくヘルンの身にとっては、愛する妻への献身的な犠牲だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆あなたのためです』と、さすがにヘルンも夫人に愚痴をこぼしている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人もよくその良人の心を知り、『ヘルンの一生は、皆私や子供のために尽してくれた犠牲でした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚十数年、ヘルン既に五十｜歳を過ぎ、二人の男児と一人の女児の親となってる晩年の手紙である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻を愛称して『小サイ可愛イママサマ』と呼んでるヘルンは、同時にいかにまた子煩悩であったかが解る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンはその妻と共に、姑の老婦人と一家に同居し、純日本風の仕方でよく孝養の道を尽した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの文学に出る日本婦人のモデルは、多くその妻に非ずば姑の老婦人だといわれてるが、すくなくともヘルンは、この点での好運にめぐまれていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故ある人々は、ヘルンがもし悪妻をめとり、意地悪の姑等と同居したら、彼の神国日本観は、おそらく顛倒した結果になったろうと言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの生活様式は、全く純日本風であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたヘルンの生活は、極めて質素のものであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日二三合の米の飯と、少しばかりの副食物と、二三合の日本酒とさえあれば、それで私の生活は充分であると、その訪問客に語っているヘルンは、実際に学者風の簡易生活をしていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎に仕事をしている時のヘルンは、周囲のちょっとした物音にも、すぐ『私の考え破れました』といって、腹立しくペンを投げた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンは常に散歩を好み、学校の帰途などには、まだ知らない町の隅々を徘徊したが、新しい興味の対象を見出すごとに、必ず妻を連れてそこへ再度案内した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた一所に行きます』と言って、ヘルンが妻を連れ出す所はたいてい多くは寂しい静閑の所であり、寺院の墓地や、邸の空庭や、小高い見晴らしの丘などであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある時、ヘルンが案内して連れ出した所は、暗い闇夜の野道の中に、小高い丘があるばかりで、周囲は一面の稲田であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の見る物もなく風情もないので、夫人が怪しんで質問したところ、ヘルンは耳を指して、『お聴きなさい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "松江から東京に移るまで、ヘルン夫妻は、自分の家を持たなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局それは、夫人の強硬な反対によって中止されたが、後でそれが有名な化物屋敷と解った時、夫人がほッと胸を撫でおろしたとは反対に、ヘルンは大変失望して、『ですからなぜ、あの家住みませんでしたか。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンについての一不思議は、あれほど広く多方面の文献に亘って、日本人以上に日本のことを知っていながら、日本語をほとんど知らなかったということである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたヘルンの日本語は、ヘルンの家族以外の人々には、容易に意味がわからなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
