    "definitions": [
      {
        "index": 1,
        "gloss": "return of something",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いずれ、貴兄に機会があればお詫びするとして取敢えず原稿を御返却いたします。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其｜袂を捉へて『餘りじやアありませんか、何卒返却して戴きたいもんです』と泣聲になつて訴へた。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズック製の旅鞄に、二枚の着換えを入れて、四冊の書物と日記帳とを加えて、手拭の類を収めると、そのほかにすることといっては、鍵のかかるところに鍵をかって、本箱の上に自分のと別にしてならべてある借用の書物を人見か柿江に頼んで返却してもらえばそれでいいのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四階級は他階級からの憐憫、同情、好意を返却し始めた。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭の位階を返却す。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内にも言いきかせ、とにかく之は怪しいから、そっくり帯封も破らずそのままにして保存して置くよう、あとで代金を請求して来たら、ひとまとめにして返却するよう、手筈をきめて置いたのである。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年まえの病気のとき私は、ほうぼうから滅茶苦茶に借銭して、その後すこしずつお返ししても、未だに全部は返却することの出来ない始末なのであるが、そのとき河内さんへも、半狂乱で借銭の手紙を書いたのである。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "返却したくても由なく、こうして一時、あずかって在るのである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」少年も寝ころんでいて、大声で、侮蔑の言葉を返却して寄こした。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "締切までに小生の机上に堆積したる原稿意外に多く爲めに會計擔任者と合議の上、紙數を増す事豫定より五十頁の多きに達し、從つて定價を引上ぐるの止むなきに到り候ひしも、猶且その原稿の全部を登載する能はず、或は次號に※し、或は寄稿家に御返却したるものあり。",
              "citation": {
                "source": "消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンリ・ベイカー氏へ同等品を返却希望。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕べに申告があって返却されたのですが、そのあいだに私は型どりをして合い鍵をこしらえておきました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "館野と別れる時に例令養子に行くにしても此から先き二年間の學資を出すことゝそれから放蕩して拵へた借財を返却してくれることでなくちや厭だといつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って、すぐにその紙片を返却した。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり固パンのように、すぐに返却しておゆるしを乞うべきところでもあったのだが、どうも、かっぽれが気の毒で、何とかなぐさめてやりたく、わかりもしない癖に、とにかくその十ばかりの句を拝読した。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人から借りていた書籍はそれぞれ返却し、手紙やノオトも、屑屋に売った。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王はそれをお受けになることは醜いことであるというように言っておいでになったが、求婚者としての言葉が添えられていることであれば辞退もできるが、これまで長い間何かの場合に公然の進物を送り続けた源氏であって、親切からすることであるから返却のしようがないように言って女房たちは困っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "また氏がちょっと立つごとに跡へ坐って烟管を口にし、氏帰れば至って慎んで返却したは極めて可笑しかったとある。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば僻地盗難繁かった処々は、庚申に祈りて盗品を求め、盗もまた気味悪くなってこれを返却した例多く、庚申講を組んで順次｜青面金剛と三猿の絵像を祭りありく風盛んなり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日中にそれ等のノートは返却しなければならないことを思ふと、彼の心は苛立たずには居なかつた。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雛はたった今、すぐにご返却なさいませな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も御身の場合は余程の物好きからでもありませうから別段に何とも申しませぬが、最早物好きなる旅も程好く打ち切つて負債の返却に取りかかつては如何かと老婆心をめぐらせます。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の十一月から節約に節約を加えて、借金の返却を心がけたので、財嚢はつねにつねに冷やかであった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、親戚の者のいったところを考え合せると、父は陸軍大佐で、演習中に突然亡くなり、母一人の手でお杉が養われていたところ、或る日、恩給局からお杉の母へ下っていた今までの恩給は、不正当であったから、その日まで下った全部の恩給額を返却すべしという命令を受けとったのだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も高野の宝物保存に就いては異議は無いのだから、朝吹君や益田君が自分達が以前狩り集めた物を返却すといふ条件付なら、何時でも寄附に応ずる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昨夜、事件の現場で拾った懐中時計と三枚の十銭ニッケル貨幣とを返却して貰うことだった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、それを、支配者が農民の観念の統帥としてあてがって置いた悪魔という文句で表現して、機械を地主へ返却したのであった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此書籍をドクトルに返却することを遺族に申残し候。",
              "citation": {
                "source": "アンドレアス・タアマイエルが遺書",
                "author": "ANDREAS THAMEYERS LETZTER BRIEF",
                "note": "青空文庫"
              }
            },
            {
              "text": "天鹽の土地問題も、松田の雇ひ技師に書類を見せたところ、とても相談にならないと云ふので、北劍の家へ行つて、義雄は書類を返却してしまつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田村が氣違ひになつた」と云ふ評判を却つてこちらからあざ笑つて返却した義雄ではあるが、激動後の反動の爲めか、段々に氣拔けが増して、自分ながらぼんやりしてしまつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
