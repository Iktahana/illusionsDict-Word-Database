    },
    "definitions": [
      {
        "index": 1,
        "gloss": "remote place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "野辺地の浜に近い灌木の茂った斜面の上空に鳶が群れ飛んでいた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして――東は海を限り、北は野辺地に至るまで、東西九｜里、南北十三｜里、周囲十六｜里。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教はもっと度量が広く、疑いつつ弥陀を念じても疑城胎宮（疑いを持ちつつ念仏するものの生れる極楽浄土の辺地）といって極楽圏に対して番外当選ぐらいのところまでは行けることに、浄土教の祖師たちは説明されていますものの、疑わないに越したことはありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "途すがら、下河原沼の暁風、野辺地の浦の汐風、浜茄子の香など、皆この古帽に沁みて名残をとゞめぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水川という村よりまたまた野辺地まで海岸なり、野辺地の本町といえるは、御影石にやあらん幅三尺ばかりなるを三四丁の間｜敷き連ねたるは、いかなる心か知らねど立派なり。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "文曰、野辺地村に千曳神社あり、古老伝云往古此辺に碑あり甚だ大なる石なりければ、土人新墾に不便とて、かの石碑を引退かむとするに多人して引たれども得動ざりき。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏説によると、地獄にもさまざまあるが、凡先づ、根本地獄、近辺地獄、孤独地獄の三つに分つ事が出来るらしい。",
              "citation": {
                "source": "孤独地獄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーさん」「飛行船隊の中から、一隻、アクロン号というのが、陸奥湾を横断して、唯今、野辺地の上空を通っているのだ」「どこへ、逃げてゆくのかしら」「莫迦だなア、君は。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう北側の辺地に一杯つゆ草が咲いていた。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "辺地に近い石かげへ、短い竿で蠅をさした鈎を投げ込んだ。",
              "citation": {
                "source": "ザザ虫の佃煮",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十万円ちかい大穴だの、八百長｜紛擾、焼打、そうかと思うと女子競輪などゝ殺気の中に色気まであり、百聞は一見に如かずと食指をうごかしていたが、伊豆の辺地に住んで汽車旅行がキライときているから、生来の弥次馬根性にもかかわらず、出足がおくれたのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "周防石城山神籠石周辺地図　神護寺は維新前に一度第二奇兵隊の拠るところとなった。",
              "citation": {
                "source": "周防石城山神籠石探検記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、水仙は海辺地方の植物であって、山地に生える草ではない。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "房州〔千葉県の南部〕、相州〔神奈川県の一部〕、その他｜諸州の海辺地には、それが天然生のようになって生えている。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同じこの夜のことであった、紀州熊野｜中辺地街道の、野長瀬の郷を七人の男女が、不思議な振る舞いをして通っていた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ちかい辺地とても、流言のざわめき、軍靴の恐怖はたちこめている。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の色々な辺地を廻って、八個所ばかり掘って見た。",
              "citation": {
                "source": "凍上の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはここから浜へ出て、陸中の海ぞいを、貝魚を拾いながら上総まで上る、とおっしゃって、陸奥の野辺地というところで別れました」　と、おしえてくれた。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "このうえは、野辺地まで行ってみるほかはないと思っているとき、尻内の馬喰宿で、はじめてほのかな手がかりがあった。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて類のない誓願を抱いて、辺地異域にはべり、日夜万民を憐れみ、普賢菩薩の悲願に習い、生身のまま入定した事を実証せんがため弥勒の出現を待つものです」　と伝えた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日の昼すぎ、野辺地という町に着いた。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "野辺地の町を出はずれると、左手に寒々と光る陸奥浦の海が見えてきた。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、野辺地の町でごらんになった二組の骸骨は、庄吉が夢に見るほど逢いたがっていた弟夫婦の成れの果てのすがただったので、たまさか故郷へ帰るなり、天明と天保の飢饉のあとを見て無常を感じ、急にとりとめなくなったと思う。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの常式では、野辺地の郡代官に引継げば、それでわれわれの役目がすむのだが、こんなところまでついてきたのは、しょうしょう、おねがいの筋があるからだ。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "東北では発音をケセネまたはキスネと訛っていう者が多く、岩手県北部の諸郡でそれを稗のことだといい、また米以外の穀物に限るようにもいう土地があるのは（野辺地方言集）、つまりは常の日にそれを食していることを意味するものである。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "無能な人を罵ってアモクソといい（野辺地方言集）、ササメとは言わないのは、ササメ以上はまだこれを食料に用いる余地があったものと思われる。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "相模三浦郡葉山町大字上山口字｜間門甲斐｜八代郡山保村大字嶺字マカド駿河｜駿東郡片浜村大字東・西間門同　富士郡吉永村大字間門下野｜安蘇郡｜界村大字馬門同　芳賀郡中川村大字馬門陸奥上北郡｜野辺地町大字馬門　マカマと言う地名もある。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "海辺地方の百姓は年じゅう汐風に吹かれているので皆が皆こんな風になるのである。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨日午後八時頃から十時頃にかけて東京周辺地域のテレビにＮＨＫ民放合わせて七局に海賊放送が流れた事件で、警視庁は逆探知の結果海賊放送の電波の発信源は板橋区周辺と考えられることを明らかにしました。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大へんちいさなこどもをつれてちょろちょろとゴーシュの前へ歩いてきました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
