[
  {
    "uuid": "e24f4448-5e88-5ad7-b6d0-3f451fcc5b0f",
    "entry": "辺地",
    "reading": {
      "primary": "へんち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
