          "literary": [
            {
              "text": "父は善根の深い人で、四国、西国の霊場を経巡る遍路の人達のために構えの一棟を開放し善根の宿に当てていた。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その密使として、これから高野をはじめ、諸山へ経巡る道すがらじゃ。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神輿は行きたい方へ行き、めぐりたい方へめぐる。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金※の裾野を東より北へめぐるに、日暮れたり。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる理想郷は、それらの坑によって地下をへめぐる。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
