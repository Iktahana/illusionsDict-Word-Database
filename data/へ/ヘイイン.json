[
  {
    "uuid": "2304d49b-11e3-58d6-95f6-9beb68bf0da3",
    "entry": "兵員",
    "reading": {
      "primary": "へいいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "military strength",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、兵員は充実して置かなければならなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくは戦闘艦の巨砲の一発の価、陸軍兵員の一日分のたくあんの代金にも足りないくらいの金を使って懸命に研究し、そうして世界的に立派な結果を出しているようである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "警備隊から、驚破と駈つけた兵員達は、外套も被なかつたのが多いさうである。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛布はすべて旅団の兵員が、遠征の際に用ゐたるをつかひ候よし。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "武歩たちまち丘下に起りて、一中隊の兵員あり。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを冒して、安全に十分の兵力をマライ上陸させるためには、船が足らん、飛行機が足らん、更に兵員がうんと足らんぞ」委員Ｇ「日本の方だって大損害を起している。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、適当な手段が見つかったとしても、巨額の対抗兵器と危険多き多数の兵員を要することだろう。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に急遽必要とするのは兵員である。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百倍だ二千倍だというが、目下の一千五百万人の兵員を五百倍とすれば四十五億人、二千倍とすれば百八十億人――わが国の人口は一億三千万人であることは常識である。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦内では、いよいよ繋留用意の号令が出て、係の兵員は眼のまわるような忙しさだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も本当に帰艦したわけではなく、指をくわえて待ちくたびれている兵員たちに、すこしでも早く、この珍奇な飛行島の様子を知らせてやろうという友達思いの心からだった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふむ、そうか」　副長はさらに大勢の兵員を集めて聞いてみたがどうも分からない。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その私室の前には、四五名の兵員が声高になにか論争していた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも夜は元気のいい水兵たちの笑声で賑やかな兵員室も、今夜にかぎってなんとなく重苦しい空気につつまれていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも兵員がついているところはあらまし消し終え、大事なところだけは、ほぼ闇の中につつまれた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "機数はわからんか」「すくなくとも四機、あるいはそれ以上ではないかと思われます」　訓練された兵員は、それほど能力のない器械を時にその能力以上に使いこなす。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たたたたたっと、作業をおえて甲板を走ってかえる飛行班の兵員たち。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに印度志士が慓悍であるとはいえ、十分武器をもったこうも大ぜいの兵員にとりかこまれては、どうにもならない。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵員と機械とがまるで一人の人間の手足のように、うまく動くのであったから。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "徴兵制度に依って多数の兵員を得たのみでなく、自由平等の理想と愛国の血に燃えた青年に依って質に於ても全く旧国家の思い及ばざる軍隊を編制する事が出来た。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民皆兵の徹底が兵力を増大し、人口密度大なる欧州の諸国家では国軍をもって全国境を守備するに足る兵員を得るようになり、遂に迂回を不可能として持久戦争の時代に入ったのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上作戦の場合は無数の兵員を得るため国民皆兵で誰でも引張り出したのであるが、今後の戦争では特にこれに適した少数の人々が義勇兵として採用せらるるようになるのではなかろうか。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "遭難と同時に船長が絶対の権威をもって役に立ちそうな男の船客に各受持ちを定めて命令を発したのだが、ポウシェン少佐は兵員陸揚げなどで経験があるというので、救命艇の一つを預かって避難者の積込み方を監督することになった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "三鞭酒を抜く、機関室からは、兵員の合唱が洩れてくる。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "各自の部署を離れて、兵員室に行く部下の顔は明日の決行を思い、誇りと喜悦の色に輝いている。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦側から、海中に飛び込む兵員、しだいに現われゆく赤い船腹、やがて、魚雷網の支柱にまで火が移って、まったく一団の火焔と化してしまったのである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、丁度、その中下甲板の検査をする役に当つたので、外の仲間と一しよに、兵員の衣嚢やら手箱やらを検査して歩きました。",
              "citation": {
                "source": "猿",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてその年も明たが、彼の京都で長州兵が禁門に発砲したことがあったり、その前後も藩主や世子は京都江戸へ奔走されていたので、兵員も多人数を要することになり、従来の士分以上では不足を生じた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその少数ながらも藩の四境を固める兵員を配置して、それらがなかなかの騒ぎであった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　という警報で、海底トーチカの兵員は、それというので、部署についた。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
