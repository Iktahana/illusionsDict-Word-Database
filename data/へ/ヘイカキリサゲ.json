          "standard": [
            {
              "text": "深刻な貿易赤字を解消するため、政府は平価切下げの実施を決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "平価切下げのニュースを受け、投資家たちは一斉に自国通貨を売り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その国は経済危機を乗り切る苦肉の策として、平価切下げという手段を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "前大戦の終戦の一年目には、ベルリンだけで五十万人も餓死したが、勝ったフランスも食べるものがなく、インフレーションに苦しんで平価切下げをやり、伊太利はギャングと浮浪児の巣で、英国は阿片とコカインの大流行だった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
