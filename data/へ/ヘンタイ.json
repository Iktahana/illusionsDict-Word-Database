[
  {
    "uuid": "e32fd48f-b4a0-512c-a90b-8b38d67201b5",
    "entry": "変体",
    "reading": {
      "primary": "へんたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
