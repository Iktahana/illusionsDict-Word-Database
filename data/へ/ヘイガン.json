    "definitions": [
      {
        "index": 1,
        "gloss": "closing one's eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
