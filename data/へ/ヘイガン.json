        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "第一志望の国立大学だけでなく、滑り止めとして私立大学もいくつか併願するつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "併願していた企業から先に内定が出たため、就職活動を終了するか迷っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "複数の学部を併願できる制度を利用して、合格の可能性を少しでも高めたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
