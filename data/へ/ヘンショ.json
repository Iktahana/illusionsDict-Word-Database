[
  {
    "uuid": "ef6f8b9a-3e11-58df-92b5-2aedde7e29c6",
    "entry": "返書",
    "reading": {
      "primary": "へんしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
