        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "希ガスは最外殻が閉殻となっているため、化学的に非常に安定している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "電子が軌道を完全に満たして閉殻構造をとると、反応性が著しく低下する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "物理の授業で、原子の閉殻とイオン化エネルギーの関係について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "closed shell",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
