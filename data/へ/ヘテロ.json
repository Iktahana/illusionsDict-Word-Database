        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "交配実験の結果、生まれた個体のほとんどがヘテロであることが確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "遺伝子検査により、彼が特定の劣性遺伝疾患のヘテロであることが分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "博士は、ヘテロが生存競争において有利に働くケースについて論文を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
