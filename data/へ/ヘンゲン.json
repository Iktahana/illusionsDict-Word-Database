[
  {
    "uuid": "4f8f6c15-e3b7-540d-809c-55803e8e619e",
    "entry": "変幻",
    "reading": {
      "primary": "へんげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "transformation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雨と晴れとの中にありて雲と共に東へ／＼と行くなれば、ふるかと思えば晴れ晴るゝかと思えばまた大粒の雨｜玻璃窓を斜に打つ変幻極まりなき面白さに思わず窓縁をたたいて妙と呼ぶ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑波山の紫は、花崗石の肌の色に負うことが多いが、富士山の冬の紫は、雪の変幻から生ずる色といっても大過はあるまい。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のような多彩にして変幻きわまりなき自然をもつ国で八百万の神々が生まれ崇拝され続けて来たのは当然のことであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日置いて九日の日記にも「風強く秋声｜野にみつ、浮雲変幻たり」とある。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの組立ては、いちいちに様が変り、時を経るに従って事情を違えては行くものの、その様の変りよう、事情の違いようが複雑変幻きわまりない中に、およそ一貫した根本の性質があるというのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、この「法性」を知る前に、大生命中のいちいちの組立てにつき、その変幻極まりない複雑な相を、前に述べました因縁の法則に当てはめて相において学び取ろうとするのが、私たちの智の範囲に属する経験や知識です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきなぐさはその変幻の光の奇術の中で夢よりもしずかに話しました。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時関八州を横行して、変幻出没、渚の網に陽炎の影も留めず、名のみ御曹子万綱と、音に聞えた大盗あり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水が湯となり氷となるが、人生の事情の多端錯雑、変幻極まりなきに比べてはるかに簡単であり、したがつて物に接するは、事に処するよりも単純であるが、それでも本当に物に接するといふことに徹底するには、大分の知慮分別と、鍛練修業を必要とする。",
              "citation": {
                "source": "些細なやうで重大な事",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "時時にその濃藍色が群青に柔金に瓏銀に変幻した。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この引力は人をして適ま偉大なる人物とならしめ、適ま醜悪なる行為をなさしめ、或は善、或は悪、或は聖愛、或は痴情、等の名を衣たる百般の光景を現出して、人生を変幻極まりなきドラマたらしむ。",
              "citation": {
                "source": "熱意",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの川のかれらに遥に超えたゆえんは変幻極まりなき河川としての綜合美と、白帝城の風致と、交通に利便であって近代の文化的施設余裕多き事であろう。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "巒気と水光と変幻する雲、雲、雲。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んだ変幻豆でげすな」「洒落にもならない話だよ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とはいえあの「蟲」の主人公が、女優の屍体を土蔵の中からトウトウ取り出し得ずに、変テコになってヘタバッてしまう迄の極度にあられもない気分の変幻を、あんなに平気で扱い去った筆力の凄まじさには「鬼か人か」と叫びたいくらい、参いらせられてしまいました。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "而るに形躯を変幻し、草木に依附し、天｜陰り雨｜湿うの夜、月落ち参横たわるの晨、梁に嘯いて声あり。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山もとより少なからず、しかも変幻出没して雲表に豪然たる偉容を作れるは少なし。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而るに形躯を変幻し、草に依附し、天陰り雨｜湿うの夜、月落ち参横たわるの晨、梁に嘯いて声あり。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が心の照応する所境によって変幻極りない。",
              "citation": {
                "source": "おばけずきのいわれ少々と処女作",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見あげる空には星の変幻出没が限りなかつた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて五雲は思ひもかけぬ図柄を我々の眼の前に提供し、次の作品が予測できないやうな変幻の妙を示した。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、自分では知らずに、変幻極まりなく、且最も深遠な事物を表現する。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま本誌に連載されているランドンの『灰色の幻』はガストン・ルルー張りの変幻極まりなきものです。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十五日より今日に至るまでの、こうした私の変幻自在の心持ちを書くということは、ほとんど不可能であろう。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの川のかれらに遙に超えた所以は変幻極まりなき河川としての綜合美と、白帝城の風致と、交通に利便であつて近代の文化的施設の余裕多き事であらう。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "変装とか、変幻出没の超人的行為の力を借りない点において、ともかく、自然味をあまり損じていないのがこれらを通じて作者の手柄である。",
              "citation": {
                "source": "日本の近代的探偵小説",
                "author": "――特に江戸川乱歩氏に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼は昼間でも種々の奇怪な形を見せて変幻出没するのでした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
