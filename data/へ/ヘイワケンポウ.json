        "examples": {
          "standard": [
            {
              "text": "日本の平和憲法は、戦後の復興と民主主義の歩みを支えてきた精神的支柱である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "平和憲法の理念を守るべきだと主張する人々が、国会議事堂の前で声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "憲法第9条を含む平和憲法の堅持を訴える署名が、全国から何百万筆も集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日本は今次の敗戰によつて、世界に先驅けた平和憲法を制定したが、一歩獨立方式を誤れば、神聖なる新日本の意義は完全に失われてしまうであろう。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに去年四月の日本社会党中央委員会ではいままでの軍事基地反対運動、平和憲法擁護運動、原水爆禁止運動、沖縄返還および日中国交回復国民運動と日米安保条約体制打破の国民運動を、とくに本年におきましては日中国交回復国民運動と日米条約体制打破の国民運動に力を結集してたたかうことを決定したのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
