        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山陽が後｜真に屏禁せられる一年前の事である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此年に山陽は屏禁せられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽は京都の福井新九郎が家から引き戻されて、十一月三日に広島の家に著き、屏禁せられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "総参詣人一日へいきん二万人以上づつ有由。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
