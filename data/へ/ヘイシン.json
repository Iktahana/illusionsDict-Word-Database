    },
    "definitions": [
      {
        "index": 1,
        "gloss": "keeping pace with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其が一転すると、並進式とでも申しませうか。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、此迄とつて来た並進式に満足が出来なくなつて、なるべく、一場に二人の中心人物を顔を合せる様にしよう、と言ふことに考へ変りせられたのだらう、と思ひます。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、此二人に、舞台で、一度も顔を合せさせない処は、てれこ式・並進式のなごりは止めて居る様です。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如くにして、どうして彼らは社会の進歩に並進する事が出来よう、どうして彼らが富裕なる生活を遂げる事が出来よう。",
              "citation": {
                "source": "特殊部落ということについて",
                "author": "まず部落としての集団的取扱いを廃せよ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらその撤廃をして有効ならしめるには、彼ら自身において自ら発奮興起し、普通民と社交上において並進しうべきまでに改善するところがあらねばならぬ。",
              "citation": {
                "source": "特殊部落ということについて",
                "author": "まず部落としての集団的取扱いを廃せよ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
