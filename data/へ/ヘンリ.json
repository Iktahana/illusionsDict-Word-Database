        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見れば、たいへんりっぱな身なりをしています。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、さっきもお話ししたとおり、たいへんりっぱなメンドリだったのです。",
              "citation": {
                "source": "ほんとにそのとおり！",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学生は学校で、先生から「ペテロというえらい人が、むかし、たいへんりっぱなはたらきをして、みかたに大｜勝利をもたらした」ということを、教わりました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "セレンジブ王の御殿は、大へんりっぱなものでした。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は太陽の光と能率のわるい肥料で永くかかって栽培していましたが、今はそれに代って、適当なる化学線と電気とすぐれた植物ホルモンをあたえることによって、たいへんりっぱな、そして栄養になるものを短い期間に収穫できるようになりました。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの組も人数が少く、先生は多く学費はかなり高価であったが、ここで教育せられた生徒はたいへんりっぱであったから、入学志望者は毎年五六倍もたくさん集った。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、わたしはなんどもなんども使いをやって、あなたがわたしたちのあいだで、たいへんりっぱなおこないをしていると知らせてやりました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛭田博士　ドアの中をのぞいてみますと、その部屋が思ったよりずっと広くて、たいへんりっぱなのに、まずびっくりしてしまいました。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだがひどく小さくて、ポケットにでもはいるくらいだというので、そんなあだ名がついていましたが、すばしっこくて、たいへんりこうな少年でした。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
