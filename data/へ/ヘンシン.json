[
  {
    "uuid": "a32c9290-786b-5d40-af71-190590047d8b",
    "entry": "偏心",
    "reading": {
      "primary": "へんしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "eccentricity (in mechanics, electronics, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕はそこで磁針を引きつけるふしぎな力を見つけるかもしれませんし、また無数の天体観察をやってそれをだんだん正確なものにしてもいけるでしょうが、いつもきまって変らないその外観上の偏心率を示すためには、どうしてもこの旅か必要なのです。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "英和辞書を引っ張ると「中心ヲ外レタル」とか「偏心的ナル」だとかしち難しい訳が出ているが、平ったく言えばなあに「調子｜外レ」ということだ。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、今まで大へんしんせつにしてくれた一人の商人が、私に、みんなと一しょに、やしの実を取りに行かないか、とすすめました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は大へんしんせつそうなふうをしていましたが、ほんとうは、アフリカのまほう使でした。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、小人たちは、たいへんしんせつにしてくれて、「おまえさんの名まえはなんというのかな。",
              "citation": {
                "source": "白雪姫",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いままであたくしをたいへんしんせつにしてくれておりましたので、こういうしあわせな身になりましても、おばたちのことをわすれたくはございません。",
              "citation": {
                "source": "三人の糸くり女",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
