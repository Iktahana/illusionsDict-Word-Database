        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのうちに身体は左右ヘゴロチャラゴロチャラ揺れる。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘゴと言ふ、大きな羊齒の一種が繁つてゐた。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "羊歯に似た、ヘゴといふ植物が富岡には珍しい。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の生れた新潟では寸をつめて名前をよぶ癖があって、ヘイゴをヘゴとよぶ。",
              "citation": {
                "source": "ヒノエウマの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬称のサンを略して「ヘゴサ」とよぶのである。",
              "citation": {
                "source": "ヒノエウマの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに新潟では弱虫をヘゴタレと呼ぶから益々よくない。",
              "citation": {
                "source": "ヒノエウマの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "南洋の植物にヘゴマルハチというのがあってこれが読本にでてくると、同級生の奴らはゲラゲラキャアキャア大喜びで鳴りやまないから、こういう時には笑う奴をセンメツしたくなったものである。",
              "citation": {
                "source": "ヒノエウマの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の本名が炳五といい、故郷の呼び方で一般にヘゴとよばれるのが非常にイヤだった。",
              "citation": {
                "source": "人の子の親となりて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはその島の西端荒川村の玉ノ浦にヘゴがあるというのでそれを見、そして採集するために行って十分に検分し、採集してきた。",
              "citation": {
                "source": "若き日の思い出",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の石のヘゴの幹が今私の宅にある。",
              "citation": {
                "source": "若き日の思い出",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清兵衛の話を取り集めると、その島の高いところには土当帰、赤鉄、タコの木という種類の巨木が亭々と聳え、谷間には木性羊歯、ヘゴが繁りあい、海岸には椰子、檳榔などの長木が、扇のように緑の葉をひろげている。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
