        "examples": {
          "standard": [
            {
              "text": "寝る前に本を読む習慣があるので、クッション性が高く背もたれになるヘッドボードのベッドを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "アンティーク家具の店で、繊細な木彫りが施された見事なヘッドボードに一目惚れして購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "部屋の雰囲気を変えるために、ベッドのヘッドボードにLEDのテープライトを取り付けて間接照明にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "逃げたほうがいいって」　慶一はじぶんのギターを、ヘッドボードのむこうにおいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなものか……口にだしていわなくちゃあ、わからないよな」　いぶかしげな視線を向けながら、令子も上半身を起こし、ヘッドボードにもたれかかる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは反射的にのぞき込んでみたが、家内はたしかにヘッドボードの影に横たわっているのが見えた。",
              "citation": {
                "source": "幽香嬰女伝",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、ベッドにすわってヘッドボードに背をもたせかけ、ＴＶの画面を見ていた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓にヘッドボードを寄せてシングル・ベッドがあり、ドアのある壁に接して、ベンチともテーブルともつかない横に長い台があった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
