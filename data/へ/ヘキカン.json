    "definitions": [
      {
        "index": 1,
        "gloss": "portion of wall between two pillars",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おかしいことには、その時の手術室の壁間に掲げてあった油絵の額が実にはっきり印象に残っている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は四十年前と同じ若々しさ、あどけなさをそのままに保存してエメラルド色のひとみを上げて壁間の聖母像に見入っているのである。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "導かるゝまゝに入込んだのは、階上の南端の一室で、十｜疊位いの部室、中央の床には圓形のテーブルが据へられ、卓上には、地球儀や磁石の類が配置され、四邊の壁間には隙間も無く列國地圖の懸けられてあるなど、流石に海軍士官の居室と見受けられた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋燈の光は煌々と輝いて、何時の間にか、武骨なる水兵等が、優しい心で飾立てた挿花や、壁間に『歡迎』と巧妙に作られた橄欖の緑の葉などを、美くしく照して居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁間には、鳥羽僧正の漫画を仕立てた長い和装の額が五枚｜程かけ連ねてあります。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "里伝にこの島に名馬草を産し、牝馬これを食えば必ず名馬を産めど、絶壁間に生える故馬これを求めて往々墜ちて死すと（『甲子夜話』続編五七）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の焦黒てふ者壁間より覗い知って、門より入り来りその銀を偸むを、月娥はその夫帰ってわが房に入ったと思いいた。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "來城、壁間に掲げたる余が自作自筆の一軸を見つけて、この詩佳なりといふ。",
              "citation": {
                "source": "獨笑記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "時国の話によると主人は絵かきだということで、下にも二階にも、壁間に怪しげな油絵の額が沢山かかっていた。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして面妖にも、青色の極東を中心とする大地図が消え失せて、あとには始めにみた花鳥の図が、何事もなかったように壁間に掛っていた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボウイが正面壁間の黒板へ何か書き出す。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには目も眩む金色燦然たる大額が、壁間にズラリと並んでいた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ一緒に探して呉れたまえ」　速水は、壁間のスイッチを押してから、重い扉を開いた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡田三郎助の雛妓の額が、また壁間に残っているのも、思い出の種である。",
              "citation": {
                "source": "芝、麻布",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "千八百六十六年、ボオドレエルの狂疾を発して、巴里の寓居に絶命するや、壁間｜亦この檀口雪肌、天仙の如き麗人図あり。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に然るからはこれを果亭と認めて壁間にぶら下げたのにしろ、毛頭自分の不名誉になる事ぢやない。",
              "citation": {
                "source": "鑑定",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "六畳敷きほどの広さの小ぢんまりとした部屋は床の間の基督受難の掛軸や、壁間の聖母の画像や違棚の金縁背皮の厚い聖書らしい書物など、宣教師らしい好みで飾られていた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑道――ディグスビイの酷烈な呪詛の意志を罩めたこの一道の闇は、壁間を縫い階層の間隙を歩いて、何処へ辿りつくのだろうか。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その建物の主屋は、前世紀の終り頃、英国長老教会マッカイ博士が布教をかねて建造したものであるが、亭子脚を具えた廊下、窓や壁間の均勢、中央のドームなど、西洋と支那との両様式を巧みに取り入れ、而も台湾の土地柄に適合したものとなっている。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は幸福な太陽と大空との恍惚からはなれて、パンをむしりながら、新聞の外国電報欄を注意深く読みながら壁間の世界地図の上にその一字一句を明確に具象化することのたのしみにうつつてゐた。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ごとが御前の機嫌を損じましたか、その次第を――ほほう、これは変った絵をお架けになりましてございまするな」　さすがに美術商よと讃むべきであるが、岩田天門堂は、話の途中で壁間の画を一目見ると愕きの声をあげた。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあそれはあそこの壁にかけよう」　烏啼は上々の機嫌になって、再現した名画を壁間に掲げ、惚れ惚れと眺めた。",
              "citation": {
                "source": "すり替え怪画",
                "author": "烏啼天駆シリーズ・５",
                "note": "青空文庫"
              }
            },
            {
              "text": "天じょうの上の古風なシャンデリアと、四方の壁間にとりつけられた、間接照明灯が、影のない明かるい照明をしている。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁間に、ぽッと四角な窓があいた。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより以後は、欽吾が仰ぐたびに壁間に懸っている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰がぬ時も壁間から欽吾を見下している。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "序ながらこゝで、例の※陽湖の入口に大姑島といふ島があり、その島の同じ道教の寺を訪ねた際、壁間に掲げられた聯句を何気なく書きつけて来たから、参考の為に写してみる。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニキーチナ夫人、二百何人かの文芸家をメムバーとするクラブを作って居て、入った部屋には、壁間すき間なく、作家たちの写真、スケッチ、ポートレイト架すなり。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に四つの病室と開いた扉から見える壁間の額を眺めつつ二三度歩いた。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁間には、塗りかえられた旧蘭印、旧マレイの地図が、夕陽を浴びて赤く輝いていた。",
              "citation": {
                "source": "不沈軍艦の見本",
                "author": "――金博士シリーズ・10――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
