[
  {
    "uuid": "ce57df8f-e5eb-5e73-a44d-709047143fb2",
    "entry": "扁額",
    "reading": {
      "primary": "へんがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
