    "definitions": [
      {
        "index": 1,
        "gloss": "framed picture or motto (usu. horizontal, hung over gates or lintels)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雨戸を固く鎖したる本堂の扁額には霊鷲山、舎利蔵寺と大師様の達筆にて草書したり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "石室の入口には「申陽之洞」という扁額が懸っていた。",
              "citation": {
                "source": "申陽洞記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "及び軍鶏も、その柳屋の母娘も、その後行方の知れない事とは、同時に焼けた、大屋の隠居、酒屋の亭主などは、まだ一ツ話にするが、その人々の家も、新築を知らぬ孫が出来て、二度目の扁額が早や古びを持って来たから、さてもしばらくになった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは、特にこの機にあたつて大陸の作家や、僅少なる我国の大作家の上を顧慮する余裕もなく、常に窮極なる生命と生活の瀬戸ぎわでデルフオイの扁額を思ふのみなのだ。",
              "citation": {
                "source": "月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は煙草をふかしながら、扁額の支那人の字を見てゐた。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒月の名は西鶴の発見者及び元禄文学の復興者として夙に知られていたが、近時は画名が段々高くなって、新富町の焼けた竹葉の本店には襖から袋戸や扁額までも寒月ずくめの寒月の間というのが出来た位である。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰山前に頽るるともビクともしない大西郷どんさえも評判に釣込まれてワザワザ見物に来て、大に感服して「万国一覧」という大字の扁額を揮ってくれた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処は去年の夏頃友達の小林秀雄に依つて知らされたのみやで、二階の座敷には先の若槻宰相の筆になる扁額が懸つてゐたと思ふ。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄想と、寝返りと、口の内にて演説のまねと、今朝来の経過を繰り返して考へ見る事と、二つの扁額、（為山の水絵、不折の油絵）を見つむる事と、これらの中にやうやう苦痛の三、四時間を過ぎて、熱次第にさめかかる。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりで何かうまいものをお母さんに御馳走しますかナ」　お三輪は椅子を離れて、木彫の扁額の掛けてある下へも行って見た。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の扁額に曰く“故郷難忘”五月二日　曇、夕立、晴、満島泊。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日までゐた茶室の扁額が直ぐ目の下に見えて、朝日が初冬の梢ごしに障子の腰硝子を透して、机のうへまでちら／＼してゐた。",
              "citation": {
                "source": "倒れた花瓶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の建物は二階造りの大きなもので、二階の上には尖塔の立つた太鼓樓まで附いてゐて、階上正面の扁額には、何々親王家の染筆になつたといふ「天滿校」とお家流に書いた大文字が、金網の中から、肥桶擔ぐ百姓共を威壓するやうな筆勢を見せてゐた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "密閉されたガラスの棚には、大きな数十の古硯や古墨その他、古い文房具の犇めくように並んでいる中に混り、八大山人の対幅と、オートイユの競馬の版画が懸けてあって、扁額には「眉子山房」と鳴鶴風の意外に生真面目な字が読まれた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と千鶴子は一寸扁額を見上げて云った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと、人心地がついた所で頭の上の扁額を見ると、それには、山神廟と云う三字があった。",
              "citation": {
                "source": "仙人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶亭には花卉の鉢を陳べ乃木東郷両大将の記念自署などが扁額として掛つて居た。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又多蔵古来帝王扁額、名流題寄。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "城内の小池小路にあったその古びた建物は有備館と呼ばれ、著名な儒者である佐久間｜洞巌が、筆を取って対影楼の扁額をかかげた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れが百太夫であると云ふが、神前に掲げられた扁額を見ると中央に「事代主神社」とあり、その右に「道薫坊」「百太夫」と並べ、左に「秋葉神」と書いてある。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "総司は、背後に積重ねてある夜具へ体をもたせかけ、焦心っている眼で、お力が持って来て、まだ瓶にも挿さず、縁側に置いてある椿の花を見たり、舞込んで来た蝶が、欄間の扁額の縁へ止まったのを見たりしていたが、「先生、勿論、私も従軍するのでしょうな。",
              "citation": {
                "source": "甲州鎮撫隊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋風の壁へかかっているのは、純日本風の扁額であった。",
              "citation": {
                "source": "柳営秘録かつえ蔵",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また本社の拝殿に一の扁額をかかぐ、神庫に蔵められし小鷹丸の艦材を刻めるものなり。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一片の扁額、なほ当年の遺物たり。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方の欄間に向いあって漢文の扁額が懸り、一つには、「其人ヲ看テ其病ヲ看ズ」とあり、一つには、「静ニ処シテ以テ動ヲ観ル」とある。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿上の扁額を見ると桂府としてあった。",
              "citation": {
                "source": "蓮花公主",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは四百餘年前の建築であることは、門※の陶製の扁額に「首里の王おきやかもひかなし御代にたて申候、正徳十四年己卯十一月二十八日」とあるのを以て知ることが出來る。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "西岡未亡人の家にはそんなわけで、西岡医院開設当時に贈られた蒼海翁のあの雄勁な筆力を見せた大字の扁額を持ち伝えていた。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といいながら愛雀軒という扁額を掛けた庭の柴折戸を遠慮なく明けて入って来たのは柳下亭種員に笠亭仙果と呼ぶ両人の門弟である。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が新しくブラシをおろすたびに、「煙だよ」とか「電柱だよ」とか一々説明してくれる人もあって、なんだか少し背中や首筋のへんがくすぐったいような気持ちもした。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
