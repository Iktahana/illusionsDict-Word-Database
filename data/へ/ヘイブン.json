[
  {
    "uuid": "13dac8a6-b3a2-5406-b543-9023b114a7b4",
    "entry": "平分",
    "reading": {
      "primary": "へいぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
