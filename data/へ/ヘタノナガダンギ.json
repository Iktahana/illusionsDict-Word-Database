        "examples": {
          "standard": [
            {
              "text": "校長先生の朝礼の挨拶は、いつも下手の長談義で生徒たちは退屈そうにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "結論をなかなか言わない彼からの報告は、まさに下手の長談義で聞いているのが辛い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "下手の長談義にならないように、スピーチは要点を絞って短く簡潔にまとめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "下手の長談義で余り長くなりますから、これまでに致して置きます。",
              "citation": {
                "source": "馬琴の小説とその当時の実社会",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『花と龍』はもっと沢山かきたいことがあったのであるが、あまり下手の長談義になっても困るので、多くの素材を割愛した。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
