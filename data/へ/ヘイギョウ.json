        "examples": {
          "standard": [
            {
              "text": "後継者不在のため、創業100年の老舗旅館がついに閉業を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商店街のあちこちに、閉業を知らせる貼り紙が目立つようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お気に入りのパン屋が閉業してしまい、ショックを隠せない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "やがて医者となり辻川に帰ったが、父の祖父左仲同様に流行らない医者で、思いあまって閉業しようとした矢先き、姫路の熊川舎という町学校の舎主として赴任することとなった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉業、無用恟々、無用隠匿、無用　こう三無用の触れだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
