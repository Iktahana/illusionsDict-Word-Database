[
  {
    "uuid": "5582841b-3be4-5eb1-a681-53a480665713",
    "entry": "平伏",
    "reading": {
      "primary": "へいふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prostrating oneself (in submission, respect, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "徳兵衛「へへー」と平伏した。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）　やがて、　取次の侍が、恐る恐る出て来て、其の場にペタリと平伏した。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝団九郎の室　武蔵を伴って亭主が団九郎の前に、　平伏して、頼み込んで居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その侍、ハハッ、と平伏して「知らぬ事とは申せ無礼の段平に」と謝まった。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平伏して居る家臣一同（百名ばかり）。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠍が沢山の手をついて平伏して薬をのみそれから丁寧にお辞儀をします。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　くじらが頭をかいて平伏しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に汝が心にもこれにて可しと思へるか」と御尋に、はツと平伏して、「私不調法にていたし方ござなく、其が精一杯に候」と額に汗して聞え上ぐる。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆守幸豐君、御手を膝に置き給ひ、頭も得上げで平伏せる彼の何某をきつと見て、「よくものを考へ見よ、汝が常に住まへる處、知らず、六疊か、八疊か、廣さも十疊に過ぎざるべし。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌しくまうつむけに平伏す）ははッ、大権現様、御免なされ下さりませ、御免なされ下さりませ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は吻と息を吐いて、肌を納めようとした手を動かすに遑なく、きゃッといって平伏した。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "潰されたままにたいした憤慨もせずに平伏してゐざりよる。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまがえるはすっかり恐れ入って、ふるえて、すきとおる位青くなって、その辺に平伏いたしました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古火鉢と、大きな細工盤とで劃って、うしろに神棚を祀った仕事場に、しかけた仕事の鉄鎚を持ったまま、鏨を圧えて、平伏をなさると、――畳が汚いでしょう。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "むむ、何しろ一番｜糺明て見ようと、掌を高く打鳴らせば、ややありて得三の面前に平伏したるは、当家に飼殺しの飯炊にて、お録といえる老婆なり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この屠犬児恐しき家業には似もやらで、至極｜実体者、地に平伏し、「唯今は御慮外をいたしまして、恐入ってござります。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御帰館――」と叫ぶにつれ、老婦人｜衝と出でて、式台に成らせたまえば、一同眼の覚めたる心地して、万歳を哄と唱え、左右にずらりと平伏するを、見向もせで、足疾に仏室の内、隔の障子を閉切りたまいぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲目は、あかい手絡をかけた、若い女房に手を曳かれて来たが、敷居の外で、二人ならんで恭しく平伏した。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧は前に彳んだのを差覗くように一目見て、「わッ、」　とばかりに平伏した。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と惜気もなく、前髪を畳につくまで平伏した。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると船頭は、良寛さんの足元にばたつと平伏したので、良寛さんはびつくりした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」去年の夏にも、私はこの娘さんと同じ年恰好の上品な女中を兄の長女かと思い、平伏するほどていねいにお辞儀をしてちょっと具合いの悪い思いをした事があるので、こんどは用心してそう言ったのである。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの私だったら、この種の原稿の依頼に対しては汗顔平伏して御辞退申し上げるに違いないのであるが、このごろの私は少し変った。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿河の局さまは、一瞬醜い泣顔になり、それから胸に片手をあて、突き刺された人のやうに悶えながら平伏いたしました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、和田左衛門尉さまは、はつと平伏なさいましたきりで、額の皺に汗をにじませ、しばらくは何も言上できぬ御様子でございましたが、やがて、例の訥々たる御口調で、甚だ唐突に、故右大将家御挙兵以来の義盛さま御自身の十数度にわたる軍功を一つ一つならべ立てたのでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて士卒三人おそるおそるお庭の片隅にまかり出まして、そのうちの一人が少し進み出て、赤皮縅の鎧、葦毛の馬の武者一騎あざやかに先登かけて居られました、と申し述べ、たちまち義村さまは平伏なされ、忠綱さまは得々としてあたりを見廻しました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "才兵衛は松の木を引き抜いて目よりも高く差し上げ、ふと座敷の方を見ると、鰐口が座敷で笑いながらお酒を飲んでいるので、ぎょっとして、これは鬼神に違いないと幼く思い込み、松の木も何も投げ捨て庭先に平伏し、わあと大声を挙げて泣いて弟子にしてくれよと懇願した。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といかめしい口調で言い、御奥へ引上げる城主に向って平伏し、「やれやれ、馬鹿どもには迷惑いたす。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と式部は平伏する。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで源三は抵抗もせずに、我を忘れて退いて平伏したが、もう死んだ気どころでは無い、ほとんど全く死んでいて、眼には涙も持たずにいた。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
