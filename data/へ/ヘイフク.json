  {
    "uuid": "9f49f016-98c5-562e-a3d5-367e2f28a476",
    "entry": "平復",
    "reading": {
      "primary": "へいふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "restoration to health",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶まで断ちて、わが平復を祈りたまふ母の今日また何か怒れる。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶まで断ちて、わが平復を祈りたまふ　母の今日また何か怒れる。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "一箇月の療養と看護とで平復退院。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくし、これはとおもいまして、お肩をもんでおりました手をやすめて、「はゞかりながら、おさっし申しあげております」と、おぼえずへいふくいたしました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまあよいといたしまして、わたくしまでがおめしにあずかりましたので、おざしきのそとのいたじきにかしこまってへいふくいたしますと、「おゝ、坊主、おれのこえをおぼえているか」と、いきなりおことばがかゝりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
