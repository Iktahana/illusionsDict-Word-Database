[
  {
    "uuid": "59ac4532-4f64-53d3-89d6-0db8a5c59315",
    "entry": "反閇",
    "reading": {
      "primary": "へんばい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
