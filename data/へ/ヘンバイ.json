    "definitions": [
      {
        "index": 1,
        "gloss": "ceremony performed by a sorcerer to protect a noble setting out on a trip",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人長が左右左と足踏みするのは、三拍子の法を書いた条を見ても訣る如く、これは反閇の単純なものらしいのです。",
              "citation": {
                "source": "神楽（その二）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ軾が常に用ゐられるのは円座と同じ用途なのですから、それを蹴るといふことに或不調和を感じてかうした説を立てたのでせうが、我々が畳莚は座る為に用ゐてゐながら、又、反閇の範囲を模型式に示すことがあるのを思へば訣る筈です。",
              "citation": {
                "source": "神楽（その二）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　中心行事――反閇・花の行事・物語り花祭りの中心になつてゐるものは色々あります。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽と習合した事から、一層複雑になつたのだと思はれますが、現在行はれてゐるものを見てゐますと、其最中心になつてゐるものは反閇です。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三河ではへんべと言うてゐますが、此は、昔から、陰陽道の方でやかましい方式で行つてゐるのですが、反閇の本道の精神は、陰陽道でやるものではなく、その家の主人がやるべきものだつたのです。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "反閇の踏み方にも、色々種類があつたらうと思ひます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花祭りでは、此反閇を、主に鬼が踏みます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今では、反閇だけが中心の様になつてゐますが、嘗ては物語りの盛んだつた時代もあつたと思はれます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此鬼が、鎮魂に来たしるしに反閇を踏む、其威力が村全体に及ぶと考へたのであります。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "主としては、中臣祓をしに出る禰宜が、神楽をすゝめる為に諸国を廻つたと言ふ物語りと、山から鬼が来て反閇を踏む霜月の行事、それにまう一つ花育ての行儀と、此三つが重つて居るので、翁の方は軽く見ていゝと思ひます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、太夫が反閇を踏むに似た様な舞をする外は、太夫「して」かけあひ、或は同音で謡ふのである。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山三郎の表芸は、恐らく「立謡」を主要部とし、反閇流の舞台漫歩の形を持つた幸若舞にあつたものと思ふ。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも其間にやはり、古い意義を存して、天子外出の時の方法としての警蹕・反閇の形を、少しく大きくして、新室ほかひのない宴遊をしたものと考へられぬでもない。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "声楽方面には、曲舞・田楽・反閇などの及ばぬ境地を拓いた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸若太夫が「日本記」と称する神代語りを主とするのは、反閇の謂はれを説くためである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿楽に翁をおもんじ、黒尉の足を踏むのも、家及び土地の祝言と反閇とである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことほぎは舞よりも、わざの方ではあるが、宮廷の踏歌や、社寺の曲舞に、反閇の徘徊ぶりが融合して、曲舞の一つとなつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安朝末から武家時代の中期にかけて、陰陽家の大事の為事の一つは、反閇であつた。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も土御門流の唱門師の末などで、反閇を踏んで、家の悪霊退散の呪ひをする者がある。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "反閇は一種の「大殿祭」の様なもので、「新室ほがひ」の遺風であらう。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は曾て、偉鑒門外で警蹕をかけ、反閇を行うた神楽のあつた事を想像する。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に本末顛倒して、神楽の為に時を設ける様になつたが、結局神楽は、元宮廷内で発生したものでなく、冬期の祭日に、外から入り来る異人の反閇所作であつた事が考へられる。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯大倭宮廷に古くあつた鎮魂術の形式上の制約に入つて、舞踏を主として、反閇の効果を挙げようとしたのが、かぐらであり、「言ひ立て」によつて、精霊を屈服させようとする事と、精霊が「言ひ立て」をして、服従を誓ふのと、此二つの形を一つにごつたにして持つものが、「ほかひ」であつたとは言へる。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿楽能に於ける翁は、此言ひ立て・語りを軽く見て、唱門師一派の曲舞（の分流）から出て、反閇芸を重くした傾きがあります。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後に、反閇の千歳が出て、詠じながら踏み踊る。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、殆ど、反閇及び踏み鎮めの舞ばかりを、幾組も作つてゐるのです。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、鬼は退散させられないで、反閇を踏む事になつてゐて、此辺の演出は正しいものなのです。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、幸若の舞ひぶりなるものは、地固めの舞ひ（即、反閇）から生れたもので、足ぶみをして舞ふものなのである。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯一つの聲で、警※を發し、反閇した。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
