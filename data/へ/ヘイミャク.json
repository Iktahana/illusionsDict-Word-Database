        "examples": {
          "standard": [
            {
              "text": "医師は患者の手首に指を当て、「乱れのない平脈ですのでご安心ください」と微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "激しい運動の直後だったが、数分休むとすぐに平脈に戻り、彼の心肺機能の高さがうかがえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "東洋医学の診断において、平脈は健康状態が良好であることを示す重要な指標とされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "何遍験しても平脈ではない。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
