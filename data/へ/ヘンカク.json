[
  {
    "uuid": "aeb5a089-d64e-5c24-998c-cf533134baf5",
    "entry": "変格",
    "reading": {
      "primary": "へんかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
