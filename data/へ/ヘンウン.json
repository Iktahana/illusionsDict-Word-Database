        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空は片雲なく、地は霜柱白銀のごとくきらめく。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋天片雲無きの日にここへ来たのは没怪の幸であった。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は山角に波まんとして空際の片雲色殊に鮮かなり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りつゞきし雨、路上に微泥をとゞめて、空さりげなく、片雲だになき好天氣、日影ほか／＼と暖きに、醉さへ加はりて、陶然として歩す。",
              "citation": {
                "source": "小金井の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋天片雲無きの口にここへ来たのは没怪の幸いであった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い、ぼかし絵のようなその海を背にして、深谷氏の船室が白々と輝き、風が出たのか白い柱の上空を、足の速い片雲が夥しく東の空へ飛び去っていた。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分風が強くなったと見えて、相変らず足の速い片雲の影が、芝生の上に慌だしい明暗を残して掠め去る。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日こそは、と朝起きて仰ぐ空には片雲もなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "予もいづれの年よりか片雲の風にさそはれて漂泊のおもひやまず。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅がなつかしくもある、秋風が吹きはじめると、風狂の心、片雲の思が起つてくる、……しかし、私は落ちついてゐる、もう落ちついてもよい年である。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして片雲が帆走っていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹糸のような片雲であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、そのおり天頂を振りあおぐと、色も形もない、透きとおった片雲のようなものが見出されるであろう。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片雲を仰いで風雪を知り、巷語を耳にして大勢を算す、唯大なる眼の人たるを要す。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して一鳥｜過ぎらず片雲駐まらぬ浅碧の空を、何時までも何時までも眺めた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予もいづれの年よりか、片雲の風にさそはれて、漂泊のおもひやまず……　間もなく、四名の人々は喧ましい活気を運んで帰宅した。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて山に片雲なく空気は飽くまで透明に、南の桔梗色に染められた秩父連山を除けば、赤城榛名は言うに及ばず、遠い上信界の山まで雪の肌が鮮に冴えて、山が近寄って来たのではないかと訝る程である。",
              "citation": {
                "source": "山と村",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜の九時頃から空が明るくなって、十一時頃には片雲も止めぬ快晴となり、皎々たる満月に照されて、近き上河内岳の巨体は、深沈な大気の中にすき透るような蛍光を放っているかのように想われた。",
              "citation": {
                "source": "大井川奥山の話",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は蒼々と澄み返り、呼べば答えを返しそうに片雲を浮かべて静まり返り、不断に火を吐く大日輪はその中ほどに燃えている。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇み立ったお藤が、源十郎とともに、だんだん小さくなる栄三郎をめざして小走りにかかると、すうっと片雲に陽がかげって、うそ寒い紺色がはるか並木の通りに落ちた。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天片雲なく、天気清朗、極めて爽快を覚ゆ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天洗うがごとく、四面片雲を見ず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入りて帰船すれば、一天片雲なく、満月檣頭にかかり、虫声露光、あたかもわが三五の明月を望むがごとく、壮快極まりなく、吟情勃然として動く。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日片雲なきも、水蒸気の空中に満つるありて、清朗ならず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに天涯遠く晴れて片雲なく、清朗の北天に旭日を懸け、その光気の海水に映射する光景は、言亡慮絶の妙趣を実現せり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天片雲なきも、また星光を認めず、全く白昼なり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに一天片雲なく、没後残光をとどめ、夜半なお余明あり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入りて一天片雲なく、明月ひとり皓々たり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "予もいづれの年よりか、片雲の風にさそはれて、漂泊の思ひやまず……」　周知のごとく芭蕉の「奥の細道」の冒頭であるが、これは大和古寺巡礼の際における私の御詠歌として選んだのである。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
