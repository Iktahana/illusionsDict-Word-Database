[
  {
    "uuid": "38389237-da91-56dd-a1b3-cd126741c90e",
    "entry": "兵学",
    "reading": {
      "primary": "へいがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "military science",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また兵学に精通し、敬神家で、槍は一代に冠絶し、春日の名槍を自在に繰り、剣をよくして、備前｜長船小豆長光二尺四寸五分の大刀を打ち振うのであるから、真に好個の武将である。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマ帝国のさまざまな官職に在る間に、兵学、歴史、文法、修辞学、自然科学等に関する数多の著作をなしたが、残存しているのはその“Naturalis historia”数十巻のみである。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵学校の方から空車が一つ出て来て、ゆる／＼と西の方へ行つた。",
              "citation": {
                "source": "追儺",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "有時性の散乱心とは、今日法律を学んでいるかと思えば明日は医学を学ぶ、今月文学を修めているかと思えば明月は兵学を修めている、というようなことである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネルソンは英国海軍兵学校の入学試験に於いて、その体格が悪いといわれて落第した人ではないか。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業生の大半は、陸軍士官学校と海軍兵学校を志願した。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄広瀬中佐はまだ兵学校の寄宿生であった。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷地の選定もきまり、兵器廠と一緒に兵学寮創設の案を立てて、その設計図の調製を終った大村はほっとした気持でくつろぎ乍ら、鴨川にのぞんだ裏の座敷へ席をうつして、これから一杯と、最初のその盃を丁度口へ運びかけていたところだった。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その長男の英介は数学の天分が桁外れに抜群で、攻玉社中学を二年から四年へ飛んで卒業すると、海軍兵学校に無試験で入学した。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、後に彼は兵学校を受けたが、近視眼のために不合格だつた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷三好坂に塾を構え兵学の講義をいたしおる者」　すると槍の武士が一｜揖した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵庫｜前名を弥左衛門といい、尾羽打ち枯らした浪人であったが、その器量に眼をつけたのが、由井民部助正雪で、兵学講義に参上する、紀伊頼宣公へ推薦した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかというに由井殿とは、懇密の中で兵学の門下！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリードリヒ大王とナポレオンの用兵術を徹底的に研究したクラウゼウィッツというドイツの軍人が、近代用兵学を組織化しました。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇二年のボンナール『独仏高等兵学の方式について』には「ジョミニーの論述する如き一般原則から敷衍せる戦法の系統は謬妄、危険で絶対に排斥すべきもの」と言っている。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三門に天文、数学、博物学、医学、兵学、農学。",
              "citation": {
                "source": "蠹魚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏原という卒業生の非常な秀才が海軍兵学校に入学していたのが、急性肺炎で亡くなったと聞くと、校長は、がっかりしたように、「惜しいことだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋思想の真先に輸入されたのは宗教思想（すなわちクリスト教）であったが、それに次いで医学、化学、物理学、植物学、兵学などが輸入されたのであったけれども、明治の初年に至って、哲学、論理学、心理学など、先覚者のはじめて注意するところとなって、思想界に清新の気運を喚起してきたのである。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "序論",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰勝の嫡子｜重光は家を継いで、大田原政増、清勝に仕え、二男｜勝重は去って肥前の大村家に仕え、三男｜辰盛は奥州の津軽家に仕え、四男｜勝郷は兵学者となった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍在籍中にまとめた論文でワシントン大学から博士号を得た直後の一九七二年、キルドールは兵学校の掲示板で、インテルの４００４の「チップ上のコンピューター――二五ドル」という広告を見た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時義家は家来たちに向かって、「がんの乱れて立つ時は伏兵があるしるしだということは、匡房の卿から教わった兵学の本にあることだ。",
              "citation": {
                "source": "八幡太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊８　少年兵　兵士の息子で、生まれるとから軍籍に編入され、少年兵学校に於いて軍隊教育を施されていたもの。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は兵学校へはいったものの、いつか一度は自然主義の作家になることを空想していた。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず兵学校を卒業してからもモオパスサンの小説などを愛読していた。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "君を海軍兵学校に入れてやるというのはその人さ……」　中学生は今一度真赤になった。",
              "citation": {
                "source": "人間レコード",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "極端を論ずれば兵学の外に女子に限りて無用の学なしと言う可き程の次第なれども、其勉学の程度に至りては大に注意す可きものあり。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを形容していえば、軍人が兵学校を卒業して正に戦場に向いたる者の如し。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧田と私とは、兵学校以来の親友で、喧嘩一つした事がないのですから。",
              "citation": {
                "source": "猿",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして兵学の道場を開いて、天下に向うのだ。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
