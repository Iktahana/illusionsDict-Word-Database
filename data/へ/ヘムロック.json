        "examples": {
          "standard": [
            {
              "text": "このログハウスは、木目が美しく耐久性のあるカナダ産のヘムロック材をふんだんに使って建てられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ソクラテスが処刑された際に飲まされた毒薬は、ドクニンジン（ポイズン・ヘムロック）の絞り汁だったと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ホームセンターの木材コーナーで、DIY用に加工しやすいヘムロックの板を数枚購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "樫の大木の枝々には不思議な木の実が、古い松の木から垂れるヘムロックのように、灰色して力なく、動きもせずに垂れていた。",
              "citation": {
                "source": "女王スカァアの笑い",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            }
          ]
        }
