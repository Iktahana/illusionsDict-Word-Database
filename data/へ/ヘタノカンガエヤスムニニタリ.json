        "examples": {
          "standard": [
            {
              "text": "素人がいくら企画を練っても、下手の考え休むに似たりで結局プロの案には敵わなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "迷路で道に迷ってしまい、立ち止まって悩んだが、下手の考え休むに似たりですぐに歩き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "知識がない分野について議論しても下手の考え休むに似たりなので、まずは本を読んで勉強しよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "わたしも虫眼鏡を持っててくてくあの五階まで行ってみましたが、下手の考え休むに似たりで、もうあなたがすっかり調べてお帰りになったあとでしたよ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七　下手の考え休むに似たりとか云いますから、思い立ったらすぐに取りかかって、なんとか早く埒をあけてしまいましょうよ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その尾について、ほかのひとりが、「夜が明けるぞ、夜が」「下手の考え休むに似たり。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
