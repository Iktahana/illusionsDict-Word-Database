        "examples": {
          "standard": [
            {
              "text": "プロレスラーが相手の首に強烈なヘッドロックを決めると、会場から割れんばかりの歓声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "兄弟喧嘩の末、兄が弟をヘッドロックで押さえ込み、ようやく降参の合図を出させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "悪役レスラーはレフェリーの目を盗んで、反則気味のチョークが混ざったヘッドロックで締め上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつもなら、ここでヘッドロックか、コブラツイストでもかけにいくところだが、体力を使い果たしたところに不安が重なったので、完全に力が抜けて、慶一は教壇に腰をおろしてしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "と真顔できくワラに、慶一は電光石火のヘッドロックをかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いま、なにかが、おれの首んとこを……」　山崎が、慶一にヘッドロックをかけた状態で、フォールにもちこもうとするかのように、力をいれた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれのアイディアなんだよ、このヴィデオはさ」　慶一は、これがあることを知っていて、半年のあいだ、なにもいわなかった高志に、ヘッドロックをかけようとしたが、思いなおした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギターを肩にかけていることも忘れて、慶一は服部にヘッドロックをかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　位置の関係から、しかたなく慶一は、左腕でヘッドロックをかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十を目前にした男たちが、笑いながらヘッドロックをかけたり、かけられたり、ボディブロウを喰らわせたりしているので、二〇メートルもない道程が、急流の横断のように感じられる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
