    },
    "definitions": [
      {
        "index": 1,
        "gloss": "third division of the night (approx. 11pm to 1am)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "不好な處へいや／＼ながら出かけて行くのかと怪まるゝばかり不承無承にプラツトホームを出て、紅帽に案内されて兔も角も茶屋に入つた。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな、薄汚い新聞記者と、喧嘩させて、だまつて面白がつて見てゐやがつて、僕は、あんなやつとは、口きくのさへいやなんだぜ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、その臭ひをかぐのさへいやだと云ふ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、あなたにさへいやみや皮肉をおつしやりさへしなければ。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かに――と云ふことだけはおしげによく解つてゐた、母親と、義理の父と云ふのさへいやな、母親の近頃の連れあひ新吉とに対する意地からにちがひなかつた。",
              "citation": {
                "source": "一の酉",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがいつからともなく彼女は、私の両親や人のいない時に限って私の前へいやに立って見せるようになって来た。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネッドは、油の海へいやというほど顔をおしつけられた。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、今、ものをいふことさへいやなんだ。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけ覚えとけよ」　と、さも憎々しげに云つてから、彼女のシュミイズの肩へいやといふほど噛みついた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時分になって、ようやくこの場へのさばり着いて、そうして、着くと早々、お角さんの方へいやな眼をつかって、キザな笑い方をしながら、またもその鼻っ先へ盆蓙を敷いてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく名人戰の會場になつた白山の「もみぢ」といふ家は庭に沿つて東から南へいやに長い建物であるが、晝間の勝負が差しかけになつて棋士が寢るときは、木村は、東の一ばん端れの部屋に坐し、大山は南の最端の部屋を取り、どつちも極力遠くへ離れて眠ることを希望してゐたといふ。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
