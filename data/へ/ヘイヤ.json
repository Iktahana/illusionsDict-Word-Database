  {
    "uuid": "32324735-8faa-5497-8535-5b54be3175a8",
    "entry": "丙夜",
    "reading": {
      "primary": "へいや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
