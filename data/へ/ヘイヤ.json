[
  {
    "uuid": "0f23ab6d-dba6-5684-a9de-384a9fc0634c",
    "entry": "平野",
    "reading": {
      "primary": "へいや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
