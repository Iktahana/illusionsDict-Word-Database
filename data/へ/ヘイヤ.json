    "definitions": [
      {
        "index": 1,
        "gloss": "plain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は津軽平野のまんなかに生れたので、海を見ることがおそく、十歳くらいの時に、はじめて海を見たのである。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者は東京に住んで居ながら、故郷上州の平野の空を、いつも心の上に感じ、烈しく詩情を敍べるのである。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり車窓に目醒むれば汽笛は闇に吠え叫び火焔は平野を明るくせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "久遠に輪※を斷絶するもああかの荒寥たる平野の中日月我れを投げうつて去り意志するものを亡び盡せり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後に楢の林を負ひ、周圍みな平野の麥畠に圍まれたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の植物景観が関東平野のそれと著しくちがうのが眼につく。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして谷底まで下りた人の多数はそのままに麓の平野を分けて行くだろうし、少数の人はそこからまた新しい上り坂に取りつきあるいはさらに失脚して再び攀上る見込のない深坑に落ちるのであろうが、そのような岐れ路がやはりほぼ四十余歳の厄年近辺に在るのではあるまいか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "登りつめると綺麗な芝を植ゑた斜面から玉川沿の平野一面を見晴す事が出來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東国の北部の平野は広かった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野のどこからも眺められるその山は、朝は藍に、昼はよもぎ色に、夕は紫に色を変えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の国の平野が目の下に望まれた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野に雲の海があるとき、霞棚引けるとき、それ等を敷莚にして、幽婉な寝姿が影となって望まれる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の障子を開けた外は重なった峯の岨が見開きになって、その間から遠州の平野が見晴せるのだろうが濃い霞が澱んでかかり、金色にやや透けているのは菜の花畑らしい。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはやや湿地がかった平野で、田圃と多少の高低のある沢地がだるく入り混っていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北上川沿岸の平野には稲が一面に実って、もう刈入れるばかりになっているように見える。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北上川の蛇行水路の右岸の平野に低湿の沼沢地が一面に分布しているのは不思議である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼の一神教的哲学は茫漠たるロシアの単調の原野の民には誠に恰好なものであり、満洲や支那の平野に極めてふさわしいものでなければならない。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のどん底から山の下の平野の空へ向って鉄路が上向きに登っているから、恰度大砲の中から打出されたような心持がして面白い。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒暖二様の空気が関東平野の上に相戦うために起る気象現象である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野ではこれと反対に旧道の曲線を新道の直線で切っている場合が多いのである。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか道灌山へ夏目先生と二人で散歩に行った時、そこの崖の上で下の平野を写生していた素人絵かきがあった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（金は憲坊に頼みました）先づ平野屋のいもぼうの缶詰（ッてのがあるそうです）黒のとろろこぶ、花かつを、懐中じるこ、甘酒の素、なるせの漬物とほーじ茶。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "『その時は日がもうよほど傾いて肥後の平野を立てこめている霧靄が焦げて赤くなってちょうどそこに見える旧噴火口の断崖と同じような色に染まった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "河の流れをたどって行く鉛筆の尖端が平野から次第に谿谷を遡上って行くに随って温泉にぶつかり滝に行当りしているうちに幽邃な自然の幻影がおのずから眼前に展開されて行く。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一と月後には下の平野におとずれるはずの初秋がもうここまで来ているのである。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、黄河を迂回して、側面からここを圧迫する馮玉祥の騎兵部隊と、泰山の南を縫うて、明水平野に出た陳調元の優勢な一部隊に圧迫せられ、又、戦わずに、界首と、黄河の線を抛棄した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上卑俗で薄汚い平野の眺めはすぐに私を倦かせてしまった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野は見渡す限り除虫燈の海だった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄明りの平野のなかへ、星｜水母ほどに光っては消える遠い市の花火。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海と雲と平野のパノラマがいかにも美しいものに思えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
