    "definitions": [
      {
        "index": 1,
        "gloss": "military affairs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仍つて早く返し遣る者なりとなれば、旧堵に帰着し、兵事を忘却し、弓弦を綬くして安居しぬ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天慶二年十二月十五　　　　　　謹※上　太政大殿少将閣賀恩下　此状で見ると将門が申訳の為に京に上つた後、郷に還つておとなしくしてゐた様子は、「兵事を忘却し、弓弦を綬くして安居す」といふ語に明らかに見はれてゐる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "中臣氏、斎部氏が、朝廷の祭祀を司り、物部氏、大伴氏が武将として兵事に当り、弓削氏が弓の製造に従事し、玉造氏が玉の加工に当つたやうなものである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此部は事と法とに約して判すれば、事の部で、理論や主張が説かれてあるのでは無く、全く兵事を説いたもので、防禦對敵の施爲を傳授したものである。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『松屋筆記』に引ける『蓬※日録』に、〈およそ兵事を達するには、急に能く風雨を致し、囲を突きて走り、けだし赭丹を有って身に随く、赭丹は馬腹中に産するところの物、これを用いて念呪すなわち風雨を致す〉と載せた赭丹も、蒙古名シャダーの音訳だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵器廠設置の案はとにかくとして、士族の特権だった兵事の権を、その士族の手から奪いとろうとした国民皆兵主義の提案は、忽ち全国へ大きな波紋を投げかけた。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊公が面会して兵事を談じると、彼は議論縦横、ほとんど常人の及ぶところでないので、楊公は大いにこれを奇として、わが帷幕のうちにとどめて置くことにした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊公も怪しんで、試みに兵事を談じてみると、ただ茫然として答うるところを知らないという始末である。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "村役場の兵事係りが夜に日をついで、その命令を各戸に伝達すると、二十四時間にその管下に集まらなければならない壮丁たちは、父母妻子に別れを告げる暇もなく、あるは夕暮れの田舎道に、あるは停車場までの乗合馬車に、あるは楢林の間の野の路に、一包みの荷物をかかえて急いで国事におもむく姿がぞくぞくとして見られた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の柵内には町長だの兵事係りだの学校生徒だの親類友だちだのが集まって、汽車の出るたびごとに万歳を歓呼してその行をさかんにした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "中學の門と斜に向ひ合つて、一軒の理髮床があつたが、其前で何日かしら菊池君を見た……否、アレは市役所の兵事係とか云ふ、同じ級の友人のお父親の鬚だつたと氣がつく。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学の門と斜に向ひ合つて、一軒の理髪床があつたが、其前で何日かしら菊池君を見た……否、アレは市役所の兵事係とか云ふ、同じ級の友人のお父様の髭だつたと気がつく。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "国防献金ももはや問題とならない（但し恤兵事業等は郷党の心からなる寄附金による事が望ましい）。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから此方じゃ、区長、兵事掛。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵事義会の重立ち、何でも礼服を着た方が三｜方か四｜方送って下すった。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に兵事義会から十円……それから大将の屋敷から十円、秋山大尉の親御から五円……何でも一切で百円はござんしたろう。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方と秋山さんの親御が、区役所の兵事課へ突然車をおつけになって、小野｜某と云う者が、田舎の何番地にいる筈だが、そこへ案内しろと仰ったそうです。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵事課じゃ、何か悪いことでもあったかと吃驚したそうでござえんすがね、何々然云う訳じゃねえ、其小野某と云う者の家に、大瀬上等兵の親御がある筈だ、その老人に逢わしてくれと云うんで、その時そのお二方は、手前とこまでお訪ね下すったが、私は外へ出ていてお目に掛りませんでした。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日に「新兵事件」の判決文が来て、いささか驚かされた。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "成善と倶に東京に来た松本｜甲子蔵は、優善に薦められて、同時に十五等出仕を命ぜられたが、後兵事課長に進み、明治三十二年三月二十八日に歿した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡役所の兵事係が二人腹減らして待つてはるんや。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "村役場の兵事係や村總代も提灯を振り照らしつゝ出て來た。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "守は文治を、尉は兵事を掌り、監はその監察をする。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "擅興律は兵事に關する諸々の取締のことであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人は村の兵事係であった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へいじゃあない、小六さんたあ何だ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「云わないことか、それ、こんなに埃が立つじゃないの、しっかりおしよ」「へい」「へいじゃないよ、ほんとだよ」「へい」　平吉は平気で胡蓙を敷いた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の心得　石膏の胸像をば画面の中央へいじける事なくまた実物よりも妙に大きくならぬよう、ほぼ実在の大きさを想像させる位いの、のびやかさを以て画面の中央へ行儀よく描くべき事。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それって、ふこうへいじゃないかい？",
              "citation": {
                "source": "サンタクロースがさらわれちゃった！",
                "author": "A KIDNAPPED SANTA CLAUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
