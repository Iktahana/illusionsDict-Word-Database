    "definitions": [
      {
        "index": 1,
        "gloss": "military system",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この戦に於て所謂百姓兵の為すある事があり、徴兵制度の根本が確立したのである。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ又近頃｜禁軍の檢閲ありしを聞きつと噂すれば、彼は希臘の兵制を論じて、マケドニア歩兵の方陣の操錬を細敍すること目撃の状の如くなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "受験制度や徴兵制度を改革できるものは、ここから逃げ隠れできない若者だけだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の国体論や兵制論については不同意であります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由（則チ差別觀）ヲ忘レテ只觀念的平等ニ立脚シタル時代ノ社會主義的理想家ハ國民ニ徴兵制ノ如ク勞働強制ヲ課セント考ヘシコトアリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "卷八　國家ノ權利徴兵制ノ維持。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "國家ハ國際間ニ於ケル國家ノ生存及ビ發達ノ權利トシテ現時ノ徴兵制ヲ永久ニ亙リテ維持ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在及ビ將來ノ領土内ニ於ケル異民族ニ對シテハ義勇兵制ヲ採用スル者アルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "而モ此ノ故ヲ以テ「ヴェルサイユ」會議ニ於テ英米ガ傭兵制度ヲ日本ニ強ヒタルハ何タル迷妄ゾ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "徴兵制度ノ形式ハ獨佛ニ學ビタルモ、徴兵制度ノ精神タル國民皆兵ノ義務ハ、中世封建ノ期間ヲ除キテ、上世建國時代ニ發源シ更ニ現代ニ復興シテ漲溢シツツアル國民的大信念ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "徴兵制其者ガ直ニ所謂軍國主義ニ非ザル事ハ、徴兵制ナリシガ故ニ辛ウジテ獨逸ヲ防止スルヲ得タル佛蘭西ガ、會議ノ人々ヨリ軍國主義ナリシトテ攻撃セラレザリシガ如シ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ軍國主義ガ、單ニ自己ガ問題外ナル傭兵制ナリト云フノ理由ヲ以テ、他ノ徴兵ニヨリテ斯ル軍國主義者ノ侵害ヲ防衞セントスル者ニ己ノ冠ヲ冠セントセシハ惡ムベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "是レ徴兵制ヲ明確ニ永久ノ制度ナリトセル所以ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "只獨逸ガ最後ニ破レタルガ故ニ徴兵制ノ價値ヲ疑フハ非常ナル妄斷ナルコトヲ注意ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "特ニ獨逸ノ實戰シタル軍隊ハ徴兵制ノ佛蘭西ト露西亞ニシテ、甲ノ徴兵國ガ乙ノ徴兵國ニ破ラレタリト云ヒ得ベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "新たに建設された満洲国はどんな兵制を設けるか知らないが、在来の制度や組織を変革して、よく教えよく戦わしむれば、十分に国防の任務を果たし得る筈である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にかえりますが、こうして兵制が乱れ政治力が弛緩して参りますと、折角ローマが統一した天下をヤソの坊さんに実質的に征服されたのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は特に十字軍の影響を受けて地中海方面やライン方面に商業が非常に発達して、いわゆる重商主義の時代でありましたから、金が何より大事で兵制は昔の国民皆兵にかえらないで、ローマ末期の傭兵にかえったのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "国の滅亡に直面して、革命の意気に燃えたフランスは、とうとう民衆の反対があったのを押し切り、徴兵制度を強行したのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "１、傭兵制度　十八世紀の戦争は結局君主が、その所有物である傭兵軍隊を使用して自己の領土権利の争奪を行なった戦争である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし列強の攻撃を受け戦況不利になったフランスは一七九三年徴兵制度を採用する事となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "徴兵制度に依って多数の兵員を得たのみでなく、自由平等の理想と愛国の血に燃えた青年に依って質に於ても全く旧国家の思い及ばざる軍隊を編制する事が出来た。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に正確にいえば、ドイツ模倣の一年志願兵制度が日本社会の実情に合しない結果であったのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに特権制度として一年志願兵制度が発達し、しかもその価値を発揮したのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "全健康男子総て従軍する事となった今日は既成の観念よりせば国民皆兵制度の徹底であるが、既に世は次の時代である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりでは、帝国主義の戦争ヒステリーにかかったものたちの上ずった大声がこの次の戦争には日本の人民を利用することができる、傭兵制を考えられる、とわめきたてている。",
              "citation": {
                "source": "この三つのことば",
                "author": "――わたしたちは・平和を・欲している――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて一方には国権論派ともいうべきもの起こり、中央集権の必要を説き、陸海兵制の改正を説き、行政諸部の整理を説き、主として法制上の進歩を唱道せり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
