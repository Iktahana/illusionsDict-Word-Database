        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "他のへっぽこ占ないは駄目よ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "へっぽこ部長だ、お前は。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ルコックは哀れなへっぽこだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "あってもへっぽこ悪事、動機が見え透いているから、スコットランド・ヤードの刑事どもでも見破れてしまう始末だ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばへっぽこレストレードの発見だが、あれは単なる目くらましで、社会主義者か秘密結社をにおわせて、警察を誤った方へ向かわせたいだけだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "へっぽこな親父をもったより骨が折れる。",
              "citation": {
                "source": "墓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "へっぽこ詩人の女郎奴、貴様がついて来たら本当にこの僕の天外な像が分っただろうに、莫迦な女郎奴と彼は心の中で文素玉を憎々しげに罵った。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、俳優の立派であるか、へっぽこであるかということは、それは決して舞台の上にあがって、ある役を演じてはじめてわかるのではない。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女、三杉磯がひいきで、三杉磯がへっぽこの間、夜は女とねて、昼は掃除もするというようにして居たが、そろそろ売り出すとこんな婆より新橋の方がいい。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく仕事を休んで、うまいものを食ってごろごろしていれば癒ってしまう」　医務室のへっぽこ医者にわかるわけはないのだ。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして創作する者は感じても差支えないと思うような人は、へっぽこだからです。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "或るへっぽこ医者は冷水浴療法を僕にすすめたし、やや気の利いた他の医者はドーナウの例の温湯浴をすすめた。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吉良領がどうしたんだ、忠臣蔵のへっぽこ芝居にたぶらかされている奴等におれたちの気持がわかってたまるもんかい、よし、ひと口でも吉良上野の悪口をたたいてみやがれ、そのままにしておくものか」　青年たちは三人五人と肩を組んで、祭礼があるごとに他領へ押しかけていった。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "博物館でとらえたのは、あれは二十面相でもなんでもない、ただのへっぽこの野郎だったということを、世間に広告するようなもんじゃないか。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
