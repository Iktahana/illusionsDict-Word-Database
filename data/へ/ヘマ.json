        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "教練の度毎にヘマをやつて小隊長や分隊長に小言を云はれ續けだつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時には、片岡直温のヘマ振りまで引っぱり出して猛烈に攻撃する。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初から狙っている本はチャントきまっているんですが、直ぐにその本の処へ行くようなヘマは決してやりません。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん売付ける新聞紙は別に刷らしていたから、警察に睨まれるようなヘマは一度もしなかった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際私に危害を加えるような、ヘマな相手でない事がハッキリと直感されたから……。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄まアして……」「嘘を吐けこの野郎……手前等の眼につくようなヘマをやるけえ」「だって本当だよ……小父さん……青い帽子を冠って、白い服を着て、小ちゃな写真機を持ってたよ」「フーン。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは西洋で初めて食道鏡を使った時の失敗談で、手先の器用な日本人だったら、あんなヘマな事をする気遣いはありませんよ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とにも角にも、どこまでも慎重に……慎重に取りかからねばならぬ……あくまでもヘマをやってはならぬ……。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エエ、モウ　スグ、オンモガ　ミラレマス」ト　ホカノ　ツボミガ　コタヘマス。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホントウニ　ソウデスヨ、ワタシモ　ハヤク　ボウヤニ　コノ　ヨイ　セカイヲ　ミセテ　ヤリタクテ　タマリマセン」ト　ウマハ　コタヘマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マダ　ヒラカナイ　ツボミサン　モウ　ハルデスヨ、オンモニ　デテ　イラツシヤイ」「マダ　ネンネシテル　ツボミサン　オメメヲ　サマシナサイ」　スルト　ツボミガ　コタヘマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アツチノ　ハウデ　ウツクシイ　ヤサシイ　コヱガ　ワタシヲ　ヨブカラデス」ト　ソノ　タケノコハ　コタヘマシタ。",
              "citation": {
                "source": "タケノコ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イエイエ、ワタシハ、アナタノ　フイテ　イラツシヤツタ、ソノ　フエノ　コヱガ　アンマリ　ヨカツタノデ、コツチヘ　サソハレテ　キマシタ」ト　タケノコハ　コタヘマシタ。",
              "citation": {
                "source": "タケノコ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソラヨ」ト　カアサンノ　デンデン蟲ハ　コタヘマシタ。",
              "citation": {
                "source": "デンデンムシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミチコサン新美南吉　ミチコサンガ、コトリヤノ　マヘマデ　クルト、シラナイ　オバサンガ、ウバグルマノ　ナカノ　ニモツヲ　ナホシテ　ヰマシタ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ、「エエ、ケツシテ　シマセン」ト　コタヘマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶キャプテンが会計のヘマを演じて、合宿の費用を学校から取れなくなってしまったのだそうだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　とヘマを言って、ああ厭味だと思って、冷汗を掻いた処を、（お人が悪いよ、子持だと思って、）　これにまたヒヤリとしたように覚えている。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はもう三日後になってるんだから、おくれてるんですぜ』と、白水は、その切り株があわてて、ヘマな返事をすることだろうと思って、引き取って答えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ギ　ンサクキリコブ　ジ　イヘマルヤケ』　越えて十三日にまた同文のものが『ゴテンバ』局發で來た。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をやらしてもヘマばかりするところに道節の人間味がある。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳も児供の時から画才があって、十二、三歳の頃に描いた襖画が今でも川越の家に残ってるそうだが、どんな田舎の百姓家にしろ、襖画を描くというはヘマムシ入道や「へへののもへじ」の凸坊の自由画でなかった事は想像される。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことは大の好き、折角お目鑑に叶ったものをヘマしちゃならねえ。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこで落ち合うたのじゃ」「遠藤主計頭様はなんしろ御大名、ヘマを踏んで引ッくくられでもしちゃ大変だから、その時はお屋敷へしらせてお殿様にお救い願おうと存じまして、万一の用意にと、床新さん達に用のすみ次第、あちらへ廻って貰ったんでござんす。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おれが、バレるようなヘマをするっていうのか？",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私が裏切り的に庚戌会に出席した事を、電話か何かで探り知った彼女は、狼狽の余り、おなじ日に、おなじ種類の患者を二度も私にブツケルようなヘマな手段でもって、私と白鷹氏の会見を邪魔しようと試みたものであろう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その私のお友達の方は頭のいい、決心の強いお方ですから、この最後の一通を押えられるようなヘマな事は決してなさらないでしょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなヘマな相手には引っかかりませんよ」　とか何とか威張る新しい令嬢があるかも知れぬが、そんなお方は前に掲げた「少女のラブレター」を今一ペン読み直して頂きたい。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
