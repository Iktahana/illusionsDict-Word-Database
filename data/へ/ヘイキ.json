[
  {
    "uuid": "4dc4bbfb-fd82-50bb-b7b1-9bcd957286e6",
    "entry": "併記",
    "reading": {
      "primary": "へいき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "writing side by side",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それだから年号と年数と干支とを併記して或る特定の年を確実不動に指定するという手堅い方法にはやはりそれだけの長所があるのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは前に塩田｜良三の生れたことを記したから、此に柏軒門下にして共に現存してゐる松田｜道夫の此年に生れたことを併記して置く。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "著作権の表示には、マイクロソフトと日本電気の両社名を併記する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚も一人の鑑定人は高工教授の佐藤氏で、之は四、五日遅れて十月二十九日の公判廷へ呼び出されているのだが、便宜上ここへ併記して置こう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばソラマメはソラマメでよろしく、なにも煩わしく蚕豆と併記する必要はない。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに、本書中に迷信を併記せるも、そのほかになお迷信に関する事項はすこぶる多ければ、他日、さらに「迷信集」を編述する心算なり。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、その迷信にさらに種々の迷信を付会して、妖怪を解釈するありさまなれば、ここに迷信の題下に各種の妖怪をも併記することにする。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし気に入らなければ、「変更した」旨を併記した上で、〈道理〉を〈法〉や〈掟〉、あるいは〈定め〉や〈正義〉に置換してもらってもかまわない。",
              "citation": {
                "source": "道理の前で",
                "author": "VOR DEM GESETZ",
                "note": "青空文庫"
              }
            },
            {
              "text": "218の句と併記されていることから推定した。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして宮本武蔵、无何と俳号氏名が併記してあるが、さてどういうものであろうか。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい太郎は、いちばんはじめに、いちばん近くの、くわ畑の中の金平ちゃんの家へいきました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「仕方ありませんからそこを出て村の居酒屋へいきなり乗り込んであった位の酒を瓶詰のもはかり売のも全部片っぱしから検査しました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいぢや、海の方へいきませう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と弥助さんは向かふへいきかけた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんは物置のそばをはなれて、向うへいきかけますと、どこかで、いわしを売る声がします。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの日には、ごんは山で栗をどっさりひろって、それをかかえて、兵十の家へいきました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちは遠くへいき、「もういいかい。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「んでも、徳やん、さっきおっかンといっしょに、半田の方へいきよったぞ」と、兵太郎君はいって、つよいかおりをはなっているほし草のところへ近づき、なかばころがるようにもたれかかった。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "くまつかいの五郎が、ようかん色になったビロードの上着をつけ、長ぐつをはいて、シュッシュッとむちをならしながら、おりのそばへいきました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし坊をよくいじめた酒屋の三ちゃんがいてもいいのってきいたらね、三ちゃんがいても、学校へいきたいって。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤井先生は黒板のうらがわにかけてある竹のむちを持って、つかつかと石太郎のところへいき、いいかげんにしとけと、むちのえで、石太郎のこめかみをこづかれる。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギンはこわごわそばへいきました。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は間もなく馬に乗って、二人で向うの家へいきました。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウイリイはその大男をつれて王女のお城へいきました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟人はこつそりと、泉の岸をつたはつて、三人の着ものがぬいであるところへいきました。",
              "citation": {
                "source": "星の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "星の女はそれを聞くと、すゐれんの花をつなぎ合せて花の着物をこしらへて、それでからだをつゝんで、猟人のところへいきました。",
              "citation": {
                "source": "星の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さまは、「それでは、これから私と一しよに、おまへの大好きな赤ん坊と、あの二人の弟たちのところへいきませう。",
              "citation": {
                "source": "星の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すゞちやんは、とき／″＼あき子叔母ちやんのおひざにだかれて、ぽつぽのかごのところへいきました。",
              "citation": {
                "source": "ぽつぽのお手帳",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめはどうしても面会を許されませんでしたが、さんざんにねだりたのんで、やうやく聞きとゞけてもらひ、役人につれられて、イワンのそばへいきました。",
              "citation": {
                "source": "ざんげ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人甲から先に起って蒲留仙の前へいき、蒲留仙の汲んだ茶を取って飲む。",
              "citation": {
                "source": "涼亭",
                "author": "――序に代へて――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
