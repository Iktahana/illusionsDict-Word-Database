        "examples": {
          "standard": [
            {
              "text": "出口の見えない不況が続き、社会全体に重苦しい閉塞感が漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若者たちは都会の閉塞感から逃れるように、地方での新しい生活を模索し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この会社での毎日は、まるで見えない壁に囲まれているような閉塞感がある」と彼は漏らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "〈ここでは何も作れない〉　松本はＰＣ―８００１の誕生に、希望よりはむしろ閉塞感を覚えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "推理小説のような」「別人になると解放感があるだろうか」「それも人によりますね」「なにもなさすぎて、逆に閉塞感を強く感じるかもしれない」「それまでとはまったく別な人生を作っていくのですから、それこそ真に創造的なことかもしれませんよ」　真に創造的なこと、と福山は言った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
