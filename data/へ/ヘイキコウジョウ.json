        "examples": {
          "standard": [
            {
              "text": "郊外にあった大規模な兵器工場は、終戦とともに閉鎖され、今は跡地だけが残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "戦時中、多くの民間人が徴用されて兵器工場での過酷な労働に従事させられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "敵の爆撃部隊は、真っ先に海岸沿いの兵器工場を標的として破壊した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それは兵器工場なんです」と、耳うちした。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵器工場があるというのだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この広い兵器工場を見終ったときには、三根夫はすっかりくたびれてしまった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "川沿いの平地を埋める各種兵器工場の煙突は白煙を吐き、街道をはさむ商店街のいらかは紫の浪とつらなり、丘の住宅地は家族のまどいを知らす朝餉の煙を上げ、山腹の段々畑はよく茂った藷の上に露をかがやかせている。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど兵器工場の前を自転車で走っているとき、妙な爆音を聞いたような気がした。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
