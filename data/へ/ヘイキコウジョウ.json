          "literary": [
            {
              "text": "それは兵器工場なんです」と、耳うちした。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵器工場があるというのだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この広い兵器工場を見終ったときには、三根夫はすっかりくたびれてしまった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "川沿いの平地を埋める各種兵器工場の煙突は白煙を吐き、街道をはさむ商店街のいらかは紫の浪とつらなり、丘の住宅地は家族のまどいを知らす朝餉の煙を上げ、山腹の段々畑はよく茂った藷の上に露をかがやかせている。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど兵器工場の前を自転車で走っているとき、妙な爆音を聞いたような気がした。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
