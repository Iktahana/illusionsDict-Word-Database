[
  {
    "uuid": "9f79ea92-71e6-5725-a95f-8a3ff0ccb8c1",
    "entry": "閉塞",
    "reading": {
      "primary": "へいそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
