[
  {
    "uuid": "2eece7c2-3a27-56fc-ae6d-8e0fa515c960",
    "entry": "兵威",
    "reading": {
      "primary": "へいい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "military power",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "時に帝諸将士を誡めたまわく、昔蕭繹、兵を挙げて京に入らんとす、而も其下に令して曰く、一門の内自ら兵威を極むるは、不祥の極なりと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔兵威を振ひて天下を取る者は、皆史書に見るところ也。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "織田信長の兵威をもってして、如何に本願寺の宗徒、或は伊勢長島、三河の一向一揆に手を焼いたかを見てもわかる次第だ。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "拿破崙が戰略、ブリユツヘルが兵威こそ大勢を左右することを得つるなれ。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人民が欧州の文化に向かって伏拝したることはまさに欧州諸邦の人民が仏国の兵威に向かって伏拝したると同一般なり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマの建国は、たといロムルスの兵威と戦勝とに依ること多かったとしても、これに次ぐにヌーマの立法をもってするに非ずんば、到底他日の世界帝国の基を開くことが出来なかったに相違あるまい。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵威をも示されるであろう。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリのガール・デュ・ノールでは誰だか知らない人が書式へいい加減のことを書いてくれてそれで万事が滞りなくすんだのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、傷が癒えると、少尉から上司へいい報告がして貰える。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こうして、文六ちゃんのほか、子供たちは何か一つのことを、耳から耳へいいつたえました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父の故右大将だつて、頭でつかちなもんだから京都へ行つたとたんにもう、大頭将軍といふ有難くもないお名前を頂戴して、あんな下賤の和卿などにさへいい加減にあしらはれて贈り物をつつかへされたり、さんざん赤恥をかかされてゐるんだ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ばかしじゃない、貴方だって責任がおありじゃありませんか」　こう言われてみるとなるほど先方へいいかげんな返事をするのもいかがなものである。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門は突然しかるように、伝六へいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　帰りがけに、Ｂ―はそう言ってまた一ト銚子｜階下へいいつけた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かわからないところへいい気持ちにひろがって行ってしまう。",
              "citation": {
                "source": "雨と子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、その時、我善坊の方へいいハガキが屆いた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場合、風景の中を撰択の為めに走り廻る事が面倒臭いからと云って、いい加減の所へいい加減の木を附け足して見たり、でたらめの人物を描き添えて見たりする人もあるが、これはよほど熟達した人でない限りは大変危険である、人間の顔の道具を勝手に置きかえて化物とする様なものである。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場合、風景の中を選択のために走り廻ることが面倒臭いからといって、いい加減のところへいい加減の木を付け足してみたり、でたらめの人物を描き添えてみたりする人もあるが、これはよほど熟達した人でない限りは大変危険である。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、ともかく部落は全滅したということにして、あることないこと大嘘をこき混ぜて、マコンデの部落へいい触れさした。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸髷の女がまた暖簾から出て来て、元の席へ行きながら、彼の方へいいたてた。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、おおむのポーリーに餌をやり、ちんの毛をくしけずり、足のわるいおばさんの用事を、なん度も召使のところへいいにいったり、階段をのぼったりくだったり、それがやっとすむと、勉強をさせられます。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへいいぐあいに君が飛びこんで来てくれたので、君に診察を依頼したというわけだったんだよ。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、悪口を世間へいいふらしました。",
              "citation": {
                "source": "春はよみがえる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全だ」「その代り世間へいい触らすがいいか」「ナニいい触らす？",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んでもない事だ、何んでもない事だ」彼は自分へいい聞かせた。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより俺はお前へいいたい、お前こそもう少し元気を出して、ことを大胆に振る舞うがよい。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉門は唇を舌でしめしたが、かなり辛辣な口調をもって、こう左内へいいつづけた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで妾はお前さんへいいたい。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だからお前へいいつけたのではないか。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、先生のところへいいつけに行った。",
              "citation": {
                "source": "身体検査",
                "author": "ソログーブ・フョードル",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
