      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "change",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こういったような心像変換の現象は少なくもわれわれの夢の中には往々起こる現象であっておそらく何人も経験するところであろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、そういう捉われた頭を変換さすために仏教の禅語で「橋は流れて水は流れず」というような奇妙な言葉を、わざと言い出して、ちょっと人の気を抜くのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に絵や写真、動画、音などいろいろな形の情報も、今はすべてデジタルに変換できる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした機能を使って、電子本は声で読み上げたり、点字に変換したりできるようになるだろう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターによる翻訳も、一種のデータ変換かもしれない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーザーディスクの音声トラックに、音に変換したプログラムを入れておく。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "視覚障碍者は、音声に変換して聞く。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした一般的なパソコン点訳の流れに対して、ＢＢＡの作業フローは、漢字仮名交じりの原文データをコンピュータに変換させ、少ない手間で直接点字データを得ようとする形で描かれていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ目の音訳は、文章を音声データに変換することをいう。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファイル形式の変更が求められる機種向けの変換ツール、ファイル名の付け替えツールなど、それぞれの環境での使い勝手を良くする小道具も、そろってきている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、複数の変換候補からそのつど選んでいく方式で、パソコンにおける日本語入力が広く普及したように、修正しながら作業することを前提に、新しいタイプの点訳ソフトの活用も広がって行くだろう。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "LaTeX 文書に変換して自分のサーバに置くのはどうだろう。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "総合研究所で基礎研究の進められていた仮名を漢字に変換する技術を生かし、大型よりは一回り小振りのミニコンピューター（と言ったってパーソナルコンピューターに比べりゃクジラよ）をベースに、漢字仮名交じり文の作成機を商品化するプロジェクトが第一。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワープロの仮名漢字変換部分を切り離し可能とし、他のソフトでも使えるようにした一太郎が一九八五年の十月にでたときには、「ああこんな手があったのか」とオレは腰を抜かした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "単漢字変換のイージーワード　１・０版は「これじゃ売り出しても勝負にならんわ」というわけでデビューには至らず、一九八五年九月、五百字までの一括変換をサポートするバージョン２・１で初めて発売となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百字の一括変換が結構まともに動作するのには、当時感心した覚えがある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前に約束をして置いて、今更｜変換を為るのは、何とも気の毒だが、これに就いては私も大きに考へたところがあるので、必ずお前の為にも悪いやうには計はんから、可いかい、宮は嫁に遣る事にしてくれ、なう」　待てども貫一の言を出さざれば、主は寡からず惑へり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "〇・〇三二だけ軽くなって、その重さに相当するものはどんな形に消滅してしまうのかということを考えてみますのには、これはじつに勢力に変換せられることがわかりました。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "真正の宗教は自己の変換、生命の革新を求めるのである。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　或いは「十銭の持つ財的エネルギーとして、他のエネルギーに変換出来る。",
              "citation": {
                "source": "白銅貨の効用",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一次欧州大戦から次の大変換即ち最終戦争までの持久戦争期間は、この勢いで見れば、すこぶる短いように考えられる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラウゼウィッツは大王の戦争を、一七五七年を会戦の戦役、一七五八年を攻囲の戦役、一七五九―六〇年を行軍および機動の戦役、一七六一年を構築陣地の戦役、一七六二年を威嚇の戦役、と称しているが、戦争力の低下に従って止むなく逐次戦略を変換して来た。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "又この三次元は変換し得る（transformierbar）性質を持つ。",
              "citation": {
                "source": "空間概念の分析",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この交換性と変換性に於て等方性の概念の生じる基礎があるのである。",
              "citation": {
                "source": "空間概念の分析",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが知っている力とは変換されるのみである。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史のある時期におこる飛躍と質の変換を理解しなかった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第九巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに大阪、田井中、恩地の線を、甚しい方向の変換と行程の延長とを避けて、大和境に向けて引いて見ると、亀瀬峠は南に偏し、十三峠は北に偏してゐて、恩地と相隣してゐる服部川から信貴越をするのが順路だと云ひたくなる。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "作表機の時代と同様八〇パーセントを超えるシェアを誇るＩＢＭに対し、わずかな残りを他社と分け合っていたハネウェルは一九六三年、ＩＢＭ機の性能を大きく上回るＨ２００を、１４０１用に書かれたプログラムをそのまま利用できるよう変換するソフトウエアと合わせて発表した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
