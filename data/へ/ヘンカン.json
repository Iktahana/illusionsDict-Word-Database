[
  {
    "uuid": "b9bb1a47-fd09-5d8f-8439-6466c6c893b8",
    "entry": "変換",
    "reading": {
      "primary": "へんかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
