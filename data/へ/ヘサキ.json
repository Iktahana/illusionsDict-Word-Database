    "definitions": [
      {
        "index": 1,
        "gloss": "bow (of a ship)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "半七と庄太は舳先に乗った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭は馴れているので平気で棹を突っ張ると、今日はふだんより流れのぐあいが悪かったとみえて、急に傾いてゆれた船はたがいにすれ違う調子をはずして、向うから来た船の舳先がこっちの船の横舷へどんと突きあたった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて船頭はその離れて動いてゐる綱を引張つて、舳先の方に行つて、それをそこに結びつけた。",
              "citation": {
                "source": "船路",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丁堀の伝六親方を知らねえかッ」　まことに伝六の名声広大とも広大――といいたいが、実は八丁堀といった啖呵がものをいったとみえまして、通りすがりの伝馬船が倉皇としながら舳先を岸へ向けましたので、ふたりはひらりと便乗――まだ混乱のままでいる現場へこがしていってみると、しかるにこれがすこぶる奇態です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒金の船の舳先よ、岬代赭色に、獅子の蹈留れる如く、足を延べたるこゝ、入海のひたおもて、うちひさす都のまちは、煩悶の壁に悩めど、鏡なす白川は蜘手に流れ、風のみひとり、たまさぐる、洞穴口の花の錦や。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂寞大海の禮拜して、天津日に捧ぐる香は、淨まはる潮のにほひ、轟く波凝、動がぬ岩根、靡く藻よ、黒金の船の舳先よ、岬代赭色に、獅子の蹈留れる如く、足を延べたるこゝ、入海のひたおもて、うちひさす都のまちは、煩悶の壁に惱めど、鏡なす白川は蜘手に流れ、風のみひとり、たまさぐる、洞穴口の花の錦や。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お爺さん、あんなことを言はなけりや好いのに――折角、心地よく連れて来てやつたのに』　隣の老人が舳先の方に行つた跡で、主婦は老爺に小声で言つた。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮吹は舳先からうち上つて奔騰し、私たちの鐵兜の上からざざつと瀧のやうに降りて來る。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟は前後に激しくピッチングをやり又左右にひどくローリングをやり、今にも波の中に舳先を突込みさうであり、また舷を海水が乘り越えてきて、今にも沈みさうに思はれた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の舳先に掻分けられた波は船尾の方まで白い泡となつて湧き立ち、はるか後方まで白い航跡を引く。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛魚が船の舳先から、横から、ぴよんぴよんと幾つも幾つも飛出す景色はまことに愛らしく又滑稽である。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が舳先から吹いてゐる時は甲板にゐても非常に凉しいが、風が變つて船の後から吹くと、甲板にゐても風があまり吹かない。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪太郎は、うむうむと合点して舫纜を解くと、舳先に立つて竿を構へ、弟は艫の座席に着いて発動機のスヰツチをいれた。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから云ふまでもなく、海原は青鏡で、ただ、波を蹴たてて滑つて行く舟の舳先で砕ける飛沫が鮮やかに白く光るより他に目を射るものもないのだ。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鴎丸は、舳先におしたてた公園の瓦斯灯のやうに巨大な新しい誘魚灯の手入れをしながら、あの日に、あまりの永雨で気をくさらせてゐる連中が誰を憎むといふわけでもなしに（つまり天を憾んで――）あられもない大立廻りの喧嘩が始まり、樽野が奇妙な仲裁役になつてしまつたことを云ふのであつた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この舟の舳先は壊れていました。",
              "citation": {
                "source": "手紙",
                "author": "一八九三年七月二二日付　チェンバレン　宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "舳先に歩哨の銃剣が燭火のように光っている。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い翼に風を切って、高く遠く飛ぼうとするのである」純一はこれを聞いていて、その語気が少しも荘重に聞かせようとする様子でなく、依然として平坦な会話の調子を維持しているにも拘らず、無理に自分の乗っている船の舳先を旋らして逆に急流を溯らせられるような感じがして、それから暫くの間は、独りで深い思量に耽った。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "舳先には二人の小者が坐つてをる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にその寺院の屋根に似たダダッ広い額の斜面と、軍艦の舳先を見るような巨大な顎の恰好の気味のわるいこと……見るからに超人的な、一種の異様な性格の持主としか思えない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は手製の爆弾と巻線香を持って舳先に立ち上るのだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と思ううちに、その舳先に仁王立ちになった向う鉢巻の友吉おやじが、巻線香と爆弾を高々と差し上げながら、何やら饒舌り初めた。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は舳先に見る月の清らなること昨日に異らず候。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、彼女は舳先の方に蹲んだまま、ただその円らな瞳を二三度瞬いたきりである。",
              "citation": {
                "source": "植物人間",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、照れたように後の洋子を振りかえって見ると、彼女は、まださっきのままに舳先に腰をおろしてい、真黒な瞳をあげて、川島の汗の泌出た背中をジッと見詰めていたようである。",
              "citation": {
                "source": "植物人間",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或夜は黒きわたつみの上、片手に乱るる裾をおさへて、素足のまま、君が大船の舳先に立ち、白き蝋燭の銀の光を高くさしかざせば、滴る蝋のしづく涙と共に散りて、黄なる睡蓮の花となり、又しろき鱗の魚となりぬ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫓は舳先や艫に三、四挺あるが、櫓で運ぶという事は、よくよく順潮の時に少しやるだけで、もっぱら帆によって行く事になっている。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃から舳先に當る初島は藍鼠色より萌葱色に近くなりました。",
              "citation": {
                "source": "初島紀行",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそのお月さまの船の尖った右のへさきから、まるで花火のやうに美しい紫いろのけむりのやうなものが、ばりばりばりと噴き出たからです。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそのお月さまの船の尖った右のへさきから、まるで花火のように美しい紫いろのけむりのようなものが、ばりばりばりと噴き出たからです。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
