        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ロードバイクのハンドリングが少し重く感じたので、ヘッドセットのベアリングをグリスアップした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "フレームを新調したついでに、剛性の高いチタン製のヘッドセットを組み込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "段差を越えるたびにヘッドセットからカチャカチャと異音が鳴るので、ショップで見てもらうことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
