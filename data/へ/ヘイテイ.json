[
  {
    "uuid": "18c4f7fd-fc27-5b54-b77f-a1b5a3908480",
    "entry": "平定",
    "reading": {
      "primary": "へいてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
