      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suppression (of a rebellion, civil war, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "直訳なら「平和化」で、先ず「平定」とでも訳する所であろうが、とにかくフランス人らしい巧妙な措辞である。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "サロンを平定した私、フレデリックの桃色に化粧した爪先に唇を当てて、千九百二十年後の女性の進歩した足を観察する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "西南戦争に出征していた父が戦乱平定ののち家に帰ったその年の暮れに私が生まれた。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳の上ではそれほどでもないが、廊下のような板敷きへかかると船の傾きを踏み試めすような蛙股の癖が出て、踏み締め、踏み締め、身体の平定を衡って行くからである。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから藤原氏三代百余年間の平泉の栄華があり、文治五年、源頼朝に依つて奥州は平定せられ、もうその頃から、私たちの教科書はいよいよ東北地方から遠ざかり、明治維新にも奥州諸藩は、ただちよつと立つて裾をはたいて坐り直したといふだけの形で、薩長土の各藩に於けるが如き積極性は認められない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜田博士は、さらに奥羽の沿革を説き、「頼朝の奥羽平定以後と雖も、その統治に当り自然他と同一なること能はず、『出羽陸奥に於いては夷の地たるによりて』との理由のもとに、一旦実施しかけた田制改革の処分をも中止して、すべて秀衡、泰衡の旧規に従ふべきことを命ずるのやむを得ざる程であつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに東北が平定して官軍も凱旋した。",
              "citation": {
                "source": "掠奪した短刀",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月は斎藤九郎兵衛が京都から浅野長政等の書を持って来て、いよいよ関東奥羽平定の大軍が東下する、北条征伐に従わるべきである、会期に違ってはなりませぬぞ、というのであった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時秀吉は笑って、おれは弓箭沙汰を用いないで奥羽を平定して終うのだ、汝等の知るところでは無い、と云ったというが、実に其辺は秀吉の好いところだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "新規平定の奥羽の事、一揆騒乱など起ったる場合は、政宗は土地案内の者、政宗を先に立て案内者として共に切鎮めよ、という命令を下して置いた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此年の夏、南部の九戸左近政実という者が葛西大崎などのより規模の大きい反乱を起したが、秀次の総大将、氏郷の先鋒、諸将出陣というので論無く対治されて終い、それで奥羽は腫物の根が抜けたように全く平定した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "命はそこから、なおどんどんお進みになって、いたるところで手におえない悪者どもをご平定になり、山や川の荒くれ神をもお従えになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　おん母上の皇后は、ついで熊襲をも難なくご平定になって、いよいよ大和におかえりになることになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅馬がこれを平定したとき、羅馬から Padua に通ずる本街道だけに磔柱六百を數へたさうである。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に異母兄に当る織田信広や、岩倉城主織田信安等の叛乱があったが、みな信長に平定せられた。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "願文は武井入道｜夕菴に命じて作らしめたと伝うるもので、「現今の世相混沌たるを憂えて自ら天下を平定しようと考えて居ます処、義元横暴にして来り侵して居ます。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "願わくば天下の為に神助あらんことを」と云った意味のものであるが、果してこの様な願文を出したかどうか多少怪しい処はあるが、この戦をもって天下平定の第一歩であると考えて居た事は疑あるまいと思われる。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州、瀬戸内海、大和地方にかけて、既に御稜威の下に、欣んで帰順する者も多かつたが、事理を解せぬ蛮民も多く、途中に於ても、それらに対する警戒平定に、多くの日時を費されたことと思ふ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰服はぬ者こそ、平定したが、天つ神の子孫が、この中つ国を支配すべき名分を信じて帰順したものには、最大の仁慈を垂れたまうたやうである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和地方を悉く平定せられた後、「夫れ大人の制を立つる、義必ず時に随ふ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十二代｜景行天皇の御代になると、朝廷の稜威は国内に於ける群小の土豪どもを悉く平定せしめて、たゞ西に熊襲、東に蝦夷の二族を残すだけになつた＊。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二族の平定者として、日本武尊の御名が美しく輝いてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "越えて天正十八年三月、自ら大軍を率ゐて北條氏を小田原に攻囲して之を滅し、関東を平定したが、その陣中に、奥羽の雄伊達政宗が来降し、こゝに天下は全く統一したのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "島原征伐がこの年から三年前寛永十五年の春平定してからのち、江戸の邸に添地を賜わったり、鷹狩の鶴を下されたり、ふだん慇懃を尽くしていた将軍家のことであるから、このたびの大病を聞いて、先例の許す限りの慰問をさせたのも尤もである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村重成ら決死の出陣に香で身を燻じた人多く、甚だしきは平定文容姿言語一時に冠絶し「人の妻娘｜何に況や宮仕へ人は、この人に物いはれざるはなくぞありける」（『今昔物語』）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハヌマン味方の創を治せんとて薬樹を北海辺に探るうち日暮れて見えぬを憂い、その樹の生えた山を抱えて飛び返るとて矢に中った時、この二物を塗って疵癒え、楞伽平定後、獲た物を以て子分の猴卒どもに与え尽した時、またこの二物のみ残ったからだ（『グジャラット民俗記』五四―一五六頁）。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地方が初めて平定した時、四方を巡回して南山の深いところへ分け入ると、日もようやく暮れかかって来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢の桑名に松平定綱といふ殿様があつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "「油売り松並荘九郎がともかくも美濃を平定し斎藤道三と宣る浮世だ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーランドやトルコの軍を破り、プガチョフの乱を平定し、後、フランスのイタリア侵略を阻止した功によりイタリア政府より公爵を授かる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
