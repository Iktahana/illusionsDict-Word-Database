        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「私のこと、へちゃむくれだと思ってるんでしょ」と彼女は不貞腐れて言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "昔のアルバムを見返すと、そこには見事なへちゃむくれの自分の顔が写っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "クラスの男子からへちゃむくれとからかわれた彼女は、泣きながら家に帰った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "老いぼれの、田舎者の、わからずやのへちゃむくれめ、次永喜兵衛は心の中でそう罵っていた。",
              "citation": {
                "source": "霜柱",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
