          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "肝試しで一番に逃げ出すなんて、お前は本当にへちゃむくれだな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "あの社長は普段は威張っているくせに、クレーム対応になるとへちゃむくれになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "こんな少しの段差で怖がるなんて、うちの犬は案外へちゃむくれなのかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
