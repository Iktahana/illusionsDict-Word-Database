        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それよりもうなのごと山山のへっぴり伯父さ呉でやるべが。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、山山のへっぴり伯父。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西根の山山のへっぴり伯父は月光に青く光って長々とからだを横たへました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西根の山山のへっぴり伯父は月光に青く光って長々とからだを横たえました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆島と高松を往復する一〇〇｜噸足らずのボロ汽船であったが、彼の石炭のいれ方がちゃちだから船が進まんと、罐の前でへっぴり腰を蹴り飛ばされた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてな、ここらに色鳥の小鳥の空蝉、鴛鴦の亡骸と言うのが有ったっけと、酒の勢、雪なんざ苦にならねえが、赤い鼻尖を、頬被から突出して、へっぴり腰で嗅ぐ工合は、夜興引の爺が穴一のばら銭を探すようだ。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮足立つ所孫右衛門、「糞ッ」　というが早いか、十文字槍をもってへっぴり腰に突いてかかった三助へ斬込んで一太刀肩へ斬込んだ。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "味方のフランス式伝習隊の兵を見ると、旗本のへっぴり侍ばかりで薩摩のイギリス仕込みだって、これと同じだろう。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よしきた」　森君はへっぴり腰になって片足を浮かしてかまえた、もし足にあたりそうな球がきたら片足をあげて逃がそうという腹なのである。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいですか、本気をだしますぞ」「よしッ、虫けらの本気はどんなものか、へっぴり虫！",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の両の掌は、へっぴり腰を立てた酔眼の棟梁を殴りつけていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "船員も乗客も、みょうな、へっぴり腰で、ゆかの上をごそごそはいまわっていた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そんなに遠くでへっぴり腰をしていないで、近くへ寄ってよく見ろ」　清五郎は首を差しのべておずおずと眺めてから、「いかにも、こりゃア赤腹」　アコ長はニヤリと笑いながらとど助のほうへ振りかえり、「とど助さん、少々妙ですな。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蠑※",
                "note": "青空文庫"
              }
            },
            {
              "text": "「花もなくて」　歌いながら、へっぴり腰も面白く、飛立つように身も軽く一舞いした。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつらはへっぴり腰で、大げさに腰をふりふり突貫する。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "肱を水平にし、へっぴり腰でふらふらと歩いてくる一人が彼に声をかけた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "足だけひいて、へっぴり腰で打つのなら、恐ろしくない。",
              "citation": {
                "source": "柔道と拳闘の転がり試合",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へっぴり腰だぞ……」と誰かが呼びかけた、「おっかあを……んじゃあるめえし、しっかり腰を伸ばしてええべや」　高くて広い浴場の空間が、ばかげた哄笑でわれ返るような反響を起こした。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
