[
  {
    "uuid": "2de162d2-f356-531e-8908-cc8e14abc2b8",
    "entry": "兵営",
    "reading": {
      "primary": "へいえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
