          "standard": [
            {
              "text": "ヘブライ文字は右から左へと読まれるという特徴があり、初めてアラビア語以外の言語でそのルールを知って驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "エルサレムの旧市街の看板には、独特の四角い形をしたヘブライ文字が英語と並んで書かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "趣味でカリグラフィーを始めた彼女は、アルファベットだけでなく美しい装飾が施されたヘブライ文字の書き方も練習している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「そうなんだ熊城君、君は猶太人が、ヘブライ文字の※からまでに数を附けて、時計の文字盤にしているのを見たことがあるかね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブナの木にきざまれたヘブライ文字は、こういう意味である。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
