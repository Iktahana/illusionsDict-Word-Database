[
  {
    "uuid": "5b34e860-0a46-59f1-9c32-2e4779b7d0ea",
    "entry": "返礼",
    "reading": {
      "primary": "へんれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
