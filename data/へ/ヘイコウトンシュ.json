    "definitions": [
      {
        "index": 1,
        "gloss": "being at a complete loss as to what to do",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "取引先から到底実現不可能な短納期と大幅な値引きを同時に要求され、営業担当者はただ閉口頓首するしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "宴会の席で上司から昔の自慢話を延々と聞かされ、部下たちは愛想笑いを浮かべながら心の中で閉口頓首していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "初めての海外旅行でパスポートも財布も盗まれてしまい、言葉も通じない路地裏で文字通り閉口頓首して座り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あれが茂木さんへ着かなかったら閉口頓首。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一口に書いたが、書いてると自分が生活して居る間に書いてるときだけ頭をこまかく働かして居ないことがわかって、閉口頓首した。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お納戸坊主が、閉口頓首して、御寝の間のお雨戸をソロソロ繰りはじめる、そのとたんを見すまし、つまり、お坊主の手が雨戸にかかるか掛からないかに、お傍小姓がお眼覚めを申し上げるのです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑さにまだ馴れなくて閉口頓首して居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお年よりの気質とものの話しかたを知りぬいているから閉口頓首、千石船もチリチリです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さもよめそうなふりをしないことを、閉口頓首の正直さとしておうけとり下さい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
