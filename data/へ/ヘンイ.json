[
  {
    "uuid": "a65e67de-e978-53fa-8398-41b5cfc68d52",
    "entry": "変位",
    "reading": {
      "primary": "へんい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
