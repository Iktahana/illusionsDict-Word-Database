        "examples": {
          "standard": [
            {
              "text": "江戸時代の人々は、初めて目にする碧眼紅毛の異国人に驚きを隠せなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その物語には、碧眼紅毛の海賊が東洋の島々に辿り着く冒険譚が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幕末の街角を歩く碧眼紅毛の軍人たちは、当時の日本人にとって未知の世界の象徴だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ああ、日本にしてもしその望みなしとすれば、東洋はついに碧眼紅毛の餌食となりておわらんのみ。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど碧眼紅毛の異人種だがりっぱな風采は見るから神医の感をうける。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
