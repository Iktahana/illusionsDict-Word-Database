  {
    "uuid": "28e912a6-396b-5ce4-a3d2-5b29adb58152",
    "entry": "縁",
    "reading": {
      "primary": "へり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "edge (of a river, woods, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "牧野さんといふ人は、恋愛に殉じる態の純情家といふものとは遙かに縁遠いと思はれるからだ。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聴いて感じられるものは、はや気分でさへない、云つてみれば気分の暈縁くらゐな所かもしれない。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしともかく、それらの音楽によつて多くの人々が、好い気持にされてゐるのだから文句はないのだが、然しもと／＼気分の暈縁なぞといふオボコイものを聴いて喜んでゐる連中が取引のこととなると俄然骨ばつてくるし、而も楽々骨ばれるやうに前以て備へてゐるので、「音楽と世態」なぞと今並べてみたくなるのである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話にもならないなら、Ａにそんなこと話す方が悪いと、云ふ人もあるであらうが、それあさうに違ひなくとも、ＡとＢとの縁といふものはともあれあるのだし、実際の場合、やつぱりＢが悪いといふのは妥当でない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ、田舎の川べりにでも住んで、夏は縁台を出して夕顔の花をみてゐるといふ、あの消極的平安の中に安住しなければならないのです。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その『生得の詩人達』中の、コルビエールの篇は、四五年前、雑誌『社会及国家』に、私が訳載したのだが、文壇とは余り縁のない雑誌ゆゑ、大方は御存知ないことと思ふ。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌リュテースを編輯してゐたレオ・トレズニカは、アムール・ジョーヌと『歎き』（ラフォルグの詩集）の作者との明らかな類縁に驚いて、コルビエールに肩を持ちながら両者を比較してラフォルグを荒だてたのであつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "銘仙の袷に金紗の羽織を着、兎の毛で縁をとつたオールドローズの繻子の肩掛に寒々とくるまり、海老茶の袴を胸高く穿いてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手の籔が切れる所に来ると、右手の方に養漁場がみえ、その他は一面の田で遠く神田上水源の方の森並に縁取られてゐる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "八雲は縁側に立ってそれに聞き惚れ、『いかに面白いと楽しいですね』と言って喜んだが、また『私、心痛いです』と言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁というのは、妙なものですね。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁などというのは迷信である。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁と言ったってかまやしません。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿命と言い、縁と言い、こんな言葉を使うと、またあのヒステリックな科学派、または「必然組」が、とがめ立てするでしょうが、もうこんどは私もおびえない事にしています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、妙な縁でしたね。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水寺のすぐちかくに赤い毛氈を敷いた縁台を二つならべて置いてある小さな甘酒屋で知り合った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の恋の相手というのは逢うのに少しばかり金のかかるたちの女であったから、私は金のないときには、その甘酒屋の縁台に腰をおろし、一杯の甘酒をゆるゆると啜り乍らその菊という女の子を私の恋の相手の代理として眺めて我慢していたものであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なくらいに顕著なおでこと、鉄縁の小さな眼鏡とたいへんなちぢれ毛と、尖った顎と、無精鬚。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が赤毛氈の縁台のまんなかにあぐらをかいて坐ったまま大きい碾茶の茶碗でたいぎそうに甘酒をすすりながら、ああ、片手あげて私へおいでおいでをしたでないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながく躊躇をすればするほどこれはいよいよ薄気味わるいことになりそうだな、とそう直覚したので、私は自分にもなんのことやら意味の分らぬ微笑を無理して浮べながら、その男の坐っている縁台の端に腰をおろした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は馬場との約束どおり、午後の四時頃、上野公園の菊ちゃんの甘酒屋を訪れたのであるが、馬場は紺飛白の単衣に小倉の袴という維新風俗で赤毛氈の縁台に腰かけて私を待っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいぶかしく思いながらその後姿をそれとなく見送り縁台に腰をおろすと、馬場はにやにやうす笑いして言いだした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああ」馬場は溜息ついて縁台にごろんと寝ころがった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、昨年の秋、山田君から手紙が来て、小生は呼吸器をわるくしたので、これから一箇年、故郷に於いて静養して来るつもりだ、ついては大隅氏の縁談は貴君にたのむより他は無い、先方の御住所は左記のとおりであるから、よろしく聯絡せよ、という事であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、大隅君には友人も少いし、いまはもう私が引受けなければ、せっかくの縁談もふいになってしまうにきまっているし、とにかく私は北京の大隅君に手紙を出した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴兄の縁談は小生が引継がなければならなくなった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は久しぶりで先生のお宅へお伺いして、大隅君の縁談を報告し、ついては一つ先生に媒妁の労をとっていただきたいという事を頗る無遠慮な口調でお願いした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "互いの家系と写真と、それから中に立った山田勇吉君の証言だけにたよって、取りきめられた縁である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時頃、やっとお目ざめになり、新聞ないかあと言い、寝床に腹這いになりながら、ひとしきり朝刊の検閲をして、それから縁側に出て支那の煙草をくゆらす。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
