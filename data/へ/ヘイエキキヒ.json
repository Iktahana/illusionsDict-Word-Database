        "examples": {
          "standard": [
            {
              "text": "戦争反対を叫ぶ若者たちが、隣国へ逃れて兵役忌避を図った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "兵役忌避を助けた容疑で、地下組織のメンバーが数名逮捕された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は宗教的な信念から、処罰を覚悟で兵役忌避を選択した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼ノ兵役忌避ヲ本旨トスル「クエーカー」宗ノ如キハ、小乘教ノ基督ニ於テスラ天國ノ戰ヲ指シ、地上ニ於テ尚我レ刄ヲ出サンガ爲ニ來レリト宜シテ終ニ羅馬ヲ天火ニ亡シタル一面ヲ有スルニ係ラズ、只其ノ殺ス勿レノ一項ヲ盾トシテ盲守スルニ過ギザル者。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし彼の方は兵役忌避者であったが、司教の方は僧侶法忌避者であった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
