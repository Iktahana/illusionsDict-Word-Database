        "examples": {
          "standard": [
            {
              "text": "港の近くに巨大な兵站基地が建設され、連日大量の物資が運び込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "敵軍は我々の兵站基地を狙って、空爆を仕掛けてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "兵站基地には、最前線へ送るための食料、弾薬、医療品が備蓄されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ここを全軍の基点として、勝龍寺を後方の補給｜兵站基地とし、さらに西南方の淀から円明寺川の一線を扇なりに引いた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢中の定軍山はすなわち南鄭の要害、敵の兵站基地である。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
