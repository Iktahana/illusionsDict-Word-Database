    "definitions": [
      {
        "index": 1,
        "gloss": "cliff that stands tall like a wall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
