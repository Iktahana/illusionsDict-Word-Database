    "definitions": [
      {
        "index": 1,
        "gloss": "strange",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」ジョバンニはこんな変てこな気もちは、ほんたうにはじめてだし、こんなこと今まで云ったこともないと思ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニはこんな変てこな気もちは、ほんとうにはじめてだし、こんなこと今まで云ったこともないと思いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は助手が変てこな、ねじのついたズックの管と、何かのバケツを持って来た。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ夜中になって変てこな物音をたてる生物になってしまったのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉書へいたずら書きをした彼の気持も、その変てこなむず痒さから来ているのだった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、どうもじつに変てこなものを見たのです。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "変てこなねずみいろのだぶだぶの上着を着て、白い半ずぼんをはいて、それに赤い革の半靴をはいていたのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "変てこな鼠いろのマントを着て水晶かガラスか、とにかくきれいなすきとおった沓をはいていました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この変てこな議論が一見菜食にだけ適用するように思われるのはそれは思う人がまだこの問題を真剣に考え真実に実行しなかった証拠であります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかはり、どうもじつに変てこなものを見たのです。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、風が自分の耳元にそのやうにひそひそ囁き、さうして、いつのまにやら自分の胸中に於いても、その変てこな歌ともお念仏ともつかぬ文句が一歩一歩竹藪の下の雪を蹈みわけて行くのと同時に湧いて出て、耳元の風の囁きと合致する、といふやうな工合ひなのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去はこれ程馬鹿気て、愉快で、変てこに滑稽に通過されたのだと教えて呉れるのです。",
              "citation": {
                "source": "岡本一平著並画『探訪画趣』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二　さて子どもがふたりで自転車屋をあずかるというのはうれしいような、だが変てこなものだ。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という変てこな恰好の芸人だろう。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュピター」「石盤に数字を書いて計算してるんでがす、――わっしのいままで見たことのねえ変てこな数字でさ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋は、造りがまずく、煤で黒くなっていて、天井が低く、すべてその他の点でその時代のそのような場所と大体同じようなものではあったが、それでもその中のここかしこに陣取っている変てこな飲み助連中の評判では、十分によくその目的にかなっているものなのであった。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「好いにも、悪いにも何だか気になってならねえんでさ、変てこにこう胸へつッかけて来るんでね、その勘定の一件だ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と訊ね、わたしは単なる病気の静養者だと答へると大層酒を飲む、変てこな病人だ、お前がそれで病人なら俺だつて大病人だ、と疑つて、あはゝとわらつた。",
              "citation": {
                "source": "城ヶ島の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついて来た女将は立ったまましばらく二人を見くらべていたが、「ようよう……変てこなお内裏雛様」　と陽気にかけ声をして笑いこけるようにぺちゃんとそこにすわり込んだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは自意識の処理、小説叙法の装置――などと云うと変てこですが――について新分野を拓いてゆくものではないでしょうか。",
              "citation": {
                "source": "ある手紙",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」愛するという言葉がつかえないもんだから、興味をもつなんて、変てこな言い方をするんです。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに彼奴つたら、うつかりお湯なんかで一緒にならうものなら、おつに気どつてゐる見たいにふくれてやがる癖にして、こつちの隙を見はからつては、それあもう変てこな眼つきで、じいツとひとの方ばかりを視詰めてゐるぢやないの。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやんと、するだけのことをして種子をおろしても、似ても似つかぬ、変てこな物が生えて来るのぢや。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、なんだか変てこな心持が、留吉の心をいやに重くしはじめました。",
              "citation": {
                "source": "都の眼",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も人間が通るのに、評判を立てるほどのこともないのだが、淋しい田舎で人珍しいのと、それにこの男の姿がいかにも特色があって、そして鶩の歩くような変てこな形をするので、なんともいえぬ不調和――その不調和が路傍の人々の閑な眼を惹くもととなった。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると城之介が帰って来て、ヘラヘラ変てこに笑ったかと思うと鉄杖の中から巻軸を出し、うやうやしく献上する。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花吹雪する真っ昼間、小町の方でほれたので、おれの方でもほれてやり、かむりの笄落としたが、どうでも小町はいい女、柳の五衣に緋の袴、檜扇持ったとりなりは、官女官女官女だア……」　だんだん変てこなものになる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それはそうと、神様のことだが、島原一揆の連中には、森宗意だの蘆田忠左衛門だの、相当の人物がいたんだが、どうもね、みんな信心家で、ハレルヤ、ハレルヤ、ゼウス、ゼウス、などと変てこな呪文を唱え、神様へ頭をさげたので、とうとういくさに負けッちゃッた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おや、変てこな符号があるぞ」　二の丸と三の丸の境い目の、濠の一所にポッツリと、半分にち切れた井桁のようなものが「キ」こんな塩梅に描かれてあった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "緊張のあまり、踊りがへんてこな形になつたといふだけの事ではないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
