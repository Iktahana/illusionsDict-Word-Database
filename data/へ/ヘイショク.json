    },
    "definitions": [
      {
        "index": 1,
        "gloss": "holding a lamp in one's hand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "して見ると教えさえすれば猴も秉燭はおろか中らずといえども遠からぬほどに発銃くらいはするなるべし。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだらなの眞菰のなかに、水漬く火や、――今宵も星は、秉燭の火影に、天の戸こそまもれ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老学庵筆記、巻八）　　　　　　　（二十六）　杜詩の夜闌更秉燭、意は夜の已に深きを謂ふなり。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "崢※赤雲西、　　日脚下平地柴門鳥雀噪、　　歸客千里至妻孥怪我在、　　驚定還拭涙世亂遭飄蕩、　　生還偶然遂鄰人滿墻頭、　　感歎亦歔欷夜闌更秉燭、　　相對如夢寐　徳洪妄は更字をさらにの意に読まずに、こもごもの意に読まさうとしたものと思はれる。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            }
          ]
        }
