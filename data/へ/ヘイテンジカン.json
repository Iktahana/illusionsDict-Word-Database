    "definitions": [
      {
        "index": 1,
        "gloss": "closing hours (of a store, restaurant, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このレストランの閉店時間は22時ですが、ラストオーダーは21時半です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "閉店時間を忘れて話し込んでしまい、店員さんに促されて席を立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "連休中は通常よりも閉店時間を1時間早めて営業する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "閉店時間を過ぎていたので、客は私だけだった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで閉店時間まで粘ったやつは、出てくる頃にはもう前後がわかりません。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も胸中を打ちあけ、一同に対策を諮ったところ、店員側は何よりもまず閉店時間を、これまでより二時間延長し、日曜日も平日の時間通り営業することを希望した。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
