          "literary": [
            {
              "text": "人間は何か精神的な目標をもって緊張して居るときには、心の平静を保つ。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の平静を保つことに努めつとめて来た私もとう／＼その平静をかきみだしてしまった――だからアイヌは見るもの、目の前のものがすべて呪はしい状態にあるのだよ――。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はつとめて心の平静を保つよう注意を怠らぬであろう。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "が四谷の塩町に行くまでは自分はまだ幾分の平静を保つことができた。",
              "citation": {
                "source": "地異印象記",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
