      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "spatula",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「一円九十銭の日当の中から、日に、五十銭の米を二升食われて、九十銭で着たり、住んだり、箆棒奴！",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣の袖を襷に結び上げ、竹箆を斜に構えた僧も二三人見えます。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじは、また、郭進才の場合のように呉の床箆子の附近をさがしまわって、破った、虱のいる肌着が一枚丸めて放ってあるのをつまみ上げ、舌打ちをした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処にそれ、はじめの一冊だけ、ちょっと表紙に竹箆の折返しの跡をつけた、古本の出物がある。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "代赭色の小鉢に盛り上がった水苔から、青竹箆のような厚い幅のある葉が数葉、対称的に左右に広がって、そのまん中に一輪の花がややうなだれて立っている。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物の重いばかりでなく、箆棒に前途ばかり急いで、途中ろくろく休む事も出来ねえ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　竹如意が却って一竹箆食いそうなことを言う。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ワトソン君指先が箆のように平べったくなっているだろう、――これがこの二つの職業には、共通の特徴なんだが、しかしこちらは表情に、霊感的なところがある」　私の友人はこう云いながら、その婦人の顔を静かに、燈火の方に向けた。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "（５）ferule ――学校で、懲罰として児童を、とくにその掌を、打つためにつくられた木の箆。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、堅い紙がいったん折り曲げられて紙折り箆で押えられ、そのもと折られた同じ折目のところから反対に折り返されたときにできる折れぐあいなんだよ。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間の壁には、竹箆で土を削って、基督の像が、等身に刻みつけて描いてあった。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ黒い瓶を一具、尻からげで坐った腰巻に引きつけて、竹箆で真黒な液体らしいものを練取っているのですが、粘々として見える。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（ようゆう）ですね、老婆は、今度は竹箆を口に啣えて、片手で瓶の蓋を圧え、片手で「封」という紙きれを、蓋の合せ目へ禁しながら、ニヤリとしている。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹箆にも杓子にもならない。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えゝ、箆棒、一日の手間鍛冶屋へ打つ込んちあなくつちやなんねえ」彼は呟いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は若え衆等行くと思つてはあ、夜まで置けねえんだな」「極つてらあな」「そんだつて箆棒、若え衆等だつてさうだことばかりするものぢやねえ、詰んねえ」憤慨してかういふものも「外聞惡いも何にも知んねえんだな」嘲笑の意味ではあるが何處となく沈んで又斯ういふ者も有つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんでも、南のおつかさん行きたけりや連れてくつちつたんだぞ」「箆棒、そんなことされつかえ、踊なんざあ後幾日だつてあらあ、今夜らつから行かねえつたつてえゝから、他人に云はれつとはあ、其れに乘つてあふり／＼出たがんだから」勘次は一｜概に叱りつけた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「箆棒に大かく成つたつけな、此の馬鈴薯はなあ」一人がいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えゝ箆棒な」と相手はいつて畢つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「箆棒に迂遠つけえ唄だな、此の夜の短けえのに眠つたく成つちやあな」側から惡口を吐いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "醫者は爼板のやうな板の上に黄褐色な粉藥を少し出して、白い糊と煉り合せて、罎の酒のやうな液體でそれを緩めてそれから長い鋏で白紙を刻んで、眞鍮の箆で其藥を紙へ塗抹つて患部へ貼つてやつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「箆棒、つん燃したくつて、つん燃すもの有るもんか」爺さんは少し激して「過失だもの後で何ちつたつて仕やうあるもんぢやねえ」と獨で力んだ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも其夜ランプの下で自分の袷地を裁つて威勢よく箆をつけて居るのを見て少し心がゆつたりしたやうであつた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "職工が煉瓦の型に固めあげた粘土を、崩れないように陽で乾しながら、箆で敲き固めるのだった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘辛い樹皮の香りに魂を奪はれた彼等は、シヤベルや箆を携へては朝となく夕べとなく来襲した。",
              "citation": {
                "source": "肉桂樹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして竹箆返しに跡釜が出来たから小屋を立退けと逼った。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また岡は、思はず四五尺も離れると、箆を持つた腕を突き出して、恰も水の深さを計る芝居の謀反人のやうに身構へて、前後左右から私の姿を実験するのであつた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、あれを「諸々の力が上昇し、下降して黄金の吊籠を渡し合ふ」といふゲーテの言葉を暗示として、あの表題を定めたのであるが、例へば未だ、何処を何う目標として箆を構えるべきかのさしたる手掛りもなく、きれぎれな痴夢と、その日その日の愚かしい営みの回想が綾となつて濛つとしてゐるばかりであつた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼はやゝともすれば左う呟いで、箆を置いて想ひを凝らしてゐた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は斯んな心的状態にある自分の風格や個性が、彼の箆先に依つて髣髴されることを思つてやゝともすると冷汗を覚えた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
