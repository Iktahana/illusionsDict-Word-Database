[
  {
    "uuid": "9de22b9c-682a-5c05-9f59-05ebff19022b",
    "entry": "箆",
    "reading": {
      "primary": "へら",
      "alternatives": [
        "ヘラ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
