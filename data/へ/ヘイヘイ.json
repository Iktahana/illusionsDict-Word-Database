    },
    "definitions": [
      {
        "index": 1,
        "gloss": "yes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なあにどうせ私などはへいへい云ふやうにできてるんですから。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へいへい」　と、どぎまぎして慌ておれり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちは何と申す」「へいへい。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちは金貸しを業と致しおるな」「へいへい。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金貸しは面白かろう」「へい、御冗談、へいへい。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ、持ち参れい」「へいへい。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へいへい、お邪魔様申します。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へいへい、なるほど。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その意を得ざる掏摸は、ただへいへいと応うるのみ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と数珠形に引立てて戸外へ出ずれば、今まで荒れに荒れた屠犬児、神妙に畏りて、「へいへい私も御一所に。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」丁か半か五「へいへいへい、何旦那ちょいとその、洒落に遣りましたばかりなんで、へい、大した天下を望むような謀叛を起したではござりやせん。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へいへい、お庇さまで、まずこれで、今夜から枕を高う寐られまする。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へいへい、頭、難有うござります。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その農家の親仁が、「へいへい、山雀の宿にござります。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただへいへいと申上げますと、どうだね、近頃出来たばかり、年号も今年のだよ、そういうのは昔だって見た事はあるまい、また見ようたって見せられないのだから、ゆっくり御覧、正直な年寄だというから内証で拝ませるのだよ。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気なれば気の毒、早速医者の手にかかるがいいが、もし我儘だったらあんまり卑屈にへいへいしていると、却って増長させていけない。",
              "citation": {
                "source": "良人教育十四種",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へいへい改心いたします。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――静御前様、へいへいお供をいたします。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へいへい、どうぞこちらへ」　女中は二人をまじまじと見やりながら、客の前もかまわず、番頭と目を見合わせて、さげすんだらしい笑いをもらして案内に立った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭取　へいへい合点でござりまする。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時与次郎はへいへいと言って番人にあやまった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へいへい、それはねがってもない幸でございます。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くしたらいいじゃねえかよ」「へいへい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらかおいらも焼きが回ったらしいよ」「へいへい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へいへいなんにも吹きましねえ」　立ち帰る二人を見送りもせず、夜まで考えていた将右衛門。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれはどうも官僚だからへいへい云わないと悦ばんのだよ。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "へいへいよろしゅうございます。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「源さん、憚りさま、お湯を一つ」「へいへい、一つと仰しゃらず、二つお揃いで、持参致します。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は」　二人は、返事をしないで、番頭に「では、そのお方お一人だけ――」「へいへい、決して、もう一人などとは申し上げません。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
