        "examples": {
          "standard": [
            {
              "text": "反政府勢力との交渉がまとまり、占拠されていた施設は平和裏に政府側に返還された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大規模な政権交代だったが、暴力的な衝突は一度も起きず、全てが平和裏に運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "緊張関係にあった両国の軍隊が、平和裏にそれぞれの撤退期限までに引き揚げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "○　舜（しゆん）は平和裏に帝堯（ぎよう）に位を譲られ、武（ぶ）王は殷（いん）の暴君紂（ちゆう）を武力討伐して位についた。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "連合国は、日本人民の平和裏の自主性を認めているのである。",
              "citation": {
                "source": "人民戦線への一歩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
