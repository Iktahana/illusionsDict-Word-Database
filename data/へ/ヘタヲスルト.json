    "definitions": [
      {
        "index": 1,
        "gloss": "if one is unlucky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下手をすると、私ばかりではない、おまえたち三人のくびもとぶのだよ。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからどんな途方もない想像をもってきても、読者を吃驚させるような強さがなくて、これでもか、これでもかとおさえつけている間に、下手をすると作者の方がくたびれてしまうのである。",
              "citation": {
                "source": "乱歩氏の諸作",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手をするとただの合言葉に終って了うかも知れないのだ――文学を思想の科学の角度から取り上げるのは、今後の認識論の課題の一つにぞくするようである。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手をするとだまされつちまふよ。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手をすると逆捻を喰らう。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物にもよるが、下手をすると、俗つぽくなつて読めないものになりさうだ。",
              "citation": {
                "source": "翻訳について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手をすると、自分は参考人か容疑者として警察へ引っぱられるかもしれん。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸鑿というのは丸くしゃくれるから、巧くやるとすっきりしていい代りに、下手をすると却っていいところを取って了う。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手をすると、滑走しているうちに、この島が爆破するかもしれない」　塩田大尉の命令一下、全員は攻撃機にのりこみました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、下手をすると恥をかくわよ」一三　志村鈴江から、二、三日して電話があり、ロベエル・コンシャアルが来てゐるから、すぐ来いといふ知らせである。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手をすると、人間解放という人類の歴史に逆行することにもなりかねない。",
              "citation": {
                "source": "自由と進歩",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "計画的には、組織的と事務的との二つの要素があって、下手をすると、事務的に陥り易い。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重爆用の滑走路にこの施設をするとなると、下手をすると駆逐艦一隻くらいの鉄を必要とするかもしれない。",
              "citation": {
                "source": "霧を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは下手をすると、結晶が蒸発するか、過剰生長をする虞れがあるが、巧く半殺しの状態になっていてくれれば、一番巧いかつ安全な方法である。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手をすると追いつかるるたい」　と李旦がいった。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（言われて房代、省三、浮山の三人が柳子を抱えあげて、ソファに寝せる……）こういうタチの人は、下手をすると、おかしくなる。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くなんとかしてコントロールしないと、こいつから逆に人間は――下手をすると地球そのものまで、吹きとばされてしまうかも知れん。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の道なんぞ、有るような無いようなもんで、下手をすると甲州へ出やすよ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手をすると、せっかくの良い脚本をぶちこわしてしまう。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一下手をすると飯の食ひ上げだもんな。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あのまゝでだんだん行つてゐると、下手をすると気が変になるんぢやないかしら。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆　取れりやいいさ、取れりやいいけど、下手をすると元も子も無くしてしまふ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私なども県会で時々妙なことを言われる位で、理くつが通っているいないに関係なく、自分の意見をあまり強く押し出していると、下手をすると国賊だなんと言われるからね、ははは。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林　なんせ実行組合の方では、今日明日にでも組合の決議をして、明日が日からでも開墾の鍬入れをしようと息まいているだから、下手をすると力づくの争いが起きかねない。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "警備員二　そうだなあ――航空母艦が来ているようだから、下手をすると小型機がつっこんでくる恐れがあるんじゃないかなあ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは危なくなったら逃げ出せばいいと、多寡をくくって平気でいたが、これでは逃げ出すどころか、下手をすると命が危ない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず誠実から来る一種の文化的勇気――之は下手をするとドン・キホーテのものであるが勿論彼はキホーテではない――に敬服さえするのである。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は元来、吾々の問題探求の深化でなければならないのだが、下手をするとその皮相化に終る危険があるだろう。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうけは半分あんたにあげるわ」「やつてもいいけど、下手をすると、つかまるんだろう？",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ伊賀守の敗戦で、下手をすると大事に及ぼうとしたところを、わずかな手兵で勝ちを制したのだからすばらしい手柄である。",
              "citation": {
                "source": "蒲生鶴千代",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
