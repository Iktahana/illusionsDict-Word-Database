          "literary": [
            {
              "text": "そして第十八へきかい予備面が痛いと。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだをねぢってあちこちのへきかいよび面にすきまをつくるのはなほさら、よろしくありません。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだをねじってあちこちのへきかいよび面にすきまをつくるのはなおさら、よろしくありません。",
