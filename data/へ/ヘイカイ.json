    "definitions": [
      {
        "index": 1,
        "gloss": "closure (of a ceremony, event, meeting, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「では、」村長はみんなの方に向いて「今晩の講演会はこれで閉会といたします。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　６　博覧会の閉会の日は、珍しく日本晴のお天気であった。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長の閉会の挨拶がはじまった時は、校庭はもはや黄昏れていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方閉会、続いて近所の料理屋で懇親会、それが果ててもなお別れかねて私の宿屋まで十人ほどの人がついて来た。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして思わず酒をも過して閉会したのは午前一時であった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうじき閉会になりますから。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もう閉会である。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹事が自席から閉会を告げると、聴衆はドアの方へ波打って行った。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、一緒に卓を囲んで闘った面子の一人が、自分の二千｜符をほとんどみんな攫ってゆき、その面子一人が断然一人勝ちでプラス四千点にもなったというが、麻雀大会閉会後、「あいつは、インチキの名人なんだ」と誰かに聞かされたときは、全く口惜しくって泪が出る。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概それが閉会の合図であつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十円の売価のものに対しては約三分の一位の補助金が出た上、閉会後、入場料総計算の剰余金を出品人に割り戻したので、出品高に応じて十円か十五円位を各自に下げ渡しました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "初めて博覧会の開かれた当時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふが落で、演説会は閉会となる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第七条、天皇は帝国議会を招集し、其開会、閉会及び衆議院の解散を命ず」更に進んで「第十一条、天皇は陸海軍を統御す」「第十三条、天皇は戦を宣し和を媾じ及諸般の条約を締結す」「第十四条、天皇は戒厳を宣告す」という諸条項を読んでも我等は「立憲」が全く似而非立憲政体であることを知ることが出来る。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "委員のＨは閉会を告げた。",
              "citation": {
                "source": "遺言",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "では高屋さんも、それから浅間君も……今夜の協議はこれで解散ということにしましょう」　黒河内総監は別に愕きも怒った様子もなく、静かに閉会を宣した。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹事が閉会を告げた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいからそれを、私は閉会の日まで買い切るからね。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど杉江さん、念を押すまでの事はないだろうが、あれは必ず、閉会までは確かなんだろうね。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会閉会の後自由党の強要にて党首板垣退助入閣。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその三方の縁側には、本省の官吏や府県の随行員や新聞記者が数多並んで、これも籐椅子に腰をかけていた、陛下にも開会式と閉会式とに臨幸があって勅語を賜わった外に、一回会議を聴聞あらせらるるために臨幸があって、一時間余も私どもは天顔に咫尺したのである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国においてもせめて、拳骨ぐらいの喧嘩があるであろうと、大会の閉会になるまで、好奇心をもって種々の新聞に眼をくばっておった。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、ぢき閉会になりますから。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜玉子、バタ　○プロフィンテルン閉会。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉会になることを懼れるのである。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "博覧会閉会の後巴里に留り修学せんと欲したれど学資に乏しかりしかば志を変じ商估となり、その宿泊せる下宿屋の一室に小美術舗を開きぬ。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "閉会の後、高等四年の生徒はかはる／″＼丑松に取縋つて、種々物を尋ねるやら、跳るやら。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三越楼上素人写真会閉会。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この暑いのにそう長くやっては何だか脳貧血でも起しそうで危険ですからできるだけ縮めてさっさと片づけますから、その間は帰らずに、暑くても我慢をして、終った時に拍手｜喝采をして、そうしてめでたく閉会をして下さい。",
              "citation": {
                "source": "中味と形式",
                "author": "――明治四十四年八月堺において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋を渡って向うへ通る、暗の晩の、榛の木の下あたり、蛍の数の宙へいかいことちらちらして、常夏の花の俤立つのが、貴方の顔のあたりじゃ、と目を瞑って、おめでたを祈りましたに……」　声も寂しゅう、「お寺の鐘が聞えました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
