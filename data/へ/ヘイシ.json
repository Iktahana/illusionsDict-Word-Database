    "definitions": [
      {
        "index": 1,
        "gloss": "soldier",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "南京陷落の日に萩原朔太郎歳まさに暮れんとして兵士の銃劍は白く光れり。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち外戚祖父とその兄弟は工兵士官であり、また外戚祖母の先祖にも優れた砲工兵の将官が居た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六十八段、大根が兵士に化ける話は少し怪しいが、次の六十九段と合せて読んで見ると寓意を主として書いたものとも思われる。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルメンの兵士も、意気な紳士達も、真赤な帽子を斜かいに被った闘牛士も目には映りませんでした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルセーユの夜の酔泥れた女騎兵士官の寝床、売春婦の体温が軍服に滲みでて、私が彼女が卒倒しない程度で号令をかけるのだが、たちまちアダが軍帽の下にクレオンで愛情を描くと、卵色の口を開いて作り声を出すと、ねえ、つきあえよ、Ｙ。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵營から既に十｜里に近い行程と、息詰るやうに蒸し蒸しする夜の空氣と、眠たさと空腹とに壓されて、兵士達は疲れきつてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、中根ばかりではない、どの兵士達ももうそれに耳を假すだけの氣力はなかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まるで酒場の醉ひどれのやうな兵士の集團は濕つた路上に重い靴を引き摺りながら、革具をぎゆつぎゆつ軋らせながら劍鞘を互にかち合せながら、折折寢言のやうな唸り聲を立てながら、まだ五六｜里先のＮ原まで歩かなければならなかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつと氣が附くと、前の兵士の背嚢に鼻先がくつついてゐたりした。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「志願兵殿、何時でありますか‥‥」と、背後から兵士の一人が訊ねた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夢かな‥‥と思ふと、木の空洞を叩くやうな兵士達の鈍い靴音が耳に著いた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然一人の兵士が私の體に左から倒れかかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛い、誰だつ‥‥」と、私は體を踏み應へながらその兵士を突き飛ばした。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼は闇の中をひよろけてまた背後の兵士に突き當つた、「氣を附けろい‥‥」と、その兵士が呶鳴つた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四｜列縱隊は五｜列になり三｜列になりして、兵士達はまるで夢遊病者のやうにそろそろ歩いてゐるのだつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち夜の暗闇の中に劇しい水煙が立つて、一人の兵士が小川の中にバチヤンと落ち込んでしまつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寢呆けて反對に駈け出す兵士もゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポカンと空を見上げてゐる兵士もゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸邊に丸くかたまつてゐた兵士の集團はあわてて駈け出した。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、兵士達の姿にはもう疲れの色も眠たさもなかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とうとう『馬さん』やりやあがつた‥‥」と、一人の兵士がげらげら笑ひ出した。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、中根は都會生れの兵士達のやうにズルではなかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然し、僕もずゐ分氣を附けちやあゐたんだぜ‥‥」と、私は傍の兵士を顧みた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、三十｜分も經たない内にまた兵士達の歩調は亂れて來た。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でえ、何でえ‥‥」と、小聲でいぶかる兵士もあつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "分隊の兵士達はすべての事の意外さに呆氣に取られて、氣の拔けたやうに立つてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　病室には、汚れたキタならしい病衣の兵士たちが、窓の方に頭を向け、白い繃帯を巻いた四肢を毛布からはみ出して、ロシア兵が使っていた鉄のベッドに横たわっていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の兵士は、寒気のために動作の敏活を失った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士達は、始終過激派を追っかけ、家宅捜索をしたり、武器を押収したり、夜半に叩き起され、やにわに武装を整えて応援に出かけたりしなければならなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気なれば気の毒、早速医者の手にかかるがいいが、もし我儘だったらあんまり卑屈にへいへいしていると、却って増長させていけない。",
              "citation": {
                "source": "良人教育十四種",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
