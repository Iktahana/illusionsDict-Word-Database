  {
    "uuid": "640e4c65-4187-5f30-9da9-ea087ed3dd91",
    "entry": "平氏",
    "reading": {
      "primary": "へいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Heike family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "書房主山崎剛平氏は、私でさえ、ひそかに舌を巻いて驚いたほどの、ずぶの夢想家でありました。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎剛平氏の隨筆集、「水郷記」である。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "書房主山崎剛平氏は、私でさへ、ひそかに舌を卷いて驚いたほどの、ずぶの夢想家でありました。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八歳の夏休みに東京へ遊びに来て尾張町のＩ家に厄介になっていた頃、銀座通りを馬車で通る赤服の岩谷天狗松平氏を見掛けた記憶がある。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "松平氏は第二夫人以下第何十夫人までを包括する日本一の大家族の主人だというゴシップも聞いたが事実は知らない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗煙草が全盛の時代で、岩谷天狗の松平氏が赤服で馬車を駆っているのを見た記憶がある。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "松平氏は資本家で搾取者であったろうが、彼の闘志と赤色趣味とは今のプロレタリア運動にたずさわる人々と共通なものをもっていた。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ思い出して、急に材料を捜しにかかったが、容易に見つからず、とうとう彦根測候所に頼んで、同所の筒井百平氏から、必要な気象観測のデータを送っていただいて、それでやっと少しはまとまった事を考えるだけの資料ができた。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、歌舞伎座にて「相馬平氏二代譚」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "島村抱月氏、田山花袋氏、相馬御風氏、正宗白鳥氏、馬場孤蝶氏、森田草平氏。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "予告は此原稿と、氏の書信によって、草平氏が書いた。",
              "citation": {
                "source": "長塚節氏の小説「土」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくまずして、砂子屋書房主人、山崎剛平氏に、ばとんをお渡ししなければならなくなった。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞伝和尚の事は、竹内運平氏著の青森県通史にも記載せられてある。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽の人、竹内運平氏の青森県通史に拠れば、「この安東一族の騒乱は、引いて関八州の騒動となり、所謂北条九代記の『是ぞ天地の命の革むべき危機の初め』となつてやがては元弘の変となり、建武の中興となつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、竹内運平氏もその事に就いて次のやうに述べてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの竹内運平氏は「青森県通史」に於いて、この辺以南は、昔からの津軽領ではなく、秋田領であつたのを、慶長八年に隣藩佐竹氏と談合の上、これを津軽領に編入したといふやうな記録もあると言つてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高見王の御子｜高望王が平の姓を賜はつたので、従五位下、常陸大掾、上総介等に任ぜられたと平氏系図に見えてゐる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "桓武平氏が阪東に根を張り枝を連ねて大勢力を植つるに至つたことは、此の高望王が上総介や常陸大掾になられたことから起るのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾義仲は平氏を逐ひ落した大功が有つた。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "源義經もまた平氏討滅の大功が有つた。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤原氏の手から政権を収めていた平氏が破れて、源氏が鎌倉に拠ると、元暦元年十月を初発として鎌倉に地震が頻発した。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　　　　三　西明寺――もとこの寺は、松平氏が旧領石州から奉搬の伝来で、土地の町村に檀家がない。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、主人一平氏は家庭に於て、平常、大方無口で、沈鬱な顔をして居ます。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝に平氏あり、夕に源氏あり、飄忽として去り、飄忽として来る、一潮山を噬んで一世紀没し、一潮退き尽きて他世紀来る、歴史の載するところ一潮毎に葉数を減じ、古苔蒸し尽して英雄の遺魂日に月に寒し。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその翌る日のこと、東京市長をやっていた親友の後藤新平氏が遣って来たので、法螺丸は早速引っ捉えて講釈を始めた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "話してみい」　法螺丸「心得たり」　というので、昨日聞いたばかりのホヤホヤのサンジカリズムの話を、その雑誌丸出しの内容に輪をかけたケレンやヨタ交りに、面白おかしく講釈すること約二時間、流石の後藤新平氏も言句も出ずに傾聴すると「シンペイ」するなとも何とも云わずに、大急ぎで帰って行った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜平氏は親友湊屋仁三郎の使者として同業の水野が、白足袋などを穿いて改まって来たので、何事か知らんと思って座敷に上げた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "水野は遠慮なく厄介になりながら熱心に説去り説来ったが、聞き終った青柳喜平氏は米搗杵みたいな巨大な腕を胸の上に組んだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白足袋を宙に舞わして逃げて行った恰好が、今思い出しても可笑しいと青柳喜平氏は筆者に語った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早湯も水も咽喉に通らなくなって、この塩梅ではアト十日と持つまい……という医師の宣告を聞くと、一同の代表みたような親友中の親友、青柳喜平氏が二十四｜貫の巨躯を押し出し、篠崎仁三郎氏の耳に口を附けた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
