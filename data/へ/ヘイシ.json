  {
    "uuid": "67fe4937-b1f3-565e-9689-e67af0d20171",
    "entry": "へい死",
    "reading": {
      "primary": "へいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "falling dead",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "病気なれば気の毒、早速医者の手にかかるがいいが、もし我儘だったらあんまり卑屈にへいへいしていると、却って増長させていけない。",
              "citation": {
                "source": "良人教育十四種",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「余りに、へいしが多過ぎて、酔いの廻るの早いこと」「はて、さて、どうしたものじゃろうか」　俊寛が直ぐ後をうけていった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○　季子然＝＝魯の権臣季氏の一門で、季桓子（きかんし）の弟、季平子（きへいし）の子。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そしてお前さんは、何にも言わないで、へいへいして、蹴ってくださいとお臀を出していたね。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
