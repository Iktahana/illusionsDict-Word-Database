[
  {
    "uuid": "bea091ce-cb9b-565c-9b27-f68c06e08068",
    "entry": "蔕",
    "reading": {
      "primary": "へた",
      "alternatives": [
        "ほぞ"
      ],
      "is_heteronym": false
    },
    "grammar": {
