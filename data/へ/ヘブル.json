        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "またいう「新約の仲保なるイエス」と（ヘブル十二の二十四）。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピエートロは寺院屈指の勇士なればかく〔恩惠〕神の六一―六三〔ローマを正しき〕ローマ人をキリストの教へに歸せしめし〔汝の愛する兄爲〕パウロ（ペテロ後、三・一五參照）〔録す〕ヘブル書（パウロの筆と信ぜられし）に六四―六六〔信仰とは〕ヘブル書一一・一。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "况んやアリヤン文明と云ひ、蒙古文明と云ひ、ヘブルウ文明と云ひ、漫に之を區分するも、其源流に遡れば則ち一のみ、若し、源流に遡らずして、其の下流につきてのみ云はんとする乎。",
              "citation": {
                "source": "世界の日本乎、亞細亞の日本乎",
                "author": "竹越三叉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリヤンなく、蒙古なく、ヘブルウなし。",
              "citation": {
                "source": "世界の日本乎、亞細亞の日本乎",
                "author": "竹越三叉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本あるのみ、支那あるのみ、波斯あるのみ、英國あるのみ、佛國あるのみ、露國あるのみ、源流に遡れば天下は一のみ、支流に下れば列國あるのみ、アリヤンと云ひ、蒙古と云ひ、ヘブルウと云ふ、半上落下の區分あるを許るさず。",
              "citation": {
                "source": "世界の日本乎、亞細亞の日本乎",
                "author": "竹越三叉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘブルウの昔人、西方に日の沈むを見て、歐羅巴と名け、東方に日の昇るを見て、亞細亞と名けしのみ。",
              "citation": {
                "source": "世界の日本乎、亞細亞の日本乎",
                "author": "竹越三叉",
                "note": "青空文庫"
              }
            },
            {
              "text": "必しもアリヤンと云ふ勿れ、必しも、ヘブルウと云ふ勿れ。",
              "citation": {
                "source": "世界の日本乎、亞細亞の日本乎",
                "author": "竹越三叉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘブルューの予言者を指導した者のみが断じて神の唯一の使徒ではない。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝ら神の御意を行いて約束のものを受けんために必要なるは忍耐なり」と聖書にあるとおりである（ヘブル書第十章三六節）。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "新約聖書に含まれる二十七の文書のほかに、エジプト人の福音、ヘブル人の福音、パウロ行伝、ペテロ黙示録、バルナバの書簡等があったが、これらは聖書に包含せしむべき価値なき偽書であるとして、排斥せられたのである（「偽典」と総称せられる）。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パリサイ」という言葉はヘブル語のペルシム（Perushim）から出たのであり、その意味は「別の者」（英語の separated ones）ということであります。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "（八の二七―二九）「キリスト」というのは「メシヤ」というヘブル語のギリシャ訳でありまして、救主の意であります。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "「主」というギリシャ語のキュリオスは、エホバというヘブル語の訳語として用いられている。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをヘブル語にてエホバと言おうが、ギリシャ語にてキュリオスと言おうが、日本語にて主と言おうが、とにかく我らの神とするものは、唯一の宇宙的実在者である。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ヘブル九の一二、一五）と、あるがごとくです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "との悲痛な叫び声が聞えました（マルコ伝に「エロイ、エロイ、ラマ、サバクタニ」とあるのはアラミ語で、マタイ伝二七の四六に「エリ、エリ」とあるのはヘブル語である）。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
