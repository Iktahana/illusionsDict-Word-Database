[
  {
    "uuid": "c0fa467d-5fd6-5d72-98b8-2ce0e5e57a41",
    "entry": "平常",
    "reading": {
      "primary": "へいじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
