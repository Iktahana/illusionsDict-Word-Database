        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かうして見ると、平安宮廷の女房生活を、其等の人の歌詞から推して、紊れきつてゐた様に言ふのは間違ひである。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安宮廷の女房の前身は、釆女其他の巫女である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安宮廷・貴族の生活上の言葉にしたぐつ（韈）がある。",
              "citation": {
                "source": "熟語構成法から観察した語根論の断簡",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安宮廷の歌合せの原となり、而も形式化して残つた歌会始の式を見ても、舎人と共に、女の召人なる采女が中心となつてゐた事が思はれる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
