    "definitions": [
      {
        "index": 1,
        "gloss": "Heian period (794-1185)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
