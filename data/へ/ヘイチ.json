    },
    "definitions": [
      {
        "index": 1,
        "gloss": "level ground",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに場所も平地であるから、雲霧とか山霧とかいふ温泉特有の情趣がなく、すべて感じが乾燥して居る。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてどこから見ても、神河内を統御する大帝は穂高岳で、海抜五千七百尺の神河内から聳ゆること更に五千尺に近く、梓の濶流も、支線の小峡流も、その間の幾十反の点々たる平地も、何もかも一切包まれた谷は、神つ代の穂高見の命の知ろし召す世界である。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "測量標の直ぐ下は、野宿に適当な広い平地があって、それから凄まじいほど、垂直の断崖を作している、その下が雪田で、雪解の水は大樺の谷、それから小樺の谷へと、落ちているらしいが、そこまでは解らない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、横に曲りくねった、普通平地で見るような石楠花でなく、白花石楠花である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホールス・キャムプという平地に出で馬を下り、野営の仕度をする、海抜九千尺、水も少しはある。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "平地に突兀として盛り上る土積。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑波｜嶺に、雪かも降らる、否諾かも、愛しき児等が、布乾さるかも　山の祖神は、平地に禿立している紫色の山を望み、それは筑波という山であって、それには人身の形をした山神が住んでいることを聞き知った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり突如として入った別天地に私は草臥れるのも忘れて、ただ、せっせと主人について歩いて行くうちどのくらいたったか、ここが峠だという展望のある平地へ出て、家が二三軒ある。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ここで見渡せる堤と丘陵の間の平地一面と、丘陵の裾三分の一ほどまで植え亙してある桃林が今を盛りに咲き揃っている強烈な色彩にちょっと反感を持ちながら立ち止まった。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山（シャン、サン）の仲間はちょっと見当たらないが、しかしアイヌの「シン」は地や陸を意味すると同時にまた「山地」（平地に対する）をも意味するそうである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓の低い平地へかけて、無数の建築の家屋が並び、塔や高楼が日に輝やいていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し右手の臥牛山の中腹から、やや急な傾斜を作つて、入り亂れた家家が流れるやうに大野の平地の方へ擴がつてゐる地形の面白さが私の眼を惹いた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は天主閣の建っていた所が平地になって、いつしか姫小松まばらにおいたち、夏草すきまなく茂り、見るからに昔をしのばす哀れなさまとなっています。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山登りがじょうずで、城山を駆け回るなどまるで平地を歩くように、道のあるところ無い所、サッサと飛ぶのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "愈※平地を離れて山路にかゝると、これからが初まりと言つた調子で張飛巡査は何處からか煙管と煙草入を出したがマツチがない。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすぐ馬によって平地へ引き上げられた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、一人の死屍に、そして、山の方へだが、まだ、山へはさしかからず平地をつゞいて行くのに、どうして六頭もの馬が、湯気が立つほど汗をかいているのだろう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿ヶ石川の南の平地に十時半ころまでにできた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあたりはすこしばかりの平地で稲の刈り乾されてある山田。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その路はしばらくすると暗い杉林のなかへは入ってゆくのだったが、打ち展けた平地と大らかに明るい傾斜に沿っているあいだ、それはいかにも空想の豊かな路に見えるのだった。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜木山の麓から私の坐つてゐた土堤へかけては山と山とに狹められたこの村中での一番大きな平地だ。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後になつてすでに影になつてしまつた街道を歩いてゐて、家と家との間から、また暗い家のなかに開いてゐる裏木戸から、この一帶の平地をちらと見た時程平和な氣持のするときはない。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雲はその平地の上に懸つてゐた。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平地のはての雜木山には絶えず時鳥が鳴いてゐた。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下がテニスコートの平地になっている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の坐っているところはこの村でも一番広いとされている平地の縁に当っていた。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした村のなかでは、溪間からは高く一日日の当るこの平地の眺めほど心を休めるものはなかった。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲はその平地の向うの果である雑木山の上に横たわっていた。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中を平地に窪んで、居る処も川幅も、凡そ百｜畳敷きばかり、川の流が青黒い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前の平地に沢山のテエブルと椅子が並べてあって、それがほとんど空席のないほど遊山の客でいっぱいになっている。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
