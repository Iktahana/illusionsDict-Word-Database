[
  {
    "uuid": "cee50530-bfaf-5456-967f-c6da187161ee",
    "entry": "平々凡々",
    "reading": {
      "primary": "へいへいぼんぼん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
