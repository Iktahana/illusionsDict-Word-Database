    "definitions": [
      {
        "index": 1,
        "gloss": "deckle-edged (e.g. paper)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
