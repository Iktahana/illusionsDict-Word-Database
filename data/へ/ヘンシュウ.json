[
  {
    "uuid": "52d8f332-a004-5f06-91cf-6dfd9c87e785",
    "entry": "偏執",
    "reading": {
      "primary": "へんしゅう",
      "alternatives": [
        "へんしつ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bias",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は新短歌が現に挙げてゐる成績に偏執し過ぎたかも知れない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに万一にも眼界の狭い偏執的な学者でも出て来て、自分に興味のないような事項の観測の無用論を唱えたりするような場合には事柄はますます心細くなる。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその頃から真と正義に対する極端な偏執が目に立った。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際もし車掌がある一つの主義を偏執してたとえば大通りばかりを選ぶとするとそれを徹底させるためには時にはたいへんな迂路を取らねばならぬような事があるだろう。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕に偏執狂を扱う看護卒のような心得がある。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の苦悩に日々責め苛れて、益々｜邪と偏執とに傾きかゝつた彼の習性が、一夕の法話に全く矯め直されたのでもあらうか。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "和いだ感情、寂しいと思ふあこがれ、邪と嫉とがもつれあつた偏執。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その神祕的な意味を解かうとして、私は偏執狂者のやうになつてしまつた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その神秘的な意味を解かうとして、私は偏執狂のやうになつてしまつた。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は偏執症の蒐集慾以外に精力を使ふことを絶対に嫌つた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しも肉感を逆立てない、品のいゝ肌質のこまかい滋味が、かの女の舌の偏執の扉を開いた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉はめずらしく手紙の此の部分だけを偏執狂のように読み返えし読み返すのをやめなかった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学四年生の彼は、偏執的に彼の黒猫を愛していた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の偏執と自我と自尊と嫉妬のために、詮ずるに烈しい恋のために、――三年の間、夜に、日に、短銃を持たせられた、血を絞り、肉を刻み、骨を砂利にするような拷掠に、よくもこの手が、鉄にも鉛にもなりませんでした。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが贋乞食であることくらい、あなたがこゝへ来て十日も経たないうちに彼は嗅ぎ出しましたさ」　学者乞食の花田は廃朽の自然物から何か価値を取出すことに魅惑を持ち、偏執狂的にその在所を究めずには措かない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子が、目星を執拗に気にする偏執性を退散させるには、加奈子はやや強い態度が必要だった。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この三四日、目星ばかり気にし続けて居た京子の偏執が、今朝もまだ、眉や顎に痛々しい隈を曳いている。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子は京子の憂鬱や偏執に困らされても、悪どい悲惨極まる生活には陥されるようなことはなかった。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見当違いや、煩わしさや、憂鬱や偏執に、「我」も「根」も尽き果てようとする時、加奈子は、不意に、京子のその半面の気違いのロマンチックに出遇う。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡先生が折角上京されたと思うと突然帰国された、それに就て自分は大に胸を痛めている、先生は相変らず偏執ておられる。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸幕府の衰亡　江戸幕府は、三代将軍家光に至つて、あらゆる機構が整ひ、武家政治は完成された形を示したが、五代将軍綱吉に至つて、幕府の太平が謳歌される傍ら、綱吉の偏執的な性格や、生類｜憐愍令や、悪貨鋳造などからの影響もあつて、太平の余弊たる享楽主義が天下を風靡した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は指の偏執狂だった。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ愛人の彰子の手のように素晴らしく綺麗で立派な指を探ろうとする偏執狂だった。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは此翁の偏執の念強くして人の才を妬み、特に平生我を喜ばざるを知れり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとつは、ビーチボーイズの〈グッド・ヴァイブレイションズ〉が、異常な構造と、リズム・チェンジの多用、偏執的ハーモニーといった、ヒットをさまたげる要素を大量にかかえながら、先週、とうとうナンバーワンになったことだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等の偏執に予等までも卷込まれ、其粗暴の鬪諍によって我血族の血汐を流した。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも畢竟はこっちが女主人であると思って、備前屋ではおそらく馬鹿にしているのであろうという、女らしい偏執まじりの愚痴も出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "その偏執や愚痴は別としても、備前屋が今まで素知らぬ顔をしているのは確かに不義理であると半七も思った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、女性の通有性として偏執的な傾向が強く、困ることも多い。",
              "citation": {
                "source": "わが妻の記",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "西南の役もおわった明治十二（一八七九）年の七｜月には、国会論をかきあげて、慶応義塾の出身者がへんしゅうしている報知新聞に、社説として一｜週間ほど、毎日はっぴょうしました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
