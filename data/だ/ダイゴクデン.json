    "definitions": [
      {
        "index": 1,
        "gloss": "Council Hall in the Imperial Palace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "狂言は「ハムレット」「浦島」「大極殿」にて、土肥春曙のハムレット好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "はては朱雀門、大極殿、大学寮、民部省まで移りて、一夜の程に塵灰となりにき。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、蘇我氏のかゝる不臣が許されるわけはなく、御英邁なる中大兄皇子を中心とする中臣｜鎌子（後の藤原鎌足）、蘇我｜倉山田石川麻呂、佐伯子麻呂等の活躍に依つて、皇極天皇の四年六月、入鹿は大極殿に於て、誅戮を受けたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "院は宮が斎宮としてお下りになる日の荘厳だった大極殿の儀式に、この世の人とも思われぬ美貌を御覧になった時から、恋しく思召されたのであって、帰京後に、「院の御所へ来て、私の妹の宮などと同じようにして暮らしては」　と宮のことを、故人の御息所へお申し込みになったこともあるのである。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "大極殿の御輿の寄せてある神々しい所に御歌があった。",
              "citation": {
                "source": "源氏物語",
                "author": "絵合",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに当時最勝｜会を宮中法事の第一とし、天平九年冬十月最勝会を大極殿に啓く、その儀元日に同じというほどで（『元亨釈書』二の「釈道慈伝」）、二経の内『最勝王経』を特に朝家が尊んだので、『法華経』凝りの徒がこれに抗して瓢より米が出た話を作って、かの経が『最勝王経』に勝ると張強したのだ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ本より大極殿の楽なり、この曲を舞う時、舞人甲に鼠の形をつけ、上の装束も色糸で幾つも鼠を縫い付くるとある。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもと大極殿の楽なり。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは昔大極殿で舞った舞いを大黒天の好む舞いとし、大黒柱を祭って宮中を鼠が荒さぬようまじのうたと見える。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時學問の造詣は如何と云ふに、都良香が貞觀十八年に大極殿が燒けた時に廢朝の事を議した文や、又元慶元年に夜の日食に就ての建議などは、いかにも其の該博を見して居る。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして遂には朱雀門や大極殿、大学寮、民部省等の重要な建築を一夜の中に尽く灰塵としてしまった。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてには朱雀門、大極殿、大學寮、民部の省まで移りて、ひとよがほどに、塵灰となりにき。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡崎の大極殿の屋根渡る朝烏見て茄子を摘む家　これは晶子さんには珍しい写生の歌で、春泥集にある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は橋の下でも、あるいは大極殿の山門の中でも決して辞退はしないつもりである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく引用せられる天武紀十年三月の「天皇大極殿に御し、川島皇子以下十一名に以詔しめて、帝紀及び上古の諸事を記定せしむ……」とあるのが、或は其「日本書」なるものゝ由来を書いたのともとれる。",
              "citation": {
                "source": "日本書と日本紀と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この月の八日にも大極殿で舞つたが、よぼよぼして起居も不自由な濱主が、いよいよ舞にかかると妙技を發揮し、『宛も少年の如し』と記されて居る。",
              "citation": {
                "source": "愛國百人一首評釋",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇治、鳳凰堂、平等院、宇治川花屋敷、佐久間象山遭難地、加茂川、本能寺、御所、烏丸通、堀川、嵐山電車、仁和寺の山、塔、如意輪観音、大竹林、隠窟、臨済宗大本山天龍寺、保津川、桂川、金閣寺（鹿苑院）、大極殿（平安神宮）。",
              "citation": {
                "source": "つゆじも",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の事を例に言つてゐるが、例といふものは實際變つてゐるものである、例へば即位式は大極殿で執り行ふといふのが例だといふ事になつて居るが、大極殿がなくなると仕方なしに別殿で行ふ、別殿もなくなると又何か其時々に相應した處で行はなければならぬ。",
              "citation": {
                "source": "應仁の亂に就て",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "大極殿で入鹿が殺され、蝦夷がわが家に殺されたとき、死に先立って、天皇記と国記を焼いたそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大極殿の再建と住宅建築の樣式とは自ら區別して考へられなければならぬ。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十二日、新帝安徳天皇の即位式が行なわれたが、先年の火災で焼失した大極殿が使えないので、紫宸殿が評議の末、式場にあてられた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大嘗会が行なわれるはずであったが、新都には大極殿も、即位の大礼を行なうべきところはなく、清暑堂もないので神楽を奏する場所もない。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "承和十二年正月八日最勝会の時、大極殿の前に於て従五位下尾張浜主といふ百十三歳の翁が和風長寿楽を舞つた。",
              "citation": {
                "source": "枕物狂",
                "author": "川田順",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝陽殿、大極殿、総章観などが造営された。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            },
            {
              "text": "洛中の耳も、大極殿のたたずまいも、やがての鐘を、偉大な予言者の声にでも触れるように、霜白々と、待ち冴えている。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、平安の皇居大極殿の址は、市中の細い横丁裏にあって、人民酒場と書いた飲み屋の赤い軒燈や、子どものおむつを干し並べた家々の背に囲まれ、またそれは何よりも雄弁に、千年の歴史を午後の陽に描いていた。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
