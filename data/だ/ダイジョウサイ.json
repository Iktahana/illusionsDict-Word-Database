[
  {
    "uuid": "f8afd9eb-12fe-5b95-ad36-3eeadc636ae3",
    "entry": "大嘗祭",
    "reading": {
      "primary": "だいじょうさい",
      "alternatives": [
        "おおにえのまつり",
        "おおなめまつり"
      ],
      "is_heteronym": false
