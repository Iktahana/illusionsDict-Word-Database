        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが三方に分れて逃げたらしく、中之島公園へ逃げて来た連中はざっと三十名ばかり、差入れの着物や洋服などのいわゆる私服を持たぬ青い官服の囚人姿の者がその大半だったので、一眼見るなり拘置所からの脱走者だと判った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大量脱走者を出した大阪拘置所が、警察へ報告したのは、一時間たってからであった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "引揚者のわびしさも、脱走者の焦燥も、貴子への恨みも恥も外聞も忘れて、ただ貴子の白い肉体へのもだえに揺れているうちに、やがて俥は田村の玄関についた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ここの主人は他の脱走者の例にならって、その屋敷を多年出入りの商人にゆずり渡して行ったのである。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱走者が相継ぎ、しかも彼等の多くは捕えられ、或いは殺された。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に脱走者は船から七八間離れた渦の中を船尾を※つて鮮やかに島の方へと泳いでゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾にゐた二人の島民水夫が其の場から海に跳び込んで脱走者の後を追うた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱走者と追跡者との距離は見る／＼縮まつて行くやうに見えた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に脱走者は船から七、八間離れた渦の中を船尾を廻って鮮やかに島の方へと泳いでいた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾にいた二人の島民水夫がその場から海に跳び込んで脱走者の後を追うた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱走者と追跡者との距離は見る見る縮まって行くように見えた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の脱走者機関士舵をあげろ　同志ワフラメヱフ君はなんといふ眼をするのだそんな眼差しを何処に隠してゐたのだ。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年程立つた頃、自分は又その同じ村の青年の脱走者を二人から紹介された。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど自分は杉山からその新脱走者の家の経歴を聞いたばかり、別段二人ほど懇意にはならなかつた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の心は脱走者であることさえ一時忘れ、群衆の熱狂にあおられ、だんだんと愉快な気持になっていった。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは脱走者である僕に懸けられた莫大な賞金のことに違いなかった。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてみんなが網を張れだの、崖の上へいってそっと綱をひいてみろだの、竹ばしごを組んで二人ばかり登って助けろだのとさわいでいる間に三人の脱走者は反対方向の山へまぎれこんでしまったのである。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、三人組の脱走者は、とある屋敷内に来かかりました。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑波の脱走者、浮浪の徒というふうに、世間の風評のみを真に受けた地方人民の中には、実際に浪士の一行を迎えて見て旅籠銭一人前弁当用共にお定めの二百五十文ずつ払って通るのを意外とした。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸国の人の注意は尊攘を標榜する水戸人士の行動と、筑波挙兵以来の出来事とに集まっている当時のことで、那珂港の没落と共に榊原新左衛門以下千二百余人の降参者と武田耕雲斎はじめ九百余人の脱走者とをいかに幕府が取りさばくであろうということも多くの人の注意を引いた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は将軍家が江戸｜東叡山の寛永寺を出て二百人ばかりの従臣と共に水戸の方へ落ちて行かれたとか、今日は四千人からの江戸屋敷の脱走者が武器食糧を携えて両総方面にも野州方面にも集合しつつあるとか、そんな飛報が伝わって来るたびに、彼の周囲にある宿役人から小前のものまで仕事もろくろく手につかない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "武装解除を肯じない江戸屋敷方の脱走者の群れが上野東叡山にたてこもって官軍と戦ったことを聞いたのも、百八十余人の彰義隊の戦士、輪王寺の宮が会津方面への脱走なぞを聞いたのも、やはり名古屋まで行った時であった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロシア報知」が難民救済の文集を企画すると、『サガレンの脱走者』一篇をこの文集に寄せた。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由主義系の新聞『ロシヤ報知』が難民救済のための文集を企画すると、彼はこれと右派の有力紙『新時代』との間の仲介役を買って出、且つみずから『サガレンの脱走者』一篇をこの文集に寄せた。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "不愛想で、陰気で、みようによってはなんとなく秘密ありげな女だったが、ふっと、ああいう特殊な社会の脱走者にたいする刑罰が、いかに苛酷をきわめたものであるかに思いあたった。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱走者に処罰をくわえるのだったら、なにも客のいる時をえらぶ手はない。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロウブス及び後にはディオクレチアン３）は、野蛮人の脱走者や捕虜に土地を与え、そして彼らの過剰人口を国家にとり最も危険の少なそうな所へ配置して、帝国の荒廃地方を恢復しようという計画を採用した。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダートムーアにいる時、警察犬を飼っていたので、あのころは一人の脱走者もなかった。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それはシル※ストルの兄のジャン・モアンが脱走者で、家族の間ではもう何人もうわさもしなかつたが、それでも未だ、何處か亞米利加で生活してゐると云ふ事實が、兵役免除の特權を弟から奪つてしまつた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
