    },
    "definitions": [
      {
        "index": 1,
        "gloss": "deity with extraordinary spiritual powers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "河が、春日大明神の帯のように、きらきら銀色に輝いて流れました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は飯綱大明神、または飯綱権現と称し、先ず密教修験的の霊区であった。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山猫大明神さまのおぼしめしどほりぢゃ。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河が、春日大明神の帯のやうに、きらきら銀色に輝いて流れました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山猫大明神さまのおぼしめしどおりじゃ。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、滝先生、滝公、滝坊、へん滝豪傑、こっちの大明神なんで。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは心得てまさ、義作が心得たといっちゃあ、馬に引摺られたからとあって御信仰が薄いでしょうが、滝大明神が心得てついてます。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へへへへ、南無大明神でいらっしゃる。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよう、待ってました大明神様！",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人のなさけも勿論であるが、これも日ごろ信ずる稲荷大明神の霊験であるというので、お岩は自分の屋敷内にも彼の稲荷を勧請して朝夕に参拝した。",
              "citation": {
                "source": "四谷怪談異説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査来、戸籍調べらしい、飛行機来、一句くれていつた、冀くは今夜も敬坊来、樹明来、南無アルコール大明神来！",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九日、壬辰、鷹狩を禁断す可き事、守護地頭等に仰せらる、但し信濃国諏訪大明神御贄の鷹に於ては、免ぜらるるの由と云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺一帯の田の、水が枯れた時に、僕は隣村へ水をもらひに行つて、つひに大成功して、大トラ変じて水虎大明神といふ事になつたのです。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがてえ、昔時からテキパキした奴だったッケ、イヨ嚊大明神。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大明神｜眉を皺めてちょいと睨んで、思い切って強く帚で足を薙ぎたまう。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "別段、こだわるわけではありませんが、作州の津山から九里ばかり山奥へはいったところに向湯原村というところがありまして、そこにハンザキ大明神という神様を祀っている社があるそうです。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり人間をとって食べるので、或る勇士がついに之を退治して、あとの祟りの無いように早速、大明神として祀り込めてうまい具合におさめたという事が、その作陽誌という書物に詳しく書かれているのでございます。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（再び槌を取りあげ）南無｜帝釈四天王、五道｜冥官、日本伊勢大神宮、八幡大菩薩、春日大明神其他｜氏神、南無阿弥陀仏。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔Gen-gen, byo_-soku-byo_,〕 …… 〔Gen-gen, byo_-soku-byo_,〕 ……お岩稲荷大明神様……南無妙法蓮華経……　日が光る、くわつと暑い空気が淀む、鶏頭が笑ふ……石鹸を剃毛で掻き立てて顔一面に塗りつけると、白子のやうに眼ばかり青く光り出す。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真赤な歇私的里の鶏頭、　お岩稲荷大明神様……　不図、俺は気がついた、何といふ坐り態だ、まるで汝の肉体は白痴の女見たいにぶくぶくだねえ、だらしのない、どんなに暑くたつて、もつとチヤンと坐つておゐでなさい。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔Gen-gen, byo_-soku-byo_〕 …… 〔Gen-gen, byo_-soku-byo_〕 ……お岩稲荷大明神様……南無妙法蓮華経……どうぞ旦那との縁が切れますやうに……　恐ろしい、真昼間に何事だ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔Gen-gen, byo_-soku-byo_〕 …… 〔Gen-gen, byo_-soku-byo_〕 ……お岩稲荷大明神様……どうぞ御願ひ奉る……　喧ましい、鶏頭、鶏頭、俺の肝の虫がもう弾ぢぎれさうだ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔Gen-gen, byo_-soku-byo_〕 …… 〔Gen-gen, byo_-soku-byo_〕 ……お岩稲荷大明神様……南無妙法蓮華経……どうぞ商売繁昌致しまするやうに……　鶏頭、鶏頭、俺はもう気が狂ひさうだ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無妙法蓮華経……お岩稲荷大明神様……　苦しい、苦しい、汗が流れる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は其の雀の宮へ下車したことがないから実物を見たことはないが、東国旅行談の云うところによると、其処に雀を祭った雀大明神の宮があって、土地の名もそれから起ったらしい。",
              "citation": {
                "source": "雀の宮物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓は恩に思って己の家の中へ宮を建てて雀大明神と云って雀を祭った。",
              "citation": {
                "source": "雀の宮物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがいいの、ね」と、矢ツ張り甲高な笑ひ聲で、「どうしても年寄りがゐないと、いゝ考への出ないもの、ね――おツ母さんでなけりやア――おツ母さん大明神だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外、諏訪明神を信仰し、「諏訪｜南宮上下大明神」と一行に大書した旗も用いていた。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他に、駿州の鎮守総社大明神に神使として目されていた白狐が居たのが、義元出発の日、胸がさけて死んで居たとも伝える。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康（年三十四）は竹広村弾正山に、三郎信康（年十七）は草部村松尾大明神鎮座の山に布陣した。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
