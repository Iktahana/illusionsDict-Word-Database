[
  {
    "uuid": "59afcb79-08cc-5aba-a14b-d6e5f35aa80a",
    "entry": "大明神",
    "reading": {
      "primary": "だいみょうじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
