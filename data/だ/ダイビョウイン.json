    "definitions": [
      {
        "index": 1,
        "gloss": "large hospital",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伊部は二十五歳で医学博士になったくらいの秀才で、酒も煙草も飲まぬ、いわゆる品行方正の男だったし、勤務先の阪大病院でもまず相当な給料を貰っていたから、高利貸に金を借りるような生活はまるで想像も出来なかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その足で阪大病院へ行った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、生国魂神社の鳥居のかげで暫く突っ立っていたが、やがて足は田蓑橋の阪大病院へ向った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋を渡るのももどかしく、阪大病院へかけつけると、浜子はいなかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "阪大病院で看護婦をしていると、死んだ文吉が言っていた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かくして我々は小道へ入り、大病院の一棟へ向かう小さな裏口をくぐった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ大病院、警視庁、神奈川県警察部、臼杵病院を手玉に取って来たか。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェルダン市の市役所のあったところ、大病院のあったところ、学校。",
              "citation": {
                "source": "女靴の跡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝於青森大病院、罪人解体に付、斎木藤田昨夜より罷越、今夕又一宿。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日大病院に而御進撃之砌医局用意之薬種並道具等申合。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文礼子青森大病院へ行。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒石城下通りより浅瀬石村大病院へ立寄一宿。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤病人三人（秋月辰三、小山忠三郎及人夫富五郎）戦事手負大病院へ御預に相成。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森辰巳屋へ一旦著、大病院へ三人之病者頼行。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大病院下宿和島屋某へ著。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きついて見れば、帝大病院の一室で絶望を宣告された腹膜炎の彼は奇蹟的に生きてゐた。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――こちらが帝大病院、こちらが三高です」　熊野神社から北へ入つて、彼がさう指さして説明した時、自分は、嵯峨野へ走つてくれ、と命じた。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正九年に、その人との中に女の子が生れたので、夫の郷里京都へ、もろもろの問題を解決に旅立ったが、持病の胆石が悪化して、京都帝大病院で亡った。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝大病院へつれて行ったんだけれど、電車を降りてずっと歩き出すとそのまんまどこまででも真直に行っちまうんですもの。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月に盲腸炎を起し、慶大病院で手術した。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部の設備の充実してゐる事は、我我門外者の観察ながら、日本の大病院にも是れに匹似すべきものが少なくはないかと想はれた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
