        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり水が低きにつく如く、花がひそやかであるが如き気持がなければ、詩は駄目だと思つた。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、色々と分析的な努力をもしてみたが、やはり駄目で、すつかり自信を失つた気持であるやうな場合もあつた。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "するともう、Ｂは何を云つても駄目なのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう駄目です、この不景気にはキリがありません。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄目です』などと夫人にからかわれ、『あ、どうしよう、私この鼻』など言って悄気返り、『真ッぴら、真ッぴら』と、今おぼえたばかりの日本語を面白がって使ったりして、夫人や女中たちを大笑いさせたりしているのだが、その後で、『しかし、よく思うて下さい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くから母に死なれ、父は頑固一徹の学者気質で、世俗のことには、とんと、うとく、私がいなくなれば、一家の切りまわしが、まるで駄目になることが、わかっていましたので、私も、それまでにいくらも話があったのでございますが、家を捨ててまで、よそへお嫁に行く気が起らなかったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭がわるいから駄目なんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だらしがないから駄目なんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕ひとりでは駄目です。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私も若い時には、大酒を飲んだものですが、いまはもう、さっぱり駄目になりました。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私は先生からそのように駄目な男と思われて、かえって気が楽なのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、どうせ、駄目な男と思われているのだから、先生に対して少しも気取る必要は無い。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生もう死ぬるものでございませうか」「駄目らしいね」医者は低声でそれを答へた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さう早く出るもんか」「だがね、今日はもう何も云つては駄目ですよ、今急病人があつてお父様は気が立つてるからね」　その時、俄然台所の方から、牛肉か何かを叩く音がして来ると、そゝくさと蒼い顔の妻君は長男の部屋をも立ち去つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も詩と云つたとて、詩壇の現状では駄目である。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか調べてみたいと思うけれどもこれからでは到底駄目であろう。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこの頃人の話で大凡こんなものかくらいは解ったようだが元来西洋の音楽などは遠くの昔バイオリンを聞いたばかりでピアノなんか一度も聞いた事はないからなおさら駄目だ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかしてあんなものが聞けるようにも一度なりたいと思うけれどもそれも駄目だと云うて暫く黙した。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに婦人は駄目だ、冷淡で熱情がないから。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "露伴の妹などは一時評判であったがやはり駄目だと云う事だ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねつから、その日は駄目でした。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さん、はじめは、ぎよつとしたが、しかし、お酒飮みといふものは、お酒を飮んでゐない時には意氣地が無くてからきし駄目でも、醉つてゐる時には、かへつて衆にすぐれて度胸のいいところなど、見せてくれるものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と旦那は怒り、ぎよろりと妻子を睨んですつくと立ち上り、奧の薄暗い部屋に退却して、そつと鏡を覗き、がつかりして、「これは、駄目だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さんには冐險心が無いから、駄目ね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事で私をおさへようたつて駄目さ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、何もかも駄目である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「傍へ寄つて來ちや駄目だつて言つたら。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上品ぶつたつて駄目よ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ、寄つて來ちや駄目だつて言ふのに。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠りながらも、何のたはけた夢を見てゐるのか、惚れ藥つてのは、あれは駄目だぜ、きかねえや、などわけのわからぬ寢言を言ひ、眼をさましたのは、お晝ちかく。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
