          "literary": [
            {
              "text": "今からすぐにいって、しかと談じ込んで参れ」「どういう風に、談じ込むんでございますか。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "執拗に談じ込むと、彼はうるさそうに叫んだ。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもならば、二人、三人、或いはそれ以上雑多な人数がここへ詰めて来て、がやがやとし、食事を取って、談じ込むもあれば、そうそうに出て行くもある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は決してこの事に就いて、熊谷の方へ談じ込む気はないんです。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
