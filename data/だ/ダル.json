    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dull",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこでペダルが終わって八分の一の休止のあとにまた同じような律動が繰り返される。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会の夏の夜月は空にメダルのやうに、街角に建物はオルガンのやうに、遊び疲れた男どち唱ひながらに帰つてゆく。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "九合目に来た、もう一杯の雪で、コンクリートで堅めたように凍っているから、鳶口ででもなければ、普通の金剛杖では、立ちそうにもない、胸突八丁、大ダルミなどは、大分息苦しく、殊に足の辷り方が烈しかったが、それでも思いの外に、怯まずに登りついた。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、私が男の子に訊くと、「あだ名をダルマつて云ふんだよ。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでダルマつて云ふんだよ」「さうかい。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな議論が実用上どういう価値があるかは分りにくいが、ただ生物界の現象を説明するに力学を応用するようになった率先者の一人としてここに御紹介するその学者の名はダルシー・ウェントウォース・トムソンという。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この巨きな室にダルゲが居るんだ。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の中はガランとしてつめたく、せいの低いダルゲが手を額にかざしてそこの巨きな窓から西のそらをじっと眺めてゐた。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダルゲは灰色で腰には硝子の蓑を厚くまとってゐた。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダルゲが俄かにつめたいすきとほった聲で高く歌ひ出した。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダルゲは又じっと額に手をかざしたまま動かなかった。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ダルゲは振り向いて冷やかにわらった。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音によって多少発生年代を異にしたもののようで、キ→イ（「築墻」がツイガキ、「少キ人」がチヒサイヒト、「先立ち」がサイダチとなった類）ギ→イ（「序」がツイデ、「花ヤギ給へる」が「ハナヤイタマヘル」など）、ミ→ム（「かみさし」がカムザシ、「涙」がナンダ、「摘みたる」がツンダルの類。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてクラウジウスやティンダルの説を永久に否定してしまった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先任者ティンダルが病気でやめたその後を継いだのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてはファラデー、ティンダルの務めた職である。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓をめぐりて会長が、　　　　　　　メダルを懸くる午前二時、カクタス、ショウをおしなべて、　　花はうつゝもあらざりき。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはナムサダルマプフンダリカサスートラというものである。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことし（一九二八）になって雑誌ネチュアー（四月十四日発行）の巻頭紹介欄にMunro's Lucretius. Fourth Edition, finally revised.に関するダルシー・タムソンの紹介文が現われた。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケルヴィンのほかにクラーク・マクスウェルやティンダルのごとき大家もまたルクレチウスに注意を払ったという事実があるそうである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば日本の「アソ」、「ウス」、「オソレ」、「エサン」、「ウンセン」等に対してカムチャツカの「ウソン」、マリアナ群島の「アソンソン」、スマトラの「オサール」などがあり、またわが国の「ツルミ岳」、「タルマイ山」、「ダルマ山」に対しジャヴァの「ティエリマイ」、「デラメン」などがあるという類である。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の理論からすれば、ダルトン方則で、単に普通の指数曲線的垂直分布を示すはずのが、事実はこれに反して画然たる数個の段階に分かれるのである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近な例を取ってみても、ファーブルの昆虫記や、チンダルの氷河記を読む人は、その内容が科学であると同時に芸術であることを感得するであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "チンダルのアルプス紀行とか、あまり有名ではないが隠れた科学者文学者バーベリオンの日記とかいうものがそうである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上にあげたような一流の科学者のほかにたとえばフラマリオンやフルニエー・ダルベのような科学の普及や宣伝に貢献したよい意味でのジャーナリストもあるが、しかしそういうものは純粋の科学者から見ると、どうしても肝心のところに物足りないところのあるのはいかんともすることができない。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代では競技会でメダルやカップやレコードを仕留めるだけが目的の空中曲技も、昔の武士は生命のやりとり空中組み打ちの予行練習として行なったものと見える。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後方に一輪車が取り付けられ、そうして三つの輪の中央のサドルに腰をかけた人がペダルを踏んで推進する仕掛けになっている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "座席に腰かけている人はパナマ帽に羽織袴の中年紳士で、ペダルを踏んでいるのは十八九歳ぐらいの女中さんである。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しのチンダル効果さえ示さない全く不可視な固体コロイドは考えられないとすれば、「不可視人間」もまた考えられなくなる道理である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
