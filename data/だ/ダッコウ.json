[
  {
    "uuid": "52420132-72af-5f08-bc9d-f4e5094870c1",
    "entry": "脱稿",
    "reading": {
      "primary": "だっこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
