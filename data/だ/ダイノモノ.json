    "definitions": [
      {
        "index": 1,
        "gloss": "food set out on a stand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
