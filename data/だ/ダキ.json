    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indolence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自負心は惰気を生じ、虚栄を夢み、沈衰となり、退歩となる。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような状況下では、全帝国における惰気倦怠の掃き溜め、このロンドンに私が居着くのは当然のことだった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼南統率下の毎日新聞社の末期が惰気満々として一人も本気に働くものがなかったのはこれがためであった。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大いに疲労して、白昼の凡てに、惰気を催うすにも拘はらず、知られざる何物かの興奮の為に、静かな夜を恣にする事が出来ない事がよくあつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、余り客の立て混んでいない昼湯の、あの長閑な雰囲気は、彼の様に所在のない人間が、贅沢な眠から醒めたのちの体の惰気を、そのまま運んでゆくのに最も適した場所であった。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそういう話は、いずれ薔薇園でやってもらうことにしようじゃないか」　ところが、次の瞬間法水の顔にサッと光耀が閃いていて、突如鉄鞭のように、凄じい唸りが惰気を一掃したのである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この告白は、たぶん惰気と暑さで、諸君を困らしめるにちがいない。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷水によって眠気と惰気とをはらい、さわやかな朝日をおがんで清新な英気を受ける。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後大分日が経ったが、幕軍は少しも盛り返えす様子もなく、従って我藩の軍隊もいよいよ惰気を生じた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大いに疲労して、白昼の凡てに、惰気を催おすにも拘わらず、知られざる何物かの興奮の為に、静かな夜を恣にする事が出来ない事がよくあった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことが村の若者の心に、惰気と不安定とを知らず識らず齎していた。",
              "citation": {
                "source": "土地",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将公綱を初めとし、紀清両党の郎党たちも、追々｜惰気を催して来、しかも思い切って心を許し、眠に入ることが出来なかったので、身心次第に疲労れ衰弱えて、戦意｜頓に失われ、退陣したいものと思うようになった。",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は曰く、「もし奉行余が言を聴き、今日の急務を弁知し、一、二の措置をなさば、吾れ死して光あり、一、二の措置をなす能わざるも、また赤心を諒し一死を許せば、吾生きて名あり、また酷烈の処置に出で、妄りに親戚朋友に連及せば、吾言うに忍びずといえども、昇平の惰気を鼓舞するに足る、皆妙」と。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十二　貧民窟に居ても栄一は存外呑気であるから、惰気ものに会つては、なまけものゝ研究をし、下駄屋の門先に立てば古下駄屋の哲学を研究して居た。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき惰気眠りを促しきたり、筆を執るにものうし。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこれがために惰気を生ずるのを恐れるのである。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の形相がすっかり変って、三角波が白い波の穂を飛ばし、ミストラル気味の寒い尖った風が、四十日目の惰気をいっぺんに吹きはらってしまった。",
              "citation": {
                "source": "予言",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜来の惰気と昏迷を、むうっとするばかり澱ませている。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして天下いま他に恃む何ものとてない時代においてをやであります」　さしもの広い部屋も、この中の惰気も、また自我も争気も、しばらくは一掃されて、彼ひとりの声しかそこには聞えなかった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃から伊丹城中には、惰気ようやく満ち、士気また紊れ始めたかと見らるる徴候があらわれ出して来た。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都は今、旋風の中心だ、江戸のような惰気や、自暴はない。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しばらく降りませんでしたから……」「春も終りだから、散った花屑やら人間の惰気を、ひと雨ドッと、洗いながすもよかろう」「そんな大雨が来たら、武蔵さんは一体どうなるでしょう」「うム、あの人か……」　二つの顔が一しょに、千年杉のほうを振り向いた時である。",
              "citation": {
                "source": "宮本武蔵",
                "author": "地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日頃からの惰気、倦怠、孤愁などはみな汗となって流れるかのようだ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、槍を持ったなと思う瞬間、微笑ましい光景などは消し飛んで、兄弟の掛り合う烈しい気声は、朝から続いて惰気満々だった大人どもの試合のどれよりも真剣で凄まじくさえあった。",
              "citation": {
                "source": "剣の四君子",
                "author": "高橋泥舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "この惰気からわく霧のような心中の敵は、ともすれば不平をささやき怯みを誘い、仲間同士のあらを挙げては不和を醸し、また、郷愁を覚えさすなど――あらゆる煩悩の弱点を衝いて、鉄壁の士気を潰乱しに蒐って来る。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄然、仕事場の空気は、きのうまでの惰気を一掃して、戦場のような眼つきと、汗の殺気がみなぎった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、午まえよりも、秩序がみだれ、惰気が漂って、山淵右近が奉行していた昨日と、変りがなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "御勝利、疑いもござりませぬ」「理由は」「駿河公方の年来の驕慢」「それだけか」「四万とは号するものの、敵の布陣の拙」「ウム」「また、義元殿が本陣は、昨宵、沓掛を出て、今朝からの暑気に、人馬の疲労はもとより、惰気を生じおるべしと存ぜられます。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "惰気と倦怠の陽炎が、そこの白壁にも見てとれる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちの中心が緊張していればすぐそれを感じ、惰気にみちていれば、彼らも共に惰気に満ちる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
