        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこが大事なところだ。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気のあるうちに大事なところは済ましちまへ。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気のあるうちに大事なところは済ましちまえ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまが大事なところなんだ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは大事なところだと思います。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この辺は最近、国防上なかなか大事なところであるから、里数その他、具体的な事に就いての記述は、いつさい避けなければならぬ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見知らぬ連中が、明日の試験に備えているところへ、一分一秒が大事なところへ押しかけてきたのだ。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが君大事なところだ。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しく危いぞ、と思つたが、かういふところが大事なところだ、決して機嫌など取つてはならない――。",
              "citation": {
                "source": "晩秋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも兵員がついているところはあらまし消し終え、大事なところだけは、ほぼ闇の中につつまれた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが大事なところだ。",
              "citation": {
                "source": "不思議なる空間断層",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを避けるには今から大事なところへ石をうっておく必要があると思う。",
              "citation": {
                "source": "『十八時の音楽浴』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくできあがりかけた大事なところを半年も休みにされてはまたもとのもくあみに帰ってしまう。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではあるが、ここは一番大事なところだと考えた。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時には吾輩、思わずカッとなりかけたもんだ……が、しかしここが大事なところと思ったから、わざと平気な顔で空を嘯いて見せた。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "心では不愉快ではあったが、この男の大事なところを握ったのが、無性におかしく思われた。",
              "citation": {
                "source": "香油",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とうとう自分でお陀仏になったか」「あんがい、かんたんな最期をとげたじゃないか」「大事なところを弾丸にうちぬかれたのだろう」　怪魔のからだは、ばらばらになっていた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、大事なところになると、おじさんが説明をしてくれたから、なおさらよく分ったのだ。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからが最も大事なところ。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今が大事なところだ、私が――」　といいかけた帆村は突然口を噤んだ。",
              "citation": {
                "source": "千早館の迷路",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ機関室などの大事なところは、夜光塗料が、かすかに青白く光って、機械の運転に、やっとさしつかえのないようには、なっていた。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あったら大事なところを！",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒をのみながら酒を軽蔑する、そこが大事なところです。",
              "citation": {
                "source": "霧の中",
                "author": "――「正夫の世界」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事なところで、献身的につくしてくれるものでもない。",
              "citation": {
                "source": "愛の問題（夫婦愛）",
                "author": "――生命の法に随う――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝが大事なところかも知れぬと気がついたから、カストリ一升とりだす。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは、国民の士気に関係する大事なところである。",
              "citation": {
                "source": "心理の洞察",
                "author": "――政治に求めるもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこの引上げが大事なところ、あせらぬように用心しろと戒め合ってそろりそろりと引上げるが、人間が乗ったにしてはどうも手応えが軽すぎる。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋金の大事なところが一本だけ不足しているのである。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の言ふ大事なところはここのところだ。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの装飾には金をかけても、こんな大事なところに手をぬくのです。",
              "citation": {
                "source": "Ｓ夫人への手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
