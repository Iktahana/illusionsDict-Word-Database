    "definitions": [
      {
        "index": 1,
        "gloss": "to talk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三鷹の薄汚い酒の店で、生葡萄酒なんかを飮んで文學を談ずるくらゐが、唯一の道樂で、ほかには、大きなむだ使ひなどをした覺えはない。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭趣味の事実を談ずることは、談者自ら興味多く、聴く人にも多くの趣味を感じ、且つ参考になることが多い。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてまた隅田川を説きながら語次横に逸れて枝路に入ること多きは、これまた黄序に言ひけん如く、伊洛を談ずるものは必ず熊外を連ね、漆沮を語るものは遂に荊岐に及ぶ、また自然の偶属にして半離すべからざるものなればなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし密教の大道理からいえば、荼枳尼も大日、他の諸天も大日、玄奥秘密の意義理趣を談ずる上からは、甲乙の分け隔てはなくなる故にとかくを言うのも愚なことであるが、先ず荼枳尼として置こう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事は、まだその頃ありました、精盛薬館、一二を、掛売で談ずるだけの、余裕があっていう事です。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃から既に、日本では酒が足りなくなっていて、僕が君たちと飲んで文学を談ずるのに甚だ不自由を感じはじめていた。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世事測る可からずと雖も、薙髪して宮を脱し、堕涙して舟に上るの時、いずくんぞ茅店の茶後に深仇の冥土に入るを談ずるの今日あるを思わんや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主義も社会主義も有りはしない、そんなことは昼寝の夢に彫刻をした刀痕を談ずるような埒も無いことで、何も彼も滅茶滅茶だった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄帝の氣を談ずる言さへ、至つて至ることあり、至つて至らざることあり、至つて太過なることありとある。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、私が肯かないわ、とお源をつかまえて談ずる処へ、熱い湯だった、といくらか気色を直して、がたひし、と帰って来た主税に、ちょいとお前さん、大丈夫なんですか、とお蔦の方が念を入れたほどの勢。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "論議の範囲に於て、善悪を説くは、正面に之を談ずるなり。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸の範囲に於て善悪を説くは、裡面より之を談ずるなり。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ業なくして勇を談ずるは、仮勇なり。",
              "citation": {
                "source": "想断々（２）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腐朽」わが右にあり、「死淵」わが左にあり、剣を揮ふもの誰ぞ、筆を弄するもの誰ぞ、天を談ずるもの誰ぞ、地を説くもの誰ぞ、何れに進歩あらむ、何れに退歩あらむ。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "婚姻と死とは、僅に邦語を談ずるを得るの稚児より墳墓に近づく迄、人間の常に口にする所なりとは、ヱマルソンの至言なり。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄を説き天堂を談ずるは、小乗的宗教家の癡夢とのみ思ふなかれ、詩想の上に於て地獄と天堂に対する観念ほど緊要なるものはあらざるなり。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「必然の惡」を解釋して遊歩塲の一少女を點出しかの癖漢の正義を狂欲する情を描き、或は故郷にありしときの温かき夢を見せしめ、又た生活の苦戰塲に入りて朋友に一身を談ずる處あり。",
              "citation": {
                "source": "罪と罰（内田不知庵譯）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "平凡無癖を以て愚物なりとし、一癖あるにあらざれば談ずるに足らずとする露伴に道也あるは、無理ならぬ事なり。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五にして苦海に堕ち、それより浮沈隆替の跡は種々に異なれども、要するに色を売る歴史のみにして、恋を談ずる者にあらず。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち登臨の事を談ずるは之を後にせんといふ。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は關西の旅行で甘酒と飴湯とを味つて、此二つの味を解せぬものはともに旅行を談ずるに足らぬと思つた位である。",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "山水を談ずるも亦復｜是の如し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "興に乘じて古人の事を談ずるときは、われは自ら我辯舌の暢達になれるに驚きぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "……むろん崑崙茶といったら、お茶仲間の評判の中心で、魅惑のエースと認められている事だし、お出入りのお茶屋が又チャンチャン一流の形容詞沢山で……崑崙茶の味を知らなければ共にお茶を談ずるに足らず……とか何とか云って、口を極めて誘惑するんですから、下地のある連中はトテモたまりません。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」談ずるのが、戸外に待っている私たちに強く響いて、ひそかに冷汗になっていた処――「むふん。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "技師はむろん主人と見たので、いささかていねいに用むきを談ずる。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は金錢を談ずることの野卑なのを羞ぢるのではないかと思つたので、それからは金錢に就いては餘りいはぬやうにして居た。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそここで酒を始めやうぢやないか、さうして飲みかつ談ずると為う」「さあ、それも可からう」　独り可からぬは遊佐なり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も、名人の域に達すれば、共に談ずるに足る。",
              "citation": {
                "source": "遊羽雜感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "談ずる処は多くは実務に縁の遠い無用の空想であって、シカモ発言したら※々として尽きないから対手になっていたら際限がない。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
