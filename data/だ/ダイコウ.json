    "definitions": [
      {
        "index": 1,
        "gloss": "acting as agent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『アーサー・ピナー　金融代行業』と印字されていまして。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙の本作りの工程になぞらえれば印刷機や製本機の機能を代行し、植字工や編集者の作業の多くを自動化して受け持つこの製品は、Expanded Book Toolkit と名付けられている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は、フロッピーディスクなりＣＤ―ＲＯＭなりに書き込んだブックの販売代行です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "販売代行するものと同様、立ち読みできるようにしておきますが、注文は版元に直接してもらいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻布は大学生を見習ってしっかり騒いだ口で、古川はここで校長代行の辞任を要求する大騒ぎの急先鋒として名をはせた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰め打ちでは、この作業を写植オペレーターが代行する。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近頃、くろがね天狗の手練が、大いに落ちたようだ」　という噂も、実はこの半之丞代行の拙い業によるものだった。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "タケシが受験勉強に最後の追い込みをかけていた一月十八日、加藤東大学長代行の要請を受けて機動隊は安田講堂に立てこもっていた学生を排除。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊富な資金力を背景に、レンタル制をとるＩＢＭに対抗するために、日本のコンピューターメーカー七社は一九六一（昭和三十六）年にレンタル代行機関、日本電子計算機株式会社（ＪＥＣＣ）を設立した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでレンタル代行機関を設けてここが国産メーカーからマシンを買い上げ、償却期間をＩＢＭより長く設定してレンタル料金を抑えるとともに、返却のリスクを引き受けて普及促進を図ることが目指された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻布高校二年生のとき、七人の仲間とともに校長代行の辞任要求運動の先頭に立った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "教祖は仲々人にあふのをおきらひで、私が、何事も代行してゐるものですから……」四十一　いよいよ今日は退院と云ふ日に、ゆき子は医局に金を払ひ、待合室で何気なく新聞を見た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中巻新来朝五国聯合　バード・ストーン一座大曲馬プログラム　（午後一時開演）（同　五時終了）★１……君が代行進曲　専属音楽団★２……文字を解し、計算し、地図を読む馬　米国理学博士　アスタ・セガンチニ夫人★３……二頭立戦車曲芸　◇第一戦車　〔伊太利〕　ルビヤ・ベルチニ嬢。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一日　猪苗代行、二十四日帰京　二十五日―二日間宮、こう駆落ちす。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "恫喝代行――人間でなければ彼は何者ぞ？",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つ、文学、といってもつまらぬ翻訳だけだが、その点は母の代行をするのだった。",
              "citation": {
                "source": "新妻の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の奴等は丈が低いから、少しのび上ると帽子ごしによく見える、何でも時代行列なんで、ディオゲネスが桶に入って来るかと、思うと、女学生の撥っかえりが、クレオパトラに化けて大勢の黒ン坊を従えて来る、独逸面のまずいクレオパトラは人を馬鹿にしているが、その奴隷になる学生は尚のこと気が知れない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "組長の早期交代を認めるか、さもなければ、副組長を置いて、一切の事務を代行させるか、その場合、組長は、むろん町会に対する全責任を負ふといふのである。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務も一切助役が代行する。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、蝋山君に代行社長になってくれと交渉があったが辞退した。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母」とは他の何人たりとも代行することのできない絶対唯一の愛である。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に故神田山陽が演じた「鬼神の於松」（故陵潮種と聞く）では久々に遠国から江戸へでて来た於松が故郷深川へと舞戻る可く品川から、この永代行乗合舟へ乗込むの件りがある。",
              "citation": {
                "source": "山の手歳事記",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲー・ペー・ウー、ゲシュタポ、中国の藍衣社、ＣＣ団などの秘密警察組織を、憲兵隊に代行させようという意図なので、本来の防諜機関としての任務のほかに、国家主義でない個人の活動と思想を抑圧する。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ですから、私が代行いたしまして、お片付けするんです」「そんなら、お前の判を捺せ」「ごじょうだん」　青ン膨れの店員が嫌な顔をした。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の査察は重大な仕事だったが、さまざまに迷ったすえ、部下の技手に事務を代行させることに肚をきめ、正午近く、米、野菜、その他、若干の食糧を積んだ橇とともに島へ出発させた。",
              "citation": {
                "source": "海豹島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
