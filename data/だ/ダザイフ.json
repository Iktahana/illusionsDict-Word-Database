      {
        "index": 1,
        "gloss": "dazaifu (under the ritsuryō system, governmental office with jurisdiction over Kyushu, Iki and Tsushima)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
