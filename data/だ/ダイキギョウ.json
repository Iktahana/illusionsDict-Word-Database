[
  {
    "uuid": "5c5cdc84-cee1-56cb-9fc3-db9d490b62c5",
    "entry": "大企業",
    "reading": {
      "primary": "だいきぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
