        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――恐らく彼が、片手でルパシカの胸を抱え、右手で頻りに金髪を撫でつつ、決心しかねている今の瞬間、若いダーシェンカは、手ミシンを廻しながら、子供服の袖でもつけているであろう。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、おお、あなたは本当に仕合せものよ、可愛いダーシェンカ！",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたなんぞ本当に仕合せだわ、ねえ、ダーシェンカ、ちゃんとリョーナにたよって暮していられるんだもの。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリーナは、「ね、後生だからダーシェンカ」　心臓でも搾られるように云って、ダーリヤの手頸を捕え、自分の胸に押しつけた。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダーシェンカ、親切なダーシェンカ、あなただけは私を分ってくれるでしょう？",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ね、ダーシェンカ、あなたにはまだまだ私位の年になった女がどんな恐しい心持で将来を見るか想像も出来やしないわ。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私共だって、あんた方のように若い気軽な夫婦だった事もあるのよ、ダーシェンカ。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、私たった一つ諦められないのは、エーゴルをあんな恐しい男にしてしまってくれたことよ、ダーシェンカ。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「可愛いダーシェンカ、あんたは優しいいい娘さんですよ、――どうか立派な児供が生れますように」　妊娠のために感じ易くなっているダーリヤはマリーナを擁きしめたい程感動した。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちのダーシェンカも……やっぱりその、言っておりますよ……何やかやとな。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダーシェンカが二十万あてますよ……あれは富クジを一枚もってますでな。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……うちのダーシェンカが話してくれたのさ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、すぐ引返してきて、ドアのところで）うちのダーシェンカが宜しくと申しました！",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
