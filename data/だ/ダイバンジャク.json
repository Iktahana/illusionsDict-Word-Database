    "definitions": [
      {
        "index": 1,
        "gloss": "large rock",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしながら、この大盤石量の達観は持ち得なくとも、常にこの理を心に置いて人生の間違いない生き方をする。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大の毛唐が、いくら真赤になって呻いても大盤石の如く貧乏揺ぎもしなかったわ。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉の町の、谿流について溯ると、双六谷と言ふのがある――其処に一坐の大盤石、天然に双六の目の装られたのが有ると言ふが、事実か、と聞いたのであつた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半丁ばかりも往くと、新三郎の背には大盤石が乗ったようになって動けなくなった。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　梅津朔造氏の「安宅」の稽古の時に翁は自分で剛力の棒を取って、「散々にちょうちゃくす」の型の後でグッと落ち着いて、大盤石のように腰を据えながら、「通れとこそ」と太々しくゆったりと云った型が記憶に残っている。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大盤石のひろがりて、海につき出でたる處を野島崎と稱す。",
              "citation": {
                "source": "房州の一夏",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三町をも超える大盤石を掘貫こうという風狂人じゃ、はははは」と、嗤うものは、まだよかった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものに狂ったとみえ、あの大盤石を穿っていくわ。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と私は、いつもと違つて、恰で大盤石を蹴つたかのやうな突嗟の「失敗」を感じて、脚が曲つたまゝに物凄く痺れた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女一人くらいと思って、提督はひっぱりあげにかかったが、どうしたのか大盤石のように重い。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろり／＼と臑皿の下へ手をあてがうて動かして見やうとすると、大盤石の如く落着いた脚は非常の苦痛を感ぜねばならぬ。",
              "citation": {
                "source": "九月十四日の朝",
                "author": "病牀に於て",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に一歩を進めて下を覗けば五月雨に水嵩ましたる川の勢ひ渦まく波に雲を流して突きてはわれ、当りては砕くる響大盤石も動く心地してうしろの茶屋に入り床几に腰うちかけて目を瞑ぐに大地の動き暫しはやまず。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい家ほどもある、大盤石が、頭へ落下して来るとすれば、痛いかどうか……。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀の柄に手をかけたまま、大盤石に挟まれたように身をもだえた。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奪ひ持ちたる刀を投げ棄て、竹杖｜軽げに右手に取り直し、血に渇したる喜三郎の兇刃に接して一糸一髪を緩めず放たず、冷々水の如く機先を制し去り、切々氷霜の如く機後を圧し来るに、音に聞えし喜三郎の業物も、大盤石に挟まれたるが如く、ひたすらに気息を張つて唖唖切歯するのみ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "拡大も拡大……グーッと範囲を大きくして国家的、もしくは世界的の重大問題と変化して、私の頭の上から大盤石のように圧しかかって来るのであった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、あの容貌の醜い若者でさえ、今となっては相手の背からさっき擡げた大盤石を取りのける事が出来るかどうか、疑わしいのは勿論であった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴後獨木橋をわたりて向岸なる一大盤石の上に跼し、靜坐默想して獨り深山の靈氣を思ふ。",
              "citation": {
                "source": "日光山の奧",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の肩は紫に腫れて荷を負うことができない、チビ公は睡眠の不足と過度の労働のために頭が大盤石のごとく重くなり動悸が高まり息苦しくなってきた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいかな」　先生はこういって、「うん」と一つうなった、たよたよとした細い腕はがきっと組んだまま大盤石！",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "大盤石の上に安坐する時は誇りが一切に代るのだ。",
              "citation": {
                "source": "独語",
                "author": "――癩文学といふこと――",
                "note": "青空文庫"
              }
            },
            {
              "text": "千百の寇は来るとも吾のかじ　　　　のかば岩ほも共に飛ばなんと云へる如き大盤石の根底を有せざるべからず。",
              "citation": {
                "source": "信仰個条なかるべからず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを通してギギーという、大盤石でも動かすような音！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上の大きな岩は、昔、建御名命と盤古の神と戦場ヶ原で戦った時、何とかいう力のある神が投げ上げた大盤石だそうな。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こつちは大盤石だとわかつても、やつぱりその顔は漂つてゐる。",
              "citation": {
                "source": "鸚鵡",
                "author": "『白鳳』第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、かくあるべしと待っていた勘次、丸太ん棒のような腕を伸ばして襟髪取ってぐっと押さえた大盤石、弥吉、元の土に尻餅を突いて、やにわにげらげら笑い出した。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "この峰へ登りたるに、絶頂に近き所に大盤石がある。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "真理を求むる者のみが、大盤石の上に立って居る。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕陽新聞の地位は大盤石の上に据えられるのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
