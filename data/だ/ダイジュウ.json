        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第十三、十四、十五、十六行。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佛蘭西文學の旺盛時代たる路易第十四世の朝に於て、突如として一世の耳目を聳動し來れる一書あり、其の簡淨痛快にして靈犀奇警なる人世批評は、天下驚畏の中心となれり、本書是れ也。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま『文章世界』第二巻第十三号で、片上天弦、前田木城、水野葉舟、吉江孤雁ら合評の紀行文家月旦が出た。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「奈我奈家婆」、これは『万葉集』第十五巻の最後の歌（三七八五番）にあるのですが、「ながなけば」は、お前が鳴けばという意味の言葉であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書物の第十五章は盲と芸術との交渉を述べたものであるが、その中に、盲で同時に聾のヘレン・ケラーという有名な女の自叙伝中に現れた視覚的美の記述がどういう意味のものかという事を論じた一節がある。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本のところどころに現われる自然界と人間の交渉、例えば第十九段に四季の景物を列記したのでも、それが『枕草子』とどれだけ似ているとか、ちがうとかいう事はさておいて、その中には多分の俳諧がある。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十二、三十六、三十七、五十六、七十三、百七等の諸段はその例である。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和三年五月『漱石全集』第十三巻、月報第三号）",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから第二の、第四の、第十の騎兵があらはれた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十三年五月――底本・初出：「新青年　第五巻第十號　夏季増刊『探偵小説傑作集』」博文館　　　1924（大正13）年※底本のコピーは、推理小説研究家の山前譲氏にご提供頂きました。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本書紀第十六巻に記録された、太子が鮪という男に与えた歌にも「ない」が現われており、またその二十九巻には天武天皇のみ代における土佐国大地震とそれに伴なう土地陥没の記録がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして第八日第九日目を十分に休養した後に最後の第十日目に一気に頂上まで登る、という、こういうプランで遂行すれば、自分のような足弱でも大丈夫登れるであろう。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第十七回極東ビヂテリアン大会〔〕　一九三一年九月四日正午より。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第十何夫人連中も喰うかね？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて、陳調元の第十三師と第二十二師が入城した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いゝのは、第十五夫人の弟の蔡徳樹である。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かばひながら一郎はどこからか「にょらいじゅりゃうぼん第十六。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この現象については、最近に、土佐郷土史の権威として知られた杜山居士寺石正路氏が雑誌「土佐史壇」第十七号に「郷土史断片」その三〇として記載されたものがある。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十一回目のラウンドで、審判者はＴＫＯの判定を下してベーアの勝利となったが、素人がこの映画を見ただけでは、どちらもまだ何度でも戦えそうに見え、最後に気絶して起きられなくなるようなところはこの映画では見られなかった。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして第十八へきかい予備面が痛いと。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第十二のみ、諸井　　　　　三郎の作曲によりて残りしものなり。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、イ警第三二五六号　聴取の要有之本日午後三時本警察署人事係まで出頭致され度しイーハトーヴォ警察署一九二七年六月廿九日第十八等官レオーノ・キュースト殿とあったのです。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第十八等官、レオーノ・キュースト氏はあなたですか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　　　　第十回　沙魚の水葬天の賜――反對潮流――私は黒奴、少年は炭團屋の忰――おや／＼變な味になりました――またも斷食　少年の聲に飛起き海上を眺めた私は叫んだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十一回　無人島の響人の住む島か、魔の棲む島か――あら、あの音は――奇麗な泉――ゴリラの襲來――水兵ヒラリと身を躱した――海軍士官の顏　此島は、遠くから望むと、恰も犢牛の横つて居る樣な形で、其面積も餘程廣い樣だ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十二回　海軍の家南方の無人島――快活な武村兵曹――おぼろな想像――前は絶海の波、後は椰子の林――何處ともなく立去つた　櫻木海軍大佐は暫時して口を開いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十四回　海底の造船所大佐の後姿がチラリと見えた――獅子狩は眞平御免だ――猛犬稻妻秘密の話――屏風岩――物凄い跫音――鐵門の文字　其翌朝日出雄少年と私とが目醒めたのは八｜時※で櫻木海軍大佐は、武村兵曹をはじめ一隊の水兵を引卒れて、何處へか出去つた後であつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十五回　電光艇鼕々たる浪の音――投鎗に似た形――三尖衝角――新式魚形水雷――明鏡に映る海上海底の光景――空氣製造器――鐵舟先生の詩　武村兵曹は腰なる大鍵を索つて、鐵門の扉と開いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　　　　第十七回　冐險鐵車自動の器械――斬頭刄形の鉞――ポンと小胸を叩いた――威張れません――君が代の國歌――いざ、帝國の萬歳を唱へませう『其處が、奇々妙々の發明だよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二番めの姉だけは、きょうだいじゅうでいちばん親しかったし、いつも自分の味方になってくれていたが、いまは米良家の人間であるし、なにより良人が大事である。",
              "citation": {
                "source": "末っ子",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
