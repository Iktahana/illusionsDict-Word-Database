        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そそくさと二階を下りて来たお糸さんは、「どうなすつたの、」と云つて種田君の外套に手をかけて半ば脱ぎかけたのを受取つて、「全くねえ、あんまりなんですもの、」と訳の分らぬことを云ひつつ，お仲さんの袖をひいて、「お二階はなんだしね。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだしね、私貴方に内証々々で、ちょっと買って来たいものがありますから。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだしね、羽織なんて誰も持ってやしませんぜ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕ひとりの愛憎の念に拠って、世の中が動いているものでもないんだしね、まあ、あの人たちの事は、あの人たちに任せるより他は無いよ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の方もボーナスを貰ってやめたのだしねえ。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月は目の前だしね。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゐて貰へば私だつてそれだけ助かつてるんだしね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりはこんなだしね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "水が変るとよくある事だしね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "買物はさつきのですつかり濟んだのだしね。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、汗びっしょりだしねえ……」　と、じぶんのブラウスを見る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冷たい奴だな」「もう、明後日から期末だしね」　といって、頭に整髪料をふりかける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "例のあることだしね」　と薫は話し続け、また、「兵部卿の宮様のことも、私がお勧めしている以上は安心して御承諾くだすっていいものを、そうでないのはお二方の女王様にそれぞれ別なお望みがあるのではないのですか。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実際、ルミはあなたが好きらしいのだが、――不幸なことにあれは僕なしには、一日も、いや一時間も生きてゆけないのだしね。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからさア、厚木へ通ふのも大変だしね、そろそろ、あとのを探さうかと思つてンのよ……」　ゆき子は、賑やかな女達の後から足早やについて行つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本所の焼跡に、一杯屋でも建てたいンだが、坪二万両としても、十坪ぢや相当なもンだしね。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ三伝が来るかと思うと……戸締りなんぞに頼れなくなってしまって……私はここで竦んでいるんだし……成戸は成戸で、今夜はお悦のあの部屋にいるんだしね」　と、その時、左枝の瞬きがふいに止まったかと思うと、側にある、瓦斯の計量器のうえに視線が落ちた。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本の横に張った綱だけでは、とうていあの窪みができるはずはないのだしね。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしはこの通りの体だしね、何も彼もお父さんがなさるのだから、おとなしくしなけりやあいけませんよ。",
              "citation": {
                "source": "雛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生君のそばに居りたいと云ふほどの考へでもなささうだし、君の妻子のことも何もかも承知してゐるんだしね。",
              "citation": {
                "source": "蠢く者",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにお父さんは御病気だしねえ！",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "値段も手頃だしね」「桜草もいゝな。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど身体が心配だしね。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と宗匠は急に元気づいたが、お豊はポンと長煙管をはたいて、「以前とちがつて、長吉も今が勉強ざかりだしね………。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と宗匠は急に元気づいたが、お豊はポンと長煙管をはたいて、「以前とちがって、長吉も今が勉強ざかりだしね……。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしも一度御見舞に行きたいと思ふんだけど、何しろこんな事情だしね……昨夜お前が帰つてから、手紙が来たのさ。",
              "citation": {
                "source": "世帯休業",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の好きなものには絵ばかり習はせるし、体操の好きなものには体操ばかりさせるんだしね。",
              "citation": {
                "source": "感化院の太鼓（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "とおくだしね、きみは。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
