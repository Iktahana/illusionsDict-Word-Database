    "definitions": [
      {
        "index": 1,
        "gloss": "percussion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いよいよ胸をくつろげて打診から聴診と進んで来るに従って、からだじゅうを駆けめぐっていた力無いたよりないくすぐったいような感じがいっそう強く鮮明になって来る。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の社会事業家によくある好意をもって他人の事情を打診する表情で「お子さんはもう巴里に何年ぐらいになりますかな。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして打診の真似をする。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "火曜の晩に電報を受け、馬主のロス名誉大佐と事件担当のグレゴリ警部の両人から協力を打診されている。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーノックが自分の言語について説明すると、ジョブスはとたんに膝を乗り出して、レーザーライタへの移植を打診しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの如く、ていねいに永い事、聴診や打診をなさって、それから私のほうに真正面に向き直り、「御心配はございません。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、お母さまのお胸を注意深そうな表情で打診なさりながら、「わかりました、わかりました」　とお叫びになり、それから、また私のほうに真正面に向き直られて、「お熱の原因が、わかりましてございます。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この部屋にいる者の顔色を打診したのであろう。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "山頭火に与ふ　　酔中の自己打診　　　　　自己批判　　　　　自己忠告生死の一線　　彷徨　　超越　　逍遙　七月四日　曇、時々微雨。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、いつも妻の体を調べている指さきが、いま彼の背を綿密に打診していた。",
              "citation": {
                "source": "秋日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボイジャーが今度は本当にエキスパンドブックを作るためのソフトウエアを出したということで、ツールキットと名付けられたこの道具のレビューをやらないかとの再度の打診だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三九年に第二次世界大戦が勃発して以降の戦時体制下、弾道研究所では微分解析機の改良が進められていったが、もう一方で研究所は新しい弾道計算装置の開発をペンシルベニア大学に打診した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで上司を通じ、半導体セクションにシステム１００に使えるレベルのものの開発を打診してみた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの用件は、従来どおりＲＯＭに収めた形で供給するベーシックをＩＢＭのマシンに提供する用意があるかとの打診だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月に入って、ベーシック以外のフォートランやコボル、パスカルといった言語も供給できるかとの打診が、開発チームからマイクロソフトに寄せられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが西は、浜田の打診に即答することを避けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "用事があるというならそちらこそ来るべきだろう」　ソード電算機システム、アイ電子計測、リコー、松下通信工業といったまともな企業から、もっと確かそうなベーシック購入の打診をすでに受けていたゲイツは、そっけなくそう答えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお西からの連絡が入る前に日本企業からのベーシック購入の打診があったことも、『帝王の誕生』の著者によるビル・ゲイツへのインタビューによって確認されている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八〇（昭和五十五）年の夏、ＩＢＭから基本ソフトウエア供給の打診があったとき、ビル・ゲイツにもポール・アレンにも、言語製品の供給に関しては何の懸念もなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「従来のものと互換の８０８６版ベーシックを書いてくれれば、我々には購入する用意がある」　そんな浜田の遠回しの打診をけ飛ばすことに、西和彦は危惧を覚えなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "互換ベーシックさえ作れれば日電版ＰＣで勝負できる　一六ビット互換ベーシックの開発を西和彦に打診した段階では、浜田はいったん日本版のＩＢＭ ＰＣに傾きかけていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もちろん、まったくできないという話じゃありませんよね」　浜田から打診を受けた情報処理事業グループのソフト開発のベテランは、そう答えてから面を上げ、たずねるような視線を浜田に投げた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがフィールドサポート部に籍を置く早水には、いかにもオフィスコンピューター用のプログラム開発を打診するかのようにして彼らを訪ねることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やはりこれはマイクロソフトに頼んでくださいよ」　年末の打診から年明けの再度の打ち合わせを経て、そうまとめた古山の言葉の調子は柔らかかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜田からの遠回しの打診が立ち消えとなった時点から一九八二（昭和五十七）年の夏にいたるまで、アスキーは彼らが互換ベーシックの開発に取り組んでいることを、まったく知らなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある小さな計測器メーカーは、機器のコントローラーをマイクロコンピューターを使って作ってほしい旨、松本先生に打診してほしいと編集部に丁重に連絡を入れてきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "府中のエンジニアに打診して、ブートストラップローダーからＯＳを経て、アプリケーションまで一気に立ち上げてしまうことに技術的な問題点がないことを確認してから、浜田はこのシナリオの最大の障害を崩しにかかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜田からアプリケーションにＭＳ―ＤＯＳをバンドルしたいと打診を受けた瞬間、西はこの戦略が日本におけるＰＣ―９８０１の勝利を決定づけるだろうと直感していた★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八四（昭和五十九）年秋、開発中のＪＸ用アプリケーションの準備に関して打診を受けた古川は、ＪＳ―ＷＯＲＤをこの新しいマシンにも移植したいと考え、ジャストシステムを日本ＩＢＭ側に引き合わせた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その両脚は今でもまだしんしんと痛みます。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
