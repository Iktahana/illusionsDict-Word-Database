    "definitions": [
      {
        "index": 1,
        "gloss": "fort",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "踏むものが一巡するごとに、人々がなだれをうって台場台場をうずめた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川の澪は洲崎の沖の方に東より来りて横はれるなるが、本澪、上総澪、台場附近と共にこれらの澪筋もまた釣魚の場所たり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛げた寝衣の胸に吹き入るしぶきに身顫いをしてふと台場の方を見ると、波打際にしゃがんでいる人影が潮霧の中にぼんやり見える。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十四年九月）　　　　　三　品川の台場　陰った寒い日、私は高輪の海岸に立って、灰色の空と真黒の海を眺めた。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの「お台場」は、泛ぶが如くに横わっている。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の眼を以て、この台場の有用無用を論じたくない。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人々の阿父さんや祖父さんは、六十年｜前にここを過ぎて、工事中のお台場を望んで、「まあ、これが出来れば大丈夫だ」と、心強く感じたに相違ない。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　慶応の初年、私の叔父は富津の台場を固めてゐた、で、或日の事。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは舟の上に立っていて、御台場に打付ける浪の荒れ狂うような処へ鉤を抛って入れて釣るのです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな釣はその時分にはなかった、御台場もなかったのである。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "空と海との燻し銀、けふの曇りにふる雨はそれは涙のしのびあし、青い台場の草の芽に沁みて「四月」も消えゆくや、帆かけた船も、白鷺もましてさみしやふる雨に。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "某夏の微月の射した晩、夜学会をやっていた仲間の少年達と台場の沖という処へ旗奪に往ったことがあった。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台場とは藩政時代に外夷に備えるために築いた砲台で、小山のようになった土塁の上には大きな松などが生えていた。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はその台場の南側の草原で旗奪をやった。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）福岡市｜須崎お台場に在る須崎監獄の典獄（刑務所長）となり、妻帯後間もなく解職し、爾後、数年閑居、日清戦役後、台湾の巡査となって生蕃討伐に従事した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして自身は制服のままお台場の突角に立って海上を見渡していると、やや暫くしてから足下の石垣をゾロゾロ匐い登って来る者が居る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十三年の四月、桜の真盛りに、福岡市の洲崎お台場の空地（今の女専所在地）で九州沖縄八県聯合の共進会があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "台場の停車場から半道ばかり、今朝此原へかゝつた時は、脚絆の紐も緊乎と、草鞋もさツ／＼と新しい踏心地、一面に霧のかゝつたのも、味方の狼煙のやうに勇しく踏込むと、さあ、一ツ一ツ、萱にも尾花にも心を置いて、葉末に目をつけ、根を窺ひ、まるで、美しい蕈でも捜す形。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早、天地、処を隔つたやうだから、其のまゝ、銃孔を高くキラリと揺り上げた、星｜一ツ寒く輝く下に、路も迷はず、夜になり行く狭霧の中を、台場に抜けると点燈頃。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうの不出来は例外であるが、一体に近年はお台場の獲物がひどく少なくなったらしいと老人は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の向うに、台場のやうに浮んでゐるのは、航空母艦の赤城か、鳳翔なんだが、大概もう今では一見して、それと判別出来るほどになつてゐるのに、明る過ぎる陽炎にさへぎられて、かたちが定かに見えぬのであつた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの父は富津の台場の固めを申し付けられて出張した。",
              "citation": {
                "source": "父の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に台場が出来てから、そのあたりもだんだんに開けてきて、いつの間にか小料理屋なども出来た。",
              "citation": {
                "source": "父の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川台場沖あたりで打ち出す祝砲がかすかに腹にこたえるように響いて、子供らは往来でそのころしきりにはやった南京花火をぱちぱちと鳴らしていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は台場の方を目指して、思ひ切り漕ぎ進んだ。",
              "citation": {
                "source": "海の中にて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月十三日より、かねて一両年心がけのちよじゆつども、いまださうかうまゝにて、夫を塾中にせき五郎子ゐられ、一人にまかせ候てかかせ、又自身がなほし候てうつさせ、日本せいきと申物に候、又なほし、其間に詩文又だいばつ、みなみなはんになり候やうに、さつぱりとしらべ申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「｜何処だいば――昼飯だよう」　やがて冬となれば、男達は籾を売りに牛車の大王鈴の音もりんりんと賑やかに都会へ向う。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、「ただいばるだけならいいが、ブルがいるので、倶楽部を出ていくものもあるしね、なんとかならないものだろうか？",
              "citation": {
                "source": "小指一本の大試合",
                "author": "山中峯太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ幾人かの老｜案山子どもが、二十年前に芸術や政治上の一流新進者を気取っていた者どもが、同じ贋物の顔つきで今日もまだいばっています。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそばに、おだいばがみえています。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
