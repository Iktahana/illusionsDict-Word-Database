    "definitions": [
      {
        "index": 1,
        "gloss": "to be duplicated",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
