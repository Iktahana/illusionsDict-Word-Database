    "definitions": [
      {
        "index": 1,
        "gloss": "first wave (of troops, immigrants, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
