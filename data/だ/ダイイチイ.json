        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕は氏の晩年の小説（歯車、西方の人、河童等）を日本文学中で第一位の高級作品と認めてゐるが、その俳句に至つては、彼の他の文学であるアフオリズム（侏儒の言葉）と共に、友情の割引を以てしても讃辞できない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光や軽井沢も悪くないが、それは温泉でないから別として、温泉では箱根を第一位にあげたい。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくりものの鳥は、「皇帝のご寝室づき歌手」という、名前をいただき、位は左側第一位にのぼりました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば是に美術家があると假定して見ると、古往今來盡未來の第一位の人たらんとするものもあり、古の人に比して、誰位になり得れば、滿足と思ふものもあり、それよりも低き古人を眼中に置いて、それ位が滿足であると思ふものもある。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿子は大阪で行われた予選で第一位を占めた。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンクールの成績が発表されると、寿子は第一位になっていた。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥は、「帝室御夜詰歌手長」の栄職をたまわり、左側第一位の高位にものぼりました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやその上に、輝く第一位を発表するスペースがもはやないではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九一年のパーソナルコンピューターの恐怖第一位は、毎度毎度で恐縮であるが何と次項へと先送りだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その父と母が別れると聞いたときの衝撃は、オレの怖かったものオールタイム・ベスト10の輝く第一位である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖かったもの第一位の不気味な影は、正体は見えないままオレの中で確実に膨れ上がっていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ第一位は、「マイクロコンピューターへの大型遺伝子混入事件」だったのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなたには又忍男の殿が、來む馬競べに第一位の勝を占めなば恩賞願ひの儘ぞと、大殿の仰せを幸に必ず其日の勝を得て、手古奈が事の許しを得むと勇み給ふ。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば此処に美術家があるとすると、古今絶無の第一位の人になろうとする者もあり、昔の人に比べて誰位になれれば満足と思う者もあり、それよりも低い古人を眼中に置いて、それ位で満足であると思う者もある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　川上眉山　硯友社は御大紅葉を初めとし美妙といい漣といい美男のお揃いであったが、美貌をいったら川上眉山は第一位であったろう。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（できぬかも知れぬ）崇高感を第一位に置くもよい。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは人間の機微に触れた内部の消息を伝えた作品を第一位に据えてもいい。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "相当の理由があって第一位に置かんとならば、相当の理由があって等差を附するならば差支ない。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　川田功氏の「砲弾を潜りて」は、日本のあらゆる戦争文学の中、第一位に置かる可き名作であった。",
              "citation": {
                "source": "マイクロフォン―雑感―",
                "author": "「新青年」一九二五年一二月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「で、古昔から智仁勇と文字通りに順序を付けて、智を第一位に置いたやうぢやが……」と侯爵は前に突出した腕をだらりと狐の尻尾のやうに卓子の上に投げ出した。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業の第一位は農業である。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化、文芸賞の数の多いことでは、今日、日本が第一位にあるのではないかと思われる。",
              "citation": {
                "source": "今日の文学と文学賞",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根を間引いてコヤシをやる、大根こそは日本蔬菜の第一位である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助は渝らざる愛を、今の世に口にするものを偽善家の第一位に置いた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "各国の有業者の人口に対する比率で見ると、婦人有業者の第一位を占めるのはフランスであり、次がドイツ、続いて日本の順である。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の有業者との割合では、男五九・一に対する女三一・九で、婦人の働きての数の多いことでは日本がほとんど世界第一位を占めている。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽といっても第一位が声楽家たちであり、楽器の演奏家たちがそれにつづいているのであって、ヨーロッパの音楽史はあれほど幾多の卓抜なプリマドンナの名を記しながら、婦人の作曲家というものはほとんど一人もその頁のなかに止めていない。",
              "citation": {
                "source": "婦人の文化的な創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の労働者の生活がどんな非人間的条件であったか、「搾るための物を言う家畜」として扱われていたかは、ロシア全土の文盲率が世界資本主義国第一位を占めていたのでも明らかである。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカなどでも労働者の比率から見ると被服工場に働いている婦人労働者が第一位を占めている。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日配の統計の純文学では「細雪」が第一位です。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
