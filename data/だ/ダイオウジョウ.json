    "definitions": [
      {
        "index": 1,
        "gloss": "peaceful death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "観念の眼を閉じて、安らかに大往生を遂げたとは思えない。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に財産も殖え、体重も以前の倍ちかくなって、町内の人たちの尊敬も集り、知事、政治家、将軍とも互角の交際をして、六十八歳で大往生いたしました。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空腹を防ぐために子への折檻をひかえた黄村、子の名声よりも印税が気がかりでならぬ黄村、近所からは土台下に黄金の一ぱいつまった甕をかくしていると囁かれた黄村が、五百文の遺産をのこして大往生をした。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甕へ落ちてから何カ月｜経ったか大往生を遂げた猫は固より知る筈がない。",
              "citation": {
                "source": "『吾輩は猫である』下篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十三で死んで、私は子供心には、そのとしがたいへんな老齢のやうに感ぜられ、まづ大往生と思つてゐたのだが、いまは五十三の死歿を頽齢の大往生どころか、ひどい若死にと考へるやうになつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "室香はお吉に逢いてより三日目、我子を委ぬる処を得て気も休まり、爰ぞ天の恵み、臨終｜正念たがわず、安かなる大往生、南無阿弥陀仏は嬌喉に粋の果を送り三重、鳥部野一片の烟となって御法の風に舞い扇、極楽に歌舞の女菩薩一員増したる事疑いなしと様子知りたる和尚様随喜の涙を落されし。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の信心深い仏徒や居士の終りには、聖衆来迎、紫雲音楽めでたく大往生というのが常である。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、まアくびにもならずに勤めていましたので、父はそんな私を見て安心したのか、二年後の五月には七十六歳の大往生を遂げました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に配偶に別れてからは、日も夜も足りないようにお西様へお参りをして居たから、その点では家内の人達に遉はと感嘆させたほど、立派な大往生であった。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに読者は、彼れ恐らくは死に臨んで大煩悶に陥るであろうと予期しつつ読み進むに、その死また甚だ平安にして彼は安らかなる大往生を遂げるのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十七歳で眠るが如く大往生を遂げた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨空に重い雲が渦をなして老人の病室近くに舞い下り、枕許につめている人々は、煌々たる電灯の明るさに、昼と夜との錯覚をひきおこすようなことになった或る不気味な日の午後、大熊老人は全く意識不明に陥り、やがてその夕刻、脈膊も薄れて、眠るが如く大往生を遂げてしまった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆どすべての場合に私はモルヒネの大量を用いましたが、先刻まで非常に苦しみ喘いでいた患者は、注射によって、程なく、すやすやと眠り、そのまま所謂大往生を遂げるのでありました。",
              "citation": {
                "source": "安死術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十八日　今ごろ東京の真ん中で退屈で何とも仕方のない人間は、大往生をしているようなものだと思う。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は仲間めがやつて来て乃公の大往生を見て吃驚するだらうて。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方に配達された夕刊には「カッフェで大往生」と題して「細田弓之助（33）が喫茶店『黒猫』で頓死したが、原因は病み上りの身で余り激しく駈け出した為、心臓｜麻痺を起したものらしい」とあったのです。",
              "citation": {
                "source": "三角形の恐怖",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉するだけ落葉して濡れてゐる・よごれものは雨があらつてくれた　一月十三日ぐつすり寝た、大安眠だつた、これならば大往生も疑ない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎藤さんは島木さんの末期を大往生だったと言っている。",
              "citation": {
                "source": "島木赤彦氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、小生屍体引取りの際は、どうせ大往生ではありませんから、死顔など見ないでほしいということ、楊子はその場合連れて来ないこと。",
              "citation": {
                "source": "遺書",
                "author": "尾崎秀実",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして眼を一点の曇りもない空の中に放ってぼんやりしていると、ふと自分が今死ねば大往生が出来そうな気がして来た。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "泉鏡花先生こそは、自分の創造した世界に、自分の思ふまゝの人間を生かし、我儘に遠慮なく、自分の持つてゐる限りの思想感情を流露しつくし、表現し切れぬ惱みを殘さず、大往生を遂げられたのである。",
              "citation": {
                "source": "覺書",
                "author": "水上瀧太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "執着をすて神様にたのんで大往生をとげなさい。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の実家は仏教の篤信者で、彼女の伯母なぞは南無阿弥陀仏を唱えつゝ安らかな大往生を遂げた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死を自覚して安らかに大往生をしたなどという人の話を、僕は全然信じない。",
              "citation": {
                "source": "好意",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを示して、そして火の消ゆるが如くに息絶えた父は、まさに天地カイビャク以来の大往生であろう。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが彼と向いあって、彼に代ってジイッと隠居の脈をしらべていた唐七は、その死を確認して静かに手を放し、手を合わせてホトケに一礼し、さて彼に向って、「ヤ、ありがたいオナラによって隠居は大往生をとげました。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
