        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこでええい大サービスと、「それも読者の腰が抜けて、パソコン誌が百倍売れるくらい激しく変わりますよ」と吹くと、急ににこやかになってきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "教材を広めるための出血大サービス価格、景品まがいといった意識だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたいセラダは気に入った女の子には大サービスしますが、縁もユカリもない野郎なぞには決してサービスしないタチでした。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "出血大サービスの連続の毎日の上に、心は優しく美しい人でないといけないのですからね。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳山も渡辺も二三回宛出て大サービスだ、漫談も三十分以上やる、トリに「朗かな演芸会」、昼間はこれをＣＫ管内中継した（300）。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大サービスで一千円の仕立代、ちょっとおどろく。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
