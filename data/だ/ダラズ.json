    "definitions": [
      {
        "index": 1,
        "gloss": "fool",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俺も馬鹿な――大方、気の迷いだらずが――昨日は恐ろしいものが俺の方へ責めて来るぢゃないかよ。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京の兄さん達も何処かで泳いでいるだらずかなあ」　とまた三吉が思出したように言った。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分お前も廊下で見掛けただらず。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここは何処だらず。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "他所の児の様に、ヒクヒク周囲の者に、肝癪を起させる程泣きもしず、意地汚く乳もねだらず、その健康から云っても、おぼろげながら見える品性から云っても、私は、実に理想的な児だと信じて居る。",
              "citation": {
                "source": "暁光",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな夕方の帰りなんぞには、私はいつもよりか大人しく母の手に引かれて、絵双紙屋の前を通っても何んにもねだらずに、黙って歩いていた。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも風のように来ては風のように去る男が、今度は動こうともしないで、その一室をわが物ときめこんで、割拠して敢てくだらず、という意気込みです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『可愛さうに、山猫にでも成るだらず。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "へえもう二十四五にも成るだらず。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "『はあ、あの姉さんは妙なことを言ふ人で、へえもう死んで了ひたいの、誰も居ないやうな処へ行つて大きな声を出して泣いて見たいのツて――まあ、奈何して其様な気になるだらず。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈何して吾家の児は斯う行儀が不良いだらず――』　といふ細君の言葉なぞを聞入れるお作では無かつた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さまがこんなに村を出歩かせるのも、御病気になってから初めてだらずに。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大方こんなことだらずと思った」とお種は言った。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大方そんなことだらずと思った」と母も考えて、「銀行の用だ、銀行の用だと仰って、何度父親さんも東京へ出たか知れない……東京で穴埋が出来なかったと見えるテ。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大方、そんなことだらずと思った」　とお種は苦笑に紛したが、心の中には更に種々な疑問を起した。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "南北千五百尺東西四千二百尺の埠頭の側にこのくらい豆を積んだらずいぶん盛なものだろう。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "中部の寒暖、なかんずくバルパライソのごときは、冬時五十度以下にくだらず、夏時八十度を限りとすという。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処から一里に少し欠ける――ユックリ行っても、さようさ、あんたらの足なら、一時間というとこだらず。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっぽど、こんで古くこそなったが、へえ、おなごの古くなったので……やっぱし、こんで、ババさまだらず。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（チラッと自分の手を見てから）うむ、……ヒビやアカギレだらず……年中、こうだ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいに若い女を振返って）……なあ、そうだらず？",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その気性じゃ、先ず、そうだらず。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこの家のおかみさんと言うものはそれがつとめだらず。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　うん……（はじめは、めんくらっていたが、百姓が、その廻りくどい言い方で以て何事を話そうとしているかがおぼろげながら解って来て、うなだれて聞いている）百姓　そうだらず？",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労性と言うやつだらず。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　ハハ……（笑いながら立上ってフロシキをたたみ、立去る仕度をする、青年も笑い出している）百姓　フフ……（笑っている女と青年を、ずるそうな表情で見くらべながら）そうだらず？",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年　……（相手の言葉が明るく淡々としているだけに余計に迫って来るものがあり、叩きつづけられなくなり、叩くのをやめて、棒を立て、調子を取って麦を叩く百姓の姿をシミジミと見守る）百姓　……そうだらず？",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
