[
  {
    "uuid": "63f9c4ad-c130-50f7-a0b8-e2ac028c8eaa",
    "entry": "代表作",
    "reading": {
      "primary": "だいひょうさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
