[
  {
    "uuid": "0dcf8996-2c64-5cb6-a71f-d729aef7e9d3",
    "entry": "大薯",
    "reading": {
      "primary": "だいじょ",
      "alternatives": [
        "ダイジョ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "water yam (Dioscorea alata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ロブスチード氏の『英華字典』には大薯と訳してあるが、これは薯と訳すれば宜しく大の字はいらない。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからだいじょうぶさ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、人には、もうだいじょうぶだ、癒った、と言った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯父さんと謂われたる老人は、ぐらつく足を蹈み占めながら、「なに、だいじょうぶだ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だいじょうぶよ。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しがみつかれた男もまた、へたくそな手つきで相手の肩を必要以上に強く抱いてしまって、こわいことない、だいじょぶ、など外人の日本語みたいなものを呟く。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だいじょうぶだろうね。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だいじょうぶでしょうか」「僕も心配に思っています」　この時園とおぬいさんとは生れて始めてのように深々と顔を見合わせた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだだいじょうぶと渡瀬は思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいていだいじょうぶ行きます。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも動きやしないから、だいじょうぶだよ。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なあにだいじょうぶ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――たぶん、だいじょうぶだとおもいます。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それなら、だいじょうぶ」と、ゲルダは言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「だいじょうぶ、だいじょうぶ」と、言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこうなれば、雪の女王がいつ帰ってきたって、だいじょうぶです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だいじょうぶ、もう、すっかりかわいてる。",
              "citation": {
                "source": "いたずらっ子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "これができたら、世の中へ出てもだいじょうぶよ」それから、おかあさんは、いくらかとんでみせました。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ウサギくんのことは、もうだいじょうぶ。",
              "citation": {
                "source": "かけっこ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だいじょうぶ、うまくいきますよ。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だいじょうぶだってば！",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（野中）　大丈夫、だいじょうぶ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（奥田）　だいじょうぶでしょう。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれもほかにきいてやしないから、だいじょうぶだよ。",
              "citation": {
                "source": "王さまと靴屋",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「かあちゃん　どこへも　いかないから　だいじょうぶだよ。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だいじょうぶかい？",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには一つの小さな石油ランプが燭っていたが、その燈がすなおに光っているときには、「今晩、だいじょうぶよ」　と云った。",
              "citation": {
                "source": "築地の川獺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月は、だいじょうぶ。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君みたいないい人と、おとなしく遊んで居れば、だいじょうぶ、あいつは、もっと、か弱く、美しくなる。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいんだ、だいじょうぶだ。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
