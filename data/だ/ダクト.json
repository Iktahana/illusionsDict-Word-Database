        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）ひつさげて、大合唱のコンダクトを執つた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒は恐くは主としてオオトヂダクトとして其学を成就したものではなからうか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "のちに同大学の副学長を務めるブッシュは、ここでプロダクトインテグラフと名付けた積分の自動計算機を開発している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "セッションの冒頭に講演に立ったゼロックス、オフィスプロダクト部門のドナルド・マッサーロは、「これまでは自分で欲しいと思っている人にパーソナルコンピューターを売ってきたが、今後は、マシンを必要とはしていても必ずしも欲しいとは意識していない人に売っていかなければならない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、あまりプロダクトはない。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "始め、銀キラキラの真中に老コンダクターを出して一寸びっくりさせ、おわりに死んだ二人の若者を並べて又コンダクトするところなどいいメロドラマだ。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドン特定地に関する限り、ホルボーン・バイアダクトが狙い目だ。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
