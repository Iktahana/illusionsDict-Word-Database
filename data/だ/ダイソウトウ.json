    "definitions": [
      {
        "index": 1,
        "gloss": "President (of China; title used 1912-1924)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
