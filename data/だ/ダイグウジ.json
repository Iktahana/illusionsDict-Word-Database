[
  {
    "uuid": "2a4eaa59-01bf-5264-ad7d-01b60093cf6a",
    "entry": "大宮司",
    "reading": {
      "primary": "だいぐうじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
