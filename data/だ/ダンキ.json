    },
    "definitions": [
      {
        "index": 1,
        "gloss": "warm up (e.g. engine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると父がまたしばらくだまっていたがとにかくもいちど相談するからと云ってあとはいろいろ稲の種類のことだのふだんきかないようなことまでぼくにきいた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなぐあいですから、ツェねずみはだんだんきらわれて、たれもあんまり相手にしなくなりました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっちゃって置くと、だんだんきつくなりますよ」　体格検査の時間にそう言われた時、道子はぽうっと赧くなった。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かき、みかん、もゝ、くり、ざくろ、なつみかん、なし、りんご、ぶだう、さくらんぼ、うめ、びは、ぐみ、ゆず、だいだい、あんず、はだんきやう、ゆすらうめ、の十八種に問題のやまざくらの實をも數へる事に話はきまつた。",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房も詮議がだんだんきびしくなって来たのを恐れて、罪の重荷を放しうなぎと共に大川へ沈めたのであろう。",
              "citation": {
                "source": "放し鰻",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝泥をこね返したような雪道はだんだんきれいになって行って、地面に近い所が水になってしまった積雪の中に、君の古い兵隊長靴はややともするとすぽりすぽりと踏み込んだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は、「ぼくはべつだんきらいでもない」と言った。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう奴がいるために、浮世がだんだんきたなくなる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから南京ねずみのくるくるとまわす車も、だんだんきれいな模様がつくようになった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはだんだんきれいになる」という詩の中で、をんなが附属品をだんだん棄てるとどうしてこんなにきれいになるのか。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正一五・三あなたはだんだんきれいになるをんなが附属品をだんだん棄てるとどうしてこんなにきれいになるのか。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時時内心おどろくほどあなたはだんだんきれいになる。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはだんだんきれいになる」といふ詩の中で、をんなが附属品をだんだん棄てるとどうしてこんなにきれいになるのか。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが自然に委されてあつたために、揃ふ顔がだんだんきまつて来た。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんきせるを腰にぶらさげておいでかな」「まさか。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お話がだんだんきたなくなつて来た。",
              "citation": {
                "source": "入浴",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だんだんきゅうりがなくなるから、それより逃がしてやったほうがいいでしょう。",
              "citation": {
                "source": "もののいえないもの",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、嵐は、だんだんきちがいじみてきた。",
              "citation": {
                "source": "寒い日のこと",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の踏切りにはをぢいさんが電車の通るたびにしやだんきを擧げたり、降したりしました。",
              "citation": {
                "source": "赤い電車",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、だんだんきいているうちに、全くその調子が異っている事に気がついた。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　敦子さまの物語はまだいろいろありましたが、だんだんきいて見ると、あの方が何より神様からお叱りを受けたのは、自殺そのものよりも、むしろそのあまりに強情な性質……一たん斯うと思えば飽までそれを押し通そうとする、我侭な気性の為めであったように思われました。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだんきいて見ると、爺やが死んだのは、私よりもざっと二十｜年ばかり後だということでございました。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはだんだんきれいになる」という詩に、（をんなが附属品をだんだん棄てると、どうしてこんなにきれいになるのか。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々内心おどろくほど、あなたはだんだんきれいになる。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがだんだんきれいになるという言葉は、よく解りうなずかれる言葉ではないか。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて人が上を行くようになると、雪はだんだんきたなくなる。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学生は、だんだんきみが悪くなってきました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂君は、だんだんきみが悪くなってきましたけれども、今さら尾行をよすのはざんねんですから、両手をにぎりしめ、下腹にグッと力を入れて、同じいけがきのやぶれから、暗やみの寺内へとしのびこみました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とだんき、すのをど、すおさく。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
