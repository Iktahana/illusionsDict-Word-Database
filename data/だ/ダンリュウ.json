[
  {
    "uuid": "8ccc1809-e3ed-53b3-ade6-b0d7a1d9dd06",
    "entry": "暖流",
    "reading": {
      "primary": "だんりゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
