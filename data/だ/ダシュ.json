        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三十分後に第三金時丸の舵手は、左に燈台を見た。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生時代には柔道もやり、またボートの選手で、それが舵手であったということに意義があるように思われる。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と二｜等運轉手、非番舵手、水夫、火夫、船丁に至るまで、互に眼と眼を見合せつゝ口々に罵り騷いで居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "９　舵手――一心に舵輪を廻している。",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのことを舵手を始め、船長も誰も知らないとは、ああ、なんたる失敗であろう！",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "舵手は蒼ざめて、厚まくれた外套にくるまりながら、決然たる態度で舵輪を廻している。",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "舵手の小倉は、船首を風位から変えないように、そのあらゆる努力を傾注していた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、労働賃銀増額、――水火夫、舵手、大工ら下級船員全体に対して、月支給額の二割を左の方法によって増給すること。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、小倉が、舵手室へ帰って清書して、波田に手渡しする。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が、書きました」舵手の小倉が答えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇野（捺印した舵手）、小倉、貴様らも同意した、捺印したんだな。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "艫の舵柄の傍では、年老った船頭が一杯機嫌で胡座をかき、大きな煙管で煙草を喫みながら舵柄を見て、二人の壮い舵手に冗談口を利いていた。",
              "citation": {
                "source": "幽霊の自筆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲霧か何かが風のぐあいで吹き飛ばされて来たものだろうと、舵手の一人がそれを見て思った。",
              "citation": {
                "source": "幽霊の自筆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「船幽霊が来やがった」　二人の舵手は舵柄にすがったなりで起きあがれなかった。",
              "citation": {
                "source": "幽霊の自筆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舵手の一人は直ぐ傍の箱を手探りに執って、それを船頭の方へ出した。",
              "citation": {
                "source": "幽霊の自筆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東屋氏は紙巻に火を点けると、舵手の私に向って口を切った。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やい、命知らずの舵手よ、苦しい海に病み疲れた此小船を、速う巖礁角へ乘上げてくれ！",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "波の上にある舵手、海岸にある燈臺守、鐵道の側にある線路番人、町にある交通巡査なぞがそれだ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶や袋や箱を重く積込んだ渡船は帆をかけ、舵手席に、平静で、冷やかな眼をしたパンコフが坐り、舷には灰色の脆い早春の氷塊が濁った水に漂いながらぶつかる。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクソウルは、タイタニック号でこそ四等運転士だったが、主席舵手として最長年の海上生活の経験を有する実際家上りの腕っこきだった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、気持よい」と手足をのばした途端、襖ごしに、舵手の清さんと、母の声がします。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "がっかりすると言うより、ぼんやりして、海を見ていると、舵手の清さんがやって来て、肩を叩きます。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、最後の五百メエトルに日本選手は渾身の勇を揮って、ピッチを四十に上げ、見る見る中に伊太利へ追い着くと見え伊太利の舵手ガゼッチも大喝一声、漕手を励まし、五万の群集は熱狂的な声援を送ったが、時｜既に遅く、一艇身半を隔てて伊太利は決勝線に逃げ込んだ。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、最後の五百メエトルに日本選手は渾身の勇を揮って、ピッチを四十に上げ、見る見る中に伊太利へ追い着くと見え伊太利の舵手ガゼッチも大喝一声、漕手を励まし、五万の群集は熱狂的な声援を送ったが、時既に遅く、一艇身半を隔てて伊太利は決勝線に逃げ込んだ。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "花さき花はうつろいて、露おき露のひるがごと、星霜移り人は去り、舵とる舵手はかわるとも、わが乗る船はとこしえに、理想の自治に進むなり。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こいちゅは、そのう、今朝、工場をぬけだしゅた、不届けな工人でしゅ、今、しょいつを………」歯がないために、ふわ／＼して、発音がうまく出なかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御容体は何という名のある病気ではないのでございますが、今まで衰弱がはなはだしゅうございましたところへ、お食慾のないことが重態に導いたのでございます」　などと六条院はお話しになって、「失礼な場所でございますが」　と、宮のお寝みになった帳台の前へお敷き物の座を作って法皇を御案内された。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って臭気も甚だしゅうございますゆえ、御検分はいかがでございましょうか？",
              "citation": {
                "source": "古千屋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくば、大奥へ、ふたたび、追いやられねばならぬおからだでござるぞ――な、そこを、ようわきまえて――拙者、くだくだしゅうは言わぬ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師が台所にとびこんだしゅんかん、戸はあけられ、かすかな人のけはいが外へむかってかけだしたようだった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
