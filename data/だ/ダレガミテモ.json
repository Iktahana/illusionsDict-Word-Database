[
  {
    "uuid": "c1e40e3b-e79b-53b1-a807-a07b614a0331",
    "entry": "誰が見ても",
    "reading": {
      "primary": "だれがみても",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
