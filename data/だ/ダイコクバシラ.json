    "definitions": [
      {
        "index": 1,
        "gloss": "central pillar (of a building)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
