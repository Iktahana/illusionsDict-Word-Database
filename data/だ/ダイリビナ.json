[
  {
    "uuid": "8ec5db9f-d1b6-5b19-b419-42ddfc6fce3d",
    "entry": "内裏雛",
    "reading": {
      "primary": "だいりびな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
