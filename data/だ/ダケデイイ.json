        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さう思ふと、彼は急に家に歸りたくなつた、ほんのちよつとの間だけでいい、――「マグダレナよ、――私はいつもそんな風だつたね、赦してくれたまへ。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一と晩だけでいい、垢を洗い落して、サッパリした蒲団でねてみたいなア！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "千枝子ひとりで出掛けて行ってきくと、前借は五千円、新円で先払い、宴会でお酌をするだけでいい。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうにお酌だけでいいの……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お馴染はんおいやすのンどっか」「いや、なに一寸会うてみたいんだ、いや、顔を見るだけでいい」　そして、君勇を呼んだのだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、あなたのことだけ考えて、ぼんやりして暮していたいわ」「考えるだけでいいの……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度だけでいいから、おまえの顔を見せておくれ。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福を、ああ、もし神様が、自分のような者の祈りでも聞いてくれるなら、いちどだけ、生涯にいちどだけでいい、祈る）　自分は、そこにうずくまって合掌したい気持でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、人の見ている前だけでいいのです。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざっと、まあ、大負けに負けて」「二万円」「それだけでいいの？",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれだけでいい。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日でも打ってやるよ」「いや、今日だけでいいよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジウムを掛けに通うだけでいいが、しかし通うのが苦痛で堪え切れないのなら、無理に通わなくてもいいという。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の時はまた酒だけでいい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、お前だけでいい。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいい……それだけでいいのだ。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度そこへ閉っていたドアを無理矢理あけて、白いズボンが斬り込むように、「一杯だけでいい。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るだけでいいからはいれという。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を書くのには頭と眼と手だけでいいと思っていたのは誤りであった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度だけでいいから、私を信じて。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして断固拒否するのか、フェリアは説明せず、この決意を守り通す、それだけでいいと思っていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのかわりに、といっても、なあに、その前掛にくるんでいる三本のむちをもらうだけでいいのだがね、といいました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "立って、ものごいの少女のように、「麦を一つぶだけでいいですからくださいませんか。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、ただわたしの部屋をきれいにせいりせいとんして、おそうじしてくれるだけでいいんじゃよ。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「『レトワール紙』の議論のこの節を反駁するだけでいいのなら、僕は、それをそっとそのままにしておいたろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄漿をつけている人だけでいいんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "少年少女の死",
                "note": "青空文庫"
              }
            }
          ]
        }
