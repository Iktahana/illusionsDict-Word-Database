[
  {
    "uuid": "0b9f11ab-0f64-5240-b5be-ab9f7f91a849",
    "entry": "脱兎",
    "reading": {
      "primary": "だっと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
