[
  {
    "uuid": "f6fa109a-f3b3-5393-a222-ff5d517c54ac",
    "entry": "台帳",
    "reading": {
      "primary": "だいちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
