[
  {
    "uuid": "54c8c0ab-1667-56c8-b0cd-8d26476b8df5",
    "entry": "ダイヤ",
    "reading": {
      "primary": "ダイヤ",
      "alternatives": [
        "ダイア"
      ],
      "is_heteronym": false
    },
    "grammar": {
