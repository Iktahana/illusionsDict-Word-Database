          "literary": [
            {
              "text": "「いちばん最近の仕事は、ダンベル体操の本でした。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野玲子がビキニ姿でモデルを務めたダンベル体操の本だ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷さんが見せてくれたダンベル体操の本に出ていたあの女性だということは、すぐにわかりました。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ダンベル体操の本を毎日のように鑑賞しています」　と日比谷は言った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん初期のことで服装もそのまま両袖を結んだり、襷をかけたり、中には両肌脱ぎのシャツ一枚、不体裁お構いなし、柔軟体操からダンベル（亜鈴）、球竿、クラブ（徳利形の木製具）など相当重い奴を大汗になって振り回す、嫌々ながら物事すべて新規だから苦情もいえず、いったところで幹事や先生の一喝に縮みあがる。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
