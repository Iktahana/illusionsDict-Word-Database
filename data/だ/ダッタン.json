[
  {
    "uuid": "0e440457-2da7-56e5-be4f-fa5b00e0cae4",
    "entry": "韃靼",
    "reading": {
      "primary": "だったん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Tartary (various tribes that historically inhabited the area north of China)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二月、韃靼の兵｜来りて燕を助く。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱能、周長等、王の急を見、韃靼騎兵を縦って庸の軍の東北角を撃つ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "永楽元年には、韃靼の兵、遼東を犯し、永平に寇し、二年には韃靼と瓦剌（Oirats, 西部蒙古）との相和せる為に、辺患無しと雖も、三年には韃靼の塞下を伺うあり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し燕の兵を挙ぐるに当って、史｜之を明記せずと雖も、韃靼の兵を借りて以て功を成せること、蔚州を囲めるの時に徴して知る可し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてしもない韃靼海のただなかだ、小さい鴨の水掻、ぴつたりとつけた胸毛の燃えるやうな濃い青。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "劫初からの海、韃靼の寒空、しかも、夏、夏、夏、どちら向いても、うねりの絶間もないうねりの、冥い、光らぬ、おそろしく、また、穏かな、波濤と波濤と波濤の連続。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからそろそろ韃靼海だからね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うところは韃靼の黒い遥かな大うねりの波濤の彼方である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "韃靼海の八月のやや赤みかけた円い太陽が、まだ水平線から、うち見に四、五尺の空に輝き輝きしている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その横文字の看板の、そのまた屋根の、町並の上の近くは濃く青く、はるばると末は冥んだ韃靼海である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "韃靼海の深い、遠い、冥い響きが、海鳴りが、波の音が、潮騒が、　あ、きこえる、きこえる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、黒い黒い韃靼海。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "服は廉物の白に花模様のキャラコの更紗で、何れも韃靼風のものかと思われた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビヤ、韃靼等牧畜業の盛なる地方においては、獣乳が主要なる食物であるため、これを種々の物に製するのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "百ガルヴァルは、日本の二四一九貫二〇〇匁で、大した量でないがこの話成った頃の韃靼では、莫大な物だったのだ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "アストレイの『西蔵記』に、大｜喇嘛の糞尿を信徒に世話しやりて多く利を得る喇嘛僧の事を載す、蒙古人その糞の粉を小袋に入れ頸に掛け、その尿を食物に滴して用うれば万病を除くと信じ、天主僧ジャービョン西｜韃靼に使した時、大喇嘛の使者かようの粉一袋を清帝に献ぜんと申し出て拒まれた由。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "古カルデア人が、オナッガに戦車を牽かせ、韃靼人は、キャングを飼い擾す事あり（マスペロ『｜開化の暁』英訳七六九頁、ウッド『博物画譜』巻一）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラウンの『俗説弁惑』三巻二十五章にいわく、プリニウスとガレヌスは痛く馬肉を貶しまた馬血を大毒と言ったが、韃靼人他に勝れて馬肉を食い、馬血をも飲むでないか、それは北方寒地の人体にのみ無害故しかりと言わんか。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一三〇七年筆ハイトンの『東方史』四八章に、韃靼人は殺人を罪悪とせず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは支那で羔子と俗称し、韃靼の植物羔とて昔欧州で珍重された奇薬で、地中に羊児自然と生じおり、狼好んでこれを食うに傷つけば血を出すなど言った。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "予昔欧州へ韃靼から渡した植物羔を見しに、巧く人工を加えていかにも羊児ごとく仕上げあった。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せめて犬でも一匹ゐてくれるといいんだが」……　　　　　◇　愛蘭の詩人イエエツは気分ほど大切なものはない、歴史上の大事件でも煎じつめると、ふとした人間の気分一つに原づいてゐるのを見付けることが少くないといつてゐるが、実際さうで、むかし韃靼人と波斯人とが幾年もにわたつて大戦争をしたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その原因をよく訊いてみると、韃靼人が波斯人は口髭をよく手入しないから薄汚いといつたからのことで、波斯人に髭でもなかつたら、あんな恐ろしい戦争は起らなかつた筈である。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すれ違う連中の八分通りはトルコ帽をかぶったペルシア人、韃靼人である。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋っぽい、うるしのような匂いのする露路へ入ると、ぎっしり並んだ箱の蓋をあけたように種々様々の韃靼人の店があった。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「資本主義時代は平均十二時間、三十五留――韃靼人やアルメニア人は同じ労働で、半額が普通だったです。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数露里行ったところで、はじめて一台の韃靼人の荷馬車をビュッと追い抜いた。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸を開けたのは年をとった、韃靼人であった。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は皮膚病だったんです。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰れやこしだったんだ？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
