  {
    "uuid": "f5df9229-47d1-51d0-b8b2-6b756bdad4fb",
    "entry": "脱炭",
    "reading": {
      "primary": "だったん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "decarburization",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとえば Dombrowski はすごい量の正常尿（100リットル）を処理して少量のカダベリン（＊脱炭酸したリシン）の存在を証明することができた。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は皮膚病だったんです。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰れやこしだったんだ？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうに二人で死ぬ気だったんでしょうか」「ほんとうも嘘もねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "真剣に死ぬ気だったんだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケントの上等だったんですがな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこにぬいだったんだい？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつは、ええ若いものだったんだ！",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえ、たしかに二反だったんです。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア人やだったん人がふらふらと行ったり来たりしてゐた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が、Ｔ「最初から皆共謀だったんだ」　と言う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いったい俺は今夜あの男をどうするつもりだったんだろう」　生島は崖路の闇のなかに不知不識自分の眼の待っていたものがその青年の姿であったことに気がつくと、ふと醒めた自分に立ち返った。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の学会で先生が報告するはずだったんだが、今のままじゃまだ貧弱でね」　四方山の話が出た。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかみから、いま聞いて来たんですけどね、」　と橋田氏も、まじめな顔をして、「あの子は、腎臓結核だったんだそうです。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死霊の祟りということもあるからね」「もともと、捨犬だったんですもの」家内も、少し不安になった様子である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪は、昔から、そういう子だったんだ。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ、お日さまも星のうちだったんですわね。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体星といふものははじめはぼんやりした雲のやうなもんだったんです。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこゝでおれは探し出すつもりだったんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体星というものははじめはぼんやりした雲のようなもんだったんです。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうここでおれは探し出すつもりだったんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、竹内君は御存知ですが僕はこう見えても同志社の旧い卒業生なんで、矢張その頃は熱心なアーメンの仲間で、言い換ゆれば大々的馬鈴薯党だったんです！",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋本のおじさんだったんだ。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "己れだって粗忽な真似はし無えで、兄弟とか相棒とか云って、皮のひんむける位えにゃ手でも握って、祝福の一つ二つはやってやる所だったんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし俺がいなかったら、おまえたちは飢え死にをするよりしかたないところだったんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴の燃えることは奴の滅びることだったんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だまして呼んだってわけでもないけど、僕の絶対真面目の要求だったんだから、かんにんしろよ、千歳さん」　千歳はしばらく水を眺めて心を空しくしていたがふと慶四郎を顧ると驚いた。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
