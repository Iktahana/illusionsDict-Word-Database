[
  {
    "uuid": "0260fa78-b27e-5c21-bcde-96c545631c1b",
    "entry": "駄々",
    "reading": {
      "primary": "だだ",
      "alternatives": [
        "ダダ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "whining (to get one's way)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫人にとってのヘルンは、最も信頼する良人であったと共に、一面ではまた『大きな駄々ッ子坊や』でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで式のある日などには、夫人が無理に押えつけ、女中までが手伝って騒ぎながら、まるで駄々ッ子を扱うように、あやしたりすかしたりして、厭がるのを強いて着せねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも結局して、私は彼にいたはられ、甘やかされ、故意に駄々をこねることの悦びにさへ、充分自ら飽滿してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お寒いのに、なぜ、おとり申上げた村里の宿へお出でになりませんの」　翁は頑是ない子供が、てれながら駄々を捏ねるように、掌に拳を突き当てつつ俯向き勝ちにいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが天眞爛漫だからして、まるで駄々つ子が暴れ出すやうで、なんとも言ひがたく純眞である。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良が突然、駄々をこねて云うのである。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一日もあの屋敷にはゐられないから暇を貰つてくれと、今年二十一になる武家の女房がまるで駄々つ子のやうに、たゞ同じことばかり繰返してゐるので、堪忍強い兄もしまひには悶れ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さん／″＼駄々をこねて砲台牌をくわえさして貰った真中のデボチンは、三分の一ほど吸った吸いがらを、俥から、傍の保安隊士の頭上に吐きすてた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「またあの眉楼頭（デボチン）は駄々をこねてるよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざま駄々をこねて居たようですが、どうにか落ち附き、三島の町はずれに小ぢんまりした家を持ち、兄さんの家の酒樽を店に並べ、酒の小売を始めたのです。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は店の方に行って駄菓子を取ってきてそれを立ち喰いしながら、駄々子のように母に手伝わせて和服に着かえた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻がやさしい声で、真夜中だからおとなしくして寝入るやうにと云へば云ふほど、子供は鼻にかゝつた甘つたれ声で駄々をこねだした。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子どものような母が自分の兄のような大きな子どもが手ばなせないと駄々をこねたに過ぎなかったのだ。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎は厭だと駄々を捏ねるのを、守膳が老功で宥め賺し、道中土を蹈まさず、動殿のお湯殿子調姫という扱いで、中仙道は近道だが、船でも陸でも親不知を越さねばならぬからと、大事を取って、大廻に東海道、敦賀、福井、金沢、高岡、それから富山。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "別府で死にたいと駄々をこねて来たものの、三年経ったいまは大阪で死にたいと、無理を言う。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄々っ子のように、もっと隠れていてやればおもしろいと思うくらいだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、すっかりその娘さんが気に入ってしまった彼は、すぐ結婚式を挙げたいと駄々をこねた。",
              "citation": {
                "source": "十八歳の花嫁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は近頃印刷局に通ツてゐるとのことであツたが、末ツ子のお芳といふのは、大した駄々ツ子で、九ツにもなツて尚だ母親の膝の上に乗ツて、萎びかゝツた乳をさぐッてゐるといふ風であツた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親が馬の年なら彼女はきっと牛で、彼は気の荒い駄々ッ児なかわりに人情っぽい人のよさがあり、彼女は何かと人の世話を焼きたがる一面、女らしい涙｜脆さはなく、多勢の子供だから一人や二人は死んでも、生きるためにはしかたがないといったふうだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途々、妹は駄々をこねていた。",
              "citation": {
                "source": "律子と貞子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも自分でも今日は気分の調子が取りにくい気がします」規矩男は駄々児のように頭を振った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は炬燵に入って、叔母に向って駄々を捏ねていた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、肉親という事実に安心し、甘えて駄々をこねているのだとは、どうしても私には思われません。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　もともと気の小さい、懐育ちのお坊ちゃんなんだから、遊蕩も駄々で可かったんだけれど、それだけにまた自棄になっちゃ乱暴さが堪らないんだもの。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、駄々ッ児のようだわね。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御鎮守の姫様、おきき済みになりませぬと、目の前の仇を視ながら仕返しが出来んのでしゅ、出来んのでしゅが、わア、」　とたちまち声を上げて泣いたが、河童はすぐに泣くものか、知らず、駄々子がものねだりする状であった。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがままな駄々つ子のやうに言はれて来た私の、裏の苦悩を、一たい幾人知つてゐたらう。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆつくりいつくしめば、いつくしんだだけ人様に対して反動を廻すとかなんとか、さういふ自他のけぢめを掻き毟つたやうな行為は少くなるんだし、自分としてもコクのある気分でゐられるんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹、太宰、佐野次郎、馬場、ははん、この四人が、ただ黙って立ち並んだだけでも歴史的だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の底では、あなたのからだだつて紙一枚の重さくらゐしか無いのですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
