          "literary": [
            {
              "text": "中学を卒業する一年ほど前、当時ジョホールで大農園を経営していた伯父は何年振りかで帰朝いたしました。",
              "citation": {
                "source": "鉄の処女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の兄、マンには伯父に当る人が、ブラジル移民で成功し、大農園を経営している。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそこで大農園を経営したいんだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョージ卿のままでよいし、大農園や三百年続く大邸宅を所有できる。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
