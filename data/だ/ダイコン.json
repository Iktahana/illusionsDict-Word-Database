[
  {
    "uuid": "3cf40015-a685-5b12-80bc-5ae55d869d59",
    "entry": "大根",
    "reading": {
      "primary": "だいこん",
      "alternatives": [
        "だいこ",
        "ダイコン"
      ],
      "is_heteronym": false
    },
    "grammar": {
