          "literary": [
            {
              "text": "其処で渋りながら備中守の差出す腕を、片手で握添へて、大根おろしにズイと扱く。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體、これには、きざみ葱、たうがらし、大根おろしと言ふ、前栽のつはものの立派な加勢が要るのだけれど、どれも生だから私はこまる。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で聞くと、※さんの苦心は、大根おろし。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の山もりに大根おろし。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根おろしも薄黒い。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクス主義が、我々夫婦の実生活にどんな役割を演じようとするのか、それは我々家庭にとつて『摺鉢』や『大根おろし』よりも不用な物。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕎麥の粉に里芋の子をまぜて造つたその燒餅の焦げたところへ大根おろしをつけて焚火にあたりながらホク／＼食べるのは、どんなにおいしいでせう。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は冷い大根おろしを附けて、燒きたての熱い蕎麥餅を皆なと一緒に爐邊で食ふのが樂みでした。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかあかと燃える焚火の側で、焼きたての熱い蕎麦餅に大根おろしを添えて、皆なで一緒に食う事を楽みにした広い炉辺の方へ帰って行った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、くすぐつて遣れ――さうめん――にうめん――大根おろし／＼。",
              "citation": {
                "source": "出発",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "（夕）　　　（朝）ぬた　　　　　味噌汁大根おろし　　豆の煮たの菜葉汁　　　　煮〆漬物　　　　　漬物（めずらしく精進料理）（川口在）黒味噌（赤にあらず）田舎には山羊を飼養している家が多い。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "小串へ行つて、買物をする、財布を調べて、考へ考へ、あれこれと買つた、茶碗、大根おろし、急須、そして大根三本、茶一袋、――合計金四十三銭也、帰途、お腹が空いたので、三ツ角の茶店で柏餅を食べる、五つで五銭。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛子漬をするために、壺、鉢、塩などを買ふ、大根も買つた、久しぶりに大根おろしが食べられる。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日憂欝、畑の草をとつてごまかす、大根おろしはうまかつた、間引菜の味噌汁も。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝課諷経は食後にして、大根おろしに納豆で食べる、朝飯はいちばんうまい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "生で食うときは大根おろしにし、烹て食うときはふろふきにした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根おろしは汁を棄てず、醤油などを掛けなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄檗では煮汁も大根おろしも添えない。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏は去勢した雄の若鶏の鋤焼、鋤金に鶏の脂肪をひいて、肉を焼きながら大根おろしのしたじで頬張るに限るという。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根おろしのように、身を粉にして動くことを、無益も利益もなく、めちゃめちゃに好んだ壮健至極な娘でさえ、ばかばかしいと思ったほど酷き使った。",
              "citation": {
                "source": "勝川花菊の一生",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "来つけてから十年になること、そして、この家のどの古い女中も肉の択び方、炭加減、大根おろしの量の盛り方などは、自分よりも下手だと云って、特に、この店の良心的な野菜類の選定の厳格さを賞した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても今頃何の必要があって、隣りの室で大根おろしを拵えているのだか想像がつかない。",
              "citation": {
                "source": "変な音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして時ならぬ今時分何しに大根おろしを拵えよう。",
              "citation": {
                "source": "変な音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはきっと別の音が大根おろしのように自分に聞えるのにきまっていると、すぐ心の裡で覚ったようなものの、さてそれならはたしてどこからどうして出るのだろうと考えるとやッぱり分らない。",
              "citation": {
                "source": "変な音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者さんが足が熱って仕方がない、胡瓜の汁で冷してくれとおっしゃるもんですから私が始終擦って上げました」「じゃやっぱり大根おろしの音なんだね」「ええ」「そうかそれでようやく分った。",
              "citation": {
                "source": "変な音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊てんぷらに新鮮なだいこんおろし、これにしょうゆをかけて食べれば俗なだしに優る。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊だいこんおろしは新しくないと不味い。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊赤い身の刺身にはだいこんおろし。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいこんおろし一つするにも、それはいろいろと違うのであります。",
              "citation": {
                "source": "衰えてきた日本料理は救わねばならぬ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいこんおろし等も、畑からすぐ採ってしますと、たまらなくおいしく、かつおぶしなどはいりません。",
              "citation": {
                "source": "衰えてきた日本料理は救わねばならぬ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
