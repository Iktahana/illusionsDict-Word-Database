[
  {
    "uuid": "8bdd9d5c-dcc2-51d8-b20d-f393b1aff922",
    "entry": "弾痕",
    "reading": {
      "primary": "だんこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
