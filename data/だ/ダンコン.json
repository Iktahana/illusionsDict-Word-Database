      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bullet hole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼方はるかに白浪の咆ゆる所、檣折れ舷砕けたる廃船の二つ三つ漂へるはバルチツクの海ぞ、そこの岸辺に近く、嘗て実弾の祝砲を見舞はれたる弾痕の壁の下、薄暗き深宮に潜々乎として其妻と共に落涙又落涙、悲しげなる声をあげて祈り、祈りては又泣く一箇｜蒼顔痩躯の人を見ずや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は見渡したら果して、弾痕があった！",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、そこに果たせるかな弾痕があった！",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その胸のあたりに弾痕があった。",
              "citation": {
                "source": "猫の踊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門柱や扉には無数の弾痕が残つてゐた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは工部局の死体検視所から死体を受けとると、四ヶ所の弾痕がことごとく日本人の発砲した弾痕だと主張し始めた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い旗が出て上下に振れば十点、黒い円形の弾痕指示器が出て左右に振れば零点なのです。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院にも、鉄砲の玉があたっていて今だに弾痕が残っていて、激戦の日がおもわれるのであった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで誰にも云わないで単身、オートバイを乗り付けて調べてみると、一寸普通人には気が付かないが自動車の幌のまん中に、かなりの近距離から発射したらしいピストルの新しい弾痕がある。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方流血に彩られたる帝国ホテルは弾痕、破壊の跡｜瀝然として蜂の巣の如く、惨澹たる光景を呈しおれるも損害等は目下のところ判明せず。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……伊東はその朝、検視の折、武太郎の無残に切断された右｜大腿部の内側に銃砲による弾痕を密かに発見して、急に口を噤んでしまったことを思い合わせた。",
              "citation": {
                "source": "暴風雨に終わった一日",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾痕なし　裁判医が退場すると、現場は急にしいんと静かになった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それにしても、屍骸の何処を見ても弾痕の無いのは不思議ですな」「それでも兄さんは死んでいます！",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　中尉はさういつて、用意された白紙張の衝立に向かひ、ポン／＼と、一発又一発、丹念にうつて行くと、やがてその弾痕は点々とつらなつて、大きなＰの字をゑがき出した。",
              "citation": {
                "source": "風変りな決闘",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして散らばつた弾痕を次から次へと鉛筆でつないで行くと、VIVE LA FRANCE!　　（フランス万歳！",
              "citation": {
                "source": "風変りな決闘",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾痕と被害程度とを比較して、判ります」塩原参謀は、指先で、コツコツと窓硝子をつついた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見給え、この弾痕を。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の中で拾ったと云って、弾痕ある鶇を一｜羽持て来た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弾痕や弾丸から、われわれが何処の国籍の人間か、すぐ判断されてしまう」「じゃ、彼奴のうしろへまわってくびをしめましょう。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みろ、弾痕無数……伸縮自在の虫状突起……ふざけるな……。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスは、天井に大きな弾痕のあるロシヤ軍の将校集会所を振りだしに、山へ登つて、坦々たるドライヴ・ウェイを上下しながら、主防備線づたひにぐるぐるめぐつて行く。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "内容を、「鶴の抒情」は今事変従軍以前のものから、「蒼い弾痕」は従軍中、「阿呆の大地」と「天の狼」は帰還後今日迄のものの四章に分けた。",
              "citation": {
                "source": "天の狼",
                "author": "富澤赤黄男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはメーデーに労働者の子供までを傷けた警官隊の弾痕のめじるしであった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……彼の右胸にある弾痕が、自分の命を助けて呉れた記念である。",
              "citation": {
                "source": "春いくたび",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹幹に深い穴があいている木も若干見えたが、これは一八六八年の革命当時の大砲の弾痕である。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの検屍官の推定を裏付けるかのごとく、夫人の屍体は以上のような無数の疵をその豊艶なる肢体に印しつつ、三発の弾痕から鮮血を雪白の敷布に迸らせて、まったく一糸｜纒わぬ裸体のままで仰臥していたのには、思わず面を背けずにはいられなかったと立会いの警官たちも述べていた。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼いて柚の酢をかけてお上ったら頬が落ちますぞ」　お城の門まで行ったが、もう暗いので、壁に残った戦乱の弾痕は見えなかった。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを平静な感情として、ホラ、ここで笑いがはじまりだんだんこんなに高まっている。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだんこんな者が村に来なくなってから、単に子供を嚇す想像上の害敵となって永く残りその子供がまた成人して行くうちに、次第に新しい妖怪の一種にこれを算えるに至ったのは注意すべき現象だと思う。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
