  {
    "uuid": "4879f109-4cbb-5ea6-9abe-67ddd95a545d",
    "entry": "ダレ",
    "reading": {
      "primary": "ダレ",
      "alternatives": [
        "だれ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "undercut (of a machined edge)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "要するにラストシーンがダレると困りますから、三四郎の立廻りをなるべく簡単にやって頂きたい）Ｔ「空晴れて風そよぐ――」Ｓ＝垂れ下った柳　静かな川の流れ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思ふと、彼は急に家に歸りたくなつた、ほんのちよつとの間だけでいい、――「マグダレナよ、――私はいつもそんな風だつたね、赦してくれたまへ。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "マグダレニアンの壁画とシャバンヌの壁画の間の距離はいかに大きくとも、それはただ一筋の道を長くたどって来た旅路の果ての必然の到達点であるとも言われなくはない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき英国の美術館にある名画の写真をいろいろ見せられて、その中ですきなのを二三枚取れと言われたので、レイノルズの女の子の絵やムリリョのマグダレナのマリアなどをもらった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁夫や税吏や娼婦やマグダレナのマリヤやザーカイやの間にまじつた基督の顏を見る樣に思つた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "句が総じてダレています。",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまは、この像のそばに、バラのように赤いシダレヤナギをうえました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "久能張りのサミダレになった鉋目がまだ新しく見える胴の内側には、蛇の鱗ソックリに綾取った赤樫の木目が眼を刺すようにイライラと顕われていたからである。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト、ツボミタチノ　アタマノ　ウエデ　ダレカガ、「ヒバリデス、ヨ」ト　フトイ　コヱデ　イヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤガテ　オドロキガ　トマルト、「イマノ　フトイ　コヱハ　ダレデセウ」「キツト　オソロシイ　モノニ　チガヒナイネ」ト　ヒソヒソ　イヒアヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ダレカ、ソラノ　ナカニ　ヰルノ？",
              "citation": {
                "source": "デンデンムシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カナシミハ　ダレデモ　モツテ　ヰルノダ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハテ、コンナ　ウツクシイ　花バタヲ　ダレガ　アラシタノダラウ」ト　ヲトコガ　タホサレタ　イツポンノ　ケシノ　花ヲ　オコシテ　ヤラウト　スルト、ソノ　ネモトニ　シンチユウノ　ラツパガ　ヒトツ　オチテ　ヲリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロデ、ソノ　ムラハ　アサニ　ナツテモ　ダレモ　オモテニ　デテ　クル　モノハ　ナク、マドサヘ　アケナイノデ　アリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「デハ　ダレノ　カゲ」「ワシノ　カゲサ」ト　ポストハ　ニツコリシマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラスには七十人くらいの学生がいて、みんな二十歳前後の青年らしいのに、智能の点に於ては、ヨダレクリ坊主のようである。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の食事の世話をして呉れる日本語の巧い島民女マダレイに、先刻の家の女のことを聞いて見た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）マダレイは、黒い顏に眞白な齒を見せて笑ひながら、「ああ、あのベツピンサン」と言つた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の食事の世話をしてくれる日本語の巧い島民女マダレイに、先刻の家の女のことを聞いて見た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）マダレイは、黒い顔に真白な歯を見せて笑いながら、「ああ、あのベッピンサン」と言った。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）マダレイは、黒い顔に真白な歯を見せて笑ひながら、「ああ、あのベツピンサン」と言つた。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか怪しいな」「怪しいにも何も、私は、そのヨダレが欲しさに生命がけでモートル船に乗って随いて行きましたが、その中に又、世界中で私一人しか知らん奇妙な魚類をば見付けました」「フーン。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度出来てもその次にはダレてしまって出来ない。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……出来過ぎた処がある……ダレた処がある……ああでもない、こうでもいけない……と演出される度毎に洗練され、煎じ詰められて来る。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり異性に対して恍惚としていられる方の気持はともかくもダレていて、天下泰平ノンビリフンナリしているところがあります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、ギドー・レニの「マグダレナのマリア」があった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのマグダレナのマリアをもらって、神代杉の安額縁に収めて、下宿の※間に掲げてあったら、美人の写真なんかかけてけしからん、と言った友人もあった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩石のはざまよりは、青き迷迭香（ロスマリヌス）、赤き紫羅欄花など生ひ上りたるが、その巓にはチウダレイクスが廢城の殘壁ありて、猶｜巍々として雲を凌げり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌を現し、ヨダレを出し、笑ひ、自分の拳で、自分の頭をコキンと殴り、妙な踊りををどり、空を蹴る（破れ靴が虹のやうに飛んで、眼の下の川に落ちた。",
              "citation": {
                "source": "朝居の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
