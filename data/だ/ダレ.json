[
  {
    "uuid": "d53a6581-5e15-5323-8126-f02bd75c1f56",
    "entry": "誰",
    "reading": {
      "primary": "だれ",
      "alternatives": [
        "だあれ",
        "だーれ"
      ],
      "is_heteronym": false
    },
    "grammar": {
