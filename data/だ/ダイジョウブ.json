        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「たぶん、大丈夫だろうと思います。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいから大丈夫だよ。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「犬は大丈夫かい」「エエエエ直っきに来ますわ」「どうしてあの崖を駈け登れるだろう」慕門次は笑っている、ひょいと見ると、鼻をフン、フン、やりながら、もういつの間にか、傍へやって来て、嬉しそうに尾を掉っている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さん、直ぐ帰って来ますよ、坊やを連れて行って来まさ」（大丈夫ですよ、向うの気の済むまで居て来ますよ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丈夫だから」　老母の眼からは、涙が落ちた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見たときこれならこの建物は大丈夫だということが直感されたので恐ろしいという感じはすぐになくなってしまった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "メートルとキログラムの副原器を収めた小屋の木造の屋根が燃えているのを三人掛りで消していたが耐火構造の室内は大丈夫と思われた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丈夫だ、安心しろ。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『いゝいゝ、大丈夫だ。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらにひろがる高い雑木の梢を見た、あすこまで昇ればまづ大低の洪水なら大丈夫だ、そのうちにきっと弟が助けに来る、けれどもどうして助けるのかなとおれは考へた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」もう大丈夫だと安心しながらジョバンニはそっちを見あげてくつくつ笑ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長は大丈夫かといふやうにじっとその眼を見た。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですけど大丈夫ですわ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲がきれて陽が照るしもう雨は大丈夫だ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波、これも大丈夫だ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の流れる所は大丈夫｜滑らないんだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう大丈夫役人どもは私たちを殺しに来たのでもなく、私どもの居ることさえも知らないことがわかったのです。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「六十ぐらい大丈夫あります。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩が大へん柔らかでしたから大丈夫それで削れる見当がついていたのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は鼻緒を切つて仕舞つて何う爲ようかと思つて居る、本當に弱つて居るのだ、と信如の意久地なき事を言へば、左樣だらうお前に鼻緒の立ッこは無い、好いや己れの下駄を履て行ねへ、此鼻緒は大丈夫だよといふに、夫れでもお前が困るだらう。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は鼻緒を切つてしまつてどう為ようかと思つてゐる、本当に弱つてゐるのだ、と信如の意久地なき事を言へば、そうだらうお前に鼻緒の立ッこは無い、好いや己れの下駄を履て行ねへ、この鼻緒は大丈夫だよといふに、それでもお前が困るだらう。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験さえすめば数カ月後には大丈夫綺麗に忘れてしまうような、また忘れて然るべきような事を、何年もかかって詰め込む必要はない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は鼻緒を切つて仕舞つて何う爲ようかと思つて居る、本當に弱つて居るのだ、と信如の意久地なき事を言へば、左樣だらうお前に鼻緒の立ッこは無い、好いや己れの下駄を履いて行きねへ、此鼻緒は大丈夫だよといふに、夫れでもお前が困るだらう。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヽ大丈夫忘すれやアしなひ併しコーツと何んだツけねへ。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふぐのひれの干したの（大丈夫ですかな？",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "若侍の一人が「オオＴ「いい所へ、進藤氏　中村座へ行こう」　進藤、震え上って「馬鹿な事」　若侍が、Ｔ「日下部先生をお頼み　したから　今日は大丈夫」　成程、強そうな日下部典六の一党。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩は夕立ち、明日から四五日お天気は大丈夫よ」「まあ、そんなところですなあ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから本当に再び立ち上がれる大丈夫な命が見付かって来よう。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからだいじょうぶさ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、人には、もうだいじょうぶだ、癒った、と言った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
