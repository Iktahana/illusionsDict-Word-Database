    "definitions": [
      {
        "index": 1,
        "gloss": "writing on someone's behalf",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」伯母の病気が危篤だと云ふ代筆の手紙を手にして彼はかう呟いた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎県五島の故郷へ出す妓の手紙を代筆してやりながら、何故こんな所へ来た？",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎は字が書けぬので、番頭に手紙を代筆させた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄村のところへ教えを受けに来ている二三の書生たちに手紙の代筆をしてやった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "書生たちは、われもわれもと三郎に手紙の代筆、もしくは口述をたのんだのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに日に幾十人ものひとに手紙の代筆をしてやったり口述をしてやったりしていたのではとても煩に堪えぬ。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舍の粗野な老婦が居て、側の人にたのみ、手紙の代筆を懇願してゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の粗野な老婦が居て、側の人にたのみ、手紙の代筆を懇願してゐる。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎県五島の親元へ出す妓の手紙を代筆してやりながら、いろいろ妓の身の上話を聞いた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三好透がなんのために妹を脅迫するのか判りませんけれど、手紙ぐらいは誰かに代筆を頼んだかも知れませんよ。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「………」さきの偽筆は自分のために利益と見えたことだが、今のは自分の不利益になる事件が含んでいる代筆だ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "友川三郎兵衛矩兼血判嫡男　長一郎矩道代筆印次男　三次郎矩行　　印文久二年五月十四日　又、別紙奉書の※紙には美事なお家様の文字が黒々と認めてあった。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "済んまへんけど、あんた、一つ手紙書いてくれはれしまへんどっしゃろか」と豹一に手紙の代筆を頼んだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙の代筆が済むと、相変らず帯封を書き続けるのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が親元へ出す手紙の代筆をしてやりながら、いろいろ女の身の上話をきいた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方でＡ村の姉のはほとんど自筆で、たまに代筆があっても手跡は全くちがっていてこのほうはほとんど問題にならなかった。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は、どうもね、その」「くどい、書けんか」「書けません」「よし、それじゃ、婆あの分は、俺が代筆をしてやる」筆のことを思いだして、「筆がないな、婢を呼ぼうか」　岡本は注意深かった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も別に悪戯をするとも思わないけれど、第一代筆だろう。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗用の書状だけでも私の代筆が出來るならばまだしものことであります。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう手紙の代筆は眞平だ。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春どんの消息は、時々春どんの弟が代筆で、「熱が時々高くなるので、兄さんは未だ少しも起られません。",
              "citation": {
                "source": "やぶ入の前夜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかくは代筆された手紙を自分で私のところへ携へて来るのですが、その内容はいつもきまつて意味が曖昧なのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかくの手紙は、私の強意見をもつてぶくりんの行状をたしなめて呉れといふのが本意なのですが、ぐでりんの代筆に依るその文面はいつもほんとうにぐでりん流に一向要領が得られず、私はもうその筆者のヤケに肩さがりにそろつた達者な筆蹟を一目見るや虫唾が走るのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかくは、口では何うしてもその頼みごとを私に告げる術がなくて、ぐでりんに代筆を乞ふのですが、それらの事情の一端にはもともとぐでりんも相当な主要人物として登場してゐるのですから、これは完全なる代筆文とも申されぬのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮のお歌を女別当が代筆したものであった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "代筆のお返事などは必要がありません。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と云う速達のハガキ――それも誰かの代筆らしいのを、受け取った時、友人の急な重態に駭くのと同時に、心の底の何処かで『いゝ気味だ』と、云うような気がするのを、何うしても打ち消すことが出来なかった。",
              "citation": {
                "source": "神の如く弱し",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
