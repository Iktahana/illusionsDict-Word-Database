    "definitions": [
      {
        "index": 1,
        "gloss": "to stop (someone) by throwing one's arms around them",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おみのは又起ちあがりて行かんとするを、子之介は抱きとめる。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――落つこちるのでも、身投でも、はつと抱きとめる救手は、何でも不意に出る方が人氣が立つ。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを追おうとするお絹を万次郎が抱きとめる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウロは駆け寄って抱きとめる。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（彦三郎は突きのけて行かうとするを、權三は抱きとめる。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十吉は縁より飛び下りて抱きとめる。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは一生懸命に追い着いて、うしろからお角を抱きとめると、先生も引っ返して、ようようのことで刃物をうばい取って、無理に家へ連れ込むと、お角は先生のふところから紙入れを引き摺り出して、それを持ったままで何処へか出て行ってしまいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蟹のお角",
                "note": "青空文庫"
              }
            },
            {
              "text": "康頼　（成経を抱きとめる）成経殿。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　反絵は卑弥呼を抱きとめると、兵士たちの方を振り返って彼らにいった。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱きとめるつもりが、うまくゆかなくて、兄の身体の下敷になったまま、ズトンと床に仆れました。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "六太郎が慌てて抱きとめるようにして、「その身体では無理だ。",
              "citation": {
                "source": "保久呂天皇",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒鼻がボーイを抱きとめる。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その移りかわりがあまりにあざやかに眠元朗の目にうつり過ぎたため、かれは危ないものをうしろから抱きとめるように、もとのように穏やかな心になろうとした。",
              "citation": {
                "source": "みずうみ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを倒れさせまいと、誠がその肩を抱きとめる。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑事の抱きとめる手がおくれて、あやか夫人は下へくずれ、二三度床板をつかむように這いだして、やがて、くずれて、動かなかった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが飛びついて、抱きとめるのが一秒おくれたら、この盛装の花嫁御は、神様の祭壇の前に、不様にひっくり返っていたに違いない。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手で胸に抱きとめるようにしてデスクに落ちるのをふせぎ、左手に握りなおした。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに立っていた道具がかりの木村という男が、ハルミさんを、だきとめるようにして、「アッ、びっくりするじゃありませんか。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林君は、とっさに立ちあがり、ふたりをだきとめるようにして、どうしたのだと、たずねますと、正一君は、「あいつがバスの中にいる。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
