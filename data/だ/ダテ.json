[
  {
    "uuid": "6dab6fc4-0209-5132-bae3-b61bd5a7502d",
    "entry": "伊達",
    "reading": {
      "primary": "だて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elegance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の句には、芭蕉のやうな幽玄な哲学や寂しをりもなく、蕪村のやうな絵画的印象のリリシズムもなく、勿論また其角、嵐雪のやうな伊達や洒落ツ気もない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「江戸の花」には、命をも惜しまない町火消、鳶者は寒中でも白足袋はだし、法被一枚の「男伊達」を尚んだ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」の色彩はおそらく「遠つ昔の伊達姿、白茶苧袴」の白茶色であろう。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎い男、妾の伊達男、お前が苦しむほど抱きしめたい、女の全て投げ出して。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "――Ｙ、妾を伊達の花嫁と思ってくれない？",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」太田ミサコは鉤形の鼻を鳴らして殺風景な部屋椅子に腰を下ろすと、埃のつんだ卓子に片ひじついて、「ほほ、それではバル・セロナ生れの伊達ものには見えないわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と納戸へ入って、戸棚から持出した風呂敷包が、その錦絵で、国貞の画が二百余枚、虫干の時、雛祭、秋の長夜のおりおりごとに、馴染の姉様三千で、下谷の伊達者、深川の婀娜者が沢山いる。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「鞄は汚れたのが伊達なんですとさ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州武士の伊達政宗が罪を堂ヶ｜島に待つ間にさえ茶事を学んだほど、茶事は行われたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイヤのネクタイピンなど、無いのを私は知って居りますので、なおのこと、兄の伊達の気持ちが悲しく、わあわあ泣いてしまいました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きている限りは、ひとに御馳走をし、伊達な着物を着ていたいのである。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は上衣と胴衣を脱いでワイシャツ一つのネクタイを緩めているし、眉香子も丹前を床の上に脱ぎ棄てて、派手な空色地の長｜襦袢に、五色ダンダラの博多織の伊達巻を無造作に巻きつけている。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』という声が自分のすぐ前でしたと思うと自分とすれ違って、一人の男がよろめきながら『腰の大小｜伊達にゃあささぬ、生意気なことをぬかすと首がないぞ！",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年六月、東京朝日新聞）　この記事が東京朝日新聞に出たのを見た滝野川の伊達氏が、わざわざ手紙をよこして、チャップリンの文楽見物の事実を知らせてくれた。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び女を二人連れた下町風の伊達者が通常「詩人の隅」と呼ばれる壁寄椅子の隅に陣地を占め白葡萄酒を飲み乍ら料理の来るのを待っている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、錦絵のお孝とて、人の知った、素足を伊達な婦である。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊達巻で素足という芸者家の女房。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生際曇る、柳の葉越、色は抜けるほど白いのが、浅黄に銀の刺繍で、これが伊達の、渦巻と見せた白い蛇の半襟で、幽に宿す影が蒼い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と抱いて出た掻巻の、それも緋と浅黄の派手な段鹿子であったのを、萌黄と金茶の翁格子の伊達巻で、ぐいと縊った、白い乳房を夢のように覗かせながら、ト跪いてお孝の胸へ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "輪曲ねて突込んだ婀娜な伊達巻の端ばかり、袖を辷って着流しの腰も見えないほどしなやかなものである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處へ病上りと云ふ風采、中形の浴衣の清らかな白地も、夜の草葉に曇る……なよ／＼とした博多の伊達卷の姿で、つひぞない事、庭へ出て來た。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　フト夫人は椅子を立つたが、前に挾んだ伊達卷の端をキウと緊めた。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「哥太寛も餞別しました、金銀づくりの脇差を、片手に、」と、肱を張つたが、撓々と成つて、紫の切も亂るゝまゝに、弛き博多の伊達卷へ。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其のかはり、衣服は年上の方が、紋着だつたり、お召だつたり、時にはしどけない伊達卷の寢着姿と變るのに、若いのは、屹と縞ものに定つて、帶をきちんと〆めて居る。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト其の胸を、萌黄に溢れ、紫に垂れて、伊達卷であらう、一人は、鬱金の、一人は朱鷺色の、だらり結びが、ずらりと摩く。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）お沢　（悄然として伊達巻のまま袖を合せ、裾をずらし、打うなだれつつ、村人らに囲まれ出づ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌リュテースを編輯してゐたレオ・トレズニカは、アムール・ジョーヌと『歎き』（ラフォルグの詩集）の作者との明らかな類縁に驚いて、コルビエールに肩を持ちながら両者を比較してラフォルグを荒だてたのであつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして距離のへだてから、自然に交情が疏くなつてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は万策尽きた気持で、襖をへだてた小坂家の控室に顔を出した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "觀念して、ただていねいにお辭儀しておけばいいのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
