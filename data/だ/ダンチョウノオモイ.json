    "definitions": [
      {
        "index": 1,
        "gloss": "heartbroken thoughts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
