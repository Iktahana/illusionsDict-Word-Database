    "definitions": [
      {
        "index": 1,
        "gloss": "warm country",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冬ながら九州は暖国ゆえ、天気さえよければごく暖かで、空気は澄んでいるし、山登りにはかえって冬がよいのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘロドトスが言った通り、ペルシアは暖国だがその人誕生祝いに馬肉を饗し、また全で馬、驢、駱駝を烹用いて、ギリシア人が、かほどの美饌を知らぬを愍んだから、どの国で馬肉を食ったって構わぬはずだと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に櫨のみ暖国でもよく紅葉する。",
              "citation": {
                "source": "沼津千本松原",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い方からやって来たお新は暖国らしい空気を楽しそうに呼吸した。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の降らない暖国では樹木がこうも、さやさや軽く真直ぐ育つものか。",
              "citation": {
                "source": "九州の東海岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐は南国暖国、秋のおわりに、豆苗が伸び、胡瓜がたくさんぶらさがっている、よい国だ。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暖国には樹上の家、寒国には土中の室、神代には皆それであった」　土地の者にも土室が好い事を勧めていた。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に古代には軽羅をまとつた希臘、羅馬等の暖国の民さへ、今では北狄の考案した、寒気に堪へるのに都合の善い洋服と云ふものを用ひてゐる。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に仏医ショアベーの名著『暖国の疾病』を操ってみれば判るとおりで、それにある奇形癩の標本を、いちいち稚市と対照してゆけば、やがて幾つか、符合したものが見出されるに相違ない。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "求馬は甚太夫喜三郎の二人と共に、父平太郎の初七日をすますと、もう暖国の桜は散り過ぎた熊本の城下を後にした。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃は極月二十日の午後、暖国のこととて日射し暖かに、白砂青松相映じ、心ゆくばかりの景色である。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう四辺は夕暮れて、暖国の蒼い空高く円い月が差し上った。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "独白――　レモンの花の咲く南方の暖国はここであります。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの川で探る鮎の餌釣りは暖国四国の餌釣りと共に、微妙な感覚を糸の揺曳に見る。",
              "citation": {
                "source": "香魚の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっぽんは暖国を好むものと見えて、四国、中国、九州地方に多い。",
              "citation": {
                "source": "すっぽん",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "又私は少年時代、北原白秋の思ひ出なぞといふものに異常なノスタルヂイを刺戟されたものであるが、あの風景が九州の暖国の色調に溢れたものであることは、今更私が言ふまでもないことであらう。",
              "citation": {
                "source": "気候と郷愁",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの樹は暖国でなくては生じていなく、内地では稀れに植えたものを除くの外は僅かに四国の南部と九州とに野生があるのみで、そう普通に見られる樹ではない。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来暖国の産であるからトテモ日本の北ではダメというので久しい間誰れもこれを関東地へは持って来なかった。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この暖国産の桜が意外にも熱海でワケなくよく育ちよく開花するので、これを眺めた私は忽ち一の熱海繁栄策が胸に浮かんだので数年前これを発表しておいた。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南天はわが国の暖国には山林地に自生がある。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿根生の大形常緑草本でヒガンバナ科に属し、Crinum asiaticum L. var. japonicum Baker の学名を有し、我国暖国の海浜に野生している。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然は水母の化石を百万年の後に残し、人間の夢は今この雪の結晶を十年博物館の一隅に設えて、暖国に育った子供達に顕微鏡を覗かせたいと願う。",
              "citation": {
                "source": "雪の化石１",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐の韓愈が雪を豊年の嘉瑞といひしも暖国の論なり。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖国の雪一尺以下ならば山川村里｜立地に銀世界をなし、雪の飄々翩々たるを観て花に諭へ玉に比べ、勝望美景を愛し、酒食音律の楽を添へ、画に写し詞につらねて、称翫するは和漢古今の通例なれども、是雪の浅き国の楽みなり。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三年十勝岳へ通っているうちに、何とかしてこの美しい雪の結晶を、そのまま固めて、暖国の子供たちに見せてやれないものかと思うようになった。",
              "citation": {
                "source": "雪の化石２",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖国は作るよりもむしろ商うのに多忙である。",
              "citation": {
                "source": "地方の民藝",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　窯は日本の南端に近い暖国にある。",
              "citation": {
                "source": "苗代川の黒物",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
