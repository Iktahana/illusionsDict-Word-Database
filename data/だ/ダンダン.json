[
  {
    "uuid": "05445208-d2ad-531d-bf80-dc6b5f032619",
    "entry": "段々",
    "reading": {
      "primary": "だんだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gradually",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あんな奴が、段々偉くなりやがる」、ハテ面妖なとＡの方で思ふのだが、Ｂとしたら、変な話ぢやないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に神経を使はなくては、何時も綺麗でキチンとしてゐるとはいくまい婦人の和服といふものは、段々改良されてはゆくのであらうか、なぞとそのうち僕は考へ始めたものである。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処の景色を私は好きである、坂は段々勾配を増し、酔つて夕陽に照らされてスタコラゆけば、まるで我が身か、我が身が運ぶ箱か分らず、多分今飲んだビールを運ぶ容器であるに相違なからう。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし段々寒くなって来ました。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして段々人嫌ひになつて行くのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分、バッハ頃から段々人類は大脳ばかりをでかくしだしたのだ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は段々自分が話の中心になることを感ずるとモヂモヂし始めた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段とは言つても、段々が一つづつ分明になつてゐるわけではなく、灰色の鈍く光る小さい珠の敷きつめられたゆるい傾斜の坂のやうなものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井の頭の池のところから、石の段々を、二十いくつ登つて、それから、だらだらの坂を半丁ほど登ると、御殿山である。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は段々睡くなつて、そのうち卓子の上に伏せつて眠りましたが、するとお庭の椽側のそばの、陽を浴びた石の上で、尾を立てたり下ろしたりしてゐる、プチ公（犬の名）の夢を見るのでした。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルが段々調子を上げ、全で余韻がなくなるほど絶頂に達すると、一時途絶えた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにあとから／＼此處を目指して町の方から坂を下りて來る人の群は段々に増すばかりである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際に一人が五つの階段の一段々々を踏み鳴らす。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日が段々低く落ちて行つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯律儀な太陽は私にかまはず段々に低く垂れ下つて行つて景色の變化が餘りに急激になつて來るので、いゝ加減に切り上げてしまはなければならなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所が場所だけに見物が段々背後に集まつて來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不自然さが二峰を人工の庭の山のように見せ、その下のところに在る藁葺の草堂｜諸共、一幅の絵になって段々近づいて来る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三）　ハ行音は、第二期の末までは、ファフィフゥフェフォのようにＦではじまる音であったが、江戸時代に入って次第に変化を生じ、唇の合せ方が段々と弱くなり、遂には全く唇を動かさずして、これと類似した喉音ｈをもってこれに代えるようになった。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでも同じ数だけなのですが、言語においては或る一時代の言語にあったそういう音韻組織は、時の移ると共に段々変って行くことがあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾つかきまった数だけ使われておったその音自身が段々変って行く。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の語の下に用いられるようになって、段々濁音になったというようなことがあったので、或る場合には濁音、或る場合には清音で書いてあるということもあると思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと共に、時代的に見れば、ずっと古い時代に厳格に区別せられていたのが、或るものは奈良朝の半頃から、或るものは奈良朝の末頃から段々区別が混同して、平安朝に入ってからは大抵区別がなくなったろうという風に考えられる。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風にして、音から言えば普通の短音は後になるほど段々少なくなって来た。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体の数から言えば今の方が多いのでしょうけれども、ずっと古くからあった音は段々減って来たのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから段々年代が降るに従って混乱がひどくなって、実際の発音としては全然区別が出来なかったろうと思う位になっております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「仲蔵……」　声段々細って遂にガックリなる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々獣的になる典六の顔。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度に作者の前書に書いてゐることの意味が段々強くなるのを知つた。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどうしたことだらう、私の心を充してゐた幸福な感情は段々逃げて行つた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風に致しましたら、わたくしはやっぱり段々に扮装なんぞは構わなくなりまして、化粧も致さないようになりますのでございましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
