    "definitions": [
      {
        "index": 1,
        "gloss": "carrying in one's arms (a baby, pet, doll, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「何だ、お前姉さんに抱っこして……。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに気が置けなくて……それにまあいつも晴々した見晴らしで御座いますこと……オヤ坊ちゃんおとなしですこと……一寸｜入らっしゃい、抱っこしましょう」　と口では云いながら、内心実はつまらない。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、逃げ回ってばかりいないで、少し坊やを抱っこしてやってちょうだい」　彼女は夫に赤ん坊を突きつけた。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝子は、ベッドの上に半分のるやうにして、時子のほっそりした小さな頬に顔をすりつけた、そして、『あゝ母ぁさんに抱っこして、お家に帰るんですよ。",
              "citation": {
                "source": "秋は淋しい",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦の杉本さんは、なにか洗物でもしてゐたと見えて、裾をからげて入って来ると、『さゝお家に帰るんですわね、お母さんに抱っこして。",
              "citation": {
                "source": "秋は淋しい",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾がチャンと抱っこしていたのに……ええ。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりいつものように右の手には御気に入りの人形が抱っこされていました。",
              "citation": {
                "source": "博多人形",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ろ」「それから」「は」　あなたは母様の膝に抱っこされて居た。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人同士は、けろりとけんかも忘れ、睦じく抱っこ寝んねしている間に、傍のおみささんは娘の手を引っぱって逃げ歩き、とばちりを受けて私まで（たれにもいいこそしないが）一晩中まんじりともしなかったとは！",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたいも抱っこして」「あたいも」「あたいも」　そう云えば私はこの協会の中では、いつの間にか南先生で通っていた。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして元柳ばしぎわに船をつけてもらうと、抱っこしたまま、いい匂いのものにくるまれて、薬研堀の囲いものの家へ投りこまれた。",
              "citation": {
                "source": "牢屋の原",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前にこうして抱っこされていてもよ……綱渡りの途中で綱が切れちゃって、そのまんま宙に浮いているような気もちよ。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "久し振りに抱っこして寝たいですからと申込みました……久蔵親分は若い人に似合わない子供好きで、見付の子供は皆オジサンオジサンと云って懐いていたそうです。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてデッキに片足をかけて、奥さんに、「赤ちゃんを抱っこしましょう」　と声をかけて、奥さんの返辞を聞かないうちに、もう赤ン坊を受取って、中へ飛び込んだ。",
              "citation": {
                "source": "愛の為めに",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、しっかり抱っこして……。",
              "citation": {
                "source": "南さんの恋人",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ姉様の所へおいで、さあ昔のように緊かりと抱っこしてあげましょう。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、あたしの方に、おぶさったり抱っこしたりする力も、なかったとしたら……。",
              "citation": {
                "source": "立札",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた随分よくして貰って方々｜抱っこして行ったりしたんだけどね。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれどれ、おじいちゃんが抱っこしてやろう。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方赤ちゃんを抱っこして大学の銀杏の木の下のベンチに腰をかけてゐると、何だかペナイサキペナイかヲカチペにいた時の事が思出されます。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんまる坊主になって戸外へばかり出たがるので、家中の人が交る／″＼抱っこして出るので真黒くなって、外で会ふ人は誰も女の子だといふ人はありません。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく膝の上に抱っこして子守唄をうたってやりますよ。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時に私は膝に抱っこしてやるんですがね、そして子守唄をうたうんです。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の止めの一句を云ってしまうと、それで安心しきったように、然しまた凡てから暫く休らいだかのように、「少しお父さんに抱っこしていらっしゃい、」と云いながら子供を私の方へ差出す。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ抱っこしてお貰いなさい。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、お父様に抱っこしてごらんなさい。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱っこしてあげましょう。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々子が菓子ほしい時に、父は必ずだっこしろ、だっこすれば菓子やるというために、菓子のほしい時彼はあっこあっこと叫んで父の膝に乗るのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩お神明さんの、杉のうしろにかくれていて、来るやつを見ていたそうです、そしていよいよ網を入れて鯉が十｜疋もとれたとき、誰だっこらって出るんでしょう、魚も網も置いたまま一目散に逃げるでしょうバキチは笑ってそいつを持って警察の小使室へ帰るんです。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまに、この箱から、お父さんのお声が聞えて来ますよ」　夫人は末の小さいお嬢さんをだっこして、そう教えている。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
