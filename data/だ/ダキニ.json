    "definitions": [
      {
        "index": 1,
        "gloss": "Dakini (fairy-goddess)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
