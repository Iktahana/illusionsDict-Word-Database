[
  {
    "uuid": "6db06fe3-f09b-504a-aab6-1d9f7e80eb55",
    "entry": "堕獄",
    "reading": {
      "primary": "だごく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
