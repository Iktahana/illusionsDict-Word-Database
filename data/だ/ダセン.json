          "literary": [
            {
              "text": "ほうきめのついてる根元の砂地に、やや黄ばんだせんだんの実が散り乱してある。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今朝はフィッタブルに集まらなくちゃならんので、人手もないし、船もだせんのだが――」「そんなら泳いでわたるか？",
              "citation": {
                "source": "歌う白骨",
                "author": "THE ECHO OF A MUTINY",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただせんぼう（羨望）のため息をもらしながら、この誇り高き紳士とその愛によってむすばれた子犬とのあとを、かなりながいあいだついていった、ということを告白するだけである。",
              "citation": {
                "source": "年の瀬の音",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
