          "literary": [
            {
              "text": "また、保田与重郎君の幻想と小宮豊隆氏の高度な知的ディレッタンティズムが肩と肩とを抱き合わせ得ないことも自明である。",
              "citation": {
                "source": "近頃の話題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ｐとｄとを抱き合わせて見給え。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堡塁の傍らに、旗竿を立て、黄色の地に、白の半月と赤い星を抱き合わせに染め抜いた、札荅蘭族の旗が掲げてある。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            }
          ]
        }
