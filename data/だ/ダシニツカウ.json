        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "で、折角大事にして、ちょくちょく小出しに使うがいい。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先二三十年の間、ボツボツ小出しに使うはずだった力を、一どきにグンと使ってしまったので、もうへとへとになって来た。",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台松島湾の数珠子釣りも郷土色があっておもしろいが、魚も松笠で色もどす黒く、手につかんでもざらつき、煮出しに使うぐらいなものだ。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由党にしてからが、せいぜい自分等の役に立つ間だけ俺達を出しに使うて、自分等が世の中に出てしまえば、放り出そうという手だ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が振り返ると、彼女の良人がすぐうしろで、石灰の掻き出しに使う大きなショベルを振り上げていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロックをだしにつかう、あらゆる商業行為が有効に可能となるのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
