    "definitions": [
      {
        "index": 1,
        "gloss": "to embrace each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白花という名を冠らせるくらいだから白くはあるが、花冠の脊には、岩魚の皮膚のような、薄紅の曇りが潮し、花柱を取り巻いた五裂した花冠が、十個の雄蕊を抱き合うようにして漏斗の鉢のように開いている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふざけて抱き合う拍子にくわえたシガーが泥の上へ落ちたのを拾ってはまた吸っています。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の心が両方から自然に開けていって、ついに驚きながら喜びながら互に抱き合うのはありそうなことであって、そしていいことだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央に怪神の抱き合うた形の炉あり、炉には汗のように油脂が滲み出て居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心易いものと心易いものが、お互いに死出の友を求めて組みし合い、抱き合うばかりにして突進した。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬生は未だ生きているような壮い女の屍と抱き合うようにして死んでいた。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに抱き合うておいでの花聟僧に花嫁僧お二人じゃ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはそんな人殺しなんぞやった覚えはねえよ」「じゃ、だれだ、だれだ、だれがやったんだよ」　ひょいとみると、ひしめきたっているその群れから離れて、暗いあんどんの灯影の下に、身を引きそばめながら、抱き合うようにして震えている子どもがいるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、抱き合うのよ、いい子だから！",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「其処には、人間と人間とが互に抱き合うような情味や、人間としての生の享楽などと云う事は薬にしたくもない」とも云っているようだ。",
              "citation": {
                "source": "新しき世界の為めの新しき芸術",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び線路に戻ると、互いに振り向き、腕を互いに廻してひしと抱き合う。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち窪地の底で抱き合う二人の背の上へ、鹿の塊りがひき続いて落ち込むと、間もなく、雑然として盛り上った彼らは、突き合い蹴り合いつつ次第に静に死んでいった。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような孤独とかような創造とのうちに深く潜み入るとき、詩人が“Voll milden Ernsts, in thatenreicher Stille”と歌った時間において、私は宇宙と無限の関係に立ち、一切の魂と美しい調和に抱き合うのではないであろうか。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「抱き合うのは男女と相場が定ってるんだが……」「だから不景気で食えねえと愚痴っぽくなんのよ。",
              "citation": {
                "source": "お菜のない弁当",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（両人無音にて顔を見合わせ、かたく抱き合う）少年　（四方を見廻し）お姉様、このお室は淋しいね。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両人抱き合う、やがて離れる。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "互に抱き合うと、彼女は彼の頸筋に顔を埋め、彼は彼女の髪に顔を埋めました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき検事と署長とは、踏台の上に抱き合うようにして乗っていた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は支配人室でサンドウィッチのお弁当をすませ、第四幕オデット姫の助力によって魔法使いロットバルトを刺殺し、舞台が明るくなって、暁近い湖面の背景の前に、王子ジイグフリードと、王女オデット姫と抱き合う最後の感激を見て、帝劇を出ずる時、しばしば振返って別れを惜しまざるを得ないのであった。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父甥なぞの間柄かと見えて、迎えるものと迎えらるるものとが男同志互いに抱き合うのもある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆の声こそは世界の声だ、一切のものが更新されるのだ、一切の組織が人間自然の意志に帰るのだ、人間と自然が抱き合うのだ、そしてそれを高めてゆく世界、そこに民衆的文化――正しき人間と自然との結合、強い意志――永遠の生長。",
              "citation": {
                "source": "君達に送る――新しい民衆の精神",
                "author": "――雑誌『民衆』の創刊号に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間からも木蔭からもそろそろと匍い出した闇は、この打ち開けた原を取り巻いて、最初は地の上を匍うているに過ぎなかったが、次第に上の方にのし上って、何時の間にかつと抱き合うと、大きな翼の下に原を押覆せてしまった。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "異性と抱き合う順序として、まず同性の私の所へ動いて来たのです」「私には二つのものが全く性質を異にしているように思われます」「いや同じです。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "半分とかからないうちに、これだけの順序と、段落と、論理と、空想を具えて、抱き合うように彼の頭の中を通過した。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいとしい、可哀いと抱き合うばかりでも、世の中の主な楽の一つです。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「有難い、志は忘れぬぞ」「旦那様、嬉しゅう御座います」「話は後でする、来い」「…………」　二人はのた打ち廻る蛇の中で、犇々と抱き合うと、其の儘｜舷を蹴って夜の水の中へ――「それ逃すな」　二艘の船から、追っ駆けて飛び込もうとしたがいけません。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第八夜　蛇使いの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乙や、逢いたかったよ」「姉や、よく来てくれたね」　抱き合う二人、言葉とがめをするのも忘れて、百枝は微笑ましく眺めやるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "迷子札",
                "note": "青空文庫"
              }
            },
            {
              "text": "山に眠る家、家を庇う山、人と自然とがここでは互に抱き合う。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは、だきあうようにして、せんこうていのきかいの中にうずくまっていました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の少年はその勢いのものすごさに、もう逃げる場所もない地下室のすみで、たがいにだきあうようにして、とうとう悲鳴をあげないではいられませんでした。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
