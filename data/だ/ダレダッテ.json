        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誰だって、いつまでも上品な坊ちゃんではおられない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時刻には、誰だって眠っていなければならない筈であった。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍艦の場合などでは、それをどうして沈めるか、どうして穴を開けるかを、絶えず研究していることは、誰だって知ってることだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて訊くと「あんな伯母さんのことを気にかけるものではありません」「仔細あって私たちは交際ってはいません」「あれで、なかなか裏に裏のある女でね」「あんな大きな山に住えば誰だって評判はよくなるさ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、誰だって、ほんたうにいいことをしたら、いちばん幸なんだねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくらも、一疋か二疋なら誰だって拾った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だって夏海岸へ遊びに行きたいと思わない人があるでしょうか。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊だって誰だって気持ちのいい所へは来たいんだ。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子も真の親の様に思ってくれ私も吾子と思って余所の人は誰だって二人を兄弟と思わないものはなかったほどであるのに、あとにも先にも一度の小言をあんなに悔しがって夜中泣いて呉れなくともよさそうなもの。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だって、自分の下に使うのに、おとなしい羊のような人間を置いときたいのはあたりまえじゃないか――だが、一年や二年、シベリアにいたっていなくったって、長い一生から見りゃ同じこった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動をやっている者は、先生だって、誰だって悪いというような調子だ。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だって人間なら、汗や垢が、ぬるぬるして気持が悪いなァ同じこった！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう誰だって胸中からもくもく湧いてくるうれしさに笑い出さないでいられるでしょうか。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だってきれいなものすぎさな。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だって惜しいとは思います。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、誰だって、ほんとうにいいことをしたら、いちばん幸なんだねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だって高慢税は出したかろうではないか。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ直後のことも、あれこれ書いてお知らせするつもりでありましたが、ふと考えてみれば、そんな悲しさは、私に限らず、誰だって肉親に死なれたときには味うものにちがいないので、なんだか私の特権みたいに書き誇るのは、読者にすまないことみたいで、気持ちが急に萎縮してしまいました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だっていいじゃないか。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、誰だって章魚のきらいな人はない。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だって夏海岸へ遊びに行きたいと思はない人があるでせうか。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊だって誰だって気持ちのいゝ所へは来たいんだ。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だってむしゃくしゃしたときは何をするかわからないのだ。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "饑死する者は世間に滅多にありや仕ないから、食って生きてるだけなら誰だってするよ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だって人間ならそうある筈なのだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえの顔を見りゃ、だれだっていやんなっちまわあ！",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれだって、おなかをぶたれるのはいやですからね。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれだって、殺してたべようとは思わないほどに、なってしまいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのやばん人どもは、だれだって見つかりしだい、殺してたべてしまうのです。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "くつ屋は、だれだって、ぬいあわせたとは思えないほど、かっこうよくつぎあわせました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
