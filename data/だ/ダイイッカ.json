        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これが修業の第一課である。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の美容術の第一課は、心のたんれんだ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年十一月岡本かの子第一課　悲観と楽観　悲観も突き詰めて行って、この上悲観のしようもなくなると楽観に代ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は、あてにならない、といふ発見は、青年の大人に移行する第一課である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠すには曝せ、というのは、探偵小説の第一課だからね。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其夜私は、薄暗い手ランプの影で、鉛筆の心を甜めながら、贈物の帳面に、讀本を第一課から四五枚許り、丁寧に謄寫した。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其夜私は、薄暗い手ランプの影で、鉛筆の心を舐めながら、贈物の帳面に、読本を第一課から四五枚許り、丁寧に謄写した。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今日から学校が始まつて少年少女が登校する、私も小学生の心で人生第一課から学び直さう！",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一課、眼所能見之物論と、実に面倒な漢文で訳がついている。",
              "citation": {
                "source": "蠹魚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一課　貧乏　太陽は斜に、桐の木の枝のところにそこらをぼやかして光つてゐた。",
              "citation": {
                "source": "障子のある家",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、美人座へ、時々行く外（多分美人座では、私が、千早昌子を好きだと考えているであろうが、酒場では、好きでなくとも好きな一人を仮定しておくことは酒場交際法の第一課である。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今の仕事は鋭利な鋏を、右手の掌の中へ隠して、紐を指先で切ると同時に、掌へ、印籠を落す、という、掏摸の第一課の仕事であった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは宇宙旅行の第一課にそうとうする知識なのである。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論イデオロギー第一課の説明ではよく理解が行くが、劇としての必然性が極めて稀薄で、何だか効果なし。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず女中からというのが記者常識の第一課だから、三人の女中に個別対面してみたが、「ゆうべのお客さんは大川さんお一人ですよ。",
              "citation": {
                "source": "能面の秘密",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても怖しくて居たたまらなくなったんです」　完全に信じうるものをも疑えというのが、これも探偵小説の第一課だ。",
              "citation": {
                "source": "能面の秘密",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪紳士の留守宅に、おいて、このような奇怪な出来事が誰人にも知られずおこなわれている折も折、警視庁の捜査第一課はその主力をあげて三台の自動車に詰められ甲州街道をまっしぐらに西へ西へと飛ばしていた。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "駐在所の警官から警視庁へ連絡があってそこで捜査第一課の出動となったわけであるが、今日は田山課長が一行をひきいて、これまでにない力の入れ方だった。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁には四ツ目殺しという第一課がある。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第一課の生き死にをどうやら心得ているだけなのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の熱演も、捜査第一課の講義にあずかって、オジャンになってしまった。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "救いなどゝいうものはない、こう自覚することが麻薬中毒を治す第一課で、精神病院へ入院してもダメ、こと精神に関しては、自分の意志で支配して治す以外に法がないとさとる。",
              "citation": {
                "source": "安吾巷談",
                "author": "麻薬・自殺・宗教",
                "note": "青空文庫"
              }
            },
            {
              "text": "十兵衛はこの第一課を先ずノートに記入した。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "月下氷人という役がどんなに難かしいものか、第一課でうんと手を焼いてみるがいいや。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、話を前に戻して、いかに味が分らない人と言っても、まったく分らぬわけではないから、その人なりの嗜好を尊重することが、ものを美味く食わせる第一課である。",
              "citation": {
                "source": "道は次第に狭し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ぜいたくで値段の少々高いくらいは、前もって承知の食道楽者にとっては、なおさらのこと、材料の選択が第一課だ。",
              "citation": {
                "source": "料理の秘訣",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが果報の第一課であるが、カケコミを成就したものはいかにも顔がハレバレして、妙花天に遊ぶ果報を得たことがうなずかれる。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒色を慎しむことが潜水夫の第一課だ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の総会の第一課題は、北氷洋の氷山についてであって、氷山の起源、移動、融解、特にその出現の予報について論議しあう点に重きをおいた。",
              "citation": {
                "source": "国際雪氷委員会のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "捜査の重点は直ちにこの部分へ移され、警視庁捜査第一課と、洲崎署の全力は、古石場町を出発点にして、全市域に亙って、その足跡を追跡しはじめた。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
