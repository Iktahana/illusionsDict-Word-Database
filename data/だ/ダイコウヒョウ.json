    "definitions": [
      {
        "index": 1,
        "gloss": "very highly commended",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "権之助の地震加藤、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年（庚午）　一八七〇○三月、守田座において市川左団次の丸橋忠弥初演、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵の馬子丑蔵が田舎訛りのベエベエ詞のゆすり場、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊五郎の魚屋宗五郎の酒乱、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎の渡辺崋山、左団次の高野長英、いずれも大好評にて、四十五日間も打ち続けたり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "左団次の佐野次郎左衛門、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊五郎の多助、馬の別れが大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎の大口屋暁雨、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九〇年五月十六日に開かれたこのセミナーは、内容充実し大好評であった（らしい）。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした宣伝が効を奏して、この興行は大好評の大入りを占め、芝居を観ると観ざるとを問わず、東京市中に牡丹燈籠の名が喧伝された。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが少しく遺憾であったが、役々いずれも好評、取り分けて例の「馬の別れ」が大好評で、この以来、塩原多助といえば直ぐに「馬の別れ」を思い出すほどに有名なものになってしまった。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も知るごとく、この劇の見せ場は二幕目の深川富吉町新三宅の場で、菊五郎の新三と中村仲蔵の家主長兵衛が大好評を博したのである。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治論の盛んな時代で、かの末広鉄腸居士の政治小説『雪中梅』などが盛んに行なわれたので、機を見るに敏なる大阪の興行師はすぐにそれを脚色させて、主人公の国野基を右団次、ワキ役の武田猛を鴈治郎に勤めさせて、角座で上演することになると、それが非常の人気を集めて、なかんずく鴈治郎の武田は大好評であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは何かの差支えがあって観なかったが、この鬼女もやはり大好評で、かれの病いはいよいよ重くなって来たにもかかわらず、舞台の上の台詞の声が新富座の前の往来にまで筒抜けに聞こえたということであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田は初めて川上の一座に加入した当時、脚本は俳優が作るものだと考えていたほどに、芝居については無知な人物であったそうであるが、三、四年のあいだにめきめきと上達して、殊に今度の「威海衛陥落」における丁汝昌の役は大好評であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目は黙阿弥作の「重盛諫言」を土台として、三代目新七が新たに鹿ヶ谷の別荘や日吉の神輿振りなどを書き加えたもので、団十郎の重盛や西光法師はすでに定評あるものであったが、八百蔵の清盛入道は書きおろしの左団次を凌ぐという大好評で、今や彼が売り出しの頂上であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは福地桜痴居士がさきに一部の小説として春陽堂から発行したものを更にみずから脚色したもので、居士の作中ではあまり上出来の物とも思われなかったが、団十郎の大口屋暁雨や八百蔵の釣鐘庄兵衛などが大好評で、近年｜未曾有ともいうべき大入りを占めた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎の活歴が往々にして一部の観客の批難のまとになったのは、こうした悪い病いが付き纏っていたからで、暁雨の大好評にひきかえて、この板額は頗る不評であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、自分の気に入らない小道具を使っては、なんだか心持が悪くて思うような芝居が出来ないというのであろうが、書きおろしの中村仲蔵はそんな贅沢な註文をしないでも、立派に勝家の役を仕負わせて大好評であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと昔、リリアン・ギッシュが主演して大好評であった「ブロークン・ブラッサム」という映画があった。",
              "citation": {
                "source": "映画の語る現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年のサロンに「出あい」が大好評で入選した。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワ地方労働組合ソヴェトの名によって劇場で上演され大好評だった「憤怒」。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『戦旗』が一九二九年ごろ、片岡鉄兵の「アジ太・プロ吉世界漫遊記」をのせて大好評であった。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の指揮者は、イタリーのプレエシアで「お蝶夫人」の再演を指揮して始めて「お蝶夫人」が大好評を博した時のカンパニーニでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩竈では松島の一ツの馬放島というところで海水浴場をひらいたら、大評判、大好評であったそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも一山の場合は毎晩一人ずつ斬る、その一人ずつの斬り方がことごとくちがっていたため、いっそう大好評だったといわれるから素晴らしい。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に松島を、次に躑躅ヶ岡の枝垂櫻と天守臺の招忠碑とを描いたものを作つて大好評であつた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛生課なども大好評である。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文丙に入学した第一年の記念祭のとき、どういう題だったのか、保は坊主になって、フランス語の動詞の変化をお経代りにして大好評だった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも放送は大好評の由（40）。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
