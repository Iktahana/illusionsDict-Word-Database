[
  {
    "uuid": "8a6935f9-7ea7-5bc1-8849-8c6b45cd5119",
    "entry": "脱する",
    "reading": {
      "primary": "だっする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
