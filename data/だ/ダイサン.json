[
  {
    "uuid": "b9bece4d-0258-5f00-9093-95f3d6c181ed",
    "entry": "代参",
    "reading": {
      "primary": "だいさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "visiting a temple for another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「妹と二人で家をあけちゃあ困るんですけれど、きょうはよんどころない御代参を頼まれたもんですからね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人で二つ願っちゃあ、あんまり慾張っているようで勿体のうござんすから、自分は自分、妹は御代参と、こう役割を決めてまいりました」「これが病気とでもいうのかえ」　松吉は親指を出してみせると、女は肩を少しそらせて笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "御代参をたのまれたのは、町内の古着屋のおっかさんに……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様は日頃信仰する市ヶ谷八幡と氏神の永田町山王へ代参を立てられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌々年も、代参ばかりで御自身のおいではございませんでした。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたそれ途中一土手｜田畝道へかかって、青田｜越に富士の山に対した景色は、慈善市へ出掛ける貴女とよりは、浅間の社へ御代参の御守殿という風があった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨夜、突然、永野喜美代参り、君から絶交状送られたとか、その夜は遂に徹夜、ぼくも大変心配していた処、只今、永野よりの葉書にて、ほどなく和解できた由うけたまわり、大いに安堵いたしました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳の家では恐れて諸寺諸山へ代参を立てて守札をもらって貼り、加持祈祷をし、また法印山伏の類を頼んで祈祷さしたが怪異は治まらなかった。",
              "citation": {
                "source": "皿屋敷",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾衣はすぐに遣手のお金を浅草の観音さまへ病気平癒の代参にやった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用｜鍛冶、行徳助宗、将軍家｜御台所のお旨をうけ、要急のご祈願あって、高野山へお代参に参る途中じゃ、とこのように申し、御台さまのお手形所持いたしおったゆえ、否やなく通行許したのじゃ」「なに！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "関白家御代参として玉藻が参詣を彼らが答えると、遠光は苦い顔をして言った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唯今も申す通り、これは関白殿御代参でござるぞ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「関白殿の御牛車と申されても、それは代参、殊に女性じゃ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御代参とあれば関白家も同じこと、弟御の左大臣どのから遠慮のお指図を受きょう筈はござりませぬ」　彼女は供の侍を見かえって、一緒に来いと扇でまねいた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「予の代参というそちに対して山門内に通さぬと申し、あまつさえこちらがおとなしゅう戻ろうとするのをうしろから遠矢を射かくるなど、言語道断の狼藉じゃ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛政元年五十一歳、伊勢奉幣代参。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "成田竜玄昨夜物故、今日葬送、徳代参遣す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大師信心……どうか拙者の代参として、二人で行って貰いたい」　中間市助、宗匠の袖を引いて。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ、御代参で御座いますよ。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は御代参……ね、厄除の御守りを頂くので御座いますよ」と目顔で注意を加えた。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こよいあなたは　ときいろの　むかしのきもの　つけなさる　かしわばやしの　このよいは　なつのおどりの　だいさんや　やがてあなたは　みずいろの　きょうのきものを　つけなさる　かしわばやしの　よろこびは　あなたのそらに　かかるまま。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こよひあなたは　ときいろの　むかしのきもの　つけなさる　かしはばやしの　このよひは　なつのをどりの　だいさんや　やがてあなたは　みづいろの　けふのきものを　つけなさる　かしはばやしの　よろこびは　あなたのそらに　かゝるまゝ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェーンも　おてつだいさんなのに、　やっぱり　おりょうりしなくて、　いつも　ディナーに　でてくるのは　できあいのもの、　おがくずいっぱいの　はこで　とどくのでした。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　でも　こもりの　おてつだいさんは　いいます　――「ネズミとりを　しかけましょ！",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中（女のおてつだいさん）にさしつかえがあれば、台所のてつだいもしました。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "おてつだいさんの　とこに　いって、　ひとさら　おかゆを　つくってって　いってね、　それから　ダッシュを　おうちに　よんできて　いったの。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、だいさんせいでした。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
