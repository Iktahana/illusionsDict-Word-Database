        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "資産も、工場も、大建築も希望も、榮譽も、富貴も、野心もすべての一切を燒き盡せり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東株ビルデングの石造の大建築が、人物をザンバのように呑みこんでいた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いつかは、巨大な大建築が土台石から、がた崩れに、くずれてしまう時が来る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの人のために、この大建築から離れた所に、小さな小亭が建てられている。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "並木路のつきるところ、正面に赤い化粧煉瓦の大建築物。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "並木路のつきるところ、正面に赤い化粧｜煉瓦の大建築物。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕は、いまに、あれよりももっと立派な大建築をこしらえて、姉さんを住まわしてあげますよ。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽は今、彼が頭を向けてる大建築の表側の方にいるらしく、彼の足の向うに並んだ赤煉瓦とコンクリートの家の上の方、五分の一ばかりを、黄色く照し出していて、その下の方を冷たい紫色の日陰に彩っていた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "火災を免がれた東京駅付近の大建築物が、地震の損害を受けていても魏然として立っているのが非常に頼もしそうに思われた。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど街路を一つ隔てた向かい側に、同じような百貨店の大建築が出来上がり、その開店大売出しが今日だというので、こっちでも負けずに客を取ろうというのであった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中米南米には非凡の大建築残りて、誰がこれを作りしか、探索の緒すらなきもの多し。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米論者の大建築を悦ぶは、これ「芸が身を助くるほどの不仕合せ」を悦ぶ者たり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベニスおよびその付近には数多のパラディオ式の大建築が建てられ、永い間最も完全な様式と考えられていた。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "路は広く、街路樹の青葉は繁り、白亜の大建築は甍を空に競うてゐる。",
              "citation": {
                "source": "新興芸術派に就いての雑談",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らは、百人分の米を作って、自分は飢え、千人分の布を織って自分は凍えたり、大建築を建てて自分は行きだおれしたりするような労働者の地位を全く改めうるまでは、不断の闘争が必要なんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "六節も同様の主趣の語であって、「基」といい「隅石」というは、いずれも地を扁平体の大建築物と見ての言い方である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば荘厳な大建築も、火薬の爆発によって一瞬にして無に帰す。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の書記は予を導いてかの大建築の最下層に至った。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の焼けて灰となった書籍の一冊を読んで大発明をし、大文章を書き、大建築を作る人があったかも知れない。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "且其の焼けた一冊が他日の大発明家、大文学家、乃至大建築家を作るべき機縁を持っていたかも解らない。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸ビルの方は、丸ビルそのものはもとより、付近の背景が皆ガッシリした大建築ばかりで、そこに出入りをする職業婦人は大抵事務員式のスタイルであった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門又はデパート式別嬪屋　京橋｜木挽町の或る大建築の前の缶詰兼洋酒類煙草屋は、震災前、海軍大学その他、高等海員向きの女の世話をするので通人間に知られていた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に黒い枯木が散らばる、廃墟のような大建築が隠見する、煤煙が流れ、雲が渡り、鳶が舞い、飛行機が横切る。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄コンクリの悲哀　下町に来てまっ先に眼に付くものは、丸の内に並んだ大建築である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は取り放題、責任はアメリカへというので、腕に撚をかけると、ここ東京の丸の内、日本丸の機関部という、堂々青天を摩する大建築を並べた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
