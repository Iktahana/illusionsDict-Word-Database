    "definitions": [
      {
        "index": 1,
        "gloss": "worthless book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "本らしい本をさがす心と眼とは、駄本の列の上に憤りをもって走ったのであった。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧本、駄本、変本、安本、其の他其の他も恐れないことにしよう。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はごく僅かな本しか持たず、その少ない本の大部分も店頭であり振れたものや、安本や駄本の類で、研究用具としてはほとんど役に立たぬものと思うのだが、それでも私の本を借りに来る人が相当ある処を見ると、私の友人達が本の占有において如何に微力であるかを思うのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度二十五周年記念号を出すので何か書くようとの懇篤な御すすめがありましたので何かと考えてみましたが右様の次第でありますからほとんど何も申上げる材料はないのでありますが、せっかくの御すすめでありますから、ただほんの少しばかり思い付いたことを申上げたいと思います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またたとい目明きでも、観察力の乏しい人は何を見てもただほんの上面を見るというまでで、何一つ確かな知識を得るでもなく、物事を味わって見るでもない。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お児は四つでも箸持つことは、まだほんとうでない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、私の心にはまだほんたうの滿足は來なかつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の落ちた小枝を剪っているうちに気が付いて、よく見ると、大きさはやっと拇指の頭くらいで、まだほんの造り始めのものであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "演奏者の胸の中に鳴っている音楽が、きわめて自由に何の障害もなく流れ出しているので、楽器はただほんの一つの窓のようなものに過ぎないのである。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽の方はかなりまで好い加減に色々に変化させても、やはり同じものとして認め得られるが、人間の言語はそれがただほんのごくわずかでも変形すればもはや全然別のものに変って識別出来なくなってしまうのである。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだほんとうにお膳立てが出来ねえからな」　庄太に案内させて、半七はまず馬道の鼻緒屋をたずねた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽マジックなんだほんとうに。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう新しい人間としてはわれわれはまだほんの孩児のようなものである。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、現在の航空地図はまだほんの芽ばえのようなもので普通の地形図に少しばかり毛のはえたものである。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金の日光が、青い木や稲を、照してはゐましたが、空には、方角の決まらない雲がふらふら飛び、山脈も非常に近く見えて、なんだかまだほんたうに霽れたといふやうな気がしませんでした。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は日本人で子供が二人、末のはまだほんの赤ん坊であった。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勞働問題と婦人問題とは、前から既に問題となりつゝあつたけれども、小兒の問題はまだほんとうに問題として論議せられてゐないかに考へられる。",
              "citation": {
                "source": "子供の世界",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身綺麗なお爺さんが、只一人位ざっと済したあとは、まだほんの新湯と同じ程に澄んで居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と詩人西原北春氏はこの詩人得意の「水花踊」などまだ始まらぬまだほんのほの／″＼と酒の醉ひがまはりかけたばかりのところで――あれが始まるころはまつたく泥醉状態になつた西原氏なので――話し始めた。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ天の星の如く定った軌道というべきものもないから、何処で会おうかもしれない、ただほんの一瞬間の出来事と云って可い。",
              "citation": {
                "source": "一寸怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五｜銭は高いな」大臣はまだほんとうに高いと思いながら笑って言いました。",
              "citation": {
                "source": "四又の百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただほんのもう一抉。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ未だほんのねんねえなんだからな――）と彼女の父親は母親にそう云った。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子は、まだほんの小さな子で、六つより上には見えませんでした。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ランプで物はよく見えるようになったが、字が読めないじゃ、まだほんとうの文明開化じゃねえ」　そういって巳之助は、それから毎晩区長さんのところへ字を教えてもらいにいった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけてもあれも初旅、なりばかり大きくてもまだほんの子供ゆえ、諸事よろしくたのみますぞ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、わしは国元を出る時、あなたの親御の丹後どのから、丹三郎儀はまだほんの子供、しかも初旅の事ゆえ、諸事よろしくたのむと言われました。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は燃えているな、などと考えているうちは、まだほんとうに燃えていないのだ。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "日清戰役の時は、我々一般國民はまだほんの子供に過ぎなかつた。",
              "citation": {
                "source": "大硯君足下",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一、二の頃、そうだ、私が石川啄木に逢ってまだほんの二、三度目の時だったと思う。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
