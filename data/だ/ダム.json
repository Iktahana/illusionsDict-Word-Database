        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "早くあの「ポツダム宣言」の約束を全部果して、そうして小さくても美しい平和の独立国になるように、ああ、私は命でも何でもみんな捨てて祈っています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い丸髷の下町式マダムが弁慶縞の上っぱりで、和装令嬢式近代娘を相手に、あでやかにつややかに活躍している。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行列の前の方で鬘で年を隠したマダムが逃げた若い情夫と思わずめぐり合った。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を考えているとバーリントンハウスの玄関や、シャンセリゼーやクーアフュルステンダムなどの幻が聯想の糸に引かれて次ぎ次ぎに浮かんで来る。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして殉教者町の骨董店のマダム・ルグランが、市の或る場所に向つて馬車で出かけるときは、巴里全體が停滯してしまふ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しロダンさんは、妾に優しく椅子をすすめると、自分が妾、東洋の女優の美に対する興味の異状であること、マルセーユの石山のノートルダム寺院の尖塔の黄金像にもまして、自分は、日本女優花子の美は自分にとって尊いなどと、お世辞を仰有るのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が更けると、米良は陳子文とイサックを伴って電車路からクインス・スタチウの花園の附近にあるマダム・レムブルクの夜の家を訪れる。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はマダム・レムブルグの家でアングロ・サクソンの英諾威人、ケント族の仏伊人、スラブの露墺人、アイオニアンの血族｜希臘人の商人、オットマン帝国の土耳古人等と夜食を共にするのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・レムブルグは商取引所に於ての最近の銀の相場の高騰にあって、軍閥の勝利をたしかめると同時に同志の破滅を予感した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・レムブルグの毛深い部屋でこの陳独秀の悲壮な報告が終って、彼は自己の生涯の最後を南支那海のビイクトリア島においたのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、うとうととしていた米良をマダム・レムブルグがたたき起して一通の電報を手渡すと、　――広東に夜中反乱が起ったのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとマダム・レムブルグは素早く太い胴体を飜えして、この近代の機能の発明家は青い化粧的で、牛の舌みたいな腕で扉を閉めると、再び細目に開けて、　――それどころですか。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘商人が自転車で忙がしく商取引所方面に疾走し出すころ、マダム・レムブルグが瀝青の浮いた黒襦子の着物をつけて朝のミルクのなかで接吻をすると、海峡を船脚｜迅く航行する汽艇、陳独秀が汕頭に行く姿を指さすのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・レムブルグのオアシスはいまでは相場師で埋もれてはいないであろうか？",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はマダム・レムブルグの家でアングロ・サクソンの英諾威人、ケント族の仏伊人、スラブの露墺人、アイオニアンの血族希臘人の商人、オットマン帝国の土耳古人等と夜食を共にするのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘商人が自転車で忙がしく商取引所方面に疾走し出すころ、マダム・レムブルグが瀝青の浮いた黒襦子の着物をつけて朝のミルクのなかで接吻をすると、海峡を船脚迅く航行する汽艇、陳独秀が汕頭に行く姿を指さすのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "落つきを失った新聞記者のＹの見たマダム・ハヤミの地平線、吊ランプ下げた海峡の船が下関に着くと、僕はサンヨウ・ホテルの踊場にマダム・ハヤミを迎える。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・ハヤミの奴、大理石の経帷子きこんで昨夜｜晩く神戸へ行ったぞ、おい、君。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "空しく、僕は欧洲行の船を棄てて、マダム・ハヤミを追って神戸行急行列車に乗り込んだ。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・ハヤミ、俺も恋していた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところがマダム、いくら流行病とは云いながら彼のアマは朝の市街を厚化粧であるいているんだ！",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マダム、カリタは妾のことをどう思っていてくれますでしょう。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里、伯林、ブラッセル、アムステルダム、何れも電信の速力は一杯にウォール街に資金を流入した。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
