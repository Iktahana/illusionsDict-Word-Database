    },
    "definitions": [
      {
        "index": 1,
        "gloss": "warm temperate zone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "暫くは杉の木立、やがて、暖帯常緑濶葉樹の天然林となる。",
              "citation": {
                "source": "高千穂に思う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、すでに熱帯圏内を脱して暖帯に入る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前中に熱帯をこえて暖帯に入る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日より熱帯圏を出でて暖帯に入る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
