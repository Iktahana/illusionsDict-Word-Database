          "literary": [
            {
              "text": "役者になりたいからよろしく頼むなんどと白ばッくれて、一方じゃア、どん百姓か、肥取りかも知れねいへッぽこ旦つくと乳くり合っていやアがる」「そりゃア、あんまり可哀そうだ、わ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの旦つくにしては少し退屈な奥さんかも知れないけれど、感じは大変いいの。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だい、旦つくはお留守だ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした、あんたの旦つく、この頃はおとなしくしている」　お文はわざとそういう口をきく、奮闘したあとで酒がはいって、酔ってもいるらしい、白粉の剥げた頬が巴旦杏のように赤く光っていた。",
              "citation": {
                "source": "寒橋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥へ来ている旦つくッてえな、巧奴の情人か」「とんでもない、ほれあの……槐橋のそばの、やぶ医者ですよ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おっと、あとのお料理が焦げつくかもしれない」　また外して、厨房に戻り、腰を叩いて、「ああ、なんていう世話のやけるだんつくだろう」　と、呟いた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
