        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "試行錯誤の末、ついにマイクロコンピューターのイメージをつかみきれぬまま卒業することになった加藤だが、石油ショック後の就職難の中で、第一志望の日本電気に職を得ることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで配属先の第一志望には、「通信」と書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八〇（昭和五十五）年に受験した大阪大学基礎工学部では、当然コンピューターを専攻しようと情報学科を第一志望とした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊太郎君は偶然その学校が第一志望だった。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
