[
  {
    "uuid": "a97dd670-6253-5dea-bf64-33ae3ce8497a",
    "entry": "諾々",
    "reading": {
      "primary": "だくだく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "obedient",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうかと思うと、それほどけばけばしく女性尊重を放送しないフランス人が、家庭は全く主婦の女王の傘下に従順に温まって易々諾々である。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで私達は街に出て、印度の花、欧風化された女の嬌態、近世のパーシ女に袖を引かれて茶店に出入するのですが、私達日本の男子で印度のフラッパ女に靴の紐など結ぶように命令されて、諾々としているような非国民は一人だっていないのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子はこれを見て見ぬふり、黙許して咎めざれば、召使のものは為術なく、お丹の命令に唯々諾々。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎は三亀雄のたんげいすべからざる蓄財振りを畏敬していたので、諾々として利子を払ったが、その利子のことで伝三郎の家庭で一寸したいざこざが起ったことがある。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく入院しなければならぬ、あとは自分たちにまかせなさい、とヒラメも、しんみりした口調で、（それは慈悲深いとでも形容したいほど、もの静かな口調でした）自分にすすめ、自分は意志も判断も何も無い者の如く、ただメソメソ泣きながら唯々諾々と二人の言いつけに従うのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私があまりに唯々諾々と従ったら、周さんは敏感に察したらしく、声を挙げて笑い、「しかし、あさってからは学校へ出て、僕と一緒に講義のノオトをとりましょう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「更に問わむ、太宰もまた泣いて原稿を買って下さい、とたのみ、チエホフも扉の敷居すりへって了うまで、売り込みの足をはこんだ、ゴリキイはレニンに全く牛耳られて易々諾々のふうがあった、プルウストのかの出版屋への三拝九拝の手紙、これをこそ、きみ、リアルというか。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の中は多少は、自分自身の立場も、発揮したいような傾向も見えたが、しかし今はもうとても歯がたたないと観念して、ただホームズの為すままに、唯々諾々として、後からついて来るだけのことになってしまった。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、項羽の暴政は益々烈しくなつたが、范増はそれ以来唯々諾々として一言も王を諫める事をしなかつた。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏へ署名して判を押すのだが、僕は判を持っていないから、君の名でやってくれないか」　雄吉が、青木の依頼を唯々諾々としてきいたのはむろんである。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも自分が、青木の命令によって、唯々諾々として○○銀行支店へ引き出しに行った百円の小切手に相違なかった。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が、心を掛けるとどの女も、唯々諾々として自分の心のままに従った。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男性（夫をも含む）を虐待し、その苦痛を忍受しつつ唯々諾々として自分の美の光りを渇仰する有様を見て、初めて愛欲の徹底的満足を受ける実況は、容易に覗い得られぬと云うに止めておく。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、作者は、また唯々諾々としてこれに応ずるということである。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あはや私は、有無もなく飛び降りて憎き奴輩を引捉へてやらうと幾度身構へたかわからなかつたが、目マル目マルと奴等が間断もなく叫ぶ毎に、マルが諾々として吠えたり、尾を振つたりするさまを見ると、得体の知れぬハニカミ心が湧いて来て、思はずも眼を瞑つて了つた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」三　私はあまりのけ者にされ過ぎてゐるのと、酒の酔がないと何事も意々諾々である自分とに幾分業を煮やして、「フン！",
              "citation": {
                "source": "東京駅にて感想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは太平の世には、上士たちの命令を唯々諾々としてきいていた。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父も祖母も母も、私が云ひ出せば厭といふことなく諾々として私の息を検査して呉れたが、私はそれに何か子供の特権とでもいふやうな手前勝手な当然さを感じてゐた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一寸と言葉を遠廻しにしてやると、諾々としてゐる私のその場の呼吸をすつかり呑み込んでしまつて、様々な手法で常に彼女は私に復讐をしてゐた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は、内心唖然としたのであるが、眼付までも殺気立つてゐる気合ひに蹴落されて諾々としてしまつたのである。",
              "citation": {
                "source": "西瓜喰ふ人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その買値は、時価よりもうんと安かったけれども、売り手は別に不足をいわず、唯々諾々として、彼のつける値段に満足した。",
              "citation": {
                "source": "変な恋",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "現状に対する唯々諾々的態度、その出処進退に終始一貫した人間としての責任感がないことまで、その作家がもっている高い素直さ、人間性という評価をうける甘いホロリズムさえ、いつの間にか這い込んで来ていないことはない。",
              "citation": {
                "source": "文学の大衆化論について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて近衛首相が各大政党の領袖を招いた挙国一致政策の支持を求めた際、安倍党首が唯々諾々として引き下ったということも、少なからずファッショ化の名を高からしめたようだ。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、配給とりも直さず万事あてがい扶持で、唯々諾々と生きる無気力の習性となるなら、それは堕落と云われなければならない。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も唯々諾々としてその命に従い、あるいは又、内部に反感等を抱きながら表面には唯これに従うごときは、わが望むところにはこれなく候。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育家の一部が易々諾々として教案を草し、その教案によって百年一日の如く恐ろしい厭怠の裡に所謂良妻賢母を説いて居る、その偽瞞の現状維持は、強いても日本女性を楽観して居ります。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大内自身、組織的な決定に唯々諾々として従い、与えられた仕事だけをこなすタイプの人間ではない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは源吉の持出した「堅い約束」に、唯々諾々と応じたのだから――。",
              "citation": {
                "source": "鉄路",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い換えれば国の法律なり風俗なりに対して全く服従出来ないことがあったなら、即ち心に服従することを欲しないことあるのにかかわらず、表向だけ唯々諾々としてこれを遵奉するは自ら欺くというもので、内部の矩を踰ゆるものではなかろうか。",
              "citation": {
                "source": "自由の真髄",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老父は至極簡単で、もの事を逆にいえば唯々諾々なのである。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
