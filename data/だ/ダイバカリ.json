        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……　　　　　　七　鈴をつけた二十台ばかりの馬橇が、院庭に横づけに並んでいた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空いた電車が五台ばかり、燕が行抜けそうにがらんとしていた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その一枚とさえいう処を、台ばかり。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸番の燈大通より吹きつくる風に揺れて、肌寒う覚ゆる折しも、三台ばかり俥をならべて、東より颯と乗着けしが、一斉に轅をおろしつ、と見る時、女一人おり立ちたり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらがらと通ったのは三台ばかりの威勢の可い腕車、中に合乗が一台。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前には四十台ばかりの荷車に、それに相当する人夫がわやわや騒いでおった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎の足が門前まで来た時は、先生の影がすでに消えて、正面に見えるものは、松と、松の上にある時計台ばかりであった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助は二返｜目の所為といひ、此｜三四日来の脳の状態からと云ひ、左様一図に舞台ばかりに気を取られてゐる訳にも行かなかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には叔父も資本の幾分を卸して、車を五、六十台ばかり持って、挽子に貸し車をしている安という物馴れた男もいて真先に働いた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当の相手の源次は、タッタ今上って行った十台ばかりの炭車の真中あたりの新しい空函の中に、低い天井の岩壁から反射する薄明りの中を、頭を打たない用心らしく、背中を丸くして突伏したまま揺られて行った。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう二台ばかりあがりましたから……どうぞ」　金庫を背にした正面の机の前から、嘉造が、入って来る朝子に挨拶した。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま手がさはつたと思へば、衣桁や鏡台ばかりである。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くけたたましい車輪の音がするので振り返って見ると、目黒の方から幌をかけた人力車が十台ばかり、勢いよく駆けて来る。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助は二返目の所為といい、この三四日来の脳の状態からと云い、そう一図に舞台ばかりに気を取られている訳にも行かなかった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して、精鋭を謳われた皇軍の飛行機は、三百台ばかりが飛んでいたが敵の大空軍に較べて、なんと見窄しく見えたことであったか。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三吉の見つめる五百メートル彼方の路に、今しも大きい貨物自動車が、十台ばかり列を組んでユラユラと動きだしているのだった。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "片っぽだけのひすいの耳飾りや、宝石がなくて台ばかりの金色の指環や、数の足りない真珠の首飾、さてはけばけばしい彫刻をした大小いろいろの指環や、古色そう然とした懐中時計をはじめ、何だか訳の分らない細工物や部分品が、そのガラス箱の中にひしめきあっていた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろいたことは、いつの間に据えつけたか、エレベーターが十台ばかり並んで、しきりに上り下りしている。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "室へかえると、空を十台ばかりの飛行機が分列式をはじめた。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤外線標識灯は、台ばかりになっていた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも土間から急な梯子段を土足のまま登って行くと、十畳ばかり畳を敷いた一室があって、四方の壁際ぐるりと十四、五台ばかりも鏡台が並べてある。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　第一次計画の失敗は当然である　昭和二十一年の秋、北海道庁の庭に、百台ばかりの新しいトラクターが並んでいた。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉桜になった桜並木のバス道路に、大型の貸切バスが十台ばかりパークしていて、車をまわす空地もないのに、朱と水色で塗りわけた観光バスがジュラルミンの車体を光らせながら、とめどもなくつぎつぎに走りこんでくる。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合室の表に人力車が二台ばかり着いて人が降りるらしい物音や人声。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "板囲いの中へ入って行くと廿尺ほど掘り下げられた工事場の周りには、三台ばかりのコンクリート・ミキサアが夜風に湿めり、赤錆びたレールの上にはいくつもトロッコが引っ繰り返っている。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひいき眼ではなく、頭は悪そうではないが、憲兵づれに注目されるまで、毎朝、こんなところで、なにをうつつをぬかしているのかと、ジリジリしていると、まだ涼気の残っている京浜国道を、ギャリソン帽にズボンだけの、ピンクに日灼けした半裸体の俘虜を乗せた大型トラックが二十台ばかり、一列になってやってきた。",
              "citation": {
                "source": "春雪",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんまり別世界だってことですね」　吉之助は、レモンの入ったいい匂いの熱い紅茶をのみながら、若い顔の上に白眼の目立つような目つきでしばらくだまっていたが、「伝統的なのは舞台ばかりじゃないんですからね、歌舞伎の俳優の私生活の隅々までがそれでいっぱいなんだ……」　ため息をつくようにした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤銅色に黒ずんだ面に、額から頬までの大創を浮ばせ、それに、笠を飛ばされて台ばかり紐で結えた面構え。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その店に二台ばかり、お菓子の自働販売器があった。",
              "citation": {
                "source": "親は眺めて考えている",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは盃盤をそのまま、燭台ばかり煌々と明るいが人間は誰もいない。",
              "citation": {
                "source": "若殿女難記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
