[
  {
    "uuid": "7ccc942e-3150-59aa-b481-bcd7707e8a1d",
    "entry": "蛇行",
    "reading": {
      "primary": "だこう",
      "alternatives": [
        "じゃこう"
      ],
      "is_heteronym": false
    },
    "grammar": {
