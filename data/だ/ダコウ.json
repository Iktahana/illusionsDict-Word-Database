    },
    "definitions": [
      {
        "index": 1,
        "gloss": "meandering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北上川の蛇行水路の右岸の平野に低湿の沼沢地が一面に分布しているのは不思議である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の東海道の杉並木の名残が、蛇行する自動車道路を直線的に切っているのが面白い。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河流の蛇行径路については従来いろいろの研究があり、かの有名なアルベルト・アインシュタインまでが一説を出していたようである。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇行の波長が河床の幅に対して長いような場合に特にこれが問題になるであろう。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度自から其墳墓に埋もれたり、羅馬自ら其墳墓に沈みたり、彼等は去れり、然れども彼等を葬りし墳墓は彼等と共に其影を撤したり、天下孰れの処にか墳墓なる者あらんや、世界は墳墓に赴くにあらず、頭を挙げて蛇行するが如き此世界は、遂に「生命」に達すべき者なり。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "徑路蛇行して或は密樹の下にいり、或は獨木橋の上に走する、之を久うして下りて流と會ふ。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷は深くして※なく、遠く細徑の蛇行して盡くる所を知らざるものあり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その位置から滝そのものは見えなかったが、滝へと蛇行しながら続く坂道が目の前にある。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "権四郎爺は、二間道路の路幅一っぱいに、右斜めに歩いては左斜めに歩き、左斜めに歩いては右斜めに歩き、蹌踉きながら蛇行した。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇行していれば、何方から出て来て突当ろうとしても、何等自分の威厳を傷つけられた風に見せずに、身をかわして了えるからだっだ。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばし深林の中を行き、頂上を左の方、咫尺の上に見ながら、路は右方に轉じて蛇行す。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇行して達しうる人間の実際の方向を、直線によって描き直すことである。",
              "citation": {
                "source": "広津氏に答う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎の花の下を蛇行しているセーヌ河は、古城の銃眼を高く一方に聳えさせ、延々と巴里に向って流れている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間を流れるダニューブの蛇行は、一人娘の気儘勝手な遊行のさま。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは邯鄲の歩みを学ばないうちに寿陵の歩みを忘れてしまひ、蛇行匍匐して帰郷したと云ふ「韓非子」中の青年だつた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは邯鄲の歩みを学ばないうちに寿陵の歩みを忘れてしまい、蛇行匍匐して帰郷したと云う「韓非子」中の青年だった。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃霧は川の水面に纏りながら溪から溪を蛇行した。",
              "citation": {
                "source": "静かなる羅列",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "土質が、やわらかな沖積層で岩石がなく、そのうえ、蛇行が甚しいために水勢もなく、絶えず溢れ絶えず移動し、いつも決まりきった川筋というものがない。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "前面にはゆるやかに蛇行した白い街道が坦々と続き、遙かな翠巒の煙るような輝き、近くの山頂の黄金の帽子を冠った眩ゆさ。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "その連丘にはさまれた小盆地をコマ川が精一パイ蛇行している。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "又原を流れる川の両側には、木立が並木のように生い続きて、曲折蛇行する水路の所在を示している。",
              "citation": {
                "source": "那須、尾瀬、赤城、志賀高原",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広河原から蛇行曲折、幾回か右に左に徒渉して河床を遡ること三十分で、左手に細長い段丘状の平が現れる。",
              "citation": {
                "source": "笛吹川の上流（東沢と西沢）",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水みちが広い河原を崖から崖へと蛇行しているので、幾回か浅い徒渉を繰り返した。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秩父の山々に真に目覚めて、其後の十年余りを登り続けるようになったのは、明治四十二年の五月に南日君と雲取山に登って、残雪斑々たる連嶺が次第に高まりながら、遠く西方に蛇行している姿を眼の前に眺めた時からである。",
              "citation": {
                "source": "思い出す儘に",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川自身もこの砥のように平らな草原の中では、その行場に困ると見えて、極端な蛇行をしている。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中を悠々と流れるユーコンの支流テナナ河の蛇行。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河は著しい蛇行をしているので、彎曲点が方々で切れて、馬蹄型の湖を至るところに残している。",
              "citation": {
                "source": "異魚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは蛇行し、あるいは回旋し、あたかも曲芸を演ずるがごとし。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、長く蛇行するポートゥックスト河の流域には埋葬地として用いられた地域が数多くある。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこういうものからだんだんに現在の短歌型式が発生して来たであろうということは、これらの詩の中で五および七の音数から成るものが著しく多数であることから想像される。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
