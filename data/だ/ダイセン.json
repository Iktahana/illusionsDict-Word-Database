[
  {
    "uuid": "aebd9798-b064-56ab-afeb-7f51fb97c5d1",
    "entry": "題簽",
    "reading": {
      "primary": "だいせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "slip of paper bearing a book's title (pasted inside the book)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "價を論ずれども成らざりしかば、思ひあきらめて立ち去らんとしたる時、一書の題簽に「ヂヰナ、コメヂア、ヂ、ダンテ」（ダンテが神曲）と云へるあるを見出しつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹亭の遺した無題簽の一小冊子がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "命題の如きも、巻首及｜小口書、題簽、巻尾、各相異つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは題簽を熟視してゐるうちに、ふと紙下に墨影あるに心附いた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日小川町通の古本屋で『精神啓微』と題簽した書物を買って、めずらしそうにひろい読みしたことを今想起する。",
              "citation": {
                "source": "呉秀三先生",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "表紙の題簽に、ひよしさんわうまつり　　　　　天満あいごの若からさきのひとつ松のゆらい　　八太夫とあつて、宝永五年正月の、大伝馬町鱗形屋の出版である。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "親しく圓朝の話術に接し、ことごとく傾倒されていた故を以て我が江戸文学の恩師川柳久良伎翁には、見事な題簽を書いていただいた。",
              "citation": {
                "source": "小説　圓朝　あとがき",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物の害虫と言えばいつでもシミ独りが登場して、やあシミの巣だとかシミの何んだとか言って時には紙魚繁昌記などと書物の題簽までを賑わす名とも成り、名誉と言えば名誉だともいえない事はないでもないが、そう悪口ばかり浴せ掛けられては堪ったもんではない。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "題簽は、青山子爵御母堂元子樣に豫め御願ひしてある事を話した處、表紙のそれに、數本の藪柑子を添へたなら、面白からうと、長崎氏が云はれた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は青山御母堂の題簽と、一つの紙に繪を描く事が、何となく嬉しく、未熟な事は忘れて、一も二もなく賛成し、十月末の或日、藪柑子數本をいろ／＼配置した四五枚の表紙畫を長崎氏に見せ、其一枚を選んで木版にする處まで話が進んだ。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は全く藪柑子畫をやめてしまふのも何となく殘り惜しい氣がして、遂に扉の題簽のあしらひに描く事にきめた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め私は、題簽のあしらひであるから、先に文字を刷つて貰つて、それに然るべく繪を添へればよいと思つて居た。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日かき終へて、落ちついて考へると、これに題簽が刷られた時、さぞ位置の調和のをかしいのもある事だらうと、押の強い私もいさゝか氣にかゝりだした。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "終に臨んで、題簽を御書き下された青山子爵御母堂樣、跋文を寄せて下された小川女史、又原稿の整理をお助け下された中山榮子女史、（『只野眞葛』の著者）に對して難有御禮申上ぐる。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だがその表題の題簽も、年経て文字もかすかに手摺れてしまい、江戸時代になってから、何代目かの所蔵者が、またその横に、題簽を貼り加えた。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「遺愛集」に序を添えて呉れ、又、題簽も書いて呉れという依頼であった。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版の際には序と題簽を書いて下さることをお願いするというのである。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遺愛集」は島秋人自選の歌集で、題簽も自身付けたものである。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあとのことは先生のお眼を通していただきまして、私の無理なお願い事の題簽と解説文を賜り栗原喜代子様へお転送方をお願い申し上げます。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月六日夜記島秋人　窪田空穂先生　前略　序と題簽と私の歌稿を土曜日の午後に入手致しました。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜右衛門ははたはたと団扇を動かし、それからとつぜん、自分の読んでいる書物を取り、表紙を返して、題簽を見た。",
              "citation": {
                "source": "女は同じ物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一郎、――」と彼は云った、「おまえはいまなにを読んでいるとかいったな」「三代聞書です」「ほう」と竜右衛門は云った、「そんな本が面白いかね」「ええ、面白いです」　竜右衛門は微笑しながら、「そうかね」と云い、また自分の書物の題簽を見た。",
              "citation": {
                "source": "女は同じ物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの机の上から取ったのだろう「妙法寺記」という題簽で、半年ほどまえに良人が御菩提寺から借りて来て筆写しているものだった。",
              "citation": {
                "source": "日本婦道記",
                "author": "風鈴",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人の写した方の題簽には「鈔」という字が付いている、たぶん原本からなにか鈔録しているのであろう、写し終えて綴じたものがもう六冊あまりもある筈だ。",
              "citation": {
                "source": "日本婦道記",
                "author": "風鈴",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤右衛門はその表紙の「松の花」という題簽をあらためて見なおした、松の緑はかわらぬ操の色だ、そこに撰まれたのはあらゆる苦難とたたかった女性たちの記録である、いまの世にひろめ、のちの世に伝えて、人の心をふるいたたしめる烈女節婦の伝記だ。",
              "citation": {
                "source": "日本婦道記",
                "author": "松の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、不識庵様日用修身巻　という題簽がついていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
