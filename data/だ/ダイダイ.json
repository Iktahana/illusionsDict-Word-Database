  {
    "uuid": "6020b53b-6ec1-5244-aa8d-86e2a11953a0",
    "entry": "橙",
    "reading": {
      "primary": "だいだい",
      "alternatives": [
        "ダイダイ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
