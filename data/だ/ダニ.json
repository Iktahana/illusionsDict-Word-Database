    "definitions": [
      {
        "index": 1,
        "gloss": "tick (Acari spp.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
