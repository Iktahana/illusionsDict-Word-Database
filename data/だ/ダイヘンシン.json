          "literary": [
            {
              "text": "野山を駆け廻ったり、木によじ登ったり、いたずらばかりしていたものですから、大変身軽になっていました。",
              "citation": {
                "source": "彗星の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変身につまされまして。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月程前、ふと汽車の中で御一緒になったのが、最初でしたが、その人は、大変身分のある人のように感じられました。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日の家出でしたが、既に大変身しました。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの二年間で大変身した。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
