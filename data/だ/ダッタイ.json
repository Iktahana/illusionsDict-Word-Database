    "definitions": [
      {
        "index": 1,
        "gloss": "withdrawal (e.g. from an organization)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昭和九年四月、「紀元」脱退。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年、二科から脱退して、新浪漫派とやらいう団体を、お作りになる時だって、私は、ひとりで、どんなに惨めな思いをしていた事でしょう。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、蹴球部を脱退しようと思った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱退しないまでも、もう、スポーツがいやになった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国政府や欧米諸国はこれを認めようとせず、日本は国際連盟から脱退。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月になってコンパックが正式にＡＣＥからの脱退を表明すると、サンタクルズオペレーションも撤退だと言い出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小熊秀雄全集-20大波小波小熊秀雄独立美術分裂説　次は誰が脱退するか　▼独立の林重義も遂にシビレを切らして脱退した。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私たちが良心的に行動しようと思うならば、もはや事実上守られない空文の規則をもつ協会を脱退するか、武士は食わねど高楊子式の旧道徳をまもって、規定外の条件を付せられた原稿は書かぬようにするかのいずれかしか道はない。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな声ではいえないが、連盟脱退後の日本艦隊はどこまで強いのか、底力の程度がわからないてえことだぜ」　機関士官は、だいぶん恐日病にかかっているらしい。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし神無を入れると脱退をするといふ組合員が出たのでやめたんだ。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田が荒木に「では君がさっさと脱退したらいいじゃないか」と云ったら、其は困る、とねばって解散させたあたり、なかなか昭和文学史の興味ある一頁である。",
              "citation": {
                "source": "一九三七年十二月二十七日の警保局図書課のジャーナリストとの懇談会の結果",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱退した細田源吉以下十一名はすぐ前線作家同盟を組織した。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、「文戦」を脱退して日本プロレタリア作家同盟に参加した黒島伝治その他は第一回の「文戦」打倒同盟によって、猛烈な自己清掃を行った。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、今度の左翼十一名の脱退となった。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九二七年十一月）労農芸術家連盟（文芸戦線）が分裂して脱退派が前衛芸術家同盟を組織したときだって、イデオロギー的理由がちゃんとあった。",
              "citation": {
                "source": "ニッポン三週間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、山川派としてのこったのが前田河広一郎、彼の代作者里村欣三・葉山嘉樹・岩藤雪夫等及び今度脱退した黒島伝次・平林たい・小堀甚二等だ。",
              "citation": {
                "source": "ニッポン三週間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「同伴者」から脱退し、自己批判を遂げてラップに参加した作家も少くない。",
              "citation": {
                "source": "ニッポン三週間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例え百人の黒島をひっぱって来て百枚脱退声明取消文を書かしたところで、それが彼等の反動的イディオロギーを、自覚あるプロレタリアート農民の前にどう糊塗出来る？",
              "citation": {
                "source": "ニッポン三週間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文戦脱退はなぜすぐナップに加入出来るのか？",
              "citation": {
                "source": "文戦脱退はなぜすぐナップに加入出来るのか？",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文戦を脱退した人は、第一次の脱退の場合も最近の第二次の場合にも、すぐ文戦打倒同盟というものを自主的に組織してナップ加盟と同時に、自分たちの階級的立場を明瞭にしてきました。",
              "citation": {
                "source": "文戦脱退はなぜすぐナップに加入出来るのか？",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二年間（一九三三―一九四五）　一九三三年の一月ドイツではヒットラーが政権を得、二月日本政府代表は国際連盟から脱退した。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケレンスキー内閣の時分、彼女は社会革命党に属していたが、一九一七年には、地方の革命的鉄道従業員と一緒に、そんな政党からは脱退してしまった。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者が独立教会からも脱退し、キリスト教信者の生活、習俗に対して深い反撥を感じていた時、「或る女」が着想されたことは私どもにとって興味がある。",
              "citation": {
                "source": "「或る女」についてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正二年という年は、『青鞜』創刊から三年目、丁度坪内逍遙の文芸協会から島村抱月と松井須磨子とが脱退して芸術座を組織した時であり、婦人問題に対する社会の関心は高潮に達した時期であった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にこの労農芸術家連盟は、同年十一月再分裂を行い、青野季吉、前田河、金子、葉山等は彼等の支持する山川均の「労農」派の影響のもとにプロレタリア芸術運動を置こうとし、藤森、佐々木、蔵原、村山等の人々は脱退して前衛芸術家同盟を結成した。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この出資は後日組合を脱退せんとする者あるも、全くこれを返戻せず。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「農民組合を脱退して来い。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだったい」　晴ばれとした少年の顔からは、彼女はいずれとも決めかねた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだったい」「もう一度！",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞの十の字だったい、脚が開かないぢゃないか。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
