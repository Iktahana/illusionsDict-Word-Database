    "definitions": [
      {
        "index": 1,
        "gloss": "Datsun (motor car from Nissan Motor Company)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いまじゃ社長の女婿だというんで、工場長というのに収まってしまって、ついこの間まではダットサンを乗り廻わしていましたがね。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭介はダットサンを自分で運転して来た。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ君は、ダットサン運転の技術を体得していたので、そのトラックの運転台に乗っていた。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダットサンが、若い女のひとをつかってデモンストレーションしたことがあった。",
              "citation": {
                "source": "この初冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダットサンぐらいは女でも自由に動かして然るべきものという心持の上に立てられた企画ではなくて、ダットサンに手が出したい階級の興味、目新らしさの要求へ、女がもって行って飾られたように見えた。",
              "citation": {
                "source": "この初冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう女のひとをのせたダットサンが街角で故障をおこして困っているところを、お手伝いしましょうか、とよって行って、動けるようになったら、ありがとう、であっさり別れず、それから細君を加えない一種の交際がはじまるというような現実もあるらしかった。",
              "citation": {
                "source": "この初冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダットサンがとまって中から役人風の男が出ると、運転していた国防服があわてて事務所口へ案内した。",
              "citation": {
                "source": "朝の風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○昨夜七時すぎ緑郎、□沢一緒にダットサンで来た。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千万の現金といえばダットサン一山だぜ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "せまい往還を荒っぽく日夜突進するバス、トラック、ダットサンの交通は、根太のゆるんだ粗末な重吉の家を朝から夜中まで震動させた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の若い衆がただの道をひっぱる車の後押してえのは、ダットサンの後押しとあんまり変らないことだアね」「車と一緒にいらっしゃらなかったのですか」「車はすごい速力ですよ。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京羽村間の往復には最初オート三輪車を使用していたが、まもなく当時流行しはじめたダットサンを購入された。",
              "citation": {
                "source": "西隣塾記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "村木さんは器用な人で小型の運転が出来るので、居士が羽村へやってくると、大竹さんが東京へ帰るまでの時間を、私達はあちこちダットサンを乗り廻したものである。",
              "citation": {
                "source": "西隣塾記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "又引返して九時近くダットサン円タクで帰る、あゝ甘いもの食ひたい、ドラやきの夢を見さうだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時すぎに、新宿駅へ一旦集り、僕はシボレー、他の連中はダットサンに分乗十何台、豊島園へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奴さんだよ」をモヂって「ダットサンだよ」って歌を作れと、此の間、日産の人に話した、冗談から駒が出かゝった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダットサンの会社より借りたダットサン、高槻の運転で十一時半帰宅。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時すぎにダットサンで家を出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十九日（金曜）　六時半起き、ダットサンで、砧へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房とダットサンで橘の家へ出かける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時すぎにダットサンは、はるか鶴見の花月園迄飛んだものである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "園内のおでんを食ひ、又ダットサンで文ビル迄。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "南部僑一郎をダットサンに乗せ、虎の門の晩翠軒で夕食。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダットサン修繕中のためハイヤ呼んで貰って帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダットサンを借りたニッサンの新井といふ人を、ホテルのグリルへ招き、夕食をする。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニッサンより拝借のダットサンが、高槻と共に到着したが、ロードスターで一人っか乗れない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時頃迄ゐて、高槻の迎へでダットサンで帰る、ロードスターの箱の中へ女房乗る、雨が降り出して弱った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時にダットサンで東宝本社へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
