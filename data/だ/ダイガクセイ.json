    "definitions": [
      {
        "index": 1,
        "gloss": "university student",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この花やかにしゃちこばった気分がドイツ大学生特にいわゆるコアー学生の常住坐臥を支配しているように思われるのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖をおりかかると下から大学生が二三人、黄色い声でアリストートルがどうしたとかいうような事を議論しながら上って来る。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は医科大学生Ｆ兄弟の宅へ招ばれ、素晴らしく大きなクリスマス・ツリーの下で御馳走になり乍ら、医科大学の教室でつくるツリーへかける飾付けは、人間の心臓や肺、そのあらゆる人体諸臓器の形をボール紙で造らえて色彩をつけたものだという話など聞き夜を更かしました。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯に立って見ていた二、三人連れの大学生の一人が運転手の方を覗き込んで、大声で、「ソートーなもんじゃー」と云った。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、某私立大学生、某会社員、某教師等々と関係したことを告白せり――。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに大学生ではない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なみなす丘はぼうぼうと、　　　　　青きりんごの色に暮れ、大学生のタピングは、　　　　　　　口笛軽く吹きにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋付と黄の風呂敷）第二双の眼の所有者（大学生。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだとするとおれがあんな大学生とでも引け目なしにぱりぱり談した。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二三日たって、そのフランドンの豚は、どさりと上から落ちて来た一かたまりのたべ物から、（大学生諸君、意志を鞏固にもち給え。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもいやな説教で、折角洗礼を受けた、大学生諸君にすまないが少しこらえてくれ給え。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウルトラ大学生諸君、こんな散歩が何で面白いだろう。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて大学生諸君、その晩空はよく晴れて、金牛宮もきらめき出し、二十四日の銀の角、つめたく光る弦月が、青じろい水銀のひかりを、そこらの雲にそそぎかけ、そのつめたい白い雪の中、戦場の墓地のように積みあげられた雪の底に、豚はきれいに洗われて、八きれになって埋まった。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばある一人の虚無的な思想をもった大学生に高利貸しの老婆を殺させる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして主人公の大学生が、これに対していかに反応するかを観察する。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしこの場合における実験室は小説作者の頭脳であり、試験される対象もまた実物ではなくて、大学生や少女や探偵やの抽象された模型である。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハイデルベルヒの学生歌」（俗名、若きハイデルベルヒ）でも窓下の学生のセレネードは別として、露台のビア・ガルテンでおおぜいの大学生の合唱があって、おなじみのエルゴ・ヴィヴァームスの歌とザラマンダ・ライベンの騒音がラインの谷を越えて向こうの丘にこだまする。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに若い婦人が人待つふぜいで立っていると、やがて大学生らしいのが来ていっしょになった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、私は極めて懶惰な帝国大学生でありました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年間、その間には、往年の呑気な帝国大学生の身の上にも、困苦窮乏の月日ばかりが続きました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、大学生は、レインコオトのポケットに両手をつっこんだまま、さっさと歩いた。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、その大学生の怒った肩に、おのれの丸いやわらかな肩をこすりつけるようにしながら男の後を追った。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学生は、頭がよかった。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学生は、やはりどんどん歩いて行った。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まえの小径を大学生たちが一列に並んで通る。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノオトのおなじ文章を読み、それをみんなみんなの大学生が、一律に暗記しようと努めていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりの美男の大学生をえらんで声をかけてやった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすみどり色の外套にくるまった、その大学生は立ちどまり、ノオトから眼をはなさず、くわえていた金口の煙草をわれに与えた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験場では、百人にあまる大学生たちが、すべてうしろへうしろへと尻込みしていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授がボオルドに問題を書きなぐっている間に、われの背後の大学生たちは、学問の話でなく、たいてい満州の景気の話を囁き合っているのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
