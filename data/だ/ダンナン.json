        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "娘はただ微笑して、べつだんなんともないとばかり答えていた。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに博士の同僚だった潮見博士は快活な明るい人だったから、辻川博士とはどうしても両立せず、陰気なだけ辻川博士のほうがいつも圧迫されがちで、潮見博士のほうではべつだんなんとも思っていなかっただろうけれども、辻川博士のほうでは潮見博士をよほど快よくおもっていなかったふうがあった。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、みんなじょうだんなんですよ。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてお次は、ドライフルーツを食べるだんなんだけど、これがしっちゃかめっちゃかなさわぎになってね、大きな鳥はすぐなくなるとぶつくさ言うし、小さいのはのどにつかえて背中をとんとんしなきゃいけないし。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はふだんなんのかのと威張るけれどさて読みつくらとなるとさつぱり意気地がなくていつも負けどほしだつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはごくありふれたことで、べつだんなんの変わったこともなかった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかしあいては、うなずいただけで、べつだんなんとも返事をいたしません。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰ちゃん、それじょうだんなんでしょう。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、じょうだんなんかじゃありません。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
