        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その大網の尖端は、紐のように太く揺れて、アール・ヌーボー式の図案に見るような、印象の強い輪廓を作って、幾筋となく繋がっては、環を作る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大網を過ぐればやがて福渡。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、汽車が千葉まはりに譽田……を過ぎ、大網を本納に近いた時は、目の前の苗代田を、二羽銀翼を張つて、田毎の三日月のやうに飛ぶと、山際には、つら／＼と立並んで、白い燈のやうに、青葉の茂みを照すのをさへ視たのである。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服の男はあれは鮪の寄りへ大網を掛けた所だと説明する。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ一點ヲ寛過スルハ實ニ國家ノ大網ヲ紊ル者。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ大網の湯を過れば、根本山、魚止滝、児ヶ｜淵、左靱の険は古りて、白雲洞は朗に、布滝、竜ヶ｜鼻、材木石、五色石、船岩なんどと眺行けば、鳥井戸、前山の翠衣に染みて、福渡の里に入るなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは大網温泉なるが、紳士の湯治には適せず。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ送り來り、共に大網の湯壺を見て、こゝに始めて手を分つ。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ山下でも出会ったとおり、ああしてつじ番所の小役人まで狩り出して、江戸じゅう残らずへ大網を張ったはいいが、獲物はこそどろが三匹と、つつもたせの流れがひと組みと、ろくなやつあかからねえんでね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大網ならば夕刻あたりまでに、小鰯の一匹位かかろうわい。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは霎時遠ざかつて居たが、四十一｜年六｜月四｜日に、一人で寺尾、子安、篠原、大網、樽、駒岡の諸遺跡を過ぎて、末吉に掛つて來ると、這は抑も如何に、這は如何にである。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "末吉の貝塚",
                "note": "青空文庫"
              }
            },
            {
              "text": "箕浦は短刀を棄てて、右手を創に※し込んで、大網を掴んで引き出しつつ、フランス人を睨み付けた。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは怠惰と不純とを編める灰色の大網にして、黄金の時を捕へんとしながら、獲る所は疑惑と悔のみ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は汽車で両国から大網駅までゆく。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡辺農学士は新聞に筆を執っておられたが、後健康の関係で、房州に去り、今は大網の農学校の校長をしておられるのである。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "（１）子どもが生まれたとき、大網膜の一部がやぶれないで、そのまま子どもの頭にのこっていることがあります。",
              "citation": {
                "source": "三本の金の髪の毛をもっている鬼",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼子夫人の実家は、ここから六里半ばかりはなれた、吉浦という海岸にある、県下きっての大網元で、夫人にはもう両親もなく、たったひとりのお兄さまがあとをついでいられました。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "打った大網に雑魚もかからなかった時の感じとひとつである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹操も、野を疾駆しながら、「昼、捨ておいた兵糧は敵を大網にかける撒餌の計だ。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのごきげんもとりながら、諸国の武士どもの心を、こッそり、足利家の大網のうちへ曳きこむには……。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしは、こう思うんですがね、――よしんばまる一んち、おかみさんを両手で抱っこしていろって言われたところで、どだいもう苦になるどころか、ただもうぞくぞく嬉しいばかりだろうってね。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "つきあい仲間のインテリ連中は、誰も彼も、料簡は狭いし、感じ方は浅いし、目さきのことしか何も見えない――つまり、どだいもうばかなんです。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
