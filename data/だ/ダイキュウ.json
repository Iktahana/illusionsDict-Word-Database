          "literary": [
            {
              "text": "翌日、代休を申出る勇気もなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日後の木曜日、川島健一郎はたまたま代休だった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　無事に、五卿を送って、春日丸から上陸した筑前兵や、薩州兵に、半日ずつの、交代休暇が出た。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
