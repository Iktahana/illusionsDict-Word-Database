    "definitions": [
      {
        "index": 1,
        "gloss": "large amount of capital",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "満洲ハタダ大資本家大地主ヲ太ラセルダケダ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太ッタ大資本家共ハ、鈴文ヤ松駒ノ如キ階級的裏切者ヲ買収シ、諸君カラノ搾取ヲマスマスヤサシクシ、諸君ノ妻ヤ子ヲ、飢ニヒンセシメ、諸君ヲモ絞殺スル反動ノ城塞ヲ固クスルモノデアル。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小資本は大資本に併合される。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝで、大資本家の団体が、ある原料産地や、市場を独占していたならば、それは非常に強いし利潤も多い。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤルマア・フオン・シイドウ男爵と言へばスウェーデン切つての金持で、大資本家の一人だつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コンピューターという強力な武器を、国家や大資本が独占する状況がこれで崩せる」　彼は久しぶりの晴れやかな表情で、そう語りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はパーソナルコンピューターがいかに面白いかを、私には理解できない言葉でとうとうとまくしたてたあと、「パーソナルコンピューターによって、情報処理の強力な武器を国家や大資本が独占している状態がくずせるのだ」と、しばらくはお目にかかれなかった生き生きとした表情で付け加えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな潜在力を持ったコンピューターのパワーが、国家と大資本に連なる限られた層に独占されていれば、この技術に対する恐れを背景にそこいらの連中を黙らせる道具としてマシンを用いる試みは、巧妙に取り行なわれていただろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが国家と大資本の支柱を再生産し続けてきた東大が、東大でなくなることには可能性が感じられた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに事実のこれと反したるは、妾らの悲しみに堪えざる処なり、故にもし今大資本家に依りて製品の斉一を計り、かつ姑息の利を貪らずして品質の精良を致さば、その成功は期して待つべきなり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無償ヲ以テ徴集スル所以ハ、現時大資本家大地主等ノ富ハ其實社會共同ノ進歩ト共同ノ生産ニヨル富が惡制度ノ爲メ彼等少數者ニ停滯シ蓄積セラレタル者ニ係ハルヲ以テナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森林又ハ大資本ヲ要スベキ未開墾地又ハ大農法ヲ利トスル土地ハ之ヲ國有トシ國家自ラ其經營ニ當ルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "下掲大資本ノ國家統一ノ原則ニ依ル。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "（國家ノ權利參照）卷四　大資本ノ國家統一私人生産業限度。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "大資本ガ社會的生産ノ蓄積ナリト云フコトハ社會主義ノ原理ニシテ明白ナルコト説明ヲ要セズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "現時ノ大資本ガ私人ノ利益ノ爲ニ私人ノ經營ニ委セラルルコトハ、人命ヲ殺活シ得ベキ軍隊ガ大名ノ利益ノ爲ニ大名ニ私用セラルルコトト同ジ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "積極的ニ見ルトキ大資本ノ國家的統一ニヨル國家經營ハ米國ノ「ツラスト」獨逸ノ「カルテル」ヲ更ニ合理的ニシテ國家ガ其ノ主體タル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "其ノ事業ガ未ダ私人生産業限度ノ資本ニ達セザル時ト雖モ、其ノ性質上大資本ヲ利トシ又國家經營ヲ合理ナリト認ムル時ハ、國家ニ申達シ双方協議ノ上國家ノ經營ニ移スコトヲ得。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私人ハ惡用スベキ大資本ヲ奪ハレタルガ故ニ國家ノ物價調節ニ反抗シテ買占メ賣惜ミ等ヲナスコト能ハズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地主ト投機商人トノ有スル大資本ガ米穀ノ買占メ賣惜ミヲ自由ナラシメテ現時ノ米價騰貴ヲ現出シツツアルヲ見ヨ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等ノ大資本ヲ奪ハズシテ物價調節ヲ云フ如キハ抱腹スベキ空想政治ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐵道ノ國有タルベキ者ト民有タルベキ者ト、亦實ニ私人生産業限度ノ原則及ビ大資本ノ國家統一ノ原則ノ下ニ律セラルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "千、二千、三千、五千、乃至一万の巨額をも容易に支出する大資本主たるを以て、高利貸の大口を引受くる輩のここに便らんとせざるはあらず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同商売の者は成るべくトラスト流に合同して大資本を作つて大きな商売をして貰ひたいのだが、日本人同志の間では小な利慾心が邪魔をするから迚も相談が纏まらない。",
              "citation": {
                "source": "青年実業家",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜米利加では大資本家が小資本家を吸収して利益を壟断すると云つてトラストの幣を頻りに論じてるが日本では先づ当分トラストが行はれるほど進歩しない。",
              "citation": {
                "source": "青年実業家",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由は一部の大資本家に独占されてしまつてゐた。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲を取ったら大資本家を排除して、我々だけで王国をたてる。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "僚友会の清川や熱田は、今度の戦争は結局は大資本家が新しい搾取を植民地で行うための戦争であると云って、昼休みに在郷軍人や青年団の職工などゝ議論をした。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に英米二大資本主義国における大衆読み物のうちでだんぜん地をぬいているものは探偵小説である。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗はもとより大資本の商人でもないので、しまいには自分の商売をやめて、神授を連れて諸方を遊歴し、その字を売り物にして生活するようになった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
