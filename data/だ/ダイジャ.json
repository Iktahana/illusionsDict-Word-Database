    "definitions": [
      {
        "index": 1,
        "gloss": "big snake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "朝はこの椎茸が恐ろしく長くて、露にしめった道傍の草の上を大蛇のようにうねって行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてさらにのぞきや大蛇の見世物を思い出すことが出来る。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "横になって壁を踏んでいると眼瞼が重くなって灰吹から大蛇が出た。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八頭の大蛇を「ヤマタノオロチ」という。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば「大蛇」というような場合に『古事記』では「遠呂智」と書いてあり『和名抄』では「乎呂知」と書いてある。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、「大蛇」のオも「惜し」のオも同じもので、これを「遠」「乎」「嗚」「怨」というような文字で書いてよく、これらの文字は相通じて用いることが出来るものである。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「大蛇」「惜し」の「を」には、いろいろの文字が用いられるが、その文字と「己」「織る」「弟」の「お」に用いられる色々の文字との間には区別があって、「己」の「オ」に「嗚」とか「遠」とか「怨」とか「乎」とかを使った例はない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、「大蛇」「惜」の「ヲ」に「意」「於」「淤」「乙」などを使った例はない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰吹から大蛇を出すくらいはなんでもないことであるが、大蛇は出てもあまり役に立たない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「又ある説によると、大蛇が水の底に棲んでいる筈はない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "また二里ばかり大蛇の蜿るような坂を、山懐に突当って岩角を曲って、木の根を繞って参ったがここのことで余りの道じゃったから、参謀本部の絵図面を開いて見ました。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "心持よほどの大蛇と思った、三尺、四尺、五尺四方、一丈余、だんだんと草の動くのが広がって、傍の渓へ一文字にさっと靡いた、果は峰も山も一斉に揺いだ、恐毛を震って立竦むと涼しさが身に染みて、気が付くと山颪よ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿芝居、大蛇、熊、盲目の墨塗――（この土俵は星の下に暗かったが）――西洋手品など一廓に、※草の花を咲かせた――表通りへ目に立って、蜘蛛男の見世物があった事を思出す。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また其の岬を大蛇灘が巻いて、めぐつて、八｜雲崎、日暮崎、鴨崎、御室、烏帽子岩、屏風岩、剣岩、一つ一つ、神が斧を打ち、鬼が、鉞を下した如く、やがては、巨匠、名工の、鑿鏨の手の冴に、波の珠玉を鏤め、白銀の雲の浮彫を装ひ、緑金の象嵌に好木奇樹の姿を凝らして、粧壁彩巌を刻んだのが、一｜目である。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から雨のあとの面打沈める蒼々漫々たる湖は、水底に月の影を吸はうとして、薄く輝き渡つて、沖の大蛇灘を夕日影が馳つた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱗は光つても、其が大蛇でも、此の静かな雨では最う雷光の憂慮はない。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧のその或ものは、雲にすぼめた瑪瑙の大蛇目の傘に、激流を絞つて落ちた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五｜彩の漣は鴛鴦を浮べ、沖の巌は羽音とゝもに鵜を放ち、千｜仭の断崖の帳は、藍瓶の淵に染まつて、黒き蠑※の其の丈大蛇の如きを沈めて暗い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年だれか八頭の大蛇とヒドラのお化けとを比較した人があった。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志の八俣の大蛇の話も火山からふき出す熔岩流の光景を連想させるものである。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熔岩流がそれを目がけて沢に沿うておりて来るのは、あたかも大蛇が酒甕をねらって来るようにも見られるであろう。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蛇と鰐との闘争も珍しい見ものであるが、なにぶんにも水の飛沫がはげしくて一度見せられたくらいでは詳細な闘争方法が識別できにくいのが残念である。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して虎と大蛇との取り組みは実にあざやかである。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一声高く咆哮しておどり上がりおどり上がると、だだっ子の兵児帯がほどけるように大蛇の巻き線がゆるみほぐれてしまう。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような大蛇と虎の闘争が実際にしばしばジャングルの中で自然的に行なわれるか、どうか、少し疑わしく思われる。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、この映画の大蛇と虎のけんかはやはり人間の仕組んでやらせた見世物興行ではないかという気がしないでもない。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蛇が豚を一匹丸のみにして寝ている。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画ではまた金網で豹や大蛇をつかまえる場面もある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蛇が箱から逃げ出す場面で猿や熊の恐怖した顔のクローズアップを見せる。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくの初耳なればこそ、かくおどろいているしだいじゃが、いったいいかがしたのじゃ」「いかがも何もござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
