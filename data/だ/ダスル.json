    "definitions": [
      {
        "index": 1,
        "gloss": "to degenerate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "従つてセンチメンタリズムに堕することからあぶない所で脱かれてゐる。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の詩人は、物語にゆくか感覚に堕する。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その智は無論叡智と云へる程の神々しさはないが、また時には才智と云へば云へる上滑りした智に堕する傾向を持つてゐるが、それは可成り鋭い発見力と、細かな解剖力と、確かな批判力とを持つてゐる明智だと云へば、一番当つてゐるやうに思はれる。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけであるから、これ以後も従前のごとく逐条的詳細の紹介解説をするとすれば、それはあまりにしばしば無用な重複に陥り、またあまりにわずらわしき些末の詮索に堕するほかはないであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり間違うと、鼻持ちならぬキザな虚栄の詠歎に似るおそれもあり、または、呆れるばかりに図々しい面の皮千枚張りの詭弁、または、淫祠邪教のお筆先、または、ほら吹き山師の救国政治談にさえ堕する危険無しとしない。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、真実の処、能のヨサの正体をこれ以上に説明すると、第二義、第三義以下のブチコワシ的説明に堕するので、能のヨサを第一義的に自覚するには「日本人が、自分自身で、舞いか、囃子をやって見るのが一番捷径」と固く信じている者である。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿諛に堕するに甘んじないかぎり、あれはあれでどうしようもない。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に下らない甘ったるいメロドラマに堕する危険も多分にありそうだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "√（−１）を使う時、本格探偵小説の価値は０となるか、又は性質を変じてノンセンス、ユーマー、怪奇小説の類に堕するようである。",
              "citation": {
                "source": "探偵小説漫想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、真実のところ、能のヨサの正体をこれ以上に説明すると、第二義、第三義以下のブチコワシ的説明に堕するので、能のヨサを第一義的に自覚するには、「日本人が、自分自身で、舞か、囃子をやって見るのが一番｜捷径」と固く信じている者である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかくては人生は無意味となり、我は貴き生の消費者となり、人生の失敗者と堕するに至る。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術作品に対するお世辞の使ひ方も、性別を加へたお世辞であれば、鼻もちのならない卑しいものに堕することも少くないであらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来天才は浪費し、憧憬し、朶頤し、空想を食物にし、実を失つてその実を失へるを知らず、虚偽に住してその虚偽にあるを知らず、地獄に堕することを喜び、暗黒にあることを好み、戦慄し、分裂し、影なきに影を見、姿なきに姿を見る。",
              "citation": {
                "source": "卓上語",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでどうも蔭口というやつ、おおかた悪口に堕するものでな、例えばその人の口癖とか、または身振りとかいうようなものを、つい誇張していいたがるもので」ムカムカしているので広太郎、思わず火ぶたを切ってしまった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは哲学は科学に堕するのである。",
              "citation": {
                "source": "デカルト哲学について",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし爾考えられるならば、スピノザ哲学も数学的主知主義に堕するのほかない。",
              "citation": {
                "source": "デカルト哲学について",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、余り素朴的にのんびりしていたのでは、結局凡俗に堕するのみだ、と私は考えるのである。",
              "citation": {
                "source": "傍人の言",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくば作品は低俗に堕する。",
              "citation": {
                "source": "文学に於ける構想力",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この政治家が、これを強味だと思いこむ時に、彼もまた、精神世界における賤民の群れに堕するのだ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "道徳が不純になり、固形体になるのは主として social に堕するからではあるまいか。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は又、貪婪止むを知らざる渇望を以て、美なる物を求め奇異なる物を追ふ人々が、平和と形状とを失つて、遂には無形と平俗とに堕する事を知つた。",
              "citation": {
                "source": "「ケルトの薄明」より",
                "author": "THE CELTIC TWILIGHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なる社会的共合生活に於ても、各自の魂の憩い場所となり肉体の安息所となる一隅は存在すべきであって、それが無い時、共同生活は単に動物的群居生活に堕するであろう。",
              "citation": {
                "source": "渡舟場",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "総ての学問のうちに、最実証的でなければならぬ筈の文法にして、而も精神分析に似た傾きを持ち、その過程に於いて理論的の遊戯に堕するものが殖えて来たのも、この文章論の態度が総てに及ぶからだと言ふのである。",
              "citation": {
                "source": "形容詞の論",
                "author": "――語尾「し」の発生――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の人物を舞台に再現する前に、俳優は自分の頭の中に、その人物の理想像を先ず描いてみなければならないのに、その理想像が、一種の類型に堕するということは、文学的な人間研究が不十分で、常識の範囲に止っているからです。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それは一時放恣と個人性と非真実性に堕するまでに発展の過程をたどったけれども、すでに利潤的経済的組織は彼女をしっかりと把握してしまった。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋の名がすでに封建制度に闘いを挑んだ個人主義の旗幟であるにもかかわらず、みずから弁証法的解体によって、それはついに一つの空疎な抽象に堕するにいたったのである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れながらに筆硯的感覚を持っている人のですらそうであるから、もともとそういう性来を持たない者の強引の書となると多くは俗臭に堕する傾がある。",
              "citation": {
                "source": "書について",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙つてゐるわけにいかぬ場合、小言めくまいとすれば、それは単なる愚痴に堕する。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、考へ付いた人位はあつたかもしれないが、春団治のやうなあのドギツイ太い声による表現以外、到底、悪くすぐりに堕するのみであることをおもひ、やめてしまつたらうとおもふ。",
              "citation": {
                "source": "初代桂春団治研究",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、法帖で習字することであるが、ただその形だけを真似たのでは書家の書に堕するまでである。",
              "citation": {
                "source": "鑑賞力なくして習字する勿れ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
