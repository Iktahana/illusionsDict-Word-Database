[
  {
    "uuid": "457f4a50-877b-5e19-a4e3-5efc26f9030f",
    "entry": "題目",
    "reading": {
      "primary": "だいもく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
