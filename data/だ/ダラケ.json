    "definitions": [
      {
        "index": 1,
        "gloss": "full of (e.g. mistakes)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
