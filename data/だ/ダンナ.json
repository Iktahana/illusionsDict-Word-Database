  {
    "uuid": "074847b6-c4a1-5655-98de-d54212f7439f",
    "entry": "旦那",
    "reading": {
      "primary": "だんな",
      "alternatives": [
        "ダンナ"
      ],
      "is_heteronym": false
    },
    "grammar": {
