        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔雪うづまきて日は温き〕雪うづまきて日は温き、　　萱のなかなる荼毘壇に、県議院殿大居士の、　　　　柩はしづとおろされぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "福岡で荼毘にふされる。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺骸は領國へ運んで、箱崎の松原で荼毘にした。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌二一日、落合火葬場で荼毘にふされる。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "近藤事務長は土地の有志と計りて、事務長以下十数人、遺骸を奉じて埠頭を去る三｜哩なるパセパンシャンの丘巓に仮の野辺送りをし、日本の在留僧釈梅仙を請じて慇ろに読経供養し、月白く露深き丘の上に遥かに印度洋の※鞳たる波濤を聞きつつ薪を組上げて荼毘に附した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "生残た妻子の愁傷は実に比喩を取るに言葉もなくばかり、「嗟矣幾程歎いても仕方がない」トいう口の下からツイ袖に置くは泪の露、漸くの事で空しき骸を菩提所へ送りて荼毘一片の烟と立上らせてしまう。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "早々帰庵して、不運な彼等を火焙りにして（私としては荼毘に附して、といつた方がよからう）、一杯やつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「荼毘だ、荼毘だ」と丸顔の男は急に焼場の光景を思い出す。",
              "citation": {
                "source": "一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんあれほどしとやかな内房の女達が、祖父の死を知ると、俄かに狂気したようになって頭に纏う布を引裂きながら、額を床に打ちつけ胸を叩いて号泣した有様、星ばかりの夜の空の下で祖父の屍を荼毘にした火の色。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより鳳山亭の登りみち、泉ある処に近き荼毘所の迹を見る。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田にては土葬するもの少く、多くは荼毘するゆえ、今も死人あれば此竈を使うなり。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "推するに柏軒の遺骸は是日｜荼毘に付せられたことであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」按ずるに慧夜は原荼毘前夜であるが、俗間には法要の前夜を謂ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日解剖の為に屍体が大学へ持って行かれたので、予定が一日延びて、いよ／＼今夜最後の通夜をして、明日は荼毘に附する事になっていた。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "護謨林を出て馬車に乗り、案内者となつて呉れた三井物産の支店員から、故長谷川二葉亭君の遺骸を此地で荼毘して追悼会を開いた時の話を聞き乍ら、前年｜護謨林に従事して居た長田秋濤氏夫妻が住んで居たと云ふ林間の瀟洒たる一｜屋を過り、高地にある三井物産支店長の社宅の楼上で日本食の饗応を受けた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "追而来る××日×時、花山祭場に於て仏式を以て告別式を相営み、のち同火葬場に於て荼毘に附し申可く候……」　この文面から推せば、彼はたしかに病気で死亡し、その屍体はたしかに火葬せられたのだった。",
              "citation": {
                "source": "火葬国風景",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂魄を寓すべき前の世の骸を求めさせると、十一人とも荼毘して屍は残らぬと言ふ。",
              "citation": {
                "source": "餓鬼阿弥蘇生譚",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌安貞二年正月二十五日の暁、更に西山の粟生野の幸阿弥陀仏の処へ遺骸を移して、そこで荼毘に附した。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "荼毘の処に三肢になった松があって、それを紫雲の松と名附けられ、その荼毘の跡には堂を建てて御墓堂と名づけて念仏した。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後僅かに中一年を措いて大宝二年には、持統天皇は万乗の尊い御身を以て、御遺骸を荼毘に附せられ給い、爾後歴代の天皇大抵この式によって、御葬儀を挙行された事に見えている。",
              "citation": {
                "source": "火葬と大蔵",
                "author": "焼屍・洗骨・散骨の風俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればよしや今存する令の本文が養老の修正であるとしても、本邦火葬の最初といわれる道照荼毘の後二十年にも足らぬこの短日月間に、これを或る場合における常法として法令上強行せしめるまでに、そう急に進展すべきものではなかろう。",
              "citation": {
                "source": "火葬と大蔵",
                "author": "焼屍・洗骨・散骨の風俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "果してしからば続日本紀に、道照和尚栗原の火葬を以て、「天下の火葬此れより始まる也」と書いたのはいかに解すべきか、これは葬送の一つの儀式として、仏式により高貴の御遺骸をも荼毘に附するという様になったことの初めだという訳で、単に屍体を焼くという広い意味のものではあるまい。",
              "citation": {
                "source": "火葬と大蔵",
                "author": "焼屍・洗骨・散骨の風俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏家に荼毘の葬あり。",
              "citation": {
                "source": "火葬と大蔵",
                "author": "焼屍・洗骨・散骨の風俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論屍体を墓に葬るのではなくして、洗骨にしたか、荼毘に附したか、とにかく皮肉を除き去った遺骨を以て、しかるべき場所に散らしてしまうことであらねばならぬ。",
              "citation": {
                "source": "火葬と大蔵",
                "author": "焼屍・洗骨・散骨の風俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して中納言藤原吉野は諫諍を試みたが、その説容れられず、いよいよ御葬式に際しては、遺詔の如く荼毘に附し奉った御骨を砕粉し、大原野西山の嶺上に散らし奉ったとある。",
              "citation": {
                "source": "火葬と大蔵",
                "author": "焼屍・洗骨・散骨の風俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らも聖人の知遇に感じて、聖人の御葬式には荼毘の役をつとめ、爾来代々の法主の葬儀に参列する例になったというのである。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後四時一般焼香を終って、葬列はふたたび式場を発し、同五時半桐ヶ谷火葬場に到着、遺骸を荼毘に附した。",
              "citation": {
                "source": "小山内薫先生劇場葬公文",
                "author": "久保栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初ただびつくりし、恐がりながら、ほんのちよつとばかり途方に暮れてゐるとき、彼等を救つてやるものは一人もゐないのです。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まぁんつたびだび米子どもお話してあんすすか。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎の腕はしびれてわからなくなってただびくびくうごきました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
