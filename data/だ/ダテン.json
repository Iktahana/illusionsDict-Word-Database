          "literary": [
            {
              "text": "金眸は打点頭き、「憎き犬の挙動かな。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しからずば名乗り給へ」ト、いへば猟犬は打点頭き、「さもありなんさもこそと、某も疾く猜したり。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたみにぞかふべかりける逢ふことの日数へだてん中の衣を　というのである。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "乏しい灯影の下にづぶりつと浸りながら、三人は唯だてんでに微笑を含んだまゝ、殆んどだんまりの儘の永い時間を過した。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "乏しい灯影の下にずぶりっと浸りながら、三人は唯だてんでに微笑を含んだまま、殆んどだんまりの儘の永い時間を過した。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "係りの者は今ごろまだてんてこまいで忙しがってる時分だ」「やっぱり警察じゃまだわからんのだねえ。",
              "citation": {
                "source": "少年探偵　呉田博士と与一",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、両人ともに柳眉をさかだてんばかりにしながらかん高い声をあげると、異口同音にわめきたてました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らねえのは恥だてんで、紳士連中しきりに頷首くからね。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう時には、きくんだなア、お相撲が腹がへっちゃア可哀そうだてんで、お百姓はお米をだしてくれる、お巡りさんは見のがしてくれる、これがお前、美人をつれて遊山気分じゃア、同情してくれねえやな。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹下左膳と同居がイヤだてんで、当分東京泊りだなんて云ってましたぜ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄目ではないが……」「なんだ駄目じゃないんですか」「その代わり落語は駄目だてんだ」「じゃやっぱし駄目なんだ、ヤレヤレ」「またガッカリする、悪い癖だねお前は。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いやペストにさせらるから駄目だてんだよ」「ペスト？",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりペストの役にさせられるから可哀想だてんだ、君が」「そんなことア構いません」「いや、構う」「どうしてです」　また不平そうに相手を睨んだ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ兵隊ほどこなれないが、いだてんの合方をひかせてやるのなど、いよいよ大正風景で愉快である。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田の馬場だから高田の馬場だてんだ」「狂人だな――何だ、へんな物を持っておるな。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は卍にそっくりだてんで、昨夜｜傀儡に使われたんだ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "槍祭夏の夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "私さえ追い出せば柳子はたかが女だてんで、ヘヘ、君あ舟木から抱き込まれたね？",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし、それが全体、なんだてんだい？",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがさ、おとどし俺もカカもらったし、金吾お前も嫁もらえと、馬流の姉さんともども、いくらすすめてもイヤだつうんで、なぜだてんで、問いつめ攻め立ててるうちに、そいつがわかって来た。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちちははわれとわが子を愛づるとき老いたる母をおもひいでてその心に手をふれしここちするなり、誰か人の世の父たることを否むものぞげに　かれら　われらのごとくそだちがたきものを育てしごとくわれもこの弱き子をそだてん。",
              "citation": {
                "source": "忘春詩集",
                "author": "忘春詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "その座にわれもありまづしき父おやとしてそだちがたきものをそだてんと日夜のつかれさびしき我もつらなりぬ。",
              "citation": {
                "source": "忘春詩集",
                "author": "忘春詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "――子供｜騙しの化物騒ぎに脅かされて、七年間も寝起きをした離室を明け渡すのは、町人の恥だてんで――」「町人の恥は嬉しいな」　平次はまだ少し茶化しながら、それでも次第にこの話に引入れられる様子です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "招く骸骨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてやしばしの休憩のため、あるいはあわよくば水なり餌なりを恵んでもらえることを期待して舳先に留まったりする気配などは全く見せずに、灰色の空になめらかな弧を描いている様子は、むしろその背後に残るひたすら退屈な風景の退屈さを際だてんがために旋回しているかのようだ。",
              "citation": {
                "source": "桃太郎",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "四民鼓腹して太平を唱う折、馬関と浦賀に黒船が来てさ、さあことだてんであわて出した、開港通商、尊王攘夷、ケンケンゴーゴー、へん尊王攘夷が笑わせやがらあ！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼で俺は、家財道具がまだてんでととのってないことに改めて気づいた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ただてんやわんやにおちいらないですめば、それで満足する。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十三日（火曜）　招魂社のお祭りだてんで三十分早くあく。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の者ばかりで茶話会だてんで、しめったやうなせんべいなど買はせ、より／＼に話をして、無事ねる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　金吾はいだてんと駆け出しました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
