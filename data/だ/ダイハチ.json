          "standard": [],
          "literary": [
            {
              "text": "第五、第六、第七、第八行。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八十六、第百六、第百三十五などがそれであるが、これらにも多少の俳諧がある。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八十段にディレッタンティズムに対する箴言がある。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その兄の要求した通りに、我々は親密に和合して、今日彼の第八週年忌の祭を施行するのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして第八日第九日目を十分に休養した後に最後の第十日目に一気に頂上まで登る、という、こういうプランで遂行すれば、自分のような足弱でも大丈夫登れるであろう。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八番、デューカーの「魔術師の徒弟」。",
              "citation": {
                "source": "踊る線条",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第八等、ぶりきのメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画科学研究、第八｜輯。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八課　あまり放縦でも困る　前述の方法とちょうど正反対の方面があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八場その一（祇園精舎の内庭である。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八場縛縄問答も禅よりの構想である。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八回　人間の運命弦月丸の最後――ひ、ひ、卑怯者め――日本人の子――二つの浮標――春枝夫人の行衞――あら、黒い物が！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十八日に彼は第八回の吟味をうけたが、勿論白状しそうもみえないので、またもや拷問にかけられた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八章奇怪なる新内語りと奈落で奇遇すること。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に移り、彼らの隣の部屋に落ちつくと、明日子はぼくの持っていたレコードのアルバムを見て、聴かせてくれといい、フランクのピアノ五重奏とヴェトーヴェンの第八シンフォニイを掛けながら、三人で音楽の話などをした。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」第八夜　重い雲が空一面にたれこめて、月はまったく姿を現わしませんでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八章　感情の意味と知性の意味　自然主義の写実論は、世界をその存在のままに於て、少しも主観に於ける選択をせず、物理的レンズの忠実さで書けと言った。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八章　浪漫派から高蹈派へ　感情に於ける二つのもの、即ち抒情詩的情操（情緒）と叙事詩的情操（権力感情）とが、人文に於て常に対流することは、前章に述べた通りである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八師団は国宝だつて言はれてゐるぢやないか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し一月に就て論ずれば、月齡の第七第八頃より潮の高まる度は日々夜々に長じて、第十五第十六に至るまでは、次第に増大する。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭様で、私たちの雑誌、『春服』も第八号をまた出せるようになりました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」第八「心細さは申すまでもなかつたが、卑怯な様でも修業の積まぬ身には、恁云ふ暗い処の方が却つて観念に便が宜い。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八朝晩見馴れて珍らしくもない猿だけれど、いまこんなこと考え出していろんなこと思つて見ると、また殊にものなつかしい、あのおかしな顔早くいつて見たいなと、さう思つて、窓に手をついてのびあがつて、づゝと肩まで出すと※がかゝつて、眼のふちがひやりとして、冷たい風が頬を撫でた。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十五日　第八信（ベルリンにて）ママ、私昨晩から泣き続けですの。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と飛び上り、まさかと思って諦めていた時など、思わず万歳と叫ぶくらいだったが、もう第八｜競走までに五つも単勝を取ってしまうと、不気味になって来て、いつか重苦しい気持に沈んで行った。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と飛び上り、まさかと思って諦めていた時など、思わず万歳と叫ぶくらいだったが、もう第八競走までに五つも単勝を取ってしまうと、不気味になって来て、いつか重苦しい気持に沈んで行った。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で小生は第八監十三室「三八七」といふナンバーに名を改めました。",
              "citation": {
                "source": "わが敬愛する人々に",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八章　天業恢弘男声女声（独唱斉唱竝に合唱）神｜坐しき、蒼雲の上に高く、高千穂や※触峯。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
