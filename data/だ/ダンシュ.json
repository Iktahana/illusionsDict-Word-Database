[
  {
    "uuid": "9a53d4e4-4566-5b5d-ac5e-2fb36b473691",
    "entry": "断種",
    "reading": {
      "primary": "だんしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
