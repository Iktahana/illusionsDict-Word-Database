        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　家の裡からお祖母さんのダミ声が聞えて来た。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ええ、ええ、と、医者のダミ声は云ふのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "清江が謡いやめると参右衛門は自分も一寸後から真似て謡ってみたが、これはダミ声でとても聞けたものではなかった。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "訪れのダミ声をきくと、私はいそ／＼と、まつたくいそ／＼と、苦痛を忘れて階段を降りはじめる、借金取の前に立つた私はまるで唄ふやうなたのしさで金を払ひ得ぬ言訳の言葉をのべる。",
              "citation": {
                "source": "ヒンセザレバドンス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「王さん待ってて頂戴な」という、ダミ声の合唱が聞えて来る船艙に、下りて行く気はしなかった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてガタンゴトン、ギイギイと車輪のヒビキ）馭者　（ダミ声で馬に）おおら！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋の方からはガラッ八と三好屋の隠居の歌うダミ声。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野郎ッ、歩けッ」　下っ引のダミ声が威嚇的に響きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "捕物仁義",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御免」　声のでっかいガラッ八が、精一杯の威儀を作って訪うと、町内中の新漬の味に響くようなダミ声で、ドーレと来るべきはずの段取りを、どう間違えたか、「ハイ」　優しい声がして、格子と中の障子を、たしなみ深く開けたのは、十八九の淋しい娘です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "忍術指南",
                "note": "青空文庫"
              }
            },
            {
              "text": "腮別れ（終漁祝）には安着祝のときよりも少しは多く酒が出、漁夫たちはよっぱらってだみごえでうたをうたった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔って高いだみごえでやけにどなるような調子だった。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やい、その童の脇差を持ってきて見せろ」　と舳からだみごえをかけたのは、この船の張本で、龍巻の九郎右衛門という大男だった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
