    "definitions": [
      {
        "index": 1,
        "gloss": "soya bean (Glycine max)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
