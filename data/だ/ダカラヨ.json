        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あいつは太田だからよくわかっているのだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人称単数現在なら hasami だからよく似ている。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「張大人は野蛮だからよ……さぞ、内地の人間が見たら、おったまげるこったろうな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニ遠慮しなさんな、ちと相談もあるんだからよ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "演習だからよいようなものの、これがほんとうであったらなかなかの難儀である。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは太田だからよくわかってゐるのだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも子　だからよけいなお世話だってさっきも言ったじゃないの。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「つまり其男が恐喝したんだからよろしく御処分願ひますと云ふやうなことさ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は不満な顔をして帰つた両人を見送つて、聊か不安を感じたが、さて又考へて見ると、俺だからよく此依頼を拒絶し得たと云ふ誇りがすぐ湧いて来た。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「町内づきあひと同じ事さ、そりやお前、女が住んでる處だからよ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　天麩羅を、ちゆうと吸つて、「何しろ、お前、俺が顏を見せると、白い頸首が、島田のおくれ毛で、うつむくと、もう忽ち耳朶までポツとならうツて女が、お人形さんに着せるのだ、といつて、小さな紋着を縫つてゐるんだからよ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尖はとがらないでも、砂地だからよく抜ける。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンキ画だからよいのでしょう。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ子は寂しいもんだからよく、一人で、壁や塀に影絵をうつします。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、まあ、まるで生きてるようだね、鬼魅が悪いじゃないの」「だからよ、これで良い正月をしようと云うのだ、どうだ、鬼怒川温泉へでも伴れてってやろうか」「鬼怒川はいいね」　金五郎はそこで更めて偶人の顔を見た。",
              "citation": {
                "source": "偶人物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "己あまた、猫のさかるような高い処は厭だからよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいで坊は、その薬屋へよくいくのか」「うん、じき近くだからよくいくよ。",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたがあんまりおとなしいものだからよ。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母樣の方で、もう面倒だからよすと仰やれば、先づおれが自分でする。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからよほど気むずかしい男でない限り、そこで愉快に一ヶ月暮すことは何でもないことだった。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからよ、その上、俺たちの後だてにそれだけの仲間があって、この船を俺たちのものに出来ねえようなら、みんな尼さんの学校へでもいっちまうといいんだ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからよほど気むずかしい男でない限り、そこで愉快に一ヶ月暮らすことは何でもないことだろう。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "今だからよござんすけれど、だんだん寒くなると困りますわ」　そういうわけであるから当分は稽古にも来られまいとお雪はしおれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうよな、それよりか俺らどつちかつちつたら大根でも漬て貰へてえな、毎日栗の木見て居て干過ぎやしめえかと思つて心配してんだからよ」お品は訴へるやうにいつてさうして更に「自分で丈夫でせえありや疾くにやつちまつたんだが」と小聲でいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此の錢で外の物買つて喰つた方がえゝから此れ丈は遣るとすべえよ、折角勘定もしたもんだからよ、俺ら大層よくなつたんだから大丈夫だよ」お品はいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんでも可惜もんだからよ」「汝自分で梯子掛けて這入んのか」「俺ら可怖から厭だがな」「そんなこといふもんぢやねえ、又拘引れたらどうする、そん時は汝でも行くのか」勘次は恁ういつて苦笑した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "簇つた花の上には糊をつけた白糸が三括りばかり竿に掛けて干してある、余は此邊の人は出稼ぎでもするのかと娘にきいて見たら此邊一般の鼻に掛つた言葉でうつむいたまゝ低くいつたのだからよくは分らなかつたが「出はつて居りやヘン」といふやうに聞えた。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」で一撃の下に、笑に附せられてしまつて、彼の言が表現した通りの戯談の儘でとほつたのだからよささうな筈なのに――いつ迄たつても照子の云つた「結婚」といふ言葉を棄てることの出来ない彼なのであつた。",
              "citation": {
                "source": "ランプの明滅",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからよく考えれば、左馬頭のお話の嫉妬深い女も、思い出としてはいいでしょうが、今いっしょにいる妻であってはたまらない。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
