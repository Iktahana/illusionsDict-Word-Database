[
  {
    "uuid": "a4cdd2cc-5c5e-511f-8754-48674fb4f868",
    "entry": "男娼",
    "reading": {
      "primary": "だんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
