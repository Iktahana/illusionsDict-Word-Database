      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "second child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "右から二番目はたしかにラクシャンの第二子だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その声にラクシャンの第二子がびっくりして眼をさまし、その長い顎をあげて、眼を釘づけにされたやうにしばらく野火をみつめてゐる。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかなラクシャンの第二子がすぐ釣り込まれてあわて出し顔いろをぽっとほてらせながら「おい兄貴、一｜吠えしようか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その声にラクシャンの第二子がびっくりして眼をさまし、その長い顎をあげて、眼を釘づけにされたようにしばらく野火をみつめている。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかなラクシャンの第二子がすぐ釣り込まれてあわて出し顔いろをぽっとほてらせながら「おい兄貴、一吠えしようか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝は高祖｜武帝の第七子にして、誉は武帝の長子にして文選の撰者たる昭明太子統の第二子なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝孺は此の愚庵先生第二子として生れたり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大日本史は系図に拠つたと見えて第三子としてゐるが、第二子としてゐる人もある。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "国香は既に老衰して居た事だらう、何故といへば、国香の弟の弟の第二子若くは第三子の将門が既に三十三歳なのであるから。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋江抽斎の家では嫡子｜恒善が既に十歳になつてゐて、此年第二子｜優善が生れた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "常庵に養子｜長川があつたが、不幸にして早世したので、芸庵の第二子、常庵の弟陽庵が長川の後を承けた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "継嗣は第二子｜信之である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "磐の第二子｜善芳が十月二十八日に生れて三十日に夭した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "磐の三女ふみが一月二十九日に、第二子｜信治が十月三十日に生れた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五年二月二十二日徳の第二子｜信匡が生れた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　世に越前家と云うは徳川家康の第二子｜結城宰相｜秀康。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二子なき女は去ると言う。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯原王の事は審でないが、志貴皇子の第二子で光仁天皇の御兄弟であろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本後紀に、「延暦廿四年十一月（中略）壱志濃王薨、田原天皇之孫、湯原親王之第二子」云々とある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿奈麿は宇合の第二子、後内大臣まで進んだ。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾谷の西のはずれに初めて馬籠の村を開拓したのも、相州三浦の方から移って来た青山｜監物の第二子であった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「祖師伝」の中でも最も古いと言われる「元祖化導記」は文明十年日朝述で、寛文六年の版だとあるが、それには或記というものによって、「先祖は遠州の人｜貫名五郎重実なり、平家の乱に安房国に流されたり」と云い、その重実の第二子たる貫名次郎重忠の第四子が、すなわち祖師日蓮だと云っているのである。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖子第二子出生の由。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "名は燿蔵、諱は忠輝、号を胖庵といい、祭酒林｜述斎の第二子である。",
              "citation": {
                "source": "枇杷の花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "『実隆公記』には、長享二年三月第二子公条叙位の条に、「二歳の叙爵は数代の嘉例なり、次男相続また嘉模なり」とある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由はともかく第二子公条は相続人と定まり、その兄は出家することになったが、場所は春日大明神の管領する大和国内でなければならぬというので、最初は興福寺を望んだが、都合がつかなかったので、東大寺の勧学院に入れることにし西室と称した。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "綱宗のその第二子は、数えて三歳になる。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　トロヤ王プリアモスの第二子、ユノーとミネルウァとウェヌスの三女神の中で、ウェヌスを美しいと言ったがために、それがトロヤ戦争の発端となった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気もちは、信長の第二子｜北畠信雄と、三男｜神戸信孝の在るにたいして、当然抱かずにいられない一般の同情でもあったのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうだいにしては、余り粒が揃っている。",
              "citation": {
                "source": "杯",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
