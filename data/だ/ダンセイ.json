[
  {
    "uuid": "d3a7f000-abdb-5c28-bcc9-0ee5e09955db",
    "entry": "弾性",
    "reading": {
      "primary": "だんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
