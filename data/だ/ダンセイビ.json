[
  {
    "uuid": "5fe3f26b-93e5-5d17-83b1-d3c52b9bf16e",
    "entry": "男性美",
    "reading": {
      "primary": "だんせいび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
