          "literary": [
            {
              "text": "「かすかな物音が計画を台無しにする。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、日本人は、太陽の下にある世界の美しさを黒くし、また台無しにするような影を喜ばなかった。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、自らの富を全て台無しにする者には人間性を豊かにすることはできません。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人往々この種の句を挿んで雄壮なる歌をだいなしにする癖有之候。",
              "citation": {
                "source": "人々に答ふ",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "花をむやみに切り捨てたり、美術品をばだいなしにする者どもに対しては、今日においてもこういう法律が願わくは実施せられよかしと思う。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "この移り気が禍いして一生をだいなしにする者がどのくらいあるか判らない、ちょうど女の子が嫁入りすればその初縁を守ることが大切で、もし我儘を言って出戻りすると、つぎつぎと劣ったところへ嫁ぐようになって、悲惨な最期に達する。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはいつもばかげたつまらん冗談を言つて何もかもだいなしにするらしいのです」「冗談！",
              "citation": {
                "source": "共産主義者の犯罪",
                "author": "THE CRIME OF THE COMMUNIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "但新聞雑誌抔の期限切迫したる原稿を夜通しに大急ぎに書きつゝある場合に、一寸見たいと思ふ参考書が手もとに無きため折角の好意匠をだいなしにする時などは如何にも残念に候。",
              "citation": {
                "source": "貸借",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
