    "definitions": [
      {
        "index": 1,
        "gloss": "defection from or leaving a (political) party",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
