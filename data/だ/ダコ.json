[
  {
    "uuid": "6c25f64a-3f81-5011-b6dd-4d5416aad824",
    "entry": "唾壺",
    "reading": {
      "primary": "だこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
