    "definitions": [
      {
        "index": 1,
        "gloss": "High Treason Incident (socialist-anarchist plot to assassinate Emperor Meiji in 1910)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして明治四三年九月、わたしが出獄した時にはすでにいわゆる大逆事件が起こっていた。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に起ったのが例の大逆事件だ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "危く大逆事件に引込まれようとする　一カ年の刑期のものはとうに出た。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして検事局へ呼び出されて、こんどは本式に、いわゆる大逆事件との関係を取調べられた。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなで僕等を大逆事件の共犯者扱いするのだ。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に僕は大逆事件の被告等のほとんどみんなを見た。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後大逆事件の仲間の中にも二、三獄死した。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時大逆事件と呼ばれたテロリストのまったく小規模な天皇制への反抗があらわれ、幸徳秋水などが死刑に処せられた。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一〇年八月におこった幸徳秋水たちのいわゆる「大逆事件」が、高まる労働運動を封殺して絶対主義権力を守るために利用された大仕掛な捏造事件であったことは、今日すべての人の前に明らかである。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸徳秋水の大逆事件の前だっけね。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那ならば、否わが國でも明治の初期までならば、大逆事件として世間を騷動させたに相違ない。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇室に対する罪は、前に話した如く、副島伯の議論に依って一度削除されてしまったが、その後ち、伊藤公の議に依って規定を設けられたために、幸徳らの大逆事件も、拠って処断すべき法文があったのである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治になっても、陸奥宗光を出し、大逆事件にも此処から犠牲の一人を出した。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は刑期が滿ちて正當に出獄し、大逆事件で再び捕へられたが釋放されたこと、『西洋社會運動史』は發禁になつたこと、周圍の情勢は緊迫して身動きもならぬ有樣になつた時、支那及びベルギーの友人の熱心な勸告と援助とによつて幸運にも故國を脱出することができたこと、などを説明した。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にして思へば、あの時の會食がいかにも淋しさうで、わたしの在獄中におこつた、大逆事件の豫感が、あの人人の間にもあつたのではなかつたか。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何かの出版法違反事件で入つたのでせうが、そのまま幸徳等の大逆事件に連座するにいたつたのです。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大逆事件の餘波　明治四十三年九月、わたくしは刑期が滿ちて千葉監獄を出ました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通信で仄かにそれと察してはゐたのであるが、大逆事件を聞いてちよつと驚きました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸徳等の大逆事件に關連した取り調べであつたのです。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ大逆事件の際であるし、また幸徳の家には屡※出入してゐたので、事件に卷きこまれはせぬかと恐れたのです。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、大逆事件があつて以來、わたしどもの生活の道は八方ふさがりになりました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうこうしているうちに、幸徳秋水の大逆事件の検挙がはじまった。",
              "citation": {
                "source": "入社試験",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年は国内では有名な幸徳秋水らの大逆事件があり、またハレーすい星が現われ、外交面では日本が韓国を併合した年である。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一〇年といえば、日本の明治四十三年、いわゆる「大逆事件」で幸徳秋水以下三十余名の人々が検挙され、ファーブルの『昆虫の社会』という本まで社会という字がついていると云って発禁されるような、日本の社会主義弾圧のもとに暴力的な日韓合併が行われた年であった。",
              "citation": {
                "source": "婦人デーとひな祭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と眉をあげると、幸徳秋水とも一時は親交があったのだと砂馬は言って、「だから、大逆事件のときは、斎田慷堂もつかまってる」　ふーんと俺は唸って、「つかまって、よく無事に出られたものだ」と俺は言った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "大杉栄の場合は、「赤旗事件」で千葉監獄にはいっていて、大逆事件のときはシャバを留守にしていたのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは大逆事件の翌年だったが、大逆事件でわしの家へ警察の者が来よったとき、ちょうど猪沢市太郎がいて、女の子が生れたという話をしとったところだった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
