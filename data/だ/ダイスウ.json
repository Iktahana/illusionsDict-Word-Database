[
  {
    "uuid": "efcf2391-1bcb-5445-b532-76237e7a859e",
    "entry": "代数",
    "reading": {
      "primary": "だいすう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
