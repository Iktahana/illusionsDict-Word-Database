        "index": 1,
        "gloss": "Imperial Prosecuting and Investigating Office (1869-1871)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
