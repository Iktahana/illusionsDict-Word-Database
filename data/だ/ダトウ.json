[
  {
    "uuid": "d9989385-70ba-51c6-99fd-6d603ab01cc6",
    "entry": "妥当",
    "reading": {
      "primary": "だとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
