    "definitions": [
      {
        "index": 1,
        "gloss": "president (of a country)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一九一八年の暮バキンガム宮で大統領ウィルソンのために開かれた晩餐会に列席した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のレジオン・ド・ヌウルはフランス政府が彼の東洋流の栄養法が人口の味覚を満足さした功労によって、エリゼェの大統領官邸で贈与された（彼は巴里で生物学を研究するかたわら党費を稼ぐために豆腐を製造販売していたので。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その短い場面でわれわれは彼らがいかにして、またいかに、英国労働内閣首相であり、北米合衆国大統領であるかを読み取ることができるような気がするのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人の顔だけ写ってしゃべるのよりも、たとえば仮り小屋の壇上に立っておおぜいの老幼男女に囲まれているほうがいかにもアメリカの大統領になっている。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばマッキンレーが始めて大統領に選ばれたときに馬鈴薯の値段が暴騰したので、ウィスコンシンの農夫らはそれをこの選挙の結果に帰した。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアンカレが大統領時代には毎週火曜日に全閣員と昼食をこの店で摂るのが例だった。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に英邁勇敢なるルーズヴエルト氏が大統領に就任せし時以来、一部国民の精神は著しく其感化を受けしものゝ如く、表面に黄金を崇拝する事に変りはなけれど、其精神に於ては英雄崇拝を以て本義と為し或者は尚武練胆の気風を皷吹し、或者は米国魂に加ふるに日本魂の精萃をすら吸収し伝播せんと企てつゝあるが如し。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "○七月十六日、東京府民有志の発企にて、来朝中の米国前大統領グラント氏を新富座に招待し、新作の史劇「後三年奥州軍記」と芸妓の手踊を演ず。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは蓋し一門の大統領、従五位勲三等河野英臣の発議に因て、景色の見物をかねて、久能山の頂で日蝕の観測をしようとする催で。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうの夕刊に依ると、スペイン大統領、アサーニア氏も、とうとう辞職してしまった。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十餘年前、佛國里昂の勞働者の爆彈騷ぎに關係せる嫌疑で入獄した際、歐州各國の第一流の學者、文士連署して佛國大統領に陳情し、世界の學術の爲めに彼を特赦せんことを乞ひ大統領は直ちに之を許しました。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "米國大統領マツキンレーの暗殺でも、伊太利王ウンベルトのでも、又西班牙王アルフオンソに爆彈を投じたのでも、皆夫れ夫れ其時に特別な事情があつたのですが、餘り長くなるから申しません。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来能楽の家元というものは、政治や何かの方で云う大統領とか、首相とか、親分なぞいう実世間的な仕事をするものと違って、自流の芸術的主張を維持し研成する任務を持っている、芸術本位の世界の中心人物である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、大統領のリンコルンだって、本当はリンカーンでしょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "年取ったふとった案内者の顔はどこかフランスの大統領に似ていたが、着ている背広はみすぼらしいものであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は心裡にヱネチアの歴史を繰り返して、その古の富、古の繁華、古の獨立、古の權勢｜乃至大海に配すといふ古の大統領の事を思ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "其歌は古の恢復せられたるエルザレム（ジエルザレムメ、リベラアタ）の調にあらず、大統領の族絶えて、獅子の翼の外人に縛せられてより、ヱネチアの民はその歌謠の上の國粹をさへ失ひつるなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは大統領の館の輪奐の美を討ねて、その華麗を極めたる空しき殿堂を經に溝渠の水面の下にあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポツジヨは海を指ざしてかゝる青く波立てる大面積は羅馬の無き所なり、おほよそ地上の美なるもの海に若くはなかるべし、宜なり海はアフロヂテの母にしてと云ひさし、少し笑ひて、又ヱネチア歴代の大統領の未亡人なりといへり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ダンドロはヱネチアの大統領なりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ世紀末の最大の悪役と化したフセイン大統領率いるイラクに堂々乗り込んで、人質とされた日本人のうち高齢者と病人の解放を求めてしまうのだから、これを「吼える」と言わずして何が「吼える」か。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "御存知のない方もありませうが、卿は時のアメリカ大統領で、ワシントンやリンカーンに次ぐ偉人として高名を謳はれて居りました。",
              "citation": {
                "source": "私の万年筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨子の天子は「賢者を選擇して立てゝ天子と爲す」といふのであるから、天子の根源は「大統領」と同じものである。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船の航海中シヤトルに近くなったある日、当時の大統領マッキンレーは凶徒の短銃に斃れたので、この事件は米国でのうわさの中心になっているのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあすの奮闘的生活（これは大統領ルーズベルトの著書の“Strenuous Life”を訳してみた言葉です。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウヰルソン大統領は曩にドイツ國民に對して國家組織の改造を要求して、とう／＼あの革命を勃發させた。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パデレフスキーも日本に生れたら大統領は魯か文部の長官にだって選ばれそうもない。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの大統領が、われわれを日本へ送ったゆえんは、形式的な条約を結ぶためではない。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
