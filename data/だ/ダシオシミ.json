[
  {
    "uuid": "aab8afd8-76ce-5f55-b2b6-dd5f37cc88cb",
    "entry": "出し惜しみ",
    "reading": {
      "primary": "だしおしみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
