        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「大本営陸海軍部発表。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、知識の「大本営発表」である。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　ジリ貧という言葉を、大本営の将軍たちは、大まじめで教えていた。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず官庁や軍に売り込みをはかろうと考えていた謄写堂は、九月、初めての注文を大本営から受けたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報は来ているが、海軍省が伏せてるから号外を出せないんだ、」とさも大本営か海軍省の幕僚でもあるような得意な顔をして、「昨夜はマンジリともしなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "モルトケ時代は既に国軍は数軍に編制せられ、大本営の統一指揮下にあった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに独大本営は自らこの戦場に進出し直接三軍を指揮統一することもなさず、第二軍司令官をして臨時三個軍を指揮せしめた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八一二年はナポレオンとしては三軍の編成、その統一司令部の設置はかなり無理と言えるが、一九一四年は正しく右翼三軍の統一司令部を置くべきであり、万一置いてない時は大本営自ら第一線に進出、最も大切の時期にこの三軍を直接統一指揮すべきであった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独協定が行われて略一ヵ年を経た本年下四期に日伊協定が結ばれ、南京陥落の大提灯行列は、大本営治下の各地をねり歩いた。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし大本営一定の命令を下して各軍師団各兵站部等これを奉ぜざる者とせんか。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしわれらを召さんとならば大本営に行きて聞き合せなば宿所姓名尽く知れ居るなり。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "捏造記事である大本営発表に追い立てられてきょうの破滅が来たことを、日本のすべての人々は知らされました。",
              "citation": {
                "source": "わたしたちには選ぶ権利がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろあの当時、言論報道は全く統制されて嘘の大本営発表しか知らされなかったのだから、読者はこんにちあらわれる「秘史」にエログロと違うスリルを感じて、夏枯れしのぎに、いい思いつきのように流行しています。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に之は人気上の問題だけではないのは知れたことで、戦時体制が愈々本物の動員体制に這入るに及んで、経済統制の強化（特に臨時資金調達法の如き）や税制の強化は云うまでもなく、資源局と企画庁との合同による企画院の設立、大本営設置の実現などの現象が、続々と現われた。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大本営案については、全国務大臣が幕僚として参加するという形の軍事内政の両面に渡る案さえ一頃有力であった。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中、虚偽の大本営発表で勝利への妄信に油を注ぎつづけた責任者は誰であったろう。",
              "citation": {
                "source": "女の手帖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大本営報道が総て嘘であったということは、心から私共を悲しませ、又憤らせる。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇の名によって行われていたスパイと憲兵の絶対的な軍国主義権力が崩れて三年四年たってみると、情報局の報道と大本営発表でかためられた偽りの壁と封印の跡が、あたらしい回想と、そこに湧く批判の真実に消されはじめた。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵隊や兵隊を送った家族の女の感情にもひきずられてその女の感情で」中国へも南方へも行ったのであったが、一九四五年八月十五日がくるまで日本の人民を虚偽の大本営発表であざむきつづけた軍部としては、彼女たちの「泣いて語る話が手ごろに必要だったのである」と。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府の大本営発表を信じたばかりだった。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の声のきける短波のラジオは使用禁止され、ラジオは軍部、情報局のさしずどおり、一九四五年八月のあと、大部分が虚偽であったとわかった大本営発表を叫びつづけていた。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大本営発表のほとんどすべてがうそであったとわかった八月十五日からあとしばらくは、さすがの某誌も沈黙した。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四五年八月十五日以後に全人民はこれまでよまされていた大本営発表がほとんどすべて虚偽であったことを知って驚いた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて虚偽の大本営発表によって日本人民はたぶらかされてきた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭は社会の奮闘の中に置かれた自分及び自分の子弟の大本営であり、兵站部であり、練兵場である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮城の中に大本営が置かれ、戒厳令が下った。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯七時の大本営発表「五十機来襲、十四機撃墜（内不確実五機）、損害を与えたるもの二十七機、わが損害四機（体当たり二機を含む）」相当の戦果だ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我方地上施設ニ若干ノ損害アリ」との大本営発表である。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯午後六時二十分の大本営発表が、硫黄島戦を報ず。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
