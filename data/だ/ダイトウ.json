    "definitions": [
      {
        "index": 1,
        "gloss": "(Japanese) long sword",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしてまた、あれだけ大勢があれだけ多数の大刀を振廻わして、そうして誰も怪我をしないようにするという芸術はおそらく世界にユニークなものであろう。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝三次の宅（夜である）　行燈の燈影で三四郎が大刀の鞘を払って凝視する。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大刀ズラリと引ッこ抜く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉花道から、大刀片手に大跨にヅカヅカと舞台へ来り、平土間に向って、Ｔ「文句が有ったら　上って来い」　観衆睨み乍ら舞台の端を行ったり来たり「文句ある奴何奴だァ」と怒鳴って歩く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大刀振り上げる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、笑い乍ら大刀抜く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次「ホー四人だァ」　大吉、ニタニタ笑い乍ら、Ｔ「残った一つを　二つにする」　と云って背打ちにしていた大刀元に返す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、サッと大刀振り上ぐ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤、ワーと叫んで大刀おッ放り出して其場にヘタヘタヘタ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几の上に残って居た進藤の大刀を大吉が取り上げる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と身構えると、　其の侍は大吉には眼も呉れず、這う様にして先に倒した浪人の傍へ寄り、苦しい声で、Ｔ「父の……　カッカッ」　と叫んでとどめ刺さんと大刀振り上げたが力尽きてバッタリ倒れた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵、大刀振り上げてキッと斬り下す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳、近侍を呼び止めて、Ｔ「門前にふんぞり七兵衛と申す御用聞がうろうろ致して居る」　と言ってなりひらの方をジロリと睨んで、Ｔ「その七兵衛に斯う申せ」　と言って、Ｔ「お尋ね者のなりひら小僧が拙宅に忍び込んだ」　えッ、となりひら油断なく大刀を掴む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "文六突然、スラリと大刀引き抜いた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "立札の大写（フラッシュ）Ｔ「百両ッ」（少し大きく）　スラッと五人が大刀抜いて、Ｔ「助太刀致すッ」　と団九郎に迫る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌流大刀の鞘を払って、鞘を捨てた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校は、大刀のあびせようがなかった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大刀の斬れあじをためすためにやってみたのだ。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうか、で庄兵衛大刀を抜く。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――呼声は朱鞘の大刀、黒羽二重、五分月代に似ているが、すでにのさのさである程なれば、そうした凄味な仲蔵ではない。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大刀を突着けの、物凄くなった背後から、襟首を取ってぐいと手繰つけたものがあったっさ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水兵ヒラリと身を躱すよと見る間に、腰の大刀は※手も見せず、猛狒の肩先に斬込んだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで此の道理に照らせば自然分明であるが、今までの自分の心術でも行爲でも、苟も自ら新にせんと思ふ以上は、其の新にせねばならぬと信ずるところの舊いものを、大刀一揮で、英斷を振つて斫り倒して仕舞はねばならぬものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "袴の股立高く取つたる、年老い痩せ屈みたる侍、大刀の柄に手をかけつつ上手より登場。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに工面のしようがないので、お伽堂へ大刀さ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して各々の急所急所をきゆつと凝視めて、痛ましいほどの凌辱を相互に続ける、その恐怖と、憎々しさ、私は電球の尖をキツと差向けたまま、まるで青ざめはてた大刀の魚のやうに立ち竦んだ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「点ならござれ即点に、素襖の柿のへたながら、大刀の切字や手爾遠波を、正して点をかけ烏帽子、悪く謗らば片つはし、棒を背負つた挙句の果、此世の名残執筆の荒事、筆のそつ首引つこ抜き、硯の海へはふり込むと、ほゝ敬つて白す。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛は静に大刀を抜いて前へさしだした。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血振ひしたるわれは大刀を上段に、小刀を下段に構へて嘲み笑ひつ、「やおれ役人｜輩。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白麻のシャツに青玉まがいのカフス釦までつけ換えて、これはどうだいとうれしがった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
