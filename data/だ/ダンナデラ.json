    "definitions": [
      {
        "index": 1,
        "gloss": "one's family temple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は檀那寺の和尚の、それも隱居したのかと思ひました。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩は、鶴谷の檀那寺の納所だ、という悟った禅坊さんが一人。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夜のあけ方には、派出所の巡査、檀那寺の和尚まで立ち会わせるという狂い方でございまして。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、薄気味の悪いような、横柄で、傲慢で、人を舐めて、一切心得た様子をする、檀那寺の坊主、巫女などと同じ様子で、頼む人から一目置かれた、また本人二目も三目も置かせる気。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に沈みまする覚悟につき、冥土に参る心得のため、檀那寺の和尚が授けましたのでござります。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山門を仰いで見る、処々、壊え崩れて、草も尾花もむら生えの高い磴を登りかかった、お米の実家の檀那寺――仙晶寺というのである。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに例の一村一社制でこの社を潰さんとせしより、村の小学校長津村孫三郎と檀那寺の和尚浮津真海と、こは国体を害する大事とて大いに怒り、百七、八十人徒党して郡役所に嗷訴し、巨魁八人収監せらるること数月なりしが、無罪放免でその社は合祀を免れたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前に、渠は母の実家の檀那寺なる、この辺の寺に墓詣した。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "檀那寺へも田地の寄進をした。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が三回忌の法事を檀那寺で立派に営んだ時には、子分らしい者が大勢手伝いに来ていて、田舎かたぎの親類たちを驚かした。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対して、檀家からはお寺のことを「檀那寺」といいます。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、財物を上げぬ信者は「檀家」ではなく、法を施さぬ寺は「檀那寺」ではないわけです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、檀那寺に頼んで、新しく戒名を附けて貰ふ事にした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "米と住職９・５（夕）　前の月大阪市で米騒動が持上る少し前、それに気づいた市内のある米屋は、持米の大部分を檀那寺に担ぎ込んで、その保管｜方を頼んだものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ちに檀那寺へ急いで寺僧に息子の告白の一切を話して助力を乞うた。",
              "citation": {
                "source": "おかめのはなし",
                "author": "THE STORY OF O-KAME",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜田より半蔵門に出づるに、新宿も亦焼けたりと聞き、谷中の檀那寺を手頼らばやと思ふ。",
              "citation": {
                "source": "鸚鵡",
                "author": "――大震覚え書の一つ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "又つらつら考へれば、鸚鵡の籠を提げたるまま、檀那寺の世話にはなられぬやうなり。",
              "citation": {
                "source": "鸚鵡",
                "author": "――大震覚え書の一つ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮、谷中の檀那寺に至る。",
              "citation": {
                "source": "鸚鵡",
                "author": "――大震覚え書の一つ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の小学校へ一寸顔だけ出して檀那寺へ行つた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "檀那寺の和尚では無いから、岡崎から遂ひ出す訳にも行か無かつた。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にもいった私の檀那寺正宗寺には、代々の墓もあるから、妻と共に参拝した上に、総ての仏に対する法事を営んで、僧侶と近い親戚とへ午餐を出した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると或る晩に、その墓は五輪の塔で、こういう木の下に埋まっていると夢に見たので、その翌日｜檀那寺へ行って、夢に見た通り探がすと果して見付った。",
              "citation": {
                "source": "取り交ぜて",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲僧は寺の乏しかつた島の村々に、一種の説明を設ける様な形で、此を配置し、本土の檀那寺に似た権利を持たせた。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日になると、まず檀那寺から祝い物の笹竹を月の数だけ十二本もらってくる。",
              "citation": {
                "source": "屋根裏の犯人",
                "author": "――『鼠の文づかい』より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば京都天部部落の旧年寄家松浦氏の一族が、浄土宗黒谷派城安寺を檀那寺と仰いでいるが如きそれであるが、これらは多く特別の縁故によるものである。",
              "citation": {
                "source": "特殊部落と寺院",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "随全寺という法華宗の檀那寺の古石垣が、河原のように崩れたままになっている草叢のあたりに、見廻すまでもなく、おびただしい烏の群が一｜集まりになって降りて宿無犬が十匹余りも遠巻きに吠え立てている。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一〇八、結婚の手続き　国教宗の制規によるに、男女結婚を約するものは、その結婚の期日にさきだちて（通常五週間前）、これをその檀那寺に報知し、その寺にて毎日曜続きて三回、礼拝の節これを聴衆の前に報告し、異見故障あるものはその事情を住職に通知するを例とす。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "非国教宗に属するものは、かくのごとき手続きをふむを要せず、ただ結婚の当日、その檀那寺に至りて儀式を執行するをもって足れりとす。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事に葬ひを引受けると、後日の難儀だらう――と檀那寺に手紙を投り込んだ者があつて、葬式を出せなくなつてしまひ、檢屍をお願ひする騷ぎです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "尼が紅",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも、おばあさん、それでしたら　あなたの　だんなでらに　おねがい　したら　よくは　ありませんか。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
