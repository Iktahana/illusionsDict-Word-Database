[
  {
    "uuid": "f740a017-212a-5e8e-8e29-4ec8d48bd92f",
    "entry": "断髪",
    "reading": {
      "primary": "だんぱつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
