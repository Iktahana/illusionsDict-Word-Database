    "definitions": [
      {
        "index": 1,
        "gloss": "rice cake stuffed with sweet bean jam",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
