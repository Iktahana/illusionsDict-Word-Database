[
  {
    "uuid": "614f3afa-530d-5c15-bae2-9321714e5bd6",
    "entry": "大臣",
    "reading": {
      "primary": "だいじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
