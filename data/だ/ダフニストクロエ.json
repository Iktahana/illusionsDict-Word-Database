    "definitions": [
      {
        "index": 1,
        "gloss": "Daphnis and Chloe (novel by Longus, ballet by Ravel, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
