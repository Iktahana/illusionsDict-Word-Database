        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ユフダチ　ヤムノヲ　マツウチニツカレガ　デタカ　オヂイサンイツカ　グツスリ　ネムリマスオヤマハ　ハレテ　クモモナクアカルイ　ツキヨニ　ナリマシタ　この月は、春の下弦の月である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音によって多少発生年代を異にしたもののようで、キ→イ（「築墻」がツイガキ、「少キ人」がチヒサイヒト、「先立ち」がサイダチとなった類）ギ→イ（「序」がツイデ、「花ヤギ給へる」が「ハナヤイタマヘル」など）、ミ→ム（「かみさし」がカムザシ、「涙」がナンダ、「摘みたる」がツンダルの類。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　――ソノダチエ子。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、コウノトリは、暖かいアフリカのこと、ピラミッドのこと、砂漠を野ウマのように走るダチョウのこと、などを話しました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "デンデンムシハ　オトモダチノ　デンデンムシノ　トコロニ　ヤツテ　イキマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワタシハ　モウ　イキテ　ヰラレマセン」ト　ソノ　デンデンムシハ　オトモダチニ　イヒマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナンデスカ」ト　オトモダチノ　デンデンムシハ　キキマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　オトモダチノ　デンデンムシハ　イヒマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ソレヂヤ　シカタナイト　オモツテ、ハジメノ　デンデンムシハ、ベツノ　オトモダチノ　トコロヘ　イキマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　ソノ　オトモダチモ　イヒマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワタシノ　セナカニモ　カナシミハ　イツパイデス」　ソコデ、ハジメノ　デンデンムシハ　マタ　ベツノ　オトモダチノ　トコロヘ　イキマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウシテ、オトモダチヲ　ジユンジユンニ　タヅネテ　イキマシタガ、ドノ　トモダチモ　オナジ　コトヲ　イフノデ　アリマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "チイサイ　トキカラ、ヤマ　ノ　ケモノ　ヤ、トリタチ　ト、ナカヨク　アソンデ　ソダチマシタ。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルヒ、ヤマキチ　ノ　トモダチデ、イチワ　ノ　オオキナ　タカ　ガ、ヤマキチ　ヲ　ヒロイ　ツバサ　ニ　ノセ、ヒコウキ　ノ　ヨウニ　ソラ　ヲ　トンデ、シバラク　タカイ　キ　ノ　ウエデ、ヤスミマシタ。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "センセイノオシヘヲヨクマモリ、オトモダチト、ワルフザケヤケンカヲセズニ、ゲンキヨクアソベ。",
              "citation": {
                "source": "初夏通信",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に見たとき、この土地には二軒しか建物がなく、セイタカアワダチソウや、アキノキリンソウばかりがめだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "フン、眞ニソダチナハン。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "フン、真ニソダチナハン。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何から何まで御世話さまに成って、この御恩を忘れるようなことじゃ、捨吉もダチカンで」　交際上手な田辺の人達はやがてこのお母さんを打解けさせずには置かなかった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉代（節子の母）もね、なんだか気の弱いことを言ってるから、そんなことじゃダチカン。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダチャカン――というのは「埓があかない」の転訛で、つまり「ダメだ」という意味だ。",
              "citation": {
                "source": "だだをこねる",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば「自由をわれ等に」てなことをいったってとうていダチャカンわい――とまあいったような風にだ。",
              "citation": {
                "source": "だだをこねる",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "タダチニ、ウチニモドルベシ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と郵便局長が、さっそくマデーラを一杯ひっかけて、オランダチーズの大きな一切れと、バタをつけた蝶鮫の燻製とを頬ばりながら、言った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モシオ前ノ友ダチガウッカリシテイテオ前ノ足ヲ踏ンダラオ前ハドウスルカ？",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌劇「アイーダ」の特別名歌手と評判された強い声のソプラノ歌手ポリランダチョがいる。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "「タダチニ停船セヨ」との信号だった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノマヒゴノヤウスノヘンテコリンナコトトイツタラ※　水ノ中ニムヤミト長クツカツテヰタトミヘテ、アタマノ毛ハ一本、一本、サカダチ、カホモカラダモマツサヲ、クチビルハムラサキ色。",
              "citation": {
                "source": "ウミベノマヒゴ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
