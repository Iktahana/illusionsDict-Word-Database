        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もっとも誰かさんは出来たやうさ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも誰かさんはできたようさ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――折角誰かさんに会いに来たのにね」　と、豹吉より四つ歳上だけの口を利いた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の許へお参りをして下さいますのは分っていますけれどもね、そのさきに――誰かさん――」「誰かさん、誰かさん……分らない。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "米ちゃん、一体その誰かさんは？",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かさんに、悪いわ、済まないわ、薄情よ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……さて、これだが、手向けるとか、供えるとか、お米坊のいう――誰かさんは――」「ええ、そうなの。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かさんと誤解してるんじゃない。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かさんはわーるいな。",
              "citation": {
                "source": "卑怯者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "インフレの終ると共に、誰かさんの三日天下も終りを告げます」　恋は曲者である。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――誰かさんに似てやしないこと、どうせ。",
              "citation": {
                "source": "ふらんすの女",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は誰かさんのように、逆上し、又、亢奮する筈がないのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内人（文春の誰かさん）はニヤリと笑って言いました。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰かさんの言うのには、　救い主のお生まれを祝う頃ともなりますと、　日の出を告げるこの鶏は夜通し歌っているとやら。",
              "citation": {
                "source": "クリスマス",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの手紙にも、やはりわざと筆蹟を崩した尾の長いくねくねした字で、『誰かさんは土曜日には発ちません』とあった。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "名なしの誰かさん」　こうよびかけられて、無名氏はふりむいた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かさんの肩掛けが風で飛ばされてきてよ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃公は誰かさんの背中は重たかろうと思って気の毒でならなかったが、その中に森川さんが気がついて取ってやった。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かさんのあんなくらくらする魔法はごめんです」「でもディクソン、君はもちろんやるよな。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "与平は二人の小頭とともに、義一とりゅうの傷をしらべながら、誰かさんてつ先生を呼んでくれ、と云った。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして誰かさんに向っては、お前さんたちは私の施し方が足りないといって怒っているのではなく、もうちっと出せそうなものだと思って怒っているのだと、教えてやることでございましょう＊。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かさんに喉をしめられるかも知れないけれど。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから誰かさん＊とは正反対で、おそらくわたしは、パリにおける第一の人たるよりはむしろペリグウにおける第二第三の人である方をよろこぶであろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛する者の嘆き悲しむのを聞けば、彼らの心は憐れみの情をもってしめつけられるし、誰かさんのそらぞらしいうその愁嘆をきけば、おそらく憤りをもってその心は張り裂けんばかりであろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえってそういう危険は、ただ眼に見るのさえおそろしく、戦場から遠く離れた家の中にとじこもっている誰かさんの方が、戦争の結果が気になってたまらず、そこに血と生命とをかける兵隊さん以上に心をなやましている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏の為に、誰かさんがやらせたのか。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの名前を言ったので、誰かさんが喋らなくても、あなたに気があり、惚れたことが分かった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで誰かさんがびっくりするぞ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでだれかさんとおんなじに……」ころがしながらこう云った小虫はなんとも云わないでやっぱりコロコロころんでるそれでも前のよにかわいらしい……白い着物のたもとの上にそっとのっけて垣づたいとなりのおばさに見せにいた。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおくのほう、　テーブルの　はしにだけ　テーブルクロスが　広げてあって、　そこに　取りざらと　タンブラー、　ナイフと　フォーク、　しお入れに　からしと　イスが　あり　――　つまるところ　だれかさんの　夕ごはんの　したくなのでした。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
