        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山吹教授は部屋の隅の「ライフ」や「リーダーズ・ダイジェスト」や「ヴァニティ・フェア」等、近着のアメリカ雑誌がうず高く積まれた傍のソファに掛けて、校正用のゲラ刷に眼を通していた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉井正太郎は、こんどは誰をつかまえて、リーダーズ・ダイジェスト仕込みの話をしかけようかと一同の顔を見ていたが、男はみなだめだと判ると、稲福という舞妓をつかまえて、「君、ええ話教えたげよか。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識欲のさかんな若い人々、レーニンが云っているように向上心にもえ、階級の武器として、あらゆる知識をもちたいと思っている優秀な労働者たちが、その知識慾を餌じきにされて、きたならしい饒舌、ダイジェスト文化に、時間と金を吸いとられ、頭脳をかきまわされるのは何とくちおしいことでしょう。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはリーダーズ・ダイジェストの編輯方針と全く同じである。",
              "citation": {
                "source": "文学と生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この編集者は非常に多くリーダーズ・ダイジェストから学ぼうとしているらしく見受けられる。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リーダーズ・ダイジェストをはじめ、日本人が日本で出す新聞や雑誌でも、アメリカの世論統計を引用する場合には、しばしばギャラップの世論調査をつかい、ギャラップの調査の科学性と確実性とが語られた。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三六年ルーズヴェルトとランドン両候補の間に大統領選挙がたたかわれたとき、当時アメリカにおいて世論調査の最大権威とされていた『リテラリ・ダイジェスト』誌の世論調査が、ランドンの勝利を予測し、誤差一八％で、ダイジェストは「四十八年間の光栄ある世論調査の歴史が汚れてしまった」。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三六年のダイジェストの調査は調査ごとに五〇万ドルの費用をかけ一千万枚のアンケートを発送し、二、一五八、七八九の回答にもとづいて行われた。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大仕掛のダイジェスト世論調査が、何故にとりかえしのつかない大失敗に終ったかというと、そこには実におもしろい社会の現実のモメントがある。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三六年のルーズヴェルト大統領選挙のとき、ダイジェストの世論調査所がアンケートを送りつけた人々の名簿は、電話と自動車所有者からとられたのだそうだった。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイジェストがアンケートを送った電話・自動車所有者名簿には、数百万の失業者、もっと多数の半失業者、貧農とその妻たちその娘たちの名はのっていなかった。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイジェストが失敗した一九三六年時代の世論調査では、ギャラップ博士の調査所が正確であった。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャラップの米国世論研究所は、ダイジェストと全く似た理由によって致命的な失敗を示した。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ギャラップがダイジェストと同様に労働階級の投票率を誤算したのではなかったろうか。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「ギャラップの調査員は大部分が女子で、しかも一定の割当人員のだれを選ぶかは調査員自身の決定にまかしてあるため、労働者や下層階級の人を避ける傾向があり、従って多く民主党支持である下層階級の意見が適当に代表されなかったのは、リテラリ・ダイジェストの場合と同様であろう」と判断されている。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨーク・タイムズ東京支局長リンゼー・パロット氏、ＡＰ東京支局長ラッセル・ブラインズ氏に対して日本人として鈴木文史朗氏が出席している、肩書はリーダーズ・ダイジェスト日本版編集長とある。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『中央公論』をよむ人はまたリーダーズ・ダイジェストもよんでいる。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木文史朗はついこの間アメリカへ行ってリーダーズ・ダイジェスト本社の立派なことを日本に吹聴したが、彼はアメリカで何を学び、どう語ることを学んで帰ったというのだろう。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現につい先日東京でのダイジェスト日本陶器展で私のやや大作長方鉢をリッジウェイ大将夫人が目にとめて持ち帰られたという。",
              "citation": {
                "source": "感想",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "リーダーズ・ダイジェストなどにも紹介され、日本でも大分注目をひいている話である。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュー・メキシコ州での実験は、リーダーズ・ダイジェストの九月号に紹介されているが、この時は、沃化銀の粉を撒いたのである。",
              "citation": {
                "source": "雨を降らす話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下ダイジェスト誌の記事によって、その簡単な説明をしておこう。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その理由は、原著を見ていないので、このリーダーズダイジェストの紹介の記事だけでは、批判するだけの材料が揃っていないからである。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも以下の説明は、リーダーズダイジェストの記事を基礎としての話であって、その記事が原著の意を十分に伝えていない場合は、話は別である。",
              "citation": {
                "source": "心霊現象と科学",
                "author": "――『心の領域』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、一面、その「早わかり本」の愛読者なる政治家が、その頃最も新しい政治家で、生涯のうちに、かなりの良い仕事をしてくれ、人のためにも、国のためにも、大きな手柄を立ててくれたことを考えると、ダイジェスト智恵や「早わかり本」の手柄も満更ではなかったという結論が生み出せないこともないわけである。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次読む人読まぬ人――三人の政治家――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「実はうちの雑誌でこういうダイジェストをやっているんですが、先生のこの間の放送の。",
              "citation": {
                "source": "貧乏を売る",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかリーダーズ・ダイジェストに、終戦の時、村の人が、梅を伐った話を書いたら、すぐ朝日の投書欄へ、村の出身者の抗議文が載った。",
              "citation": {
                "source": "梅ちらほら",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四五年九月のリーダーズ・ダイジェストに、退役大佐ボナー・フェラーズの名をもつてかかげられた「降伏のためにたたかつた天皇裕仁」と題する論文が出ている。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
