    "definitions": [
      {
        "index": 1,
        "gloss": "great king",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "王が代わりに自分の弓を与えたのを引き絞ってみて「弱い弱い、大王の弓にはあまり弱い」と言って弓を投げ捨て、剣と盾とを取って勇ましく戦った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は学生がアレキサンダー大王その外何ダースかの征服者の事を少しも知らなくても、大した不幸だとは思わない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のはいらないような茂みの中には美しいフェアリーや滑稽なゴブリンの一大王国があったのである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ人類の食糧と云はゞスタンダードチョイスリーダー三　フレデリック大王の質問をまたずと雖も動物植物鉱物の三種を出づべからず。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもおまえたちは名高いヴェーッサンタラ大王のはなしを知っているだろう。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェーッサンタラ大王は檀波羅蜜の行と云ってほしいと云われるものは何でもやった。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けらいや人民ははじめは堪えていたけれどもついには国も亡びそうになったので大王を山へ追い申したのだ。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王はお妃と王子王女とただ四人で山へ行かれた。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき大王の徳には林の樹もまた感じていた。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどももしヴェーッサンタラ大王のように大へんに徳のある人ならばそしてその人がひどく飢えているならば木の枝はやっぱりひとりでに垂れてくるにちがいない。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ている沢山の群集の中に尊いアショウカ大王も立たれました。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王はけらいに向って「誰かこの大河の水をさかさまにながれさせることのできるものがあるか」と問われました。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王の問をみんなが口々に相伝えて云っているのをきいて「わたくしは自分の肉を売って生きているいやしい女である。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王はこの恐ろしくうずを巻き、はげしく鳴る音を聞いて、びっくりしてけらいに申されました「これ、これ、どうしたのじゃ。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王は非常に感動され、すぐにその女の処に歩いて行って申されました。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二課、アレキサンドル大王と醫師フイリツプ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしヨーロツパにアレキサンドル大王といふ英雄があつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレキサンドル大王はこの美徳をもつてゐたがために、一命をまつたうしたやうであります。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二課、アレキサンドル大王と医師フィリップ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしヨーロッパにアレキサンドル大王という英雄があった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アレキサンドル大王はこの美徳をもっていたがために、一命をまっとうしたようであります。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは柏の木大王のお客さまになって来ているんだ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人はずうっと木の間を通って、柏の木大王のところに来ました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王は大小とりまぜて十九本の手と、一本の太い脚とをもって居りました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると大王はまがった腰をのばして、低い声で画かきに云いました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大王もごつごつの胸を張って怒りました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　柏の木大王も白いひげをひねって、しばらくうむうむと云いながら、じっとお月さまを眺めてから、しずかに歌いだしました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると柏の木大王が怒りました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　柏の木大王が機嫌を直してわははわははと笑いました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏の木どもは大王を正面に大きな環をつくりました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
