[
  {
    "uuid": "a32833f3-d926-5efd-a5b1-8170de401319",
    "entry": "駄津",
    "reading": {
      "primary": "だつ",
      "alternatives": [
        "ダツ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Pacific needlefish (Strongylura anastomella)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だつて君そこに浮気があります浮気は悲しい音楽をヒヨツと忘れさせること度々です空　空　空やつぱり壁は土で造つたものでした。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると先生は、俺を廊下に立たせるのだつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は廊下に立たされて、何がなし、「運命だ」と思ふのだつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、午睡の夢から覚めてみると　　みなさん家を空けておいでだつた　　あの時を妙に思ひ出しますさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに正しく神経衰弱が原因だつたとしても、単純な受験生のそれではあるまいし、その神経衰弱の因つて来た所を考へてみたくなる。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてケシの花だつたかを買つて円タクに帰つて来ると、その男は花を一本づつ我々に配つた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のことはない妄想家流であつて、ジャズだつてオネガだつてアッターベルヒだつてラヴェルだつてシトラウスだつてマーラーだつて、妄想家流――といつて妥当でなければ幻想家流である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それあまあ、昔だつて一般世人は美術家より装飾美術家の方をリアリスティクだと思つてゐたものではあるらしい。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々あるどころか無数にあつて、空気中のオゾンの量に因ると考へる人だつてないとは云へぬ。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "努力だつて、努力出来るだけ出来るのである。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく海の出て来るボオドレエルの詩だつて、「信天翁」だと、広々として一物も見えぬ、秋も終りの海が見えて来る。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさて、今よりも、子供の時分の方が、よつぽど海は好きだつたやうだから、してみると今よりも、あの頃の方が「こころまゝ」だつたのだらうか？",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "感想中原中也　地方の詩のグループも多いことだが、どういふものか、ずつと以前から大連と神戸にだけ面白いものが見られるのだつた。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われらひとしく丘に立ち〕宮沢賢治われらひとしく丘に立ち青ぐろくしてぶちうてるあやしきもののひろがりを東はてなくのぞみけりそは巨いなる塩の水海とはおのもさとれども伝へてきゝしそのものとあまりにたがふこゝちしてたゞうつゝなるうすれ日にそのわだつみの潮騒のうろこの国の波がしらきほひ寄するをのぞみゐたりき",
              "citation": {
                "source": "〔われらひとしく丘に立ち〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ幼いマルスリーヌを伴つて、彼女は実際アメリカに行つたのだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが著いてみると、恐ろしい当て外れだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『快活にならうとつとめたが、どうも私に合ふのはメランコリックな情熱的な役だつた』と後年彼女は追想してゐる。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故といつて私の声は泣くやうだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "※ルモオルは却々しつかりした男で、彼女はその妻として実に申し分のない妻だつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "儲けにこそならなかつたが、詩は彼女の大切な慰安だつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、ラマルチーヌの、サント・ブーヴの、モンモランシイの、レカミエ夫人の、ミシュレの友情を招来したのだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もひどく無頓着だつた彼女は、彼等との交際も余りしなかつたのではあるが。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又教養たるや不完全なものだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "情深い、不安げなその魂は何時も困惑や切願の状態にあつて、劇しいメランコリとも呼ばるべきものだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
