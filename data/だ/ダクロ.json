        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ダホメーの酋長の家では、臣下は玉座の二十歩以内に近よることを禁ぜられて、ダクロと称する老婆によって、酋長へのいっさいの取次ぎをして貰う。",
              "citation": {
                "source": "奴隷根性論",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずその取次ぎを請うものは、ダクロの前へ四這いになって行く。",
              "citation": {
                "source": "奴隷根性論",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてダクロはまた四足になって、酋長の前へ這って行く。",
              "citation": {
                "source": "奴隷根性論",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
