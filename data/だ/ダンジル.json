  {
    "uuid": "9570674c-e0f3-5ff0-817d-a5d4c7c34215",
    "entry": "弾じる",
    "reading": {
      "primary": "だんじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to play (a stringed instrument)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "千代紙の中から琴を弾じる唐子一人つかわします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、私の弾じる琵琶の技が足らないかと思って額に汗をして語りましたが、やはりそうではありません。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の弾じる一曲を聞いて、それを機に、今夜の散会としようではないかと提議する。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの内で琴を弾じる音がコロリンシャンと至極のどかに聞えているばかりだ。",
              "citation": {
                "source": "心理試験",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ、家中の若侍たちが、一升｜提げて、やって来たので、この番小屋で、平家琵琶を弾じるやら、陣中節を謡うやら、大賑いをやった。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
