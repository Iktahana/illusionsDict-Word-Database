        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」その大学士らしい人が、眼鏡をきらっとさせて、こっちを見て話しかけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士はあはてゝ走って行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニは、ていねいに大学士におぢぎしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士は、また忙がしさうに、あちこち歩きまはって監督をはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士はあわてて走って行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニは、ていねいに大学士におじぎしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士は、また忙がしそうに、あちこち歩きまわって監督をはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君たちは参観かね」その大学士らしい人が、眼鏡をきらっとさせて、こっちを見て話しかけました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ下に肋骨が埋もれてるはずじゃないか」　大学士はあわてて走って行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、ではわたくしどもは失礼いたします」ジョバンニは、ていねいに大学士におじぎしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、さよなら」大学士は、また忙しそうに、あちこち歩きまわって監督をはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩大学士の小さな家へ、「貝の火｜兄弟商会」の、赤鼻の支配人がやって来た。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士は葉巻を横にくはへ、雲母紙を張った天井を、斜めに見上げて聴いてゐた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そこで楢ノ木大学士は、にやっと笑って葉巻をとった。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士は別段気にもとめず、手を延ばして状袋をさらひ、自分の衣嚢に投げこんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは楢の木大学士だ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出掛けた為にたうとう楢ノ木大学士の、野宿といふことも起ったのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野宿第一夜四月二十日の午后四時｜頃、例の楢ノ木大学士が「ふん、此の川筋があやしいぞ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学士はどこまでも溯って行く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その両側の山どもは、一生懸命の大学士などにはお構ひなくずんずん黒く暮れて行く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢ノ木大学士はそんなことには構はない。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかはり又大学士が、腕をのばして背嚢をぬぎ、肱をまげて外套のまゝ、ごろりと横になったときは、外套のせなかに白い粉が、まるで一杯についたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学士は寝たまゝそれを眺め、又ひとりごとを言ひ出した。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そこで大学士はいゝ気になって、仰向けのまゝ手を振って、岩頸の講義をはじめ出した。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢ノ木大学士の喜びやうはひどいもんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢ノ木大学士がもっとよく四人を見ようと起き上ったら俄かにラクシャン第一子が雷のやうに怒鳴り出した。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」楢ノ木大学士はびっくりして大急ぎで又横になりいびきまでして寝たふりをしそっと横目で見つゞけた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが今のどなり声は大学士に云ったのでもなかったやうだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、楢ノ木大学士といふものが、おれのどなりをひょっと聞いて、びっくりして頭をふらふら、ゆすぶったやうにだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
