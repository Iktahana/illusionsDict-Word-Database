    "definitions": [
      {
        "index": 1,
        "gloss": "abandoning (hope, plans)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
