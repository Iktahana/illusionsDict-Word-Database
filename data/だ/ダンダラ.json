[
  {
    "uuid": "2495e691-34c4-5994-adfe-32c6e388b9e2",
    "entry": "段だら",
    "reading": {
      "primary": "だんだら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
