    "definitions": [
      {
        "index": 1,
        "gloss": "anyone and everyone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
