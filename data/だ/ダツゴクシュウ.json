    "definitions": [
      {
        "index": 1,
        "gloss": "escaped prisoner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
