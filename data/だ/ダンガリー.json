        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "胸のあいた上着に、コールタールの染みだらけの袖、赤と黒の市松模様のシャツ、ダンガリーのズボン、ひどくすり切れた重いブーツといった格好だった。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューギニアへ行ったら、濠洲へ渡るための土人のプラウを買わなければならないが、二人乗の刳舟の値段は、煙草二百本、ダンガリー（太織木綿）一反、あるいは手斧二梃、赤木綿二反であります。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "無漂白ダンガリーのフレアード・ジーンズに、濃いオリーヴ色の洗いざらしたＴシャツだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずぶ濡れのジーンズを両脚からはぎとるように脱ぎ、ダンガリーの長袖シャツを、上半身からひんむいた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "長袖のダンガリー・シャツ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、ブルージーンズにダンガリーのカウボーイ・シャツだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときも、ブルージーンズにダンガリーのシャツだった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
