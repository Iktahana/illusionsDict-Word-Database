    "definitions": [
      {
        "index": 1,
        "gloss": "suspension of water supply",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
