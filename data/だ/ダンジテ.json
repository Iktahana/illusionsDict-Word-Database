        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "智識でも慈善事業でも其の他何物でもない、断じてない！",
              "citation": {
                "source": "詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "断じて生産の形式のものではない。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに、ああした魔力ある彼の言葉は、彼の不思議な天賦の性情から、自然と湧き出づる人格のリズムであつて、断じて彼以外の者の追蹤を許さない秘密であらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と断じて、悠然と引上げ、「ああ、やっぱり、ヒットラーに限る！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の目算では、身丈は五尺七寸、体重は十五貫、足袋は十一文、年齢は断じて三十まえだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨私は、明治以来詩人がゐなかつたといふのでは断じてない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてどんな点でも間抜けと見えない芸術家があつたら断じて妙なことだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは自然の面白さを拡張する一つの能力で、されば断じて興味以外のものを目的とすることが許されぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活が拙いといふことは、断じて芸術が拙いといふことではない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、芸術作品といふものは、断じて人と合議の上で出来るものではない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の断じて立言し得ることは、蕪村が単なる写生主義者や、単なる技巧的スケッチ画家でないということである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "断じてわしも譲歩せん。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "断じてその眼を克服せよ、たかゞ二つの節穴だ。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "断じて、断じて戦ふべし。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大恩のある簡先生の名誉のため、名望高い一門のため、郷党のため児孫のため、わしは断じて折れてはいかん。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "語感の強弱というくらいのことを外来語採用の標準とすることは断じてゆるせないと思う。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども如何なる塲合に於ても、歌に潤いが無いということをもって、創作上の進歩と認め得るような事は断じて有得ないと考えられる。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝に　俺が命令する」　断然と言い放ち、Ｔ「此後断じて　舞台に立つ事ならぬ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤知らずに尚も、Ｔ「尋常の勝負ならば　断じて大吉如きに」　大吉が後を続けた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "』という冷酷な絶対命令の下に君が屈服しないですんだことは断じてなかったのだ。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤った無理な似て非なる類推は断じて許されないとしても、このような想起者として科学は意外に重要な役目を人間の今日の生活のいろいろな場面に対して申し出しているように思われるのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "断じて八が岳では、ない。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗っても、洗っても、私は、断じて昔の私ではない。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん探して来たよ、僕は一ぺん山へ出かけるともうどんなもんでも見附からんと云ふことは断じてない、けだしすべての宝石はみな僕をしたってあつまって来るんだね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん探して来たよ、僕は一ぺん山へ出かけるともうどんなもんでも見附からんと云うことは断じてない、けだしすべての宝石はみな僕をしたってあつまって来るんだね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其所らを夢中で往きつ返りつ地を見つめたまま歩るいて『決してそんなことはない』『断じてない』と、魔を叱するかのように言ってみたが、魔は決して去らない、僕はおりおり足を止めて地を凝視ていると、蒼白い少女の顔がありありと眼先に現われて来る、どうしてもその顔色がこの世のものでないことを示している。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時が来ても、私がこの農場を解放したのを悔いるようなことは断じてないつもりです。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口検事が立って、（一）検察側はだんじて拷問、人権蹂躙を行っていない。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "永井が私へいろいろいやなことをすすめますけれど、私はだんじてそんな悪いことを致したくはございません。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、れいの武士が来て、おまえの名をよぶだろうが、おまえは、どんなことがあっても、だんじて返事をしてはならぬ。",
              "citation": {
                "source": "壇ノ浦の鬼火",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
