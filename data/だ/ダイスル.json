    "definitions": [
      {
        "index": 1,
        "gloss": "to be titled (e.g. a book)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに氏には「余が俳句観」と題するエツセイもある程なので、さだめし作品が多量にあることだと思ひ、いつかまとめて読んだ上、俳人芥川龍之介論を書かうと楽しみにしてゐた。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の昔作つた詩に、「鶏」と題する一篇がある。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「常山の花」と題する小品の中にある「相撲取草」とは邦語の学名で何に当るかという質問を受けて困ってしまって同郷の牧野富太郎博士の教えを乞うてはじめてそれが「メヒシバ」だということを知った。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃ベルギーの天文台年報にストローバンという人が出した「銀河に対する星の分布」と題する論文の抜書を見ると、驚くべき学者の根気の結果が現われている。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブートルーは「神秘説の心理」と題する論文のうちで、神秘説に関して「その出発点は精神の定義しがたい一の状態で、ドイツ語の Sehnsucht がこの状態をかなり善く言い表わしている｛２｝」といっているが、すなわち彼はフランス語のうちに Sehnsucht の意味を表現する語のないことを認めている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空気中の新元素アルゴン」と題する論文が王立協会で発表されたのは一八九五年の正月であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "クーシューというフランス人は『アジアの詩人と賢人』と題する書物の一節において、およそ世界の中で日本人とアメリカ人と程にちがった国民は先ずないという意味のことを云っている。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃ここのルスツキーという動物学者の著わした『ロシアの蟻』と題する書のごときも斯学上有益なものだそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「号外」、なるほど加藤男の彫像に題するには何よりの題目だろう、……男爵は例のごとくそのポケットから幾多の新聞の号外を取り出して、「号外と僕に題するにおいて何かあらんだ。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその巻頭に掲載された和辻哲郎氏の「風土の現象」と題する所説と、それを序編とする同氏の近刊著書「風土」における最も独創的な全機的自然観を参照されたい。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなはち、左に「地球圖」と題する一篇の小品を默示するのみ。",
              "citation": {
                "source": "「地球圖」序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近着の雑誌リリュストラシオン（３）に「黙示録に現われたる飛行機と科学戦」と題する珍奇な絵入りの読み物がある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりから映し出された映画は「三万両五十三次」とか題する時代劇であった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八　「笑う」と「泣く」と　十余年前に「笑い」と題する随筆を書いたことがあって、その中で、緊張から弛緩に移る際に発生する笑いの現象について若干の素人考えを述べたのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉やお加代や亀吉がやがて更生して行くだろう経過、豹吉とお加代、そして雪子との関係、小沢と道子の今後、伊部の起ち直りの如何……その他なお述べるべきことが多いが、しかしそれらはこの「夜光虫」と題する小説とはまたべつの物語を構成するであろう。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは『自由詩の原理』と題する部分的の詩論であったが、或る事情から出版が厭やになって、そのまま手許に残しておいた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "標題音楽とは、近代に於ける一般的の者のように、楽曲の標題する「夢」や「恋」やを、それの情緒気分に於て表情しようとする音楽であり、その態度は純粋に主観的である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第九章　詩の本質　今や吾人は、始めて本書が標題する実の題目、詩とは何ぞや？",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに僕の場合では、読者がまるで僕の言語を理解せず、僕の思想の主題するところを知らないで、意外な思いがけない解釈から、勝手な言いがかりをしてくるのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの名は「揺籠」、一つは「柩」と題するもの。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人の画は、それこそ少し青くさくて、決していいものでないけれども、たしか「芸術家」と題する一枚の画があった。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は遂に彼が嘗て――七年前――「歌牌の娯樂」と題する一文を週刊平民新聞の新年號に掲げてあつたことまでも思ひ出させられた。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まあ、私に云わないで兄さんに云った――かの女はごくあたりまえにこう内心で独り言を云っただけだった――そして普通の友人の絵でも見に行くように重光青年から招待されて、上野の展覧会場へその秋の傑作の一つと評判の高い「高原の太陽」と題する青年の出品画を観に行った。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "民友子｜先つ頃「俗間の歌謡」と題する一文を作りて、平民社界に行はるゝ音楽の調子の低くして険なるを説きぬ。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、余は、「人生に相渉るとは何の謂ぞ」と題する一文の中に其一端を論じたる事あれば、就いて読まれん事を請ふになむ。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "同作家の「婦人に寄語す」と題する一篇を読まば、英国の如き両性の間柄厳格なる国に於てすら、斯の如き放言を吐きし詩家の胸奥を覗ふに足る可けむ。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "権者の大方便と題するものは、即ち所謂コンペンセイシヨンの大法なるにあらずや。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかもめぼしがついてしまったから、てがらはこっちへちょうだいするぜ」　むろんのことに、伝六はかんかんになったようでしたが、しかし右門はいたってゆうぜんとしたものでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "またひとてがらちょうだいするんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーケットの親分代理といふやうな立派なアンチャンが焼跡へつれこんでピストルで脅迫してもダメ、くんづほぐれつの大格闘に服もシュミーズも破れてハダカになつても反撃ミヂンも衰へず、お金には買はれてやるよ、あんたに限つて洋服代をちようだいするから。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
