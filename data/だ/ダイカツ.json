[
  {
    "uuid": "6db6fc26-649a-516e-9eb2-582fb10b75ae",
    "entry": "大喝",
    "reading": {
      "primary": "だいかつ",
      "alternatives": [
        "たいかつ"
      ],
      "is_heteronym": false
    },
    "grammar": {
