      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shouting in a thunderous voice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "組合長が直線コースで校長を抜いた時は大喝采が起つた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」聞くもの大笑せぬはなく、意外、望外の拍手、大喝采。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の顏も上げさせず、黒髯は大喝して、「成らん！",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と、日出雄少年と、他に一群の水兵とは、陸に留つて、其試運轉の光景を眺めつゝ、花火を揚げ、旗を振り、大喝采をやる積りだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に櫻木海軍大佐の朗々たる詩吟につれて、何時覺えたか、日出雄少年の勇ましき劍舞は當夜の華で、私が無藝のために、只更頭を掻いたのと共に、大拍手大喝釆であつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは一円五十銭ずつ遣ろう」といっても、彼等はいつまでも煮え切らずブツブツいっているので、髯将軍の癇癪玉が忽ち破裂して大喝一声、「黙れッ！",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "と大喝一声、怯む処を附け入って、拳の雷手錬のあてに、八蔵は急所を撲たれ、蹈反りて、大地はどうと響きけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　へいげんは大喝して、「小僧、汝は掏摸だ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大喝一番腕まくりして向い来るに、ぎょっとして飛退り、怨めしげに法会を視めて多時は去りもやらず、彼がその日の収入に大なる影響あればなり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼のそぶりで金の貸し借りを判断するちう事からして間違っているし……」「間違っておりません……あいつは……ワ……私を毒殺しようとしたんです……旦那の方が無理です」「黙れッ……」　と巡査部長は不意に眼を怒らして大喝した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て墨汁一滴か何かの中に、独乙では姉崎や、藤代が独乙語で演説をして大喝采を博しているのに漱石は倫敦の片田舎の下宿に燻って、婆さんからいじめられていると云う様な事をかいた。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大喝して女を力まかせに殴り、諸行無常を観じ、出家にならねばならぬと覚悟を極めた次第で、今日つらつら考えると私のような野暮で物欲しげで理窟っぽい男は、若い茶屋女に好かれる筈はなく、親爺のすすめる田舎女でも、おとなしくもらって置けばよかったとひとりで苦笑致して居ります。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、両説の目標とするところは、共に支那の保全にあるのだから、本会は『支那の保全』を以てその目的としては如何であろう、という厳粛な発言を行って満座を抑え、両派共これには異議無く、満場一致｜大喝采裡に会の目的が可決され、この『支那の保全』は、爾来、わが国の対支国是となっているという事です。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大喝するのを、蔭で女房は夫の日頃の気性を知つてゐるだけに只黙※と涙を拭ふばかりである。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿野郎め、と親方に大喝されて其儘にぐづりと坐り沈静く居るかと思へば、散かりし還原海苔の上に額おしつけ既｜鼾声なり。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "悟空また同じく本相を顕わし、大喝一声するよと見るまに、身の高さ一万丈、頭は泰山に似て眼は日月のごとく、口はあたかも血池にひとし。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "大喝一声、太鼓の皮の裂けた音して、「無礼もの！",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "曳くや竜の口、冴は一刀、死者の素頭刎ねざまに大喝してぞ立つたるは、げにおそろしき国つ胆、由々しくもまた勇ましし。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大喝迷霧を排ふは吾人の願ふ所にあらず、一点の導火となりて世の識者を動かさん事こそ、吾人が切に自ら任むところなれ。",
              "citation": {
                "source": "「平和」発行之辞",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "民友子大喝して曰く、「砂丘の上にベベルの高塔を築かんとするは誰ぞ」と。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし外形の生命を把り来つて観ずれば、地球広しと雖、五尺の躰躯大なりと雖、何すれぞ沙翁をして「天と地との間を蠕ひまはる我は果していかなるものぞ」と大喝せしめむ。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに門人中坐容を崩すものがあったのを見て、大喝して叱した。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……乱心……乱心召されたかッ……讐仇は讐仇……身共は身共……」　と助けてやりたい一心で大喝した。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても敵わぬと観念したらしく、平馬の大喝の下に息を切らしながら眼を閉じたが、又も思い切って見開くと、火のような瞳を閃めかした。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍の下役人左右より棒を構へ、声を揃へて大喝一声、「踏めい……踏み居らぬか」　と脅やかすに初花は忽ち顔色蒼白となりつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "診察中の医者の首筋を、例の剛力でギューと掴んで大喝した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御老体にコタえると不可ませんから……」「馬鹿ッ」　という大喝が下等待合室を、地雷火のように驚かした。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様の保険じゃけに、貴様が掛けるにきまっとるじゃないか」「……馬鹿ッ……帰れッ……」　青柳に大喝された水野は、上り口から飛降りて、下駄を提げたまま二三町無我夢中で走った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
