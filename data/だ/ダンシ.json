      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "boy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "謂はば男子一生の仕事となることは出来ない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男子が年と共に前額部の禿げ上るのは当り前の事で、少しも異とするに及ばぬけれど、大隅君のは、他の学友に較べて目立って進捗が早かった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　今ではどうだか知らないが、私の国では村の豪家などで男子が生まれると、その次の正月は村じゅうの若い者が寄って、四畳敷き六畳敷きの大きな凧をこしらえてその家にかつぎ込む。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ちやんと胸を張つて、おれは日本一の好男子で、さうして、最上級の風流人だといふやうな顏をして威張つて歩くのですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本一はおろか日本二も三も經驗せぬ作者が、そんな日本一の快男子を描寫できる筈が無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美男子といふものは、顏が小さくきちんとまとまつてゐるものである。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏の非常に大きい美男子といふのは、あまり實例が無いやうに思はれる。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり美男子ではなかつた。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女も男と同じように働き、学び、考える時代となり、尚上述の条件を男子側より否定されるならば、永遠に、女性の生命は内面の不平を堪えて男子を羨み続けるでありましょう。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考えでは婦人というものに天賦のある障害があって、男子と同じ期待の尺度を当てる訳にはいかないと思う。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の主人公なるが如く心得、家庭の事は、男子の片手間の事業かの如く考えて居るのが、今日家庭を説くものの理想らしいが、これが大間違の考と云わねばならぬ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは男子には関係のないだけに、街頭は街頭でも、何となくしめやかにしとやかに行われている。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで私達は街に出て、印度の花、欧風化された女の嬌態、近世のパーシ女に袖を引かれて茶店に出入するのですが、私達日本の男子で印度のフラッパ女に靴の紐など結ぶように命令されて、諾々としているような非国民は一人だっていないのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の男子じゃないか！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして男子の太い声と婦人の清く澄んだ声と相和して、肉声の一高一低が巧妙な楽器に導かれるのです、そして「たえなるめぐみ」とか「まことのちから」とか「愛の泉」とかいう言葉をもって織り出された幾節かの歌を聞きながら立っていますと、総身に、ある戦慄を覚えました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴いしは八歳ばかりの男子なり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "少佐がどうして彼を従卒にしたか、それは、彼がスタイルのいい、好男子であったからであった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人目は男子だったが、上の二人は女だった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の相貌骨格も其当人が自分で定めたものでありませぬから、先づ運命前定説が一半だけは是認せられる訳でして、何様も不美人に生れついては男子に愛されぬ勝で、醜夫に生れついては婦人の悦ぶところとならぬ勝ですから、鏡に対して憮然たる人も世に多い訳ですが、幸にして人間は牛や馬ではありません。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルシビアデスは非常の美男子で雄材の人ですが、其終を令くしては居りませぬ。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうものとしてこの映画がはたして成功したものであるかどうかを判断するのは、残念ながら自分などにはむずかしい、おそらくすべての男子にはむずかしいであろうと思われる。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公の「野性的好男子」もわれらのような旧時代のものにはどうもあまり好感の持てないタイプである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の両側に立っている二人の美男子に、見覚えがあるでしょう？",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはね、僕が美男子であるという理由からに違いない。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、真直を見て歩いていても、あの薄暗い隅に寝そべっている浮浪者の殆ど全部が、端正な顔立をした美男子ばかりだということを発見したんだ。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、美男子は地下道生活におちる可能性を多分に持っているということになる。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君なんか色が白くて美男子だから、危いぞ、気をつけ給え。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美男子の件はとに角、そのほかに何か発見出来ましたか。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの美男子たちは、酒に酔っているようにも見えなかったが、煙草だけはたいてい吸っていましたね。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき汽車はだんだんしづかになっていくつかのシグナルとてんてつ器の灯を過ぎ小さな停車場にとまりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
