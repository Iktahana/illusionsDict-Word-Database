[
  {
    "uuid": "38271ce1-f9e3-58ee-ad3f-d5b31d7269cc",
    "entry": "男子",
    "reading": {
      "primary": "だんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
