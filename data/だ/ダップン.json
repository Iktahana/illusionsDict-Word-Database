          "standard": [],
          "literary": [
            {
              "text": "水を更えてやると気持よさそうに、日を透けて着色する長い虹のような脱糞をした。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ナポレオンもまた、風邪をひき、乃木将軍もまた、閨を好み、クレオパトラもまた、脱糞せりとの事実、これこそは君等のいうリアルならむ。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌飯と酒│　飯のありがたさ└塩と味噌　　塩のよろしさ　満腹と脱糞　三月一日　曇。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……満腹と脱糞十月二日　曇。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなところに脱糞するのは犯人のほかには考えられない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "海中で脱糞したところが、クビの横へポッカリ浮いてきた。",
              "citation": {
                "source": "戦後新人論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此亦放尿喫飯脱糞之徒耳」藤本君は思わずくすりと笑った。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして水を飲み、餌を喰べ、脱糞をする。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "人魚はこうして貪婪にひかる眼つきをしてしきりに魚をとらえて食べましたが、ついに、巨大な昆布の林のなかにはいっていって、そこへ脱糞をこころみました。",
              "citation": {
                "source": "人魚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "昆布の林で脱糞したときの人魚ののうのうとした表情、あられもない女だてらの動作にすこしの羞恥をしめさない無智、それはわたしに一種のおそれをすらいだかせました。",
              "citation": {
                "source": "人魚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こうなったら、序じゃ）　脱糞することにした。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏庭に、脱糞があったとも報ぜられた。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
