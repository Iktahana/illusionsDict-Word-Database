          "literary": [
            {
              "text": "「歌へば天国」のスタッフ集まり、ダメ出しの会。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダメ出し、カットをして帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "編曲指揮の服部良一に会ってホテルでコーヒーのみ、二時半文ビルへ、本年度から始めたダメ出し会、出席随意としたら十何人か集った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダメ出しは明日といふことで、今夜は作者も来ず、ちっとも初日みたいでなし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台事務所で、宇野信夫、ダメ出し。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のダメ出しで、簑助の胸倉をとるところ、簑助も抵抗しろとあったので心配してたが、やっぱり力を出されるとこっちが参る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "就職もダメだし、試験もダメらしい。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
