    "definitions": [
      {
        "index": 1,
        "gloss": "great earthquake (disaster)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
