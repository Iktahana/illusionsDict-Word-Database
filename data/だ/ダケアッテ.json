    "definitions": [
      {
        "index": 1,
        "gloss": "as one would expect from ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
