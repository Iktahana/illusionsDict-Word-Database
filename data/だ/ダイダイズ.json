        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その衣で鰯を包んでバターなりサラダ油なり手製のヘットなりで揚げて一人前に二つ位ずつ橙酢でもかけて出します。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人前に二つずつ位生レモンか橙酢かあるいは柚でもかけて出しますとなかなか結構です。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べるとき、醤油のなかへ橙酢か姫｜柚子の一滴を落とせば、素晴らしく味が結構となるのだ。",
              "citation": {
                "source": "蜻蛉返り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "白焼きの橙酢、から揚げ、ふらい、椀種、味噌田楽。",
              "citation": {
                "source": "榛名湖の公魚釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋味が少ないから白焼きの橙酢、カラ揚げ、椀種、味噌田楽向きにこしらえてもおいしい。",
              "citation": {
                "source": "氷湖の公魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の鍋に、里芋の茎、ほうれん草を少々入れたすまし汁を作って置いて、それにゆでた猫肉を加え、再び火にかけて沸ったところを碗に分け、橙酢を落として味あったところ、これはひどく珍味であった。",
              "citation": {
                "source": "岡ふぐ談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　あれほど美味いという河豚も、もしあの刺身の黄橙酢に添える浅葱と、チリ鍋に入れるこれが冬の畑の物かと眼を醒ますような青々とした春菊がなければ、僕は箸を出す気になれまいと思う。",
              "citation": {
                "source": "河豚",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
