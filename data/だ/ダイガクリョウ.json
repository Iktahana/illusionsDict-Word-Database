        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "現に大学寮に支那人が来ておったのでありますから、そういうことはあったと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はては朱雀門、大極殿、大学寮、民部省まで移りて、一夜の程に塵灰となりにき。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして遂には朱雀門や大極殿、大学寮、民部省等の重要な建築を一夜の中に尽く灰塵としてしまった。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月二十七日（日曜）　モヤさん、京都へ先発（秀雄さんと一緒なり）　朝モヤ、女子大学寮舎の山原さん、丹野さん訪問、オーキ、理髪の後林町へ来た。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "比叡の権僧正である弟を除くと、兄弟親族はみなほとんど兵部に関係した職についていたが、泰文だけは異例で、若いころから数理にすぐれて、追々、大学寮の算博士も及ばないような算道の才をあらわした。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはよかったが、子供たちが大きくなり、上の三人の男の子を大学寮へ送らなければならない齢がすぎかけているのに、泰文はなにも言いださない。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の京の大学寮の古図を見ますと、その敷地の西北隅に一区画をなして、「余戸」と書いてあります。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれは大学寮ばかりでなく、大きな役所にはどこにもあったことでありましょう。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは各地に分散定住していたのみならず、京都の大きな官署内にも寓居して、雑工・駆使・掃除等に従事していたことは、大学寮の古図に余戸の一区が画されているのによって察せられる。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この語り伝えが、果してどれだけの価値があるかは知らぬが、大学寮に余戸があり、東寺に散所法師のあった様に、宮城にも古くから掃除担当の小法師なるものがあったらしい。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほうはよかったが、おいおい子供たちが大きくなり、上の三人を大学寮へ送らなければならぬ齢がすぎているのに泰文はなにも言いださない。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェイムス・マニング師、ウォーレンから移ってきたばかりの大学総長であり、プレスビテリア小路上の丘に建設中の校舎が落成するまでの間、一時的に新しいキング街の大学寮に住いしていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾麻呂　あるいはまた、その一人息子、文麻呂の出世を妨げんとて、大学寮内よりこれを追放し、より条件の悪い別曹、修学院などへと転校せしとめたる我等が仇敵は？",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "清原　大学寮学生、清原ノ秀臣。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "清原　（少々震え声で）……大学寮学生、清原ノ秀臣！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "清原　大学寮学生、清原ノ………文麻呂　お爺さん！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達までが石ノ上と同じように大学寮を追っぱらわれてしまうかもしれないんだぜ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "君んとこの家は代々大学寮の重職にある文章博士だ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学寮なんかでもみんなそう云ってるんだぜ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
