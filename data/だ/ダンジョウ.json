    },
    "definitions": [
      {
        "index": 1,
        "gloss": "judge (of the Imperial Prosecuting and Investigating Office)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "壱岐殿坂教会で海老名弾正の説教を聞いた。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京橋下の一流は御濠の鍛冶橋南より比丘尼橋紺屋橋を経て来り、京橋の東炭谷橋白魚橋の下に出で、こゝにて南は真福寺橋下より来る一水と会し、北は兜橋より弾正橋下を経来れる一水と会し、桜橋東にてまた南より来る小渠と会し、遂に中の橋稲荷橋下を過ぎてこゝに来れるなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "松永弾正でも織田信長でも、風流もなきにあらず、余裕もあった人であるから、皆｜茶讌を喜んだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月、歌舞伎座にて市川団蔵、一世一代の仁木弾正を演じ、好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前名を九蔵といい、佐倉宗吾、仁木弾正、実盛物語などをその当り役としたり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "六日、丁未、天霽、弾正大弼仲章朝臣の使者、京都より到来す、去月廿七日閑院遷幸、今夜即ち造営の賞を行はる、将軍家正二位に叙し給ふ、仍つて其除書を送り進ず。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは賢秀の心を攬る為に云ったのでは無く、其翌年鶴千代丸に元服をさせて、信長の弾正忠の忠の字に因み、忠三郎｜秀賦と名乗らせて、真に其言葉通り婿にしたのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大崎の大崎義隆の臣の里見隆景から事起って、隆景が義隆をして同じ大崎の巨族たる岩出山の城主氏家弾正を殺させんとしたので、弾正が片倉小十郎に因って政宗に援を請うたところから紛糾した大崎家の内訌が、伊達対大崎の戦となり、伊達が勝てば氏家弾正を手蔓にして大崎を呑んで終おうということになったのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅野弾正大弼長政は中々硬直で、場合によれば太閤殿下をも、狐に憑かれておわすなぞと罵ることもある程だが、平日は穏便なることが好きな、物分りの宜い人であるから、氏郷贔負では有るが政宗にも同情を吝む人では無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "松永｜弾正でも織田信長でも、風流も無きにあらず、余裕も有つた人で有るから、皆｜茶讌を喜んだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村不折氏、橋本邦助氏等が新芸術、綱島梁川氏海老名弾正氏等が新宗教でもまだまだ満足は出来ぬ。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上杉家は弾正大弼斉定、浅野家は安芸守斉賢の代である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "子之助の姉は外桜田堀通の上杉弾正大弼斉憲の奥に仕えていた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲の名将｜高坂弾正昌信の守る堅城の前後を会釈もなく通って、敵地深く侵入して妻女山に占拠したわけである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄、高坂弾正、飯富兵部、馬場民部、真田幸隆等に一万二千を率いしめて、妻女山の背面を襲わしめ、謙信が巣から飛び出す処を打とうと云うのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻女山に向った甲軍は、地理に明かな、高坂弾正が先導で、月の西山に没する頃には海津を発し倉科の山越しに妻女山へむかった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして田牧の北方附近にいたるや高坂弾正の急追をうけこれに応戦した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康（年三十四）は竹広村弾正山に、三郎信康（年十七）は草部村松尾大明神鎮座の山に布陣した。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田左馬助、小山田兵衛尉、跡部大炊助等も別の一手をもって、弾正台の家康を目指すけれど大勢は既に決した。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "上杉謙信の如きは、年二十三の時、朝廷から従四位下｜弾正少弼に叙任されると、朝恩の厚きに感激し、「我｜坐ながらにして、官爵を受く、是恐らくは人臣の大義に非ず。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖は細川高国の手に属して、強弓の名を得た島村｜弾正貴則である。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "享禄四年に高国が摂津国尼崎に敗れたとき、弾正は敵二人を両腋に挟んで海に飛び込んで死んだ。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾正の子市兵衛は河内の八隅家に仕えて一時八隅と称したが、竹内越を領することになって、竹内と改めた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰に帯びた刀は二尺四寸五分の正盛で、先祖島村弾正が尼崎で討死したとき、故郷に送った記念である。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十二年十月三十日東京角筈村において内村鑑三改版に附する序　この講演は明治二十七年、すなわち日清戦争のあった年、すなわち今より三十一年前、私がまだ三十三歳の壮年であったときに、海老名弾正君司会のもとに、箱根山上、蘆の湖の畔においてなしたものであります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十二年十月三十日東京角筈村において内　村　鑑　三　　　　　改版に附する序　この講演は明治二十七年、すなわち日清戦争のあった年、すなわち今より三十一年前、私がまだ三十三歳の壮年であったときに、海老名弾正君司会のもとに、箱根山上、蘆の湖の畔においてなしたものであります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑雨は佐々｜弾正と呼んで、「昨日弾正が来たよ、」などと能くいったもんだ。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の住居の跡は、梅迫から一キロほどの北の上杉町にあって今でも“だんじょう原”と呼ばれている。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
