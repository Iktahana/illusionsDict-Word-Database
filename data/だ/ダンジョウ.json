    "definitions": [
      {
        "index": 1,
        "gloss": "on a stage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「彼が壇上に立つと聴衆はもうすぐに彼の力を感ずる。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壇上の人が何かいう度に、向かって右の方と左の方の椅子の列から拍手をしたり、何か分らぬ事を云ってはやし立てる人がいた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壇上の人が下りると、上壇に椅子へ腰かけた人、これが議長だそうであるが、この人が何か一言二言述べると、左の方の議員席からいきなり一人立上がって大きな声でわめき立てた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、始めに出た極度の大声を出す人が壇上に立ってまた何事か述べはじめた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次尚も、Ｔ「演じまするは　これ北辰一刀流　名代の踊り手　此村大吉が得意の壇上」　拍子木をガチャガチャガチャ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人の顔だけ写ってしゃべるのよりも、たとえば仮り小屋の壇上に立っておおぜいの老幼男女に囲まれているほうがいかにもアメリカの大統領になっている。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし世界の広い学界の中にはまれに変わり種の人間もいて、流行の問題などには目もくれず、自分の思うままに裸の自然に対面して真なるものの探究に没頭する人もあるから、いつの日にかこれらの物理学圏外の物理現象が一躍して中央壇上に幅をきかすことがないとも限らないであろう。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二十年八月十五日正午に、私たちは兵舎の前の広場に整列させられて、そうして陛下みずからの御放送だという、ほとんど雑音に消されて何一つ聞きとれなかったラジオを聞かされ、そうして、それから、若い中尉がつかつかと壇上に駈けあがって、「聞いたか。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この講堂建設以来この壇上で発せられた人間の声の中で、これくらい珍しいものはなかったに相違ない。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来だれもあまり問題にしなかったような題目をつかまえ、あるいは従来行なわれなかった毛色の変わった研究方法を遂行しようとするものは、たいていだれからも相手にされないか、陰であるいはまともにばかにされるか、あるいは正面の壇上からしかられるにきまっている。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらくた壇上に張交ぜの二枚屏風、ずんどの銅の花瓶に、からびたコスモスを投込んで、新式な家庭を見せると、隣の同じ道具屋の亭主は、炬燵櫓に、ちょんと乗って、胡坐を小さく、風除けに、葛籠を押立てて、天窓から、その尻まですっぽりと安置に及んで、秘仏はどうだ、と達磨を極めて、寂寞として定に入る。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "須弥壇は四座あって、壇上には弥陀、観音、勢至の三尊、二天、六地蔵が安置され、壇の中は、真中に清衡、左に基衡、右に秀衡の棺が納まり、ここに、各｜一口の剣を抱き、鎮守府将軍の印を帯び、錦袍に包まれた、三つの屍がまだそのままに横わっているそうである。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校、毎年三月の修業式のときには必ず右総代として校長から賞品をいただくのであるが、その賞品を壇上の校長から手渡してもらおうと、壇の下から両手を差し出す。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と対談しても、壇上にて憂国の熱弁を振うにしても、また酒の店でひとりで酒を飲んでいる時でも、腕に覚えの無い男は、どこやら落ちつかず、いやらしい眼つきをして、人に不快の念を生じさせ、蔑視せられてしまうものです。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "講堂で催された新學期始業式の席上で、教頭が新任先生三人の紹介をした後、猫又先生は三人の最後に壇上に現れて、赤面しながら挨拶された。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、時には偶像としての自己を壇上に置いて私達を冷かに見降さうとする矯飾的態度さへ現した。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿下も白木の壇上の白木のあの卓子に、おん身を、そのお椅子を寛々と進めたもうたことであろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会壇上に立って満場の選良に対して、「本大臣は本日ここに諸君に見ゆる光栄を有する事を喜ぶ」　とか何とか音吐朗々とやっております。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人民保護の警官が人民を斬るとはなに事ぞ」　と大道演説壇上で男泣きに泣く人を民衆は神様として担ぎ上げます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "校庭に篝火をたき、夕闇の中で酒樽を抜いて、応援歌を呶鳴り、新しい応援団長は壇上に立つと、一高に負けるなと悲痛な演説をやって、心あるものは泣くのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、背の高い痩せた男が長い頭髪をかきむしりながらはいって来て、壇上に立った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――えー、そういう訳で、大変お待たせしまして、恐縮です」　その時給仕があわててはいって来て、壇上の男に何か耳打ちした。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は全部提出するまで根気よく待っていた壇上の試験係には随分気の毒な話だが、編輯長の方針では、採点する答案は最初に提出した十人だけと、あらかじめ決っているのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆記試験の時壇上で妙な演説をやった男だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴衆は盛んな拍手をあびせかけて幾度か彼を壇上に呼び上げた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壇上に巨燭十五｜枝を燃やしおきて、一章終るごとに一燭を滅す。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四章　インターネットが吹き込む電子本の命　小さなステージに上がり、話し始めて間もなく気づいたのは、壇上の私めがけて走る幾筋かの光る視線でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当に穴を抜け出して、人の世に帰ってきたんだな」　壇上で私は、あらためてそんなことを考えていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマーク・キャンター、富士通との提携を発表するに当たっては右手を握ってラッパを作り「トラタタッタタ〜」と壇上でイントロを入れて稀代のパフォーマーぶりを発揮。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第×回国際パンクラブ総会が開かれた、フランスからやつてきたクラブ員は、紙風船を手にして壇上に立つた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
