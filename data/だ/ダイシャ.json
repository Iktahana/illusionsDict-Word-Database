    "definitions": [
      {
        "index": 1,
        "gloss": "platform truck",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "青森から乗った寝台車の明け方近い夢に、地下室のような処でひどい地震を感じた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台車に自分をのせる方法について色々の議論があるように聞えた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついこの間通りかかった時病室の端にある斜面から寝台車が引き上げられ病室の窓から大勢の人が覗いた時の光景を思いだした。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "枠台車に三台のことだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の上り下りには赤帽が世話をする、車中では給仕が世話をする、食堂車がある、寝台車がある、宿屋の手代は停車場に出迎えて居る、と言ったような時世になったのですから、今の中等人士は昔時の御大名同様に人の手から手へ渡って行って、ひどく大切にされまするので、山も坂も有ったものじゃあ有りません。",
              "citation": {
                "source": "旅行の今昔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼処に置捨てた屋台車が、主を追うて自ら軋るかと、響が地を畝って、轟々と雷の音。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下寺町の坂の真中に台車を出し、エー冷やこうて甘い一杯五厘！",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日の午後マダムは寝台車で病院へ運ばれ、お気に入りの銀子もついて行ったのだったが、病室に落ち着いてからも、忙しい呼吸をするたびに、大きい鼻の穴が一層大きく拡がり、苦しそうであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　しかし銀子の生命の火はまだ消え果てず、二日ばかりすると、医師が動かしてはいけないというのを、彼女の希望どおり春よしの二階から担架でおろされ、寝台車で錦糸堀の家の二階へと移された。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　白にレモン色の模様をとった屋台車を置いてアイスクリーム売りのイタリー人が燕のひるがえるのを眺めていた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮い車掌は慄えあがって二等寝台車の中へ駈けこんだが、それと同時に列車がぐらぐらと大きく揺れた。",
              "citation": {
                "source": "隧道内の怪火",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の傲岸な顔は、やがて来た京都行きの省線に乗った銀造の瞼にいつまでも残り、銀造はおれも昔はあんな顔だったこともあると、東京で囲っていた貴子に会いに、大阪から寝台車に乗っていた時のことを想い出していた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台車で結んだ夢ももう夢になってしまった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "下関発上り一二等特急、富士号、二等寝台車の上段の帷をピッタリと鎖して、シャツに猿股一つのまま枕元の豆電燈を灯けた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は依然として東海道線の寝台車の中に睡っているのじゃないかしらん。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷やし飴も売り、夜泣きうどんの屋台車も引いた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ロンドンへ日帰りするその晩、我々は寝台車の一隅にいたが、その旅路はロス大佐にも私にも短く感じられたものだった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今夜立って帰京する……既に寝台車も調えた。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は蒲団のままで寝台車に乗せられ、阿佐ヶ谷の外科病院に運ばれた。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りの自動車屋の前へ来ると、尨大なその寝台車が路傍樹の片蔭に用意されてあつた。",
              "citation": {
                "source": "老苦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "大杉が仏蘭西から追返され、神戸へ帰着して出迎えの家族と一緒に一等寝台車で東上した記事が写真入りで新聞を賑わしてから間もなくだった。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸へ帰着してから出迎えの野枝や児供と共に一等寝台車で東京へ帰った汽車賃は大杉の自由行動を防止して同志から遮断する必要上官憲が支弁したのである。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘がびんを取り上げてみると、あいにくそれがからだったので、なにげなく屋台車のけこみを押しひらいて、中からたくわえの別なびんを取り出そうとしたそのとたん、ちらりと鋭く右門の目を射たものは、たしかにいま浅草の小屋で見て帰ったと同じ南蛮玉乗りの大きな黒い玉でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志の命令｜一下、三人は超特急で荷物をたたみ、警備員に電源を入れてもらい、エレヴェーターで一階におり、台車にレコーダーをのせて寮にもどった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかになんでも、台車にレコーダーをのせて、校舎への坂を駆けあがるなど、むりな話だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
