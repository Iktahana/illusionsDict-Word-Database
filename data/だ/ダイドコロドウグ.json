    "definitions": [
      {
        "index": 1,
        "gloss": "kitchen utensils",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
