[
  {
    "uuid": "2f5dad64-2e0e-51cb-b52e-3b13065144a7",
    "entry": "打鍵",
    "reading": {
      "primary": "だけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
