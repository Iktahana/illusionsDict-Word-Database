          "literary": [
            {
              "text": "愛し合うことは騙し合うことよりもよっぽど悲痛な騙し合いだ。",
              "citation": {
                "source": "おみな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせお互いに好く思われよう、好く思われようと意識して、上部の所作だけを人並に尽したところで、今さら始まらないんだから、いっそ下手に騙し合う手数を省いて、良心に背かない顔そのままで、面と向き合おうじゃないかという無言の相談が、多年の間にいつか成立してしまったのである。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、だましあうこともいらないのよ。",
              "citation": {
                "source": "箱の中のあなた",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
