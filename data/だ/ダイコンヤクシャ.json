        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「へえん、随分ご親切だけど、かえって親切が仇にもなるわよ」　と、お加代はしかし大根役者ではなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く、どうにも手の込んだ大馬鹿野郎・度しがたい大根役者だよ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根役者に過ぎた美しい容貌は、今日段々その芸に妥当性を持ちはじめて来たのである。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其為、やつぱり、偉大な大根役者の部に入らなければならなかつたのです。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "先代羽左衛門の閲歴を見ても、あれほど若い間大根役者呼はりをせられた人もなかつた。",
              "citation": {
                "source": "花の前花のあと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、悪声で調子の良かつた菊五郎もやはり、大根役者から、心の趣くまゝに、彼自身を自由に、芸にうち出す事が出来るやうになつた。",
              "citation": {
                "source": "花の前花のあと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣劇の俳優、レビューガール、どんな大部屋の大根役者でも大井広介にきけばたちどころに名前が分る。",
              "citation": {
                "source": "大井広介といふ男",
                "author": "――並びに註文ひとつの事――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この芝居を演ずる料理人が大根役者であって、名優でないからである。",
              "citation": {
                "source": "料理芝居",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根役者の芝居だからいけないのだ。",
              "citation": {
                "source": "料理芝居",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根役者の人気ばかりで湧きたってるパリー全市。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある名高い大根役者が来て、天国的なオルガン伴奏につれて、神秘なる譚歌をおごそかに吟じた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "名高い大根役者――著名な喜劇役者――は、ニーチェやカーライルに関して、深奥な思想を震え声で口ごもっていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな大根役者が演ずるのを見ても、やはり同じようにうれしがってるわ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、トリガーセンじゃないの」　トリガーセンがうわごとで、「大根役者だ、マダムは。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "分ったか、このネリマヤ（大根役者）」　俺は北海道へ逃げることにした。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのジョークは、すべて、エルヴィスがいかに大きなスターであるかを、寛容なファンの笑いによって彼ら自身の心に再確認させるために計算して書かれたシナリオの一部にすぎず、大根役者にもかかわらずエルヴィスは効果をあげ、ファンは、彼を許した。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
