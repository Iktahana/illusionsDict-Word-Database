    "definitions": [
      {
        "index": 1,
        "gloss": "poor piece of writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
