    },
    "definitions": [
      {
        "index": 1,
        "gloss": "general resemblance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "従つて各人各様の特質にも拘らず、可なり大同小異の観があることは脱れられない。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も伊東は特別にくだらぬ温泉であるが、他の熱海でも別府でも、温泉らしくない点では、伊東と大同小異であらう。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一筆示し上げ参らせ候大同口よりのお手紙ただいま到着仕り候｜母様大へん御よろこび涙を流してくり返しくり返しご覧相成り候」　何だつまらない！",
              "citation": {
                "source": "遺言",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大同小異で、何れも吉原再興に反対する宣言であつた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "参考のために市村座の入場料を掲げたるが、他も大同小異と知るべし。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海道名所記にも夜啼の松のことを書いてゐるが、これも名所図絵に記された由来記と大同小異である。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷者は直ちに北区大同病院にかつぎ込み加療中。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの議論によれば、人間のすることは結局大同小異五十歩百歩の紋切型で、赤、黄、青、紫、黒、白などの原色とその組み合わせがあるだけで、異色などというものはあり得ないということになる。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にはこの対照がなく、どれを見ても大同小異の階級者が、デモクラチックに均一して銀座通りを歩いている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉王榑もまた人の告ぐるところとなり、廃せられて庶人となり、代王｜桂もまた終に廃せられて庶人となり、大同に幽せらる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王は正月の酷寒に乗じて、蔚州を下し、大同を攻む。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛庸等、大同の守将｜房昭に檄し、兵を引いて紫荊関に入り、保定の諸県を略し、兵を易州の西水寨に駐め、険に拠りて持久の計を為し、北平を窺わしめんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此歳阿魯台大同に寇す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代の芸術家は、誰しも一度は、そんな姿と大同小異の影像を、こっそりあこがれた事がある。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「支那南北記」や「大同石佛寺」のうちに植物の事を顧慮することの出來たのは、洵に是人のお蔭である。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大同電力のダムで堰かれた河流は百八十尺の高さにその水深を増したというのだ。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大同ダムで堰き止められて、本来の懸崖の三分の一以上、二百｜仞も高く盛り上ったその水際には、すなわち現実における魚は緑樹の梢にのぼり巉岩は河底の暗処に没して幽明さらに分ちがたい。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正面こそ大同電力の白い白いダム堰堤である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの家ばかりでなく、周囲の家々もまず大同小異といった形で、しかも一方には山や森をひかえているのであるから、不用心とか物騒とかいうことは勿論であると思わなければならない。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて一方行長も七月半に大同江を渡って平壌を占領した。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "東は大同江だから完全な包囲攻撃である。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此夜、行長は諸将と会して進退を議したが、既に兵糧庫も焼れて居るし、鳳山からの援軍も来ない上は、一度京城へ退いて再挙するに如くはなしと決して、潜に城を出で大同江の氷を渡って京城へと落ち延びた。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり志を同じくする雄藩が、今までの種々の行きがかりを水に流して、この際大同団結し、同盟を結ぶことである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々「十三人」は大同団結をなして既成文壇を打倒さなければならない。",
              "citation": {
                "source": "貧しき文学的経験（文壇へ出るまで）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外近隣の人数人の申立あれども皆大同小異なりき。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　内縁　それより一、二カ月を経て、東京より重井ら大同団結遊説のため阪地を経て中国を遊説するとの報あり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右あらかじめお含み置きください」　　　白猿伝　梁（六朝）の大同の末年、平南将軍｜藺欽をつかわして南方を征討せしめた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯右の如きビルダデの態度、及びそれと大同小異なるエリパズ、ゾパルらの態度はいずれも排すべきである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に氏は『浴女』と同様に前田青邨氏の『大同石仏』が共に、同じやうな効果を挙げてゐるといつてゐる前田氏の作品に触れることは次に譲らう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "全日本國民ハ心ヲ冷カニシテ天ノ賞罰斯クノ如ク異ナル所以ノ根本ヨリ考察シテ、如何ニ大日本帝國ヲ改造スベキカノ大本ヲ確立シ、擧國一人ノ非議ナキ國論ヲ定メ、全日本國民ノ大同團結ヲ以テ終ニ天皇大權ノ發動ヲ奏請シ、天皇ヲ奉ジテ速カニ國家改造ノ根基ヲ完ウセザルベカラズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
