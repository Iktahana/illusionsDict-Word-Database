    "definitions": [
      {
        "index": 1,
        "gloss": "school of kowakamai dance founded by Yamamoto Sirozaemon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私いちど、しのび足、かれの寝所に滑り込んで神の冠、そっとこの大頭へ載せてみたことさえございます。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　そこで、小さい太郎は、大頭に麦わらぼうしをかむり、かぶと虫を糸のはしにぶらさげて、門口を出ていきました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治政府になツてからも、久しくお役人の大頭に加へられてゐて、頭は古いが馬鹿でなかツたので、一度は歐羅巴駐剳の公使になツたこともある。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　そこで小さい太郎は、大頭に麦稈帽子をかむり、かぶと虫を糸のはしにぶらさげて、かどぐちを出ていきました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　そこで小さい太郎は、大頭に麦わら帽子をかむり、かぶと虫を糸のはしにぶらさげて、かどぐちを出てゆきました。",
              "citation": {
                "source": "小さい太郎の悲しみ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちはじぶんじぶんの影を見て、ずいぶん大頭で、足が短いなあと思いました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父の故右大将だつて、頭でつかちなもんだから京都へ行つたとたんにもう、大頭将軍といふ有難くもないお名前を頂戴して、あんな下賤の和卿などにさへいい加減にあしらはれて贈り物をつつかへされたり、さんざん赤恥をかかされてゐるんだ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸幕府を直接｜覆したものは、創業の家康が極度に恐れた外様の雄藩、強藩ではなくて、志士と呼ばれる下級武士の活躍であり、大頭鯨を追つて来た船を保護するために、アメリカ政府が持ち込んだ強談判であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大頭なのに、小頭と言うのも……」「平三氏！",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立の隙間より、印旛の蛇の大頭より體の上部へかけてひろく見わたさる。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「為方がないですな」Ｋはかう言つたが、「これで満鉄の大頭達がよくやつて来るところなんですか？",
              "citation": {
                "source": "海をわたる",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の大頭株を見給へ、紳商面をして澄ましてやがるが、成立は悉皆僕等と仝じ事だ。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "此奴まだ卑怯な事は、俺の旦那が薩長の大頭と御懇意なのを承知して、首尾よく嬢様を掌中に丸め込んで旦那のお引立に預からうといふ野心があるのだ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの絵に共通の点は、こうした自然物に対する深い愛と、大きな瓜に小さな昆虫を配したところにあるが、軽い羽をもった赤蜻蛉も、反抗心に燃えている螳螂も、どっかりと横に寝そべったあの青瓜の大頭の前に出ては、何となく気圧されがちに見えるのもおもしろいと思った。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "導にたてる年嵩のてだれの象の全身は「時」が噛みてし、刻みてし老樹の幹のごと、ひわれ巨巌の如き大頭、脊骨の弓の太しきも、何の苦も無く自づから、滑らかにこそ動くなれ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "導にたてる年嵩のてだれの象の全身は「時」が噛みてし刻みてし、老樹の幹のごとひわれ巨巖の如き大頭、脊骨の弓の太しきも、何の苦も無く自づから、滑らかにこそ動くなれ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは、真夏の太陽が、すべてのものを焦灼し、熱悩しようとするのに対して、その第一の愛児であるこの大頭は、自分の持つてゐるものによつて、肝腎の真夏を冷却し去らうとする反抗児であるからだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "官吏、軍人、実業家の大頭の連中が、待合にゆくのが遊蕩であると考える俗人を睥睨して集合する築地の有名な待合×××を、この新聞の読者の何人が日常の接触で知っているであろうか、という質問によって。",
              "citation": {
                "source": "「大人の文学」論の現実性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの人々の日常が、ブルジョア的環境にありながら、実質は小市民的であって、謂われている大人（官吏、軍人、実業家）の大頭の世界の中に織込まれてはいない。",
              "citation": {
                "source": "「大人の文学」論の現実性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "堺がまさに半白ならんとするその大頭をふり立てて、先頭になって、一二、一二と歩調をとって行くさまは、それやずいぶん見ものだ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい一週間ほどまえ、なんとかスタインという倫敦財界の大頭――すでに何とかスタインである以上、それはつねに財界の黒幕にきまっている――が、海峡のうえで飛行機から落ちて、新聞と取引所をはじめロンドンぜんたいが大さわぎをしていたことを。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女のまわりでは、女達の白い大頭巾が彼方此方に揺れ、絶間ない話し声が漣のように拡った。",
              "citation": {
                "source": "顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、今湯気の立昇つてゐる台の処で、茶碗を抱へて、黒焦の大頭がゆつくりと、お湯を呑んでゐるのであつた。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、今湯気の立昇っている台の処で、茶碗を抱えて、黒焦の大頭がゆっくりと、お湯を呑んでいるのであった。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんのうぬぼれがいい加減でやまるように、その憎たらしい大頭のちょん切られるところを、ゆっくり拝見するとしましょうよ。",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体その二三人の大頭はどんな人間かねえ。",
              "citation": {
                "source": "食堂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゑり治は、ゑりえんと共に私の姉などのよく親しんだ店の一つで東都の半襟の大頭の一つである。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「引いた物は引いた物だい」と大頭が云ふ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに有る、何だつて、君と大頭とは同じ物だつて、よせ、馬鹿野郎！",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
