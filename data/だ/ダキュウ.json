[
  {
    "uuid": "573236e0-a744-55fc-9655-f45f0262a60f",
    "entry": "打球",
    "reading": {
      "primary": "だきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hitting (a ball with a bat, racket, golf club, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "馬に縁ある打球戯をポロというほかに、ホニホロらしい洋語を知らぬ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一には、ホームラン性の打球を追って、フェンスによじのぼった外野手が見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いかけっこをする一年坊主どもの甲高い叫びや、飛び板を踏みならす騒々しい音をぬって、遠い打球音がきこえてくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究すればするほど、勉強すればするほど釣りの道の深さが身にこたえ、野球の選手が打球に苦心していくうちに、一次スランプに陥るのと同じように、友釣りの技もどうにもこうにも自分の力では行なえ得ぬ日がくる。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "打球よりもウォーキングが目的のようにセカセカと忙しそうに先を急いでいる。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と文平が打球板を膝の上に載せて、『いや、非常に面白く拝聴ひました。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "文平は打球板を提げて出て行つた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石の庭球狂もさん／″＼に敗北して、軈て仲間の生徒と一緒に、打球板を捨てゝ退いた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時、幾組かに別れて見物した生徒の群は互ひに先を争つたが、中に一人、素早く打球板を拾つた少年があつた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "新平民の仙太と見て、他の生徒が其側へ馳寄つて、無理無体に手に持つ打球板を奪ひ取らうとする。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、羽織を脱ぎ捨てゝ、そこにある打球板を拾つたは丑松だ。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太の手から打球板を奪ひ取らうとした少年なぞは、手を拍つて、雀躍して、喜んだ。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフは今度打球というようになった。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフ・バッグを打球錬成袋といったらどうだと、皆で笑う。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "市中到るところに散在してゐた空地に、馬上打球の勝負が催され、また借馬を商売にするものがあつたのも、思返すと、その頃が最も盛な時であつたらしい。",
              "citation": {
                "source": "冬の夜がたり",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしディック・シスラーの、あの球場でのものすごい打球を思い出すと、フィラデルフィアも捨てがたいぞ」「あんなバッターは他にいないね。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "打球はグラウンダーになって、セカンドとファーストのあいだを抜けていった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は元の位置に帰るとすぐ、何事もなかった様に打球の遊戯を始めるのであった。",
              "citation": {
                "source": "灰神楽",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
