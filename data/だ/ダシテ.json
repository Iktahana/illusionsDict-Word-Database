[
  {
    "uuid": "702eafc1-6f1c-5d12-9108-8b386980722b",
    "entry": "出し手",
    "reading": {
      "primary": "だして",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
