    },
    "definitions": [
      {
        "index": 1,
        "gloss": "poor poem",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蕪村の駄句は十に二、三、と正岡子規が評した。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば小督局の廃跡を訪うて咏んだという句、うきふしや竹の子となる人の果　の如きも、理解のない鑑賞で見る限りは、単なる観念的の俳句であって、子規のいわゆる月並臭の駄句にしか感じられない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はなはだ拙劣でしかも連句の格式を全然無視したものではあるがただエキスペリメントの一つとして試みにここに若干の駄句を連ねてみる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」スルト側から水戸の川又子、俳号を五｜茶と申す、宗匠気取りで、　ああら天狗一夜の宿を貸し給えと駄句れば、「アーメン」と誰か混ぜ返した者がある。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきらかに駄句である。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿簑の凡兆の句には一つの駄句もない、すべて佳句である、と言っている人もあるが、そんな事は無い。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、駄句のほうが多い。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといふ、思はせぶりたつぷりの、月並な駄句であらう。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "常ならば東海道の五十三｜駅詩にもなるべき景色ならんに、柿色の筒袖に腰縄さえ付きて、巡査に護送せらるる身は、われながら興さめて、駄句だに出でず、剰え大阪より附き添い来りし巡査は皆｜草津にて交代となりければ、切めてもの顔｜馴染もなくなりて、憂きが中に三重県津市の監獄に着く。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "繪葉書を送るとて、裸男駄句りて曰く、來ぬ友を惜む梅見の日和かな　山を下れば、老樹最も繁き處に、掛茶屋あり。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "十口坊駄句りて曰く、次の馬車待つ山驛の秋しめり　裸男は傘をさゝぬつもりにて、ゴム引きのマントを被りたるが、古びたる事とて、雨漏る。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄句りて曰く、九端帆の風を孕むや行々子　女中來りて、『お誂へは』と問ふ。",
              "citation": {
                "source": "川魚料理",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄句を吐いて曰く、相傘や花の土手より停車場へ（大正五年）",
              "citation": {
                "source": "千川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番の汽車にて鎌倉に赴く道々うかみ出づる駄句の數々、岡あれば宮宮あれば梅の花家一つ梅五六本こゝも／＼旅なれば春なればこの朝ぼらけ　先づ由井が濱に隱士をおとづれて久々の對面うれしやと、とつおいつ語り出だす事は何ぞ。",
              "citation": {
                "source": "鎌倉一見の記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "沓の代はたられて百舌鳥の声悲し　　　馬の尾をたばねてくゝる薄かな　　　菅笠のそろふて動く芒かな　駄句積もるほどに峠までは来りたり。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、岡部司法大臣が來道して、人を茶化した樣な駄洒落歌を作りつつ、道中を巡視してゐるので、世間はその駄句や逸事の評判に急がしくなつてゐて、道中空前の大雜誌が出ることなどは思ひ出すものもなかつたのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七　辭令に巧みな壯語男爵後藤遞相を送り、駄句り屋子爵岡部法相を送つた北海道は、今また伊藤公爵と韓太子とを迎へた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "・暑さ、泣く子供泣くだけ泣かせてだから、駄句一つの一日でもあつた！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰朝匆々ある詩派『明星』といふ一雑誌が党同異閥の精神からか、露伴先生の『出廬』を攻撃した其翌月、私のやうなものにも喰つてかかり、謂れない悪罵を逞うした折も黙視して、たゞ在京の友へ『売りかねた喧嘩の花も江戸の春』と駄句つた位のものでした。",
              "citation": {
                "source": "漱石さんのロンドンにおけるエピソード",
                "author": "夏目夫人にまゐらす",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、後世とんだ駄句の一つに數へられる虞があるからである。",
              "citation": {
                "source": "荷風翁の發句",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目金之助　　　　　高浜清様　　　　　　○明治三十九年八月十一日（葉書）　拝啓　昨日の駄句「花嫁の馬で越ゆるや山桜」を、「花の頃を越えてかしこし馬に嫁」と致し候が御賛成下さい。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣るほかに飲むあてもある遠出組　戦争中、昔を思い出して駄句ったぼくの川柳である。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "この坊主なかなか弱くはないけれど、自分に対して白を持つほどの腕ではないと見て取ったのに、三目置いているから、兵馬にとっては楽なもの、入道はなかば頃からさんざんに苦しんで、とうとう降参してしまって苦い面をすると、金公が大よろこびで復讐の意味を兼ねた駄句を作ったりなどして嘲弄します。",
              "citation": {
                "source": "大菩薩峠",
                "author": "女子と小人の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いらざるおせつかいと云はれさうな駄句だ。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――非茶人と非茶人と爐に蜜柑喰ふ――そんな駄句を作つたりして興じるぐらゐが、せきのやまのお茶人である。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほむね、これに掛かツて、カラスの足痕のごとき文字やら駄句など、みじめに、とゞめざるはない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しら浪の足あと凄し朝の月借着して宿たつ朝や秋の風　そのときの駄句である。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "異見会　春行くや、の駄句にもならない風景だったが、東京都知事以下、全国の選挙ビラも、やっと方々で掃かれている。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、ぼくが作った駄句ですが“戦いやみぬ、藪うぐいすも、啼き出でよ”という句、まあそんな景色で、人がみんな吉野山へ花見に行ってました。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄句を呶鳴り終えると、彼等は手を三度叩いて、「裁判官」「狐」「狩人」の身振をする。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
