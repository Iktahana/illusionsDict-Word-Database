[
  {
    "uuid": "da3c72bd-4766-5006-929b-0cc17dd32f1d",
    "entry": "代言",
    "reading": {
      "primary": "だいげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
