    },
    "definitions": [
      {
        "index": 1,
        "gloss": "advocacy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "相続後の家政は大概、書記や執事や代言人に任せてあって、彼自身は大審院の役をつとめるだけであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば火の発明の記事は現に私の机上にある科学者の火に関する著書の内容そのままであり、言語の起源に関する考えは、近代言語学者中の最も非常識なる説よりも、もう少し要を得ている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百代言｜気質に煩わしいことを以て政宗を責めは仕無かった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一僕は今度のやうな事の起つた際に、花井だの何だのいふ三百代言共が、その辯護を引受けるのが可かんと思ふのだ。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "星氏は事業家としては堂々たる議長なり、而して民友社は彼を呼んで眇々たる一代言といへり。",
              "citation": {
                "source": "賤事業弁",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を以て見ても、文学を論ずるに事業を標率とするの非なるは解かるべきに、余が「事業といへる俗界の神」と言ひたる言葉の意味は、星氏を呼びて「眇々たる一代言」と言ひたる記者こそ、能く御存知なるべけれ。",
              "citation": {
                "source": "賤事業弁",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は品川大井大森方面を縄張にしている匪徒で、丹前は岡本と云う三百代言あがり、揉あげは松山と云って赤新聞の記者あがり、角刈は半ちゃんで通っている博徒であった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我に代言せしむるものは、天の祐を得たらん如し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "……内証で呼出したりなんかして、どんな三百代言が引搦まろうも知れないからね、此地は人気が悪いんだから。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はやゝ責任を感じて定価を訊ねると、近頃は安いのが出来てたしか一個三十銭位からあるさうだと平次が代言した。",
              "citation": {
                "source": "水車小屋の日誌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年に代って、彼が綿々の恨みを、代言してやる必要があるのだ！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、俺が引き受けたからには、よしツ、死力を尽すであらう、俺の言葉に万一虚偽があつたら即刻命を進呈するであらう――といふやうなことを唸りながら、さう云ふ見得を切るのが得意の小原田参四郎と称ふ三百代言人であつた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を飲まぬと彼は決して相手の顔を見ることなしに口のうちで何かぶつぶつと小言を呟いてゐる風な人物（それで代言人なのだ、事件に成功したことはないさうだが。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は若い時分から、すこぶる道楽に身を崩し、詐偽のための前科もある三百代言であった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷臣の膝を走れば平身低頭の夢となり、代言人の指を走れば忽ち謝金の夢となり、美人の唇を走れば忽ち接吻の夢となる。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年に代つて、彼が綿々の恨みを、代言してやる必要があるのだ！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は何処だったか記憶がないが、何でも何処かの地方で代言をして、芸者を女房にして贅沢な生活をしていて、今一人は内務省の属官でこそあれ、好い処を勤めている証拠には、曾て帰省した時の服装を見ると、地方では奏任官には大丈夫踏める素晴しい服装で、何しても金の時計をぶら垂げていたと云う。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の小父さんは厳しい立派な髯を生した人で、何度も何度も受けてはうまく行かなかった代言人の試験にもう一度応じて見ると言って、捨吉の机の前へ法律の書なぞを持って来たものだ。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、「貴方は丸で代言人の様な事を仰しやるのね」と云つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は金の融通の切迫した必要から銀行の組織に精通し、パリじゅうの高利貸と三百代言を知り、暫くではあるが公債のためにサン・ラザールの監獄へぶちこまれた。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ジェネヴで「泥棒にも三分の理」にさえならぬ図々しい屁理屈をこねている日本帝国主義の三百代言松岡洋右の提灯もちなどとともに、大衆を犠牲として恐慌を切りぬけようとする支配階級帝国主義戦争強行のチンドン屋の役を相つとめている。",
              "citation": {
                "source": "『キング』で得をするのは誰か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも猫でも子供でもなく、父の部下のような若い代言人たちだった。",
              "citation": {
                "source": "西洋の唐茄子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判官が代言人の父に「では、それだけの金をどうしてつくる。",
              "citation": {
                "source": "最初の外国保険詐欺",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼間守一という刑法学者、銀行家の須藤、代言人の高梨哲四郎――この人は長髪で騎馬へ乗り歩くので有名だった。",
              "citation": {
                "source": "最初の外国保険詐欺",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の代言人（弁護士）は長髪の人が多かったが、高梨は白皙美貌、長髪がよく似合った。",
              "citation": {
                "source": "最初の外国保険詐欺",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺が酒に酔って帰って来ると、ツベコベいやがって面倒くさいから、蔵ン中へ叩きこんで大戸を閉めちゃったら、阿母まで締めこんでしまって――」　父はそれがくせの、左の手でやぞうをきめて、新進的代言人らしくもなく、ならずもののような巻舌で言った。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸に生れて、志望を立てたのか、流行でなったのか知らないが、剣を学んだ壮士が、幕府の倒壊をよそに見、朝臣となり、転じて自由党に参加して野人となり、代言人となった彼は、自由民権といい、四民平等ということに、どんなにか血を湧かしたのであろう。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は十才にならない小耳にも、よく父が、「俺は六十になったら代言人（弁護士となっていたかもしれない）をよす。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことから法律を学び、増島博士をはじめ十二人の代言人が――後弁護士と改称――出来た最初の、その一人になった。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの人は公事師といって、訴訟がすきで――三百代言……」　アンポンタンは子供心にこう理解した。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
