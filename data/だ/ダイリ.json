[
  {
    "uuid": "e251b187-4356-5bdf-9dd7-d70f3923c4f3",
    "entry": "代理",
    "reading": {
      "primary": "だいり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
