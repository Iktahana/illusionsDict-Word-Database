    "definitions": [
      {
        "index": 1,
        "gloss": "consent or refusal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これをこの軒の主人に請わば、その諾否いまだ計りがたし。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、中央都市や地方の定期の会、その他の催しに於ける演能の諾否を決定し、曲目を撰み、出演者の役割りをきめる。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうなると慥な諾否はいへなくなる。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、それに対する諾否のお返事を、今晩しようと云うお約束をしたのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "諾否の空照りおもり、唖蝉は氣づかはしげに立ちすくむ日を、きしきしと木食蟲　樹の髓を食む。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の諾否が肝腎、吾等の意志は添物、女が諾く上は吾等の承諾は其取捨の外には出ませぬ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、それに対する諾否のお返事を、今晩しようと云ふお約束をしたのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだとか、そうでないとか、諾否の返答が、どこからか響く筈である。",
              "citation": {
                "source": "幻覚記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その諾否を、この二つで回答してくれと仰言って……」と彼女は語尾を萎めて、あまりにも慌ただしい、人生の変転を悲しむごとくであった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、斉彬は、なかなか、何用か、と自分からいい出さないで、ちゃんと、その用を自分が先廻りに云って、それからいろいろの知識、故事を語って、ようよう伺候者が、彼等の語ろうとして来た用件をいうと、斉彬は一言で、その諾否を決した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "設計に対する詳細妥当な見積り書によって、その審議によって役所側の諾否は決せられるのであったから。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アア考えてみれば御両親の諾否が僕の運命の岐るる所。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "諾否いづれを答ふべきか、長時間にわたつて全然返答のいと口もつかめないのだ。",
              "citation": {
                "source": "破門",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝見に会見の諾否を伝えようと思っている間に、入口の扉を乱暴に開くと、笛吹川画伯がぬからぬ顔を真正面に向けて入って来ました。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "刻下の形勢に縁遠い昔の話に偏執したり、先方に諾否の返答をする隙がないほどせきこんでゐたりする。",
              "citation": {
                "source": "お喋り競争",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども諾否の御返事だけは承る権利があるだらうと思ふのです。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、諾否の御返事は、承らねばならないのです。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんその晩Ｔには諾否を与えず、黙々としてそのまま私は花月の楽屋をあとにすると、翌日、私は天王寺に桂三木助氏を訪れて、一切を話し、身の振り方を相談した。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は洋行中でしたから、帰った後にと両親は思っていましたのを、次兄の篤次郎と相談して、独逸へ電報で諾否を問合せて、ずんずん事を運んでおしまいになったのです。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は母と妻との申出に対して、諾否の返答が与えられなかった。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は諾否の返答を与えなかった。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒泉空庵氏手紙にて尾上菊五郎余が新作舞踊一幕是非とも所望の由、至急諾否の返事きゝたしと云。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども細君の諾否だけですぐ決定されべき性質のものではなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分は自分と同じ径路を踏んで行かなければならない、またひょっとしたら自分よりもっと予期に外れた未来に突き当らなければならないこの処女の運命は、叔父の手にある諾否の賽が、畳の上に転がり次第、今明日中にでも、永久に片づけられてしまうのであった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝になって、腹の痛みも御蔭でとれてありがたいと、出立する十五分前に御夏さんを呼んで、昨日申し込んだ結婚事件の諾否を尋ねると、御夏さんは笑いながら静岡には水瓜もあります、御医者もありますが一夜作りの御嫁はありませんよと出て行ったきり顔を見せなかったそうだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人権がある以前に、人間には、当人の諾否なく、その人権を附与するという人権無視がある。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はにかむ年ではなし、話題は芸術的方面にあるし、何かと話したのち私は先方のためゆっくり考えてから諾否をきめるようにいって別れた。",
              "citation": {
                "source": "結婚",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――宗治の心はすでに諾否の先へ超えているのであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "諾否は、もちろん御意にあること。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――病床の長可までが、御諾否のほど、心配いたして、ただ今も、紀伊を通じて、伺いに来ておるような熱心さ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
