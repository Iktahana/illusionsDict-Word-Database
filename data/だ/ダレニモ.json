[
  {
    "uuid": "704fa963-72c2-577a-9620-d22a4a0765f0",
    "entry": "誰にも",
    "reading": {
      "primary": "だれにも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
