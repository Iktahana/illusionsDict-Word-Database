    "definitions": [
      {
        "index": 1,
        "gloss": "leading party (e.g. in parliament)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
