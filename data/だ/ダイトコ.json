[
  {
    "uuid": "52e1724f-7b4e-59da-aa13-c12f1c68038c",
    "entry": "大徳",
    "reading": {
      "primary": "だいとこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
