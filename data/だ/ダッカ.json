    },
    "definitions": [
      {
        "index": 1,
        "gloss": "is it?",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのうちのどれだっかた東京の名妓の写真が一枚ずつ紙函に入れてあって、ぽん太とかおつまとかいう名前が田舎の中学生の間にも広く宣伝された。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」　亀吉はひょいと黒い首をひっこめて、もじもじしていたが、やがて思い切って、「――わてだっか。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、へ、へ、……」　と、亀吉は奇妙な笑いを笑って、「――ほんまだっか」　嘗めるような視線で、小沢の眼を嘗め廻した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、あの掏摸さんだっか」　と、次郎と三郎は、昼間ハナヤで豹吉を兄貴と呼んでいたことを、想い出した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "用事だっか」　と、次郎はませた口を利いた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当だっかいな」　今晩女郎買いに行く事に決めていた春松はその事を一寸念頭においていった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速やが、他あやん、その子うちへ呉れへんか」「ほんまだっかいな」「嘘言うもんか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに他あやん、あんたその子｜背負ろうて俥ひく気イだっか」「ほな、こいで失礼さしてもらいま。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "表へ出ると、丁度使いから帰って来た滅法背の高いそこの小僧に、何んぞ用だっかと問われ、いきなり風呂銭にもっていた一銭銅貨を投げ出し、ものも云わずに蜜柑を一つ掴んで逃げ出した。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "表へ出ると、丁度使いから帰って来た滅法背の高いそこの小僧に、何んぞ用だっかと問われ、いきなり風呂銭にもっていた一銭銅貨を投げ出し、ものも言わずに蜜柑を一つ掴んで逃げ出した。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにボーイがいて「なんぞ用だっか」とじろりと見られた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえこないだっから、おじさんが好きだといったな」「ええ、大すきよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだっから仕掛けて居たものが「つまずい」て仕舞ったのでその事を思うと眉が一人手に寄って気がイライラして来る。",
              "citation": {
                "source": "秋風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「華族はんて、あんなもんだっかいな。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　ミサ子は、微かに顔を赧らめながら、「私、生意気みたいだけど、実はそんなようなことも考えてはいたのよ、こないだっから。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸絵になりそうな様子の女だとこないだっから思ってる。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親達はこないだっから問題になって居る玉川の地所の事や、持主のあこぎな事やら仲に立って居る男の半間な事やらを笑い合って居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもないことですよ」「ははア燐寸と鉄道時間表の常識とが種だっか」と警官は大真面目に感心して、「すると東京が暖いとか、雨が降っていたというのは――」「あれは、上原君なんかの靴を見たんです。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにいまへんか」「ああ池谷はんだっか。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき帳場で貰った西洋封筒に入った手紙のことだが、あれは誰が持ってきたのかネ」「あああの手紙だっか。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの殺人魔の蠅男だっか。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの御用だっか」「なんの用でも、かまへんやないか。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村荘六はんに大至急｜接いどくなはれ」「ええ、帆村はんだっか。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんや思うたら、もう帆村はんと休戦条約だっか。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいで何どすか、切開でもした様だっか。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……筍はお好きだっか。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おビールだっか」　娘がスタンドの方へゆく。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはちっとも気は狂れておりやしまへんで、ただ世間並にしておりますのじゃ」「世間並って、女郎屋するのが世間並だっか？",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
