    "definitions": [
      {
        "index": 1,
        "gloss": "to hold in one's arms",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下屋の水窓へ、折から横づけの船から、穴子、ぎんばうの畚、鰈、あいなめの鮹盤臺を、掬ふ、上げる、それ抱き込む、大鯛の溌剌たるが、（大盤臺）から飛び上つた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞおかまいなく、お引き取りを、と言うまでもなし……ついと尻を見せて、すたすたと廊下を行くのを、継児のような目つきで見ながら、抱き込むばかりに蓋を取ると、なるほど、二ぜんもり込みだけに汁がぽっちり、饂飩は白く乾いていた。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼はテーブルの外に両肘を立ててソフトの外から頭を抱き込むようにした。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを一寸甞めて、大きな秘密のように業々しく胸へ抱き込むと、私は又娘の家へ近寄った。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "米吉はお房の縁で鮎川を抱き込む、つづいて増田を味方に引き入れる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮子は片脇にクションを抱き込むと、突然大きな声で笑い出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤星め、とうとあの贋物を抱き込むだて。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は九重の首を抱き込むようにして、彼女の耳に何事をかささやいた。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬太郎はそのひまに例の洋杖を傘入から抽き取ったなり、抱き込むように羽織の下へ入れて、主人の座に帰らないうちにそっと表へ出た。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三回のマタドルは昨日のオルテガで、例のメフィスト的な爛々たる凄い目を剥いて荒れ狂う猛牛を抱き込むようにして剣を突き刺すと、その剣は文字通り鍔もとまで刺さり、瞬間に黒い巨体は横倒れになった。",
              "citation": {
                "source": "闘牛",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれが一旅人たる私を知らず識らず抱き込むのだとすれば、祖先を異にする国民と国民との交りも、かういふ共感の上に立たなければ、ほんたうの親善に進み得ないのではないかと思はれます。",
              "citation": {
                "source": "国防と文化",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供をも大人をも本能的に抱き込む、鳥黐のような粘り気のある力だった。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪田が尽きると槭や岳樺の薄暗い木立が待ち構えていたように私達を抱き込む。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は母で、両腕でしっかり自分の胸を抱き込むようにしながら、じっと前方を見据えて動かない。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒に酔わせるよりは、踊りに酔わせて、夢心地のうちに人を抱き込むところなんぞは、伊勢古市でやっているような仕組みだが、あんなにされると、アラが知れない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネクタイと半端な靴下を窓框に詰め、煙たい火を抱き込むようにして暖を取った。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、甲府で早急に挙兵し、その動揺に乗じて諸侯を抱き込む策を立てたらしいこと。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕をまわして、しっかりと」　両腕に江利子を抱き込むと、彼女の骨格の良さを彼ははっきりと感じた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "反射が治まってようやく、彼は直子を自分の体の下に抱き込むことが出来るようになった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――にもかかわらず、彼が用いられたり、使者として選ばれる時は、対蜀外交の策謀とか、関羽を味方へ抱き込む工作とか、どっちにしても、間接に肉親へ弓を引くような苦しいそして至難な役目をいいつかる場合にのみ限られていた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この公卿はおれを抱き込む気でいるな。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "白くまは、人が近づくと、後足で立ちあがって、前足をひろげて、とびかかって人間をだきこむというから、こっちの方が先に、投縄をくまの首にひっかけるのだ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
