    "definitions": [
      {
        "index": 1,
        "gloss": "street performer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの大道芸人が群衆の前にその醜い髯面をさらすように！",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家というものの立場より言うならば第一の種類の人は最も敬うべき純粋な芸術家であり、第二の種類の人は、芸術家としては、いわゆる素人芸術家をもって目さるべきものであり、第三の種類の人は悪い意味の大道芸人とえらぶ所がない人である。",
              "citation": {
                "source": "広津氏に答う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大道芸人の笙を吹くもの、蛇皮線をひく者、四つ竹を鳴らす者なども集まっている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "食うといっても、酒と一緒に呑むのだそうですが、なにしろ変った人間で、蛇食い又は蛇使いの大道芸人となって諸国を渡りあるいた末に、予章という所に足をとどめて、やはり蛇を使いながら十年あまりも暮らしていました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前が、髷を切って、大道芸人になっているのたあ、ちっとばかしちがうんだ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時目立って美しい娘が供の女中を一人連れ仲見世の方からやって来たが、大道芸人の顔を見るとにわかに足を急がせた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様子が変だったので、大道芸人は眼をそばめた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあさあ太夫さん一踊り、ご苦労ながら一踊り……※男達ならこの釜無の流れ来る水止めて見ろ……ヨイサッサ、ヨイサッサ」　大道芸人が唄い出し、鼬が立っておどりだした。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君子は旅の大道芸人の稼業が決して好きではなかった。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この見物の心理を逆に利用するのが、つまり大道芸人である。",
              "citation": {
                "source": "ロツパの「楽天公子」",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　鐘撞堂新道に巣を食う大道芸人の一群。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ大道芸人のうちでも、丹波の国から生捕りました荒熊の如き無芸で殺風景なものはない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大道芸人、一と口に乞食芸人と呼ばれる下民にして此丈けの芸達者があり、尚且此丈けの風流人があつた。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸の上なる水茶屋には赤き塗盆手にして佇立む茶汲の娘もろとも、床几に憩ふ人々面白げに大道芸人が子供集めて長き竹竿の先に盥廻しゐるさまを打眺めたり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "また乞胸の名を以て呼ばれた大道芸人、縁日芸人、或いは猿引すなわち猿舞わしの如く、町家に住居して遊芸の生活をするものは、また非人小屋、非人溜りにいる非人とは別であった。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "乞胸と呼ばれた大道芸人の仲間も今では立派な街上芸術家である。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ北辰一刀流手裏剣用の五寸釘だ」　　　　急拵えの大道芸人　周作は優しく微笑した。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋台店もあれば小料理屋もあり、大道芸人などもいたらしい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "純然たる支那市場であって、昼は大道芸人などが出ていろいろの芸当をやり、むせ返る程に人出がし、雑沓するということであったが、夜の此処は、恰度東京に於ける玉ノ井のような最下等の支那娼婦の張店街を現出していた。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪々の身で、この大道芸人――芸人の身で被りものは恐れ入るが、これも侍のつまらねえ見得と、まず、この頭巾だけは許してもらいたい。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、　｜並木通りにはティモフェー・ティモフェーヴィッチという熊をつれた大道芸人がいた。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで脚下の浜辺にちらばつてならんでいる大道芸人の群れがいくらそつちを見上げても喝采してもらえなかつた。",
              "citation": {
                "source": "青君の追跡",
                "author": "THE PURSUIT OF MR. BLUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも、ここ伊丹城内の獄中にある主君を救出するために、馬子となり旅商人となり、仲間者となり大道芸人となりなどして、あらゆる苦心のもとに、身なり貌かたちまで変えている人たちであった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "住民はカンカン虫、お茶場女、ナンキン墓の墓番、大道芸人、チーハーの運送屋（シナ風の富籤）、屠殺場のアンチャン、夜蕎麦売り、といったような有職無職の人々である。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は大道芸人特有のかん高い、とはいえかなり感じのいい力のある声で、小店のなかから二カペイカ投げてくれるのを待ちながら、小唄をうたっていた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は大道芸人の歌が好きですか？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は好きですよ」とラスコーリニコフは続けたが、それはまるで大道芸人の事を話してるのではないような調子だった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際レベジャートニコフの話した通り、子供たちに大道芸人風のいでたちをさせようという試みもあったのである。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今は、父殺し・火つけ・大道芸人・馬丁となり下ったから、それなりにお前を憎むのだ」といった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "繁華街であって、劇場、キャバレー、カフェ、そして大道芸人などで賑わっていた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
