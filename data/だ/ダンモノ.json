        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで十段物がとゞこほりなく纒まるのだ。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "また能は大概一日に五番と極まつて居るが近松あたりの作に五段物が多いのは能の五番から来たのではあるまいか。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄瑠璃は既に西京で味を覚えていたし、この丸本は一段物と違い、筋も充分分る所から、いよいよ興味をもって読初めた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段とり出して見ると、一幕物としての綜合のよく出来た、段物浄瑠璃が、よくあるものである。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼好法師跡おひ、一段物にて御座候故、後より出し申候」とある。",
              "citation": {
                "source": "由良助の成立",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の受答えとしても短過ぎるこの一句を彼女に与えたぎりで、彼は別段物足りなさを感じ得なかった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子づいて声が大きくなる、唄は段物の一部分）馬鹿だね、エヘヘヘヘヘ。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、しばらくそうしていても、別段物音も聞えません。",
              "citation": {
                "source": "湖畔亭事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "女にだんだんもの心がつき、比較によって自分と他とを評価する力が生れて、福慈岳の評判を聞いてみると、その秀でさ加減はあまりにも自分の資格とはかけ離れたものであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそのうち将軍は、だんだんものを食はなくなつてせつかくじぶんで播いたりした、粟も一口たべただけ、水をがぶがぶ呑んでゐた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり具合がいいものだから、だんだんものぐさくなって、どちらへも失礼していたというわけだが、借金ばかり殖えてね」　借金？",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにだんだんものうくなった。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "村上さんはだんだんものをいわぬようになり、毎日一度、海の水を汲んでマンデーをするにも、ビクビクせねばならぬようになりました。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄ばしごを二十だんものぼると、あたまがつかえて、もう、すすめなくなりました。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっとこちらを見ている青く光る目が、だんだんものすごくなってくるのです。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
