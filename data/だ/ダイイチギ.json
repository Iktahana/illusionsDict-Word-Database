  {
    "uuid": "5a088046-3333-5cc6-be57-0ce33628b744",
    "entry": "第一義",
    "reading": {
      "primary": "だいいちぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
