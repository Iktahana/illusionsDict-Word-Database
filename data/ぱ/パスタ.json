          "literary": [
            {
              "text": "パスタノフカ〔演出〕大したものでないし、感心せず。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの方は犯人がつかまってアクト〔書類〕をパスタービチ〔提起する〕したからいいんだけれども。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの写真を撮った日には、美代子は蟹の身を使ったパスタを作ってくれたの」　そこまで語って玲子は日比谷を見た。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごく当然なことのように、ほんとになにげなく、美代子は蟹の身を使ったパスタを作ってくれたのよ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来たパスタをふたりで食べました。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから作りますけれど、美代子が作ったようには作れないわ」「美代子さんは蟹の身を使ったパスタだけを、食べると涙が出るほどにおいしく作れて、あとはいっさい作れない、というわけはないですね」　笑いながら玲子はふたたび首を振った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、パン屋の戸口で自殺する人がいたかと思えば、ある人達は冷静に食料品店に行きイタリアのパスタを求めた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "誓ってもいい、私はイタリアからオデッサにパスタを動かす積りだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "オデッサでパスタを作るんだ」「これを飲んで下さい」ウージェーヌは瀕死の老人を左腕に抱えて起こしながら言って、もう一方の手で煎じ薬がいっぱいに入ったコップを引き寄せた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
