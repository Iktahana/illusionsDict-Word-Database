        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "云いつけると、外交部から交付される筈の、外国へのパスポートまで、ちゃんと、印まで間違いのない印を捺して拵えてきた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、日本でパスポートがおりない者でも、ここで、支那人に化けて、支那の名前をつけさえすれば、陳の手でロシヤへのだって作ることができた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐会で腹をかかえて哄笑するのもキュラソのビンで自分の肖像のどてっ腹に穴をあけるのも、工場と富とを投げ出してギャングの前にたたきつけるのもみんな自由へのパスポートである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きるものの証である生命のパスポートの最終ページには、地獄行きか天国かは知らないが、ともかくもあの世行きの出国スタンプがあらかじめ押してある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――パスポートを持って歩いてたのか？",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を税関に運んで、調べて貰ふ間にパスポートにスタンプを押して貰ひました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パスポートを調べられるのは勿論ですし、所持金まで聞かれました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海は、租界なるものがあるために、パスポートなくして上陸出来る恐らくは世界で唯一の海港であろう。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "海からはパスポートなしに上陸されるが、上海の上空は一層無防禦で各種のラジオ放送が自由に流れこんでくる。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "パスポートに判を捺すのとはどつちが楽だ？",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、宿の主人やってきて、パスポートを渡しいろんなことを喋った。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーニングラードへ独り出て銀行、パスポートその他やってかえって来る。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "食後、Ｙパスポートの為に大使館へ行く。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十五日（月）　パスポート出国許可が出来て居ないと駄目というので、Ｙ、ВОКС へ出かける。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の間切符しらべパスポートしらべその他おちおちねて居る暇もなかった。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○アオムスでパスポートの後からシールをこわして居住証をはがされたときの感じ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルロッタ　（思案のていで）わたし、正式のパスポートがないもので、自分が幾つなのか知らないの。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業免状は、いはば、入国困難な国へ足を踏み入れる、パスポートでしかないんです」「講義をはじめる」　と、守屋教授は、静かに、ノートのペーヂを繰つた。",
              "citation": {
                "source": "計算は計算",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "広大号を選んだ理由は、中国船に乗れば苦力同様パスポートがいらないし、第一船賃がうんと安かったからだ。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伸子、きのうパスポート（旅券）の査証をし直しに行ったのかい？",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に、作品に描いてある諸事実が事実としてプロバブルなパスポートを持っているだけにとどまっていて、それらの客観的な実在についてまったく疑いを※しはさむ余地が起り得ないほどに煮つまったものでないことである。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう音楽の持つパスポートの刻印は、深い人間愛と平和への祈願であり、第九交響曲合唱の精神である。",
              "citation": {
                "source": "望ましい音楽",
                "author": "信時潔",
                "note": "青空文庫"
              }
            },
            {
              "text": "節子のパスポートに使う写真も島村が撮った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
