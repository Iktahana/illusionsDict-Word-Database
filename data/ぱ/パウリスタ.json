    "definitions": [
      {
        "index": 1,
        "gloss": "coffee shop specializing in Brazilian coffee",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
