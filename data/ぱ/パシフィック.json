        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（あゝ、その大きな海はパシフィックといふのではなかったらうか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ああ、その大きな海はパシフィックというのではなかったろうか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米だってパシフィック辺のように殻もないし十倍も大きくて匂もいいのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米だってパシフィック辺のように殻もないし十｜倍も大きくてにおいもいいのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの大速力のために、船体はパシフィックラインのエムロシアが、全速を出した時のような、自震動をブルブルと感じながら飛んで行くのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一三年再版、エノックの『太平洋の秘密』（ゼ・セクレット・オブ・ゼ・パシフィック）一三一頁に記された、南メキシコのマヤ人の故趾に見る羽被った蛇も、能く飛ぶという表示であろう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日、リバプール出航の約なるパシフィック会社汽船オルコマ号は、ストライキのために延期の報を得たれば、当時漫遊中の阪谷男爵をハイドパーク・ホテルに訪う。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時に至り埠頭にて滝波氏と相わかれ、パシフィック会社汽船オリサ号（五千三百五十九トン）に移り、六時抜錨して南進に就く。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこっちでも、パシフィック・パクト（太平洋協約）というようなものを造って、カナダ、アメリカ、濠州などのような太平洋を囲む諸国と連繋を密にして対抗しなくてはと思うのですがね。",
              "citation": {
                "source": "私は隠居ではない",
                "author": "吉田茂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『クラッシュ　イン　パシフィック』は地方の支店をきいてくれるそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに出港直前のパシフィック丸に乗船したのは英国の一流劇場と契約を結ぶためであった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーボー嬢に慰めの言葉をかけてやろうと、パシフィック丸に乗り込んだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギルマンが乗船している時、パシフィック丸が出港した。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "パシフィック丸到着時、乗客たちは全てを知った。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの有名なアメリカ美人で、数日前にパシフィック丸から消えた女性です。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かがコルテス嬢の名前で、パシフィック丸の船室を予約し、手荷物を運びこんだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パシフィック二三一」は機関車の力強い構成と動きを音楽で描いたという、オネッガーの代表作だ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ガ東大経済学部ヲ卒業シテパシフィック・プラスチック工業株式会社ニ入社シタコトハ知ッテイル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホノルルという雑誌の前身がパラダイス・オヴ・ザ・パシフィックでしたから、四つの基本語はどれもみな、ハワイで雑誌のタイトルになったのです」「四つの基本語、というところが面白いのね。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
