[
  {
    "uuid": "cdc6ea27-38f2-5ac9-964f-c7cb41957818",
    "entry": "パソコン",
    "reading": {
      "primary": "パソコン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
