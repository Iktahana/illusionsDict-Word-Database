    "definitions": [
      {
        "index": 1,
        "gloss": "park (public, amusement, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "テレフンケン・システムの大きな蛇のようなスパークがキュンキュンと音を立ててひらめいては消えるのを見た。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、私が思い浮べたのは、北米ポートランド市の、シチイ・パークから遠望した、フッド火山の、においこぼるる白無垢小袖の、ろうたけた姿であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心はスパークのやうに、一瞬間青白い光を放ち、熱を持つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "間近い城東電車のポールが電力線にスパークする光なのだが、小初は眺めているうちに――そうさ、自分に関係のない歓楽ならさっさと一｜閃きに滅びてしまうがいい、と思った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓のカーテンがひらいて眼下にヒビヤ・パークと警視庁の鉄筋の骨組が朝の太陽のもとに赤光をうけて眼ざめた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スパークのようなトランジェントな現象である。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――燈火を赤く反映している夜空も、そのなかにときどき写る青いスパークも。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "放電間隙と電位差と全荷電とが同じならばすべてのスパークは同じとして数えられた。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また大地震で家がつぶれ、道路が裂けて水道が噴出したり、切断した電線が盛んにショートしてスパークするという見ていて非常に危険な光景を映し出して、その中で電話工夫を活躍させている。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでたとえば軽い意味の助演者としてのスパークスなどという役者でも決してただのむだな点景人物ではなくて、言わば個性シンフォニーの中の重要な一楽器としての役目を充分に果たしているようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかおおぜいで先生を引っぱって浅草へ行ってルナパークのメリーゴーラウンドに乗せたこともあったが、いかにも迷惑そうではあったが若い者の言うなりになって木馬にのっかってぐるぐる回っていた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、あとには二千五百｜米突を示す高度計と、不思議なほど静かなプロペラの唸りと、何ともいえず好調子なスパークの霊感だけが残っていた。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……好調子なスパークの霊感……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……好調子なスパーク……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一つ他の別の意味は、集中の詩「青猫」にも現れてる如く、都會の空に映る電線の青白いスパークを、大きな青猫のイメーヂに見てゐるので、當時田舍にゐて詩を書いてた私が、都會への切ない郷愁を表象してゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイド・パークの青芝の広場に幾筋もの汗ばんだ行進隊が吸ひ寄せられて行く。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイドパークの青芝を踏まへて六つの演壇が出来てゐる。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はハイドパークの真向ひ大理石門地下鉄ステーションへ終電車近く駈けつけた。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十三年七月　　道化ものふうらりふらりと出て来るはルナアパークの道化もの、服は白茶のだぶだぶと戯け澄ました身のまわり、あつち向いちやふうらふら、こつち向いちやふうらふら、緋房のついた尖がり帽子がしをらしや。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "靄に点くイルミネーシヨン、高架線、すれちがふ省線電車、ああ、スパーク、師走月、風も吹く、風も吹くなり。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この無良心、無恥な、唯物功利道徳の世界は到る処に探偵趣味のスパークが生む、新しい芸術のオゾン臭が、生々しく蒸れ返っている筈だ。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "推理と抒景と並行する時、スルリと抒景と一致する時、本格物の痛快味が、忽然スパークを放射して、たまらなく爽快なオゾン臭を放つ。",
              "citation": {
                "source": "探偵小説漫想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人工のスパークは大空のスパークほど凄くない。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鼻つき合い」というのは、これが両方からブツカッてスパークを発した場合で、局外者から見るとハラハラするような、面白いような表現を双方から見せ合っているものであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国公使パークスは、機会ある毎に、薩摩に説いて、幕府及びその背後にあるフランスを打倒すべくすゝめ、その為めにはどんな援助でもするからと、もちかけてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一句一句が切れ／″＼にしか口に出ない、闇雲にところどころ思ひ出す白秋の「ルナパーク」をＢは、ひとりであらん限りの声で叫んだ。",
              "citation": {
                "source": "晩春日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィクトリアパークの前のレストランでラムネを飲んでいたら、給仕の土人が貝多羅の葉で作った大きな団扇でそばからあおいだ。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早春のある日、ホームズはのんびりとした気持ちで散歩に出、私も同行してリージェント・パークをぶらついた。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
