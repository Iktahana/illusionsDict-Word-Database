          "standard": [],
          "literary": [
            {
              "text": "サザーランドは改良版のＴＸ―２を使って、画面上で図面を描き、コピーをとったり保存したり、呼び出したものに手を加えたりできる、スケッチパッドを書いて博士号を得た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンゲルバートのＮＬＳ、サザーランドのスケッチパッド、さらにランド研究所を訪ねた際に見せられた画板にペンで書き込むような入力装置、タブレットも心に残っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間はコンピューターより大切なものであり、マシンの要求に人を屈服させるのではなく、人の弱点をカバーするようにシステムは設計しなければならないという異端的な確信を当時から抱いていたラスキンは、アイヴァン・サザーランドのスケッチパッドに強い影響を受けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ソーンダイクは紙をとじたパッドをひきだしからだして、どっかり腕椅子に腰かけた。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "インキのパッドをだして、エリスの指紋をとって、ソーンダイクがそれを箱の指紋とくらべてみて、二つは全然ちがうというと、彼はうれしげに監禁室へかえっていった。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "腔は支持材または類似の材料を広げたリントのパッドを詰める。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年もまえに仕入れをやめ、そのまま売れ残ったノートパッドやボールペンが、時間の流れの外にとり残されている。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "注文をとるための小さなパッドに、左手に持ったボールポイントで書きこみながら、彼女はぼくを見た。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃いの封筒とレター・ペーパーのパッド。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のロッカーから、黒い皮の、パッド入りのつなぎを出し、となりの更衣室へいった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "道をおぼえろ」　サドル・バッグからメモ・パッドとサイン・ペンをだし、第二ゆたか荘までの道順を書いた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
