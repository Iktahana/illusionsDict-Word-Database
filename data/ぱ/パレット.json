    "definitions": [
      {
        "index": 1,
        "gloss": "palette",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水色の壁に立てけけた真白な石膏細工の上にパレットが懸って布細工の橄欖の葉が挿してある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此邊の子供には大分專門的の知識があつて「チューブ」だの「パレット」だのといふ言葉を云つて居るのが聞こえた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと使った絵の具箱やパレットや画架なども、数年前国の家を引き払う時に、もうこんなものはいるまいと言って、自分の知らぬ間に、母がくず屋にやってしまったくらいである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しいパレットに押し出した絵の具のなまなましい光とにおいは強烈に昔の記憶を呼び起こさせた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このへんの子供にはだいぶ専門的の知識があって「チューブ」だの「パレット」だのという言葉を言っているのが聞こえた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　ある大学講堂の前へ突き当たって右の坂道へおりようとする曲がり角に、パレットナイフのような形の芝生がある。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（パレットナイフでチョコレットに筋をつける）これで公平だろう。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　栗栖はパレットを離さず、刷毛でちょいちょい絵具を塗っていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて彼はパレットを仕舞い、画架も縁側へ持ち出して、古い診察着で間に合わしている仕事着もぬいで、手を洗いに行って来ると、「ちょうどいいところへ来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう言ってパレットを持ち直し、「満洲にも医学校はある。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の具箱から色とりどりのチューブを取り出して、思うままに絞っていったパレットのように、あざやかな色彩が広場を埋め尽くしています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "描く男は丸い背をぐるりと返して、パレットを持ったまま、三四郎に向かった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "花柳界離れのした彼女のマダムぶりに、原稿紙やパレットに親しんでいるような人たちが、繋がり合ってどかどか集まって来た。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＥＥＥ（アメリカ電気電子通信学会）の『コンピューター』誌、一九七七年五月号に掲載されていた「パーソナル・ダイナミック・メディア」という論文の一頁目には、コンピューターを前にして、パレットを左手に右手の親指を立てて構図を決める絵かきのイラストが添えられていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女たちの性格の描写は、パレットにもっと生彩のある絵具を、もっと豊富にそなえている人に委せておいて、まあこちとら風情はほんの外郭を、それも極あっさりと一言するのが関の山である。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京中探しても、こんな良い所は無いだろうね」　与一はパレットナイフで牡蠣のように固くなった絵の具をバリバリとパレットの上で引掻きながら、越して来たこの家がひどく気に入った風であった。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嫌になつてしまふ、ミツシヱルでも雇つて、コスチウムを描かうかしら、それとも‥‥」　そんなことを考へてゐると、急に風景の緑がパレットに写つて、寒子は心の中に落ちつきを失つてしまつた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "８　パレットから緑を連想し、地図の上から、汽車をひろはふとした熱情もいつか失せて、寒子はまた何日か埃の中の静物の上に摸索を続けさせてゐた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パレット　これは普通の油絵のパレットでよろしい、あるいはブリキ板を使ってもいいでしょう、最も注意を要する事はパレットの掃除です、ヴェルニや速乾が交じっている絵具をそのまま捨てて置くと、何んとしても取れなくなるし、次の調色の非常な邪魔を致します。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "この油を筆に沁ませて、粉絵具を筆先きで少しずつ、パレットの上で溶解しながらガラスへ塗って行くのです、一時に多量溶解すると、すぐ固ってしまって始末に困ります、金銀泥の使用も同様であります。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて自然の前でする技法の特質は、想像にのみよるものが陥りやすい処のマンネリズムから飛び離れ得る事であり、また、画家が自然から直接パレットの上に絵具を調合すると、彼は不知の間に一つの不知の調子と色彩をカンヴァスの上へ現し得る事である。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな訳で自然の前でした仕事を、もし自宅で空だけの一部を記憶によって描き直そうとする時、如何にパレットの上で絵具を交ぜ合せて見ても、再び自然の前で一秒間に作ったはずのその色と調子を出す事が出来ないのである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに新らしき何物かを創造せんとするものは、それはカンヴァスの作り方でも絵の具の並べ方でも、パレットナイフの使用でも、褐色の乱用でも黒の悪用でも何んでもない。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "パレット　これは普通の油絵のパレットでよろしい。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
