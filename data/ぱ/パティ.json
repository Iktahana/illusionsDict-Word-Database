    "definitions": [
      {
        "index": 1,
        "gloss": "patty (e.g. beef)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
