        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "戸波　「ペッパロ」は川口。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、アメリカの民謡の曲を取った「ヒラ／＼と連隊旗」という唱歌があったが、それを、もう一ぺんもじってこしらえたパロディーの戯歌がはやっていた。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉は山椒の葉、アスパロガス。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑こまかき神経の悲しみの径、園の奥、金の光にわけ入ればアスパロガスの葉のかげに涙はしじにふりそそぎ、小鳥来鳴かず、君見えず、空も盲ひし真昼時、白く悲しく、数あまた釣鐘の花咲きにけり。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ＣＯＭＰＵＴＥＲ』という雑誌の一九七七年三月号に載った「パーソナル・ダイナミック・メディア」という記念碑的な論文の最後に、彼がユタ大学に博士論文として提出した「ザ・リアクティブ・エンジン」や、所属していたゼロックス社パロアルト研究所の技術レポートとしてまとめた文献に関する記述がありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもまだ、ちゃんと筋道を追った論理的な文章ならついて行きやすいのですが、冗談やパロディーの類となると、さっぱりいけません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七八年、ワーノックはゼロックスのパロアルト研究所に移ります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パロアルト研究所時代、見学に訪れたジョブスに、ワーノックは画面で見た通りをそのままプリントできるという新しい考え方を説明したことがありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六八年頃、ゼロックスのパロアルト研究所（この世界の『虎の穴』のようなものだ）に入る前、一九六八年頃にダイナブックについて考え始めたころ、アラン・ケイはこれを「サービスやコミュニケーションのアイデアとして想定した」という。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "品性と共に教養を欠くオレは、後になってからマッキントッシュを支えたアイデアが一九七〇年代にゼロックスのパロアルト研究所でアラン・ケイらによって育まれていたことを知った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも最近の雑誌などを読むと、ＧＵＩの源流探しはマッキントッシュ、リサとたどってゼロックス、パロアルト研究所のアルト（例のアラン・ケイ大人の作だ）あたりで止めておくのが流行りのようだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "手本は、ゼロックスのパロアルト研究所で進められていた研究成果の中にあった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもまた物凄い長文で、全部を此処で朗読する予猶はありませんから、それはまたの機会に披瀝することにして、今日はその雄弁と奇想に満ちた彼自らが云ふところのパロオデイア（詩――比喩の歌？",
              "citation": {
                "source": "卓上演説",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "例せばシフノス島には毒蛇あり、ケオス島に蠍、アンチパロス島には蜥蜴のみありて全く蛇なし（ベントの『シクラデス』九〇頁）。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六世紀に出たストラパロラの『面白き夜の物語』（ピャツェヴォリ・ノッチ）十三夜二譚は余未見の書、ソツジニが十五世紀に筆した物より採るという。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストラパロラの件の話にある閹鶏、伊語でカッポネ、英語でカポンは食用のため肥やさんとて去勢された鶏だ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャパロンてふ頭巾は十四世紀に始めて英国で用いられ、貴族男子や武士が冒ったが、十六世紀よりは中年の貴婦人が専ら用いた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから英仏語ともに未通女の後見として、群聚や公会に趣く老婦をシャパロンと呼ぶ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その尾の縁に鰭を附けて誇る事となったが、更に支那人の喧嘩に豚尾を巻き固めたごとく、鰭を畳み頭の一側に立たせて長尾で頭巾に巻き付ける風になり（ハ）、後には手数を省くためニのような出来合のシャパロンが出来た。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "第２図　シャパロンの進化第３図　英国のコッケイド二種　このシャパロンから出ただろうといわるるコッケイドという物がある。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "出征　　　　　　ホセ・マリヤ・デ・エレディヤ高山の鳥栖巣だちし兄鷹のごと、身こそたゆまね、憂愁に思は倦じ、モゲルがた、パロスの港、船出して、雄誥ぶ夢ぞ逞ましき、あはれ、丈夫。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "出征　　　　　ホセ・マリヤ・デ・エレディヤ高山の鳥栖巣だちし兄鷹のごと、身こそたゆまね、憂愁に思は倦じ、モゲルがた、パロスの港、船出して、雄誥ぶ夢ぞ逞ましき、あはれ、丈夫。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "出征高山の鳥栖巣だちし兄鷹のごと、身こそたゆまね、憂愁に思は倦じ、モゲルがた、パロスの港、船出して、雄誥ぶ夢ぞ逞ましき、あはれ、丈夫。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨーク・タイムズ東京支局長リンゼー・パロット氏、ＡＰ東京支局長ラッセル・ブラインズ氏に対して日本人として鈴木文史朗氏が出席している、肩書はリーダーズ・ダイジェスト日本版編集長とある。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」パロット氏「そんなことは出来ない。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴木文史朗の暴言に答えて「そんなことはできない」と答えたときのパロット氏の表情が見たかった。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パロとその臣下の前に投げうちしに、蛇となりぬ』とあつて、エジプトの博士と法術士等もおの／＼その杖を蛇と爲し得たが、アロンの杖はすべて之を呑んでしまつた。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「又もあらじ魂祭るてふ折に逢ひて父兄の仇討ちしたぐひは」幸に太田七左衛門が死んでから十二年程立っているので、もうパロヂイを作って屋代を揶揄うものもなかった。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
