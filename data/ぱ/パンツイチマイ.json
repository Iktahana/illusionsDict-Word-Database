        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ごめんこうむって、パンツ一枚の姿で日記をつける。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、パンツ一枚で非常階段ホールに入ってきた奴がひとり、仰天して防火扉のむこうに隠れた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェックのパンツ一枚に、首からバスタオルを下げ、ゴム草履といういでたちで、風呂上がりの大魔神かなんかに見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くいって、食堂のクーラーで涼もうぜ」「きみは、その格好で涼んだら、風邪ひきますよ」　ワラが、パンツ一枚の山崎を鼻で嗤う。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、あなた達はパンツ一枚なのですから、太股の紅潮した筋肉が張りきって、プリプリ律動するのがみえ、ぼくはすっかり駄目になり、ほうほうの態で、退却したことがあります。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなパンツ一枚の姿でせっせと土に挑んでいた。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにか、大チャンはパンツ一枚の裸かだった。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランニングにパンツ一枚の姿で、昨夜の大チャンの言葉をけんめいにノートに書きつけている自分を、私はいまもあざやかに思い出せる。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンツ一枚になって手紙を書いているのですよ。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "園子ちゃんが真っ白なパンツ一枚の姿でピーチオ。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
