          "standard": [],
          "literary": [
            {
              "text": "暖い砂がパツパツとはねあがつて、規律正しい諧調で砂と空気とを蹴つてゆく爪先の感覚が非常に快いのを沁々と味ひました。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖かい砂がパツパツとはねあがつて、規律正しい諧調で砂と空気とを蹴つてゆく爪先の感覚が非常に快く思はれました。",
              "citation": {
                "source": "晩春の健康",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い土間に自轉車をおしこむと、人々は腰の手拭ひを取つてパツパツと裾をはたきながら、ゆがんだ階段をぎしぎしときしませてのぼつて行く。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜米利加の星条旗が風に翻り、軍艦が波を蹴立て、鉄砲の銃先から、パツパツと白い煙が出るのを、不思議な感動をもつて見つづけた。",
              "citation": {
                "source": "「追憶」による追憶",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　パツパツとその辺を見て、やはり側に転がつてゐる手頃の岩を抱へて、鶴ハシの直ぐ側の岩の下に噛ませる。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（階段の方と室内をパツパツと見て、掌中の物を球台の下に差し込む）正宗さん、頼む！",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
