    "definitions": [
      {
        "index": 1,
        "gloss": "gaping (e.g. mouth, wound)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
