  {
    "uuid": "eac5310f-fa27-5fc9-a730-9e2e8ef3cb96",
    "entry": "８８",
    "reading": {
      "primary": "ぱちぱち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clap clap",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "右門が、Ｔ「いいお湯が沸いてますよ」Ｔ「一風呂浴びて帰ったら何うですお二人」　　　　　　　　　　　　　　　　　　（Ｆ・Ｏ）８８＝（Ｆ・Ｉ）街道　右門と伝六とおふみと伊吉、江戸へ帰ります。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "組み立てキット式のＡｌｔａｉｒ８８００用に移植したベーシックをメーカーのＭＩＴＳ社に売り込んだのをきっかけに、ビル・ゲイツがマイクロソフトを起こしたのが一九七五年。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "２Ｎ８　　２Ｎ２　　８８Ｎ＋　Ｎ２Ｎ―――――　２１６４　この配列を見ると、どこから手をつけていいか分らぬやうであるが、しばらく見てゐると鍵が發見される。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "２Ｎ８　　２Ｎ２　　８８Ｎ＋　Ｎ２Ｎ―――――　２１６４　この配列を見ると、どこから手をつけていいか分らぬようであるが、しばらく見ていると鍵が発見される。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロバーツのまとめた製作記事は大きな反響を呼び、アルテア８８００と名付けたキットは、ＭＩＴＳのヒット商品となる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテア８８００と名付けられたこの組み立てキットはまず、一九七五年一月号の『ポピュラーエレクトロニクス』誌で紹介された★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに数百の注文書を頂戴しており、アルテア８８００コンピューターシステムの無料パンフレットを、数千部発送しております。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月六日に全社経営委員会に行った報告では、ＰＣは８０８８を採用し、三二ＫバイトのＲＯＭ、一六ＫバイトのＲＡＭ、増設スロット六個のほか、さまざまなオプションを備えるとされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この基本路線に沿って選ばれたマイクロコンピューターは、八ビットと一六ビットの中間的な性格を持つ８０８８だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方８０８６の半年後に発表された８０８８では、外部とのデータのやり取りが八ビットに抑えられていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この機能の切り下げによって、８０８８の処理速度は８０８６に比べて遅くなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代わり８０８８を使えば、すでに数多く開発され、供給の安定している八ビット対応の部品を利用することができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピューターは、８０８８。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一方電子デバイス部隊から発表されたＰＣ―８８０１は、明確に仕事のマシンを志向していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＦＭ８を追うために短期間での開発を余儀なくされたＰＣ―８８０１も、漢字ＲＯＭを標準で持つところまでは踏み切れなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レベルアップしたハードウエアの性能を生かすべく、ＰＣ―８８０１には大幅に機能拡張されたマイクロソフト製のＮ88―ＢＡＳＩＣが搭載された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＰＣ―８８００シリーズは大容量のデータ処理機能や日本語処理機能を有した高級機で、ＰＣ―８０００シリーズの上位機種として、近年需要の拡大が著しいＯＡなどのビジネス用途向けに開発された製品であります」　大内は広報資料に謳われたＰＣ―８８０１の開発意図を、もう一度視線で追った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにＰＣ―８８０１は八ビット機ではあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがはっきりとビジネスに焦点を合わせたＰＣ―８８０１の性能は、かなりの部分で発表になったばかりのＩＢＭの一六ビット機、ＰＣを上回っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―８８０１は大内の目に、逸脱の一歩手前まで迫っているように映った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがあらためてＰＣ―８８０１のスペックを前にしたとき、大内は自ら定めた枠組みを明日にでも再度見直さざるをえなくなるだろうことを痛感させられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがＰＣ―８００１では一四三語、ＰＣ―８８０１では二四九語にまで膨らんでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "土井のレポートによれば、ＰＥＴで六四語まで膨らんでいたベーシックは、当時の最新機種である日本電気のＰＣ―８８０１では、二四九語を数えるにいたっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ｉｆ８００が使っていたＺ80に対応したバージョンを、仕様はほぼそのままに８０８８に移植しなおしたのがＰＣのベーシックだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが開発中のＩＢＭの新世代機すら、使っているマイクロコンピューターは八ビットと一六ビットの中間的な８０８８だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今後のパーソナルコンピューターの標準としてかつごうとしているＩＢＭ ＰＣは、八ビットの尾を引きずった８０８８を使っており、グラフィックスの処理能力もメモリーも、視覚的な操作環境を載せるにはあまりに不充分だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこの時期、大ヒットの兆しを見せはじめたＰＣ用にＩＢＭが８０８８を大量に押さえてしまったために、安価な一六ビットの第一の候補である８０８８が量産ベースでは確保しにくくなっているという事情もあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて翌年は、日本電気のＰＣ―６００１とＰＣ―８８０１用のベーシック開発に取り組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お照さんは、眼をぱちぱちさせて、嬉しさうに二三度うなづく。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがアラムハラドの斯う云ってしまうかしまわないうちにもう林がぱちぱち鳴りはじめました。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
