    "definitions": [
      {
        "index": 1,
        "gloss": "crackling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれあれ、何だか火が燃えてゐるやうな、パチパチボウボウつて音がするぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、パチパチのボウボウ山だもの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかなあ、ここがパチパチのボウボウ山とは、おれが三十何年間、いや、兄の話に依れば、ここはただの裏山だつたが、いや、これは、ばかに暖くなつて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それがねえ、」と狸は口をゆがめて、「パチパチのボウボウ山とかいふきざな名前の山に踏み込んだばつかりにねえ、いやもう、とんだ事になつてねえ、おどろきましたよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ、カチカチ山といふのがあつて、それからいよいよパチパチのボウボウ山といふ事になるんだが、あいつあいけない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げ口を一つ、作つてやるやうにしなければ、――」れいの、眼をパチパチさせながら、おつしやつた事がある。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上を自動車や、電車や、人間などが、焙烙の上の黒豆のように、パチパチと転げ廻った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼ばかりパチパチさせて、心は眠ってるのもあった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗闇で毛を逆立てゝパチパチ火花を出すアンデルゼンの猫を。",
              "citation": {
                "source": "猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草がからだを曲げて、パチパチ云ったり、さらさら鳴ったりしました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空が旗のようにぱたぱた光って翻えり、火花がパチパチパチッと燃えました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝炊きに麦藁を焚いてパチパチ音がする。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人の群衆の中に交じった自分の息子を発見した時、眼をパチパチとさせて眼くばせをした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平土間でパチパチ手を叩く奴がある。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」メリケン兵は、また札を二三枚抜いてパチパチ指ではじいて見せた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペーチカの中で、白樺の皮が、火にパチパチはぜった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の川を数知れない氷がうつくしい燐光をはなちながらお互ぶっつかり合ってまるで花火のやうにパチパチ云ひながら流れて来向ふには大犬座のまばゆい三角標がかゞやきました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊長は、耳のすぐ上で、数発の銃声がパチパチとひゞいたのをきゝとめた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中を行っている者が、何者かにびっくりしたもののようにパチパチうちだした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――銃声は、一つまた一つ、またまた一つと、つづけてパチパチ鳴りひびいた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」狐の子が尤もらしくからだを曲げて眼をパチパチしながら林の奥を手で教えました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐の生徒は悦んで手をパチパチ叩きました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　みんな悦んでパチパチ手を叩きました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大烏は息もつかずに三分ばかり咽喉を鳴らして呑んでからやっと顔をあげて一寸眼をパチパチ云わせてそれからブルルッと頭をふって水を払いました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のからだが空気の中にはいってからは雷のように鳴り赤い火花がパチパチあがり見ていてさえめまいがする位でした。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、一郎は、足もとでパチパチ塩のはぜるような、音をききました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると森の奥の方で何かパチパチ音がしました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の中の青い藪を見てはよろこんで目をパチパチさせ青ぞらをどこまでも翔けて行く鷹を見付けてははねあがって手をたゝいてみんなに知らせました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と蜘蛛が六つの眼を別々にパチパチさせて云った。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
