          "literary": [
            {
              "text": "四月七日（土曜）〔発信〕林町へ手紙四月八日（日曜）〔発信〕山岡へ手紙　　　　モヤ中井さんへ四月十四日（土曜）　パスハ〔復活祭〕。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○もうパスハが近いし 1st. May が近いので　Мосгубторготдел〔モスクワ県商業局〕ではレギュレーションを出し何日何日休み、その他布告して居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十八日、五月四日（パスハの日）は午前十時より四時まで普通に開店　三十日と三日も普段通り　◎五月一日、五日、六日はパン屋キオスクなどだけ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十九日　土　今日はパスハ〔復活祭〕の前日だ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
