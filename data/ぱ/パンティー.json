          "literary": [
            {
              "text": "桜模様の手ぬぐいか何かと並んで娘さんのパンティーがほしてある。",
              "citation": {
                "source": "さしえ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、どういう種類の娘さんたちが、そういうモードのパンティーをつけるのかしらないが、ふたつにわかれたもものしまりにヒラヒラのついた形が、こっち向きに干してある。",
              "citation": {
                "source": "さしえ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「結婚」のさし絵は男が描いたものだという点にこだわって考えないにしろ、一般に、いまの人間感覚のうちに、文化の感覚のうちにこういうパンティーなど登場させたらそれを前から描くという風な流行がありすぎると思う。",
              "citation": {
                "source": "さしえ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
