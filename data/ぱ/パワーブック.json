    "definitions": [
      {
        "index": 1,
        "gloss": "Powerbook (early Macintosh laptop computer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
