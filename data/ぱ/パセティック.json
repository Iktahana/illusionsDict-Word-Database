        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "活気のずんずん回復しつつあった彼女には何かパセティックな夢でも見ているような思いをさせた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに高志が出力をしぼり、ポール・ジョーンズのパセティックなヴォーカルが小さくなる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の矢部さんの絵は、色調において暗かったし、テーマもパセティックであって、奇麗な絵ではなかったかも知れませんけれども、私の心には今日なお刻まれている画面もあります。",
              "citation": {
                "source": "第一回日本アンデパンダン展批評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の現実、社会の歴史の現われ方がパセティックなものにばかり焦点を見るということは、一つのセンチメンタリズムであって、芸術家の広い視野と感受性とは、その反対の寛ろぎや、平安や、歓びを芸術の美として映し出すことは当然です。",
              "citation": {
                "source": "第一回日本アンデパンダン展批評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "惨苦がパセティックという感情に、導かれて、通俗人をそこの廃跡にいる間は厳粛にさせ、歴史の犠牲について、人間の発展について思わせる迫力をもって整理されている。",
              "citation": {
                "source": "観光について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、その時も、ただ、かぶっていた麦わら帽子をぬいで、それを高くさし上げて、パセティックな心もちに順応させた。",
              "citation": {
                "source": "出帆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗つてビアンキイ女史がこの詩人のことをリルケと竝べて論じてゐた本を讀んだ折、既に物故したこの詩人のパセティックな、眞の姿を知つて、それ以來何となく心を惹かれてゐたが、最近その文集の佛譯を手に入れることが出來て、數日前から讀み續けてゐるのである。",
              "citation": {
                "source": "春日遲々",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃既に「氷島」のやうなパセティックな詩境に入られてゐた萩原さんがいまもなほ、日本の近代詩の正統な道として信ぜられて、さうやつて絶えずその詩集のことを心にせられてゐたのは、この「青猫」一卷なのである。",
              "citation": {
                "source": "「青猫」について",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（刑部左衛門尉女房御返事）」　一体日蓮には一方パセティックな、ほとんど哭くが如き、熱腸の感情の昂揚があるのだ。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてさっきから自分の裡に湧き立っている制作慾にそれからそれへと促されながら、私はそんな私達の奇妙な日ごと日ごとを一つの異常にパセティックな、しかも物静かな物語に置き換え出した。",
              "citation": {
                "source": "風立ちぬ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そういうパセティックな考えすらも（それはたぶんジムメルあたりの考えであったろう）、いまの自分にはなんとなく快い、なごやかな感じで同意せられる。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレッドさんの境遇はギリシャ悲劇のようにパセティックなんだ」　六右衛門さんが癇癪をおこしたような声をだした。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は益々乗気になって、まさか、お前さんの娘じゃあるまいね、と追及すると、相手は急に間誤間誤し出して、と、と、飛んでもねえ、と、ムキになって否定しましたが、不図パセティックな調子となり、でも、沁々考げえりゃあ他人事じゃ御座んせん、と滾しました。",
              "citation": {
                "source": "陳情書",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちらの景色はパセティックなところがあるでしょう？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしたかの女が、これはまた婆羅門教のVedaの、パセティックな讃仰者であることも附け加へながら。",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしたかの女が、これはまた婆羅門教の Veda の、パセティックな讃仰者であることも附け加へながら。",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            }
          ]
        }
