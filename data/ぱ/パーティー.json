    "definitions": [
      {
        "index": 1,
        "gloss": "party (social gathering)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「ありがとう」　わざわざ送っていただいて――と、陽子が車を降りながら言ったその言葉は、パーティーへ招待されたことへの感謝の「ありがとう」にもとれて、それで約束出来たのも同然だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "発表会を終えた後、別室に用意されたパーティー会場で酒肴を振る舞うスタイルは、これまでに何度も見てきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は、滝口君の補習兼パーティーだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」11ゾンビたちも楽しんでいたパーティーは、まだはじまったばかりゲストは狼男とドラキュラ、それにドラキュラの息子〈モンスター・マッシュ〉ボビー・“ボリス”・ピケット　寮の玄関がこれだけ騒々しいのは、めったにあることではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーティーが終わったら、もういちど集合な。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマス・パーティー後のミーティングで、この新年のプログラムを提案したとき、高志は、おまえの好きなようにしろといったが、じっさいの放送を聴いてから、すこし抑えろ、「一般受け」をねらったやつも入れろ、と慶一を説得にかかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後のパーティーを開く」「寮でか？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーティーには出るはずだ」「へえ、令子ちゃん――いや、もう、ちゃんじゃないか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、最後のパーティーです。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "施設利用のご注意　以下の施設は、今回のパーティー期間中、みなさんがご利用できます。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなも、これからがほんとうのパーティーだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高志が六月に、きょうのパーティーのことで電話してきてさ、それから、へんなんだ」「なにが？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうやって集まって、パーティーをしたじゃないか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「このあいだ、ちょっとしたパーティーで、あいつの親父さんに会ったんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＫ―80を発売する日電と、それを使うユーザーそのどちらにも属さない第三のグループ、サードパーティーが、ＴＫ―80に絡みはじめたのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユーザーに迫られ、サードパーティーに押し上げられ、東京電機大学の安田寿明や東京大学大型計算機センターの石田晴久らのパソコンイデオローグたちにあおられ、いや何よりも一つの革命が進行しつつあるのだという自らの直観を信じて、渡辺たちは目の色を変えていたのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この誤解を胸に刻み込んだユーザーとサードパーティーは、超貧弱マシンＴＫ―80を押し上げはじめる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本電気のパーソナルコンピューターが伸びてくるにあたっては、カスタマー、そしてサードパーティーの力が大変大きく働いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても外部の力、サードパーティーに頼らざるをえない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、サードパーティーを指導していく力なんてないから、とにかく自由に、勝手にやってもらうしかない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サードパーティーとカスタマーに引きずられ、彼らのエネルギーが注ぎ込まれたからこそここまで伸びてきたんでしょうね」　日本電気副会長、大内淳義は今そう語る。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、日電のＰＣシリーズに注ぎ込まれたというサードパーティーとユーザーのエネルギーは、どこから来たのか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来のマシンの供給元とそのユーザーに対して、第三者としてマシンにかかわってくるサードパーティーと呼ばれる勢力は、パーソナルコンピューターのルーツとなったアルテアの発売直後にはすでに誕生していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七六年三月にアルバカーキーで開いたアルテアの世界大会には、サードパーティーから展示の申し入れがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＩＴＳのアルテアにマイクロソフトがベーシックを載せ、ＭＩＴＳの憤慨をよそにサードパーティーが周辺機器を作りはじめていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術情報を可能な限り公開し、サードパーティーによる関連製品の開発を促していくオープンアーキテクチャーこそ、渡辺はパーソナルコンピューターの魂であると信じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすることで、従来のユーザーやサードパーティーが書きためてきたソフトウエアを、新しい機種でもそのまま使えるようにする。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして第四に拡張用スロットの仕様を公開し、サードパーティーによる増設ボードの開発を促す。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場で特に大きなシェアを獲得しているアップル※は、ハードウエアの仕様を全面的に公開するオープンアーキテクチャーをとって、サードパーティーによる増設ボードや周辺機器の開発に門戸を開いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発グループによる事前の働きかけによって、出荷までに五〇種類のＰＣ―６００１用のプログラムがサードパーティーから発売され、近々に二〇〇種類まで拡大されるとアナウンスされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
