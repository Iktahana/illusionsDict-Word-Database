        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高原地方のアトモスフィアを、これほど鮮明に、印象強く、しかもパノラマ的展望で書いた俳句は外にない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面の視野が広く、パノラマ風であり、前に評釈した夏の句「鮒鮓や彦根の城に雲かかる」などと同じく、蕪村特有の詩情である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パノラマ館には例によって人を呼ぶ楽隊の音面白そうなれば吾もまた例によって足を其方へ運ぶ。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西郷像の方へ行きたれども書生の群多くてうるさければ引きかえしパノラマ館裏手の坂を下る。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も陳列所前の砂道を横切って向いの杉林に這入るとパノラマ館の前でやっている楽隊が面白そうに聞えたからつい其方へ足が向いたが丁度その前まで行くと一切り済んだのであろうぴたりと止めてしまって楽手は煙草などふかしてじろ／＼見物の顔を見ている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近の米国雑誌によれば、この種の測量にパノラマ写真機を用うれば最も簡便だという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび、都会がパノラマのように彼女の眼前に展けてきた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、淫書の扉がひらくと、濛々とした紫煙のなかの客間から、現実の微細な享楽地帯が眼前にパノラマのようにあらわれた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ぐろとした杉林がパノラマのように廻って私の行手を深い闇で包んでしまっている。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家はこの方角だ」　自分は友人と肩を並べて、起伏した丘や、その間に頭を出している赤い屋根や、眼に立ってもくもくして来た緑の群落のパノラマに向き合っていた。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このパノラマ風の眺めは何に限らず一種の美しさを添えるものである。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "末遠いパノラマのなかで、花火は星｜水母ほどのさやけさに光っては消えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海と雲と平野のパノラマがいかにも美しいものに思えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子供といい、そのパノラマといい、どんな手品師も敵わないような立派な手品だったような気がした。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらで一轉、パノラマ式の數齣を展開させるか。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パノラマ式などと柄でもないことを企て、たうとうこんなにやにさがつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上五百｜米突の高さから見晴した文明都市の光景は、それこそ一番素晴らしいパノラマの眺めである。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはパノラマ館の屋根に見る青空であり、オルゴールの音色のやうに、靜かに寂しく、無限の郷愁を誘つてゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人氣のない構内では、貨車が靜かに眠つて居るし、屋根を越えて空の向うに、遠いパノラマの郷愁がひろがつて居る。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは文明のふしぎなる幻燈機械や天體旅行の奇妙なる見世物をのぞき歩くさうして西暦千八百十年頃の　佛國巴里市を見せるパノラマ館の裏口から人の知らない祕密の拔穴「時」の胎内へもぐり込んだああ　この逃亡をだれが知るか？",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてパノラマ館の塔の上にはぺんぺんとする小旗を掲げ圓頂塔や煙突の屋根をこえてさうめいに晴れた青空をみた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　パノラマ館にて　あふげば高い蒼空があり、遠く地平に穹窿は連なつてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれこの古びたパノラマ館！",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼ない日の遠き追憶のパノラマ館！",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パノラマ館にて　　幼年時代の追懷詩である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治何年頃か覺えないが、私のごく幼ない頃、上野にパノラマ館があつた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此所で、南北戰爭とワータルローのパノラマを見た。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことには、そのパノラマ館の家の中に、戸外で見ると同じやうな青空が、無限の穹窿となつて廣がつてるのだ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に繪は、特殊のパノラマ的手法によつて、透視畫法を極度に效果的に利用して描かれてゐた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　パノラマ館の印象は、奇妙に物靜かなものであつた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
