    "definitions": [
      {
        "index": 1,
        "gloss": "with energy (of parties and such)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "銀座の往来の左右に電気ストーブを並べてパーッと暖かい空気を放射させる設備をなぜしないのだろう……などと真剣に質問する。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしゅうござんすというところで、パーッと鸚鵡をトッ放す。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビビビーン、ビビビーンと窓硝子の音が息をするのと同じ度数で、その大火光もパパーッ、パパーッと息をした。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして顔の真正面から、なにか土か灰かのようなものをパーッと浴びてしまった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――とたんに、いいあわしたように、光の柱はパーッと消えた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "破甲弾よりは、ややひくめながら叩きつけるような大音響とともに、パーッとたちのぼる火炎の幕！",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "相對した彼岸の崖には、數知れぬ螢がパーッと光る。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　パーッと眼を開き、その眼へ歓喜の光を漂わせ、金属のような声でお浦はいった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は女、まさかと思い、油断していた若侍の一人、パーッと血！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーッと立った水煙り！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに狐の背景かのように、生い茂っている雑草が、枯れて茫々と乱れている庭を、パーッと赤い眼覚めるような色が――派手な衣裳を着た女の姿が稲妻のように駈け抜けた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーッと赤い花やかな色が、その木乃伊の背後に寄り添い、むしろぴったりと食い附いている。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、あけられた扉の間から、パーッと射し出た燈火の光に、全身を明るく浮き出させ、男女が庭に立っていた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「斬って出たぞーッ」「田沼の手のものだーッ」　パーッと群衆は後へ退いた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んの否やなど……何んの何んの……その美しいあなた様に、そうまで云われて何んの拙者が……」「おおそれでは妾の願いを……」　梶子は頬をパーッと燃やした。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、こんどは騒ぎを莫迦にしたようにパーッと室内の電灯が煌々とついた。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、目前がパーッと明るくなった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "最う少しパーッとした処が有れば好いがと思わないでは無かったが努めて打ち解けさせ様とする気にもなれないで居た。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隈なく晴れた夕空に二つ三つ星がまたゝいてゐる時、ズドンと微かな音とともに、星ともまがふ金色の玉がパッとあらはれて、アッと思ふ暇も無くそれがパーッと砕けて赤く青く太陽のやうに天空を照したかと思ふと、一時にスッと消えてしまふ美しさは何とも云はれません。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意に躍り出た陣十郎、物をも云わず背後の方から……「あッ」　不意の事だったので、女は驚きの声をあげたが、……　しかし次の瞬間に、二人はパーッと左右へ別れた。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同時に飛び出し盆蓙を掴むと、パーッとばかりにひっぺがした。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の男の頭髪の代わりに、何んの獣ともわからなかったが、獣の毛が頭に生えていて、それが前方へパーッと下がり、顔をかくしているからであった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢に夢見るとはこれこのことだろう、思いもかけない喜びに、身体中の隅々までがいっぺんにパーッと明るくなってくるような思いがしたのだった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか師匠の家の庭を掃きながら落語家を廃めることを思い直したあのとき以上に自分の前後左右がパーッと何だか明るくなって、そこら道ばたに転がっている石ころのひとつひとつさえが、ありがたくてありがたくてならないもののよう考えられてきた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "論より証拠、日一日と圓朝の芸が、パーッと明るく派手やかになっていった、たとえればあのお正月の繭玉の枝々のごとく。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "韮山、それを見すまして、いきなり下手の庭口の方へパーッと走り出す）本田　あ！",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山から斜に這う風が、パーッと砂煙を舞いのぼせると、実の重い作物が、ザワザワ……ザワ……と陰鬱な音を立ててうねり渡る。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月の御会式ボラの始まるころ、大潮の夜、葛西一帯の細でぬけるものだが、コブシ大ぐらいにかたまって水面へ出て、まるで花火のようにパーッと開いて流れ出すが、実にみごとなもので、子供はよい小遣いかせぎになる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは池の端に人間が立つと、何か餌をくれるのかと、遠くから集まってきた魚が、人影をみるとパーッと逃げる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、耳の附根の邊からパーッと見る見るうちに血が走つて、顏がまつ赤になつた。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
