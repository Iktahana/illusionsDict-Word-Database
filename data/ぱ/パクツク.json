    "definitions": [
      {
        "index": 1,
        "gloss": "to open one's mouth wide and eat heartily",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "防寒靴はだいぶ古で、歩くとパクつくが、何！",
              "citation": {
                "source": "ワーニカとターニャ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その食物をパクつく間のマドロスは号泣していないのを見る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物をパクつく間にしゃくり上げるマドロスを見る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀の子がパクつく有様を見ていると、天井から糸でつるした林檎を囓りっこする遊びを思い出す。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、三人と三匹とは、パンの木の実や、椰子の実や、鹿の肉や、お魚や、鸚鵡のためには特別に木の実の御馳走などもそろっていて、それをみんながおいしそうにパクつくのです。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻迄二三カット、食堂でハヤシライスをパクつくと、又始まる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間キチ／＼なので食事の暇もなし、ふた葉へ親子を言って、「従軍記」の引込む度にパクつく。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
