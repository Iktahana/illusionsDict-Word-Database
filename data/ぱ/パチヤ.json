        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "トンパチ屋の常連は、近所の百姓と工場の労務者達であつたが、百姓の酔態といふものは僕の想像を絶してゐた。",
              "citation": {
                "source": "居酒屋の聖人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この二人が、揃つてトンパチ屋の常連なのである。",
              "citation": {
                "source": "居酒屋の聖人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になると、もつくり起きて、トンパチ屋へ行く。",
              "citation": {
                "source": "居酒屋の聖人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は酔つ払つて良く気焔をあげる男だけれども、多分、僕の一生のうちに、取手のトンパチ屋で飲んだ時期が最もおとなしい時期となるに相違ない。",
              "citation": {
                "source": "居酒屋の聖人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日トンパチ屋で会ふと向うから話しかけて文学の話を始めたから、バカヤロー、私は怒鳴つて帰つてきた。",
              "citation": {
                "source": "ぐうたら戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "又た少女の室では父と思しき品格よき四十二三の紳士が、この宿の若主人を相手に囲碁に夢中で、石事件の騒ぎなどは一切知らないでパチパチやって御座る。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちのまわりにいるやつはみんなばかですね、のろまですね、僕のとこのぶっきりこが僕が何をあなたに言ってるのかと思って、そらごらんなさい、一生けん命、目をパチパチやってますよ、こいつときたら全くチョークよりも形がわるいんですからね、そら、こんどはあんなに口を曲げていますよ。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「パチパチパチパチやっている。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、また目をパチパチやりはじめました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ、死んでからリンゴとスモモをつめて、ミイラにしてもらえるのよ」　こう言うと、ポルトガル奥さんは、日なたに寝ころんで、かたほうの目をパチパチやりました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり花火というものは、夏の夜にみんな浴衣を着て庭の涼台に集って、西瓜なんかを食べながらパチパチやったら一ばん綺麗に見えるものなのでしょうね。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでカメラを向ける者がかなりパチパチやった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "手錠を嵌られると、不貞腐れてその場へベタンと坐り込み、まるで夢でも見たように、妙に浮かぬ顔をして眼をパチパチやり出した。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者にも先刻お馴染の、いつも眼をパチパチやっている検事を初めとして、医務局の監督だの、トゥルハチェーフスキイだの、ベグーシキンだの、その他ソバケーヴィッチの謂ゆる娑婆ふさげどもが、次々に姿を現わしたのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、急いで下りて見ると、彼女は白い環の中の眼をパチパチやつて、間を置いては身を慄はせてゐた。",
              "citation": {
                "source": "犯罪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何か砲弾のような物体の下で、さかんにパチパチやっていたが、そのうちに、砲弾のようなものはスーゥと空中に浮き上ったと思うと、こんどは凄じい勢いで、呀っという間に花火のように天空高く舞いあがった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "忙しくなると、どこからかソロバンの達者な十三ぐらいの子供が一人加勢に現われてネジバチ巻でパチパチやってる。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の飲み助どもは「トンパチやんべい」　といって居酒屋へ集ってくる。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイッチをパチパチやってると部長先生が入ってきた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人もそれが分るらしく、汚い目を見せないためか、しきりにパチパチやっている。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろくに便所へも立ちません、何しろ面白い勝負で」「何方が勝つたんだえ」「最初の一番は私、次は佐吉さん、お仕舞の一番は私」「本當に外へは出ないだらうね」「休みなしにパチパチやつて、奉公人達は寢付かれない樣子でしたよ」　さう言はれると何の疑ひも殘りません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "碁敵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろくに便所へも立ちません、なにしろ面白い勝負で」「どっちが勝ったんだえ」「最初の一番は私、次は佐吉さん、お仕舞の一番は私」「本当に外へは出ないだろうね」「休みなしにパチパチやって、奉公人達は寝付かれない様子でしたよ」　そう言われると何の疑いも残りません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "碁敵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まて、まて」「彦左、しばらくその白髪首をあずけたぞ」　天魔太郎は、目ばかりパチパチやっている彦左ヱ門をうしろにのこして、夏の夜の闇のなかにすがたをかくしてしまいました。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔中略〕「どうしてもわけがわからない、ピンとこない、のみこめず不思議」と寿江子が眼をパチパチやっているのが無理もないわけね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をパチパチやったり、こすったりしているとだんだん見えてきた。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同何の事か少しも分らないで、目をパチパチやっていたが、明智が小声で説明するのを聞いてやっと仔細が分った。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくむっつりと黙りこんでいたが、血走った大きな目を（このぼろ男の目は、団十郎のように大きな二かわ目であった）パチパチやったかと思うと、目の中がわくようにふくれ上がって、ポロポロと大粒な涙がこぼれた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてな、どうもよくわからんが……」　小男の須原は、まぶしそうに目をパチパチやっている。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうです、私は湯河ですが、………」　湯河はちょっと、その持ち前の好人物らしい狼狽え方で小さな眼をパチパチやらせた。",
              "citation": {
                "source": "途上",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は黙って、眼瞼をパチパチやらせながら、その光景を眺めていましたが、彼の自白を一往信用するとしても、まだ私には腑に落ちないことだらけでした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
