    "definitions": [
      {
        "index": 1,
        "gloss": "pack",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると草川巡査は、その継嵌の板片の中の一枚を外から何の苦もなくパックリと引離して、そこから片手を突込んで鉄火箸を引き抜いて、掛金を外した。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "天満京阪裏の古着屋で一円二十銭出して大阪××新聞の法被を仕込み、売るものはサンデー毎日や週刊朝日の月おくれ、または大阪パックの表紙の発行日を紙ペーパーでこすり消したもの、三冊十五銭で如何にも安いと郊外の住宅を戸別訪問して泣きたんで売り歩く。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、人は何時迄もエァリエルやパックばかりではいられない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパック、ＡＳＴを始めとするアメリカ勢も、これで日本市場になだれこんでくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな錯乱のさなかの一九九一年四月九日、コンパックとマイクロソフト、そしてＵＮＩＸで勝負をかけるサンタクルズオペレーションを始めとする二十一社が、新しい先進的プラットフォームと銘打った、ＡＣＥ（アドバンスト・コンピューティング・エンバイロメント）構想に取り組むと発表してオレの錯乱に拍車をかけた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにコンパックは、ＲＩＳＣという高速化技術に対応するに当たって、良く言えば当初から標準化を目指す、別の言い方をすれば徒党を組む戦術にでた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパックとしても、ＲＩＳＣに対応しないことのリスクは大きすぎる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに加えて３８６以上のＰＣ互換機という従来コンパックが作ってきた流れに沿ったマシンも、ＡＣＥの標準ハードウエアと位置づけられる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが発表から半年ほどの一九九一年十月に、言いだしっぺのコンパックの社長ロッド・キャニオンが取締役会で突然解任されたあたりから、あれよあれよの腰砕けとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新生コンパックは低価格のＰＣにもう一度焦点を当て直し、ＡＣＥからはすっかり腰が引けた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月になってコンパックが正式にＡＣＥからの脱退を表明すると、サンタクルズオペレーションも撤退だと言い出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパックやＩＢＭをはじめとする各社のマシンから３８６を引っこ抜き、代わりにＡＭＤのチップを突っ込んでアプリケーションを走らせ「ほら、互換でしょ」とやった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九一年五月、コンパックを始めとするハードウエア・ベンダーは、ＯＳとチップの提供者とぐるになってＡＣＥ構想をぶち上げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると患者の控室になつて居る表の座敷の釣りランプの下で箱火鉢に倚り掛りながら藥局生が中央から分けた髮を光らせてパックを披いて見て居る。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の多くはロンドン・ニュースやグラフフ※ック、パックやウォッヘの切抜で下らぬものばかりである。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の多くはロンドン・ニュースやグラフフヰ※ック、パックやウォッヘの切抜で下らぬものばかりである。",
              "citation": {
                "source": "灰燼十万巻",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉本は顔を顰めてタオルに安香水を振り蒔き、そいつをマスクにして頭の後でキリッと結ぶとゴムの水管の先端を持って、恰度機関車の真下の軌間にパックリ口を開いている深さ三尺余りの細長い灰坑の中へ這入って行きました――。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "パックリと底板が明いた。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし締はよさそうゆえ、絵草紙屋の前に立っても、パックリ開くなどという気遣いは有るまいが、とにかく顋が尖って頬骨が露れ、非道く※れている故か顔の造作がとげとげしていて、愛嬌気といったら微塵もなし。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "シェクスピアは、森のいたずらなこだまパックを登場させた。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パックが二人のアテナ人の瞼にしぼりかけた魔法の草汁のききめは、二人の男たちの分別や嗜好さえも狂わせて、哀れなハーミヤとヘレナとは、そのためどんなに愚弄され、苦しみ、泣き、罵らなければならなかっただろう。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大戯曲家シェクスピアは、大胆な喜劇的効果として、パックの草汁をつかったのであろう。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法の汁で恋のまことが狂わせられるということもないといえないこととして、シェクスピア時代の観客は、笑いながらも本気まじりに、パックのわるさの成行を注目したことであろう。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台では、アテナの二組の恋人たちが、パックのおとす一滴の草汁のために、対手をとりちがえ、愛そのものをとりちがえて、泣きつ叫びつ混乱する。",
              "citation": {
                "source": "真夏の夜の夢",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁師のパック、詩人トック、音楽家クラバックなどの活躍する芥川の河童の国には、生活と判断とが溌溂と盛られていて、作者の社会批評と人生と芸術への気持が、積極な熱をもって流れている。",
              "citation": {
                "source": "日本の河童",
                "author": "――火野葦平のことなど――",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣り道具の店で見た中身の見える真空パックを採用してはという同僚の意見を入れ、ラミネート包装を引き受けてくれる業者をかけずり回って探し、ボール箱のケースにいたるまですべて後藤たち自身が用意した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テキサスインスツルメンツを飛び出して、一九八二年二月にコンパックコンピュータ社を設立したロッド・キャニオンもまた、ポータブルに目を付けた一人だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
