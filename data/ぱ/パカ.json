        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "焼津　八月十七日パパカラ可愛イ子ニ、ソレカラ皆ノ人ニヨロシク。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんたちがどんなに田舎者見てえな恰好をしてたって、番頭に化けたって、腰弁に化けて居たって、第一、おめえさんなんぞ、上はアルパカだが、ズボンがいけねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "パナマらしい帽子にアルパカの上衣を着て細身のステッキをさげている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがアルパカの黒背広に黒の小さな鞄を肩から引き掛けて、「さようなら、行ってまいります。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠色の壁の幾つかの煤けた硝子窓からは、流石に強烈な日光が流れ込んで、そこらの麦稈帽や鳥打帽や赫ら面や鼈甲縁の眼鏡やアルパカの詰襟のぼんの凹などが一時にくわっと燃え立って、それらがその光線を壁の影へ越えると、また後から後からと来る浴衣や、女帽や桃色のスカートに明って揺れて熾った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の黒いアルパカが吹かれる、吹かれる、吹かれる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は黒のアルパカで、頭にはハンケチをかぶっていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今度は、長髪に黒のアルパカの上着を着て、ボヘミアンネクタイをした、画家らしい男が、そう附け加えた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "密々に旨を含めて、五、六人同道せい」　パカパカとひづめの音を鳴らして、事変突発注進の一騎が、霧のかなたに消え去りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではゆるりゆるりとまいりましょうか」　三日の間、そこに来ては寝ころんでいた秣の中から、むくむくと起きあがると、平七は、曳き出した鹿毛にひらりと乗った有朋のさきへ立って、なんのこともない顔を馬と並べ乍ら、パカパカと三めぐりの土手へあがっていった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろがたてがみをさかだてたかと見るまに、パカパカとすさまじい勢いで走りだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "パカパカと矢のように駆け近づいてくる馬の鼻さきめがけて、手にしていた青竹をひゅうひゅうと打ちふりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お中元用の配り物に新花屋のこの女から頼まれて、ちっとばかり鼻毛をのばしながら、せっせとかいたもんだよ」「パカにしちゃいけませんよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は黒のアルパカ〔薄地の織物〕の上着に、縞セルのズボンをはいて、麦藁帽子をかぶっていた。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "山上からカパカパカパとひづめの音、この坂道を乗りおろして来る。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パカ、パカ、パカ、と外を裸馬が走る音が、バカと罵る。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか橋の上を今荷馬車が通つてゐるらしく、ゴロゴロといふ響と一緒にパカパカと馬の蹄の音が聞えた。",
              "citation": {
                "source": "潮干狩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "パカッというような音がし、それにつづいてパリパリと脳膜が剥がれる音が聞えた。",
              "citation": {
                "source": "人体解剖を看るの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今度は、長髪に黒のアルパカの上着を着て、ボヘミアンネクタイをした、画家らしい男が、さう附け加へた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の或るものは、粗末な紺絣の単衣に股引をはいてゐたが、或るものは汚い詰襟の夏服に巻ゲートルなぞを捲きつけ、或るものはまたちやんとしたアルパカの上衣に白のズボンといつた、会社の勤人らしい風をしてゐた。",
              "citation": {
                "source": "フアイヤ・ガン",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」前の方にゐたアルパカの背広をつけた一人が、首を傾げながら考へてゐたが、一同を振返つて、「誰か知つてゐるかね。",
              "citation": {
                "source": "フアイヤ・ガン",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いアルパカの外套を着て、古びて形のくずれた丸い柔い旅行帽をかぶったマリアは、単身その重い箱を持って満員の列車に乗りこんだ。",
              "citation": {
                "source": "キュリー夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
