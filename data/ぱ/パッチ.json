    "definitions": [
      {
        "index": 1,
        "gloss": "patch (of cloth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その外には、つぎのあたった木綿縞や紅木綿の襦袢や、パッチが入っていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十とはトテモ見えない襟化粧、引眉、口紅、パッチリと女だてらのお召の丹前に櫛巻頭。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞパッチリして眼だけは、處女の時其のまゝの濕みを有ツて、活々として奈何にも人を引付ける力があツた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼がパッチリと醒めた。",
              "citation": {
                "source": "ビルディング",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その兵隊さんというのは、郵便局員の話によると西村さんというので、眼鼻立ちのパッチリした、活動役者のように優しい青年であるが、この部落の仲間では新米らしく、すこし離れた所に蒲鉾小舎を作って、その中に床に就いたままの女を一人｜匿まっている。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物はよくわからなかったが、水の滴るような束髪に結って、真白に白粉をつけて、緑色の光りの下にチンと澄まして……黒水晶のような眼をパッチリと開いて、こころ持ち微笑みを含みながら、運転手と一緒に、一直線の真正面を見詰めて行った。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸算の顔は眼玉がパッチパチ、という柳風の句があるが、流石の政宗だから見苦しい眼パチパチも仕無かったろうけれど、左思右考したには違い無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "タパを纏った者、パッチ・ワークを纏った者、粉をふった白檀を頭につけた者、紫の花弁を頭一杯に飾った者…………　中央の空地には、食物の山が次第に大きさを増して行く。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッチリと眼を開くとサア今日こそは大変な日だぞ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "★陰惨な最後の時…………顔を蔽いつくす血の下に観念して閉じていた白い瞼をパッチリと彼女は見開いた。",
              "citation": {
                "source": "月蝕",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えまい考えまいとしても、頭の中に一杯拡がって来ることなら、いっそ考えて考えぬいて、疲れた時に眠ることにしようと、新子は眼さえパッチリ闇の中に、開けてしまった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "品夫は作りつけの人形のように伏せていた長い睫を、静かに二三度｜上下に動かすと、パッチリと眼を見開いた。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生み出される世界は、いくつかの文化が繋ぎ合わされて形成されるパッチワークだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてアントニオ猪木という人物もまた、典型的なパッチワークである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の心はいずれ、遺伝子の規定する型紙にそって、さまざまな体験を通じて織りなされた小さな布を張り繋いでいったパッチワークだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれにしても、アントニオ猪木の精神のパッチワークは、一枚一枚が明るいにしろ暗いにしろ、その基調が明快であるにしろ曖昧であるにしろ鮮烈だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の効率の良さを歴史のタコ壺にこもって楽しもうとするこの国の戦後史は、敗戦が生み出したこのパッチワークを時の流れに逆行して繕い直そうとする歴史でもあった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史のパッチワークをかなぐり捨てて過去から繋がる今に閉じこもれば、それは効率の良い、強面の犯罪的な国ができる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話に関してはこんな具合に屋上屋を重ねてその上にドームまで被せたような日々を送っているオレは、一年ほど前にオンスペック社というところがモデムとＦＡＸ、ボイスメールの機能をＰＣ用ボードにまとめたＦＡＸ―Ｏ―ＦＯＮＥという製品を出したと聞いて、指パッチンをかました。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして電話回線から信号一つ入ってくれば、はたまた一度キーが押されればパッチンと目を開いて欲しい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は眼をパッチリと見開いていた。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗に陰嚢の垂れたるは落ち着いた徴で、昔武士が戦場で自分の剛臆を試むるに陰嚢を探って垂れ居るか縮み上ったかを検したというが、パッチ股引ジャあるまいし甲冑を著て容易く探り得ただろうか。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚屋大声を揚げて啌つきの牝犬め、わが夫は十年来離さず犬の皮のパッチを穿いているが、彼処は肉荳き、リチャード・バートンはアラビア人が小唇の黒きを貴ぶ由をいった（一八九四年版『千一夜譚』注）。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、今まで眠りつづけていた村川が、パッチリ眼を開いた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッチリ明いているのに少しも動かないのです。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッチリと眼を見開いて、静かに振返ってみると花嫁の初枝は、夜具の襟に顔を埋めてスヤスヤと眠っているようである。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青眼先生は愈々不審に思って、一体これはどうした事と怪しみながら、頼まれた通りにじっと紅矢の寝顔を見つめていますと、やがて紅矢は頬の色を真青にして、火のように血走った両方の眼をパッチリと開きました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は大方耳の迷いだろうと思って、ここを立ち去ろうとしますと、今度は別の死骸の、身体から離れて転がっている首級が、眼をパッチリ開いて、月あかりに先生の顔をジッと睨みながら――「不忠者」　と叫びました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――吃驚したようにパッチリ眼を開けて、家の中をクルックルッと見廻わすと、ムックリ起き上ってしまった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
