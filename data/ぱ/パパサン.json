        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日パパさん、大久保にお出で下され。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "パパさんはこれからまたお船に乗って遠い遠い北の方へ行くのです。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も魔子は遊びに来るかも知れないが、「魔子ちゃんが来ても魔子ちゃんのパパさんの咄をしてはイケナイよ、」と小さい児供を戒めた。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供等も、パパさんが見えないと『瘤寺』と云う程でございました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日パパさん、大久保に御出で下され。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は急いで障子を明け放って、空気を入れなどして、『パパさん、あなたランプに火が入って居るのを知らないで、あぶないでしたねー』と注意しますと『あゝ、私なんぼ馬鹿でしたねー』と申しました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パパさん沢山時、待つと皆の者加減悪くなります。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度も『パパさんもう、夢から醒めて下され』などと申します。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が聞きつけて『パパさん何面白い事ありますか』と尋ねますと、こらえていたのが、破れたように大きい声になって大笑など致します。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、母様はあなたをかばいながら、「パパさんは、串談なんですよ」母様はあなたを胸に抱きよせて、「御覧よ、パパは笑ってらっしゃるよ」と仰言った。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも可笑しいと思って、こんどはパパさんいないの？",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやと思いながら、またパパさんいる？",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこんどは、パパさんいないの？",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちを喫茶店へ引っ張って行って、パパさんに面会させるんだ。",
              "citation": {
                "source": "小波瀾",
                "author": "ЖИТЕЙСКАЯ　МЕЛОЧЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題は、パパさんが受難者で、この俺が悪者でならず者で、おまえたち二人の生活を滅茶滅茶にしちまったんだ。",
              "citation": {
                "source": "小波瀾",
                "author": "ЖИТЕЙСКАЯ　МЕЛОЧЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ちなみに　ベンジャミンくんの　おとうさんの　なまえは　ばにばにパパさんと　いいます。",
              "citation": {
                "source": "ばにばにベンジャミンのはなし",
                "author": "THE TALE OF BENJAMIN BUNNY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねこが　みあげると、　なんと　ばにばにパパさんが　たかい　いしがきのうえを　ゆうゆうと　あるいているのです。",
              "citation": {
                "source": "ばにばにベンジャミンのはなし",
                "author": "THE TALE OF BENJAMIN BUNNY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばにばにパパさんは　ねこというものを　よくおもってはいません。",
              "citation": {
                "source": "ばにばにベンジャミンのはなし",
                "author": "THE TALE OF BENJAMIN BUNNY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばにばにパパさんは　ねこを　おんしつのなかへ　とじこめました。",
              "citation": {
                "source": "ばにばにベンジャミンのはなし",
                "author": "THE TALE OF BENJAMIN BUNNY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「パパさんがシドニイで買つて来ておくれたんや。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パパさんは、あそこへ一緒に行って下さらないの？",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな私のパパさんみたいなパパさんを持っているのかしら？",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、全体からして『ごめんなさい、パパさん、これからはもういたしません』などというのが、わたしは我慢のできないたちだった、――それも、わたしにそれがいえないからではない。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
