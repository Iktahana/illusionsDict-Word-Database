  {
    "uuid": "616cc007-8949-5f6c-b312-e7210e4fce7b",
    "entry": "巴",
    "reading": {
      "primary": "パ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
