      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接頭辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "para-",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あなたはそんなにパラソルを振る　　僕にはあんまり眩しいのです　　あなたはそんなにパラソルを振るさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラソルをさして歩くと、少したすかるかも知れませんが、男がパラソルをさして歩いている姿は、あまり見かけませんね。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして彼女は、何処まで習つたかと、先の方をパラパラめくつてみる。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大粒な雨が、パラツ、パラツ、と降り出した。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑蔭に於ける白のベンチ、野景に於ける女のパラソル等も、またこの意味でのよい人工的反映である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかこの若先生のところで顕微鏡を見せてもらって色々のプレパラートをのぞいているうちに一つの不思議な重大なアポカリプスを見せられた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた珪藻のプレパラートを見せられ、これの視像の鮮明さで顕微鏡の良否が分かると教えられた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この從兄は十年前に或る政治運動に獻身して捕へられ、殆ど十年近く世の中から遮斷せられ、このごろ出ることを許され、今は南洋パラオ島で懸命に働いてゐるのであります。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――パラドクサルな人生よ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気も、その重さに堪えないで、雨を、パラパラ落して来る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ひどい搾取下にある島民たちで生活されているが、見たところは、パラダイスであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし統計ほど確かなものはないが、また「統計ほど嘘をつくものはない」という事は争われないパラドックスである。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三つならんだ入口の一番左側には空箱に紫いろのケールやアスパラガスが植えてあって小さな二つの窓には日覆ひが下りたまゝになってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまん中に円い黒い星座早見が青いアスパラガスの葉で飾ってありました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して新しい方面のみの追究は却って陳腐を意味するようなパラドックスもないではない。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このパラドックスは実は何でもない事である。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは必ずしもパラドックスではない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画が実物と似ない点において正に実物自身よりも実物に似るというパラドクシカルな言明はそのままに科学上の知識に適用する事が出来る。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また構造物の模型実験が従来はいわゆる力学的相似にかまわず行われているのに飽き足らず、この点について合理的な模型を作る方法を考案し、その一例としてパラフィンの混合物で二階建日本家屋の模型を作りその振動を験測したりした。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）孕　「パラモイ」は広き静処で湾の名になる。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとリヴァプールの船工であっただけに、木工、金工に通じていたのみならず、暇さえあれば感応コイルを巻いたり、顕微鏡のプレパラートを作ったりするような男であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というパラドックスが云わば云い得られなくはない。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの卓子の一隅にはパラマント・オン・パレードで男前を見せたかのマツイ翠声がお可笑な顔をしてスープをすすっていた。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、「春の眼覺め」は原作に非常に忠實であらうとする努力は見られたが、結局原作のパラフレエズになつてしまつて急所を突いた處がなく、映畫としては甚だ冗漫だつた。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
