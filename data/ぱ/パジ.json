    "definitions": [
      {
        "index": 1,
        "gloss": "traditional Korean pants",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
