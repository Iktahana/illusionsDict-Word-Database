        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "島で銅鑼がだるそうにぼんぼんと鳴り椰子の木もパンの木も一ぱいにからだをひろげてだらしなくねむっているよう、赤い魚も水の中でもうふらふら泳いだりじっととまったりして夢を見ているんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし結局之を受けたのは、此の工事の与える教訓が一千本のパンの木よりも有効だと思ったから、それに、かかる美しい好意を受けることが、何ものにも増して堪らなく嬉しかったからだ、ということ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "起上つて窓から外を見ると、近くのパンの木の葉といふ葉が殘らず白い裏を見せて翻つてゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "起上って窓から外を見ると、近くのパンの木の葉という葉が残らず白い裏を見せて翻っている。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "起上つて窓から外を見ると、近くのパンの木の葉といふ葉が残らず白い裏を見せて翻つてゐる。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だが、そのくさりはパンの木にゆいつけてあるのだろう。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ア、もしかしたら、これパンの木じゃないかしら」　物しりの哲雄君が叫ぶように言いました。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エ、パンの木だって？",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしパンの木ならね、土人達はこの実を土の中に埋めて、蒸焼きにしてたべるんだって書いてあったよ。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すてきすてき、やっぱりパンの木だったね。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やまと島の住民　少年達が一箇月の間になしとげたことは、パンの木の発見や、油しぼり機械の発明だけではありません。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、三人と三匹とは、パンの木の実や、椰子の実や、鹿の肉や、お魚や、鸚鵡のためには特別に木の実の御馳走などもそろっていて、それをみんながおいしそうにパクつくのです。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鏡猿やパンの木に味をしめて、また何か見つけたいものだと、道もない森の中を、奥へ奥へと歩いて行きました。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それなら、パンの木を探せばいいや。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとこのへんにもあるよ」　三人はひとまず矢印を追うことをやめて、手わけをして、パンの木を探しまわりましたが、やがて哲雄君が一本のパンの木を見つけ、三人でその実をもいで、立木のとだえた広っぱのような場所に出ました。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、三人は又手さぐりで、筏につんである木箱のそばにより、その中の鳥のあぶり肉だとか、パンの木の実だとかを取出して、たらふくつめこみました。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶった鳥の肉、パンの木の実、あまい果物など、何をたべても、頬がちぎれるほど、おいしいのです。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、小さなパンのきれを一つやりますと、すぐにもぐ／＼食べてしまひました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんは、でも、ピエロをかはいがつて、とき／″＼、食べあまりのシチュウの汁なぞを、小さなパンのきれへしませてもつて来て、じぶんの手から食べさせたりしました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんは、おゝ、それがいゝと、よろこんで、すぐにおほきなパンのきれへバタをつけたのをもつて、二人で出かけました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんはパンのきれをむしり／＼してはなげこみました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、おばあさんは、すつかりおこつて、のこつたパンのきれをもつたまゝ、ぷり／＼してかへりました。",
              "citation": {
                "source": "小犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざとでもそうしたはずですよ……子供はいわゆる『切り離されたパンのきれ』で、親のふところへ戻りっこないなんて、ちょっ、そんな旧式の消極主義はだめです！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
