    "definitions": [
      {
        "index": 1,
        "gloss": "putty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その他炭の棒やホヤや附属器械のパテントを一々数え立てたら限りがない。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殻の口に青味の混ったパテを詰められ、生海丹や海老の隣に並んでいる。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬草と葫とバタとこね合せたパテを作って置き、それに引き出した身をまぶし再び殻に詰め込み火鍋にかける。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『さうだらうか、それから北極兄弟商会パテントの緩慢燃焼外套ね………。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにパテント外套と氷河鼠の頸のとこの毛皮だけでこさへた上着も着ようといふやつだ。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、パティキュラー・ケースがああなると云う丈けで、全体がああ云う運命になると云うことは含んで居ない。",
              "citation": {
                "source": "予の描かんと欲する作品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこれで間に合うと言って、パテーベビーの映写機を持って来て、最新のフヰルムをかにかくに自分で写してみせます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪戯者の児守さへ、けふは下から真面目顔、ふたつ並べたその鼻の孔に、眇眼に、まだ歯も生えぬただ揉みくちやの泣面のべそかき小僧が口の中蒸気｜噴きつけ、驀進、パテー会社の映画の中の汽車はゆくゆく、――空飛ぶ鳥のわしとそなたは何処までも。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "街に入ると、パテ（木の小太鼓）が響き、華やかな服を着けた土人の娘達が教会へはいって行く。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云つて、今、大急ぎで、家へパテー・ベビーをとりに行つたところだよ。",
              "citation": {
                "source": "サンニー・サイド・ハウス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらかといえば、髪を黒く染めたパティ・ボイドという感じだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス・ギャル、芦川いづみ、シェリー・フェブレー（ワラの発音だとシェリー・ファーベアズだけど、そんな名前で〈ジョニー・エンジェル〉を歌っているすがたなんて、どう考えても想像できない）、パティ・デューク、浅丘ルリ子、シルヴィー・ヴァルタン、マリー・ラフォレ……。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カイン」「サタン」の詩二つながら人界の災殃を賦し、「イパティイ」は古代衰亡の頽唐美、「シリル」は新しき信仰を歌へり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はおどろきました」「うふ、――」　川上機関大尉は、杉田のそばをはなれるとまた元の中国人の硝子屋にかえって、ぬからぬ顔で壊れた窓硝子のパテをはがしにかかった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし川上機関大尉はおちつきはらって、窓枠に硝子板をはめて、パテをつめている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫妻はラジウム製造というパテントを取らなかったために、アメリカのラジウム生産業者に貴重な自由を与えて了った。",
              "citation": {
                "source": "技術と科学との概念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類のために解放した筈のラジウム製造のパテントが、アメリカの会社の利潤の源となったことは可なり遺憾とすべきで、ここにも問題はあるのであるが、私がヒントを得たのは、寧ろ他の点だ。",
              "citation": {
                "source": "技術へ行く問題",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にこの式の映画が大流行を来すと思うから、何ならパテントをお譲りしても宜敷い。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "持っているパテントの数でも十や二十じゃ利かないだろう。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の冬だっけが、そんなパテントの権利も、巨万の財産も海員｜擁済会に寄附して、胃癌で死んじゃったが、惜しい人間だったよ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一つ、私は欧洲大戦以前、チャップリン出現以前における、パリパテー会社の喜劇俳優、マックスランデーを非常に好んでいた。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし亦権力も畢竟はパテントを得た暴力である。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして蓋の硝子を閉め、縁をパテで詰めてしまうと、もう一遍、つくづくと彼女の、赤裸な姿体を見直してみた。",
              "citation": {
                "source": "魔像",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上そのアルバート・ホールの音楽会には、アドリナ・パティもおうたいになるということもお話になりました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドリナ・パティが私と同じステージで歌をうたう。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかと申しますと私は上野の音楽学校で、音楽の歴史の時間に、一九世紀の歌のクインとしてアドリナ・パティのことを習ったのですから、「パティ時代」をつくった大プリマドンナのアドリナ・パティは歴史上の人物だとばかり思っていました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
