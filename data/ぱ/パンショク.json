    "definitions": [
      {
        "index": 1,
        "gloss": "bread-centered diet (as opposed to rice)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "パン食べよか」「おっちゃん、パン持ったはるのン？",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国パン食将来の隆盛のためにここに三軒、軒をならべ店を向い合っておのがじしはげむがよろしい。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は、パン食であつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうはっきりいってのけられるだけのパン食通は、ざらにあるものではない。",
              "citation": {
                "source": "鮟鱇一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは自分らで試してみるが第一と、早速その日から三食のうちの二度までをパン食にして続けてみた。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のところで奉仕パンと称して品質を非常に吟味したもの――これは私が我が国にパン食を普及せしめたいという抱負もあるので――一本三十銭の原料代で売出している。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "粥というもの、飯というものは十年も食わずパン食ばかり続けて来たが、粥がつやのある乳色の趣きをもって、幼穉な食慾をそそった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は幸運にも炊飯といって、米と水さえあればどこでもめしが炊けるが、外国人はパン食であるがゆえに、どこへゆくにもパン焼き竈や専門職人を同伴しなければならない。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、パン食をやっていて米屋のお世話にならない連中でも葬儀社の御厄介には早晩ならざるを得ないのだから、白米商よりも更に一層正業だといって差支ない。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネると、順天堂へ寄り、包帯で顔を包みて帰宅、パン食、食いにくゝて弱る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十七日（木曜）　十時起き、パン食、十一時半眼医者へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰宅十二時すぎ、眠い／＼、パン食して床へ入る、又暑い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カレーパン食ひ、ピョン／＼して十二時に寝る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆んど飯を食はずパン食にしてゐるが、糖尿病にはいゝだらうけれど、食ふたのしみといふものゝ無い人生ほど淋しいものもあるまい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "パン食をして治せばすぐ治る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネて、すぐ帰宅、パン食。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月二十日（土曜）　十一時起き、パン食、一時半に、公会堂へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっすぐ帰って、パン食。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿へ帰り、軽くパン食して、「涼風」のつゞき、床へ入って四時迄書く、三十枚。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネるとすぐ帰り、パン食して又「涼風超特急」を二時半迄に五十枚書き上げた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "パン食――飲みたいのでウイをのむ、わりに暑くなく、早く床へ入る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネてすぐ宿へ帰り、パン食。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
