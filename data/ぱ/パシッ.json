        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いきなり平手で、馬鈴薯のような子供の頭をパシッパシッ殴った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "発作的に息子を打って、そのパシッと云ういかにも痛そうな音をきくと、始めて我に帰った様になって、口をキーッと結んで打たれるままになって居る息子を見て涙をこぼす事があった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り芋を引きに出て来たなと思って耳をすましていると、パシッとかかった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "源次　（助三の出した手と、同時に横面をピシリパシッとなぐりとばして）何をしやがるんだ、俺がさした酒だ、すけてくれと誰が言ったい。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（パシッとなぐる）金吾　春子さまに対して、うむっ！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古賀　（パシッパシッと二つばかりまた殴って）フウ――。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
