        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから、疲れ果てた身体を固い竹の床の上に横たえて眠る――パラオ語でいえばモ・バズ、即ち石になるのである。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の炊事場――パラオ語ではウムといふが、此處南方離島では何と呼ぶのか知らない――に、焔が音も無く燃えてゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナポレオンの野郎、今ではパラオ語をすつかり忘れて了つとるんですと。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二年間此の島でトラック語ばかり使つてゐたために、ナポレオンはパラオ語を忘れ果てたといふ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、生れた時から使つて來たパラオ語迄忘れるとは？",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕のパラオ語の先生」とＨ氏は私に紹介した。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリヤンは先づ筆記されたパラオ古譚詩のノートを見て、其處に書かれたパラオ語の間違を直す。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の炊事場――パラオ語ではウムというが、此処南方離島では何と呼ぶのか知らない――に、焔が音も無く燃えていた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナポレオンの野郎、今ではパラオ語をすっかり忘れてしまっとるんですと。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二年間この島でトラック語ばかり使っていたために、ナポレオンはパラオ語を忘れ果てたという。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、生れた時から使って来たパラオ語まで忘れるとは？",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリヤンは先ず筆記されたパラオ古譚詩のノートを見て、其処に書かれたパラオ語の間違を直す。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
