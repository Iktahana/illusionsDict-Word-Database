        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あたしたちには、だれが、おいしいスープとパンケーキを食べるのか、ちゃんとわかりますのよ。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ママ、きっと天国の扉のところで、大きな水差しいっぱいの水と、そば粉のパンケーキをたくさん用意して迎えてくれるんだから。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、両側をこんがり焼いた、あたたかいパンケーキ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも帰りかけるものがあると、うろたえて奥へいって茶を掩れてきたり、通りまで駈けて行って、せいせい言いながらパンケーキだの今川焼だのを奢ったりする。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）パンケーキの一種。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてさて、　そこで　また　みつけたのが　ちっちゃな　パンケーキ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちいさい　パンケーキを　たべて　きづいたら　とんでもなく　おっきくなってたからって。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "しろウサギの　おうちで　みつけた　ちいさな　ふしぎな　パンケーキ、　それを　ひとつ　たべた　アリスは　ぐんぐん　ちいさくなって　そのまま　ドアを　とおれるようになってね。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "むりだよね、　きっと　でっかい　あしで　ずどんと　パンケーキみたく　ぺしゃんこに　されちゃう！",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日なんかパンケーキの粉をねってるあたしを見て言うのよ、嬢さん、あなたの手袋でお菓子をこしらえたら私が食べてあげますよって。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験動物を使って得た事実からは、メキシコにおいてトウモロコシをアルカリ処理してトルティーヤ（tortilla：主食のパンケーキ）を作るさいに、栄養的に利用できない結合型のナイアシンが遊離して利用できるようになることが示された（33-35）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンケーキを三枚、それにシロップとバターをたっぷりとかけ、ソーセージを二本、そしてハーフ・ア・グレイプフルート。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、デザートには、パンケーキ・スゼット。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンケーキ・シュゼットの媚びるやうな味も今は夢。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴル、クリームスープ、ビフテキシャリアピン、それにパンケーキスゼット。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュうまくなし、鶏のコーン詰揚げうまし、栗のパンケーキ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから神戸のベルネクラブ、オルドヴルから、えびのニューバーグ、鶏、しまひに火のついたパンケーキ・スゼット。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "元町のベルネクラブ、オルドヴル、フロッグレッグー脂こくなくてうまかった、次の犢の煮込、シャムピニオンのうまかったこと、パンケーキ・スゼット。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢蝦のチーズ焼、鳥のクリーム煮、次にパンケーキ・スゼットでおしまひ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "メニュウに、ポット・ローストビーフに、パンケーキといふのがあり、それにする。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローストビーフと言ったって、ソップがらみたいなビーフに、グレヴィのかゝった奴、パンケーキにちょっぴりアップル・ソースといふわけの判らないもの。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
