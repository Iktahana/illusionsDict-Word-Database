[
  {
    "uuid": "be44c015-51dd-578e-8ebf-1f4dad5b4dc9",
    "entry": "包",
    "reading": {
      "primary": "パオ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
