        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "灰銀のフラノのワンピースに緋裏のついた黒のモヘアのストール、パンプスの靴とナイロンの靴下が入っていた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "錆色のパンプスのハイヒールがあんまり細くて高いのを、春彦はあぶなっかしいなと思いながら、誠意をこめてあいそ笑いをし、容器のほうへ手を振った。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このような色のスニーカーをさがしているの」　と、彼女は、応対してくれていた店員に、自分のパンプスを示してみせた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車とおなじようなスカイ・ブルーのパンプスであることに、ぼくはそのときはじめて気づいた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いパンプスにピンクの水着、そして黒い大きなこうもり傘をさす、というアイディアを彼女が出した。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいな色の初夏のパンプスが、おなじ角度で右へ向き、そろっていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、けっしてベージュではなかったし、黒のパンプスなんてさっきの赤いスカートとおなじで、笑うほかないし。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "美代子がパンプスを履いてるところを、私は見たことがないわ」「ストッキングは」　という日比谷の質問に、玲子は首を振った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒールの充分にある白いパンプスに、スカートの広がったシャツ・ドレスを節子は着ていた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからまっすぐにのびていく向こうずね、そして足に履いている白いパンプス。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンプスのぼけ具合が絶妙だった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
