    "definitions": [
      {
        "index": 1,
        "gloss": "repeatedly opening and closing (one's mouth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
