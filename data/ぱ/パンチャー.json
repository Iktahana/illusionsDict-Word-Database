        "examples": {
          "standard": [
            {
              "text": "このパンチャーで穴を開ければ、書類をファイリングしやすくなるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "厚紙にきれいに穴を開けるには、ちゃんとしたパンチャーが必要だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "事務用品店で、色々な種類のパンチャーを見たことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "キー・パンチャーとかウェートレスとかの仕事をやりながらブルースをうたい、恋愛のはてにテキサス州のオースティンまでひきかえし、そこからチェット・ヘルムズとともに再びサンフランシスコに出た。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
