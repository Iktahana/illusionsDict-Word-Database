        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "洋服のときはゴルフパンツである。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」新郎はネクタイをほどきながら、「ついでに君、新しいパンツが無いか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は即座にカバレット・トア・ズン・ドルにお別れを告げると、ローヌ河でパンツを洗濯してすっかり清浄な心と魂を持つ女になったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方は揃いの新しいユニフォームをチャンと着ているのに、こちらはワイシャツにセイラ・パンツ、古足袋、汗じみた冬中折れという街頭のアイスクリーム屋式が一番上等で、靴のままコートに上って叱られるもの。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは眼の前に重なり合った草の茎の隙間から見るテニスコートの白い一直線の上を、ソロソロと後しざりして来る薄茶色のセイラアパンツであった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アッ……」　と小さな叫び声をあげてセイラアパンツは駈け出そうとした……が、草の陰から覗いている彼の静かな眼つきをふり返ると、またも、彼と向き合ったまま、ベタリと草の中に坐ってしまった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "体操に支障無きようパンツ、シャツの用意を忘れぬ事。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごめんこうむって、パンツ一枚の姿で日記をつける。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンツも純白のキャラコである。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらふきの兵太郎君は着物だったので、まずかばんをはずして、しりまくりし、パンツをぬいだ。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ手ぬぐいで足から腰をふいて、パンツとズボンをはいた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "音次郎君は、草の上からパンツをひろってきた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごわごわした固い布地の黒色パンツひとつ、脚、海草の如くゆらゆら、突如、かの石井漠氏振附の海浜乱舞の少女のポオズ、こぶし振あげ、両脚つよくひらいて、まさに大跳躍、そのような夢見ているらしく、蚊帳の中、蚊群襲来のうれいもなく、思うがままの大活躍。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズボンの下には、パンツだけだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランニングシャツにパンツという姿で、女中の肩にしなだれかかりながら勝治は玄関にあらわれた。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝治は、相変らずランニングシャツにパンツという姿で、月夜ってのは、つまらねえものだ、夜明けだか、夕方だか、真夜中だか、わかりやしねえ、などと呟き、昔コイシイ銀座ノ柳イ、と呶鳴るようにして歌った。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は、半袖のワイシャツに、短いパンツはいて、もう今日の仕事も、一とおりすんだ様子で、仕事机のまえにぼんやり坐って煙草を吸っていましたが、立って来て、私にあちこち向かせて、眉をひそめ、つくづく見て、ところどころ指で押してみて、「痒くないか。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフパンツはいて、葡萄たべながら飛行機に乗っていると、恰好がいいだろうな。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフパンツのようである。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすいメリヤスの運動シャツ、白いパンツ、足にぬったヨジウム。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日道子はアンダーシャツにパンツを穿き、その上に着物を着て隠し、汚れ足袋も新聞紙にくるんで家を出ようとした。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩パンツ姿も凜々しく月光を浴びて多摩川の堤防の上を疾駆するあなたを考えただけでも胸が躍ります。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い月の光が彼女の白いアンダー・シャツを銀色に光らせ、腰から下は黒のパンツに切れて宙に浮んだ空想の胸像の如く見えた。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴子は一日に五度衣裳をかえたが、土曜日の夜は、白いショートパンツに白いワイシャツという無造作な服装になることが多かった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴子が言ったのは、白いショートパンツに白いワイシャツの魅力であった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイヤの指輪をほめるには、春隆は余りに侯爵だったし、だいいち、せっかくのショートパンツとワイシャツにダイヤはぶちこわしで、ふとパトロンのある女の虚栄のあわれさであった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴子のショートパンツは、尻の重みに圧されて、皺をくぼませていたので、起ち上った時は腰のまるみが裸の曲線とそっくりに二つに割れて、ふと滑稽な、しかしなまなましい色気が後姿に揺れていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴子は昨夜のショートパンツではなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はパンツの中へ新聞をかくして、便所の中で読んだという。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
