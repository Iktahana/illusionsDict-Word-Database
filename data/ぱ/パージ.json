        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "レッドパージで全国の学生がたたかっていた十月　一万九百人の戦争協力者が解除された。",
              "citation": {
                "source": "東大での話の原稿",
                "author": "一九五〇・十二月八日",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本治一郎氏の天皇制に対するたたかいとパージがよくその消息を告げている。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことあたらしく観察するまでもなく、大学法案に関する問題、レッド・パージに対する各大学の状態が強いられている現実を語っている。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての人々に訴えるこれらのたたかいの成果におそれて、労働組合、言論機関、芸能人ばかりでなく、教授と学生への思想抑圧、レッド・パージがおこった。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていま、日本から理性の存在そのものをつみ取ろうとするレッド・パージに対する反対。",
              "citation": {
                "source": "若き僚友に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レッド・パージとそれに反対する学生の大量な処分は、全く中世的な方法であり、みせしめのためのはりつけ同然です。",
              "citation": {
                "source": "若き僚友に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パージからのがれるためにさまざまの手段が用いられ、その効力があるような余地が残されている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "侵略戦争協力の責任によって最近パージにかかった林房雄、その他の作家を組織員としていることが、国際ペンクラブへの正式加入にふさわしい条件であろうか。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ジュヌーコンプランパージャポネーズ（私は日本語がわからん）と云いよる。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "パージとはうまいことを考えた。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十七日まで、パージユーヨ期間。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月三十日　水曜　全労連、突然解散、土橋はじめ十二名パージ　岩崎に『平和をわれらに』原稿わたす。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつものに非ず　郵逓、農村三千人の赤パージ（予定）　区委員会から新日本文学について詰問。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、会社であまりよく云われないらしく、パージがとけて復帰したことも、多くの人から反感をかわれていました。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時を同うして一万何千名の御歴々がパージから解放され、解放旋風というものが吹きまくっていたようだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "パージ族というのもあるが、パージ族というほど育ちの良いところはないから、とにかくこの閑日月は浪人の風格であることは確かなようで、すると、官庁か大会社で悪いことをしてクビになった奴かなア。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その八　安吾愛妻物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この左りにあるのが有名な孤児院でスパージョンの紀念のために作ったのです。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スパージョン」て云うのは有名な説教家ですよ」「スパージョン」ぐらい講釈しないだって知っていら、腹が立ったから黙っててやった。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなで七人、「先生」とガスパールおじさんに、三人の坑夫のパージュ、コンプルー、ベルグヌー、それからカロリーという車おしのこぞう、それにわたしであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱山の中は水でいっぱいになっているにちがいない」「マリウスはどうしたろう」「鉱坑は水でいっぱいになっている」と言った「先生」のことばで、パージュは三｜層目で働いていた一人むすこのことを思い出した「おお、マリウス、マリウス」とかれはまたさけんだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "パージュが水を取りに行こうとした。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはおれの寝台の下にはいっている……おお……」「あいつを水の中にほうりこめ」とパージュとベルグヌーがさけんだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の中にほうりこめ」とパージュとベルグヌーが、「先生」　の後ろに丸くなっていた罪人にとびかかって行きそうにした。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはくい改める」　やがてパージュとベルグヌーがさけびだした。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどそれを見つけたパージュがわたしを呼び止めた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生」と、ガスパールおじさんだけはわたしを食べようとは思えなかったが、パージュとカロリーと、ベルグヌーは、とりわけベルグヌーは長ぐつの皮を食い切るあの大きな白い歯で、ずいぶんそんなことをしかねないと思った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとパージュとベルグヌーが、とんきょうな様子でかれとおしゃべりを始めた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "財界の特需景気と警察予備隊景気、戦争気分をそそるレッド・パージとそれに対蹠する戦犯一万九百人の解放。",
              "citation": {
                "source": "戦争はわたしたちからすべてを奪う",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
