          "standard": [],
          "literary": [
            {
              "text": "また構造物の模型実験が従来はいわゆる力学的相似にかまわず行われているのに飽き足らず、この点について合理的な模型を作る方法を考案し、その一例としてパラフィンの混合物で二階建日本家屋の模型を作りその振動を験測したりした。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、三錠目は壜の中にパラフィン紙がつまっていて、なかなか出て来なかった。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチの棒を使って漸くパラフィン紙ごと出してみると、今度は白い錠剤だった。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａは偶と、パラフィン紙の皺を伸ばしてみた。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か持って参ろうと思ったんですが、まだお目にかかったことがないので、どんな物が、お気に召すか分りませんので、お花ならと思いまして……」と、パラフィン紙の中から、強烈な匂いをこぼしている、アメリカン・ビュウティと呼ばれる赤みを含んだ黄バラの花束を、準之助の前に差し出した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "出る時に岡は持って来たパラフィン紙に包んである包みを開くと美しい花束だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中身を見て、わかんないような奴は、どっちを食ったって、おなじじゃねえか」　広岡は、うるせえ野郎だな、ちょっときいただけじゃねえか、とぶつぶついいながら、パラフィン紙の上に中身を三分の一ほどのせる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おう、と山崎が返事したので、広岡が上体を伸ばして、缶とランプとパラフィン紙という一式をわたす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は、パラフィン紙にコンビーフをのせ、それをランプの台におき、ランプの先を折り曲げて至近距離に近づけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これくらいのパラフィンをあそこに注射すれば、これくらいの鼻にはなる。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日のさす往来でパラフィン紙を透きとおす活々した花の色が、教師をひきつけた。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち浴槽の外、流し場の横に濡れたパラフィン紙が捨てられてあつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂にはいる前に初江は気になると見えてまた同じ質問を林田にしたので、林田も同じように答えたと云うことだ」「成程、それで事件直後林田は気になるので第一にパラフィン紙を探したんだな。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川君が僕に電話をかけている間に林田はヴェロナールのパラフィン紙をかくして、健胃剤を流してそのパラフィン紙を浴場でひろつたと称して警察に出し、初江の着衣の中から残りの健胃剤を探し出したということになる。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラフィン塗りの紙細工か。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の框に瓶の底を載せて、パラフィンを塗った固い栓を、矢張り袖口で捉えて引き抜いた。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、私はスイートポテトの如くパラフィン紙に包まれた象の幽霊と称するものを人から貰った。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで某氏はパラフィンを注射した俳優に知合のある事をはなして、そんな例もあるから心配するにも及ぶまいというと、彼女はその俳優の鼻が見せてもらいたいといいだしたので連れてゆくと、やっと安心してその後注射した。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事の部下は、トランクを一個持って来て、命ぜられたものを一つ一つ丁寧にパラフィン紙に包んでトランクの中に収めた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚写真である、盲人は首を傾けるやうにして成瀬の様子を伺ひ、写真を覆つたパラフィン紙の音を聞くと、えッへへへへと笑ひながら、惚気る訳ぢやあないがとことはつた後、結婚当時の生活が如何に幸福に溢れてゐたかをくどくどと納得させるのであつた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座三越にゆく、ポンジーの紙箱入白粉二つ、ストロベリー口唇棒だけパラフィンに包んだの二つ、12.75。",
              "citation": {
                "source": "日記",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで白煙をあげて消えたが、パラフィン蝋燭を吹き消した後のような匂いがした。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、薄いパラフィン紙を押しつけて傷の形を写し取って、その面積を測ったのだそうである。",
              "citation": {
                "source": "鼠の湯治",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子板を薄いパラフィン膜で蔽い、その上に結晶をのせて、裏から指先でちょっと温めてやると、先ず結晶の枝の先から融け始め、融けた水は毛管現象で結晶中心に吸い寄せられて、全体が一つの小水滴になりそのまま凍ってしまうのである。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｇはパラフィンを塗った硝子板で、落下した結晶を受けるために挿入したものである。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には絹繊維をパラフィン蒸気の上に暫くさらしてそれを用いて見たが、それも今の目的に適していた。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、ルダンさんだ」　上衣はいつもの古ぼけたスモオキングだが、きょうは折目のついた縞のズボンをはき、パラフィン紙で包んだ、大きな花束を抱えている。",
              "citation": {
                "source": "黄泉から",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のこの真っ黒な眼が、もう少し茶色だったらどんなでしょう」「…………」「鼻はパラフィンの注入や、象牙の嵌入でどんな形にでもなります。",
              "citation": {
                "source": "葬送行進曲",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある、では一寸貸してくれ、有難う、これでよかろう」　理科の時使うピンセットの先を、人形の小さい口の中に入れて、中からそっと引張り出したのは、ていねいにたたんだ一枚のパラフィン紙です。",
              "citation": {
                "source": "眠り人形",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
