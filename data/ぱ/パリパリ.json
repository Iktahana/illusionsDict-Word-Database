        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "突然この音が絶えると同時に銀幕のまん中にはただ一本の旗が現われ、それが強い砂漠のあらしになびいてパリパリと鳴る音が響いて来る。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなくパリパリ呼子が鳴り汽罐車は一つポーとほえて、汽車は一目散に飛び出しました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまいぞ、うまいぞ、鈴蘭なんかまるでパリパリだ」　風が来たので鈴蘭は、葉や花を互いにぶっつけて、しゃりんしゃりんと鳴りました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもその小さな子は空が紫色がかった白光をしてパリパリパリパリと燃えて行くように思ったんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリパリという、幽かな音が、窓の外から聞えて来た。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、きょうの夕方、その窓の外で、パリパリと低い音たてて傘をひらいた。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その合羽はもちろん、その仕事着さえもパリパリと凍っていたのである。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "最新流行仕立｜卸しのパリパリを着ているのも、どちらかといえば江戸ッ子でないのが多い。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも何がしのパリパリでさえこうだから、他は推して知るべしだと思った。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いの一番の筆頭は華族様、富豪なぞいう御方々で、東京では勿論の事、日本でも上流のパリパリ。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆をつけて居る時の苦心の名残は、つゆほどもなく、スラスラと、江戸前のパリパリの筆の運びには、感歎のほかはないのである。",
              "citation": {
                "source": "紅葉山人と一葉女史",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヤと思う間もなく、うしろにあって、パリパリという物を裂くような音が聞えたかと思う途端、火床を開いたようにドッと猛烈な火の手があがり、彼は俄に高熱と呼吸ぐるしさとに締つけられるように感じた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "パカッというような音がし、それにつづいてパリパリと脳膜が剥がれる音が聞えた。",
              "citation": {
                "source": "人体解剖を看るの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "内臓を切り放し、外へ引出すときに、烏賊の皮をむくときのように、パリパリと音がするのであった。",
              "citation": {
                "source": "人体解剖を看るの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを一歩でも立ち入って、何か込み入った商法のことに成ると、新どんや吉どんのような多年大勝の御店の方で腕を鍛えて来たパリパリの若手は言うまでもなく、馳出しの小僧にすら遠く彼は及ばなかった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜食堂車にいたら、四人並びのテーブルの隣りへ坐った男が、パリパリ高い音を立てて焼クロパートカ（野鳥の一種）をたべながら、ちょいと指をなめて、　――シベリアにはもう雪がありましたか？",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頁の右肩に英語で肩書や住所などの印刷された、純白で透し模様のあるパリパリした薄い紙はどんなに私を誘惑しただろう。",
              "citation": {
                "source": "木蔭の椽",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は暫くぼんやりと何も考えてはいなかったが、突然、屋根の方を、ビュンと唸る音がして、つづいて、パリパリと何か裂ける響がした。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリパリと何か裂ける音がした。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "先殿の御役目が好かッたので、八万騎の中でも大パリパリ……だが、これが悪縁になってくれなければ好いが、少々心配だて」「宗匠、大層、月並の事を仰有いますね」「何が月並だよ」「だって、吉かれ凶しかれ事件さえ起れば、あなたの懐中へお宝は流れ込むんで」「金星、大当りだ。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿九歳で後家になってから猶更パリパリしていた養母の亀吉は、よき芸妓としての守らねばならぬしきたりを可愛い養娘であるゆえに、小奴に服膺させねばならないと思っていた、その標語――芸妓貞鑑は、みな彼女が実地にあって感じたことであり、また古来の名妓について悟った戒めなのであった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤木さん夫婦は妹娘を真にして柳橋でパリパリの××家のおとっさんおっかさんになってしまった。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉娘と妹娘との旦那の張合いで、××家は柳橋でもパリパリの芸妓家となった。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "高位高官の宿坊であり、鬼の金兵衛さんがパリパリさせていた楼ではあり、そこへこの新智識の才子が大事の娘の恋婿である。",
              "citation": {
                "source": "最初の外国保険詐欺",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃と、むし暑さ、氷を沢山呑むと、髪の毛が沢山抜けると云って氷を呑まない由ちゃんも、冷蔵庫から氷の塊を盗んで来ては、パリパリ噛んでいる。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩みたいな、東京中の新聞社を喰い詰めた、パリパリの摺れっ枯らし記者の上に立つ編輯長とは、どう割引しても思えないだろう。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
