        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "辞表を出してから引き続いてＣＡＣの仕事を手伝うこともあったが、大半の時間はパチンコ屋で過ごした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は何をしていたかてんだ――どうだい」「十二分ぐらいは何をしても過ぎちまわア」「坂の下にパチンコ屋も喫茶店もなくてもかい。",
              "citation": {
                "source": "正午の殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくづく呆れた長男が、「表通りならいざ知らず、野良道にパチンコ屋をたてたッて景気がでるものか。",
              "citation": {
                "source": "餅のタタリ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲人のアンマだから私も心配になって、散歩がてら出てみると、パチンコ屋からツエをたよりに出てくるアンマにぶつかった。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチンコ屋の前にズラリと並んだ自転車。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "織物業は目下はなはだ不振で、桐生の町はデフレの上にも不景気らしく、メーンストリートの古いデパートまでパチンコ屋に身売りという昨今であるが、警察の交通整理同様に不景気もこのお祭にだけは歯がたたないのである。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にパチンコ屋と町の碁会所とはその簡単なヒマツブシという点で甚だ類似した性格があるから、碁会所へ通う可能性の青年はパチンコ族になったと見てよかろう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチンコ屋で一番根気よくねばっているようなのが昔なら碁席の常連になっているのかも知れない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチンコが狂うとパチンコ屋の親父がハコをポンポンとたたく。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この古い町にもパチンコ屋ができた。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでパチンコ屋へ再三ねじこんで「音を低くしろ」　と談判したけれども、ラジオとちがって、パチンコの音を低くするわけに行かない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日早朝、パチンコ屋の開店とともに店を訪れた。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチンコ屋もあるし、ストリップもあるし、そして一番混雑していないのは、むしろストリップであったようだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝塚の難民は七万坪の遊園地のうちで劇場と動物園にもっぱら群れをなしているのであるが、劇場は大中小とあって、それぞれは廊下でつらなり、廊下の左右は売店であるが、全日本の都市や温泉街の売店街の様相がそうなったと同じように、売店の半分は目下パチンコ屋に転じて盛業中である。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの縦横の廊下に、パチンコ屋だのボットル落しだのホームランゲームだのと、その店の数だって人口三万の東海道の温泉都市と覇を争うほどの盛大なものだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マナジリを決するとは、まさにパチンコ屋に於ける彼女らを云うのであろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局そういう結論を宝塚のパチンコ屋で戦意とみに昂揚している娘たちが教えてくれるのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女だけのパチンコ屋というものはフシギの多い日本のうちでも宝塚にしかないだろうからねえ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチンコの機械が狂うと、パチンコ屋のオヤジが箱をトントンと叩くね。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチンコ屋のオヤジはパチンコの機械の構造はよく知らないらしいが、トントン叩くとたいがい正常に返ることを知ってるのだね。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がお医者さんをパチンコ屋のオヤジだと云ったのは、そういうワケです。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチンコ屋のオヤジはちょッと勉強すればパチンコの機械の構造をのみこむことができるが、お医者さんの場合はいくら勉強してみても、目下のところはとてもとても機械の構造を見破り、故障やその原理を発見する見込みはありません。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう手軽に見るのは素人考えかも知れんが、パチンコ屋のオヤジ式にトントンと叩くうちに正常にかえりそうだよ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなところにも、パチンコ屋があるんですね。",
              "citation": {
                "source": "雲のわくころ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムが短期（相場）でしくじって店を投げだし、そのあとがパチンコ屋になった。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "広場をわたりかえして、駅の前のパチンコ屋へ行く。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "サト子は、パチンコ屋をとびだすと、駅口でタクシをひろった。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのとき、軒を並べたパチンコ屋の、暗い海へと、宵の灯影をあか／＼と溢れさせてゐる漁村風景が、われ／＼の目に映つたからである。",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の端のトンネルをくぐって西口へ出ると、パチンコ屋の横丁に、やはり珈琲店で「スター」というのがある。",
              "citation": {
                "source": "池袋の店",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "……わかった、パチンコ屋であそんでたのね？",
              "citation": {
                "source": "待っている女",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
