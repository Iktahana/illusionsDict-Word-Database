        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると、妻はいままで閉じていた眼をパッと見ひらいた。",
              "citation": {
                "source": "秋日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "走りながら「どうせ……どうせ……」と女は思ってパッと見ひらいた目からとめどない涙をこぼした。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてパッと見ひらいたまつげとまつげとの間に銀の様な糸をはり始めた。",
              "citation": {
                "source": "お女郎蜘蛛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐怖と憎悪とがあからさまに、パッと見開いた眼にあった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太気づいて大刀と加多をパッパッと見て、驚き、これも敵だと思い、とっさに一二歩右へ寄ろうとする。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太気付いて大刀と加多をパッパッと見て、驚き、これも敵だと思い、とっさに一、二歩右へ寄ろうとする。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺めているとパッと見えなくなり、またすこし離れたところに同じ形のものがあらわれ、じりじりと動き出す。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして、ごつんと木を斬ったようなひびきを腕に感じると、赤黒い血しおが、顔へかぶって来るようにパッと見えて、彼女は眼が眩むような心地がした。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティルトン公爵がこよなく愛する先祖伝来の家なら、大塔、小塔、広い厩舎があり、ちなみにパッと見で今流行りの巨人国建物のようだろう。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
