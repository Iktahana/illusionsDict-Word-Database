          "literary": [
            {
              "text": "電車の車体は黄色に塗られ、架空線はないから随ってポールやパンタグラフは無い。",
              "citation": {
                "source": "科学時潮",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンタグラフなどといふ語もおぼえて、実に熱心に見て居る。",
              "citation": {
                "source": "孫",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてゴロリと上向きになると、ビクビクと宙に藻掻いていた六本の脚が、パンタグラフのような恰好になったまま動かなくなってしまった。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
