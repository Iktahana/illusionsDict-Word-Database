    "definitions": [
      {
        "index": 1,
        "gloss": "with a snap",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空が旗のようにぱたぱた光って翻えり、火花がパチパチパチッと燃えました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」助手が又一つパチッとやる。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空が旗のやうにぱたぱた光って翻へり、火花がパチパチパチッと燃えました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　穂吉はパチッと眼をひらきました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチッて云ったらう。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士はみかげのかけらを手にとりあげてつくづく見てパチッと向ふの隅へ弾く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空が旗のようにぱたぱた光って飜り、火花がパチパチパチッと燃えました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチッて云ったろう。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士はみかげのかけらを手にとりあげてつくづく見てパチッと向うの隅へ弾く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると猫はしばらく首をまげて聞いていましたがいきなりパチパチパチッと眼をしたかと思うとぱっと扉の方へ飛びのきました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　百姓は顔をまっ赤にして手をあげて革むちをパチッと鳴らしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　百姓はわたくしの顔の前でパチッパチッとはげしく鞭を鳴らしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと、パチパチパチッとはげしい音がして見る見るまるで煙のように砕けました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからパチッと石をとります。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチッと眼がさめるなんて、あれは嘘だ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、電燈のスイッチがパチッと鳴ると同時に部屋が明るくなった。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「な、兄ちゃ、狐……」――瞬間、炉の火がパチパチッと勢いよくハネ飛んだ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチッと物音を立てたのは、捕り縄がはねられたに相違ない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチッパチッと囲碁の音！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お話し致そう、それまでの経路を」パチッと今度は扇をとじ、膝の上へ突っ立てた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとやって見ましょう』内野さんは机の下を探し回って、太い電線を見つけてつないで、それから先刻の壁のスイッチを押して、ニッケルの文鎮を傍へ持って行くと、パチッと音がして吸いついちゃった。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千世子はひよっこの様に目をパチッとしたっきり返事もしないでザワザワする空気の中にひたって居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチッ、パチッと音のするのは、泉水で鯉が躍ねるのであった。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今日｜外科は大進歩をとげ、人体を縫合せ、神経をつなぎ、そのあとで高圧電気を、ごく短い時間、パチパチッと人体にかけることによって、百人中九十五人まで生き返らせることが出来る。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあれは四月でなくては咲きませんの」　杜松子は顔をかしげるようにして萩の花むらをながめながら、「花もサンパチックないい花ですけど、葉もいやしい葉ではありませんのね」　といった。",
              "citation": {
                "source": "ユモレスク",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
