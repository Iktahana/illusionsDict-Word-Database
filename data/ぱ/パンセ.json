        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "パンセのないものは詩人ではない。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しパンセは起るものとして自己を益し、パンセしようとしてすれば良く行つて歴史家の知にしかならないものだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンセは詩ではないが詩はパンセする人から生れる！",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してパンセとは現象に対する忠実さの過剰と言へる。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し自分自身の言語或ひは心象でパンセされて出来た主義なら、その主義は彼自身なのだから、その主義を守るも守らないもないものだ！",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠にパンセは言葉にたよる他、仕方ないものなのか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボードレエルの「旅への誘ひ」をデュパルクの作曲でパンセラが歌つてゐる古いレコードであつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンセは、ごついし、春夫の詩集は、ちかすぎるし、何かありそうなものだがね。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は三年ほど以前に自分が治療したパンセイという患者も、過激な仕事のために生命を失ったのだと主張している。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、彼は医者としてそういうふうに断定し得る権利を持っているので、パンセイの頭には亀裂が入って、そこから暗黒世界がほんのわずかばかり沁み込んだために、彼を死に至らしめたのだという私の説を一笑に付している。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パンセイは故国を長くはなれていたのが原因で死んだのだ」と、彼は言っている。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいつもヘザーレッグが往診に呼ばれて外出する時には、よくパンセイのそばに坐っていてやったが、ある時わたしはもう少しで叫び声を立てようとしたことがあった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはテオパルド・ジャック・パンセイという男で、一八八五年度の教養のあるベンガル州の文官で、自分では心身ともに健全だと思っている。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、パンセイ君。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもありがとう、パンセイさん」と、キッティは言った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジャック・パンセイというおれは、今シムラにいる。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは賜暇を得てシムラに来ているジャック・パンセイだ。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィアルドオ夫人は「従妹ベット」がパンセラスの仕事を督励したとは別の方法で、言葉で、宝石の沢山はまった奇麗な白い手で、恐らくはツルゲーネフの芸術活動と、その成功を刺戟し、部分的には精神的共働者でもあったであろう。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サント・ブウヴは、バルザックが「従妹ベット」の中のパンセラスに関しての芸術論で「客間で大成功をして、大勢の芸術愛好家に相談をされて、批評家になってしまった。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそこからはすぐパスカルの『パンセー』の世界にも行ける。",
              "citation": {
                "source": "フランス哲学についての感想",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パスカルのものは以前レクラム版の独訳で『パンセ』を読んだ記憶が残っているくらいであった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パンセ』について考えているうちに、ハイデッゲル教授から習った学問が活きてくるように感じた。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パンセ』は私の枕頭の書となった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パンセ』を初めパスカルのいくつかの作品が翻訳され、広く読まれている。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "……パンセ・ヴゥ（お察しねがう）ってとこよ。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はパスカルのパンセを読んだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてパスカルのパンセがはじめて了解できるようになった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、パンセ・ヴゥ（お察しねがう）ってとこよ。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
