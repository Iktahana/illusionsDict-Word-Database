        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「露西亜語なんか分らなくったっていゝや、――親爺のあとを継いで行きゃ、食いっぱぐれはないんだ、いつなんどきパルチザンにやられるかも知れないシベリアなんぞ、もうあき／＼しちゃった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この頃、パルチザンがちょい／＼出没するちゅうが、あぶないところへ踏みこまないように気をつけにゃいかんぞ！",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「パルチザンがやって来りゃ、こっちから兎のようにうち殺してやりまさ。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは馬賊か、パルチザンに相違なかった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒達は、パルチザンの出没や、鉄橋の破壊や、駐屯部隊の移動など、次から次へその注意を奪われて、老人のことは、間もなく忘れてしまった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森をくゞりぬけて奥へパルチザンを追っかけたことがある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車を顛覆され、おまけに、パルチザンの襲撃を受けて、あわくって逃げだしたこともある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これから、さき、なおどれだけ自分の意志の反してパルチザンを追っかけさせまわらされるか量り知れない自分にはうんざりせずにいられなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パルチザンと鉄砲で撃ち合いをやり、村を焼き、彼等を捕えて、白衛軍に引渡す、そういうことにあきてしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、ある時は、逃げて行くパルチザンを撃たずに銃先を空に向けた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソビエットを守るパルチザンの襲撃は鋭利になりだした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パルチザンはそこへつけこんできた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、何故、彼等ばかりが進んでパルチザンをやっつけに出しゃばらなければならないのだろう！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顛覆した列車の窓からとび出た時の、石のような雪の感触や、パルチザンの小銃とこんがらがった、メリケン兵のピストルの轟然たる音響が、まだ彼の鼓膜にひゞいていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、待ちかまえていたパルチザンの小銃と機関銃が谷の上からはげしく鳴りだした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　日本軍の攻撃が厳重になればなる程、パルチザンの怨恨と復仇は鋭利になった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、パルチザンは、枕木の下へ油のついた火種を入れておくだけだった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パルチザンでも、朝鮮人でも、日本人でも、誰でも、かれでも殺してよろこんで居る。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「橇」とか「パルチザン・ウォルコフ」などを見れば、これはすぐうなずける。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方の山からは、始終、パルチザンがこちらの村を覗っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにパルチザンの巣窟があることは、それで、ほぼ想像がついた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはパルチザンがいる。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつが、パルチザンと策応して、わざと道を迷わしとるのかもしれん。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道を探すだけでなしに、パルチザンがいやしないか、家があるか、鉄道が見えるか、よく気をつけてやるんだぞ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、パルチザンと同じだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本軍に追撃されたパルチザンが逃げのびてきたのだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォルコフのあとから逃げのびたパルチザンが、それぞれ村へ馳せこんだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げて行くパルチザンの姿は、牛乳色の靄に遮られて見えなかった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士達は、小屋にパルチザンがかくれていて、不意に捨身の抵抗を受けるかもしれないと予想した。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "通訳は、この村へパルチザンが逃げこんで来ただろう。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
