        "index": 1,
        "gloss": "(attractively) small face (esp. a woman's)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下卑た小顔がテーブルのドミノ牌のように蒼白だ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒りで小顔が真っ赤になり、白髪が布ブラシのように逆立っている。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、赤いしわくちゃ小顔をしかめている。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "日焼けした小顔が不安で真っ青になり、地面をじっと見て突っ立ち、コプリの言葉を待っていた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちが奥へ行くよりも、そっちが表へ出て貰いましょう」「そこがお話だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "むすこがおやじに電報をかけた、おれはちゃんと手帳へ書いておいたがね、」　じいさんは手帳を出して、それから大きなめがねを出してもっともらしく掛けてから、また云いました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学で教わった数学は、三角でも代数でも、いったいどこがおもしろいのかちっともわからなかったが、田丸先生に教わってみると中学で習ったものとはまるでちがったもののように思われて来た。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこがお悪くいらつしやいますんです。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "むすこがおやぢに電報をかけた、おれはちやんと手帳へ書いておいたがね、」　ぢいさんは手帳を出して、それから大きなめがねを出してもつともらしく掛けてから、また云ひました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庭の手入れをする植木屋でさえも、いったい、どこがお庭のおわりなのか、見当もつかないくらいだったのです。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろやっと、ここがおもしろくなりかけたのだもの。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もしそこがおもしろくなければ、今度は、べつの所へ行ってみようと思っていたのでした。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれだけがその水をのむなら話がわかるが、ほかのもんもみんなのむ井戸に、どうしておれが金を出すのか、そこがおれにはよくのみこめんがのオ。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこがお祖父さんの寝室です。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はア、お嬢さまが――」「まあ、祥子さまが……どこがお悪いの？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこがお好きなんですか……？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただほかのひいさまたちとおなじように、足というものがなくて、そこがおさかなの尾になっていました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは無造作に浮奔だの親不孝だと言うが、そこがおれにゃ、やっぱり解んねい。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしここがお互いに解しがたいことであるらしい。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども時が時で、おまけに張子の虎がなくなっているもんですから、なんだかそこがおかしいので……」「まったくおかしい、なにか訳がありそうだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここがおいらの根城なんだからな」男が、ブッキラ棒に答えた。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と突然戸外で事務長の、「ここがお部屋です」　という声がした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも……」「あの方のどこがお気に入らないの。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのご不審でのお越しならば、ここに一匹招きねこがおりますゆえ、ようごろうじませ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいきょうが元手でござんす、こういう招きねこがおるんでござんすと、親バカの新助が自慢したおまえじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしのどこがおかしいんですかよ」「そろいもそろってまぬけの穴があいているから、おかしいんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どこがおかしいんじゃ」「わたしはそんなつもりで、磨いていたわけではないんですが」「ではどんなつもりで磨いたというんじゃ」「こうやってぼんやり手を動かしておると、心持が馬鹿になれますから、それで磨いていたんですが」「またそういうことを言う！",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなはそのとおりの色男じゃあるし、べっぴんならばほかに掃くほどもござんすだろうに、あのまあ太っちょの年増のどこがお気に召したんですかい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしのどこがお気にさわったんですかい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこがお気に入らねえんです！",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
