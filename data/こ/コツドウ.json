[
  {
    "uuid": "dcbde3f6-d3b4-5818-a018-4a1a54f824a3",
    "entry": "骨堂",
    "reading": {
      "primary": "こつどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "charnel house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "墓地の円屋根、納骨堂、また、反青き塔のつま。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ即ち觸手ある大都會、貪婪の蛸に比すべし、骨堂なり。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "学術雑誌で名前を知っている偉い博士たちの研究室が、納骨堂の中でもあるかのように同じ形をしてうちならび、白い大理石の小さい名札の上にその研究室名が金文字で記されてあった。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "長年教会へ通いつめているので、納骨堂や祭具室の冷たい匂いがその衣類にまで浸みこんでしまったのであろう。",
              "citation": {
                "source": "老嬢と猫",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は姉の子供の娘一人と定雄の子供の長男次男と、それに定雄夫妻に姉、総勢六人で父母の骨を納めてある大谷の納骨堂へ参った。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同｜揃って上に登り、納骨堂へ参拝して、それからいよいよ本堂で経を上げて貰わねばならぬのであるが、誦経の支度のできるまで六人は庭向の部屋に入れられた。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また京都の街を見降す位置にある本願寺の納骨堂に父の骨を納めることは、この街に電力を送っている宇治川の水電を成就させた父の心も安ませることだと思ったが、幸子には、その灯も涙の種になるのかもしれないと思ったりした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮池に懸った石橋を渡って納骨堂の石段を登って行くときも、矢代は稀に見る槙三の端麗な精神について千鶴子に賞讃した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーモンの塁砦を東北に見はるかす高地の上に素晴らしく大きな蒲鉾型の納骨堂が横たわり、その中央に高い燈台塔が立っている。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "納骨堂の中には、身内の人たちでもあろうか、花などを持った参詣者も少からず見受けられた。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くに納骨堂の白い丸屋根が見える。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして苦悩に満ちた生涯は終り、湯呑のやうな恰好をした病院製――患者が造つてゐる――の骨壺に骨の切れ端が二三個納まつて、ハルちやんが抱へて行つたやうに、納骨堂の棚の上に並べられる。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前の夕方、納骨堂のあたりで暫く雲を眺めてからそこを通ると、Ｙ君が私を呼んで、牛乳を振舞うてくれた。",
              "citation": {
                "source": "牧場の音楽師",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向うは広々とした農園と果樹園になつてゐ、青々と繁つた菜園の彼方に納骨堂の丸屋根が白く見え、近くには焼場の煙突が黄色い煙を吐いてゐる。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "木造の背の高い古ぼけた各教室は、納骨堂が化けているようであった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ただ、巴里への旅行者が、必ず一度はエッフェルへ昇るように、羅馬へ来る人は、初代｜基督教徒の地下街と、カプツィニの人骨堂と、ベニト・ムッソリニだけは、誰でも、旅程の第一日に据えて参詣して行くものですから、きっとあなたも、クイリナアレ政庁への訪問者に相違ないと思ったまでのことです。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "一際こんもりと生茂った林の間から寺の大きな屋根と納骨堂らしい二層の塔が聳えている。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "又次には、瀬戸内海を見おろす眺望絶佳の丘の上にある立派な納骨堂であつた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼はわたくしの手を握り、電灯を担ぐと、そのまま納骨堂の中に消えて行きました。",
              "citation": {
                "source": "墓場",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お参りなら、管理事務所に頼んで、納骨堂に案内しておもらいなさるとよござんすよ」　教えられた通り、管理事務所の扉を開けた。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "机を前に調べものをしていた管理人に来意を告げて納骨堂への案内を頼んだ。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "納骨堂は別棟になっていて、椎や樫の老樹の間に、まるで土蔵のような形に建てられてあった。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日ばかり前になりますが――、あの日、あの荒れの真最中に御夫婦連れの方がお見えになって「小田切の親類の者だが、今日｜故郷へ帰るについて暇乞かたがた参詣に来た、是非納骨堂に案内して欲しい」と申したそうでございます。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分にもあの暴風雨の最中なので、荷物の置場に困り、納骨堂の入口に持って行ったそうでございます。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴風雨の日納骨堂で見た小田切大使の遺骨、たしかにそれに違いない。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どうにも不安でならなかったものですから、納骨堂にあるお遺骨を異物と思わせようと苦心した結果、あなたにお目にかかったあの暴風雨の日などは、女優をしている従妹に涙を流す役をつとめさせたりしたのです。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言でいえば、床はまさに一種の納骨堂と言ってよく、幼児の――ごく近年のものもあったが、それ以外はほぼ崩れ切ったものにまで至るあらゆる時代を網羅していた。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのキュクロプス式納骨堂では照明なしにいられるものではないから、深淵の調査のためにはこれ以降の彫刻の解読を諦めざるを得なかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
