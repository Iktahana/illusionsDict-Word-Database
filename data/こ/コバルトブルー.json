        "examples": {
          "standard": [
            {
              "text": "南国のリゾート地で、コバルトブルーの海を眺めながらのんびりと読書を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は愛車をコバルトブルーに塗装し、週末になると海岸線をドライブするのが日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このカクテル、コバルトブルーでとっても綺麗ね」と彼女はグラスを傾けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "またアメリカ人は“青くなる”といった私の答えに，頬にベッタリとコバルトブルーやウルトラマリンの絵具をなすりつけたとんでもない顔を連想したのかも知れません。",
              "citation": {
                "source": "“青い顔”",
                "author": "間所紗織",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓からコバルトブルーの光が夕方の薄暗い空間に浸透し、部屋の中の事物を青白く染めていた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
