        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ディス・プログラム・イズ・コンパイルド・バイ・ケイ・アンド・ユアーズ・トゥルーリー、キープ・ユア・ヘッド・アップ、ティル・ネクスト・サンデイ、バイバイ」　ワラのあいさつが終わると、〈バルボア・ブルー〉が大きくなり、二〇秒ほどでフェイドアウトした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "バグが見つかるたびに、プログラマーはソースコードに戻って修正を行い、再びコンパイルと呼ばれる機械語への変換、さらにロードモジュールの作成を繰り返す必要がある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
