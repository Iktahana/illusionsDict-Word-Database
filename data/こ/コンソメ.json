        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "厨房一同入寮晩餐会メニューチキンコンソメ　　アスパラガスのサラダマッシュポテト　　ヒラメのソテコールドミート　　パンデザートはバニラアイスクリーム　慶一は、「厨房」という字を、とりあえず「とうぼう」と読み、コックかなんかの意味だろうと考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三はやがて食事を部屋へ持ちこませて、フォクを執ったが、葉子はコンソメの幾匙かを啜って、オレンジを食べていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤枝と私はほんとうにくつろいだ気もちでコンソメのスプーンを取つた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでここに偶然が非常な働きを見せている」　藤枝は手早くコンソメを片付けて次に出て来た伊勢海老をほほばりながらつづけた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "穢ないといえば穢ないが、その触感は、朝湯のコンソメよりもすてがたい味を持っている。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十日　月　ツウェトヌイ〔並木街の名〕のルイノクへ出かけてトリを買い、ストラスナヤから歩いて来て卵を十、４р で買い、家にかえってから油橋さんのところへ行ってきのうたのんだスハリをもらい、ブリオン〔コンソメスープ〕作ることをたのんで来た。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯はコンソメーに、パンとチースで平げた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "スープといっても、透明なコンソメの方である。",
              "citation": {
                "source": "風土と伝統",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが家の例に見ても、若い子たちがもっぱら言うのは、ポタージュやコンソメについてである。",
              "citation": {
                "source": "押入れ随筆",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんとした、うまいコンソメだった。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京で食うのは、魚翅もカタマリのまんまのや、それの澄汁のような、コンソメのようなの、又は、ポタージュに近くても、濃度も足りないし、色々な、オマケの如きものが混入していて、つまらない。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、これから、先ず、オードヴルから、スープは、コンソメ、ポタアジュの二つを平げ、順々に十数種を食うことになるのである。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、スープの部へ入ると、２は、ポタアジュで、３が、コンソメである。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、僕のところへだけ、スープが、コンソメから、ポタアジュと運ばれるので、「おや？",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンソメ、ブフ・アラ・モドみなお軽少で腹が張らない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カットのおかげで四時十分にハネたので、ホテ・グリへ菊田と上山で行き食事、コール・コンソメにポークビーンズ、スチュウ・コーンといふ変り方。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュもコンソメも。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たいコンソメにレモンジュースを入れたのが先づ美味い、白い魚のコキールとビフテキを食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チアコンソメとオルドヴル、ミニツステーキを食って座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルニューグリルへ行き、コンソメ、キスのフライと犢のエスカロップを食った、犢の大きさには参った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンソメとスパゲティと肉の煮込み、うまかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールコンソメとソーセージサワクラウト、ソルベー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷映画へ涼みに入る、ニュースと一本見て、丁度逢った徳山とホテルのグリルへ行き、夕食、コールコンソメ、コールドラブスター、カネロニー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのグリルで那波支配人と会ひ、コールコンソメ、フィレソール、コールビーフ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールコンソメに、フィレソール、オックス・タング、キャビネットプディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためコンソメ、ヴィール・ピカタにアスパラガス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューグリルへ、オルドヴル、コンソメにビフカレーライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "速水氏とその妹、川口・三益を招待し、おやぢ自慢の料理食はせる、コンソメに魚のグラタンとビフテキにカレーライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンソメにフィレソール、チキンコロッケ、何を食っても、Ｍ・Ｍの食事以来うまいと思へなくなっちまった、不幸であるかも知れない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ腹が定かでないから、コンソメとサワラのグラタン、トースト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
