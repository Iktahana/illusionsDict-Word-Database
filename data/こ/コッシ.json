[
  {
    "uuid": "d65d6bf8-f8ee-51c9-abfa-0f465677251c",
    "entry": "骨子",
    "reading": {
      "primary": "こっし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
