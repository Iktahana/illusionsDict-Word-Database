[
  {
    "uuid": "c1006f60-8275-5693-911d-7452326ee99d",
    "entry": "狡兎",
    "reading": {
      "primary": "こうと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
