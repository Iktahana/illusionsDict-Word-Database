      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "smart rabbit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『本草啓蒙』に「兎の性｜狡にして棲所の穴その道一ならず、猟人一道を燻れば他道に遁れ去る、故に『戦国策』に〈狡兎三窟ありわずかにその死を免れ得るのみ〉という」。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一向｜埒明かずとあってカリブ人、また鼠を遣わすとこやつ小賢しく立ち廻ってたちまち獏の居所を見付けたが、獏もさる者、鼠に向いわれと同類の汝がわが食物を得る場を垢の他人の人間に告げたって、人間ほど薄情な者なければ、トドの詰まりは狡兎死して良狗煮らるだ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパ大戦に於てはヨーロッパの交戦国の女性は、男性の手不足のために生産労働にかり出されたが、併し狡兎死して走狗烹らるの譬えの通り、資本の必要から見て不用になった彼女達は、忽ち家庭へたたき戻された。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "誘わない中から撃退です」「ハッハヽヽ」「僕はこんなに邪魔にされる積りで奔走したんじゃありません」「狡兎死して走狗煮られ……」「はあ？",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "忙しいんだ」「狡兎死して走狗煮らる」「何だい？",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と問われて、さあ、それは、一口でこうと説明は、どうも、その、と大いに弱っていたようであったが、むりもないことと思った。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹の苦しみを見かねて、私が、これから毎日、Ｍ・Ｔの筆蹟を真似て、妹の死ぬる日まで、手紙を書き、下手な和歌を、苦心してつくり、それから晩の六時には、こっそり塀の外へ出て、口笛吹こうと思っていたのです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻燈を見に行こうと囁いたのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうこれから先方へ、申込みに行こうと思っているのですが、あなたのところに大隅さんの最近の写真がありませんか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば町へ行こうとして家を出る時、反対の森の方へ行ってるのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうところに敵なくして剣の力で信仰と権勢を植え付けて行った半生の歴史はそれほど私の頭に今残っていないが、全盛の頂上から一時に墜落してロシアに逃げ延び、再びわずかな烏合の衆を引き連れてノルウェーへ攻め込むあたりからがなんとなく心にしみている。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　山上において、積雪がどういう状態をしているかという事は、下界の人々には解らぬことであるから、最後にこれを説こうと思う。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風だったから、瀬戸内海などを航行する時、後ろから追い抜こうとする旅客船や、前方から来る汽船や、帆船など、第三金時丸を見ると、厄病神にでも出会ったように、慄え上ってしまった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が三毛猫だけ連れてもう一匹の玉の方は置いて行こうと云ったら、子供等がどうしても連れて行くと云ってバスケットかなんかを用意していた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方から、そのなかのＳというプロレタリア党が「俺達の教会」へ私を連れて行こうと言うのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "福慈の神に出会い一目それをわが娘と知るや無我夢中になってしまって、矢庭に掻き抱こうとした旅塵の掌で、危うく白妙の斎の衣を穢そうとして、娘に止められて気が付いたほどである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神はさすがに、それとすぐ感じ取り、啓示を聴く敬虔な態度で、両の掌を組み合せ、篝火越しに聴こうとする。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁はこの茂みの下にしばらく憩って、疲れを癒やして行こうと思った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば思うほどひとり壁立｜万仭の高さに挺身して行こうとする娘の健気な姿が空中でまぼろしと浮び、娘の足掻く裳からはうら哀しい雫が翁の胸に滴って翁を苦しめた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて始めて、日々の糧の心配なく、専心に書物の中のことと、実験室の成績と突き合せながら、使える部分を自分の工夫の中へ鞣し取って、世の中にないものを創り出して行こうとする静かで足取りの確かな生活は幸福だった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂鬱な顔をしながら、根に判らない逞ましいものがあって、稽古ごと一つだって、次から次へと、未知のものを貪り食って行こうとしている。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツの農夫は馬に近よって頸を平手で叩こうとしました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなそこまで行こうと云うのか。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだまって籠を提げて向うへ行こうとしました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは行こうとしました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども元来私どもはイギリス海岸に行こうと思ったのでしたからだまってそこを通りすぎました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの救助係の大きな石を鉄梃で動かすあたりから、あとは勝手に私の空想を書いていこうと思っていたのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板を見てわらっていました、それから繭を売るのが済んだら自分も行こうと云うのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兄さんは向うへ行こうとして、振り向いてまた云いました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし部音は音色の形を取って簡明な把握に背こうとする。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
