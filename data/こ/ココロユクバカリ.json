    "definitions": [
      {
        "index": 1,
        "gloss": "to one's heart's content",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
