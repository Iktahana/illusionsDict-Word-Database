        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんな事を考へながら一椀の鯉こくをすゝつてしまつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を考えながら一わんの鯉こくをすすってしまった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鯉こくにするとうまいぜ。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは鯉こくであつた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだんでせうか、あの鯉は、」「あれは、先生に肉を御馳走した鯉でございますわ、」「えツ、」「いゝえ、先生は、今晩宿で鯉こくを召しあがつたでございませう。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川を見晴らした中二階で、鯉こくと鯰のすっぽん煮か何かを喰わされて、根が悪党でもない長助は、何もかも正直に話してしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼び寄するも、手間取る次第なりとて、裸男專斷にて、鯉こく、鯉のあらひ、蒲燒、椀盛の四品を誂へたり。",
              "citation": {
                "source": "川魚料理",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれとろゝ汁よ鯉こくよとわが若草の君をいたはり励まし作りあげられた御馳走に面々悉く食傷して昨夜の勢ひなくみなおとなしく寝てしまふた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは鯉こくであった。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだんでしょうか、あの鯉は」「あれは、先生に肉を饗応した鯉でございますわ」「え」「いいえ、先生は、今晩宿で鯉こくを召しあがったのでございましょう、このあたりは、鯉が多いものですから、宿屋では、朝も晩も鯉づくめでございますわ」　女はこう云って惚れ惚れする声を出して笑った。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、今晩は洗いに鯉こくよ」　絶大な希望で彼女は出かけるのだ。",
              "citation": {
                "source": "この夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜は山中の旅行に餓えていた美味、川魚のフライ、刺身、鯉こく、新鮮な野菜、美しい林檎、芳烈な酒、殆んど尽くる所を知らず四人して貪った。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "放牧　其夜は山中の旅行に餓ゑてゐた美味、川魚のフライ、刺身、鯉こく、新鮮な野菜、美しい林檎、芳烈な酒、殆んど盡くる所を知らず四人して貪つた。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "沓掛に来ましては、魚類が不便なので、牛肉の罐詰や佃煮や、時にはすぐ側の旅館にたのんで鯉こくなどを、朝から食べました。",
              "citation": {
                "source": "食慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目に鰥と鯉こくが出来たというので岡持へ入れて持って来る、是から酒をつけて橋本幸三郎が此の婦人の身の上を問います、これは後に申上げます。",
              "citation": {
                "source": "霧陰伊香保湯煙",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり鯉の濃漿のような訳で」妻君「アラ鯉こくもそうですか」お登和「鯉こくもその日に食べると詰まりません。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "向は鯛のあらい、汁は鯉こく、椀盛は若※と蓮根、焼物は藻魚の空揚げ、八寸はあまご、箸洗い、という献立だった。",
              "citation": {
                "source": "ユモレスク",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのごたごたした横町をはいったところに、鯉こくで有名な川半という料理屋があった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村俊子さんがアメリカからかえって来て、この間の雨の日、浦和の田舎の名物の鯉こくをいろんなひとと食べにゆき、いろいろ話し、大変面白く感じました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは鯉の洗いと鯉こくを出しましたが、お母さんこれもやはり「旅にしあれば」召上った由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "運ばれて来た食事は、山女魚の田楽に鯉のあらい、甘煮と鯉こく、卵焼などであった。",
              "citation": {
                "source": "追いついた夢",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なつさんこのあいだの鯉こくは残っていませんかね」　衣巻は初めのうちはそんなふうに云ってよくおなつをまごつかせた。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "納所用の朱い椀に、手製の鯉こくの味噌のにおいや、八助が寺の小流れで洗いあげた作り身などが添えられて出る。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
