[
  {
    "uuid": "9fa77c03-8286-5e16-95b5-f444f756dc16",
    "entry": "神月",
    "reading": {
      "primary": "こうづき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
