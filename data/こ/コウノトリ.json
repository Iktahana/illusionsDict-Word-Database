    "definitions": [
      {
        "index": 1,
        "gloss": "stork (esp. the Oriental stork, Ciconia boyciana)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
