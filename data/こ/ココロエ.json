[
  {
    "uuid": "5258af9c-c436-5aa7-9569-f55d9119da91",
    "entry": "心得",
    "reading": {
      "primary": "こころえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
