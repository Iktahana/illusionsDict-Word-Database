    },
    "definitions": [
      {
        "index": 1,
        "gloss": "knowledge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どういふつもりで付けたのかまだ訊ねてみないが、僕が勝手に想像する所では、無口でそつとしておいて貰ひたい男が、誰でもが多かれ少なかれ感じてはゐても余りに底深い、流れだとして殆んど全く触れないで過ぎる態の非情を、人目にも立たず浚渫してゐるといつた風の心得であらうと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主を何と心得ている、馬鹿にするな！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も該ノートの論旨を心得てゐれば心得てゐないよりは幾分宿命をいい方に転向させることが出来るといふものであらう。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事なしかもかなり六かしい事柄の核心を平明にはっきり呑込ませる術を心得ているようであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀さんは鳥や魚の世界の秘密をすっかり心得ているように見えた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御住所を搜し、こちらからお訪ねして、なほ精しく故人の御遺徳をも伺ひ、それから、私ごとき非文不才の貧書生に、この活字日誌の使用を御許可下さるかどうか、改めてお願して、そのおゆるしを得て、はじめて取りかかるべき筋合ひのものであるとは、不徳の小文士と雖も、まづは心得て居りました。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかかる純粋と深刻さで執り行う祭を、修業としての心得を、翁は東国へ来て生い立った娘の神からして始めて聞いた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その十二）直次は其夜の闇にまぎれて、松川屋敷を出ぬ、明けて驚きし佐助夫婦が、常は兎角に小言もいひけれど、いかに定めて斯かる仕義と流石に胸やすからねば評議とり／″＼に、おそよは朝な／＼手を合する神々にも、心得違ひの無きやうにと祈りぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一説によれば chicane の略で裁判沙汰を縺れさせる「繊巧な詭計」を心得ているというような意味がもとになっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "論理の糸を手繰って闇黒な想像の迷路を彷徨しているうちにどこかで新しい出口を見付け、そこで事実の日光にまともに出くわすまでは何事も主張する権利はない事を心得ていなければならない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "震源とは何を意味するか、また現在震源を推定する方法が如何なるものであるかというような事を多少でも心得ている人にとっては、新聞紙のいわゆる震源争いなるものが如何に無意味なものであるかを了解する事が出来るはずである。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭の主人公なるが如く心得、家庭の事は、男子の片手間の事業かの如く考えて居るのが、今日家庭を説くものの理想らしいが、これが大間違の考と云わねばならぬ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば第九十二段に弓の修業の心得から修道者の覚悟を説くのでも、直ちに移して以て吾等科学研究者の坐右の銘とすることが出来る。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間に立交わって人とつき合うときの心得を説いたものが案外に多い。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも当代世相レビューの一景と思えば面白くもあったが、天下の早慶戦の日に落着いて連句などを作ろうとするものの不心得を自覚したので、ふと思い付いて二人で東宝劇場へ出かけることにした。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的常識というのは、何も、天王星の距離を暗記していたり、ヴィタミンの色々な種類を心得ていたりするだけではないだろうと思う。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "典六が「よし心得た」と五郎蔵に、Ｔ「では、明日芝居が　果てたら仲蔵を　柳島の妙見へ　誘き出そう」　お光の驚き！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉暫時雪枝の名を呼んだが遂に息絶えたと知ると静かに其処に寝かし、今更後悔の念に絶えず、Ｔ「心得た！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳尚も近侍に、Ｔ「早速御手配なされとな」　近侍心得て去ろうとする。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎心得て袍褞の儘、大悦びで、今しも殿様が、文六に金子を与えんとする時、　ヒラリと二階から、その中へ、とび下りた団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "只太陽の方が煖炉より余程廉価だと丈は心得てゐる。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "貝原は夏中七八｜遍も小初を踊りに連れ出したことがあるので、ちょっとした小初の好きな喰べものぐらい心得ていた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　が、彼は、軍隊の要領は心得ていたので、本当の自分の心持は、誰れにも喋らず、偽札に憤慨したという噂は、流れ拡がるにまかせて、知らん顔をしていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "握手と同時に現われる、相手の心を読むことを、彼は心得てしまった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田原は大都會と心得て居る田舍娘！",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "水車は川向にあつて其古めかしい處、木立の繁みに半ば被はれて居る案排、蔦葛が這ひ纏ふて居る具合、少年心にも面白い畫題と心得て居たのである。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "水車は川向にあってその古めかしい処、木立の繁みに半ば被われている案排、蔦葛が這い纏うている具合、少年心にも面白い画題と心得ていたのである。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここをなんとこころえる。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに就いて少し話がある」　云いかけて甚右衛門は眼で知らせると、酌に出ていた女中はこころえて、早々に座を起って行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで日常｜茶飯事のようにこころえているのだから、いささかも、かれにすまないと思う必要はないわけである。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
