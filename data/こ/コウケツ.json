[
  {
    "uuid": "b0704b3e-929d-52b2-b591-2794d3095e53",
    "entry": "高潔",
    "reading": {
      "primary": "こうけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
