    "definitions": [
      {
        "index": 1,
        "gloss": "universal life force",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "思無邪であり、浩然の気であり、涅槃であり天国である。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして浩然の気を養っております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は小坪に柴門を閉じ、城市の喧塵を避けて、多日浩然の気を養う何某とかやいえる子爵なり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、佐助を喜ばしたのは、師もまた洒落るか、さればわれもまた洒落よう、軽佻と言うならば言え、浮薄と嗤うならば嗤え、吹けば飛ぶよな駄洒落ぐらい、誰はばかって慎もうや、洒落は礼に反するなどと書いた未だ書も見ずという浩然の気が、天のはしたなく湧いて来たことであった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟子（中国、戦国時代の儒学者）のいわゆる浩然の気のようなものは、この間の消息を語っているものと理解できる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "至大・至正・至公・至明の道と我とを一致させるのが、即ち浩然の気を養う根本である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古今偉大の人、賢聖の人々、誰が浩然の気を養わない者があろう、皆良く浩然の気を養い得ている人である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "くよくよせんと、浩然の気を養つておけ。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "青瓢箪のような顔をしている青年ばかりこしらえちゃ、学問ができて思想が高尚になったって、なんの役にもたたん、ちと若い者は浩然の気を養うぐらいの元気がなくっちゃいけませんなア」　などという。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "また半夜何ということなく宇宙を観じて浩然の気を養うた孟子に取っては森羅万象悉く教育家であろう。",
              "citation": {
                "source": "教育家の教育",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち我が精神を自信自重の高処に進めたるものにして、精神｜一度び定まるときは、その働きはただ人倫の区域のみに止まらず、発しては社会交際の運動となり、言語応対の風采となり、浩然の気外に溢れて、身外の万物恐るるに足るものなし。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も孟子の云いし浩然の気に等しく、之を説明すること甚だ難しと雖も、人にして苟もその気風品格の高尚なるものあるに非ざれば、才智｜伎倆の如何に拘わらず、君子として世に立つべからざるの事実は、社会一般の首肯する所なり。",
              "citation": {
                "source": "〔気品の泉源、智徳の模範〕",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう御難儀を遊ばしていらッしゃるんでげすから、港々にお着遊ばしたときは些とは浩然の気もお養いなさらずばお身体が続きますまい。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがつまり、浩然の気といふんだよ。",
              "citation": {
                "source": "屋上庭園",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "見はるかす田ンボのまんなかじゃ、白ハチマキの工員さんは、浩然の気を養うに手もなく、もっぱら精神修養につとめなければならなかったろう。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういうものを見て感じるのは、日本の家庭の暗さということで、婆さん連が浩然の気を養うのを咎めたいような気持は起らなかった。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "「浩然の気を養うという大人の風格があるよ」　と、感心したのか、ひやかしたのか、わけのわからないことを長平が言うと、せつ子はなさけなそうに苦笑して、「ゴキゲンとりむすぶの、つらい。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟子の浩然の気、助長の害を論ずるを見るべし。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの小供があまり騒いで楽々昼寝の出来ない時や、あまり退屈で腹加減のよくない折などは、吾輩はいつでもここへ出て浩然の気を養うのが例である。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川から舟を一艘雇うて――私はこの前の日曜に行きました」「何か釣れたかい」「何も釣れません」「釣れなくっても面白いのかい」「浩然の気を養うたい、あなた。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣営でさえこの調子であったから、浩然の気を養うと称して、付近から遊女をかき集めて酒宴深更に及び、桃源の夢に耽っていた侍たちは、ほとんど半狂乱であった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃で彼は忽ち仲間の放浪芸術家たちを呼び寄せ、カフェからカフェへ居酒屋から居酒屋へ、久々で盛大なる「宴会」を催おし浩然の気を養った挙句、単独でモナコへ渡り、賭場モンテカルロですっからかんになると、突然日本に郷愁を感じたものか、再びもとの懐しい紡縷を纏うて、孤影｜瀟然として帰来したのである。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "その和一郎にしろ、先月、伸子がきいたオペラについてモスク※の劇場広場のエハガキを書いてやったことにはふれていないで、今年は美術学校も卒業で卒業制作だけを出せばいいから目下のところ大いに浩然の気を養ってます、と語っている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一面には、士気を疲らせないために、時折、軍馬を休め、浩然の気を養わせて、長期戦を期していた。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男児たる者がしんそこ浩然の気をやしなえるというのはかの女性のごときを措いて他にはないだろうな。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つきあってと言うと、俺が風巻を誘ったみたいだが、「浩然の気を養おう」　ピー屋へ行こうと最初に言い出したのは、風巻のほうなのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁者の心得をのべたものです」「ははあ」「舟遊びは浩然の気を養うからよろしい」「先生、浩然の気ってなんでございますか？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経衰弱にでも罹らなければ浩然の気は養えない。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
