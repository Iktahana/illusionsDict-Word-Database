    "definitions": [
      {
        "index": 1,
        "gloss": "childish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恐らく二十一歳の青年の子供じみた陽気さと見たことだろう。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした私の子供じみたせんちめんたりずむをお笑ひ下さるな。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供じみた此の図柄と、色の鮮明さと、そのスケールの大きさ（全く途方もない大きさ）とが、私を茫然とさせた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ出て戦に加わろうという子供じみた誘惑に勝たねばならぬ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリヴァア・トゥイストは、何という子供じみた家庭小説であることか！",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（此の少年は恥しがりで、神経質だわ）しみじみと見上げると、豹一の子供じみた顔の中で一個所だけ、子供離れしたところがあった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一の子供じみた頭や、むやみに上着の袖の長い如何にも新入生らしい服装をなめて掛かったのか、委員は、「推戴式に出ないと、承知せんぞ！",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの人たちは――君の父上でも、兄妹でも、隣近所の人でも――ただ不思議な子供じみた戯れとよりそれを見ていないのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は早く早くここを切り上げて日本に帰りたいという子供じみた考えのほかには、おかしいほどそのほかの興味を失ってしまって、他郷の風景に一｜瞥を与える事もいとわしく、自分の部屋の中にこもりきって、ひたすら発船の日を待ちわびた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒直な明らさまなその目にはその場合にすら子供じみた羞恥の色をたたえていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の恋も、それに伴ういろんな興奮や悩みも、いま新たに出現した未知の何ものかの前へ出すと、我ながらひどく小っぽけな、子供じみた、みすぼらしいものに見えた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自身の子供じみた僻みっぽい魂情を、いくらか悔いてもいたが、とかく苦悩と煩いの多いこの生活を、一気に叩きつけるのも、彼女に新らしい恋愛もまだ初まっていない、こんな時だという気もしていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供じみた脅嚇に過ぎないのを愧ぢてゐたけれど、そんな事を遣りかねない野獣性が、どこかに潜んでゐるやうにも思へた。",
              "citation": {
                "source": "風呂桶",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "――考えて見ると消極的とか積極的とかいう言葉はどんな風にでも使えるので、丁度、良いとか悪いとかいう評価が子供じみたものであるように、之も一種の小児的感傷の形容詞にすぎない。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへまた、これくらいな嚇しに乗せられて、尻込みするような自分ではないと云う、子供じみた負けぬ気も、幾分かは働いたのであろう。",
              "citation": {
                "source": "西郷隆盛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま考へてみると、それはむしろ私の子供じみた驚きのためだつたのだらう。",
              "citation": {
                "source": "二三の追憶",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私がもう一度、『じゃ君は彼等のように、明治の世の中を神代の昔に返そうと云う子供じみた夢のために、二つとない命を捨てても惜しくないと思うのか。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、笑いながら反問しましたが、彼はやはり真面目な調子で、『たとい子供じみた夢にしても、信ずる所に殉ずるのだから、僕はそれで本望だ。",
              "citation": {
                "source": "開化の良人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これは、子供じみた、ばかげた、下らない思想です。",
              "citation": {
                "source": "坂田の場合",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな、そんな、子供じみたことを」　私は顔をあげた。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "極端な例は、英語で書かれた書物を地上に投げつけて、快哉を呼ぶといふやうな子供じみたことです。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "道平は房一の後についてこの何もない座敷に入つて来たが、やはりあの子供じみたもの珍しさの色は消えなかつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせいつか話さなければならないのなら――と思いながらも、撫子のまだ余りに子供じみた身体つきや、もううすうす頭の君の求婚の事を勘づいていて、私からそれを聞かされるのをそれとなく避けているとしか思えない折々の羞かしそうな様子だのを見ると、私にはどうしてもその話が持ち出せないのだった。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まったく、いつまでたっても子供じみた女房だよ」　仁科六郎は蓬莱建介に心の中で感謝した。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の子供じみた皮肉や嫌味も、笑ってきき流し、冗談や街でみた事件を面白おかしく喋ったり、父の絵をほめたり、とにかく、玄関を一歩はいれば、私はすっかり自分をある仮面でつつんでしまうのです。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらない、ふざけた、子供じみたいたずらをして見せたものだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなところへ立ち寄りたいような子供じみた、オモチャを弄ぶような心理はないらしく見えらア。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、もうこんな子供じみたくだらないことはやめましょう」と、ヘルマンは彼女の手をとりながら言った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            },
            {
              "text": "浩三　　おい、おい、よしてくれ、子供じみたことを云ふのは……。",
              "citation": {
                "source": "傀儡の夢（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "克子はそんな子供じみた仕返しに興味がなかった。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
