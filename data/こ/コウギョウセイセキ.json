    "definitions": [
      {
        "index": 1,
        "gloss": "box-office record",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかもその興行成績は日清戦争当時の如くならず。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○戦争の影響にて、各劇場の興行成績思わしからず。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから李香はやはり包孝粛を売物にして、各地を巡業してあるくと、広東の一件がそれからそれへと伝わって――もちろん、本人も大いに宣伝したに相違ないが、到るところ大評判で興行成績も頗るいい。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって「湯屋髪結床の噂」なるものが、芝居の興行成績にも直接間接の影響をも及ぼしたのであるが、現今は殆んどそんなことは無い。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時は中幕に「鎌倉三代記」が出て、菊五郎の三浦、福助の時姫、芝翫の佐々木という顔揃いで、それも一つの呼び物となった為か、興行成績は頗る好かった。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "知盛はそれほどにわたしを敬服させたが、少年の敬服や感服は当てにならないものと見えて、その芝居の興行成績はあまり思わしくなかったということを後に聞いた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体にその頃の各劇場は興行成績がいつも思わしくなかったらしい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして現在のところではまだ興行成績に関しては何らの寄与もなし得ない人たちのほうがもうけすぎているのだという事情を十分理解しなければいけない。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "興行成績は思はしくなかつたさうだが、当時殆水の出端と言ふべき盛りの政治郎の、八重垣姫の美しかつたことは、伝説のやうに言はれてゐる。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京へ　房枝たちが養われている新興ミマツ曲馬団が、今後うまく立ちなおって、よい興行成績をあげるようになるかどうか、それは団員たちにとって、生きるか死ぬかの大問題だった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、一般の商業劇場は、歌舞伎劇以外に新しい現代的通俗劇の樹立によつて興行成績の向上を計るべきです。",
              "citation": {
                "source": "演劇漫話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本映画も、いろいろと困難と戦ひながら、ともかくも、やゝ見るべきものが作られるやうになり、その興行成績も常にわるいわけではないと聞くにつけて、時代も徐々に移りつゝあるのだといふ感じがする。",
              "citation": {
                "source": "日本映画の水準について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大物主義」で行くのが興行成績をあげる唯一の道だと思つてゐるからである。",
              "citation": {
                "source": "新劇の大衆化",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "此二つの劇団は一旦松竹の手を離れましたけれども、今日では十分興行成績を挙げて居りますので、松竹が更に之に臨時に劇場を貸して興行させる。",
              "citation": {
                "source": "日本演劇の特質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（興行成績はそれにもかかわらず、日劇のレコードを破っている。",
              "citation": {
                "source": "映画のもつ文法",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考へでは、やりやうによつて、可能だと思ふが、第一回は慎重に興行成績をある程度まで挙げようといふ意図なら、なるほど、真船豊の「いたち」でさへもちよつと危険かも知れぬ。",
              "citation": {
                "source": "劇文学は何処へ行くか",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも、興行成績は、今の時勢では、平凡といふところが関の山であらう。",
              "citation": {
                "source": "劇文学は何処へ行くか",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "『彼岸花』は興行成績もよかったようだが、あれだけのスターを揃えれば、大当りするのが当り前なので、会社ももとよりそこに安全性を考えていたわけだ。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画の出来がよくて、その上興行成績がよければ、それに越したことはないが、若い頃には、興行性と芸術性とは相反するものだと、私は考えていた。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸なる吉良上野　恩讐の夢は、あとかたもなく消えて、早くも三百年が過ぎようとしてゐるのに、「忠臣藏」の人氣と興行成績が殘した遺産は、雪の夜に松坂町で殺された吉良上野に對する侮蔑と憎惡となつて徐々に形をあらはしてきた。",
              "citation": {
                "source": "生きている忠臣藏",
                "author": "――忠臣藏は何故流行するか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅田映画劇場へ寄り、「子守唄」の後半を見る、あまり興行成績は、よくないさうだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
