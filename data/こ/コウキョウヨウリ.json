          "literary": [
            {
              "text": "公教要理は滑稽だったし、神父の説教は矛盾していた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隣の部屋では公教要理のお話が始まっているらしい、大きな子供と修道女との問答。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "公民館の入口には、公教要理のけいこに少年たちが百人ばかり集まっている。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "公教要理を改訂する、祈祷書に赤筆を入れる。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "カトリック教会では、「公教要理」というものを教えられるが、聖書は教えられない。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に、「公教要理」はカトリック教の公定の教義を述べたものであって、その範囲を出ることはカトリック信者には許されない。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
