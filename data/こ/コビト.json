    "definitions": [
      {
        "index": 1,
        "gloss": "little person (in folklore and fantasy, e.g. fairy, elf, gnome)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いくら小人島の蚊でもこんな細かい目を潜って侵入する奴はあるまい。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀の小人が立ってゐる。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　原のむかふに銀の小人が消えて行く。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人の小人数で、日本兵が街を歩いていると、武器を持ったアメリカ兵は、挑戦的につめよって来た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ユフカ村から四五露里｜距っている部落――Ｃ附近をカーキ色の外皮を纏った小人のような小さい兵士達が散兵線を張って進んでいた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその衣ずれのようなまた小人国の汽車のような可愛いリズムに聴き入りました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、小人数とは言へ、他に人がなかつたら、此の友染の袖をのせて、唯二人で真暗の水に漾ふ思がしたらう。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたけさん、まあ一番安全なのは小人森村で、一番思いやりの深いものは聖人園だが、どっちにするかい」　おたけは送ってもらわないでもいいといって、森村と園とを等分に流し眄で見やった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば一家にあっては、目上も目下も大人も小人も、みな一人ずつの人間として扱われて、頭数で数えられるような場合です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小人主義なり、俗物主義なり、小成功主義なり、事無かれ主義なり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に憫笑すべき小人根性ながら、此根性は武侠主義の敵なり、国家大発展の妨害者なり彼等は国家を愛するよりも、先づ金銭を愛し妻子を愛さん事を思ふ。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して小人だけが己惚れを持つものだろうか。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙遜は美徳であると知っていても、結局は己惚れの快感のもつ誘惑に負けてしまうのが、小人の浅ましさだろうか。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くも、高いとんがり帽子をかぶった小さい小人の妖魔が茂みの中からのぞいているのが、はっきり見えるような気がするのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、小人の妖精か、さもなければ、ほかの小さな精霊が来ているのではないかと思いました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば、小人たちは、ふたりずつに別れて、木の葉や、高い草の上にたまっている、大きな露のしずくの上で、玉乗りあそびをしていました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき、しずくがころがり落ちると、その上に乗っている小人たちも、長い草のくきのあいだに、ころがり落ちました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ほかの小人たちは、きゃっきゃっと笑って、大さわぎをしました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっぽけな黒い小人が、ずきんに鬼火をつけて、広間の中を踊りまわりました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ふたりは、広間にいる小人や鬼火たちといっしょに、ぐるぐる踊りまわりました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と足音をひそめて私が近寄ると、氏は極々あたりまえの顔をして「炎天の地下層にですな、小人がうじゃうじゃ湧こうとしてるんじゃ無いですかな。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄と小人という題なんだけど、金子先生は、ただやたらに、ナポレオンやソクラテスをほめて、市井の小人のみじめさを罵倒するのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間がみんな、ナポレオンやミケランジェロになれるわけじゃあるまいし、小人の日常生活の苦闘にも尊いものがある筈だし、金子先生のお話は、いつもこんなに概念的で、なっていない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小人はおのれを売っても、なおかつ、人をたのしませることができない。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」文学のおかしさは、この小人のかなしさにちがいないのだ。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚無主義者の神への揶揄であるとか、小人の英雄への反抗であるとか、それから、彼にはいまもつてなんのことやら譯がわからぬのであるが、觀念の幾何學的構成であるとさへ言つた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚無主義者の神への揶揄であるとか、小人の英雄への反抗であるとか、それから、彼にはいまもってなんのことやら訳がわからぬのであるが、観念の幾何学的構成であるとさえ言った。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "限りなき親しさと驚きの眼を以て私は君達のよろこびとかなしみとを理会する。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は詩を思ふと、烈しい人間のなやみとそのよろこびとをかんずる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金、送るなり、又、兄御自身お遊びがてら御持参くだされたら（かれ自身は更に動く気なきものの如し、かさねて無礼なり）よろこび（よろこびとは、真らしきも、かれも落ちたるものなり）これに過ぎたるは、ございません。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
