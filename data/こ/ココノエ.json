        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "円錐形にそびえて高く群峰を抜く九重嶺の裾野の高原数里の枯れ草が一面に夕陽を帯び、空気が水のように澄んでいるので人馬の行くのも見えそうである。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ところでもっとも僕らの感を惹いたものは九重嶺と阿蘇山との間の一大窪地であった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはかねて世界最大の噴火口の旧跡と聞いていたがなるほど、九重嶺の高原が急に頽こんでいて数里にわたる絶壁がこの窪地の西を回っているのが眼下によく見える。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "韓文公が詩集のうちに、一封朝奏九重天―云々とあるもの則是。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女たち、黄菊には九重のみけしきがある。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも当人時ならず、春風｜胎蕩として、今日｜九重ににおい来る、菊や、菊や――酒の銘。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "禮を厚くして神君を九重の奧深く祀つたのは無理もない。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "九重に霧や隔つる雲の上の月をはるかに思ひやるかな　これを命婦から源氏へお伝えさせになった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯のさへづる春は昔にてむつれし花のかげぞ変はれる　院は、九重を霞へだつる住処にも春と告げくる鶯の声　とお答えになった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "人この裏に立ちて寥々冥々たる四望の間に、争か那の世間あり、社会あり、都あり、町あることを想得べき、九重の天、八際の地、始めて混沌の境を出でたりといへども、万物｜未だ尽く化生せず、風は試に吹き、星は新に輝ける一大荒原の、何等の旨意も、秩序も、趣味も無くて、唯濫に※く横はれるに過ぎざる哉。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "桓武天皇九代の皇胤と列べ立てゝは緞帳の台詞染みて笑止しくないが、御歴代の天皇様から御鐘愛を蒙むつて恐れ多くも九重に咫尺し奉つた例は君達も忠君無二の日本人だから御存じだらう。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、この狆を見本にしてお彫りになれば、この狆の姿が九重のお奥へ参るわけで御座いますね」「そうです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "葉茶屋の狆のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「九重さん」「何ざます？",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "微行の用意せい」　――九重の筑紫の真綿軽く入れた風よけの目深頭巾にすっぽり面をつつむと、やがて対馬守は何ごともなかったように、静かな深夜の街へ出ていった。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それよりも大奥のお局、腰元、お女中たちの間における美男相撲江戸錦の人気はむしろすさまじいくらいで――「な、九重さま。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「九重の門のしりくめ繩のなよしの頭ひゝら木らいかに」とぞいひあへる。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "台坐には、十一坐、九重坐、七重坐、蓮坐、荷葉坐、多羅葉坐、岩坐、雲坐、須弥坐、獅子吼坐、円坐、雷盤坐等で、壇には護摩壇、須弥壇、円壇等がある。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年は九重の雲に見し秋の月を、八重の汐路に打眺めつ、覺束なくも明かし暮らせし壽永二年。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "むなしさよ　　101九重の空のひろがりは虚無だ！",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "九重に霞隔てば梅の花ただかばかりも匂ひこじとや　何でもない御歌であるが、お美しい帝が仰せられたことであったから、特別なもののように尚侍には聞かれた。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後から刑事と二人で下りて来たのは、買われた娼妓の九重だった。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りかけて客は九重の方を顧み、眼で刑事に哀願してから、また九重の傍に戻って来た。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は九重の首を抱き込むようにして、彼女の耳に何事をかささやいた。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "来て見るとＦ楼には九重はいなかったが、その隣のＨ楼に、九重の妹のみどりという女がいた。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            }
          ]
        }
