[
  {
    "uuid": "183fefe6-a7de-5bbc-ae7a-1fe559b309f9",
    "entry": "酷寒",
    "reading": {
      "primary": "こっかん",
      "alternatives": [
        "こくかん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "severe cold",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酷寒の季節に酷暑に遭った例がある。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂人のような悶えでそれを引き裂き、私を殺すであろう酷寒のなかの自由をひたすらに私は欲した。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "定罰のような闇、膚を劈く酷寒。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の酷寒には水滴の代わりに美しい羽毛状の氷の結晶模様ができる。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王は正月の酷寒に乗じて、蔚州を下し、大同を攻む。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち酷寒酷暑に於ける從事、或は蟲害其の他に就ての繁雜なる手數、緻密なる觀察、時間的不規律な勞働に服するなどの種々の場合に、努力によらなければ、中途にして歇むの状態に立ち至ることもまゝある道理で、換言すれば好んで爲すと云つても、其の間に好まざる事情が生ずるのは人生に有り勝な事實である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "師走、酷寒の夜半、女はコオトを着たまま、私もマントを脱がずに、入水した。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像を絶した困苦・欠乏・酷寒・孤独を、（しかもこれから死に至るまでの長い間を）平然と笑殺していかせるものが、意地だとすれば、この意地こそは誠に凄じくも壮大なものと言わねばならぬ。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死のような夜更けの酷寒に締めつけられて凍み割れる木材の鳴き声が、冷気を伴ってときどきぴゅんぴゅんと微かに聞こえてくるだけだった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち酷寒酷暑に於ける従事、或いは虫害その他についての繁雑な手当て、緻密な観察、時間的に不規則な労働に服す等の種々の場合に、努力しなければ中途で止める状態になることも間々ある理屈で、換言すれば好んで為すと云っても、その間には好ましくない事情が生じるようなことは人生に有りがちな事である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この村の山中にこだまネズミというて、普通のネズミよりはやや小がらな、焦茶色の艶のある毛色のネズミがすんでおりますが、この小ネズミが、酷寒の樹木の枝などが凍り折れるようにしばれるときなど、木のまたなどにいて、じつに恐ろしい音をたてて破裂してしまいます。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "大八はそれを、どこの女人かこの酷寒の真夜中にと思って、つくづくと見ておりますと、女は立ってきて、この子どもをちょっと抱いていてくれという、心よくその赤子を受けて大八は抱いてやると、女はそのまま小用でもたしに出ていったのかそれっきりなかなか帰ってきてくれませぬ。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの船客は、寒暖計の水銀が面白い程収縮して往くのには気がついても、この、こうして急激に酷寒が襲って来た理由を知っているのは、前に同じ季節に大西洋を渡った経験を有つ極く少数の人だった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に京都の酷寒の時期をわざ／＼選んで入園しましたのも、全く如上の意味から出て居ることでした。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、園には、春から夏にかけて入園者が大変多いのですが、秋からかけて酷寒となるとウンと減つてしまひます。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新しく辷り落ちて来た軽い、深い粉末の堆積の中に落ち込み落ち込み、掻き分け掻き分け進んで行くうちに瞼がヒリヒリと痛くなり、鼻の穴がシクシクと疼き出し、息も絶え絶えになって一と休みすると、忽ち零下何度の酷寒を感じ初めるので、又も匐うようにして歩き出す苦しみは、経験のある人でなければわからない。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、その手初めが“Ser-mik-suah”グリーンランド中部高原の北緯七十五度あたり、氷河と峻険と猛風雪と酷寒、広茫数百の氷河を擁する未踏地中のそのまた奥。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬は、こういう酷寒の地では雪中にもぐって、眠る――と、いうことが重大な使嗾となった。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "その彼が、稀獣｜矮麟を追い、麝牛をたずね、昼なおくらき大密林の海綿性湿土をふみ、あるいは酷寒水銀をくさらす極氷の高原をゆくうちに、知らず知らず踏破した秘境魔境のかずかず。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球のこの回転のしかたは、いつも、横腹を太陽の方に向けるやうになつてゐますために、回転の軸の両端、すなはち、北極と南極との両地方は、太陽の熱を受けることが少くて、酷寒の地域となつてゐます。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとひ、人の住めない酷寒の地域であらうとも、世に知られない部分が地球の上にまだ残つてゐるといふことは、地球の主人公たる人間にとつては、甚だ残念なことでもあり、不面目なことでもあります。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――刺すような酷寒の朝で、――入江は一面に霜で真白になっており、漣は静かに磯の石ころを洗い、太陽はまだ低くて、丘の頂に射し、遠く海の方を照しているだけだった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさい、水気を含んだ雪の次ぎに一晩の酷寒でも来ようものなら、スケイトの熱心家は喜ぶだろうが、スキイヤアは一せいに泣き顔である。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "（栗の発育）　一月の酷寒、二月のしけ、三月の風、四月の細雨、五月の朝露、六月の善い収穫、七月の好い麦打ち、八月の三度の雨、それはソロモン王の位よりも尊い。",
              "citation": {
                "source": "百姓日記",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると太陽が完全に遮閉されるので、地球に天変地異が起こり、その後に酷寒が訪れ、生物の大部分は死滅に瀕する。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点について、ディズニー自身が「現在、すでに多数の地理学、自然科学、民族学の専門家たちが、天然色カメラを携え、炎熱のアフリカや酷寒のアラスカ、さらに南半球の果までも旅行して、今までに皆様が見たこともないような新形式の映画を作るための材料を集めつつあります」と言っている。",
              "citation": {
                "source": "ディズニーの人と作品",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも話したとおり、アイヌは氷のことをルは実はすなわち「とけるもの」という意味で、これによって彼等は氷をノーマルなスタンダードな状態と考えていたことが明らかになるし、氷をノーマルな状態と考えることは、彼等が永く酷寒の地に住みなれて、北方人の心になりきっていたことを示すものであります。",
              "citation": {
                "source": "言語と文化史",
                "author": "――アイヌ文化の探究にあたりて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの季節ならばともかく、酷寒の生活が思ひやられるところから、どうしても、使ひ走りをする男が必要であつた。",
              "citation": {
                "source": "それができたら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "食も無く水も無く、炎熱又は酷寒の道を一日に十里十五里と歩み行き、しかもその末に敵の十字砲火の中に身をさらす。",
              "citation": {
                "source": "俳優への手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酷暑と言えば早く秋冷の候になる事を冀い、酷寒と言えば早く春暖の候になる事を冀うのが人情であります。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
