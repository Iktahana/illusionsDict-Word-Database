    "definitions": [
      {
        "index": 1,
        "gloss": "to get (become) acquainted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
