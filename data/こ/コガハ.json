        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから、おけいこがはじまったら、よくおぼえるようにするんですよ」「じゃあ、やっぱり、あの男の子たちが言ってたように、ぼくたち、殺されるんだね。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庭でもってきゃっきゃっという騒ぎ、女中衆が三四人、池の周囲を駆けてるんで、鬼ごッこがはじまってるか、深川だって呑気なもんだと、ひょいと見るとどうです、縁側に腰をかけてたのは山の井の診察所で見た、別嬪だろうじゃありませんか。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあったけえのにどてらなんぞ着ていたひにゃ、おへそにきのこがはえますぜ」　しかし、右門はすましたものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "この入梅どきだ、よくきのこがはえなかったもんですよ」「黙ってろ」「へ……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初せきせいいんこがはやり出しそれが下火になると兎が、それから食用蛙がはやつた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんぶやわかめなどの海草の林が見え、岩の上にはなまこがはっている。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しおしおとまた浜べへ出てみましたが、海の水はまんまんとたたえていて、どこがはてともしれません。",
              "citation": {
                "source": "浦島太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごほうびに、明日から、この林の中にいっぱいきのこがはえるようにしてあげよう。",
              "citation": {
                "source": "お山の爺さん",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日の朝、皆で、「おうさむこさむ……」や「きいのこきのこ……」などを歌いながら、その林にやって来ますと、一面にきのこがはえていました。",
              "citation": {
                "source": "お山の爺さん",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこがはつきり違ふのではないかと思ふのです。",
              "citation": {
                "source": "大政翼賛会と文化問題",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロ／＼トロ／＼と追つかけごつこがはじまりました。",
              "citation": {
                "source": "文化村を襲つた子供",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆山もここがはずれで、あたりは海と山ばかり、いささか人里はなれた不便な場所である。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもそこがはっきりしないと解剖の報告にあるんだがいずれにせよ、極きわどい刹那の話だ。",
              "citation": {
                "source": "死者の権利",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ここがはいり口です。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのために、そうして暮したいように暮すんだか、そこがはっきりしなくちゃ」　これは、当然素子と伸子自身の生活ぶりにかかわっている感想である。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこがはっきりすると君は無邪気になれるんだ。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこがはっきり覚えていません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖観音の背から胴体にかけてのなめらかな美しさは、指でさわるとそこがはじけそうに思われるほど如実であった。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことを言いましたけれども、米友はまたちゃらっぽこがはじまったという面をして取合わない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあーんだ、ここでも戦ごっこがはじまってやがる」と米友が冷笑しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで老人と語りあった彼でさえ、岸の上へあがってみると、眼のさきにあるそこがはるかに遠く、焚火の火や、老人の姿や、茶を啜ったことまでが、まるで現実のことではないように感じられるのであった。",
              "citation": {
                "source": "橋の下",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、その晩は塚へお参りをしたあとで行者の庵に泊めて貰ったのか、宿へ戻って寝たのか、聞書の記事ではそこがはっきりしないけれども、そう云う細かい事柄は孰方でもよい。",
              "citation": {
                "source": "聞書抄",
                "author": "第二盲目物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこがはっきりしないと、きみの立場が非常に不利になるんだ」「それはわたしにもよく分かっております。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビロードのはこの中に、もう一つ、ピカピカ光る黄金の宝石ばこがはいっていました。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふつうのはこの中に、黄金のはこがはいっているのです。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな木の下に、ひとりのおとこがはこをもってたっていました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっつかまえろっ」　かようにして、鉄管迷路のめくら滅法な鬼ごっこがはじまった。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、また、怪人と潜航艇との、死にものぐるいの、追っかけっこがはじまりました。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二十面相の車は青いボディー、小林君たちのは黒いボディー、その二台の自動車の追っかけっこがはじまりました。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
