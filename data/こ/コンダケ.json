        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「なんて言ったって、こんだけの山茶花、この界隈に無えがら……」「山茶花など、どうだって……それより、早ぐ寝で休んだらいかんべな、爺つあんは。",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ、こんだけ、ここでいろいろ食って、よく食欲があるな」　山崎は、ワラの鉛筆のような躰をねめまわした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「柾生、山崎、佐藤、広岡、こんだけ起こしてこい」「ハンゾー先輩は？",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんだけの沢山の女給と云ふものが、どンなになつて行くンでせうねえ。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶子も湯へ手をつつこんだけれど流石に熱いと見えて、いつとき流しに坐りこんで湯を浴びてばかりゐた。",
              "citation": {
                "source": "うき草",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな気持を云いあらわしようもなくて、サイは、「荷物こんだけ？",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "割合にまち、割合によろこんだけれ共、電車から下りたのは小供達と源さんきりであった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは、うちのかわいそうな子どもたちを、晩ごはんにのみこんだけど、あの子たちは、まだおなかのなかで生きているのかしら。",
              "citation": {
                "source": "オオカミと七ひきの子ヤギ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮山　そう、所有権は伯母が握ってんだからな、あいでも、変なもんだな、こんだけの家屋敷が、もう死んだも同然の、ただ息をしているだけの伯母に握られて、どうにも出来ないんだからなあ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "轟　……こんだけの家を抵当にすれば、随分借りられるだろうなあ。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "轟　いや、こんだけ厄介になっているのに、その上そんな……実際、頭がカーッとして叫び出しそうになる事があるんだ。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美緒　……だつて私は死ぬまいと思つて、こんだけ気ばつてゐるでしよ？",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、こんだけ待つて来ねえのぢやから、何か差しつかえが出来たのぢやろ。",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから今日まで四年近く、こんだけ仲の良い俺でさえ、そうとハッキり気が附かなかったんだ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ、知らない事だと言ってもだ、こんだけの金吾の思いが、ツンともカンともまるっきし通じねえと言うのは、あんまりムゴイぜ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こんだけ、その春子さんつう人を思いこんだ人の心が、私なんずがどう懸命になったとて、もう、どうならず？",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうさなあ、南佐久中で、こんだけ工合のいい門口の百姓は家五軒とはねえずら。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "といつても、こんだけしきや、ない。",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の声　でも、こんだけの荷物があるのに、雨よ、あんた。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんだけ（とボストン・バッグの先でこづいて見せ）したくはして来てる。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんだけ大きななにを、君みたいな――佐山　……ぼく一人じゃ、ないんですけど……村子　（火のついたロウソクを持って、行きかけた足をとめて佐山を見ていたが）……すると、なんなの、あんた兵隊だったの？",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "んで、まあ、同じことなら、とにかく、国がこんだけの戦さしているんだ、戦争に出て――すると、遺族扶助料だってもらえるから……とても、この悲壮な気になって――会社の友だちやなんかに送られて出かけたんですがね――したら、いきなり、こんな山ん中の豚小屋みたいな仮兵舎にたたきこまれて、穴掘りです。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とにかく、こんだけだ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんだけで――村子　そいで――？",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（自分のビスケットをかじる）村子　いえさ、こんだけの広さで、私たち――空気の入って来るところ、どこにもないんでしょう？",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花岡　（口を動かしながら、あたりを見まわす）なあに、こんだけありゃ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんだけ捜してもわからないんだから。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんだけ私が、あんたのこと、愛しているのが、わからないの！",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村子　だって、あんた、こんだけなにして、もう死ぬばかりになっていたのに、――現に、あんただって、あんな弱音をあげるくらいになっていたのに、そんな、よくまあ――花岡　だからよ、人間の慾に底はねえといってるんだ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんだけ水がおごっちょるのに、どうで渡れよう」　啜りあげるように叫んだ。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
