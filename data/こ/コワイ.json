[
  {
    "uuid": "803011b5-5192-54ab-a027-578251489ddd",
    "entry": "怖い",
    "reading": {
      "primary": "こわい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
