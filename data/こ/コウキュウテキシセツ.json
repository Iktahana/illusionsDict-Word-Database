        "examples": {
          "standard": [
            {
              "text": "国際税務において、外国企業が国内に恒久的施設を持つかどうかが課税の基準となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外に支店や工場を設立する際、それが恒久的施設に該当するかどうかを判断する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "税務当局は、企業の活動が恒久的施設を構成するかどうかを詳細に調査する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "凶作のみならず水害風害あるいは地震や火事の災害を根本的に除くためには、やはり同様な恒久的施設が必要である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
