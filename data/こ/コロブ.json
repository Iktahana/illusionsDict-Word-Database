    "definitions": [
      {
        "index": 1,
        "gloss": "to fall down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "縁側に向いている硝子窓から、工房の中が見えるのを、なるべく眼を外らして、縁側に出て仰向けに寝転ぶ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一と足下りかけた瞬間から、既に、自分はきっと滑って転ぶにちがいないと思った。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と口を開けて、にやりとして、「へ、へ、転ぶと、そこらの花に恥かしい。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どしん、と寝転ぶ音。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の児たち　きゃあ――男の児たち　やあ、転ぶない。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤土の急勾配、溝のごとくになり、辷って転ぶ事も幾回なるを知らず、足を大の字｜形に拡げて両側の草を踏みつつ、ヨタヨタ進まねば容易に登る事の出来ぬ場所も五、六町。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夏の三時起に、眠り眠りここを歩行いて、ドンと躓いたのがこの石で、転ぶと、胸を打って、しばらく、息を留めた事がござりました。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "風は※々と両腋に起こりて毛髪｜竪ち、道はさながら河のごとく、濁流脚下に奔注して、身はこれ虚空を転ぶに似たり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、すべって転ぶのもある。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁や襖にぶつかったり、樽に躓いたりして、転んでは起き、起きては転ぶばかりです。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　一日、雪降り凜※たる寒気の中を例の如く太七の家の前を通るうち、プッツと切れた下駄の鼻緒に転ぶ途端、無作法に笑ひこける太七の家の職人共に、何が可笑しいと詰り寄るうち、ふと一人の職人が細工場の戸を開けて外を窺つた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と寝転ぶようにして、頬杖ついて、畳の上で読むのを見ながら、抜きかけた、仏壇の抽斗を覗くと、そこに仰向けにしてある主税の写真を密と見て、ほろりとしながら、カタリと閉めた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か黒山のような物に打付かって、斛斗を打って仰様に転ぶと、滝のような雨の中に、ひひんと馬の嘶く声。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ていて転ぶうれいなし。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでやっと彼の川の土手へ出た時には皆が疲れて、「もう、此処で寝ようじゃないか」　と、云って土手の上に寝転ぶ者もあったくらいです。",
              "citation": {
                "source": "提灯",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ慌て過ぎて、振袖に躓いて転ぶようだから、痩我慢で黙然でいたんだ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど一たび大磐石の根の覆るや、小石の転ぶがごときものにあらず。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果は親子共に菰の上に寝ることになろうと土の上に転ぶことになろうと、親として欲する有りの儘な声で喚び交してみたかったのである。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時また、転ぶ様に馳けつけて来た女、この二日間小田島に纏り続け、彼の前でイベットを目の敵に罵り通して居たあの女だ。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "転ぶのはまだ早いや。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔道屋か」　茉莉はまかりまちがっても転ぶような、そんな下手なダンサーではなかったのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思うと、些細なことで気にいらないことがあると、キンキンした疳高い声で泣き、しまいには外行きの着物のまま泥んこの道端へ寝転ぶのだった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんどん………あな、うち転ぶ人のむれ、音もころころ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、見よ、わが幻に転ぶもの吸い尽くされし空の罎、――空なる命、最終の辻の恐怖に、ふと青む。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "出会いがしらに突き当る者がある、逃げようとして転ぶ者がある。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨は人家ありけるよと打喜び、山｜岨の道なき処を転ぶが如く走り降り、やゝ黄ばみたる麦畑を迂回りつゝ近付き見るに、これなむ一宇の寺院にして、山門は無けれど杉森の蔭に鐘楼あり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の有様を『甲陽軍鑑』に、「敵味方三千七百の人数入り乱れて突いつ突かれつ伐つ伐たれつ互に具足の綿噛みを取り合ひ組んで転ぶもあり首をとつて立ちあがれば其首は、我主なりと名乗つて鑓つけるを見ては又其者を斬り伏せ後には十八九歳の草履取りまで手と手を取合差違へ候」とある。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでやつとあの川の土手へ出た時には皆が疲れて、「もう、此所で寝やうぢやないか、」　と云つて土手の上に寝転ぶ者もあつたくらゐです。",
              "citation": {
                "source": "提燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は、風流の身だしなみも何も忘れて、仰向にながながと寢そべり、「ああ、あ、醉つて寢ころぶのは、いい氣持だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どっちへころぶことか！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
