    "definitions": [
      {
        "index": 1,
        "gloss": "as for this",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此れはいけないと思つたが、何處か部屋はありませうかと聞かない譯にも行かなかつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れは浴槽を適當に一段高くしておけば問題はなくなるであらう。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯を食ひながら女中の話を聞くと、先達つて何とかいふ博士が此の公園を見に來て、此れは大變にいゝ處だから此の形勝を保存しなければいけないといふ事になり、更に裏手の丘迄も公園の地域を擴張する事になつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れは私の繪が弱いのか世の中が強いのか、どつちだか此れもよく分らない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言ひし文章の音律とは、今の小説では、十七八の娘だと地の文に書いてあるから、其會話が十七八だと思つて見るが、此れは眼に見せる文章で、十七八の娘とも何とも斷り書をしなくとも、讀んで十七八の娘だと聞えなければいけない。",
              "citation": {
                "source": "文章の音律",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "拂ふほど砂もつかない、が、此れは後で悚然とした。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜食の膳で「あゝあ、何だい此れは？",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどもあらせず、勝に乘つたる秀吉が一騎驅けに馬を寄せると、腰より采を拔き出し、さらりと振つて、此れは筑前守ぞや、又左、又左、鐵砲打つなと、大手の城門を開かせた、大閤大得意の場所だが、そんな夢も見ず、悶え明かした。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢぶきなり、其の人、長火鉢を、此れはと又問ふ。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も食する者なかりしが、金澤の人の行きて、此れは結構と豆府の汁にしてつる／＼と賞玩してより、同地にても盛に取り用ふるやうになりて、それまで名の無かりしを金澤茸と稱する由。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉の雨を掌に握つて、我がものにした豪儀な客も、ギヨツとして、此れは悄氣る……筈の處を……又然うでない。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は大抵旅行の時期を夏から秋の初めと定めておくが、此れは旅裝の輕便を欲するからで、學生の旅行期と一致して居る。",
              "citation": {
                "source": "旅行に就いて",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れは俳諧に於てのみならず昔から支那日本で所謂天文と稱したものが、昔のギリシャで「メテオロス」と云つたものと同樣「天と地との間に於けるあらゆる現象」といふ意味に相應して居たから、其因習がどうしても拔け切らないせゐであらう。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れは前述の理由から當然のことである。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れは俳句が所謂モンタージュの藝術であることを明示する。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れは併し恐らく其当時の先生自身の心境を語る意味の言葉であつたかと思はれる。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に袋へ米と挽割麥とを交ぜたのを入れて、それから此れは傭人にも炊いてやれないのだからお前がよければ持つて行つて秋にでもなつたら糯粟の少しも返せと二三｜斗入つた粳粟の俵とを一つに遣つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大分有るな、此れは又わしの來るまで動かしちやならないからな」巡査はいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「如何なもんでござんせうね此れは」内儀さんは微笑を含んで巡査に向つていつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰌とは違つて此れは彼の手にも僅づゝは採ることが出來た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わし此らあ、蜀黍伐つて引つ懸けべと思つたんでがす」「うむ、此の粒の零れたのはどうしたんだ、蜀黍なんだらう此れは」「へえ、なに、わしが一攫み引つ扱いて來て見たの打棄つたんでがした」勘次は恁ういつて蒼く成つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「噺の外でがさどうも、彼此れはあ、小卅日にも成んべが、まあだかたでどつちから手つけてえゝか分んねえんでがさどうもはあ、わし等方見てえに洪水ばかし出たんぢや、居んのも厭んなつちまあやうなのせ本當に、さう云つてもこつちの方はようがすね」おつたは相手を見つけて力を得たやうにいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れは東名の濱へ出るには一番近い道なので其代りには非常に難澁だといふことである。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れはお山の砂を草鞋へつけて來ることは昔から禁じてあるので島へ渡るものは皆新しい草鞋を穿いて、もどりの船に乘る時にはぬぎ捨てる筈だ相である。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者は太い聲を掛けて斜に打あげると此れはボンと鳴つた。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其男がどうも見たことのある顏だと思つたら此れは小木の宿屋の主人であつた。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんは此れは椿ダンゴといふのだといつた。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤泊を出帆する時に舳を米山に向けたのを變だと思つたのであるが此れは以ての外の失策をしてしまつた。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れは彼が早くより支那に行つて居つたからであるが、長く支那に居らなくても入唐したものゝ詩文はどうしても入唐しないものゝ詩文よりはよろしいやうに見える。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "穆宗の長慶年間に元白の詩文集が出てから初めて有名になつたのであるが、此れは大師が日本へ歸つた後であつて、時は恰も弘仁の末頃であるから、嵯峨天皇の時には元白集は珍らしく、天皇が御覽になつた位のことで、一般には未だ行はれなかつたと云はねばならぬ。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
