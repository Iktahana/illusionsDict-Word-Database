          "literary": [
            {
              "text": "松浦先生の口をあけさせて、とりあえず喉頭鏡を突込んでみたが、そこいらに骨は見当らなかった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ喉頭鏡などの発明がなかった頃であるから、余計に感謝されたわけである。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "又もや生理学者のチェルマクがこの発見に飛びついて喉頭鏡を開発した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼底鏡、喉頭鏡のように巧みな器具が発明され医師たちは器官の中まで覗いて変化を直接に見ることができるようになった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
