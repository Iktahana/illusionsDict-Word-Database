    "definitions": [
      {
        "index": 1,
        "gloss": "parents' ability (or inability) to let go of their children",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "息子が一人暮らしを始めて半年経つのに、母はまだ子離れできずに毎日電話している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつまでも心配するのは親の勝手だけど、そろそろ子離れしなきゃね」と彼女は自嘲気味に笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の自立を促すためには、親の方にも覚悟を持った子離れが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「永くもない一生のうちに、しばらくでも親子離れて暮すなんて……先のことは先にして――あんたどう思います」逸作は答えた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
