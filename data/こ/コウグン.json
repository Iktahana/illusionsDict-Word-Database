    "definitions": [
      {
        "index": 1,
        "gloss": "Red Army",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、彼自ら紅軍に大将として出場したのである。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕合の形勢は、始終紅軍の方が不利であった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "出る者も、出る者も、敵のためにばたばたと倒されて、紅軍の副将が倒れた時には、白軍にはなお五人の不戦者があった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、紅軍の大将たる忠直卿は、自ら三間柄の大身の槍をりゅうりゅうと扱いて、勇気凜然と出場した。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅軍は、昨日よりもさらに旗色が悪かった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも、紅軍の副牌（部将）周謹の働きは目ざましく、彼の槍の前に立ちうる者はなかった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
