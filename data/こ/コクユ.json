        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「まず第一に、香取防衛司令官の告諭であります。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし縣令や告諭ぐらゐでは覺束ない。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし県令や告諭ぐらいでは覚束ない。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無条件降伏よ」　続けて、内閣告諭というのが放送された。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "武装解除について、陸海軍人に対する告諭、予科練、各地在郷軍人に与うる訓諭、そういう放送が夜昼くりかえされた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが去年、その老公が隠居したので、一時は気落ちもしたが、その折、老公が発した藩士一統への告諭に泣いて、前よりもかえって結束をかため、汁講もつづけられて来た。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「向こうでは待てないっておっしゃるし、兄もしつこくゆけって云うものですから、とうとう承知してしまいましたの」「ではまもなく祝言ですね」「この二十八日ですって」七重はじっと彼の眼をみつめた。",
              "citation": {
                "source": "艶書",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
