        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「誰れだい、たったこれっぽちしか入れてねえんは。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だんなのするこったから何かいわくがござんしょうが、まさかこれっぽちの暑さで、脳のぐあいをそこねたんじゃござんすまいね」　いったかいわないかのときでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでもこれっぽちの金しか貰わないんでさあ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これっぽちのお金しかないのに物価は高い。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一軒の家に住んでいながら、親と子との間柄でありながら、仲のわるくなった今となって、たったこれっぽちの親切さえも惜しまれるのだったらしい。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やくざめいたこんな間違えでお上へお手数を掛けようなんて、そんなけちな了見はこれっぽちもございません」　と暗に助五郎の来訪を迷惑がるような口吻を洩らして、それとなく逃げを張るだけの用心も忘れなかった。",
              "citation": {
                "source": "助五郎余罪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "これっぽちの値打もねえぜ！",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子屋　これっぽちもわからん。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "キング　これっぽちもないか？",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これっぽちもわからん。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これっぽちもないか？",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのこれっぽちの意味もないと思うけれど。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　裁判員もみんな手持ちの黒板に書きとめてね、「こんなのこれっぽちの意味もないと思うと女。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "この相互愛が、これっぽちでも衰えることがあれば、彼女はむしろ死にたい。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「三十銭だけど、たったこれっぽちさ。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は工業にこれっぽちも興味がなかったので、冒涜につまらぬ時間を費やしていればいいさ、とロッサム青年はついに老人をどこかの研究室に閉じこめてしまい、自分は技術者の観点から研究を始めてしまいました。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "献身が尊いなんて、これっぽちも知らなかった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "村人の中で誰一人として、その場をおちょくるなんて考えはこれっぽちもない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角の計画を持ちながら、佐川二等兵を優れた技術家にしあげられないのも残念だし、百円もの俸給を貰っていて、これっぽちの本が買えないと云うことにも腹が立って来たのである。",
              "citation": {
                "source": "指導物語",
                "author": "或る国鉄機関士の述懐",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはしおらしさというものはこれっぽちもないかも知れません。",
              "citation": {
                "source": "聖アンデルセン",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "これっぽちも疑いません。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "心配とか不安とかこれっぽちもせず、最愛の家族を残して出発した。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うまでも無いですが、私は色目なんかこれっぽちも使っていません」「もちろん、そうよね。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはこれっぽちもあそびたくありません」「ばか、これは冗談じゃないぞ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
