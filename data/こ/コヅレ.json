[
  {
    "uuid": "d3685b81-7efa-5a4e-94e1-8018c465ee05",
    "entry": "子連れ",
    "reading": {
      "primary": "こづれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
