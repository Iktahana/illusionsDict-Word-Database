    "definitions": [
      {
        "index": 1,
        "gloss": "superior insight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伏して高察を賜はらば、恩幸なり恩幸なり。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "事態切迫専断実行の場合御高察の程｜偏に御願申上候、云々』　　　老農の歌へる「渡良瀬の詩」世間は、去る三十年五月の「鉱毒防禦工事」の命令書で、鉱毒問題は既に解決して了つたものと思つて居る。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に渇望の至り、造次も忘れず、伏して、高察を給へ。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
