    "definitions": [
      {
        "index": 1,
        "gloss": "official bulletin board (esp. Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水はきれいで薄曇りの空を逆に映して居り、堀の縁には桜の若木が並木に植付けてあって、青年団の名で注意書きの高札が立っていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を見て、桜木の並木を見て、高札を読んで、空を仰いでから、ちょっと後のかの女を振り返って、規矩男は更に導くように右手の叢の間の小径へ入った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤松の陰に「山門制戒」の高札も立っている。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからば、早速触れを出す事に致そう」　翌日、高札場の前を通り掛ると、人々が集って笑っている。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は今出川住人富田無敵の訴出に依れば、盗賊の逐電致せし者にきっとまぎれなき由、依って高札を掲げる事如件」　とあり、何となく面映ゆく赤面していると、意外な囁きが耳に入った。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "高札の文章にわざわざ『今出川往人富田無敵』の名を入れた理由も読めたと、直ちに奉行所へ乱入して…………と思ったが……。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪で、船乗り業｜桂屋太郎兵衛というものを、木津川口で三日間さらした上、斬罪に処すると、高札に書いて立てられた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "高札の立った日には、午過ぎに母が来て、女房に太郎兵衛の運命のきまったことを話した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大嘗会というのは、貞享四年に東山天皇の盛儀があってから、桂屋太郎兵衛の事を書いた高札の立った元文三年十一月二十三日の直前、同じ月の十九日に五十一年目に、桜町天皇が挙行したもうまで、中絶していたのである。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、最高札は上下の縁が少しばかり凸形になっているし、並の札は両横の縁が少しばかり凸形になっているのである。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなぐあいになっているので、だまされる人は普通のように札を縦に切るものだから、いつも相手に最高札のほうを切ってやるし、だますほうは横に切るから、同様にきっと相手に点になるような札は一枚もつかませないことになるのだ。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "「追分の高札場のそばの土手下で……」「それじゃあ近所ですね」「はい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪で、船乘業桂屋太郎兵衞と云ふものを、木津川口で三日間｜曝した上、斬罪に處すると、高札に書いて立てられた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "高札の立つた日には、午過ぎに母が來て、女房に太郎兵衞の運命の極まつたことを話した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大嘗會と云ふのは、貞享四年に東山天皇の盛儀があつてから、桂屋太郎兵衞の事を書いた高札の立つた元文三年十一月二十三日の直前、同じ月の十九日に、五十一年目に、櫻町天皇が擧行し給ふまで、中絶してゐたのである。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうあそこに見えていますが、あの橋までおいでなさると高札が立っています。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮汲み女の言った通りに、新しい高札が立っている。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この路次裏の井戸が即ち馬琴の硯の水で、文芸の理解のない官憲も馬琴の名だけは知っていたと見えて、数年前から東京史蹟の高札が建てられた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といって、大きな高札を抱えて、馬に乗って出かけました。",
              "citation": {
                "source": "羅生門",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、せっかく来たものだから、高札だけでも立てて帰ろう。",
              "citation": {
                "source": "羅生門",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と独り言をいいながら、門の前に高札を立てました。",
              "citation": {
                "source": "羅生門",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国のアーサー王物語の主人公ともいうべき、義経の書いたものだという伝説のある、奇妙な高札が日本のある寺院（須磨寺）に現存している。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の駅近くへ出ると、小料理屋の間に挟まって、大石｜内蔵之助の住んでいたと云う、写真や高札を立てた家があった。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はあの発頭人の得業恵印、諢名は鼻蔵が、もう昨夜建てた高札にひっかかった鳥がありそうだくらいな、はなはだ怪しからん量見で、容子を見ながら、池のほとりを、歩いて居ったのでございますから。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで恵印はわざと悠々と、もう朝日の光がさし始めた池の方を指さしまして、『愚僧の申す事が疑わしければ、あの采女柳の前にある高札を読まれたがよろしゅうござろう。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにはさすがに片意地な恵門も、少しは鋒を挫かれたのか、眩しそうな瞬きを一つすると、『ははあ、そのような高札が建ちましたか。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "恵印は元よりあの高札を打った当人でございますから、そんな莫迦げた気のすることはありそうもないものでございますが、目の下で寄せつ返しつしている烏帽子の波を見て居りますと、どうもそんな大変が起りそうな気が致してなりません。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺の事情はともかくも、あの高札の文句を書いたものは自分だと重々承知しながら、それでも恵印は次第次第に情けない気もちが薄くなって、自分も叔母の尼と同じように飽かず池の面を眺め始めました。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体今見た竜の姿は眼のせいではなかったろうか――そう思うと、自分が高札を打った当人だけに、どうも竜の天上するなどと申す事は、なさそうな気も致して参ります。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣、その上に、その横に連なっている柵、高札場が見えた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
