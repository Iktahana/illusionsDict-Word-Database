[
  {
    "uuid": "f117dd35-d7d3-58ee-914e-9f9c939e3973",
    "entry": "古伝",
    "reading": {
      "primary": "こでん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
