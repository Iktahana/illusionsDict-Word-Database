      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "legend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鮑聶等の女仙は、もと古伝雑説より取り来って彩色となすに過ぎず、而して月君は即ち山東蒲台の妖婦唐賽児なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇佐八幡の御託宣は名高いが、あれは別として、一体神がゝり御託宣の事は日本に古伝のあることであつて、当時の人は多く信じてゐたのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども棊の果して尭の手に創造せられしや否やは明らかならず、猶博物志の老子の胡に入つて樗蒲を造り、説文の古は島曹博を作れりといふが如し、此を古伝説と云ふ可きのみ。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "註　アイヌ・モシリ　　　蝦夷島（アイヌ語）　　カムイ・ユカラ　　　神謡（　同　　）　　オイナ・カムイ　　　古伝神（　同　　）曇り日のオホーツク海光なし、燻し空には日の在処、ただ明るのみ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝦夷島の神、古伝神、オキクルミの裔。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼アイヌ、蝦夷島の神、古伝神、オキクルミの裔。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは古伝神オキクルミを矜る、その蝦夷島の神を。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も中古伝説の中の王子の小船のようにちかりちかりとその光は笑って来る。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "是より先、天武天皇は、わが国の古伝の保存及び国史の編纂に大御心を注がせられ、天皇おん自ら旧辞を稗田阿礼に勅語したまうたとあるから、さうした御苦心が、古事記となつて実を結んだわけである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七に、神社合祀は史蹟と古伝を滅却す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国のリッブル河辺の民、昔より一の丘上に登り一の谷を見れば英国無双の宝物を得べしという古伝あり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく神社合祀は、第一に敬神思想を薄うし、第二、民の和融を妨げ、第三、地方の凋落を来たし、第四、人情風俗を害し、第五、愛郷心と愛国心を減じ、第六、治安、民利を損じ、第七、史蹟、古伝を亡ぼし、第八、学術上貴重の天然紀念物を滅却す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "古伝にこの神インドを征服したというから虎を愛するはずだ、インドへ出立前に秘儀を女神キベレーより授かる、キベレーは獅を使い物とす、生まれて棄てられ豹に哺まれて育ったという。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "（古伝説と、シルレルの詩から。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドの古伝の技芸天即ち芸術の神のように、芸術は天上世界に遊ぶ者の美睡の頭脳中から自然に生ずるものかも知れない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おきなが」の術は道家から出たものか、日本古伝であるか明らかでないが、「おき」は気息で養生全命の道であるとされているもので、道家の胎息内息、仏者の調息数息の道に似ている。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドの那伽を古来支那で竜と訳したが、インドの古伝に、那伽は人面蛇尾で帽蛇を戴き、荘厳尽くせる地下の竜宮に住み、和修吉を諸那伽の王とす。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世日本同様異常の蛇を竜とせる記事多きも、それは古伝の竜らしき物実在せぬよりの牽強だ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "北欧の古伝に魔蛇ヨルムンガンド大地を囲める大洋にありて尾を口に啣え大地を繞り、動く時は地震起る（マレー『北方考古篇』）。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "猴の話は東洋に少なからねど、欧州に産せぬから彼方の古伝が乏しい。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "古伝にアハリアは梵天創世最初に造った女で瞿曇仙人の妻たり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "由って俚言土俗に関して他所風の雑らぬ古伝を受くるに最も恰好の人物だ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も中古伝説の中の王子の小舟のやうにちかりちかりとその光は笑つて来る。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（11）この話はおもに土地の口碑と、それから東奥古伝という本で見た。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "この白鬚の巨人も、この山の主（東奥古伝）。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "――でんこでんこの遊びではないが、一町ほど遠い遠うい――角邸から響かないのは無論である。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここでんねん」　松本の横顔に声を掛けて、坂田は今晩はと、扉を押した。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこでん、今は、同じこつばやっとります。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人の苦力がいつぴや乗つとつて、何処でんかしこでん唾吐きちらきやあつ。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
