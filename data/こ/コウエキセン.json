        "examples": {
          "standard": [
            {
              "text": "17世紀には、東洋との交易船が盛んにヨーロッパへ行き来していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "嵐で難破した交易船から、珍しい香辛料が発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代地中海では、多くの都市が交易船で結ばれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "傾いた陽の光が市場に触れ、歳降った丘の屋根と鐘楼を金に染め、かつてプロヴィデンスのインド交易船が錨を下ろした夢見る波止場に魔術を投げかけるのだ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして朝廷の大官は日本政府の名による印可符（許可証）を彼の交易船に貸していたというわけでもある」「お待ちください。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
