    "definitions": [
      {
        "index": 1,
        "gloss": "to long (for)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今、この焦がれるような苦しみに追い立てられて、わたしは死にもの狂いになってあなたに縋りつきます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……手前の焦がれる広太郎、かえしてやるからいうことを聞け、どうだどうだとやらかすのさ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うとその無念やら怨恨やらは一層お宮を思い焦がれる情を切ながらした。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "智恵子は現身のわたしを見ず、わたしのうしろのわたしに焦がれる。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦がれるの何のということが、口で講釈できるものだとでもいうのかい？",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、彼が成長して立派なとても美しい青年になった時、彼女は含羞むようになり、間もなく夢中になって恋い焦がれるようになった。",
              "citation": {
                "source": "大ヴォローヂャと小ヴォローヂャ",
                "author": "ВОЛОДЯ　БОЛЬШОЙ　И　ВОЛОДЯ　МАЛЕНЬКИЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "橘　子を想い焦がれる親心、臨終の間際まで待ち悶え、さぞやご無念、心残りでございましょう。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――恋い焦がれるとはその時の私を云うのでしょう、私の胸には「会いたい見たい」の願いより外何物もありませんでした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋い焦がれる市十郎なるが故に、夜も日も怨みに恨みつめなければ、それを胸に持てなかった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お金持ちの人ほど、お金にあこがれるのね。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三鷹に帰ると、またすぐ旅の空をあこがれる。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの草稿を読んでから、あまりに健康で常識円満な女性は却って奇蹟とか神秘にあこがれる一面があるものだと教えられて、あらためて、Ｓ夫人を見返してみた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その画家はパリにあこがれるのによくこういう言葉を使った。",
              "citation": {
                "source": "マロニエの花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の上、ぞつこん思ひこがれる御新姐お組が、優しい風流のあるのを窺つて、居※りの夜店で表紙の破れた御存じの歌の本を漁つて來て、何となく人に見せるやうに捻くつて居たのであつた。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いふまでもなく番町邊では、あこがれる蛙さへ聞かれない。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "津々浦々、都、村、里、どこを聞いても、あこがれる唄はない。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上むりして努めてみたって、たいしたことにもなるまい、こうして段々老いてゆくのだ、と気がついたときは、人は、せめて今いちどの冒険に、あこがれるようにならぬものであろうか。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また私は、眠りの中の夢に於いて、こがれる女人から、実は、というそのひとの本心を聞いた。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水甕のお家をあこがれる。",
              "citation": {
                "source": "豊島與志雄著『高尾ざんげ』解説",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その笛の音こそはプラトオのエロス――靈魂の實在にあこがれる羽ばたき――である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の食慾は光にかつゑあなたの白い指にまつはる果物の皮の甘味にこがれる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不幸にあこがれるという性癖は、将来、僕の人格の主要な一部分を形成するようになるのかも知れぬ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気持の楽な時、うっとり映画俳優をあこがれるなんてのは、話になりませんけど、いのちの瀬戸際になると、ふっと映画俳優を考えつくらしいのですが、僕は、それを神の声のように思っているのです。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あこがれる志が、信頼して、努力して、最高の願の所へ到着したとき、成就の扉の開いているのを見た時は、こんなものだな。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "器用、奇智にあこがれるのである。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野暮な者ほど華奢で繊細なものにあこがれる傾きがあるやうだが、あの人の御日常を拝見するに、ただ、都の人から笑はれまいための努力だけ、それだけなんだ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、妙ね、然ういへば……何ですつて、蛙の聲が、其の方には、こがれる女の小玉だ、小玉だと聞こえたんですつて、こたまだ。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、妙ね、そういえば……何ですって、蛙の声が、その方には、こがれる女の小玉だ、小玉だと聞こえたんですって、こたまだ。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二例を挙げようか、彼等の或る者は曰く、私は才能なく学問にも暗い、ただ偶々俳諧を好み高桑闌更（俳人、江戸時代）にあこがれる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でも東京へ」とあこがれる気持ちの裡面には、自堕落によく似た自由解放や、虚栄と間違い易い文化的生活に対する欲望がチラ付いている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
