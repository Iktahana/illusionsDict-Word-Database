[
  {
    "uuid": "480492ac-6ed4-5391-a282-92239df19024",
    "entry": "黄砂",
    "reading": {
      "primary": "こうさ",
      "alternatives": [
        "おうさ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "yellow sand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と、突如、円形の黄砂広場は、直射を受けて眼に痛い。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "匍匐前進をやった後は、黄砂がどこからともなくしみこんで、胸や腹の皮膚を黄色にした。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "水が涸れて、河床が露出しているだけで、しかし黄砂のようにめり込まないから、歩きやすいのである。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうだとすると何がこの魚をこうさせるかが問題になる。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒いとこや山の中はみんなこうさ。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうさ降りだら馬も人もそれっ切りだったぞ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無駄をしないで、私と遊びに行きましょう」　そこで夫は苦笑しながら、「こうさばけられては仕方がない」と言って、朗らかに妻と一緒に遊びに出かけました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無名の青年　――あなたの純粋がこうさせたのです。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうさえしてしまえば、あとはむこうへ届こうが届くまいが、郵便屋の責任だ。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のに綺麗な衣服を、姉様と二人で縫い上げて、翌日は着せてあげようと楽みにして寝た晩から、あの邪慳な得三に、こうされたのはよく御存じでないかい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　二十三「たって聞きたくばの、こうさしゃれ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ついに一人残らず、こうさけぶようになってしまいました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、トナカイをすみっこへ連れていって、そこであたらしい氷を頭の上にのせてやりながら、こうささやきました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ゲルダは、はだをもつきさすような、寒さに気がついて、こうさけびました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とうとうしまいには、町じゅうの人たちが、ひとりのこらず、こうさけびました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも牛が眼をさましていたって、火をつけるにはいっこうさしつかえないわけだけれども。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの言いたいのはこうさ、日本がすすんで、自分の古いしょうばいがお役に立たなくなったら、すっぱりそいつをすてるのだ。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この巫女は、当年初に仕えたので、こうされるのが掟だと思って自由になったそうである。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、また、こうさせたことに就ての原因として、女が人から卒直に愛されるというそのことが女を急激に変えるものであるとするなら、実際その証拠をわたくしは身にみているわけであります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何番で、むこうさまのお名前は」と言って、いっかなわたくしが直接に呼出すのを諾いませんでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "命はまずその建の家へたずねておいでになって、その悪者とごこうさいをお結びになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、それを聞いて、こうさけびました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　東門をみつけて、参事官はこうさけびました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハートと、王女さまのかしらもじでふちどったしんぶんが、さっそく、はっこうされました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう風だから山手も下町も、千住の床屋でまで追出されやあがって、王子へ行きますとね、一体さきさき渡がついてるだけにこちとらの稼業はつきあいが難かしゅうがす、それだのにしばらく仕事をさしてもらおうというその初対面の許で、宿の中ほどの硝子戸をあけると、突然、私あ忙しい身体でござえして……とこうさ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりしていたが、一挺来ていたというもんだ、いつでもこうさ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒をいただいてるんです」「酒を飲むんだって、そんな乱暴に飲んでどうする」「あんまりです、あんまりです」　お政は泣き声にこうさけんでうつふしてしまった。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうさけんで母は奥座敷へとび去った。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つれなさを恨みもはてぬしののめにとりあへぬまで驚かすらん　あわただしい心持ちで源氏はこうささやいた。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "動かしてみてもなよなよとして気を失っているふうであったから、若々しい弱い人であったから、何かの物怪にこうされているのであろうと思うと、源氏は歎息されるばかりであった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
