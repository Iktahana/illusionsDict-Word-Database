        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例へば小松清氏によつて、行動主義文学といふのが提唱される。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "左に従い来る山々｜山骨黄色く現われてまばらなる小松ちびけたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉なくや小松まばらに山｜禿たりなど例の癖そろ／＼出で来る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡村先生が亡くなって後は小松という医者の厄介になった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松の若先生でも楠先生でも、もし無事だったらまだ生きておられてもいい年輩であったが、二人とも壮年で亡くなられた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松という名刺を見て主人は心当りがないらしく、ボーイにもう一度身元を聞かせた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松というのは母方の実家の姓だと言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八年前まで元気でおりまして、相変らず東海道を往来しておりましたが、神経痛が出ましたので流石の父も、我を折って私の家へ落着きました」　小松技師の家は熱田に近い処に在った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は休暇毎には必ず道筋のどこかへ出かけるようにしております」　小松技師は作楽井氏に就ていろいろのことを話した。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松技師は帰りしなに、少し改って「実はお願いがあって参りましたのですが」　と言って、暫く黙っていたが、主人が気さくな顔をして応けているのを見て安心して言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松技師が帰ったあと、しばらく腕組をして考えていた主人は、私に言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "草は柔らか向ふの小松はまばらです、そらはひろびろ天も近く落葉松など植えたもんだ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏の踊りも今時だめだ、まばらの小松も緑青を噴く。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は天主閣の建っていた所が平地になって、いつしか姫小松まばらにおいたち、夏草すきまなく茂り、見るからに昔をしのばす哀れなさまとなっています。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松のみどりが強烈な日光に照らされて樹脂中の揮発成分を放散するのであろう。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓のさまして緑なる、　　　小松と紅き萱の芽と、雪げの水にさからひて、　　まこと睡たき南かぜ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の下なる七つ森のその三つなり、　　小松まばらに雪を着るもの。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝより下は、左に小野某の小松島園あり、右に小松宮御別邸あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松島園より下は少許の草生地を隔てゝ墨田堤を望む花時の眺めおもしろく、白髯の祠の森も少しく見ゆ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつかしやの隠居は小松菜の中から俎板のにおいをかぎ出してつけ物の皿を拒絶する。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ていると、池のいちばんむこうのはしまでひろがっていって、そこの小松のかげが、ゆらりゆらりとゆれました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂家の屋敷は元来、町にあったのを、家運の傾むくとともにこれを小松山の下に運んで建てなおしたので、その時も僕の父などはこういっていた、あれほどのりっぱな屋敷を打壊さないでそのまま人に譲り、その金でべつに建てたらよかろうと。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松山の麓に移ってこの方は、純粋の百姓になって正作の父は働いているのを僕はしばしば見た。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂家の屋敷は元来、町にあったのを、家運の傾むくとともにこれを小松山の下に運んで建てなおしたので、その時も僕の父などはこういっていた、あれほどのりっばな屋敷を打壊さないでそのまま人に譲り、その金でべつに建てたらよかろうと。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の半面は亀井戸辺より小松川へかけ木下川から堀切を包んで千住近傍へ到って止まる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉は墓の間を縫いながら行くと、一段高いところにまた数十の墓が並んでいる、その中のごく小さな墓――小松の根にある――の前に豊吉は立ち止まった。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父さんを起こそうとしたがやめた、起こすと叔父さんがきっと『何だ何だ』と大きな声を出す、鹿が逃げてしまう、僕は思わず、叔父さんが小松に立てかけて置いた銃をソッと把った。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまつたね、話がないんだ、と言つて笑ふと、娘さんは、私の窮屈がつてゐるのを察して、男は無口なはうがいい、と言ひ置いてさつさと部屋から出て行つて呉れた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくすると、今度は敏夫が又ごろ／＼と轉つて來て、兄の胸に巣喰ふやうにちゞこまつて、二人で抱き合ふやうな形になつた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯すべからざる森厳の威に恐れかしこまつて居ると云ふ有様であつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
