        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "殘るものはただえたいの知れない暗がりに身心をひきずりこむ抵抗しがたい虚脱感あるのみである。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この空虚なさびしさは理窟ではどうすることもできない、心の深いところに根ざした抗しがたいものゝやうに思はれた。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを踏みつけようとしている良人の狂暴な手は、年々反抗しがたいものとなった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "横光利一や小林秀雄は、芥川龍之介が理性の冴えたインテリゲンツィアらしく率直に「漠然とした不安」の抗しがたいことを告白した、その社会と文学との発展がひきおこす歴史的に必然の動きを、糊塗してみせる手腕で存在しはじめた作家、評論家であった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜毎に私の大脳に忍び入つて、私を絶対に抗しがたい畏怖の下に圧しつけるものが、私の敵でなくて何だらう。",
              "citation": {
                "source": "美しき敵",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて事件のあったあの晩にも、今いったような抵抗しがたい衝動に駆られたのである。",
              "citation": {
                "source": "ピストルの蠱惑",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "えらそうな事を考えてみたところで、運命には抗しがたい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分では、こんな状態はいけないことだと思はないでもなかつたけれど、水の流れは、自分の抗しがたい方へ假借なくどんどん流れてゆく。",
              "citation": {
                "source": "濡れた葦",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不可解な抵抗しがたい壓迫と、悲しい實に悲しい心持が、僕を殆んど何も解らないくらゐにした。",
              "citation": {
                "source": "南方",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ミドルトン　わたしはしばしば機会があって、女性が忍耐強く、抗しがたいような逆境にたえてゆくのを見たことがある。",
              "citation": {
                "source": "妻",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも、憶い出すと、手足が震え、眼がまわるのであるが、そのときには、抗しがたい、ほとんど狂乱した衝動に促されて、この、たった一つの追求以外には、精神も感覚もみな失ってしまったようであった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾時代かの伝習はその抗しがたい手枷足枷で女をとらえた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、もはや抵抗しがたい威厳を帯びて、草の間から私に命じた。",
              "citation": {
                "source": "測量船",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分達の室は地面の上の穴倉みたような所で、四方共｜頑丈な建物だの厚い塗壁だのに包まれて、縁の前の小さい中庭さえ比較的安全に見えたけれども、周囲一面から出る一種｜凄じい音響は、暗闇に伴って起る人間の抵抗しがたい不可思議な威嚇であった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分達の室は地面の上の穴倉みたような所で、四方共頑丈な建物だの厚い塗壁だのに包まれて、縁の前の小さい中庭さえ比較的安全に見えたけれども、周囲一面から出る一種凄じい音響は、暗闇に伴って起る人間の抵抗しがたい不可思議な威嚇であった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここでお降り願います」　その声の調子のなかに、抵抗しがたい、強圧するような調子があった。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さん、君は――七十年この世に生き多少の名誉もかち獲た君は――精いっぱいの賢いことをいおうとも、わたしはすべてのそんなものから逃げだすようにさそう抵抗しがたい声を聞く。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは先日またそのそばを通ったが、八年前に何の害心もない空から恐るべく抵抗しがたい雷電が落ちてきた、あの痕跡がむかしよりもっとまざまざとしているのを仰ぎ見て畏れにうたれた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが相続した目もくらむような遺産という誰にも抵抗しがたい話題を持ち出してしまえばいい。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そのペンのあとは、今の峯子に抵抗しがたい思いで正二を偲ばせた。",
              "citation": {
                "source": "今朝の雪",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "抵抗しがたい暴力がのたうちまわり、住民の生活をはねとばし、直線の大道路をひきまわし、しかも何一つとして完成させないで、突然その狂暴な力は虚脱した。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "してはならないと考えていても、いつも外部から私の危険性が誘い出されるごとに、私は抵抗しがたい自分の性分のために、いつも淋しい後悔の心になるのであった。",
              "citation": {
                "source": "幼年時代",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉の響きは抗しがたいものがあったので、Ｋは全然返事をしなかった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "立派な美しさというものは何と抵抗しがたいでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色っぽい昼の光が、激しい雨におぼれて消えかかったころ、彼は抗しがたい衝動に駆られてテーブルから立上った。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし空腹からくる狂気のために恐ろしく、抵抗しがたいものになつていて、手向いのしようもなかつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが二人はさしあたり、抗しがたい眠気に襲われていた。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにをするかわからないこの若い藩主が自分の存在を高く評価していること、また笈川の将来がかなり大きく保証されているらしいことなど、老人にはまず抵抗しがたい誘惑であった。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでは抵抗しがたい天災の力に慄え戦いていたのであったが、このときに突如としてその心の態度が消極的から積極的へ移ったのである。",
              "citation": {
                "source": "地異印象記",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い顔の中で、きれいな白い歯が見えた、「塩引と菜っ葉の汁だけですけれど、どうか起きてめしあがって下さい」　炊きたての飯のあまいかおりと、魚を焼いた脂っこい匂いとが、彼をひっ掴み、抵抗しがたい力で彼を絞めあげた。",
              "citation": {
                "source": "あだこ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
