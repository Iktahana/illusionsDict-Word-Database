            },
            {
              "text": "先ほどの処の地続きは平にならされてテニスコートになっている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下がテニスコートの平地になっている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の下にはコートのローラーが転がされてあった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが済むと怪しげな名前の印度人が不作法なフロックコートを着て出て来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫がゝつた黒い処へ、一｜面に、はい、桜の花びらのちら／＼かゝつた、コートをめしてな。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空に一｜輪、蕾を添へて、咲いたやうに、其の常夏の花を手にした、細りと白い手と、桜ぢらしの紫紺のコート。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
