    },
    "definitions": [
      {
        "index": 1,
        "gloss": "coat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『わたし、フロックコート着る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの趣味はすべてにおいて庶民的で、儀式ばったことが嫌いなので、フロックコートなどの礼服を非常に嫌い、常に野蛮人の服と称し『なんぼ野蛮の物』と言っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれではあまり体面に関するので、夫人が是非フロックコートを新調するようにすすめたが、頑として中々きかない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上に参るの時、あなた、シルクハット、フロックコートですよ』などと、子供をだますようにして説き伏せられ、やっと礼服を新調したけれども、やはり少しも着ようとしない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コートリ、タマゴ、ハーカマ、ハオリ……」「アーメ、カサ、カーラカサ、アサヒ……マツ、ツル、シカノ……ツノ、ウシノツーノ。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈が高く顔の小さい、額がノツシリしてフロックコートのよく似合ふ、前校長の容姿が何時か彼の心を離れないものとなつてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "また向うからただ一人、洋紅色のコートを着た若い令嬢が俯向いたまま白いショールで口を蔽うて、ゆっくりゆっくり歩いて来る。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の日本人がステンショとかオーフルコートとか称したことを考え、昭和の吾々がビルジングとかブデンとか云っていることを考えればこれくらいはゆるしてもらってもいいであろう。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきり立ちでもするかと思った期待を外された養母の態度にみち子はつまらないという顔をして、ラケットを持って近所のコートへ出かけて行った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "静岡辺は暖かいからというので私は薄着の綿入れで写生帳とコートは手に持っていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘠せてオーバアコートを着てわらじを穿いた男が青光りのさるとりいばらの中にまっすぐに立ってゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんならわたしのコートやりますわ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「コートなんかぢゃ着ないも同じこったよ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてロンドン滞在中、某氏とハンプトンコートの離宮を拝観に行った事がある。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあのいつもの漆喰細工の大玄関をはいってそこにフロックコートに襟章でも付けた文部省の人々の顔に逢着するとまた一種の官庁気分といったようなものも呼び出される。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はユーストンの地下鉄の乗換場附近にある玄関に、日章旗を交錯した日本料理店胡月の卓子で、外交官の松岡、画家の山中、トンテム・ハム・コートの伊太利料理店の主人と暗い東洋風の部屋で、日本食の晩餐後お互に深い沈黙に陥っていた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "トンテム・ハム・コートの伊太利人は彫刻の美に昔から物馴れた眼をそむけて、醜悪なものの前で色を失っていた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンさんはコート・ダジュールの華美なノアイユ旅館から、度々妾のお芝居を見にいらっしゃったのだそうです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が自分の部屋にかえると隣の寝台にカーテンも引かないでペチ・コートのまま仰向けになったアダが、夢うつつにも寝床で寝るトア・ズン・ドルの女を再び見出した。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "海原、離宮、車輛、工場のテニスコート、僕が彼女の乳房のあたりを見つめているうちに、八時四十分、大阪着。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大島のかさねを黒いコートでつつんで、リスの毛皮を左乳に垂らした、頬紅をささない蒼白な厚化粧の女が、いつも一点をみつめ前後の気配を感ずる都会の女の乗った車が、中央九番街のクロス・ワード模様の東洋銀行のまえで停止すると、彼女のフェルトの草履が石畳を踏んで衣服の黒い裾裏が地上を流れる風にはねかえった。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気の流通がよくてしかも雨やあらしの侵入を防ぐという点では、バーベリーのレーンコートよりもずっとすぐれているのではないかという気がする。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午后はみんなでテニスコートを直したりした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "釦の多いフロックコートを着たようである。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ほどの処の地続きは平にならされてテニスコートになっている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下がテニスコートの平地になっている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の下にはコートのローラーが転がされてあった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが済むと怪しげな名前の印度人が不作法なフロックコートを着て出て来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫がゝつた黒い処へ、一｜面に、はい、桜の花びらのちら／＼かゝつた、コートをめしてな。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空に一｜輪、蕾を添へて、咲いたやうに、其の常夏の花を手にした、細りと白い手と、桜ぢらしの紫紺のコート。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
