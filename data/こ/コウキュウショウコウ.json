        "examples": {
          "standard": [
            {
              "text": "その作戦は、複数の国の高級将校が密接に連携して計画されたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は若くして頭角を現し、将来の軍を担う高級将校として期待されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の教科書には、多くの高級将校の決断が戦局を左右したことが記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それどころか軍中央部の高級将校のなかには、進んで激励や賞讃の言葉を蹶起の青年将校たちに呈する者が数多いたのである。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
