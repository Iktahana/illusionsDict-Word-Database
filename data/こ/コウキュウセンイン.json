    },
    "definitions": [
      {
        "index": 1,
        "gloss": "officer (of a ship)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんな考えは、高級船員などの間ではありふれた考え方であり、また普通船員のうちにあってもやはり同様であると信じられる。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも高級船員のうちにも、普通船員のうちにも、けっしてイングランド教会の者はいないのである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "船も高級船員もソワソワしていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボウトの傍には高級船員が拳銃を擬して立っていて、こういう者は射殺して構わないのだ。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しこの時早くも最悪の場合を予想し得た人があったとすれば、それはスミス船長と二、三の高級船員だけだったろう。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は上甲板の高級船員室の屋根に這い上がって、沈没と同時にブライドは其処から一度海に呑まれた。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、船橋上の高級船員の間には、戯談も幻想もない。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に船長初め高級船員がひた隠しにしても、事実は何時の間にか洩れて、船客一同の間に暴風雨のように拡まる。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "高級船員が行く処だからね。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｉ・ＩＮＡって聞くと毛唐の高級船員なんか慄え上るんだそうです。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、以前はその四人が、同じ室戸丸の高級船員だったことが明らかになれば、ぜひにも読者諸君は、それと失明との関係に、大きな鎖の輪を一つ結びつけてしまうに相違ない。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此二三十分間に僕は初めて高級船員の威厳と興味とを感じた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イルベリイ船長、コックス機関長、Ｔ・ノルマン一等運転士の他は、高級船員から乗組員全部、この一航海だけを期間に雇われた者許りだった。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤だの青だの、なんだかゴチャゴチャした色をしているから、ハッキリ形はわからないが、これはれいのラスキン大尉が名をつけたという『鉄水母』ではないのかなァ」　と、望遠鏡の中をしきりにのぞいている高級船員がいった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑うスミス警部　フランス汽船ルゾン号の高級船員は、長良川博士とエバン船長との間にとりかわされている無線電話を、高声器にみちびいて聞いていた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口をはいったところには、高級船員らしい七八人の男がきちんと整列していて、隊長岸少尉のかおを見ると、一せいに挙手の礼を行った。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに立っております高級船員たちも、どこから見ても中国人ですが、これがみな日本人なんで、商船学校も出た者もおりまするし、予備の海兵も混っております」　虎船長は、そういって後の船員たちを指した。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸隊長は、あらためて高級船員の面をじっと見まわしたが、なるほど、眼の光だけは炯々として、新東亜建設の大精神にもえていることがはっきりと看取される。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノーマ号の、高級船員らしいのが五六人、そこへ集ってきて、なにか協議をはじめた様子である。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長が、ノーマ号の高級船員を相手に、強硬に主張をつっぱっているには、一向おかまいなしで、むこうの水夫をつかまえて、手真似ではなしをしている。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長その他、高級船員は、むしろ、若者の留めやくにまわったのであるけれど、自分たちとても、もともと胸中にたぎる武侠精神の所有者だったから、あたまから、若者たちをしかりつけるわけにはいかない。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき奥から、高級船員があらわれて、こえをかけた。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、猛獣対人間の最初の戦闘において、かなり腕ぷしのつよい連中がやられ、高級船員も相当たおれ、それからボートを出して船を捨てて逃げだすなど、たいへんなさわぎになったそうです。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖餐礼や塗油式がして貰いたかろうと思ってよ、金を持ってるんなら、高級船員へでも渡しておいたほうがいいぜ。",
              "citation": {
                "source": "グーセフ",
                "author": "ГУСЕВ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この例において定期船の高級船員たちは飲料および調理に鉛水槽の水を使ったが、水夫たちは同じ水源の水を木製の容器に入れていた。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果、高級船員には疝痛の発作が起きたが、水夫たちすべては健康であった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "船で一緒に働いてをります男も女も、お客さまや高級船員の前では、それこそ、虫も殺さないやうな顔をしてをりますけれども、蔭で自分たちだけとなりますと、これはもう、恥かしいなんてことはまるで知らないもののやうになつてしまひます。",
              "citation": {
                "source": "緑の星",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえ、いえ、蔭と申せば、お客さまや高級船員が、なにをなさつてるかわかりやしません。",
              "citation": {
                "source": "緑の星",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国航路の高級船員の留守宅！",
              "citation": {
                "source": "オカアサン",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしばらくして、僕は船医と一緒に朝飯を食いにゆくと、食卓にはあまり船客が来ていなかったので、僕はわれわれと一緒に食事をしている一、二名の高級船員が妙に沈んだ顔をしているのに気づいた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "上床",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
