[
  {
    "uuid": "e4d2ad10-999c-5b12-889a-c30a48a6a2f2",
    "entry": "高級船員",
    "reading": {
      "primary": "こうきゅうせんいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
