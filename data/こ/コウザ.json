[
  {
    "uuid": "48a0442b-380f-5712-ada9-4fd5c30bffed",
    "entry": "口座",
    "reading": {
      "primary": "こうざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "account (e.g. bank)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ともかく事が過ぎ、ぼくの父があとの屋敷と銀行口座の一万四〇〇〇ポンドほどを受け継ぎました。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、原稿を用意してもらいながら、取次店の口座を開けずに、私たちは空中分解した。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の帳面の決算をして、その中のどの口座を見ても丸一年の間ずっと損にばかりなっていることを知る時じゃないか。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "書留郵便だと金がかかるといい、前橋では振替口座に加入していた。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その分の費用は、当方から一部、口座振込にてお支払いいたします。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "金を受け取るが早いか、密かに開設したシェバリエ・ロレーン名義の口座に振り込んだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "同口座から、ヨーロッパの各都で小切手が使える。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが銀行の僕の口座に入ってる。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「収入はなるべく使わないようにして、自分しか知らない口座に積み立てておいた、というのがもっとも純粋に自前のやりかたでしょうね。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから別の口座に移すのです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが銀行の口座を知ってるから、部屋代はそこに振り込んでくれたらいい。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ちに私の銀行口座に、手数料無償で一万九千二百五十五ポンド払い込んでください。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんの数日前、初老の共同経営者スペンサから買い、小切手で自分の口座から支払った。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時も今も、よく知らなかったこと、それは銀行に預けた口座から各種会費と競馬経費を支払い続けていること、その訳は行員への指示を取り消さなかったからだ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は楽しかったなあ、若さも元気も、銀行口座もあり、無尽蔵だった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行が口座を凍結し、投機的な担保にはとても用心深い。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国を出る前、銀行員に指示しなかったので、現在まで僕の口座残金から、出走費用が払われていたのです。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "何回も口座を開設するように申し上げたのですが、聞いてもらえませんでした。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "地位のある紳士が銀行口座を持たないなんて妙でございます。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙も、銀行口座も、帳面もないのです。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半腹にかかりある巌角の苔のなめらかなるに、一｜挺はだか蝋に灯ともしたる灯影すずしく、筧の水むくむくと湧きて玉ちるあたりに盥を据えて、うつくしく髪結うたる女の、身に一糸もかけで、むこうざまにひたりていたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　しょうねんたんていだんのたったひとりのしょうじょだんいん、宮田ユウ子ちゃんは、ルビーでできた赤いカブトムシをもって、じぶんのうちのせっこうざいくのこうばにはいって、なにかやっていました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
