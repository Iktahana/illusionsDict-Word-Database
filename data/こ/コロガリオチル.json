    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to tumble down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｓ＝廊下　障子破れて、襖が倒れて、五六人の黒い影が組んづほぐれつ段梯子を折り重って転がり落ちる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殴り込みだッ」Ｓ＝階段の処　折り重って転がり落ちる児分共。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれ百尺｜竿頭、百歩を進めた超凡越聖、絶学無造作裡に、上は神仏の頤を蹴放し、下は聖賢の鼻毛を数えるに到っては天魔、鬼神も跣足で逃げ出し、軒の鬼瓦も腹を抱えて転がり落ちるであろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて崖から転がり落ちると、女も続いてムササビのように飛び降りる。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしこの二つの領域で押し込まれてしまえば、やがてはより利益率の高い製品や米国内市場も、坂道を転がり落ちるように失ってしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "……斯んなことを考へてゐるうちに、階段を昇つて来るやうな眠気が、タッタッと迫つて来て、最少しで彼は、縁側から転がり落ちるところだつた。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを撮み取ろうとすると、円い実は小さな生物か何ぞのように、こざかしく指の間を潜りぬけて、ころころと地べたに転がり落ちる。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時は、病気にかこつけて、温泉場の旅館で、芳町時代から、関係の断続していた情人と逢っているところへ、いきなりクルベーに来られて、男が洋服を浚って、縁から転がり落ちるようにして庭へ逃げたあとに、時計が遺っていたりした。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "無我夢中に、どこをどう突走ったか覚えがないが、建物の外へ出ると、真暗な庭にとびだし、それから、つきあたったところの高い塀にヤッと飛びついて、転がり落ちるように塀の外に落ちた。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、こわいような、自分の身体がどこで止るか、止るまで分らず転がり落ちる夢中な感じは、何と痛快だろう！",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その弾丸が部屋の隅のグランドピアノを貫いたらしく、器械の間を銛丸がゴロゴロと転がり落ちる音が、何ともいえない微妙な音階を奏でた。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして銀次と絡み合ったまま玄関の石段を真逆様に転がり落ちると、小女は独りでムックリと起き上って、頭から引っ冠せられた銀次の着物と帯をはね除けた。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々｜雹でも降るかのように林の中から聞こえて来るのははぜた大栗が転がり落ちるのである。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこで拾ったのか、恐らく転がり落ちる間際にだったろうが、それを一生懸命に握りしめてるのである。",
              "citation": {
                "source": "霧の中",
                "author": "――「正夫の世界」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、　勝「御用だ」　ピュッーと来るやつを、身を退き身体を逆に反して、肋の所へ斬込んだから、勝藏は捕者は上手だが物干から致してガラ／＼／＼どうと転がり落ちる。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "車夫「あッ」　と梶棒を放して車夫が前へのめったから、急に車の中から出られません、車夫は逃げようとして足を梶棒に引掛け、建部の溝の中へ転がり落ちる。",
              "citation": {
                "source": "松と藤芸妓の替紋",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服の一部分に入れて置けばよいようなものであるが、五年も同じところに入れて置くと、洋服の生地がボロボロになり、その隙間からラジウムは自然に下に転がり落ちるだろうと考えられたからだ。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何百といふ雀の群が塊まり乍ら竹藪の中へ転がり落ちる。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬り損じた刀を取り直し、再度頭上へ振り冠った左門の足もとを、坂を転がり落ちる丸太のように、頼母の体が転がり、縁側の方へ移って行った。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "３「お兄イ様ア――ッ」と答える澄江の声が聞こえ、つづいてワ――ッという悲鳴が聞こえ、その澄江に突かれたのであろう、一人の博徒が横腹を抑え、街道から耕地へ転がり落ちる姿と、散った博徒の間を突破し、こっちへ走って来る澄江の姿とが見えた。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キャッ」　と悲鳴を上げると共に岩から下へ転がり落ちる。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラバラと四人とも転がり落ちる。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その皎々たる頬の上からきらりきらりと閃きながら、蓮の葉をこぼれる露の玉のように転がり落ちるものがあった。",
              "citation": {
                "source": "母を恋うる記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬られる者、斬ろうとして足踏み外し海に落ちる者、熊手に引き落されて溺れる者、組み合って刺されるやそのまま敵と共に海へ転がり落ちる者、平家が足場を十分に利用して戦えば、源氏はその不利を歴戦の勇でおぎなった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔っ払って、下水へ転がり落ちるはずみに、雨樋の先の尖がったところで、ほんの少し引っ掻いただけなんで――」　この調子では、何を聴いても素直には言いそうもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お民の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドを転がり落ちると、直ちに花の様な真赤な色が彼女の目を刺戟し、ヌルヌルした液体が彼女の触覚をくすぐった。",
              "citation": {
                "source": "江川蘭子",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、クリークの中を泳いですすむまね、掩護物のかげからかげに腰をかがめていく動作、トーチカを占領して万歳を絶叫する途端に腹をうたれて、ころころと土堤からころがりおちるところ――それらはみんな真にせまつてゐた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の表面が溶け、小さな流れをつくって大急ぎで沢のなかへ流れこみ、山襞や岩の腹についていた雪は大きな塊になってあわてふためいて谷の底へころがりおちる。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはどうしても、これになってしまうからね」　ひろ子は、指さきで頬っぺたを涙がころがりおちる形をしてみせた。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからだらだらと川上へのぼれば堰があり、そのうへに青く淀んだ水が三方にわかれてひとつは樋に、ひとつはむかふ岸の森のなかへ、残りは堰の口からどどんどどんと地響きをうたせてころがりおちる。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
