[
  {
    "uuid": "9c9c2b88-3b56-5380-ba53-91ad3a593801",
    "entry": "転がり落ちる",
    "reading": {
      "primary": "ころがりおちる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
      "ctype": null,
