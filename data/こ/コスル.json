[
  {
    "uuid": "daf55895-adb4-5195-bd45-6b8c84d0626f",
    "entry": "擦る",
    "reading": {
      "primary": "こする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to rub",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あのトラホームの眼のふちを擦る青い石だ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄なのなは大きくて引き擦るがらわがんなぃ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の甲をはげしく擦る釘のようなものを感じた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は冬によくやる木片を焼いて髪毛に擦るとごみを吸い取ることを考えながら云いました。",
              "citation": {
                "source": "鳥をとるやなぎ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と擦るように袖を撫でた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と奥さんが背中を擦るようにして言われたので、ハッとする。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と手の甲で引擦る。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は透さず第二の燐寸を擦ると、彼は再び眼を掩った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は勝つに乗って、続けさまに燐寸を擦ると、敵は既う此方を向く勇気が失せたらしく、頭を回らして一散に逃げ出した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は左の手に蝋燭を持ち、右の手に岩を抱いて、辛くも其身を支えているのであるから、到底燐寸を擦るべき余裕は無い。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は手早く燐寸を擦ると、余りに慌てた結果、火は点いたが又｜忽ち消えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は愈よ悶れて、一度に五六本の燐寸を掴んで力任せに引擦ると、火は漸く点いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで妙に氣が頽れて些とも氣が引ツ立たぬ處へ寂とした家の裡から、ギコ／＼、バイヲリンを引ツ擦る響が起る。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は絵の具を介して筆尖でこの怪物の面を押し擦るタッチのうちに病友がいかにこの腫物を憎んだか。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩提の善友、浄土の同行、契を此土に結ばんには今こそ言葉をかくべけれと、思ひ入て擦る数珠の音の声すみておぼえずたまる我涙かな、と歌の調は好かれ悪かれ、西行｜急に読みかくれば、彼方は初めて人あるを知り、思ひがけぬに驚きしが、何と仰られしぞ、今一度と、心を圧鎮めて問ひ返す。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き兼ねけんと猜するまゝ、思ひ入りて擦る数珠の音の声澄みて、と復び言へば後は言はせず、君にて御坐せしよ、こはいかに、と涙に顫ふおろ／＼声、言葉の文もしどろもどろに、身を投げ伏して取りつきたるは、声音に紛ふかたも無き其昔偕老同穴の契り深かりし我が妻なり。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを掻払うごとく、目の上を両手で無慚に引擦ると、ものの香はぱっと枕に遁げて、縁側の障子の隅へ、音も無く潜んだらしかったが、また……有りもしない風を伝って、引返して、今度は軽く胸に乗る。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……嫁御はなるほど、わけしりの弟分の膝に縋って泣きたいこともありましたろうし、芸妓でしくじるほどの画師さんでございます、背中を擦るぐらいはしかねますまい、……でございますな。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はッと縁側に腰をかけた、女房は草履の踵を、清くこぼれた褄にかけ、片手を背後に、あらぬ空を視めながら、俯向き通しの疲れもあった、頻に胸を撫擦る。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）女房　（背を擦る）若様は、歎悲むのがお嫌です。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の下に方一尺五寸に切りたる炉あり、一日に一度位は豆大の火種もなくなりて、煙草を吸ひつけるに燐寸を擦る事はあれど、大方は昼も夜も、五合入りの古鉄瓶にしにしたる水瓶など筆立や墨汁壺に隣りて無雑作に列べらる。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋民の小学校にありし頃よく用ひし事あり、丁子と云ふ名はよけれど、之を硯に擦るに、恰も軽石に踵の垢を磨く時の如き異様の音す。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と羽織を脱いでなお痩せた二の腕を扇子で擦る。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども時彦を嫌悪の極、その死の速かならんことを欲する念は、良人に薬を勧むる時も、その疼痛の局部を擦る隙も、須臾も念頭を去りやらず。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その陽子にジイーッと音を立てて燃える感じがあると、章三が思うのは、軸を手に持って、スッと擦る時の残酷めいたスリルに自尊心の快感を予想するからであろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒板へ書いている数式が間違ったりすると学生が靴底でしゃりしゃりと床をこするので教場内に不思議な雑音が湧き上がる。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）猫は停ってすわって前あしでからだをこする。",
              "citation": {
                "source": "猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで遠く、胡弓をこするような低い音が、悲しく連続して聴えていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに鉢の底面からは相当離れた所に固定しているコップは不動であるから、そこで相互間の週期的の摩擦運動が起こり、そのためにちょうど弓でクラドニ板をこする場合に似た事がらが生ずるのであるらしい。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの場合になぜ金属棒は松やにを着けた皮でしごき、ガラス棒だとアルコールを着けた綿布でこするか、この幼稚な疑問に対してふに落ちる説明をしてくれる教師はまれであろう。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
