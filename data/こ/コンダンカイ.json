        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "▼然し前述のやうに、当局者の『思はせぶりな頭のふり方』が案外、作家、ジャナリズムに大きく作用し、当局にとつても所謂『薬が利きすぎた――』状態を呈し、当局と文筆業者との懇談会などといふ、世話の焼ける催しも開かなければならなくなつたのであらう。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に出来ているサークルで、そこには婦人サークル員がまだ参加していないところでも、国際婦人デーの記念の座談会・懇談会は必ず持たなければならぬ。",
              "citation": {
                "source": "国際無産婦人デーに際して",
                "author": "――作家同盟各支部に婦人委員会をつくれ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文連の第二回「文化会議」のサークルに関する懇談会記事に云われているとおり、読むことによって成長させられてゆく面はゆるがせにできない。",
              "citation": {
                "source": "その柵は必要か",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、たとえば、文学者懇談会は、継続されなかった。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる肉体小説、風俗小説の作者から、共産党員である作家・批評家までを包括して持たれる懇談会は、ただそれらの各種の人たちが、もちこして来ているめいめいの型のままで、一堂によりあつまったというだけでは、烏合であろう。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "新日本建設国民運動の提案懇談会の際、「民間人」と称する代表者の中に元治安維持法関係の役人が参加していたことは会の本質を語るものとして注目された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その運動も一段落をつげた投票日の朝の懇談会である。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そういう方にたいしては、こちらでも、至急考慮いたしますが――……」　私たち二人の作家の訪問は、一回きりで、つぎに、保護観察所という、刑務所の出張所のような役所で、内務省の役人との懇談会があった。",
              "citation": {
                "source": "ある回想から",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露懇談会で知ったとき、フイリッポフに信仰談をした。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○国鉄と麻布三連隊の兵士　赤坂一レンタイと市電労働者の共同懇談会が持たれた。",
              "citation": {
                "source": "大衆闘争についてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、大衆的懇談会で革新有志二十人をつくる。",
              "citation": {
                "source": "大衆闘争についてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤勘十の労救の城南の懇談会をもった。",
              "citation": {
                "source": "「乳房」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "保護観察所は文筆関係者と内務省検閲課の役人とを招いて、懇談会を開いた。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "就ては、われわれはわれわれのポストを強化するため、明日正午から一時までの休憩時間に、われわれだけの懇談会を開くことにしたい。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "懇談会の儀、お忘れなきよう。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「懇談会とは何だい。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日の懇談会には、僕たちで、爆弾を投じてやろうじゃないか。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸太郎　うん、工業クラブで対支貿易の懇談会があるんだがね。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "○市電無事争議休戦　○きのう内相官邸にあった労働法案懇談会、資本家側にげ出し。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月四日（日）　宮、民主民族戦線の提唱者として各組合との懇談会を組織的に歩きはじめた。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十七日（日）　近代文学同人懇談会。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨勢博士があんまりトンマなことを言ったせいか、これを機に、大矢主任は懇談会を中止することにした。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "新刊の『活文壇』は再三上野｜三宜亭に誌友懇談会を開き投書家を招待し木曜会の文士｜交※文芸の講演を試むる等甚｜勉むる処ありしが、書肆早くも月々の損失に驚き文学を疎じて赤本を迎へんとするに至つて『活文壇』は忽ち廃刊となりき。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄文社劇評家懇談会日本橋の若松屋に開かる。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他慰労会といい懇談会といい委員会といい義理の宴会挙げ来れば尽る時なし。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十六日の東京に於ける民政党懇談会席上では、ロンドン条約にあまり触れないと云って、海軍第二補充計画についてだけ語っている。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "安藤広太郎・寺尾博・岡田武松・藤原咲平等の農学及び気象学の学者達が集って、農相官邸で「冷害対策懇談会」を開いて、色々面白い研究が発表された。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "計らずそこへ現れた伸子と素子とは、翌日もたれる懇談会へ招かれた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "懇談会へ傍聴に来ていた文化部の責任者から、その次の日、文化部を訪ねて来るように招かれた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それはまだ解決されず、雑誌『ピオニェール』の編輯局が中心となり、作家と小さい読者との懇談会を開いたりした。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
