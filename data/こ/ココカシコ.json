  {
    "uuid": "adb3bc94-dc16-53db-bbe0-d1c606cb50b2",
    "entry": "此処彼処",
    "reading": {
      "primary": "ここかしこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
