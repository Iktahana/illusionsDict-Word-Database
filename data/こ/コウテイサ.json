          "literary": [
            {
              "text": "今回自分は、鉄道模型を配置するような箱庭の取材にここへとやってきたのであって、高低差を求めてやってきたのである。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を境にして左右に分かれて高低差のある、高いほうの敷地のなかの、平屋建ての家だった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の南の縁は、十メートルほどの高低差のある脇道と接していた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の海まで、かなりの高低差があった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
