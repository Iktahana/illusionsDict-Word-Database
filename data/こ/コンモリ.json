        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どこか昔の姿が残っているが昔のこんもりした感じはもうない。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十幾階の角形の建築物や、工場の煙突の上に、白蝶の翼をひろげたように、雪の粉を吹いて、遠くはこんもりと黒く茂った森、柔かい緑の絨氈を畝ねらせる水成岩の丘陵、幾筋かの厚襟をかき合せたカスケード高原の上に、裳裾を引くこと長く、神々しくそそり立つ姿であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば信州へんでもある東西に走る渓流の南岸の斜面には北海道へんで見られるような闊葉樹林がこんもり茂っているのに、対岸の日表の斜面には南国らしい針葉樹交じりの粗林が見られることもある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなにか美しいはずのこんもりした渓間に、ゴタゴタと妙な家のこけら葺の屋根が窮屈そうに押しあっているのを見下ろして、なるほどこうしたところかと思った。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな闇の風景のなかでただそこだけがこんもり明るい。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が聴いたのは何週間にもわたる六回の連続音楽会であったが、それはホテルのホールが会場だったので聴衆も少なく、そのため静かなこんもりした感じのなかで聴くことができた。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遠そうだね」「あそこに木がこんもり茂っているだろう。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふわ／＼と其処へ靡く、湯気の細い角の、横に漾ふ消際が、こんもりと優い鼻を残して、ぽつと浮いて、衣絵さんの眉、口、唇、白歯。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道にさし出た、松の梢には、紫の藤かゝつて、どんよりした遠山のみどりを分けた遅桜は、薄墨色に濃く咲いて、然も散敷いた花弁は、散かさなつて根をこんもりと包むで、薄紅い。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋の二階の縁側にその時代にはまだ珍しい白いペンキ塗りの欄干があって、その下は中庭で樹木がこんもり茂っていた。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月影はこんもりとこの一群を映している、人々は一語を発しないで耳を傾けていた。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、黄ばんだ葉も半落ち切らない上に、何百年間か張りはびこった枝が、小さな森くらいに空を劃ってこんもりと影を作り、その処々に、尨大な毬の様な形に、葛の蔓のかたまりが宿って居るので、鳥はそのなかにでも隠れて居るのか、一向に、その姿が、トシオに見えないのでした。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と再び二人は飛行船に乗じて、今度は地と擦れ擦れに進みながら、そこここと見下すとある山の麓にこんもりとした林があってその間に一筋の小川が流れている。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「樹林がこんもりして、松の中に緋葉が見えましょう。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏切がこんもりと、草の中に乾いた川のように、こう高く土手を築いた処で、その、不性たらしい斑が、急に背筋に畝を打って狂って飛上るんです。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ向うに、煙だか、雲だか、灰汁のやうな空にたゞ一ヶ｜處、樹がこんもりと、青々して見えませう――岩崎公園。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「直きだ、そうれ、お前が行く先に、猫柳がこんもりあんべい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はこんもりとした森の中へ駆けこんで行きました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんもりとした大きな森のあいだには、お城や農園が見えたりかくれたりしています。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしく憂鬱なるこんもりとした森の木立のなかでいちめんに白い蝶類が飛んでゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんもりとした森の木立のなかでいちめんに白い蝶類が飛んでゐる　むらがる　むらがりて飛びめぐる　てふ　てふ　てふ　てふ　てふ　てふ　てふ　これはただ蝶が飛んでゐるばかりではない――ね。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しどろもどろの叢は雫の露をぶるぶる振り払いつつ張って来た乳房のような俵形にこんもり形を盛り直している。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水をひたひたと湛えた向河岸の石垣の際に、こんもりと雪の積もった処々を引っ掻いて木肌の出た筏が乗り捨ててあり、乗手と見える蓑笠の人間が、稲荷の垣根の近くで焚火をしている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すんなりと伸びた枝先にこんもりと盛り上る薄紅紫の花の房、幹の両方に平均に拡がる小さい小判形の葉。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はやゝ下膨れの瓜実顔の、こんもり高い鼻の根に迫らぬやう切れ目正しくついてゐる両眼の黒い瞳に、長い睫毛を煙らせて、地を見入つてゐるときには、何を考へてゐるか誰も察しがつかなかつた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝展の入選畫帳を父の本棚から持ち出しては、その中にひそめられた白い畫に頬をほてらせて眺めいつたり、私の飼つてゐたひとつがひの兎にしばしば交尾させ、その雄兎の脊中をこんもりと丸くする容姿に胸をときめかせたり、そんなことで私はこらへてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻だって、兄さんのは骨ばって、そうして鼻梁にあざやかな段がついていて、オリジナリティがあるけれども、僕のは、ただ、こんもりと大きいだけだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゃがんでいるツネちゃんのモンペイの丸い膝がこんもりしている。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ありたけの飛石――と言っても五つばかり――を漫に渡ると、湿けた窪地で、すぐ上が荵や苔、竜の髯の石垣の崖になる、片隅に山吹があって、こんもりした躑躅が並んで植っていて、垣どなりの灯が、ちらちらと透くほどに二、三輪｜咲残った……その茂った葉の、蔭も深くはない低い枝に、雀が一羽、たよりなげに宿っていた。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "差渡し、池の最も廣い、向うの汀に、こんもりと一｜本の柳が茂つて、其の緑の色を際立てて、背後に一叢の森がある、中へ横雲を白くたなびかせて、もう一叢、一段高く森が見える。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
