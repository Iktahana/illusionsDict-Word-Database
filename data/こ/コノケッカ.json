[
  {
    "uuid": "0689ec46-6d05-58cb-b267-64e7808776cc",
    "entry": "この結果",
    "reading": {
      "primary": "このけっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
