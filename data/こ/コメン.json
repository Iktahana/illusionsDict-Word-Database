        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "河口湖の湖面は朝霧に覆はれ、白く眼下に烟つてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎はさつそく泥をこねて、所謂岩乘な、いい舟の製作にとりかかり、狸は、すまねえ、すまねえ、と言ひながらあちこち飛び廻つて專ら自分のお辨當の内容調合に腐心し、夕風が微かに吹き起つて湖面一ぱいに小さい波が立つて來た頃、粘土の小さい舟が、つやつやと鋼鐵色に輝いて進水した。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は夕陽にきらきら輝く湖面に浮きつ沈みつ、「あいたたた、あいたたた、ひどいぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辛抱を試しみるように、湖面に、ときどきさざ波が立つ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖面の夕紫は、堂ヶ島を根元から染めあげ、真向いの箒ヶ崎は洞のように黝んだ。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖面暗くして波浪上らず、雨脚矢のごとく湖上を打つ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎はさつそく泥をこねて、所謂岩乗な、いい舟の製作にとりかかり、狸は、すまねえ、すまねえ、と言ひながらあちこち飛び廻つて専ら自分のお弁当の内容調合に腐心し、夕風が微かに吹き起つて湖面一ぱいに小さい波が立つて来た頃、粘土の小さい舟が、つやつやと鋼鉄色に輝いて進水した。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京を出てからもう二年目の秋だな」　復一は、鏡のように凪いだ夕暮前の湖面を見渡しながら、モーターボートの纜を解いた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エンジンを入れてボートを湖面に滑り出さすと、鶺鴒の尾のように船あとを長くひき、ピストンの鼓動は気のひけるほど山水の平静を破った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして傾いたボートの船縁からすれすれに、蒼冥と暮れた宵色の湖面が覗かれた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪の音がやや高くなって、中天に冴えて来た月光を含む水煙がほの白く立ち籠めかかった湖面に一｜艘の船の影が宙釣りのように浮び出して来た。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖面を想像させる冷い硝子の発散気を透して、闇の遠くの正面に、ほの青く照り出された大きな官庁の建物がある。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしらもどうせ、五月八日の赤城さまのお祭りには大洞へ上りますだから」　私たちはだら／＼と雪の火口原へ下り、湖面近くへ辿りつきました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの石に屈ませ、月の光に透して湖面を覗かします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南の外輪山を越したり峡間を抜けて吹いて来る風は、一吹き毎に無形の拳となり、霧の塊を湖面へ向けて投げつけます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中において恐らくいかなる湖面といえどもこれほどの水深を蔵する凄みは少いであろう。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはその壮麗なるダムの前の広々とした湖面を一周して、さて、いよいよ帰路についた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時過ぎ、おそい月が湖面に青白い光をそそぐ頃、盛政の軍は総退却を開始した。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く湖面を帆かけた小舟がのんびり通りすぎる。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の横から岡を越えて裏に出ると、廣い湖面に臨んだ小さな斷崖となつてゐた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は東金より買い来たれる菓子｜果物など取り広げて湖面をながめつつ裏なく語らうのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "里も若葉も総てがぼんやり色をぼかし、冷ややかな湖面は寂寞として夜を待つさまである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "セコチャンは、自分をのみ殺した湖の、蒼黒い湖面を見下ろす墓地に、永劫に眠った。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、かなりの重傷で、とても助からぬと見て竹青は、一声悲しく高く鳴いて数百羽の仲間の烏を集め、羽ばたきの音も物凄く一斉に飛び立ってかの舟を襲い、羽で湖面を煽って大浪を起し忽ち舟を顛覆させて見事に報讐し、大烏群は全湖面を震撼させるほどの騒然たる凱歌を挙げた。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚容は気抜けの余りくらくら眩暈して、それでも尚、この場所から立ち去る事が出来ず、廟の廊下に腰をおろして、春霞に煙る湖面を眺めてただやたらに溜息をつき、「ええ、二度も続けて落第して、何の面目があっておめおめ故郷に帰られよう。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が、湖面を渡って来たみたいに、ひやりとする。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれだけがその水をのむなら話がわかるが、ほかのもんもみんなのむ井戸に、どうしておれが金を出すのか、そこがおれにはよくのみこめんがのオ。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒藤権右衛門家内より、近藤右門様おんもとへ――」「こめんどうくせえこといってくるじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中があじけなくて、生きているのもこめんどうになったから、早く敷いて寝かしてくれよ」　悲しげに横たわると、そのまますっぽり夜具の中に面をうめてしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、菩提樹の葉で出来たというジーグフリードの致命点が、この場合、フォン・エッセンの何にあたるか――さっぱりぼくには、この取り合せが呑みこめんのだがね」　と検事は惑乱したように云ったが、さらに「ニーベルンゲン譚詩」を繰ってゆくうち、第二の発見が生れた。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
