        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あたしきっとあの森の中に立派なお姫さまが立って竪琴を鳴らしてゐらっしゃると思ふわ、お附きの腰元や何かが青い孔雀の羽でうしろからあをいであげてゐるわ。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その※ 繪は武家の奥方らしい女が座敷に坐つてゐると、その縁先に腰元風の若い女がしよんぼりと俯向いてゐるのであつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰元は正しく幽靈であつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭先には杜若の咲いてゐる池があつて、腰元の幽靈はその池の底から浮き出したらしく、髪も着物も酷たらしく濕れてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "草雙紙は、かの薄墨草紙で、酷い主人の手討に逢つて、杜若の咲く古池に沈められたお文といふ腰元の魂が、奥方のまへに形をあらはしてその恨みを訴へるといふところで、その幽靈がもの凄く描いてあつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その挿繪は武家の奥方らしい女が座敷に坐つてゐると、その縁先に腰元風の若い女がしよんぼりと俯向いてゐるのであつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹は腰元の藤江に化けていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂粉の気の少い処だから、此の青い燈籠を携ふるのは、腰元でない、女でない。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落城も程近い城中にあって当時若い腰元のおあんはその朋輩とともに、将卒が取って来たたくさんの敵の首の歯におはぐろを塗っているのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆はどんなメンタルテストをしたかと言うと、自分の腰元の中でも、年頃で一番美人の女を選びまして何やらそっと命令け、かの禅僧の修業している庵室へ行かせました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い腰元は庵室を覗いて見ますと、かの僧は室の中央に静かに坐禅を組んでいました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い腰元は、試験も済んだので、老婆のところへ戻って行き、僧の一件を報告しました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、あの若い腰元がもたれかかったのを実際世間上の場合に見立てれば、一人の女性に恋をし向けられた場合と見て取ってもいいわけです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸は内へ、左右から、あらかじめ待設けた二｜人の腰元の手に開かれた、垣は低く、女どもの高髷は、一対に、地ずれの松の枝より高い。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶にこぼれて出て来るのは、小姓梅之助に手を曳かるる腰元の青柳か、密と外して酔ざましの椎茸髱。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方でも其界隈は、封建の頃極めて風の惡い士町で、妙齡の婦人の此處へ連込まれたもの、また通懸つたもの、況して腰元妾奉公になど行つたものの生きて歸つた例はない、とあとで聞いた。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いわれも聞きたし、更めて花の礼も言いたいが、――何だか、お前さんは、魔神の眷属……と言って悪ければ、娘か、腰元、ででもあるような気がする。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "初卯の日、母様が腰元を二人連れて、市の卯辰の方の天神様へお参んなすって、晩方帰っていらっしゃった。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの腰元に斉眉かれて、荒き風にも当らぬ花なり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "引退りて腰元一人、三指にて侍べれり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "照子は腰元を召して、「門内に変死があるというね。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰元やがて復命すらく、「乞食より汚穢い婆々です、さうして塩茄子のように干乾びておりますよ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と腰元に顔を見られて少しく狼狽え、「直ぐ出懸けるよ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "照子はわくせく気を急らし、腰元附添い駈出でて、永田町へ……「御急ぎッ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡瓜ならば日野川の河童が噛ろう、もっての外な、汚穢うて汚穢うて、お腰元たちが掃除をするに手が懸って迷惑だ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "左に、腰元、木の芽峠の奥山椿、萌黄の紋付、文金の高髷に緋の乙女椿の花を挿す。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お巡りさんの前を、豆潜水艇をのせたトラックは、すこしもとがめられないで、通りすぎていきました。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こしもと衆のはなしでは、そのときばかりはお顔のいろまでがまっさおにかわって、ひでよし公をはったとおねめつけなされたそうにござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしだけはなんとなく無気味なようにかんじまして、うす／＼嗅ぎつけておりましたので、「あのお児はお茶々さまに眼をつけているらしい」と、こしもとしゅうに耳うちをしたことがござりましたけれども、めくらのひがみだと申されましてみなさまがおわらいなされ、まじめにきいて下すったかたはござりませなんだ。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こしもとしゅうにきゝましても、丸顔のおかおがひところほそおもてになられましたのに、このころはまた頬のあたりがふっくらとしもぶくれにおなりあそばし、それにおくれ毛のひとすじふたすじかゝりました風情はたとえようもなくあだめいて、おんなでさえもほれ／″＼したと申します。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
