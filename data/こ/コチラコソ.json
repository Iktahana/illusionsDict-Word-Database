        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「いいえ、こちらこそ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらこそ」　鶴雄も頭を下げて、はなれて坐るわけにもいかないので、傍へ行くと、「昨日の方を待っていらっしゃるんでしょう」　宮子はずばりと言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、こちらこそ……」　中之島公園でのことを想い出して、豹吉は微笑しながら、「――こんなところで、会おうとは思わなかったよ」「いや、案外会うんじゃないかと思っていた」　小沢はにやにやしながら、言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、ごらんのとおりの、おたふくで、いい加減おばあさんですし、こちらこそ、なんのいいところも無い。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こちらこそ願ってもない。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ手習いの難波津の歌さえも続けて書けない子供でございますから失礼をお許しくださいませ、それにいたしましても、嵐吹く尾上のさくら散らぬ間を心とめけるほどのはかなさこちらこそたよりない気がいたします。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらこそ飛んだ粗相、本当に三平さんとやらがおっしゃる通りです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はあ、あの、こちらこそ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらこそ、お変りなくて結構です。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、こちらこそ御禮を申遲れまして。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渥美　　こちらこそ……。",
              "citation": {
                "source": "賢婦人の一例（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらこそ、外して頂かなくつちやなりますまい。",
              "citation": {
                "source": "賢婦人の一例（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "微々　　いや、こちらこそ……。",
              "citation": {
                "source": "喧嘩上手",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸地　　いや、こちらこそ……。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらこそ」と、妻が挨拶を返す。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやいや、こちらこそ、ご迷惑なことをお願ひして……。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好　いやあ、こちらこそ。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらこそごぶさたしています。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、こちらこそ」と隼人は会釈を返した、「こんな時刻に御足労をかけて済みません、かけはしを直したらまた御相談にあがります」「お待ち申しております」と云って、老人は夜空を仰いだ、「明日は晴れるようでございますな」　翌朝、隼人は四時に起きた。",
              "citation": {
                "source": "ちくしょう谷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻太郎はん、頼りないよってに、よろしゅう頼みまっさ」「こちらこそ」　大勢の芸者たちが、藤間いせの指導の下に、稽古に熱中している。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「四五日うち、出そうかと思うとります」「お手柔かに頼みますばい」「こちらこそ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちのことは水に流して、おつきあい下さるとありがたいです」「こちらこそ、そう願いたいと思うとります」「辻木惣八は、わたしも、或ることで、すこしは関係があります。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は真赤になって、「こちらこそ、よろしく……」　すると朝野は、「先生」ともあろうものがヒョコヒョコした態度をとっちゃ困るといった顔で、私のお辞儀をやめさせようとするように、「先生は……」　一層いかめしい声をして、言いかけるのを、「朝野君……」と私は遮った。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知らないで男が安心しきって笑っているのを見ると、こちらこそ、ふきだしたくなるのでした。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらこそ」「この塀ですけれどね。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにぶんよろしく」「こちらこそ」　幼い頃から変わっていないヨシオの気質のひとつは、やらなければならないなにごとかが目の前にあらわれたなら、そのことにすぐにとりかかって手早く終わらせてしまうという、常にはっきりした傾向だ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしくお願いします」「こちらこそ」「店の外へ出てみて」　ふたりは店の外へ出た。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎さんとおっしゃる」「そうです」「まあ、それはそれは、わたくし、こうして初めて電話でお話をしますけど、じつはお母さまの昔の友人で、杉浦と申します」「はあ」「初めまして」「どうかよろしく」「こちらこそ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらこそ不満でおざる」「窮鳥｜懐に入れば――という事もある。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
