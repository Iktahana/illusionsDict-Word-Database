    "definitions": [
      {
        "index": 1,
        "gloss": "confused fight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "徒歩の兵は大部分討たれあるいは捕えられたようだったが、混戦に乗じて敵の馬を奪った数十人は、その胡馬に鞭うって南方へ走った。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又前方で新発田隊と穴山隊の混戦があったが、穴山隊も死力をつくして激戦した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "我を忘れる混戦の中でも、流石に心々の色は見える。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇がこの期に達した時には混戦の状態に陥いる。",
              "citation": {
                "source": "文壇の趨勢",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "混戦の状態に陥ると一騎打の競争よりほかになくなってしまう。",
              "citation": {
                "source": "文壇の趨勢",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の文壇がすでに混戦時代に達したか、あるいは達せんとしつつあるかは読者の判断に任せておきます。",
              "citation": {
                "source": "文壇の趨勢",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる混戦時代が始まって、彼我相通じ、しかも彼我相守り、自己の特色を失わざると共に、同圏異圏の臭味を帯びざるようになった暁が、わが文壇の歴史に一段落を告げる時ではなかろうかと思います。",
              "citation": {
                "source": "文壇の趨勢",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎは善悪混戦の時代である。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "結論――自分の立場",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く混戦となったのである。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして一層の混戦が、展開されることになった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その混戦の場を抜き、一挺の駕籠が飛んで来た。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそういう光景に対し、何んのかかわるところもなく、混戦は引き続いて行われていた。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その混戦の場を抜け、一人の女が彷徨っていた。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一大混戦となり、小林は包まれて出られず、田川がトップをきっていたが、ゴール前の混戦に、アッというまに横からとびだした黒五郎が優勝してしまった。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "混乱混戦の場となったが、この時｜宿もいよいよ混乱！",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから恐ろしい混戦になり、坊主之助を取り遁がしたのだ」　数馬は山路を里ある方へ一人苦しそうに歩きながら昨日からの事を考えた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は昨日の戦いが混戦になるのを待ち構えて花村方の陣へ入り、坊主之助を付け狙った。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのうちつづみの与吉は、小高い斜面の切り株に腰をかけて、たかみの見物と洒落ていたがだんだんのんきにかまえていられなくなって、そこらにある石でも枯れ枝でも手あたりしだいに泰軒を望んで投げつけてみたけれど、単に混戦の度を増して味方に迷惑なばかり。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鳴動の突然なのには、ちょっと胆力を奪われたが、何しろ早晩地面の上へ下りるべき運命を持った身体なんだから、しまいにはどうかしてくれるだろうと思って、やっぱり頬杖を突いて河岸の上の混戦を眺めていた。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "師盛だけは夜の混戦にまぎれて一人だけ離れたが、平内兵衛、海老次郎を召し連れて、一の谷に落ちていった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか戦は全くの混戦で、源平の区別もつかぬ程、沈む小舟があるかと思うと、ひっくり返る舟もあって、戦は夜まで続いた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋上はたちまち混戦になった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にはみな西川派へ合流してしまったようなものだが、この三派にもおのおの、盛衰と消長とがあって、或いは合し、或いは離れて、かなりの混戦があった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいら一人を目の敵にやって来たなら、まだ始末はいいが――この多勢で入乱れて混戦となったら手はつけられねえ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには絶望的な混戦があった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような頑強な抵抗が三週間続いた後、コルテスは遂に総攻撃を決行したが、混戦の最中コルテス自身は危うく捕虜にされそうになり、若い士官の身代りによって漸く助かった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "日を経るにつれて、日ごとに県下の混戦が報ぜられた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民や観念の闘争の偶然性のために、他日敵味方となって混戦中に投ぜられるかもしれないが、しかし味方となろうとも敵となろうとも、常に同系の人間であったし、いつまでも同系の人間であるだろう。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにこそ外部の静穏の下に、ホメロスの描ける巨人の戦いがあり、ミルトンの語れる竜や九頭｜蛇の混戦があり妖怪の群れがあり、ダンテの言える幻の渦がある。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
