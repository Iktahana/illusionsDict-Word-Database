[
  {
    "uuid": "53ce9481-6acb-56a9-9281-d878a1aa3d14",
    "entry": "忽焉",
    "reading": {
      "primary": "こつえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
