      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sudden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "竟に非望の遂げられないことを悟つた紀昌の心に、成功したならば決して生じなかつたに違ひない道義的慚愧の念が、此の時忽焉として湧起つた。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに非望の遂げられないことを悟った紀昌の心に、成功したならば決して生じなかったに違いない道義的｜慚愧の念が、この時｜忽焉として湧起った。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居常唯だ書籍に埋もれ、味なき哲理に身を呑まれて、徒らに遠路に喘ぐものをして、忽焉、造化の秘蔵の巻に向ひ不可思議の妙理を豁破せしむるもの、夏の休息あればなり。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに在りと見れば、忽焉としてかしこに在り。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時｜忽焉として、二十五―二十七節の大思想が彼に光の如く臨んだ。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角京までやって来たことであるから、長崎、薩摩とまでは飛ばなくとも、せめて浪華あたりにその姿を現すだろうと思われたのに、いとも好もしくいとも冴えやかなわが早乙女主水之介が、この上もなく退屈げなその姿を再び忽焉として現したところは、東海道七ツの関のその三ツ目の岡崎女郎衆で名の高いあの三河路でした。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まことにそれは忽焉として先の日消えてなくなったむっつり右門で、右門は伝六のうれし泣きに泣いている姿を静かに見おろすと、涼しそうにいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どういう子どもをどこへ売ったか、大きななぞの雲が忽焉として目の前に舞い下がってきたのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を敲けば盃酒｜忽焉として前に出で財布を敲けば美人｜嫣然として後に現る。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "シリア王セレウコスの命をうけてイエルサレムの殿の資物を奪はんとせし時一騎士忽焉としてその前に現はれ、馬蹄にかけてこれを逐へり（マッカベエイ後、三・七以下）第六例、ポリュメストル（ポリネストル）。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "常陸の大洗磯前神社の「かみがたいし」（神像石）など、一夜のうちに忽焉と、暴風雨の後に現われた、と歴史の書物にも書いてある。",
              "citation": {
                "source": "石の信仰とさえの神と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、ほんとうはこうして二人から離れ、私ひとり窓のそとの景色に忽焉としているというのは、そのときのわが姿を、なん年振りかで眼に描いて、なつかしみたかったからである。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、泣いて独語したが見る間に、少年は忽焉として消え失せたという。",
              "citation": {
                "source": "支那の狸汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十一年九月）　　　　　星亨の自由黨　　　　　　（一）政治的喜劇　横濱埋立事件は極めて簡短なる問題なり唯だ斯くの如きのみ而も此の事件の眞相一たび世間に暴露せらるゝや、忽焉として茲に政治的喜劇の舞臺を開展したりき其顛末を略叙すること左の如し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十一年九月）　　　　　星亨の自由党　　　　　　（一）政治的喜劇　横浜埋立事件は極めて簡短なる問題なり唯だ斯くの如きのみ而も此の事件の真相一たび世間に暴露せらるゝや、忽焉として茲に政治的喜劇の舞台を開展したりき其顛末を略叙すること左の如し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "物の実質が忽焉として宇宙から消滅して、物でない勢力が生まれたという風な考え方は不必要なのである。",
              "citation": {
                "source": "救われた稀本",
                "author": "――寺田寅彦著『物理学序説』",
                "note": "青空文庫"
              }
            },
            {
              "text": "無人の境に忽焉として現出する氷の宮殿ならば、嘆賞しておくだけで済むが、この現象がトンネルの掘ってある山などに起きると、話が面倒になってくる。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこういう立派な仕事が、当時の日本の武蔵野の一隅に忽焉として現われるはずはないので、何かこの書が出るには、それだけのものを産むべき学問の流れがあったにちがいないということは誰にも考えられる。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍之介の衰弱したヴァイタリテイはその後久しからずして彼自身を忽焉と他界に導き、「文芸的な余りに文芸的な」は彼の文学信条を語る遺書となつたのを見てもわかる。",
              "citation": {
                "source": "個人的な余りに個人的な饒舌",
                "author": "＝龍之介対潤一郎の小説論争＝",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば悔い改めにふさわしき果を結べ」（マタイ三の七、八）と叫びし預言者の声は忽焉として絶え、「女の産みたる者のうち、ヨハネより大なる者はなし」（ルカ七の二八）とまで激賞せられし洗礼者の首は、宴席の座興として妖婦の盆に載せられたのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "神農・虞（舜　）・夏（禹　）（三七）忽焉として沒しぬ、（三八）我安くにか適歸せん。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "伯夷列傳第一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【三七】忽焉として沒す。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "伯夷列傳第一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがイデオロギーのこの規範性・価値性・は何か不可解な神秘力によって忽焉としてイデオロギーの上に天下ったのではない。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を胆（み）れば前に在り、忽焉として後えに在り。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が今日まで黒暗々裡に、暗中模索に捕われていた迷宮に、忽焉として一道の光明が現れたのを覚えた。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大都市が、ぶうんぶうんと虻の飛び交っているこの山中の真昼の睡った空気と瑠璃色の空の下に、今｜忽焉としてその全貌を晒け出しているのであった。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に中尉の病患に対して最も必要なる、アドレナリン注射液及びカルビタミン剤の持ち合せなく、大尉は窮余｜已むを得ず、薬草よりの代用薬採取を企図せられ、極力栽培に努力していられましたが、未だその成功を得ざるうちに忽焉として中尉の長逝を見ましたことは我々の最も痛恨極まりなきところであります。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "種明かしをすれば、畢竟それは陰翳の魔法であって、もし隅々に作られている蔭を追い除けてしまったら、忽焉としてその床の間はたゞの空白に帰するのである。",
              "citation": {
                "source": "陰翳礼讃",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
