    "definitions": [
      {
        "index": 1,
        "gloss": "moderately wealthy person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのトッテン師匠の高座が一九九〇年六月十三日、新百合ケ丘のアシスト本部でかかると聞いたものだから、日本一のウイルス男たるこのオレは、システム・ダウン寸前の老骨にむち打って、小金持ちの蝟集する川崎市麻生区の新興高級住宅地へと馳せ参じたのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の方がいいが、しかし必要とあればどこの小金持ちでも金持ちでも悪くないというのである。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い半木造の小屋だが、倹約家で小金持ちのようだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服にもじり外套を着てソフトをかぶった小金持ちというかっこうである。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレンジを手押し車に乗せたストランドの行商人が突然小金持ちになった。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
