[
  {
    "uuid": "8da77fff-f957-571b-88ae-249c58e9f67b",
    "entry": "根拠のない",
    "reading": {
      "primary": "こんきょのない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "形容詞"
      ],
      "ctype": null,
