    },
    "definitions": [
      {
        "index": 1,
        "gloss": "baseless",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼が狐を使ってひそかに魚を捕らせているところを源吉が偶然に見つけて、それを世間へ吹聴したので、その復讐のためにこんな目に逢わされたのではないかというのも、まんざら根拠のない想像説でもなかった。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそんなたぐいの話は支那に沢山あるから、お岩のことも矢はり支那から輸入されたものではないかと思われるが、現に江戸時代には左門町にお岩稲荷があり、今日でも越前堀に田宮稲荷が現存している以上、まったく根拠のないことでもないらしい。",
              "citation": {
                "source": "四谷怪談異説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の主張がまんざら根拠のないことでもないという証拠の一つとして、その侍の刀の刃がよほど零れていたという噂が伝えられた。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェランダに立っていたら、ふと、或る異常な（一見根拠のない）感情が私を通って流れた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「根拠のない帰結の方がすこぶる印象深いものだ。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "無頼漢の数について彼が発表した推測なるものが、パリのあらゆる令名ある解剖学者たちから、でたらめで、ぜんぜん根拠のないものとして当然いい笑いものにされている、ということだけを言っておけば十分だ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪人が檻の中に入れられることを囚われるという、学ぶということは檻の中に入り込むような事では無い、学んで善に従うことを形式に囚われるなどと云うのは、根拠のない言葉の甚だしいものである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それはデマであるが、根拠のないこともあるまい。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かつては有害だと思われていたし、それは根拠のないことじゃなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは皆、専門の学術から割り出したもので、根拠のないことなど、僕は喋らない。",
              "citation": {
                "source": "十年後のラジオ界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの外科医が下手人の数について発表している推定なるものが、パリーの第一流の解剖学者たちによって、不当な、全然根拠のないものだとして一笑に附せられているということをね」　とあるところを見ると、検屍に立ちあった医師までが犯人の多数説を建てたと見える。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで当然の帰結として永劫観念は根拠のないものだということになり、宇宙は無限の過去から存在しているのではなくて、初まりがある、すなわち創成されたものでありその際に物質もエネルギーも成立したものであるということになるのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、右翼日和見主義者とその眷族調停派たちは、自身の誤謬を固執し、作家同盟の一部の同志は、同志小林の指導的批判に対していささかも科学的根拠のないデマゴギー的漫罵をわめきたてさえしたのである。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤んぼのような根拠のないうれしさだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この報告につづくいくつもの理論部会の報告は、おのずから、小説部会からの訴えが根拠のないものでないことを感じさせたのであった。",
              "citation": {
                "source": "両輪",
                "author": "――創造と評論活動の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一概に空想とか迷信とかいうが、全然根拠のないものからはなにも生まれては来ない。",
              "citation": {
                "source": "錯覚した小宇宙",
                "author": "――Our faith comes in moments;",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、如何に臆測好きな人達でも、全然根拠のない臆測を公然と真実めかして話すのも憚られるのか、誰れも、その死因は判然しないと云つて居ります。",
              "citation": {
                "source": "背負ひ切れぬ重荷",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件以来、ありと凡ゆる根拠のない風説や、個人的な悪感情に基くとしか思われない様ざまな意外な人への疑点や中傷などが、連日何十何百となく、或いは態わざ自身訪問して、あるいは文書で、しっきりなく舞い込んで来ていて当局は応接に暇なく、極度に悩まされ続けていた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし九郎右衛門がそれを止めて、四国へ渡ったかも知れぬと云うのは、根拠のない推量である、四国へもいずれ往くとして、先ず手近な土地から捜すが好いと云った。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これに対して、妻は断固として私の疑いの根拠のない事を主張しました。",
              "citation": {
                "source": "途上の犯人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはどっちも根拠のないあらそいではなかった。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "私とは勿論くらべものにはならないけれども、私は一月から六月中旬までの間に相当妙な調子になって、やっとこの頃普通にかえりましたから信用しなかったのも全く根拠のないことではないわけです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "円材甲板に六百十四噸の石炭を積む能力があって、そのために安定を失ったのではないか、との話しもあったが、調べてみると、当時ダアバン港で二百五十噸の石炭しか取っていないことが判り、これも根拠のない事になった。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼の一生に力を尽そうとする天野の恩義を思って自分の心を疑い、根拠のない妄想を消そうとしてみたが駄目であった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "又雅楽舞台の影響についても、何等根拠のない事です。",
              "citation": {
                "source": "能舞台の解説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、蜂矢探偵が、あのへんな透明な針金細工のようなものを、金属Ｑの兄弟ではないかとうたがっているのも、根拠のないことでもないと思われる。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラヂオ風景とは、どこから生れて来た言葉か知らぬが、要するにかういふ名称は、文学の様式的分類から云へば、甚だ根拠のないもののやうに思はれる。",
              "citation": {
                "source": "ラヂオ・ドラマ選者の言葉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが不安を感ずるのも、実は根拠のないことかも知れないし、無籍者という言葉にびっくりしたのも、実は思いすごしかも知れないし、北村さんがへんに隠し立てするようなのも、他に何の理由もないのかも知れないし、すべて取るに足らないことかも知れない。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は単に根拠のない併し、又同時に新しい文法を形づくるところの気分であつて、蔑にすることは出来ないが、この場合大きな惑ひを惹き起すことがあるから注意をせねばならぬ。",
              "citation": {
                "source": "形容詞の論",
                "author": "――語尾「し」の発生――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この、あまりにも因果的とも考えられる、謎の解決にも、決して、根拠のないことではございませぬ。",
              "citation": {
                "source": "京鹿子娘道成寺",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
