    "definitions": [
      {
        "index": 1,
        "gloss": "Yellow River (China)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
