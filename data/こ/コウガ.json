        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昨日、※口の沼へ鴨打ちに行ったら、土匪がツカ／＼っと、六、七人黄河の方からやって来たんですよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや山東が、その地理的優越に於て、その軍需的価値に於て、その黄河流域無限の富庫を後方地帯に抱容する点に於て、我等は国防上、国民生活上、永久にこれを勢力圏中より逸し去ることは出来ない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国資本家の如きは、早くも黄河の氾濫地帯が棉花栽培に適することに着目し、調査の歩を進めている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、黄河を迂回して、側面からここを圧迫する馮玉祥の騎兵部隊と、泰山の南を縫うて、明水平野に出た陳調元の優勢な一部隊に圧迫せられ、又、戦わずに、界首と、黄河の線を抛棄した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つゞいて、黄河の鉄橋を破壊しつゝ津浦線を、天津に向って退却した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に三時間の後、黄河に沿うて側面から迫りつゝあった方振武が到着した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、こゝから約四哩の黄河の沿岸の※口まで、一息にとばして、そこから天津方面へ落ちのびるのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人とも黄河の河畔で、犬に喰われて白骨が出ていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の水を説かんとして先づ隅田川を説くは、例へばなほ水経の百川を説かんとして先づ黄河を説くが如し、説述の次第おのづから是の如くならざるを得ざるのみ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、新聞記事の多数の読者には、どうしても、当人が登壇して滔々と論じたかのごとく、また黄河の水を大きなバケツか何かで、どんどん日本海へくみ込むかと思わせるようになっているのである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓠子は即ち瓠子口にして、黄河の水を塞ぐの処、濮陽県の南に在り。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢武帝の時、黄河大に漲り、瓠子を決して、鉅野に注ぎ、淮泗に通じたることあり。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天より來る大黄河、長江の水さかしまに、ひた攻めのぼる兵の勝鬨すでに年｜經りぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡命太子は趙簡子の軍に擁せられて意気揚々と黄河を渡った。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け暮れ黄河の水ばかり見て過した十年余りの中に、気まぐれで我が儘だった白面の貴公子が、何時か、刻薄で、ひねくれた中年の苦労人に成上っていた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡命太子は趙簡子の軍に擁せられて意氣揚々と黄河を渡つた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け暮れ黄河の水ばかり見て過した十年餘りの中に、氣まぐれで我が儘だつた白面の貴公子が、何時か、刻薄で、ひねくれた中年の苦勞人に成上つてゐた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僊人も羨門高、王子喬、元尚、宋母忌、最後、皆燕人で、東北方の者だが、始皇は燕齊の人山、涜山、黄河、、豐鎬、杜亳（こゝには杜主を祀つたのだが、杜主は周宣王に殺された杜伯を祭つたので、人を神にしたのだ）これらの諸處に歳時の祀を致した、中にも雍の奉祠は非常に盛儀であつたと云はれてゐる。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞や牛乳の配達をして相間に勉強しやうてのは、（亀井君は現にやつておるが）、実は中々忙がしくて、片手間の勉強で成効しやうてのは百年黄河の澄むを待やうなもんだ。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世祖皇帝が江南をお手に入れる時、大軍を率いて黄河までお出でになりましたが、渡るべき舟がありません。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "続夷堅志・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考では、例へば、黄河の沿岸から文化が發芽して、それが初め西或は南の方に開けて、それから段々東北に向つて開けて行つたのが、最後に日本まで到達して來たのであります。",
              "citation": {
                "source": "日本文化とは何ぞや（其二）",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば最初支那の中でも、三代といふやうな古い時代に起つた勢力は、今の黄河の流を中心としたものでありませうが、それが揚子江の沿岸を刺激して、そこに新しい勢力を形作るといふと、漢の高祖などゝいふ人が其地方から起つて全國を一統して居る。",
              "citation": {
                "source": "日本文化とは何ぞや（其二）",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は黄河の沿岸地方で起りましたのが、今日では支那の文化の中心は矢張揚子江の下流の地方、或は廣東とかいふやうな餘程支那の邊土に文化の中心がありまして、其地方から人物も出來れば、又文學とか藝術とかいふやうなものも出て居ります。",
              "citation": {
                "source": "日本文化とは何ぞや（其二）",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "未亡人の涙７・17（夕）　東京三｜越の「山と水」展覧会に、故人｜角田浩々歌客が世界の各地から集めた石と一緒に、塚本工学博士が出品した瓶詰の黄河の水がある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国のある停車場の駅長はグラツドストーンが落して往つた履の踵を拾つて、丁寧に箱入にして蔵つておいたといふから、黄河の濁り水を克明に瓶に入れて持つて帰つたからといつて、別に咎め立もしないが、同じ持つて帰るなら、もつと美しい物を見つけて欲しかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し漢民族は南種と言っても黄河沿岸はもちろんのこと、揚子江沿岸でも亜熱帯とは言われず、ヒマラヤ以南の南種に比べては、多分に北種に近い性格をもっている。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼は飽迄も日本軍への敵意を棄てず、ぼくたちが黄河河畔の絶壁の上を喘ぐように行軍していた際、突然、荷物を棄てると、その絶壁から投身自殺した。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "因つて曰く、臣は黄河の澄むを幾度も見たりと。",
              "citation": {
                "source": "酒に死せる押川春浪",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁にいこうがどうしようが、民子は依然民子で、僕が民子を思う心に寸分の変りない様に民子にも決して変りない様に思われて、その観念は殆ど大石の上に坐して居る様で毛の先ほどの危惧心もない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は民子が嫁にゆこうがゆくまいが、ただ民子に逢いさえせばよいのだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
