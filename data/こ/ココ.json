    },
    "definitions": [
      {
        "index": 1,
        "gloss": "each house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家家娉※ヲ貯ヘ、戸戸婀娜ヲ養フ。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさて、今よりも、子供の時分の方が、よつぽど海は好きだつたやうだから、してみると今よりも、あの頃の方が「こころまゝ」だつたのだらうか？",
