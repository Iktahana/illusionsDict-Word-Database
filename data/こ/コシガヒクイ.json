        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お金があって、美人で、愛嬌がよくて、小作の百姓にまで腰が低いので、この「ガンネスの奥様」は、附近の村人の限りない好意と尊敬を受けている。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "平吉は、円顔の、頭の少し禿げた、眼尻に小皺のよっている、どこかひょうきんな所のある男で、誰にでも腰が低い。",
              "citation": {
                "source": "ひょっとこ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治も、二・三十年代以後の氏子は、神職の価値判断の標準を、腰が低いと言ふ処に据ゑて居た。",
              "citation": {
                "source": "神道の史的価値",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民さんなんざあ腰が低いんじゃねえ、頭が高けえんだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは会つたことないけど、腰が低いつていふ評判よ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう間もなく医者も参りますから、は」　と清之介君は舅即ち支配人と思っているから、甚だ腰が低い。",
              "citation": {
                "source": "女婿",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って私の会社の重役よりも腰が低い。",
              "citation": {
                "source": "閣下",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "村内のものは睦さんを見かけると、「若旦那様」　と呼びかけて腰が低い。",
              "citation": {
                "source": "村の成功者",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
