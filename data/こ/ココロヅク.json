    "definitions": [
      {
        "index": 1,
        "gloss": "to perceive",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "画室の塵一本もなきように綺麗に掃除しあるに心付く。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と婆々は片づけにかかる気で、前の銚子を傍へ除けようとして心付く、まだずッしりと手に応えて重い。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたと、これに空想の前途を遮られて、驚いて心付くと、赤楝蛇のあとを過ぎて、機を織る婦人の小家も通り越していたのであった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時にふと心付くと、何者か私の後にこそ／＼と尾行して來る樣子、オヤ變だと振返る、途端に其影は轉ぶが如く私の足許へ走り寄つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "懷中時計は海水に濡されて、最早物の用には足らぬが、時は午前の十｜時と十一｜時との間であらう、此時不圖心付くと、今迄は、たゞ浪のまに／＼漂つて居るとのみ思つて居つた端艇が、不思議にも矢のやうな速力で、東北の方から西南の方へと流れて居るのであつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦月丸の沈沒以來十｜數日間は、青い空と、青い波の外は何一つも眺めた事のない吾等が、不意に此島を見出した時の嬉しさ、翅あらば飛んでも行きたき心地、けれど悲しや、心付くと吾端艇には帆もなく、櫂も無い。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど私は心付くと、響の源は决して近い所ではなく、四邊がシーンとして居るので斯く鮮かに聽えるものゝ、少くも三四｜哩の距離は有るだらう、何は兎もあれ斯る物音の聽ゆる以上は、其處に何者かゞ居るに相違ない、人か、魔性か、其樣な事は考へて居られぬ、兎に角探險と覺悟したので、そろ／＼と丘を下つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う考へると、實に愉快で／＼堪らぬ、今や吾等の眼には、たゞ希望の光の輝くのみで、誰か人間の幸福を嫉む惡魔の手が、斯る時――かゝる間際に兎角大厄難を誘起すものであるなどゝ心付く者があらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（時に、はじめてフト自分の他に、烏の姿ありて立てるに心付く。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）紳士　（はじめて心付く）女郎、こっちへ来い。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、江戸児はこの味を知るまい、と乗合の婦の移香を、楽みそうに、歯をスーと遣って、片手で頤を撫でていたが、車掌のその御注意に、それと心付くと、俄然として、慄然として、膚寒うして、腰が軽い。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめて心付くと、厠の戸で冷く握って、今まで握緊めていた、左の拳に、細い尻尾のひらひらと動くのは、一｜尾の守宮である。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、もし、」　はッと心付くと、麻の法衣の袖をかさねて、出家が一人、裾短に藁草履を穿きしめて間近に来ていた。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房　（心付く）おお、若様。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、心付くと消えたように女の姿が見えないのは、草が深くなった所為であった。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はじめて心付くと、先刻視めた城に対して、稜威は高し、宮居の屋根。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾て心にだに留めざりし人と、ゆくりなく浮名立てらるゝときは、その人はそもいかなる人にかと疑ふより、これに心付くるやうになり、心付けて見るに隨ひて、美しくもおもはれ慕はしくもおもはるゝことありと聞く。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "石がきにサフランの花を見つつ心付く）あら鯉が、大な鯉が、――（小流を覗く）まあ、死んでるんだよ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家　（再びはじめて心付く）いや、（と軽く言う。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）紳士　（はじめて心付く）女郎、此方へ来い。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その語気の人もなげなるが口惜しくて、われにもあらず怫然として憤りしが、なお彼らが想像せる寃罪には心付くべくもあらずして、実に監獄は罪人を改心せしむるとよりは、罪人を一層悪に導く処なりと罵りしに、彼は僅かに苦笑して、とかくは自分の胸に問うべしと答えぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しこゝに忍んでゐることは誰も心付くまいな。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代は、自分の持っている勘と自覚されるものを、客観的に、歴史性の上にとり出して調べて見ようとする、その必要に心付く勘というものが、より重大な人間的役割をもっているのではなかろうか。",
              "citation": {
                "source": "文学上の復古的提唱に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理之助が現れて、さては騙かれたかと心付く辺以下もよかった。",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の芸術の進んでゆく姿に、こんなにうたれる今晩の自分の心の感じやすさの理由に我から心付くところもなくはなくて、桃子はぼんやり上気した頬へプログラムで風をおくっていた。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃子はいつとなしに、順助が、兄たちともほかの男の誰彼ともまるでちがった一種の心持を自分におこさせることを心付くようになった。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は頁を繰って見て、五月以後から、自分の思想が段々落付いて、生活を観察するように成って来たのに心付く。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の頃八丁堀の町与力｜小林藤十郎という人は、「これは多分蟠龍軒のためさん／″＼恥辱を受けた友之助の仕事であろう」と疑いましたが、誰あって文治の仕事と心付く者はございませぬ。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は馬関の唄うたひ髪にさしたる青玉あだな南のニグレスがこころづくしの貢物。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "癡れにたる夢なり、こころづくしのこの一室、あだなる「悔」の蝙蝠氣疎げにはためく羽音をりをり音なふや、噫などおびゆる魂ぞ。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
