          "literary": [
            {
              "text": "「老人には過去を、若い人には未来を」という交際術の初歩すら心得ないがさつな人だ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石に苦労した男丈けあって、川村は交際術にかけては、すばらしい腕前を持っていた。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことは、女の交際術で、上手にやるのが役目だ。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
