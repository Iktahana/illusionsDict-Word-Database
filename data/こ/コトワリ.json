[
  {
    "uuid": "e21ce31c-50eb-54b9-8e84-fda68642f65a",
    "entry": "断り",
    "reading": {
      "primary": "ことわり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "notice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さて暫く案じた揚句、大抵はお断りすることとなるのでありますが、今もよつぽどお断りしようかと思つた所でありました。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "断り切れないのである。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とても書けない」と言って、お断りしたら、「それは困る。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の或家さ瞽女がとまったから聴きにゆかないか、祭文がきたから聴きに行こうのと近所の女共が誘うても、民子は何とか断りを云うて決して家を出ない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし教授の職に附帯したうるさい仕事のために研究が出来なくなるという心配があれば、また適当な後任者の出来るまで当分の間だけ引受けるというのだったら、むしろ御断りになる方がいいと思う」という意味のことを忠告した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御断りをした積りでいるうちに何時の間にかつかまってしまって、とうとうこの「見ざるの記」を書く事になった。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に腹案もないからと一応御断りしたが、何でもいいから書けといわれる。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「お断り致します」　えッと驚く棚倉。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人はつと身を起して立って来て、（お坊様、それでござんすがちょっとお断り申しておかねばなりません。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから平に御断りを致します。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、こうして断りに来たのだ。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃ってあげましょう、と親切に言って下さるので、私は又も断り切れず、ええ、お願いします、と頼んでしまうのでした。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも三箇月間ほど我慢して、そんな侘びしい、出鱈目の教育をつづけて受けて居りましたが、もう、なんとしても、沢田先生のお顔を見るのさえ、いやになって、とうとう父に洗いざらい申し上げ、沢田先生のおいでになるのをお断りして下さるようにお願い致しました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏神様の御蔭なりゃあこそこげに気楽な一生が送れますので、福の神様が舞込んで来かかりますと、どうぞ他所様へ他所様へとお断り申上げますような事で、貧乏神から兄貴とも親分とも頼まれる心安さ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "察していながら、自分は断りをいうにしても断りのいいようもあろうに、あんな最後の言葉を吐いてしまったのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計の下の柱暦に小母さんとおぬいさんとの筆蹟がならんでいるのも――彼が最初にその家に英語を教えるのを断りに来た時に気がついたものだけに――なつかしかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが翌日仲介者が断りに来た。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何分にも、お立派過ぎると、あちらは申すんで――」「立派すぎるなんて、そんな断りようがあるか」　父親は巻煙草を灰皿にねじ込んで怒った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ断り方でも、その女性の気持ちを汲みながら、無邪気ににっこり笑って「あなたが私をどんなに愛して下さっても、私は仏に仕える身ですから、あなたの愛を受ける事が出来ません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――お断りする力が御座いません。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう遅うござりますに因って、御一人旅の事ではありまするし、さようなお方は手前どもにおいでがないと申して断りましょうかとも存じましたなれども、たいせつなお客様、またどのような手落になりましても相成らぬ儀と、お伺いに罷出ましてござりまする。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この眩暈と、風邪と、も一つ、用達と云う断りが出る、と箱三の札は、裏返らないでも、電話口の女中が矢継早の弓弦を切って、断念めて降参する。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も頼む、その様子じゃ靄を引掴んで突返すようで、断るに断り切れない。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "義作、貸しねえ貸しねえてって例の我儘だから断りもされず、不断面倒臭くって困ったこともありましたっけが、先刻は真のこった、私ゃ手を合わせました。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "モデルの誰たるかを模索することの無意味なる事を、特に読者にお断りしたい。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後海城が官選されたと聞いたとき、やつはたうとう断り切れなかつた。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたくなにしてあるときは、心に眼魂に、言葉のはたらきあとを絶つなごやかにしてあらんとき、人みなは生れしながらのうまし夢、またそがことわり分ち得ん。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュバちやんかベトちやんか、そんなこと、いざ知らね、今宵星降る東京の夜、ビールのコップを傾けて、月の光を見てあれば、ベトちやんもシュバちやんも、はやとほに死に、はやとほに死んだことさへ、誰知らうことわりもない……思ひ出お天気の日の、海の沖はなんと、あんなに綺麗なんだ！",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そばに置いてきぬことわりや夏羽織）と古俳句にもある。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、年少の読者にも読みやすいように、改行を多くしたことを一言おことわりしておく。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
