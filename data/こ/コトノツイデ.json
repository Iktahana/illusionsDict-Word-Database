[
  {
    "uuid": "d2e8baa9-268e-57d1-a961-d274337fc1aa",
    "entry": "事のついで",
    "reading": {
      "primary": "ことのついで",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
