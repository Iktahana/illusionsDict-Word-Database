              }
            },
            {
              "text": "あのこしゃくな身障者と狡猾さを争い、負けてしまった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はすこしゃア、釣ったけ？",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
