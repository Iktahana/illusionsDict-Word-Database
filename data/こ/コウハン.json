[
  {
    "uuid": "43dc7136-0cca-5641-b3ab-5406609b07f0",
    "entry": "後半",
    "reading": {
      "primary": "こうはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
