  {
    "uuid": "3346ca67-c7b4-5153-8ccf-83b913f088b9",
    "entry": "孔版",
    "reading": {
      "primary": "こうはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
