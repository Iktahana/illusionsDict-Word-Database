[
  {
    "uuid": "6187628a-b89b-5b85-8950-329821f41197",
    "entry": "光来",
    "reading": {
      "primary": "こうらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "your visit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その毘陵の人が来たので、季因是は大天狗で、「近ごろ大した物を手に入れましたが、それは乃ち唐氏の旧蔵の名物で、わざとにも御評鑒を得たいと思っておりましたところを、丁度御光来を得ましたのは誠に仕合せで」という談だ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご迷惑は重々でございませうがどうかぢきそこまで御光来を願ひたう存じます。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな乱雑な席にご光来をねがひまして面目次第もございません。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光来りて葉緑を照徹すれば葉緑黄金を生ずるじゃ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十一　みるめ、かぐはな「はい、光来なさいまし、何ぞ御用。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と得三が、物狂わしく顧みれば、「光来、光来。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで光来と、小手にて招くに、得三は腰に付けたる短銃を発射間も焦躁しく、手に取って投附くれば、ひらりとはずして遁出すを、遣らじものを。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を御褒美に上げようかしら、ああ良い品があったっけ、姉様とさあ一所に光来。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の毘陵の人が来たので、季因是は大天狗で、「近ごろ大した物を手に入れましたが、それは乃ち唐氏の旧蔵の名物で、わざとにも御評鑒を得たいと思つて居りましたところを、丁度御光来を得ましたのは誠に仕合せで」と云ふ談だ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "当地ハ成田山新勝寺オヨビ三里塚ノ近クニ候エバ当地ニ御光来ノ節ハ御案内仕ル可ク候。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄ばみたる青葱色の眼の光来る夜の恐怖にそそぐ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の上で持上って、だぶりだぶりと煽を打つと、蘆がまた根から穂を振って、光来々々を極めてるなんざ、情なかろうではないか。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はわたしが帰って来たのを喜んで、顔を見るなり、これから公爵夫人のところへ行って、口頭をもって、わたしの母は力の及ぶ限りいつ何時でも奥様のお役に立ちたいと存じている旨を述べ、十二時過ぎに御光来をお待ちすると伝えるように言いつけた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中になると戸棚から、今まで見た事もない素敵な美人が出て来て、辰雄さん、此方へ光来いなと無理に誘い出す。",
              "citation": {
                "source": "取り交ぜて",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々のにひなめには、自分の家より格の上な人をまれびととして光来を仰ぎ、咒詞を唱へて貰ふ事があつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはこれは志水様、わざわざのご光来、光栄至極、嘉門お礼申し上げまする」　坐ると嘉門は丁寧に辞儀をし、そう云ってかしこまった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神父様のご光来を迎える日もあれば、物もらいが覗く日もあった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはこれは秋山先生、ようこそご光来下されました」「逸見先生に御意得たい。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく御光来のことだから、お気に召すように打ってあげよう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにとぞ皆さん、それからそれへとご吹聴下され、にぎにぎしくおはやばや、ぞくぞくとご光来ご観覧の栄をたまわらんことを、一座一同になりかわり、象の背中に平に伏しておんねがい奉るしだぁい。",
              "citation": {
                "source": "曲馬団の「トッテンカン」",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかくの御光来に、他行をしておりまして、失礼をいたしました」「いや、わたしこそお留守に上がって泊まりこんで――」　龍造寺主計は、そういって、若松屋惣七とお高の顔を、見くらべた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「江戸一、いや、日本一の女分限者の御光来じゃな」一空さまは、剽軽に頭をさげた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後に「シャッター」が下りていて、その一枚一枚のすき間から御天道様が御光来である。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度御光来の節は久し振りにて晩餐でも供し度心得に御座｜候。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも屋根に草が生えたうちを探して行けば間違っこありませんよ」「よほど特色のある家ですなアハハハハ」　鈴木君が御光来になる前に帰らないと、少し都合が悪い。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この深夜に人間が案内も乞わず戸締を外ずして御光来になるとすれば迷亭先生や鈴木君ではないに極っている。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……高位の御人命にかかわる奇異な事態につき、極秘に御智慧を拝借いたしたく、はばかりながら、今夕、五ツ刻、拙宅まで御光来をねがわれますれば幸甚のいたりでございます。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "空からの御光来については、どこでもまるで合理的な準備は出来ず、それは個人達の怠慢というよりも、資材関係その他ですが、そちらも御自分用の防毒面はおありになろうとも思えません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひまの折りに是非一度ご光来下さるようお待ち申します。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
