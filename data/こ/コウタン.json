[
  {
    "uuid": "018444cd-3e81-56cc-bd3e-c8459bd22d11",
    "entry": "後端",
    "reading": {
      "primary": "こうたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
