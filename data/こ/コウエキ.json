      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "trade",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "広東香港間の電信が切断されてその後の消息は不明なのですが、恐らく明日は外国人は南方に於ける商業上の前途を楽観して、交易所では支那へ夥しい投資が行われるでしょう。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "交易をする市場はないしどこで毛布を賣りつけることもできはしない。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにぶらさげた招牌があるではなし交易をしてどうなるといふあてもありはしない。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どことも知らない遠くの交易市場の方へ出かけて行つて馬具や農具の古ぼけた商賣でも眺めてゐよう。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで崇高な交易の途を追って日本へ来た。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場には数多の人が集まってきて交易をやっていた。",
              "citation": {
                "source": "黄金の枕",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年頼まれて短冊とカエキ（交易）しますとたい」　やっと理窟がわかった筆者はホッとしながら、小学校の帽子を脱いでお辞儀しいしい帰途に就いた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか梅津の先生が非常に損な交易をして御座るような気がして、この婆さんが横着な怪しからぬ婆に見えて仕様がなかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖国当時、ヨーロッパ資本主義は、葡萄牙人を先駆として東洋の印度や支那や日本に力を伸して来たが、今はすでに英国が葡萄牙を卻け、和蘭を圧して、東洋貿易を独占しようとして、支那と交易し、南方から日本に迫らうとしてゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠隔地との交易を活力源として都市が勃興するに連れ、そこに台頭してくる新しい自立的な民衆が、書籍文化を支えるもう一つの柱を形成しはじめます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後美濃狐は、小川の市に来なくなったので、市人達は皆欣び合って、平かな交易がつづいた。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを救うは異人共との交易があるのみじゃ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "交易致さば国に小判が流れ入るは必定、小判が流れ入らば水じゃ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてやポルトガル国はもう三年来、われらにその交易を求めてじゃ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は決断致してあすにも交易を差し許して遣わすぞ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一にも二にも異人を懼れて、外船と交易致さば神州を危うくするものじゃと愚かも甚しい妄語を吐きおるが、国が危ういと思わば内乱がましい内輪の争い控えたらよかろうぞ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "内争を防ぐことこそ第一の急、京都と江戸との御仲｜睦じく渡らせられなば、国の喜びこれに過ぎたるものはなかろうが、御降嫁願い奉ったも忠節の第一、国を思うがゆえに交易するも忠節の第一であろうぞ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ポルトガル国トノ交易通商ハ、最早ヤ断乎トシテ之ヲ貫ク以外ニ途ハナシ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その烈しい食欲と性欲は、彼の灰と煙の中でかようにみじめに交易された。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "界隈の村々からは、鶏や玉子や七面鳥を持つて交易に来る、といつた塩梅で。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから云つて聞かせる通り、夷狄の黒船がそれからそれへと押掛けて來て、港を開けの、交易をしろのと、得手勝手のことをいふ。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、その貿易品が一般に流行する所から、貿易品的な置き物のようなものの注文が大分師匠の許に来るようになった（その頃は貿易といわず交易といっていた）。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "実物写生ということのはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、それと交易するために、自分の持物の中で、土人の欲しがりそうなものをいろいろ考えてみた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "交易所では、俄に買気が停ると、売手がそれに代って続出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の代りに交易される。",
              "citation": {
                "source": "奴隷根性論",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この変化は部分の交易かさもなければ接触そのものの消滅である。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の場合にあっては、部分は交易し移動しても、接触そのものは保たれるのであるからして、接触の量は全体としては減じないが、後の場合であるとすれば、部分は分離し付着は減じる。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなが自分の有として独占し、したがって何人にも属していない地球人の交易場。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、こんな身辺の女肉だけじゃあ需要に応じ切れないから、そこで、あらゆる方法で女を駆りあつめるんだが、この、専門の売春婦を養成して一定の契約のもとに各地へ配給する問屋制度に、昔から有名ないわゆる白奴交易路なる秘密工業がある。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
