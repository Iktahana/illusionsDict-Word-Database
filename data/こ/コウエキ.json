[
  {
    "uuid": "c04ab3a7-6548-54be-a5d4-5509b8de06ad",
    "entry": "交易",
    "reading": {
      "primary": "こうえき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
