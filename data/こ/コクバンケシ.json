          "literary": [
            {
              "text": "田口七郎兵衛は矢庭に黒板消しをつかんだが間にあわなかった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白雲頭の田口七郎兵衛は黒板消しを持ったまま不動のしせいをとった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、また――男のセイトキライ――と書かれている方を見て微笑しながら、「さア、その黒板消しを先生にお返して、席におつきなさい」　と、静かに教壇に上って行った。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
