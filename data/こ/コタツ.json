        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのうち子供は、炬燵にもぐり込んで転寝をしている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその同じ家郷を、ひとえに時間の所在に求めて、追懐のノスタルジアに耽った蕪村は、いつも冬の炬燵にもぐり込んで、炭団法師と共に丸くなって暮していた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は「漂泊の詩人」であったが、蕪村は「炉辺の詩人」であり、殆んど生涯を家に籠って、炬燵に転寝をして暮していた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「炬燵の詩人」であり、「炉辺の詩人」であったところの、俳人蕪村の風貌を表象している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は炬燵にあたつてゐました彼女は畳に坐つてゐました冬の日の、珍しくよい天気の午前私の室には、陽がいつぱいでした彼女が頸かしげると彼女の耳朶　陽に透きました。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく我儘であるくせにまた甚だしく臆病な彼は、自分で断然年賀端書を廃して悠然｜炬燵にあたりながら彼の好む愚書濫読に耽るだけの勇気もないので、表面だけは大人しく人並に毎年この年中行事を遂行して来た。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "炬燵の火もいとよし、酒もあたゝめんばかりなるを。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし朝は授業がないからゆっくりして日のよく当った居間の障子の内で炬燵にあたりながら何かしていた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に炬燵が出来ていたから私はそのまま嬉しく入った。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝床はもう一組おなじ炬燵に敷いてあったが、旅僧はこれには来らず、横に枕を並べて、火の気のない臥床に寝た。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の部屋に通されて、私は炬燵にあたった。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "炬燵の上にはお料理のお膳が載せられてある。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで聞いた事だが、その弘前の或る有力者のお妾で、まあ、当時は一流のねえさんであったようである）そうして、私のあたっている炬燵の上に置いた瞬間、既に私はそのお膳の一隅に雀焼きを発見し、や、寒雀！",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにも書けない低能の文学少女、炬燵にはいって雑誌を読んでいたら眠くなって来たので、炬燵は人間の眠り箱だと思った、という小説を一つ書いてお見せしたら、叔父さんは中途で投げ出してしまいました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を切るような風吹きて霙降る夜の、まだ宵ながら餅屋ではいつもよりも早く閉めて、幸衛門は酒一口飲めぬ身の慰藉なく堅い男ゆえ炬燵へ潜って寝そべるほどの楽もせず火鉢を控えて厳然と座り、煙草を吹かしながらしきりに首をひねるは句を案ずるなりけり。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか炬燵を抱いて氷の上にすわっているような心持ちがする。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでここに必要な二人の会話のだいたいはほぼ尽きているのだが、その後また河上氏に対面した時、氏は笑いながら「ある人は私が炬燵にあたりながら物をいっていると評するそうだが、全くそれに違いない。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓑吉は本宅の茶の間の炬燵へちょこなんと這入って、しきりに戦争の絵本かなにかに見｜耽っている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "体はもとの炬燵の中のまま顔も本の方へ矢張り向いているのである。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙も襦袢の袖口で一寸抑えて仕舞ったが、蓑吉と同じ炬燵にいた室子は、この光景を見て、何とも仕様のない、人間の不如意の思いが胸に浸み入った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "月もなく、日もなく、樹もなく、草もなく、路もない、雲に似て踏みごたえがあって、雪に似て冷からず、朧夜かと思えば暗く、東雲かと見れば陰々たる中に、煙草盆、枕、火鉢、炬燵櫓の形など左右、二列びに、不揃いに、沢庵の樽もあり、石臼もあり、俎板あり、灯のない行燈も三ツ四ツ、あたかも人のない道具市。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらくた壇上に張交ぜの二枚屏風、ずんどの銅の花瓶に、からびたコスモスを投込んで、新式な家庭を見せると、隣の同じ道具屋の亭主は、炬燵櫓に、ちょんと乗って、胡坐を小さく、風除けに、葛籠を押立てて、天窓から、その尻まですっぽりと安置に及んで、秘仏はどうだ、と達磨を極めて、寂寞として定に入る。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中へ、炬燵が化けて歩行き出した体に、むっくりと、大きな風呂敷包を背負った形が糶上る。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十をこしてから空咳がすると云つて寒い時節になると炬燵の中に跼つて居た。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも表二階の炬燵から。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒磯の巖の炬燵が眞赤だ。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝……と云ふがお午ごろ、炬燵でうと／＼して居ると、いつも來て囀る、おてんばや、いたづらツ兒の雀たちは、何處へすツ飛んだか、ひつそりと靜まつて、チイ／＼と、甘えるやうに、寂しさうに、一羽目白鳥が鳴いた。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……炬燵を辷つてあるきさうな、膝栗毛の續、木曾街道の寢覺のあたりに、一寸はさんで。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "をばさんは、バスに乘つて、峠の下の吉田へ行つて、こたつをひとつ買つて來た。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのスリツパをはいて、二階の廊下を懷手して、ぶらぶら歩き、ときどき富士を不機嫌さうに眺めて、やがて部屋へはひつて、こたつにもぐつて、何もしない。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
