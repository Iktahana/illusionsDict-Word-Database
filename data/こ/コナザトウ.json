        "examples": {
          "standard": [
            {
              "text": "パンケーキに粉砂糖をたっぷりかけて食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はケーキのデコレーションに粉砂糖を使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このドーナツは粉砂糖がまぶしてあってとてもおいしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この中に五百グラムの小麦粉と、百五十グラムの粉砂糖と、一摘みの塩を入れて攪きまぜる。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをサラダ油で揚げると膨れますから西洋紙か新聞紙へ取って油を切ってお皿へ載せてまた粉砂糖を上へ振りかけて出します」○鰺料理は本文の外にスープに作りてもよし。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを上等にしますと二合のクリームばかりへ粉砂糖大匙三杯混ぜて別段湯煎にしないでもザット沸立たせて香料を加えて固めます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この品を食卓へ出す時に粉砂糖を上へ振かけます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉砂糖をふりかけたように見える。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘党随喜の名代汁粉砂糖の味を食べ分けた下戸　甘党の随喜した汁粉の味、明治時代には名代の汁粉屋も多く、それぞれ自家特製の持味に御膳、田舎、小倉、塩｜餡乃至は白餡の上品まで口当りのよさ、ことに蓋を取った時のその匂い、ほんのりと特有の香味、煮抜きの餡の練れた工合、全く甘党を誘惑する。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
