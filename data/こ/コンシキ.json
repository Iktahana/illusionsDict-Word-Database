    "definitions": [
      {
        "index": 1,
        "gloss": "wedding (anniversary)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大隅君は、結婚式の日まで一週間、私の家に滞在する事になっているのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　四月二十九日に、目黒の支那料理屋で大隅君の結婚式が行われた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その料理屋に於いて、この佳き日一日に挙行せられた結婚式は、三百組を越えたという。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚式は午後五時の予定である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七一年の五月にイヴリン・バルフォーアと婚約し、七月十九日に結婚式を挙げた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その基本金の現額は十一万八千余ポンドで、そのうち四万ポンドは某富豪が金婚式の際に寄附したそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月十七日『東京朝日新聞』）　　　　　　　　　四十　　　　　　ノルウェーの夫婦匙　ノルウェーで結婚式の時に用いる木彫の匙がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内に行われていた全ての過去から続く催し物に喪が発せられ、結婚式の美しい半裸体の夜半の女の背中に機関銃の弾で穴だらけになったソビエットの赤い旗が迫って、宣伝隊の装甲自動車が租界内に侵入して宣伝ビラを配付した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは雨夜の仮の宿で、毛布一枚の障壁を隔てて男女の主人公が舌戦を交える場面、もう一つは結婚式の祭壇に近づきながら肝心の花嫁の父親が花嫁に眼前の結婚解消をすすめる場面である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか見た「バンジャ」という映画で、南洋土人の結婚式に、犠牲の鶏を殺してその血をちょっぴり鉢にたらし、そうして、その血を新夫婦が額に塗りまた胸に塗る場面があった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜のしらじらと明けそめたころ、私はその青年と少女とのつつましい結婚式の描写を書き了えた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよあさってが結婚式といふ日の明方、カン蛙は夢の中で、「今日は僕はどうしてもみんなの所を歩いて明後日の式に招待して来ないといけないな。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところで君も知ってる通り、明後日は僕の結婚式なんだ。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところで君も知ってるだらうが明後日僕の結婚式なんだ。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の朝ね、雨がはれたら結婚式の前に一寸散歩しようと云ってあいつを引っぱり出して、あそこの萱の刈跡をあるくんだよ。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚式がすんだらあいつらを引っぱり出して、あの畑の麦をほした杭の穴に落してやりたいね。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよあさってが結婚式という日の明方、カン蛙は夢の中で、「今日は僕はどうしてもみんなの所を歩いて明後日の式に招待して来ないといけないな。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところで君も知ってるだろうが明後日僕の結婚式なんだ。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚式場のぎょうぎょうしくて派手で、それでいて実に陰惨でグロテスクな光景もよくできている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして私はやがてこの人と結婚式を挙げました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう明日にも東京へ帰ることにして、すこしうちの事務の相談でもしましょうよ」　結婚式は挙げても、二人の心境がほんとうに茲まで進まなければ、事実上の良人と妻になってはならない――こう良人は潔い遠慮をし、私も自然にそれに従っていたのが、式後一ヶ月以上の礼儀正しい二人の生活内容であったのです。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那事変の影響は、一方、日本趣味の復活に結婚式の櫛笄等に鼈甲の需要をまた呼び起したと共に、一方大陸への捌け口はとまった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、主人夫妻が銀婚式をすることになりました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "名づけて「林檎の唄を歌う会」　――林檎の唄にかけてはかなりのうんちくのある山吹教授は、明日結婚式があるので欠席した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹教授の媒酌する結婚式があるという意味だ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――結婚式は目出度いと世間の常識は言いますね。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こころやさしいシンデレラのとりはからいで、ふたりの姉も、おしろでくらせるようになり、シンデレラのけっこんしきとおなじ日に、姉たちもおしろのえらいひとと、けっこんしましたとさ。",
              "citation": {
                "source": "シンデレラ",
                "author": "CINDERELLA, OR THE LITTLE GLASS SLIPPER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
