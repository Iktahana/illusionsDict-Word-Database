  {
    "uuid": "68ffdbf9-71cb-5d6e-8c9a-4e6e0b59fccf",
    "entry": "高卒",
    "reading": {
      "primary": "こうそつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "having graduated from high school (as one's highest completed level of education)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕達三高卒業生の據つてゐた同人雜誌であつた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓練期間は大卒で半年、高卒で一年。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タケシの同期は、高卒が二小隊、大卒が一小隊。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに秋には、中途採用の高卒組が一小隊ほど入ってきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タケシの成績は、高卒の同期中トップだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が高卒以上でなければ、嫁に行かん、恋愛もせんていふ規約、わしらで作つたわ。",
              "citation": {
                "source": "すべてを得るは難し",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの学歴は高卒となつてるが、実は、尋常を五年までしかやつとらん。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは僕が東京で三高卒業生ばかりで出してゐた同人雑誌「青空」の同人になつたからである。",
              "citation": {
                "source": "思ひ出づるまゝに",
                "author": "淀野隆三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一高卒業の時、私は病気になって、摂生室に籠もらされてしまった。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次読む人読まぬ人――三人の政治家――",
                "note": "青空文庫"
              }
            },
            {
              "text": "終了して試験を受けて合格すれば、高卒の資格なのですって。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
