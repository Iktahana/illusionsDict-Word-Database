    "definitions": [
      {
        "index": 1,
        "gloss": "(innocent) mind of a child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "道の兩側に女郎屋が竝び、子供心の好奇心で覗いて歩いた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられてゐて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられていて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の長い留守の間に祖母と母と三人きりで割合に広い屋敷の中でのつつましい生活は子供心にもかなり淋しいものであったに相違ないので、この広くて淋しい家と、重兵衛さんの狭くて賑やかな家との対照が幼い頭に何かしら深い印象を刻んだのではないかと想像される。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜めに来る光がこの饅頭笠をかぶった車夫の影法師を乾き切った地面の白い上へうつして、それが左右へゆれながら飛んで行くのが訳もなく子供心に面白かったと見える。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉使いの野卑で憎らしかったには、傍で聞いている子供心にもカッと腹が立った。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だもんだから、近所隣で井戸を掘り下げると、そこで最初はおとなしく見物してゐるが、水気を含んだ土が出て来、土混りの赤又は黒の水が出るに及んでは、子供心に冷静を失つてしまふのである。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "塔に攀じ上らないでその高さを測り得たという事は子供心に嬉しかろう。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供心に何だかそれが少しぎごちなく思われた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう調子であったから子供心にも時々驚いて服した。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし時の敗者たる知盛の幽霊に対して、子供心にもひどく同情というかなんというかわからない感情をいだいたものと見えて、そういう心持ちが今でもちゃんと残留しているのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのエキゾティックなものに憧憬をもっていた子供心に、この南洋的西洋的な香気は未知の極楽郷から遠洋を渡って来た一脈の薫風のように感ぜられたもののようである。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時だれかから聞きかじったこのげじげじという名称が、子供心になんとなく強く深い印象を与えたものと思われる。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにやるせのない子供心の突きつめた心持ちを思わせるものがある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも実に不思議な詩趣を子供心に印銘させた話は次のようなものであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また沢田先生だって、本当に私の綴方に感心なさっているのではなく、私の綴方が雑誌に大きい活字で印刷され、有名な岩見先生に褒められているので、それで、あんなに興奮していらっしゃるのだろうという事は、子供心にも、たいてい察しが附いて居りましたから、なおのこと淋しく、たまらない気持でした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら飼はれるときまっても、子供心はもとより一向たよりないもの、又近くには猫犬なども居ることぢゃ、もし万一の場合は、たゞあの疾翔大力のおん名を唱へなされとな。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら飼われるときまっても、子供心はもとより一向たよりないもの、又近くには猫犬なども居ることじゃ、もし万一の場合は、ただあの疾翔大力のおん名を唱えなされとな。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の子は空知川沿岸に於ける熊の話を為し、続いて彼が子供心に聞き集めたる熊物語の幾種かを熱心に語つた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "家と屋敷ばかり広うても貧乏士族で実は喰うにも困る中を母が手内職で、子供心にはなんの苦労もなく日を送っていたのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "石に腰をおろしてほっと呼吸を吐いて言うに言われん悲しげな顔つきをします、その顔つきを見ますと私までが子供心にも悲しいような気がしまして黙ってつくねんと母の傍に腰をかけているのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、売卜者から女難のことを言われ、母からは女難ということの講釈を聞かされましたので、子供心にも、もしか今のが女難ではあるまいかと、ひどくこわくなりましたが、母の前では顔にも出さず、ないない心を痛めていながらも時々おさよのもとに遊びに参りましたのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそんなつまらないことを覚えているのは、当時の自分の子供心に軽い嫉妬のようなものを感じたためかもしれないと思われる。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供心にも不思議に思って、だんだん聞いて見ると、これは市ヶ谷｜辺に屋敷を構えていた旗下八｜万騎の一人で、維新後思い切って身を落し、こういう稼業を始めたのだという。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになく厚化粧の母の顔を子供心にも美しいと見るのだが、しかし、なぜかうなずけない気持だった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は子供心にも、こんなに体が弱くては到底父親や母親のように大きく成ることは出来ないだろうと思っていた。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして子供心に、そんな悪魔みたいな人間が本当にこの世に居るものか知らん。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は叔父がこんな近い処に住んでいようとは夢にも思わなかったので、子供心に不思議に思いながら叔父に跟いて中に這入ると、上り口は半坪ばかりのタタキで、あと十畳ばかりの板の間に穴だらけのリノリウムを敷いて、天井には煤ぼけた雲母紙が貼ってあった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の小さい頃に死んだ私の里の祖父母は、よく夫婦｜喧嘩をして、そのたんびに、おばあさんが、でえじにしてくんな、とおじいさんに言い、私は子供心にもおかしくて、結婚してから夫にもその事を知らせて、二人で大笑いしたものでした。",
              "citation": {
                "source": "おさん",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供心に異なことを考えたもので、其主意と云うのは先ずこうである。",
              "citation": {
                "source": "落第",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
