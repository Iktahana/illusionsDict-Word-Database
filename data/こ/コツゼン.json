[
  {
    "uuid": "5c350ab9-1c00-5894-9854-41cdb2c4441f",
    "entry": "忽然",
    "reading": {
      "primary": "こつぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sudden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜一夜あのままに貼り付いていたのが朝の光と共に忽然と消えるのでないかと云うような事を考えた事もある。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくもその瞬間に自分が子供の時分に夢みていた生粋の西洋というものが忽然と眼前に現われて忽然と消えてしまったのであった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町に忽然として姿の見すぼらしい少年が現われた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばファゴットの管の上端の楕円形が大きく写ると同時にこの木管楽器のメロディーが忽然として他の音の波の上に抜け出て響いて来るのである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（忽然何物をか認め得たる如く。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（忽然、激しく愉快を感じたる如く、一層厳しく抱き付きて。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（物思いに沈みて凝立すること暫くにして、忽然夢の覚めたるが如き気色をなし、四辺を見廻す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（忽然と非常なる喜に打たるる様子。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "優しい、情深い、それかと思うと、忽然武士的に花やかになって、時として残酷にもなるような処があります。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき自分の眼前には忽然として過ぎし日のＫ大学におけるＢ教授の実験室が現われるような気がした。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの演芸の声だけでなくて演芸者自身がその声にくっついて忽然として自分の家庭に侵入して来るように感じる。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一度私の眼の下にいた一匹の河鹿から忽然としてそんな世界へはいってしまった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばＡかＢかのほかには何物も有り得ないという仮定のもとに或る人間の問題を取り扱っている際に、ある物質界の現象を学ぶことによって忽然として、他にＣの可能性の存在を忘却していたということに気がつくことがしばしば有りうるであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、このすえ付け作業がすむと今度は、両手を希薄な泥汁に浸したのちに、その手で回転する団塊の胴を両方から押えながら下から上へとだんだんなで上げると、今まではただの不規則な土塊であったものが、「回転的対称」という一つの統整原理の生命を吹き込まれただけで忽然として「生きて」来る。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どんな式服を着ていたかと聞かれると、たった今見て来たばかりの花嫁の心像は忽然として灰色の幽霊のようにぼやけたものになってしまう。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたよらぬ自然光で照らせば妙なブラッシの幽霊などは忽然と消滅するであろう。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "するときっとこの昔の郷里のゴムの木のにおいを思い出すと同時にある幼時の特別な出来事の記憶が忽然とよみがえって来るのである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、この振り出し薬の香をかぐと昔の郷里の家の長火鉢の引き出しが忽然として記憶の水準面に出現する。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが忽然として別の顔に変わる。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は忽然として過ぎた、七年は夢のごとくに経過した。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに月光がさして忽然と清談の会席が眼前に現われる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧の甲板にひびく汽笛の音とその反響によってある港の夜の空間が忽然として観客の頭の中に広がるのである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫時その寂漠に堪える人には忽然と湧く一念があって、その虚無のくちをふさいでくれるでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで支那一流の濃厚料理が数え切れぬほど出ました中に、忽然と野菜だけの一鉢が出ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて人は感情の動物で、樂しき時には何事も樂しく見え、悲しき時には何事も悲しく思はるゝもので、私は今、不圖此悽愴たる光景に對して物凄いと感じて來たら、忽然樣々な妄想が胸裡に蟠つて來た、今日までは左程迄には心に留めなかつた、魔の日、魔の刻の怪談。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇の上部艇首の方に位して、一個の橢圓形の觀外塔が設けられて、塔上には、一本の信號檣の他には何物も無く、其一端には自動開閉の鐵扉が設けられて、艇の將に海底に沈まんとするや、其扉は自然に閉ぢ、艇の再び海面に浮ばんとするや、其扉は忽然として自ら開くやうになつて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其島陰から忽然として一點の光がピカリツ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時艦頭に立てる武村兵曹は、右鬢に微傷を受けて、流るゝ血汐の兩眼に入るを、拳に拂つて、キツと見渡す海の面、電光の如く近づき來つた海底戰鬪艇は、本艦を去る事約一千米突――忽然波間に沈んだと思ふ間も疾しや遲しや、唯見る本艦前方の海上、忽ち起る大叫喚。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――月の全輪がこつぜんとして私の眼前にあらわれた。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういういきさつを経たのち、こつぜんとしてパアク・レイン・ホテルの帳場に出現した私たちである。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
