    "definitions": [
      {
        "index": 1,
        "gloss": "back of head",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "顔はあたり前ですが、後頭部に――その部分がお化けなのです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一鼻が思っていたよりもずっと高くいかにも憎々しいように突き出ていて、額がそげて顋がこけて、おまけに後頭部が飛び出していてなんとも言われない妙な顔であった、どこかロベスピールに似ているような気がした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も小学生時代に学校の玄関のたたきの上で相撲をとって床の上に仰向けに倒され、後頭部をひどく打ったことがある。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がりがり後頭部を掻きながら、なんたることだ、日頃の重苦しさを、一挙に雲散霧消させたくて、何か悪事を、死ぬほど強烈なロマンチシズムを、と喘えぎつつ、あこがれ求めて旅に出た。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "助手は根元で無造作に結へてある元結を切つて、兩耳の後ろと旋毛の邊にかけて前頭部と後頭部の髮を二束に分けた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大悦で、ぐツと氣を落着け、眼を瞑り、片手で後頭部を押へて息を凝らして考へて見る………頭の中が何か泡立ツてゐるやうにフス／＼鳴ツてゐるのが微に顳※に響く。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "また姑のオナリ婆さんは俯伏せになって、枕を抱えて寝ていたらしく、後頭部を縦に割付けられていたが、これは髪毛があるので血が真黒に固まり付いている上に、二人の枕元の畳と蒲団の敷合わせが、血餅でつながり合って、小さな堤防のように盛上っていた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "老師の後頭部の薄い禿へ仏前の蝋燭の灯がちらちらとうつつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にちょっとお洒落なのもいて、制帽のいただきが尖らないように辮髪を後頭部の方に平たく巻いて油でぴったり押えつけるという新工夫を案出して、その御苦心は察するにあまりあったが、帽子を脱ぐと、男だか女だかわからない奇怪な感じで、うしろ姿などいやになまめかしくて、思わずぞっとする体のものであった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母に近く、部屋の壁に凭れかゝって池上の息子が後頭部へ腕框を宛がいながら、怠るそうに足を前に投げ出していました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安宅先生はまた、急に女らしい所作をわたくしにだけ露骨に見せ、深い溜息を吐いたり、わたくしの額に頬を置いて、指でわたくしの後頭部の髪の毛を掻き分けながら熱い涙をわたくしの鬢に滴らしたり、それはわたくしに身慄いの出るほど嫌なものを感じさせるだけに、わたくしを途方に暮れさせる所作でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとどちらが早かったか、前なる敵を突こうと戈を引いた李陵は、突然背後から重量のある打撃を後頭部に喰って失神した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞では盛んに書き立てた……白昼の製鉄所構内で衆人環視の中に行われた、天魔の如く大胆なる殺人強盗……犯人は大地に消え込んだか……実見者又野末吉氏談……前代未聞の怪事件なぞと……殊に後頭部を粉砕されながらも勇敢に抵抗した西村会計部員の奇蹟的な気強さを、製鉄所長と医学博士の談話入りで賞讃した。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　後頭部に心持ち黄色い白毛が半月型に残っているのを綺麗に櫛目を入れていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい生活の最初の馴れない疲労が、ズキズキと背中や後頭部にうずいていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分なども一度学校の玄関の土間のたたきに投げ倒されて後頭部を打って危うく脳震盪を起こしかけたことがあった。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後頭部の中央に正確に的中り、脳を貫通しているよ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴戦の勇者が受けた外傷は後頭部、長さ二インチほどのギザギザとした裂傷とわかった。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "後頭部に傷がある事実は決定的反証とはならない。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女がずっと後頭部にある乱れた黄金色の巻き毛をさすっていたからだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は用意した鋭利な大ナイフを取り出して後頭部を力を籠めてグサと突刺した。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはまた湯に入つて後頭部を湯槽の縁に載せ、いまあけたガラス戸の方に向つて、出て行く湯氣、入つて來る霧の惶しい姿を見るともなく仰いでゐた。",
              "citation": {
                "source": "湯槽の朝",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この不運な娘のペティコートの一部が長さ二フィート、幅一フィート裂き取られて、それを後頭部からまわして顎の下で結んであったが、たぶん悲鳴をたてさせないためであったろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "『この不運な娘のペティコートの一部が長さ二フィート、幅一フィート裂き取られて、それを後頭部からまわして顎の下で結んであったが、たぶん悲鳴をたてさせないためであったろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "『この不運な娘のペティコートの一部が裂き取られて、後頭部からまわして顎の下で結んであったが、たぶん悲鳴をたてさせないためであったろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙鳥音吉はわたしの幼少の時にもチヨンまげをつけた相当の爺いさんに見えたが、いつか訪れた時もやはり同じやうな感じの頬のこけた鷲鼻の顎の長い爺いさんで、禿頭の後頭部に川蜻蛉のやうに小つぽけなチヨンまげを結んでゐた。",
              "citation": {
                "source": "山峡の凧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒たちは荒くれ男、だが中隊長の体に手をかけるやうな、勇敢な男は一人もゐない、ズラリと兵士たちをならべてをいて中隊長は兵士の額にむかつて訓示をしそれが終ると、くるりと廻れ右させて、今度は兵士の後頭部に命令した、すると彼等は、しやにむに走つた。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "額を訓示で撫でられて後頭部を命令で殴られたやうに――。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
