    "definitions": [
      {
        "index": 1,
        "gloss": "to trouble with questions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
