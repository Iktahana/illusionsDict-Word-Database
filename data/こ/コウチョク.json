      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "stiffening",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "額の油汗拭わんと、ぴくとわが硬直の指うごかした折、とん、とん、部屋の外から誰やら、ドアをノックする。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年になると着なれぬ硬直な羽織はかまを着せられて親類縁者を歴訪させられ、そして彼には全く意味の分らない祝詞の文句をくり返し暗誦させられた事も一つの原因であるらしい。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして橋の歩道にさしかかつた時分には、彼の全身には奇異な、硬直した靜けささへ見られました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人によると妙にしゃちこばって土偶か木像のように硬直して動かないのがある。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、僕はじりじり硬直をはじめた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすれば硬直したがる僕の神經に對しても、また、おそらくはおなじやうな諸君の神經に對しても、いささか毒消しの意義あれかし、と取りかかつた一齣であつたが、どうやら、これは甘すぎた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手首が硬直凝固の状態になっていてはキューのまっすぐなピストン的運動が困難であるのみならず、種々の突き方に必要なキューの速度加速度の時間的経過を自由に調節することも不可能であるように見える。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつは脚の硬直だ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉から雪次郎が密と覗くと、中段の処で、肱を硬直に、帯の下の腰を圧えて、片手をぐったりと壁に立って、倒れそうにうつむいた姿を見た。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "コルク張りの床に俯伏せに倒れて、硬直した右手にピストルを握り、血の流れている右の顳※には煙硝の吹いた跡がある。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も喰い物を与えなかったせいか、美しかった肉付きがスッカリ落ちこけて、骸骨のようになって仰臥していたが、死んだ赤子の片足を半分ばかり生み出したまま、苦悶しいしい絶息したらしく、両手の爪をボロ畳に掘り立てて、全身を反り橋のように硬直させていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一突きで、カッとなるか涙をぽろっと滴すかの悲惨な界の気持にまで追い込められた硬直の表情で、鼈四郎はチャブ台の前に胡坐をかいた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると麻川氏は「や、種蒔くが来た」と突然顔面を硬直させて立ち上った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉は柔いものゝ無限の重量を感じ、体は華やかな圧迫で却って板のように硬直して了った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の油汗拭はむと、ぴくとわが硬直の指うごかした折、とん、とん、部屋の外から誰やら、ドアをノツクする。",
              "citation": {
                "source": "音について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、すぐにその硬直の姿勢を崩して、さりげないやうな、へんに、あきらめたやうな弱い口調で、「さ、はひつて運動会を。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅野弾正大弼長政は中々硬直で、場合によれば太閤殿下をも、狐に憑かれておわすなぞと罵ることもある程だが、平日は穏便なることが好きな、物分りの宜い人であるから、氏郷贔負では有るが政宗にも同情を吝む人では無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君達は私を侮辱するのか……」かう云つて更に詞を繼がうとした先生は、突然の興奮の爲めに唇が硬直してぐいと云ひ詰つた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のかけごえのみ盛大の、里見、島崎などの姓名によりて代表せられる老作家たちの剣術先生的硬直を避けた。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生の丁寧に落着いた言葉が、初め鼓膜まで硬直した京子の耳底に微かに聞えて、だんだんはっきりと聞えて来た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "政枝は自分で自由にならないほど硬直した頸をやっと捻じ向けて、叔母の顔を恨めしそうに見上げた。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（だが、その翌日、林野局に私が挨拶に行った時は全く硬直した官僚的態度で、や、そうですか、や、と大きな事務卓を隔てて、にべもなく私の純情を跳ね返してしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ君がヘルメットにステッキで、硬直しきりの、後ろからどっかの国の侍従武官兼警視総監というところだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹厳な硬直した態度で、あの人が下座に畏こまった時には弱ったよ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピユリタンの興らんとする時に、至粋は彼等朴直なる田舎漢の上に望みて、千載歴史上の奇観をなし、独逸に起りたる宗教改革の気運の漸くルーテルが硬直誠実なる大思想に熟せんとするや、至粋は直ちに入つてルーテルの声に一種の霊妙なる威力を備へたり。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナタナヱル無花果樹下に黙坐す、ナザレのイエス彼を見て、以て猶太人の中に尤も硬直にして欺騙なきものと思へり。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時にお祖父様は中風に罹られたが、父は度々帰省してお祖父様を見舞い、その都度に、大工を呼んで板塀や窓の模様を変え、右半身の麻痺硬直したお祖父様に適合する便器を作らせ、又はお祖父様の股間にタムシが出来た時に、色々な薬を配合して手ずから洗って上げたりした。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者の脈拍や体温を記録して、筋肉の硬直具合を試し、反射を調べました。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "着ているのは長い寝間着のみで、ふくれたくるぶしと不格好な足がその下から硬直したまま突き出ている。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋肉の硬直具合を見ると。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
