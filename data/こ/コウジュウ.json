    "definitions": [
      {
        "index": 1,
        "gloss": "apartment house built by the Japan Housing Corporation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こゝへ奉公住みして足かけ三月のあひだに、討つべき隙はなかつたか。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの事情の湊合のために、源三は自分の唯一の良案と信じている「甲府へ出て奉公住みする」という事をあえてしにくいので、自分が一刻も早く面白くない家を出てしまって世間へ飛び出したいという意からは、お浪親子の親切を嬉しいとは思いながら難有迷惑に思う気味もあるほどである。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、人身ヲ売買シ終身又ハ年期ヲ限リ其主人ノ存意ニ任セ虐使致シ候ハ人倫ニ背キ有マシキ事ニ付古来制禁ノ処従来年期奉公等種々ノ名目ヲ以テ奉公住為致其実売買同様ノ所業ニ至リ以ノ外ノ事ニ付自今｜可為厳禁事。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
