          "standard": [],
          "literary": [
            {
              "text": "コールド・ウォー　（一）　田島は、しかし、永井キヌ子に投じた資本が、惜しくてならぬ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールド・ウォー　（二）　こうなったら、とにかく、キヌ子を最大限に利用し活用し、一日五千円を与える他は、パン一かけら、水一ぱいも饗応せず、思い切り酷使しなければ、損だ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "品子が借りていた住吉町の姫松アパートの一室で泊ることになり、乳房にまでコールドクリームの匂いをさせている品子の体を抱くことは抱いたが、ふと、遠くに聞える支那ソバ屋のチャルメラの音に思いがけない感傷を強いられると、収っていた母の想出が狂暴に働いて、だしぬけに気が変った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は並木のシャン・ゼリゼーまで出たが闇一筋の道の両はずれに一方はコンコールドの広場に電飾を浴びて水晶の花さしのように光っている噴水を眺め、首を廻らして凱旋門通りの鱗のように立ち重なる宵の人出を見ると軽い調子になって彼女は言った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールドビーフが食べたいな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールドビーフのつけあわせ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子も、それを見ている内に、一瞬いそいそとした気持になり、そのまま美和子の立った後に坐って、コールド・クリームで顔を拭き始めた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "厨房一同入寮晩餐会メニューチキンコンソメ　　アスパラガスのサラダマッシュポテト　　ヒラメのソテコールドミート　　パンデザートはバニラアイスクリーム　慶一は、「厨房」という字を、とりあえず「とうぼう」と読み、コックかなんかの意味だろうと考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、コールドビーフやハムサラダでビールを一杯飲むのもいい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「コールド・ビーフと一杯のビールだ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂で、久し振りでうまいコールドラブスターをつつきながら私はすつかり安心して藤枝の先見に感服してしまつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　久慈はコールドビーフのような羊のなよなよした薄焼を切りながら、しきりに矢代の鶏に秋波を投げた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　またビール一ダースの追加、一人がコールドビーフを註文すると、お由さんが気に入っていたのか、何かしきりに皿を指さしている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホット・ウォアからコールド・ウォアに移行したが、この両者は紙一重の差である。",
              "citation": {
                "source": "新たな世界主義",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その車を見送つて、コンコールドの廣場からシャンゼリゼーの大通を通りながら、これがパリの見納めかと思ふと、少年のやうな氣持で何もかも名殘惜しく顧みられるのであつた。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼にはコールドビーフを食わされてみんな大喜びをした。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯はカフェーにロールとコールド・ミート、昼の弁当にはパンにタングとハム、それからイヴォルンの白葡萄酒を一本携帯に及んだ。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールドゲームであった。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内が言うことにや、――「いかが、コールド・ビーフを、葡萄酒に水をあしらって召しあがらないこと？",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャパニーズ・プレーン・スープ・ウィズ・オイル・アップ Japanese Plain Soup with Oil-Up.コールド・ビーン・カスタード Cold Bean Custard.『日本風の透明スープ』はお清汁……『豆の冷いカスタード』は冷奴。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地は悉くコールド・クリームの匂いになって、紅い唇だけを蜜のように意識したのです。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "第四次元の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールド・ウオー冷たい戦争――武器をとらぬイクサ――それは既にはじまっていると新聞などに書いてありますね？",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までコールド・ウォアやホット・ウォアがあつて、相當疲れて來た。",
              "citation": {
                "source": "革命を待つ心",
                "author": "――今の實業家、昔の實業家――",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールド・ウォアやホット・ウオアが盛んに動いていて、兩方からヤイノ、ヤイノと言われている時はよい。",
              "citation": {
                "source": "革命を待つ心",
                "author": "――今の實業家、昔の實業家――",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリルで、オルドヴルとオニオングラタン、コールドラブスターを食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールドラブスターとキャビネットプディング二つ食ひ、コーヒーのみ、二人で九円半は高い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマトクリームスープ、コールド・ラブスター、ヴィル・ピカタ、ゼリー、満腹。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューグランドに寄り、ポタアジュ、コールドラブスター、スパゲティと、ローストビーフにヨークシャイヤプディングとアイスクリーム。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールドラブスターとミンスビーフトースト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷映画へ涼みに入る、ニュースと一本見て、丁度逢った徳山とホテルのグリルへ行き、夕食、コールコンソメ、コールドラブスター、カネロニー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
