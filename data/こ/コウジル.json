[
  {
    "uuid": "a71a7956-0506-5e82-9560-dd42dc266e29",
    "entry": "講じる",
    "reading": {
      "primary": "こうじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
