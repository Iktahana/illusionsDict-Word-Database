    "definitions": [
      {
        "index": 1,
        "gloss": "red-haired and blue-eyed (person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
