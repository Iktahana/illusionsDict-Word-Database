[
  {
    "uuid": "bf5abdb5-744b-5a6c-8cea-51fda8692d90",
    "entry": "興奮状態",
    "reading": {
      "primary": "こうふんじょうたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
