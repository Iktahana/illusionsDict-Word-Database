    "definitions": [
      {
        "index": 1,
        "gloss": "excited condition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スポーツの好きな人がスポーツを見ているとやはり同様な興奮状態に入るものらしい。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや美術や音樂は、特異な才能を有せる人の、特異な興奮状態より結晶して成り立つたもので有るから、其作用は普通の人の氣の作用より何程強いか知れぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "興奮状態からの微かな体温を残して。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏和な情緒を滅茶苦茶に掻き立てられた彼女は、何もかも掻き※りたい興奮状態にあった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋石のように白く、靭かに細長い婦人の指を、彼は興奮状態で視詰め続けた。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はいま罹っている興奮状態ではこれで十分健康なのだ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや美術や音楽は、特異な才能を持つ人の特異な興奮状態から結晶して成り立ったものであるから、その作用は普通の人の気の作用よりどれほど強いか知れない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの体験記を読んだ直後僕はやはり妙な興奮状態になつた。",
              "citation": {
                "source": "長崎の鐘",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "志操堅固な杜だったけれど、どういうものかその夜の尿の音を思いだすごとに、彼はどうにも仕方のない興奮状態に陥ってしまい、その後もその度に、彼は哀れな敗残者となることを繰りかえした。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "興奮状態はさう長くは續くわけはないから。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お増は昨夜の睡眠不足で、体に堪えがたい気懈さを覚えたが、頭脳は昨夜と同じ興奮状態が続いていた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち新びいどろ学士の興奮状態が描かれるのであつた。",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユキに促されて、私は極度の興奮状態で、ふら／＼と石段を下り寶物館の前に來て、親王の眞筆、お馬に乘られた木像、お召物の錦の袍など拜觀して、境内の瀟洒な庭に出た。",
              "citation": {
                "source": "滑川畔にて",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに出入する将校や兵士が今にも戦争が始まるやうな興奮状態を見せて、酒気と帝国主義とが漾ふので、柔かな白塔と柳絮とを歌はうとする私達の気分とは全く相容れぬ此宿の空気であつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから宗教者が、ある時興奮状態におちいつて、その心理作用が生理的条件をつき動して表現せられるとき、ある場合は旋回運動としてはげしく、又はゆるく舞ふ事になる。",
              "citation": {
                "source": "舞ひと踊りと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十數年前、文藝上の新しい主義が海外から移入された頃、その主義宣傳の運動に携はつた者は、政黨政派の爭のやうに黨同伐異を事としたが、年月がたつて彌次馬に特有の興奮状態から覺醒した時、初めて彼等は自分達の値うちを意識し、或は意識させられた。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "その駅の改札口を出ると、山田は構内をあちこちと見廻し、早かつたかな、と思つて時計を眺めて見たりしながら、しかし一種の興奮状態に胸が弾んでゐた。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻は、さつきの興奮状態とは似ても似つかぬほど落着いて、冷然と山田を眺めてゐる。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "白状をすると、僕はもうこの時、旧友にめぐり遇つたといふやうな興奮状態からさめてゐた。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "対象をかかる興奮状態に陥れる最も著るしい例として、かの政談演説乃至未開人種の宗教的儀式を見ればわかるのである。",
              "citation": {
                "source": "煽動性万能",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婦人　　（だんだん興奮状態になる）一枝、ゆるしておくれ。",
              "citation": {
                "source": "落葉日記（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなバカなことがあらう筈はないし、僕は断じてそれを信じませんが、さういふ妄想のやうなことを口走るのは、一種の錯乱状態、少くとも、興奮状態ではないかと思ふんだ。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に言えば、勝気な性質だけに、却って一種のマゾヒズム的な興奮状態にあったのではないか、とも思われなくもない。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "同化の埒外からこの興奮状態を眺める彼の眼はついに批判的であった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神もめざめて居るのは、浮子の動きを見落すまいとして居る神経細胞だけであつて、この一群の神経領域は異常な興奮状態であるが、その他の領域は大休止の熟睡状態である。",
              "citation": {
                "source": "健康を釣る",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "記録が述べるところによると、彼は抑制された興奮状態ないし緊張の下にあるように見えた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "」２　若いウォードは愉快な興奮状態になり、次の土曜日を使って、オルニー・コートの家を時間をかけて徹底的に調査した。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり酒などを飲んで、始終興奮状態が続いているのがすっかり堪えてしまったものと見える。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の隙間から蒼白くホーッと差し込む雪明りに照らされる陰気な小屋のうちで、彼は死んだような厳めしい静寂と、次第に募って来る身の置処のない苦しさに圧迫され、強迫されて、頭はだんだんと理由の解らない興奮状態に陥って来る。",
              "citation": {
                "source": "風に乗って来るコロポックル",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一種の興奮状態に陥って、あちこちと歩くのだったが、誰もその邪魔をする者はなく、彼はカフスを引っこめたり、胸のあたりにさわったり、頭髪をなで直したりし、三人の男の前を通りながら、言った。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
