    "definitions": [
      {
        "index": 1,
        "gloss": "suddenly (fall asleep, fall over, die)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
