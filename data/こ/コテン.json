[
  {
    "uuid": "ea59c6f7-02fc-5ccd-b3b8-e31395bf1919",
    "entry": "個展",
    "reading": {
      "primary": "こてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
