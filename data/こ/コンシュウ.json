    "definitions": [
      {
        "index": 1,
        "gloss": "this autumn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あいつは本当はかあいそうですね」「ええ、まあ、火が少し白くなったわ、せわしく燃えますわ」「きっと今秋ですね。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻下に薄髭を生やし、私より少し年上のように見えたが、でも、緑線を附けた医専の角帽はまだ新しく、帽子の徽章もまぶしいくらいにきらきら光って、たしかに今秋の新入生に違いなかった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海道東征　この交声曲詩篇は、皇紀二千六百年奉讃の芸能祭に際し、日本文化中央聯盟の嘱に依り特に作詩したものであつて、信時潔氏之を作曲し、今秋、上演の予定である。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人造人間の発見」「試験管から人間が生れる」「今秋までにはオギャアと産声をあげる」というようなセンセーショナルな標題をかかげているのがあるかと思うと、村木博士と内藤女史との肖像をならべて「これが試験管で出来る赤ちゃんの御両親です」などと書いているのもあった。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当店が今秋の破格大安売りとして提供すべきこの品の一号二号三号までの価格を御決定下さい。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今秋本が彼女の動静を探らせに、わざわざ番頭を寄越したとなると、場合は葉子に不運であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小川さん、今秋川家から戻つたところです。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろＢ町は今秋の大演習の御野立所になる筈だったんだからね。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白山は加賀の白山で、白山は雪が積つてもう冬だ、その次は医王山これも冬景色に近い、次が前の戸室だが、ここは今秋酣で満目の紅黄錦のやうに美しい。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "今秋四十何人か全然新しい会員が選挙されるということに老教授は歓喜を感じ得ないのだった。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今秋は御地より山百合二千個、芍薬｜種子三升程、花菖蒲五百株送附し来る都合に相成居り候間、追つて明年の結果御報知申上ぐべく候。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は今度久保田万太郎、岩田豊雄の諸君と『文学座』を組織し、幸ひに友田君夫妻の参加を得て今秋を期して大いに、新劇界のために精進すべく、諸般の準備を進めてゐたのであるが、友田君の召集のため一時延期の状態となつてゐた。",
              "citation": {
                "source": "戦死した友田恭助氏",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一周忌の歌だろうという説もあるが、必ずしもそう厳重に穿鑿せずとも、今秋の清い月を見て妻を追憶して歎く趣に取ればいい。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今秋は法律図書館を開設し、支部の最高裁判所図書館、法務府図書館や東大と並んで一大法律図書館網の完成へ一歩を進めようとしている。",
              "citation": {
                "source": "国会図書館のこのごろ",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、今年の四月には、更に進んで、支那の漢から六朝時代までの書畫の拓本をあつめて我が大學内で展覽會を開き、今秋は朝鮮の拓本の展覽會を開いて、學生及び世間の學者と共に研究の歩を進めて見たいと思つて居るのであるが、前囘の經驗からこゝに一つ私の不滿に思ふ事がある。",
              "citation": {
                "source": "拓本の話",
                "author": "會津八一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今秋不思議にも災禍を免れたわが家の庭に冬は早くも音ずれた。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "予甚快しとなさず、今秋より筆を同誌上に断ちたり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十九日（金）　東條首相が、今秋の選挙には推薦制を用いないと言った。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "今秋マサニ鎌倉移住ノ命アラントス。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今秋冷の候なれども、その日光の強きこと、わが三伏の時のごとし。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今秋田市の病院のベッドの上に居る、側には彼女が看護して居るのだ、僕は限りなく幸福だ。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "白髪の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今秋草は川洲のどこにも伸びていた。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
