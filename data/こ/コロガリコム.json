        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "七五郎」　転がり込む石松。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうして己が口の前で旨く世間を欺けば、他に親類は無し、赤城家の財産はころりと我が手へ転がり込む。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼る所はなく一部屋貸してくれと、田村へ転がり込むのはまだいいとして、章三を見た翌日、夜更けて貴子の寝室へ忍び込んで、こっぴどくはねつけられ、田村をおん出てしまう羽目になったのは、何としてもだらしがなさすぎた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二カ月ほど土工をして旅費をつくり、郷家に転がり込む。",
              "citation": {
                "source": "簡略自伝",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薦被りが転がり込む。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてて車内に転がり込むと、それがまた延着して、八時を過ぎる頃にようようパリに送り還された。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてて車内に転がり込むと、それが又延着して、八時を過ぎる頃にようやく巴里に送り還された。",
              "citation": {
                "source": "ランス紀行",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには疲れて来たんだから、君、疲れたときには、人は一番親しい所へ転がり込むもんだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤のところへ百｜法――十円――置いて赤が出たとしたところで、勝金はその一倍、すなわち百｜法の儲けにしかならないが、仮りに十一へ真正面に百｜法抛り出して十一へ玉が落ちたとすれば百法の三十五倍と元金の百法と、つまり総計三千六百法――三百六十円――というものが転がり込む。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "父と母にはねつけられたおねだりが、泣きながら祖母に訴えればかなえられることを覚え、西は何かにつけてはおばあちゃんの膝の上に転がり込むようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の作ったものの腹の中へ転がり込むんだからな。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして巡査と押し合う人間の袂の下をかいくぐって、躓きたおれんばかりに楽屋の奥へ転がり込むと、楽屋の連中は皆、外へ逃げ出すか、馬の処へ駈け付けるかしているために、どの室も森閑と静まり返っている。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "枠細工の上の方に重い刃物が附いていて、それが差し伸べられている処刑者の首へ滑り落ち、その首が転がり込む嚢が附いていたのである。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしく頼む」　長庵になってみれば、油御用の株が伊豆伍から奪われて筆幸へ廻れば、筆幸から途法もない謝礼が転がり込む約束になっているから、元より万事、慾と二人づれでなければ一寸も動かぬ長庵である。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはちょっとの間この女を死んだお婆さんの娘に仕立てれば、甲府の家主が持って来ているという二百両は、そっくりこっちの手へ転がり込む。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すばらしいお宝が転がり込む。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "大成功が転がり込むぞ」第二章　オールドマーケットは皆知っているように、競馬会の本部がある。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人入れてやる」「叔父さんの財産が美人ぐるみ転がり込むんだから、好い星の下へ生れて来た男さ」「そこを睨んでいる。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "財産は転がり込む、婚約は成立する、君も飛んだ果報者だね」　と、おだて上げると、川村めもう有頂天になって、「そうですよ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな大金が転がり込むという考えは明らかに眉唾ものだ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将がそのうちの一台に転がり込むと、さっと走りだした。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はそれをいう暇がない、あっ」　バーニ先生が駆け足で、書斎窓の所まで行き、部屋に転がり込む様は、全く偶然にその部屋を見つけたかのようだった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな地位が転がり込むなんてざらにあることじゃない。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ほどで川を下る」　まさに言った通り、フェンウィックは寝台に転がり込むと、すぐ寝入ってしまった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "大金が転がり込むからです。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしあのブレナム号がダービーに出なければ、少なくとも一万ポンドが転がり込む。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "また金持ちの風変わりな叔母さんがいて、いつか遺産が転がり込むとか。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人がさっき掘った洞穴を指さすと、客はそれを通路と誤ったらしく、壁の穴へとつき進んで、土の中へ転がり込む。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "御名物のお殿様でごぜえますから、直に申しまするが、名前は人好し長次、まとまった金がころがりこむと、じきにうれしくなって人にバラ撒いちまいますんで、この通り年がら年中文なしのヤクザ野郎でごぜえます」「わはは。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその女が死ねばどうして博士に財産がころがりこむことになっているのだか其の辺はよく藤次郎には判らなかった。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
