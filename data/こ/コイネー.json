        "examples": {
          "standard": [
            {
              "text": "新約聖書は、当時の東地中海地域で共通語として使われていたコイネーで記述されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "言語学の講義で、古典ギリシャ語から近代ギリシャ語への変遷におけるコイネーの役割を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コイネーは商人や兵士たちの言葉であり、非常に実用的で広範囲に普及していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "新約聖書の原文が「コイネー」と呼ばれる当時の民衆語で記されて、文雅語でなかった事実から考えても、聖書が本来民衆の書であったことがわかる。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "共通感覚が内部的だという点で以て初めて、アリストテレスの共通感官（コイネー・アイステーシス）は、近世の例えば常識学派の哲学による常識に、連絡しているのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の個人の意識の統一を齎すものは、一方個人心理的に云えばコイネー・アイステーシスであると共に、その同じ関係が、個人を社会心理的に見ると、所謂常識となるのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
