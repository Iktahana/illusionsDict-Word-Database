  {
    "uuid": "9f5d4edb-6b76-58ad-a7f1-9f32b7f726e6",
    "entry": "光熱",
    "reading": {
      "primary": "こうねつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
