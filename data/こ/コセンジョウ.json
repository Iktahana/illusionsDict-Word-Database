    "definitions": [
      {
        "index": 1,
        "gloss": "ancient battlefield",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
