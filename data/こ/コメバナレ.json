        "examples": {
          "standard": [
            {
              "text": "若者の米離れを食い止めるため、農協が新しい炊飯レシピの普及に乗り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "食生活の欧米化による米離れが進み、国内の米消費量は年々減少している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「米離れ」と言われる昨今だが、こだわりの高級おにぎり店はどこも繁盛している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は恐怖しながら接近した、黒いものの形は動物の黒い影絵で影から三米離れたところに怪物の本体がゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "とびかゝつたとはいふものの、実は二三｜米離れてをり、彼は髪ふりみだしてピストンの連続、ストレート、アッパーカット、スヰング、フック、息をきらして影に向つて乱闘してゐる。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とびかかったとはいうものの、実は二、三｜米離れており、彼は髪ふりみだしてピストンの連続、ストレート、アッパーカット、スイング、フック、息をきらして影に向って乱闘している。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆撃は伊沢の家から四五百｜米離れた地区へ集中したが、地軸もろとも家はゆれ、爆撃の音と同時に呼吸も思念も中絶する。",
              "citation": {
                "source": "白痴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
