        "examples": {
          "standard": [
            {
              "text": "組織において「個と全」のバランスをどう取るかは、永遠の課題だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "個人の自由を尊重しつつ、全体としての秩序を守る個と全の両立を目指す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "個と全が調和した社会こそが、これからの理想的な姿ではないだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "個と全体、主と客体、自と他は既にそのように結び合わされてしまっている。",
              "citation": {
                "source": "「冒した者」について",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が喋っている内容とそれに対する相手の反応を充分に楽しみながらも、どこかでそのことぜんたいに対してあきれたような、あるいはあきらめたような、醒めた面白さをいつも感じているような、そんな喋りかただ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "売る品物の値段は、こことぜんぶおなじです。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きることぜんたいの表現が、ブルースなのだから。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
