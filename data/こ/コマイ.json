[
  {
    "uuid": "bfc6aef9-beac-58fa-8eea-099012dd825c",
    "entry": "古米",
    "reading": {
      "primary": "こまい",
      "alternatives": [
        "ふるごめ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
