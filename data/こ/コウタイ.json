[
  {
    "uuid": "453a0c4a-dcd7-59f9-9b08-5d61bfcbafba",
    "entry": "興替",
    "reading": {
      "primary": "こうたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rise and fall (of nations)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "刑事さんたちは、食事をすますと、新しくやってきた三人の刑事さんと、こうたいしました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村さんの書生がふたり、うんてん手の栗田、それから、明智たんていのぶかの男がふたり、ぜんぶで五人が、こうたいで、家の外と中を見回っているのでした。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうたいでもち場についている船員のほかは、みんな船室にはいって、ねむりについていました。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうたいで、ひと部屋からひとりずつ、広い地底の岩の廊下を、すみからすみまでまわり歩いて、警戒しているのです。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーカス団員だけでなく警視庁のうでききの刑事が三人ずつ、夜昼こうたいで、笠原邸につめることになったのです。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、夜の九時ごろには、チンピラ隊とこうたいするのさ。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜昼こうたいで、いつも十人の見はりがついているのです。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
