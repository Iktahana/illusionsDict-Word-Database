        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "知らずして他の個人経営の馬車にでも乗ろうものなら、それこそ大変。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子は二月ほど前に、千葉で結婚をし損なった栗栖が、この土地の病院の産婦人科の主任となって赴任したことを知っていたが、わざと寿々廼家のかかりつけの、個人経営の医院で手術を受けることにした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ねえ、房ちゃんも、あんな皺苦茶婆さんに頭を刎ねられているよか、自分で、個人経営にしちゃったらどう？",
              "citation": {
                "source": "街底の熔鉱炉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、その後の税率は、集団農場の全収入を集団農場員の頭割にして、その額がその地方の個人経営の農民の平均収入より少なかった場合は免除。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多かったら、個人経営の農民の払う税の三割から六割減の率で払う。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして、官営である日本の放送事業は、個人経営のアメリカなどとは違う。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言ったところで、個人経営の商店もあるにはある。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのはとにかく大会社だけれど私のは個人経営だし……丸ビルの中なんて、トッテモひどいワ」　みどりは秋田から逃げて上京して来た。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験も、保証人もいらない個人経営の事務所の女事務員に職業紹介所から雇われるしかないのだ。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し着実な其道の人の批判では仮ひ一円に下つても会社経営では四五割、個人経営では六七割の利益は確かだと云つて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "株式会社ではあるが殆んど個人経営とも云ってよい、その小さな商会内で、彼は社長から重用せられてる敏腕家だった。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、そのつぎに、個人経営の各種農園の実態と、その経営の基礎となるような経済的、技術的な参考書を、ひと通り拾い読みをした。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の方は合同はしていても内容は個人経営の部分もあって、達ちゃんの代理は山崎の峯雄さんがやってくれるそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンの岩出銀行（涙香式に英国名を日本名に引き直して訳したもの）という個人経営の銀行社長が、ふと道で出会った乞食少年の正直な行為に感心して、この少年を引取り、学校に入れ、後には自分の銀行の社員にする。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
