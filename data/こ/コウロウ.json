[
  {
    "uuid": "31778e86-b3f4-562f-b5b2-745fb164e7c5",
    "entry": "功労",
    "reading": {
      "primary": "こうろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
