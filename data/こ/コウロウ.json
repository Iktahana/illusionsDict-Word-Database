  {
    "uuid": "9f80c1ea-b2e6-597a-8385-e666cd792bc0",
    "entry": "晃朗",
    "reading": {
      "primary": "こうろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bright and brilliant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "はる、こうろうの花のえん、めぐるさかずき、影さして、ちよの松がえ、わけいでし、むかしの光、いまいずこ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "消しながら、やがて小声で、はる、こうろうの花のえん、めぐるさかずき、影さして、と歌う。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "はる、こうろうの花のえん、の曲の合奏である。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "はる、こうろう、も、それから、唐人お吉も、それから青い目をした異人さんという歌も、みんなあたしが教えたのよ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くから、はる、こうろうの花のえん、の合唱が聞える。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "今時分こんなとこうろうろしてるんだから。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるこうろうのはなのえんめぐるさかずきかげさして　じぶんの美声に聞きほれているかのようにマスノは目をつぶって歌った。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
