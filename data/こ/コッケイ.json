[
  {
    "uuid": "4f8b9597-be26-5aaf-a9f5-77610c029fde",
    "entry": "滑稽",
    "reading": {
      "primary": "こっけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "funny",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "造花造りの羽振のよさは、あゝ、滑稽なこつた滑稽なこつた。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが滑稽だとみえないばかりに、花の言葉はみなしやらくさい。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大騒ぎをして買集めたであらうあれ等のお土産を棚の上に置いて、かうしていぎたなく眠つてゐる人間といふものは、思へば滑稽なものではないか。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに衣食住に凝って得意顔の人は、私には、どうしてだか、ひどく滑稽に見えて仕様が無いのである。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の挨拶が滑稽だといつて笑はれるがよい。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒は用達が困難になり、それに見た所それは実に滑稽な便所となつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しその数が異るとするか、人間と人間とが論じ合はうとすることは、全く以て滑稽なこととなる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちジヤツク・ウオーキイ等によつて映画で紹介されてゐるやうな、歌詞を本位として簡単な音楽を伴奏的につけ、専ら歌詞の滑稽味やエロチシズムやで、大衆を興がらすやうに出来てる「音楽入西洋万才」が、近い未来に於て日本に現れることを予感させる。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に告白すると、かうした訳を読んで滑稽になり、いつも失笑を禁じ得ないのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これほど滑稽な事実はなかつた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その讀後の深い印象から、僕はラスコリニコフを以て自ら氣取り、滑稽にもその小説的風貌を眞似たりした。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の文豪である大トルストイが、救世軍的人道主義者として擔がれたり、通俗モラルのセンチメンタリストとして、女學生の涙劇的ヒロイズムの對象であつたりしたことを考へると、今から考へて全く馬鹿馬鹿しく滑稽である。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の曲目の内に管弦楽で蛙の鳴声を真似するのがあった、それはよほど滑稽味を帯びたものであった。",
              "citation": {
                "source": "蛙の鳴声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六歳の美しい處女には近寄るなといふ深切な忠告を匂はせた滑稽物語でもあらうか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに衣食住に凝つて得意顏の人は、私には、どうしてだか、ひどく滑稽に見えて仕樣が無いのである。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰宅してみると猫が片頬に饅頭大な腫物をこしらえてすこぶる滑稽な顔をして出迎えた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は滑稽という事がここにいわゆる漫画の本質的条件とは考えていない。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私の考えているすべての漫画を滑稽であるとすれば、それは畢竟人間の真その物が滑稽な分子を含んでいるという事になるだろうと思う。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に滑稽というものは極めて真面目な悲痛なものだという結論も生れるだろう。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "就任式の仰々しい行列は彼にいささか滑稽に思われたようであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が見たら人間のテニスやベースボールは定めて間だるっこくて滑稽なものだろうという気がするのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこの曲った標柱は天然自然の滑稽であり皮肉である。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "似非風流や半可通やスノビズムの滑稽、あまりに興多からんことを求めて却って興をさます悲喜劇、そういったような題材のものの多くでは、これをそのままに現代に移しても全くそのままに適合するような実例を発見するであろう。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時僕が怒つたのは、家鴨の卵から鷄が生れたと言つて腹を立てたやうなもので、今思へば我ながら認識不足の滑稽である。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに私の方ときたら、極端にまた彼の正反對だから滑稽だ。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの宮大工上りの五十男の滑稽な申込みようはどうだ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑稽なのは、いつだつたか「人形の家」を見たことがある。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか知れないけれどもぼくはおばあさまの様子がこっけいにも見え、おそろしくも見えて、思わずその方に駆けよった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男の動作は一つ一つがこっけいで、小屋じゅうをわあわあと笑わせるのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦痛や憂鬱さえもがこの男の深刻な顔にこっけいな生真面目さを加えて、お気に入りの役者に手をたたく大勢の見物人の笑いをひき起すのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
