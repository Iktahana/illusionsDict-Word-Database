    "definitions": [
      {
        "index": 1,
        "gloss": "lecture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こういう巧智はしかしことごとくが亀さんの独創によるものではなくて、大部分は重兵衛さんの晩酌時の講話の時に授かったものであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の三｜本木の有志の方々から、こゝで一｜泊して晩餐と一｜所に、一｜席の講話を、とあつたのを、平におわびをしたのは、……かるがゆゑに袴がなかつた為ではない。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "講話など思ひも寄らなかつたからである。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま思へば、予て一｜本を用意して、前記（郷土会記録）載する処の新渡戸博士の三｜本木開墾の講話を朗読すれば可かつた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもちゃその物の効果については時々教育家や心理学者の講話を新聞や雑誌で読んでみるが、具体的に何商店のどのおもちゃがいいという事を教えてくれないのは物足りない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西川一草亭の花道に関する講話の中に、投げ入れの生花がやはり元禄に始まったという事を発見しておもしろいと思った。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオで三晩続けて探偵小説の講話があって、絶対に発見されない殺人の手段なぞに関する話が、色々な例を引いて放送されたので、一知は村中の人々の怨みを一人で代表しているような気持ちになって、全身を耳にして傾聴した。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビヤホールのラジオは、そのとき、大声で時局講話をやっていました。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思っていたら、果して、その講話のおわりにアナウンサアが、その、あいつの名前を、閣下という尊称を附して報告いたしました。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南區のある通りには紅で塗つた質屋の格子戸の外に「心學講話、藤澤老先生經書御講義」などといふ札さへ見られた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に私の書いた「探偵小説の真使命」は文芸通信社からの註文で書いた、即興的な自己反省の感想文に過ぎないので、ぷろふいる誌の「探偵小説講話」もしくは甲賀三郎氏の御話に対する批難でも反駁でも何でもないつもりで書いたものだからである。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チチノウイツケツスクコイ」　私は一所に見物していた中学生の子供二人と一所にタクシーで家に帰り、妻に金の準備を命じ、そのままの服装で、ポケット四書と丘浅次郎氏の進化論講話を携えて又もタクシーに飛乗り全速力で博多駅に駈けつけ、富士に乗後れてサクラに間に合った。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、この場長の毎日の講話は、僕にはとても楽しみだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜には、講話のかわりにレコオドを放送する。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "場長の清盛も、こないだの講話で言っていた。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、講話の時間だ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋へ帰ったら、まだ講話は始まらず、かっぽれが、ベッドにひっくりかえって、れいの都々逸なるものを歌っていた。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて講話がはじまり、日支文明の交流という題で、岡木という若い先生が、主として医学の交流に就いて、昔からのいろいろな例証を挙げて具体的にわかり易く説明して下さった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま僕はこの手紙を、午後一時の講話を聞きながら書いているのだが、きょうの講話は、どなたが放送していらっしゃるか、わかりますか？",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは事務所からの依頼で花宵先生がはじめて講話をする事になって、「献身」と題するお話であるが、こうして拡声機を通して流れ出る声を聞いていると、非常に貴い人から教え訓されているような厳粛な気持になって来る。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朶石からは画の他に漢詩作法と篆刻と築城講話と、そして国手から半弓と碁と笛と釣りと箱庭作法とを習つた。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ店から出した散文集『和歌講話』また然りである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "漣は早くから小説の筆を絶ち、小波伯父さんとなって揮毫とお伽講話に益々活動しているが、今では文壇よりはむしろ通俗教育の人である。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "きびし過ぎる親と、無関心過ぎる親とを集め、私を実例にして何か恐ろしい事を講話してやって呉れ。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青年訓練所」では、※の旦那が「修養講話」をやった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜道　健達は、士官の訓練が終って、※の「修養講話」になると、疲れから居睡りをし出した。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青年の任務」「思想善導」「農民の誇」……何時もチットモ変らないその講話は、もう誰も聞いているものがなかった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いゝや、うら等両人で行こうわ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその跡のようなものは、まだ百歩も行かないうちに、おとこえしや、すてきに背の高いあざみの中で、二つにも三つにも分かれてしまって、どれがどれやらいっこうわからなくなってしまいました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「手を掛けて肩を上げされ、私が腰を抱こうわいの。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
