        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近所の農家の子犬が第七学級の教室の窓の下を通ると、窓から黒い洋服がぶらさがっていた。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくも子犬は魚が引っかかっていると思った。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬はその魚に跳びついて咥えた。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "咥えて振り回して歩いているうちに、子犬は蟇口を発見した。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬は一片の肉が落ちていると思った。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬は味のない肉を捨てて、魚のほうへ行った。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　子犬は追われて魚を置いて逃げた。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬を追っていった田中は戻ってきて、洋服を窓にかけた。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お石は子犬を懐へ入れて来た。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬は古新聞へ包んであった。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬は新聞紙にくるまって寝て居た。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬はそれへくるまって寝た。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルタ犬は一名を獅子犬と呼ばれてゐるが名ばかり立派でからもう弱虫な怯な奴だ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬ほどもあろうと思われるまっくろな黒ねこが、女の首を、いや、首ではない、女の髪の毛を、それも島田に結ったままの髪の毛を、あんぐりと、その口にくわえながら、牙をむかんばかりのものすごい形相で、らんらんと両眼を光らしていたからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかに芽の出た麦畑の間を通って、海べの砂州に海苔の乾してある、丹那の村の入り口の橋のそばまで来ると、私の家の飼犬のイチという子犬が、私の姿を見つけて跳ね廻って悦び、吠え、尾をふり、俥の前に立って、私の家の門まで走りました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処には、実に丸々と肥えた、羊のような厚い白の捲毛を持った一匹の子犬が這って居るではないか。",
              "citation": {
                "source": "犬のはじまり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "８　子犬と食器を一緒にしているなんて、汚ねえからよしな。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白はまだ子犬の時から、牛乳のように白かったのですから。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ学校の帰りらしい、洋服を着た子供が二三人、頸のまわりへ縄をつけた茶色の子犬を引きずりながら、何かわいわい騒いでいるのです。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬は一生懸命に引きずられまいともがきもがき、「助けてくれえ。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ笑ったり、怒鳴ったり、あるいはまた子犬の腹を靴で蹴ったりするばかりです。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "白は二三間追いかけた後、くるりと子犬を振り返ると、叱るようにこう声をかけました。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶色の子犬も嬉しそうに、ベンチをくぐり、薔薇を蹴散らし、白に負けまいと走って来ます。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　　　　　　　　×　　　　　　　　　　×　二三時間たった後、白は貧しいカフェの前に茶色の子犬と佇んでいました。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬は得意そうに尾を振りながら、こう白へ話しかけました。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　子犬は悲しそうに鼻を鳴らしました。",
              "citation": {
                "source": "白",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいぬ　の　ちびすけ村山籌子　コイヌ　ノ　チビスケガ　タイヘンニ　イバツテ　ヤツテキマシタ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むらを　かけあしに　まわって、　２ひきいる　きつねがりの　こいぬを　さがしますと、　にくやの　とぐちのまえで　みつかりました。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが　まの　わるいことに、　こいぬたちが　とめるよりもさきに　とびこんで、　たまごを　みんな　たべつくしてしまって。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "コリーいぬは　みみを　かまれていて、　こいぬたちは　どちらも　へろへろ。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
