    "definitions": [
      {
        "index": 1,
        "gloss": "to become covered in moss",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
