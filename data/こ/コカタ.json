    "definitions": [
      {
        "index": 1,
        "gloss": "child's role in noh dance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
