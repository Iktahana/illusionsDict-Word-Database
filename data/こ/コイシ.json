        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "便なき幼兒のうたへる歌萩原朔太郎うすらさびしき我が身こそ利根の河原の石ひろひひとり岸邊をさまよひて今日も小石をひろふほど七つ八つとなりにけり",
              "citation": {
                "source": "便なき幼兒のうたへる歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば同じ冬の句で寒月や鋸岩のあからさま木枯しや鐘に小石を吹きあてる　など、すべていわゆる「印象明白」の句の代表である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端、目標を外れた銀貨はチチンと小石に衝突つて、跳返つて、囘轉つてベタリ。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「學校は何處……小石川？",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして小石川といふ見當をつけたかゞ私には不思議に思はれた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云はれると成程何となく小石川らしくも思はれない事はなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍服は小石を拾っては氷の上をすべらせて快い音を立てている。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍るものから、餌食を見出して来やがれ」　ぺっぺっぺっと唾を三度、庭に吐き去りかけたが、ふとそこに落ちている小石の一つを拾って手早く懐に納め、「ざまを見よ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は拾って来た娘の家の庭の小石を懐から取出して船燈のかげで検めみる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「娘が変っているだけに、庭の小石も変っていら」　翁はそういって、なおも燈のかげで小石を捻っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「庭の小石まで涙の形になってやがる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁はすごすごと小石をまた懐へ入れた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しむときは、鳴沢に小石が滑り落ちる音が止めどもなくしくしくと聞えて来る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛が網を張ったり、ある種の土蜂が小石をもって地面をつき堅めるのがそれだという。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分に蜻蛉を捕るのに、細い糸の両端に豌豆大の小石を結び、それをひょいと空中へ投げ上げると、蜻蛉はその小石を多分｜餌だと思って追っかけて来る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には風がながれてゐる、おれは小石をひろつて口にあてながら、どこといふあてもなしに、ぼうぼうとした山の頂上をあるいてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面には小石や、硝子かけや、草の根などがいちめんにかがやいてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を張った大桶の底へ小石を沈めておいて、幼い小初に銜え出さしたり、自分の背に小初を負うたまま隅田川の水の深瀬に沈み、そこで小初を放して独りで浮き上らせたり、とにかく、水というものから恐怖を取り去り、親しみを持たせるため家伝を倍加して小初を躾けた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘には処々｜草叢があり、灌木の群があり、小石を一箇所へ寄せ集めた堆があった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が十日ばかり前に小石川から来て私に妾になれと言わないばかりなのよ、あのお前の思案一つでお梅や源ちゃんにも衣服が着せてやられて、甘味ものが食べさされるッて……」「それで妾になれって？",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石川の方へも左迄は請求れないもんですから、お梅だけは奉公に出すことにして、丁度｜一昨々日か先方へ行きましたの。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い葛飾の江戸川じゃあない、江戸の小石川と牛込のあいだを流れている江戸川で……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その妹のお道といふのは、四年前に小石川西江戸川端の小幡伊織といふ旗本の屋敷へ縁付いて、お春といふ今年三つの娘まで儲けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "護岸工事に使う小石が積んであった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石に阻まれ、一しきり風に堪えていたが、ガックリ一つ転ると、また運ばれて行った。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっと流れて来る光のなかへ道の上の小石が歯のような影を立てた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その削り立った峰の頂にはみな一つ宛小石が載っかっていた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっこいしょ、どっこいしょ」　お早うを言いにあがって来た信子は「まあ、温かね」と言いながら、蒲団を手｜摺りにかけた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（どッこいしょ、）と暢気なかけ声で、その流の石の上を飛々に伝って来たのは、茣蓙の尻当をした、何にもつけない天秤棒を片手で担いだ百姓じゃ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こいしくば、たずねきてみよ、みずの底、ああ、せめて、もう一言、あの、――」聞ゆるは、ただ、波の音のみにて。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
