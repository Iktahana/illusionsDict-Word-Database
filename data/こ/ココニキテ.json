        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おじはここに来てソとわれをおろしつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の流れはここに来て急に幅広くなって、深くなって静かになって暗くなっている。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに御利益が顕われるから見てろ」「じゃここに来て油を売るのも勘定ずくなのか」「ばかあいえ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに来て私はホイットマンの言葉を思い出す。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学円　今朝から難行苦行の体で、暑さに八九里悩みましたが――可恐しい事には、水らしい水というのを、ここに来てはじめて見ました。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その縁故に因って大野は浅野家滅亡の後ここに来て身を落付けたらしい。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はここに来て、いくらか眠ってから、やっと今眼を醒ましたものらしい。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "をぢはここに来てソとわれをおろしつ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "新田といふ二十五歳の温厚な青年が、峠を降りきつた岳麓の吉田といふ細長い町の、郵便局につとめてゐて、そのひとが、郵便物に依つて、私がここに来てゐることを知つた、と言つて、峠の茶屋をたづねて来た。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姉上と、大方はわれここに来て、この垣をへだてて見えぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夜狂言見に行きたる帰には、ここに来てかくは云うなりけり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはある漂流者がここに来て食客をしてゐた時分密かに町の人に薬を売つてゐたのが、逝くなつたので、そのまゝにしてあるといふ、旧い話であらう。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ団長へも私たちがここに来ていることを知らしてないくらいだからね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おん身も名を知る相沢が、大臣とともにここに来てわれを呼ぶなり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "※がその訳を話すと、「その婦ならここに来て三月になるが、今は病に罹って寝ている」　と言って、※を誘うて中へ入った。",
              "citation": {
                "source": "美女を盗む鬼神",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、いつも職工が帰ってからここに来て、この火の海の中から簡単に純鉄を取る方法を考えているんだがね」「今も考えているんですかい」「ウン……重大なヒントが頭の中で閃めきかけているんだ。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは青木さんの汽笛が鳴ると、ああ青木が泣くから、発車の時間だ、なんて出掛けて行ったものだわ」「そんなによく判るものなら、お父さんは、僕達がここに来ていることを知ったら、ここを通るときには、汽笛を鳴らさないだろうな。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてとにかく私がここに来てから一ヶ月になります。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、俺がここに来てもう一ヶ月です。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "お世話の方に一〇〇ポンドを送って、この小屋のことを教えて、何の関係もないような振りをしてここに来てもらった。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「明日の正午、ここに来ていただければ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに来てからというもの、もう証拠は揃っているというようなことを再三おっしゃる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも業界の算盤勘定は堅調だったものが、ここに来て日本のメーカーは厳しい不況に直面させられている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにここに来て、逆にパーソナルコンピューターの側からＵＮＩＸが担ってきたネットワーク分野へと進出する勢いが増してきている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい自分が情報家電において何がやりたいのか、そこのところをきっちり詰めておかないと、ジェネラル・マジックの踏み出した確実な一歩からここに来て急速に拡散の兆しを見せ始めたアップルの家電戦略はわけが分からなくなる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがここに来て、具体的に明らかになってきたということだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたの奥さんはひと月ほど前からここに来ておいでですが、今は病気で寝ておられます。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど再びここに来て、君らがまとゐに入ることとなりし、その因縁をば、早く当時に結びぬ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「竹さんを、とても好きだと言ってる人が、いまここに来ているんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼らをうらやましくて、毎日ここにきてじっとみつめておりました。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
