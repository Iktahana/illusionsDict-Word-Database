        "examples": {
          "standard": [
            {
              "text": "玄関の棚に置いた可愛い陶器の小物入れに、いつも鍵を入れるようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「バッグの中が散らかるから、化粧直し用のグッズは全部この小物入れにまとめなよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "手芸が趣味の祖母が、余った布で作ってくれたパッチワークの小物入れを愛用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "机の横に置いた小物入れから作りかけにした衣装人形を取り出し、縁側に行って椅子にかける）真紀。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨塗りの小物入れにも触れたらしく小さい手形がついている、泥に汚れた手で抽斗を開けたのでしょう。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ついてしばらくたったとき、泰造はふと、いつも眼鏡、いれ歯、財布、時計などを入れて枕もとにおく小物入れの箱を食堂へおきっぱなしにして来たのを思い出した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぶは箪笥の小物入れの抽出から、半紙三枚を折った書付けを取出して来て、栄二の前に坐り、それを手渡した。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
