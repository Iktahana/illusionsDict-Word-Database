          "standard": [
            {
              "text": "イタリアのコムーネは、日本の市町村に相当する最も小さな行政単位である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は故郷のコムーネから功労賞を授与され、式典に招待された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "観光客向けの案内所は、コムーネの庁舎の一角に設置されている。",
              "citation": {
                "source": "幻辭AI",
