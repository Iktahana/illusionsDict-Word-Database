        "examples": {
          "standard": [
            {
              "text": "江戸時代には、浮世草子などの好色文学が庶民の間で広く読まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "好色文学は、当時の社会風俗や人間関係を理解する上で貴重な資料となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この作家の作品は、しばしば好色文学の範疇に入る。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしこの章は世に伝えられるような好色文学では決してない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　今自分が論じている恋愛や結婚などの問題にしても、世間流行の好色文学のまねをしているのではない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
