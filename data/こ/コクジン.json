    "definitions": [
      {
        "index": 1,
        "gloss": "black person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白人の子供も黒人の子供も、すべての人間の子供は、本來フアンタスチツクな夢の宮殿に住んでゐるのだ。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし黒人になれば多分唯一面のちやぶ臺、一握の卓布の面の上にでも矢張りこれだけの色彩の錯綜が認められるのであらう。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷珸の知合に黄紳の間にも遊び、少しは鼎彝書画の類をも蓄え、また少しは眼もあって、本業というのではないが、半黒人で売ったり買ったりもしようという男だ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の米国人の中にでも黒人は人間と思っていない仲間があることはリンチの事実が証明する。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "別して鹿狩りについてはつの字崎の地理に詳しく犬を使うことが上手ゆえ、われら一同の叔父たちといえども、素人の仲間での黒人ながら、この連中に比べては先生と徒弟の相違がある、されば鹿狩りの上の手順などすべて猟師の言うところに従わなければならなかった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし黒人になればたぶんただ一面のちゃぶ台、一握りの卓布の面の上にでもやはりこれだけの色彩の錯綜が認められるのであろう。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白人にとっては黒人はおそらくゼブラや疣猪とたいしてちがったものには思われてないのではないかという気がしてならない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後私の生活がいかように変わろうとも、私は結局在来の支配階級者の所産であるに相違ないことは、黒人種がいくら石鹸で洗い立てられても、黒人種たるを失わないのと同様であるだろう。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれが雌だか、雄だか、黒人にも分らんで、ただこの前歯を、」　と云って推重なった中から、ぐいと、犬の顔のような真黒なのを擡げると、陰干の臭が芬として、内へ反った、しゃくんだような、霜柱のごとき長い歯を、あぐりと剥く。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に、肩には更紗を投掛け、腰に長劍を捲いた、目の鋭い、裸の筋骨の引緊つた、威風の凛々とした男は、島の王樣のやうなものなの……　周圍に、可いほど間を置いて、黒人の召使が三｜人で、謹んで給仕に附いて居る所。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天窓の大きな、頤のしやくれた、如法玩弄の燒ものの、ペロリと舌で、西瓜喰ふ黒人の人形が、ト赤い目で、額で睨んで、灰色の下唇を反らして突立つ。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も御先祖の頃だらうけれど――其の黒人も……和蘭陀人も。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒人の給仕に導かれて、燈籠の影へ顯れたつけね――主人の用に商賣ものを運ぶ節は、盜賊の用心に屹と持つ……穗長の槍をねえ、こんな場所へは出つけないから、突立てたまゝで居るんぢやありませんか。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふと蓮葉に、ものを言つて、夫人はすつと立つて、對丈に、黒人の西瓜を避けつゝ、鸚鵡の籠をコト／＼と音信れた。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度何處か方角も知れない島へ、船が水汲に寄つた時、濱つゞきの椰子の樹の奧に、恁うね、透かすと、一人、コトン／＼と、寂しく粟を搗いて居た亡者があつてね、其が夥間の一人だつたのが分つたから、聲を掛けると、黒人が突倒して、船は其のまゝ朱色の海へ、ぶく／＼と出たんだとさ……可哀相ねえ。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西瓜は投げぬが、がつくり動いて、ベツカツコ、と目を剥く拍子に、前へのめらうとした黒人の其の土人形が、勢餘つて、どたりと仰状。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペムペルとネリとは、黒人はほんとうに恐かったけれど又｜面白かった。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒人たちは、時々何かわからないことを叫んだり、空を見ながら跳ねたりした。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒人の群れがずっと奥地にある市場から帰ってきます。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりの黒人は買ってきたライオンの子を綱で引いています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "この黒人の国にいながら、砂漠のかなたの匂い高い、まっ白な花のことを夢みているのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にけばけばしい色彩で壁に淫靡な裸体女と踏み躙られた黒人を描いて、思わせ振りな暗い入口が五六段の階段の上についている｜食しんぼう小屋のようなものが混っている。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "延珸の知合に黄紳の間にも遊び、少しは鼎彝書画の類をも蓄へ、又少しは眼もあつて、本業といふのでは無いが、半黒人で売つたり買つたりも仕ようといふ男だ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "王様が黒人の力士を養って、退屈な時のなぐさみものにしているような図と甚だ似ていた。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸には夕方の釣に出る素人や黒人の舟が一杯集つてゐた。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その調子がいかにも黒人じみてゐて、今迄の努力の廢止を促す絶對の合圖となつた。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋鹿子の襷掛けで、二の腕まで露呈に白い、いささかも黒人らしくなかったと聞いている。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこの銀色の光のなかに太くしてむくつけき黒人の手ぞ働ける……甘き甘きあるものを掻きいださんとするがごとく。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困るよ、困るよ、ほら飛行場が見える」　と、岸には黒人種風景の、裸の童子と童女がいる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
