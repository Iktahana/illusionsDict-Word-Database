    "definitions": [
      {
        "index": 1,
        "gloss": "to yearn for",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海上生活者が港にあこがれ、陸を恋しがるように、彼等は、内地にあこがれ、家庭を恋しがった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "働きに行つて家を恋しがるやうでどうするか、わたしは子供の時から四十の歳まで船に乗つてゐたが、どこの海の上でもそんな女々しい考へを起したことは一度もなかつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがわたくしが人恋しがる気持はそんな単純なものではありましょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、新次は変な子供で、浜子を恋しがる風も見せずに、化物のように背の高い玉子にひたすらなついていたようでした。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに人里の遠いところに育ったので、非常に人を恋しがる方であった。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴三「きいてるな」新吉「うん」鶴三「家を恋しがるんじゃねえぞ、父っちゃんは十二の歳から船に乗ってたが、印度洋の真中でも、大西洋を渡る時でも、太平洋の上でも、一遍だって家を恋しがった事はなかったぞ」新吉「あ、汽車が停った」窓をあける。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯田町へ着いたらすぐ大木のところへ行って見ようと、矢野はただ船に疲れた人が陸を恋しがるような思いで大木が恋しくなった。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし生物には安定を喜んで因縁を恋しがる情もある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山羊はじと／＼と水を吸うた檻の板屋根の下に小暗く引つ込んで、人のけはひを恋しがるやうにみい／＼啼いた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが人を恋しがるような風が見えて、時には何となく可哀そうなように感じられることがある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が肩身を狭くして、一種の継子のような風をして、他国人の私たちを恋しがるのも無理はない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには父も持て余したばかりか、片輪の子ほど可愛さも不憫さも弥増して、かの奉公人ふたりと相談の上で、娘の恋しがる男を引っかついで来ることにした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬と春先のみじめな東北の人達はだれでも力のみちたはずむ様な夏をやたらに恋しがる通り仙二は夏をまだ雪の真白にある頃からまって居た。",
              "citation": {
                "source": "グースベリーの熟れる頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "病にかかつてこのかた、暑さ寒さが今までになくひどく体にこたへるので、夏が来ると秋を思ひ、冬になると春を恋しがる以外には、何をも知らない私は、ことしの冬が近年になく厳しからうとの前触れがやかましかつただけに、まだ冬至も来ないうちからどれほど春を待ちかねたことか。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人でさえ是だから同類は尚お恋しがる。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの時｜兄さんが亡くならないで、未だ達者でゐたら、今頃私は何うしてゐるでせう」と三千代は、其時を恋しがる様に云つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒明けの日和はおだやかで、老人たちが恋しがるばかりではない日の光りはのどかだ。",
              "citation": {
                "source": "豊竹呂昇",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも恋しがるはずの妻はまだ貰ってはいなかった。",
              "citation": {
                "source": "保吉の手帳から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの時兄さんが亡くならないで、未だ達者でいたら、今頃｜私はどうしているでしょう」と三千代は、その時を恋しがる様に云った。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が東京を恋しがると同じわけに違ひない。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へ、へ、へ」　何ということなしに、一同がテレて、面を見合わせていると、米友は、「どうも見ていられねえよ、子が親の遺身を恋しがるというのは人情だからなあ」と言いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまに、忘れるか、忘れねえか、それは熊に聞いてみなけりゃわからねえ、眼前、こうして恋しがるのを人情として、見殺しにするのは罪だあな。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが、川上の処へ行つて来るつて云つたら、川上さん川上さんつて毎日社で顔を合はせてる人を、なんだつてさう恋しがるんでせうね、日曜ぐらゐ一日うちにいらつしつたつて損はないでせう。",
              "citation": {
                "source": "紙風船（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "まゝ親の下で苦む印度人孤児が親ある国を恋しがるものいはぬ口まで寒し旅の風旅の雨我真心を固めけり一六、ボンベイを発し、スエズに向かう　三十六年一月三日、ボンベイ港を発し、これよりインド洋に入る。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "今になってお父さんばかり恋しがるのよ。",
              "citation": {
                "source": "あじさい",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「士たる者が、安楽な家庭生活のみを恋しがるようでは、士の名に値しない。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常な生活には、非常な警戒心が要るから、人を恋しがるような余裕は薄らぐのに、きょうはあたりまえのところへ置かれているから、あたりまえの人情が湧くと見えます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時に人間を恋しがるのは好いが、その人が人殺しでもした事のある奴かも知れない。",
              "citation": {
                "source": "樺太脱獄記",
                "author": "コロレンコ　Vladimir Galaktionovick Korolenko",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い美しい奥さんの事だから、別れた亭主を恋しがるのは当り前である。",
              "citation": {
                "source": "鰐",
                "author": "ドストエウスキー　Fyodor Mikhailovich Dostoevski",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
