      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "this winter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今冬枯れで落葉に満ちては居りますが、広大な場所が、古い記憶に満たされて居る心持は、床しゅうございます。",
              "citation": {
                "source": "日記・書簡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今冬は冬と思われないほどよいお天気がつづいたので、日当りのよい斜面の雪はたいてい氷になっていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今冬は非常にお天気が悪かったためか、前穂北尾根には凍った箇所はなかったが、岩登りの下手な私がブレーキになったので、第三峰の左のチムニーで露営しなければならなかった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　　　　　　　＊（前略）余はふとした機会で思はしき手頃の土地見当りし故、今冬より満四ヶ年の契約にて借受け、試み旁々事業着手のことに致し候。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今冬の猟期には、猪は痩せほそり皮は骨の袋となるに違いない。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦闘準備なくしては今冬の無事越年を期しがたいというので、一番でッかいストーブを買ってきて十八畳の部屋へデンとそなえてやった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今冬の猟期には、猪は痩せほそり皮は骨の袋となるに違ひない。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "当局からは夏の初め頃、今冬の石炭は大丈夫配給する、道民を凍死させることは絶対にしないという声明が出た。",
              "citation": {
                "source": "琵琶湖の水",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍にねむる戦争画報を見てひた疲れ、ああ、このごと路の端にねむる人、命なり、赤き陽にこんこんとうち伏しぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大陸序曲路傍にねむる戰爭畫報を見てひた疲れ、ああ、このごと路の端にねむる人、命なり、赤き陽に、こんこんとうち伏しぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると、ちゃんと金のまりを口にくわえて、ぴょこんとうかび上がってきました。",
              "citation": {
                "source": "かえるの王さま",
                "author": "DER FROSCHKONIG ODER DER EISERNE HEINRICH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
