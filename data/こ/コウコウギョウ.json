        "examples": {
          "standard": [
            {
              "text": "国の経済成長は、主に鉱工業の発展によって支えられてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府は、地域の鉱工業を活性化させるための新たな政策を打ち出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "技術革新が、この地域の鉱工業に新たな機会をもたらしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ザール鉱工業地帯の掩護、特にオランダの中立尊重は、戦争持久のための経済的考慮によったのであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがロートリンゲンのザール鉱工業地帯のドイツ産業に対する価値は非常に高まっている。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦後、勤労大衆の苦労によってやっと鉱工業生産は戦前の三倍になりましたが、大衆の生活はどうなったか、社会不安は解消されたか、貧富の差は、いわゆる経済の二重構造はどうなったか、ほとんど解決されておりません。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通産省の官僚が発表したところによっても、貿易の自由化が行なわれれば、鉱工業の生産に従事する従業員は百三十七万人失業者が出るであろうといわれておるのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
