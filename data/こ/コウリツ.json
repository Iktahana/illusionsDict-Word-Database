    "definitions": [
      {
        "index": 1,
        "gloss": "public (institution)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "公立｜八雲小学校の事は大河でなければ竹箒一本買うことも決定るわけにゆかぬ次第。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "公立八雲小学校の事は大河でなければ竹箒一本買うことも決定るわけにゆかぬ次第。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "通常なら八年間は居座りを許されるところが、公立の愛知芸大では六年で追い出しを食らいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五歳にして学校の助教諭を托せられ、三円の給料を受けて子弟を訓導するの任に当り、日々勤務の傍ら、復習を名として、数十人の生徒を自宅に集め、学校の余科を教授して、生徒をして一年の内二階級の試験を受くることを得せしめしかば、大いに父兄の信頼を得て、一時はおさおさ公立学校を凌がんばかりの隆盛を致せり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「市立じゃないけれど、公立だよ」船頭さんは答えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ボーイ長の負傷の手当てをするために、室蘭公立病院へやっていただきたい、というのだそうでございます」「ボーイ長！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、今から室蘭の公立病院に行くからであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに公立病院があった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知らねえけど、どっかの貧乏ったらしい公立かなんかで、生徒指導でもやってたんじゃねえのか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうじゃなければ、近くの公立へいくか、もうすこし目鼻のついた私立にでもいってたはずだ」　高志は落ちついて、諭すようにしゃべっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時、いわゆる公立の小学校は麹町の元園町に女学校というのがあり、平河町に平河小学校というのがあって、その附近に住んでいる我々はどちらかの学校へ通学しなければならないのであった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "公立の学校よりも、私立の学校の方が、先生が物柔らかに親切に教えてくれるとかいう噂もあったが、わたしは私立へ行かないで公立へ通わせられた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "画の接吻４・２（夕）　サアゼントといへば、女優のエレン・テリイがマクベス夫人に扮装した、あの名高い画の作者だと知らぬものもないが、この画家がシヤ※ンヌやエドヰン・アベエなどと一緒に暮斯敦の公立図書館の装飾画を頼まれて、米国へ渡つた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は本家の方の家の世話をしたり、町で長く公立の病院長をしていて、金を拵えて村へ引っ込んでから、間もなく腐骨症の脚を切って死んだ親類の、妾と、独り取り残されたその祖母との家を見たりして日を暮していた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "（１）明治以前のわが国には現在のような公立学校はありませんでした。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年ばかり経つと、多くの公立学校が開設されました。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "官公立の神道教育施設は廃止されて公的補助を受ける教育機関が神道の宣伝をすることは止められた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、一九〇二年の教育条例第三部に規定せる地方教育官庁は、その管轄内における公立小学校に通学せる児童のため食事を給与するについてその必要と認むるところの処置を採りうる。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、（省略）　五、（省略）　六、公立小学校に職を求めつつある教師または現に職を奉じつつある教師は、この食事の給与に関し、またこれに要する費用の醵金に関し、その義務としてこれが監督または補助をなすことを要求され、またはこれが監督または補助に関与すべからずと要求さるることはない。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は区内の細かい学校が一かたまりになって、大きな公立小学校に対抗するので、源泉学校と染めた旗も出来上った。",
              "citation": {
                "source": "源泉小学校",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校は公立に改まって高等科が出来た。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯だ繁華な大通と官公立の建物とに少しの高壮な煉瓦家屋が散見せられる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに本書の如きは民間一個人の著書にして、その信不信をばまったく天下の公論に任じ、各人自発の信心をもってこれを読ましむるは、なお可なりといえども、いやしくも政府の撰に係るものを定めて教科書となし、官立・公立の中学校・師範学校等に用うるは、諭吉の服せざるところなり。",
              "citation": {
                "source": "読倫理教科書",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "公立劇場のない文明国は、世界に一つもないし、自治体たる都市の経営する非営利的劇場の設立は、今や、時代の趨勢である。",
              "citation": {
                "source": "演劇への入口",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　それはともかく、演劇、殊に映画の時代的役割を考へたら、流行風に云つても、文明国の面目上、官公立のアカデミイひとつないといふ法はないではないか。",
              "citation": {
                "source": "演劇アカデミイの問題",
                "author": "国立俳優学校の提唱",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この案の提唱者も恐らくは合流するであらうところの、国立（或は官公立）演劇映画専門学校の創設案を、先決的に考究せられんことを当局に希望する次第である。",
              "citation": {
                "source": "演劇アカデミイの問題",
                "author": "国立俳優学校の提唱",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は、皇帝を一九一七年に廃した記念日として、すべての官公立・私立がやすみで、街路は、ふだんの働き人で一杯だ。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
