    },
    "definitions": [
      {
        "index": 1,
        "gloss": "carriage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "扨、気持は、そこで一先づ安らかとなつたが、作品が熟してゆくといふことは、時日を要することであるし又、漸次のことであるから今分つたからといつて、すぐに今迄よりも好いものを書いてみせろと期待されても、六ヶ敷い。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "爛熟し、頽廢し、さうしてさびた揚句の果が、こんな閑寂にたどりついたので、私は、かへつて、このせまい裏路に、都大路を感ずるのである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "所がヴァニティの方が魂のことの方より少しゝか先に進まなかつたので、そして両方大きかつたので、或時期に至つて魂のことの方が先になつたのです、晩熟しました。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし裾野の所々に熟したオレンジの畑は美しく、また日本の南国に育った自分にはなつかしかった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分では、ただ頼みにする人、有難い人と思っている積りだが、心の底ではもう恋が成熟しきっている。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どうだ、やつぱりやまなしだよ、よく熟してゐる、いい匂ひだらう。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラの頬は、まるで熟した苹果のあかしのやうにうつくしくかゞやいて見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川下の向ふ岸に青く茂った大きな林が見え、その枝には熟してまっ赤に光る円い実がいっぱい、その林のまん中に高い高い三角標が立って、森の中からはオーケストラベルやジロフォンにまぢって何とも云へずきれいな音いろが、とけるやうに浸みるやうに風につれて流れて来るのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町はすっかりさっきの〔通〕りに下でたくさんの灯を綴ってはゐましたがその光はなんだかさっきよりは熟したといふ風でした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどもは熟したやうに睡ってゐます。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また渋味は、自然界にあっては不熟の味である場合が多いが、精神界にあってはしばしば円熟した趣味である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "北緯四十一度を越えても稲田の黄熟しているのに驚く。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが論理的に明瞭なものであるにかかわらず、使っている「国語」が世人に親しくないために、その国語に熟しない人には容易に食い付けない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その理由は第一こういう教育は官辺の影響のために本質的に出来にくいし、また頭の成熟しないものが政治上の事にたずさわるのは一体早過ぎるというのである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "就任当時は従来やりかけていた「水のジェットに対する電気の作用」などをやっていたが、そのうちに彼の頭の中では大規模の仕事の計画が熟しつつあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある人の話によると、落葉樹の葉の中で遅く発育したのがまだ十分成熟しないうちに早い霜に痛んでしまうと、それきり発育が止まって、コルク質の出来る間がなく、梢に枯れたまま淋しい趣を見せるという事である。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに從つて編輯の模樣も變るだらうが、その劃策は熟して來てゐる。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく真赤に熟したのを買ってきてくれい。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "高く炎がゆらめき、人聲が顫へ、こんぐらかつた歌が玻璃と燭光から生じ、拍子がおもむろに熟して、――遂に、舞踏が涌き上つた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "随つて、作風のしつくり落ち付いた、作的気分の十分熟しきつてゐる以前の諸作に比すれば、それ等は私の感銘からは可成り遠い作品だと云ふより外はない。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すればわれわれが、長い修業によって「象徴国の国語」に習熟して来たせいである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の熟したような色をしたその顔が、さもさも喜びに堪えないといったように、心の笑みを絞り出した表情をしている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早池峯山巓石絨脈なまぬるみ、　　　　　苔しろきさが巌にして、いはかゞみひそかに熟し、　　ブリューベル露はひかりぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴蘭の葉は熟して黄色に枯れその実は兎の赤めだま。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」タネリは云いながら黒く熟したこけももの間の小さなみちを砂はまに下りて来ました。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラの頬は、まるで熟した苹果のあかしのようにうつくしくかがやいて見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川下の向う岸に青く茂った大きな林が見え、その枝には熟してまっ赤に光る円い実がいっぱい、その林のまん中に高い高い三角標が立って、森の中からはオーケストラベルやジロフォンにまじって何とも云えずきれいな音いろが、とけるように浸みるように風につれて流れて来るのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ木さば保ご附くこなしだじゃぃ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから私たちにはまだ麦こなしの仕事が残っています。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦こなしは芒がえらえらからだに入って大へんつらい仕事です。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
