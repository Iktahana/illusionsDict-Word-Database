        "examples": {
          "standard": [
            {
              "text": "この地域では、隣接する二つの交戦団体が長年にわたり対立を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "国連は、交戦団体の間の平和的解決を促進するための仲介を試みた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼らは、交戦団体の一方から秘密裏に武器供与を受けていると疑われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "幕末において、幕府方と朝廷方とは、国際法上の二つの交戦団体となった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中立宣言があるために、徳川方と朝廷方とは、国際法上の「交戦団体」となったのである。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際法上、二者は交戦団体であるから、対等に扱われなければならない。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
