    "definitions": [
      {
        "index": 1,
        "gloss": "language",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――言葉は既に無益なるのみ。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等の頭は言葉でガラガラになり、奴等の心は根も葉もないのだ。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが滑稽だとみえないばかりに、花の言葉はみなしやらくさい。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は弱いので、　悲しみに出遇ふごとに自分が支へきれずに、　生活を言葉に換へてしまひます。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに猶、諸君も嫌ひではない冗舌は、此処に十分に按配されてをり、直き直きに抽象語を以てしなければ、かの「意味がない」と云つて嘯く、平盤な心情の人達のためには、十分哲学的学術的な言葉も此処には見出されるのである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ断片的な云ひ方であるけれども、一寸ピカソの言葉に同感を表してみたかつたまでである。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "終りに、何かの御参考にまで、イェーツの言葉を記して置かう。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何故だか萩原氏を思ふたびに、次のポオロの言葉をくちずさみたくなる。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは抽象的でも具体的でもない、又あらゆる習慣、あらゆる思索の便宜に作られた言葉、あらゆる名辞以前にあるものだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学といふものが、凡そ文字を知つてゐれば、誰にも読むことが出来るといふことからして、余りに文士志望者が容易に生じるといつた現状だが、文学を仕事とするからには、※ルレーヌの言葉を以てすれば、「自分の通り道にあつたものだけを読むだけ」の努力では何にもならぬ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉が如何に現実にとつてまどろつこしいものであるかは、諸君も先刻御承知であらうし、恐らく諸君が考へてゐられる以上にそれは事実だ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し、語る言葉はなかつたかもしれぬ、歌ふべきことがあつたかもしれぬが、それは今の事ではない。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ彼には対象を名命し形容するすべての言葉と、その正確な眼との間の隙ばかりが気になる。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉の量から言へば無論それはさうなのである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　だつてねえ………あたし「奥さん」だとか、「妻」だとか、「お嫁」だとかつて言葉が嫌なのよ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ日本の詩壇に自由詩形が紹介されて以来、真に日本言葉のなつかしいリズムを捉へて、之を我我の情緒の中に生かしたものは、室生以前には一人も無かつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはむやみと生硬の漢語や、俗悪で不自然な言葉のアクセントや、中学生じみた幼稚な興奮や、およそさうした類の低能な感傷的表情を、むやみと鼓張した態度で一本調子に並べたてられて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに私共の求めてゐたものは、もつと鮮新で、もつと自由で、そしてもつとしんみりとした情熱をもつた、純日本言葉の美しい音楽であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "（愛の詩集の読者は、だれしもさうした言葉の味覚を感得するであらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに、ああした魔力ある彼の言葉は、彼の不思議な天賦の性情から、自然と湧き出づる人格のリズムであつて、断じて彼以外の者の追蹤を許さない秘密であらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが日本人の抒情的な言葉で、あきらめと呼ばれるものであることさえ、おそらくヘルンは知ったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "オババサンニ可愛イ言葉。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも手紙の終りに『オババサマニヨロシク』とか『オババサマニ可愛イ言葉』とか書いている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『野蛮人』という言葉は、彼の語藻において『西洋人』と同字義であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族の人々は、それを『ヘルンさん言葉』と呼んで面白がった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "化物屋敷の一件以来、おそらくは『面白いの家』という言葉などが、一種の反語として家族中に流行し、すべての不潔の家、陰気な家などを指す代名詞になったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしヘルンの奇妙な言葉を、真に完全に理解し得たものは、彼の妻より外にはなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合に、妻もまたヘルンさんの言葉を使って応答した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『内のパパとママとは、だれにも解らない不思議な言葉でだれにも解らない神秘のことを話している』と、学校へ行ってる男の子が、自慢らしく仲間の子供に語ったほど、それは奇妙な別世界の会話であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に眼を見合すだけで、一切の意味が了解される恋人同士の間には、普通の意味での言葉や会話は、全く必要がないのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
