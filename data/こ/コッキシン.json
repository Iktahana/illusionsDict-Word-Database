    "definitions": [
      {
        "index": 1,
        "gloss": "spirit of self-denial",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
