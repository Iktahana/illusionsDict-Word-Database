        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "興亜院当局はこれに対し、国家連合理論を否定するものでなく、肇国の精神に反し皇国の主権を晦冥ならしむる虞あるものを許さぬ意味であると釈明したとの事である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "興亜院当局の言は当然しかあるべきである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかに、あちらにいたときは物資が欠乏しているということを頻りにきかされていたところ、帰って見たら物資は店頭にあふれていて、これでこそ興亜の大業に進む国の姿であると愉快に思ったという意味が語られていた。",
              "citation": {
                "source": "地の塩文学の塩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖戦第三年、興亜新春、万歳万々歳。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "興亜奉公日、関東震災記念日、二百十日、――等には極めて意義ふかい日であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "人、猫、鼠、小鳥“一草一人”俗仙人三月一日　曇、興亜奉公日を忘るゝなかれ。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "興亜奉公日、酒はないけれど――それがあたりまへで――ありがたくも朝食は純日本米だつた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月一日　半晴半曇、興亜奉公日。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "興亜奉公日、その一週年記念日。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百十日、興亜奉公日一周年記念日、関東震災記念日。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "興亜奉公日、国勢調査日、防空綜合訓練第一日。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "興亜の精神は我がちの我身専一を男に教えることではなかった筈である。",
              "citation": {
                "source": "女性週評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）今日は興亜奉公日、第二回目、恥ずかしいことだが、私はちょっぴりアルコールを摂取して旅情をまぎらした。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十七年川内幼稚園園歌西の薩摩の城いくつ廻ぐりめぐりて大海へ川内川の出でてゆく姿を下にのぞむ山神代の樟の群立ちの影いと深く清らなる御垣の内を許されて我れ等は学び我れ等は遊ぶ戦の後に大事なは愛の心と人も知る愛の御社の大神よ深き教を垂れ賜ひ大き興亜の御業に我れ等も与らしめ給へ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "揉んで揉んで揉みぬいた末、落ちつくといふのが、文化としての風俗生成の普通の過程であらうと思ふが、さういふ暢気なことを云つてゐられないのが、興亜の聖業などゝいふ言葉の生れた、今の場合なのである。",
              "citation": {
                "source": "風俗の非道徳性",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かから譲り受けたといふ今の住ひは、代金もまだ払つてないといふ噂だが、門の表札の下に「興亜経済研究所」と筆太に書いた看板が何時の間にか掛けられ、ぞろりとした細君の厚化粧と不思議な対象をなしてゐた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、久保君……」　と、田丸は、五人の中の一人が、興亜経済研究所長、久保鉄三の息子であることにやつと気がついた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "久保鉄三、興亜経済研究所長、自称「政界の影武者」は、七月の炎天の下で一週間、未教育兵として生れて始めての猛訓練を受け、毎晩細君に腰をさすらせた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この委員会を構成した諸官庁は企画院、内務省、商工省、情報局を中心に、陸軍省、海軍省、外務省、文部省、拓務省が参加し、その後官庁機構の変遷に伴って、農商務省、軍需省、興亜院、対満事務局、大東亜省、警視庁、運輸通信省等ほとんどあらゆる諸官庁の局長級が委員となって参画した。",
              "citation": {
                "source": "日本出版協会論",
                "author": "嶋中雄作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれが翼賛会の興亜本部にいるとき、あいつがオットー大使の後釜になってやってきた……終戦直後、一時、熱海の万平ホテルに、かくまっておいたこともあるんだ」「日銀関係では、歓迎会をやったりしているが、なんだか、うろんな人物だな。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこでは興亜書房とか云って一方で赤本出しているのですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "興亜奉公日で、コーヒーも休み、宿の紅茶を飲む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "初日、興亜奉公日の三時開き。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "テスト一回やり、「興亜のぞき眼鏡」上山雅輔作のモダン小咄を放送。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は興亜記念日とあって、東京では色々と自粛でやかましいらしい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "興亜紀念日で酒は無し、ホテ・グリで食事して十二時に帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっこうあたたまらない。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこうあっちに、畝々した線が引張ってあるだろう、これはね、ここから飛騨の高山の方へ行ったんだよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人はだれでもこうありたいものですよ。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "筺底から出して見ると、其手紙にはこうある。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
