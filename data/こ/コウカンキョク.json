    "definitions": [
      {
        "index": 1,
        "gloss": "(telephone) exchange",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
