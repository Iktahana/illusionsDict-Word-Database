        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女はもう30歳なのに、子供顔で、いつも若く見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの俳優は、老けても子供顔で、愛らしい印象を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供顔のせいで、時々学生に間違えられることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この子供顔の探偵は職業を面白がっていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の面長で下ぶくれの子供顔は、むしろ服装に負けて居る。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あまり綺羅びやかに最上級に洒落て居るので却って平凡に見える幾十組かが場の大部分を占めて居るので、慾一方にかかって居る樺色の老婆や、子供顔のうぶな青年が却って目立つ。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
