    "definitions": [
      {
        "index": 1,
        "gloss": "small hawk or falcon (used for hunting)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
