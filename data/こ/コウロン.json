          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人々の話柄は作物である、山林である、土地である、此無限の富源より如何にして黄金を握み出すべきかである、彼等の或者は罎詰の酒を傾けて高論し、或者は煙草をくゆらして談笑して居る。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに寫經生の書だなどゝいふ高論もあるけれども、唐代には書が盛んで、寫生までが能書で、後世の及ぶ所でないとは支那人の定論である。",
              "citation": {
                "source": "北派の書論",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋風俗や学問のお高論をお伺いなさい。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評とは何ぞや、夫の中に愛憎の念を挾み、妬評、諛評、悪言｜罵詈を逞くし、若しくは放言高論高く自ら標し、己を尊拝して他人を卑しみ、胸中自家の主義を定めて人を上下するが如き者奚ぞ批評の消息を解せん。",
              "citation": {
                "source": "明治文学史",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は婦人のごとき温柔の面貌に、いささか紅潮をたたえて、底知れぬ図太き胆大心小の立居振舞い、唯々として『御高論御尤なり』と言う。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして世上往々政治をもって一の玩弄物としてその経験をば烟火のごとく愉快なるものとなし、その問題をば詩人の花鳥風月における、小説家が人情の変態におけると一般の思いをなし、飄忽変化もって放言高論を逞しゅうし、もって愚妄無識の人民を籠絡せんとするがごときものあり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし知己のために一言して併せて高論を乞う。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れが曾て東京府會の議員たるや、例に依りて放言高論動もすれば議場を惱殺せしめんとす然るに彼れは常に立憲大臣の心を以て、堂々たる議論を試みんとするの癖ありを抑へむとしたるに拘らず、彼れは傲然として飽くまで沼間と頡頏せむとせり※以て其抱負の凡ならざるを諒す可し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れが曾て東京府会の議員たるや、例に依りて放言高論動もすれば議場を悩殺せしめんとす然るに彼れは常に立憲大臣の心を以て、堂々たる議論を試みんとするの癖ありを抑へむとしたるに拘らず、彼れは傲然として飽くまで沼間と頡頏せむとせり※以て其抱負の凡ならざるを諒す可し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその高論の、いまだ狹隘なる婦人の心裏に入らざるのみ。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度人は語学の天才で、雄弁・高論をやる、その上印度思想の幽遠なところを滔滔としゃべり立てたので、基教の外、世界に何の宗教もないと思って居たものにとっては、千年の夢一時に醒めたと云う塩梅であったに違いない。",
              "citation": {
                "source": "釈宗演師を語る",
                "author": "鈴木大拙",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにをそれ以上いま駈引きをする必要があろうか」　彼の高論に、荀※も服し、諸人もなるほどと感心した。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず高論を示されい」「古言にもある。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねがわくは丞相の軍が、よく彼を帰服せしめて、恩を感じ、徳になつき、蜀軍が都へ引き揚げた後も、永劫に王化はあとに遺って、二度と背くことのないようにありたいものと存じます」　孔明は長嘆して、君の高論はまさに自分の思うところと一致したものだと云い、斜めならず彼の才志を愛でた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おまえは　大へん　けんか　こうろん、とんちもんどうが　すきだそうだが、ほんとか？",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、おしょうさま、わたしは　けんかも　こうろんも　すきでは　ありません。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「では、けんか　こうろんは　すきじゃろ？",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまは　石「おまえは　いま　けんか　こうろんは　せぬ、と　いったな。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな　やつを　あいてに　けんか　こうろん　すれば、こちらが　ばかに　なる。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが何分にも御めい／＼に御りょうけんがちがいますことゝて、なか／＼まとまりがつきませんで、引きつゞき毎日のように夜おそくまでおあつまりなされ、ときにはけんかこうろんにも及ばれましたときいております。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
