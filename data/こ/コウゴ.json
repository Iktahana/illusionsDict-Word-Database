[
  {
    "uuid": "d158c577-0247-5b88-8eb5-0a2f8fd49b16",
    "entry": "交互",
    "reading": {
      "primary": "こうご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
