    "definitions": [
      {
        "index": 1,
        "gloss": "to fold (one's) arms",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　と沈着に、腕を拱く。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞼を掛けて、朱を灌ぐ、――二合｜壜は、帽子とともに倒れていた――そして、しかと腕を拱く。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、」　とただ、腕を拱く。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……画家　（徐に腕を拱く）さあ……あの菊屋と野田屋へ向って渡る渡月橋とか云うのを渡りますと、欄干に、長い棹に、蓑を掛けたのが立ててあります。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに寶の山に入つて手を拱くとは、このことですよ。",
              "citation": {
                "source": "滑川畔にて",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも腕を拱く、とはこのことと思われた。",
              "citation": {
                "source": "夢幻泡影",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "――少し考へて見る」　平次は高々と腕を拱くばかりです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "彦徳の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も考へてくれ」　平次は深々と腕を拱くのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も考えてくれ」　平次は深々と腕を拱くのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "――少し考えてみる」　平次は高々と腕を拱くばかりです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "彦徳の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳の穴や肛門までも丁寧に檢査して見ましたが、どうしても、病氣で死んだか、引付けたまゝ死んだとしか思はれない樣子に、平次もさすがに腕を拱くばかりです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "怪傳白い鼠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「仏壇の中にある、懐ろ鏡を、林彦三郎が持って行くはずはない」「なるほど」　平次が深々と腕を拱くと、それを真似たように、八五郎ももっともらしく腕を組むのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "懐ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私にも見当は付きません、が、何でも六十三は今日だね――と言ったようで」「フーム」　銭形平次も腕を拱くばかり、この判じ物は容易に解けそうもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "黒い巾着",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の夜を選つてやるにしても、振り返つて曲者の姿が見えないといふのは變ぢやないか」　平次は四方の景色を眺め乍ら、土手の上で腕などを拱くのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "髷切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「佛壇の中にある、懷ろ鏡を、林彦三郎が持つて行く筈はない」「成程」　平次が深々と腕を拱くと、それを眞似たやうに、八五郎も尤もらしく腕を組むのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "懷ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "六間以上ある綱の上――大搖れに搖れる小艶のこめかみに、下から吹矢を射るやうな名人は、江戸中に二人とあるわけはない――」　ガラツ八は高々と腕を拱くのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "吹矢の紅",
                "note": "青空文庫"
              }
            },
            {
              "text": "六間以上ある綱の上――大揺れに揺れる小艶のこめかみに、下から吹矢を射るような名人は、江戸中に二人とあるわけはない――」　ガラッ八は高々と腕を拱くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "吹矢の紅",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳の穴や肛門までも丁寧に検査してみましたが、どうしても、病気で死んだか、引付けたまま死んだとしか思われない様子に、平次もさすがに腕を拱くばかりです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪伝白い鼠",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の夜を選ってやるにしても、振り返って曲者の姿が見えないというのは変じゃないか」　平次は四方の景色を眺め乍ら、土手の上で腕などを拱くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "髷切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうだとすれば、弱き者は腕を拱くこと以外に何をなし得よう？",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶望して腕を拱く折、始終を物陰で見届けていた、これも三勇士の一人である尾張の某という侍が出てきて、小柄で腕の鬱血をとりのぞいてくれる。",
              "citation": {
                "source": "西隣塾記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁の名探偵達も、「こんな狐につままれた様な事件は初めてだ」と腕を拱くばかりだ。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "赧土色の水を見降して、直ぐに斯う濁つてしまやアがるんでね――などとＡが腕をこまねくと、「駄目だ、すつかりおぢけがついてしまやアがつてもう此方が一ト足入れると、キヤツ等の方で先に暴れて濁してしまふんだもの！",
              "citation": {
                "source": "雪景色",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに作者｜俄に惑うて思案｜投首煙管銜へて腕こまねくのみ。",
              "citation": {
                "source": "矢はずぐさ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と　さけびながら　手を　こまねく　タビサ。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
