        "examples": {
          "standard": [
            {
              "text": "有名な経済学者に講演を依頼したが、講演料が非常に高かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はボランティア活動の一環として、講演料なしで全国を回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "講演料は、参加者の数と講師の経験によって決まります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "講演料は、最初にちやんときめておかれるといゝ。",
              "citation": {
                "source": "椎茸と雄弁",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "色眼鏡　　講演料は、まさかこつちから請求もできませんし……。",
              "citation": {
                "source": "椎茸と雄弁",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿稼ぎの方では、私などもすれつからしになつてゐて、碌でもない原稿で報酬を得ても感謝する氣なんか無くなつてゐるが、今度講演料を手にすると、あんな下らないおしやべりで報酬を貰つていゝものであらうかと、子供らしく感ぜられたのである。",
              "citation": {
                "source": "私も講演をした",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で先生はあの地震の時の講演料は最低二十円最高千円、原稿料と合わせて××円になったと話されたがその金額は今覚えていない。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
