[
  {
    "uuid": "ca3ed7ae-ee68-5ff8-bd7f-bf775e318a31",
    "entry": "幸運",
    "reading": {
      "primary": "こううん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good luck",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最初に軒端の廻燈籠と梧桐に天の河を配した裏絵を出したら幸運にそれが当選した。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名を付けると先代以来の幸運に障るというような迷信から子も孫も屋号を付けなかったためだそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食慾不振のおかげで、御馳走がまずく喰われるという幸運を持合せたのであろう。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその素質を持つて生れたといふことが、何よりも天與の惠まれた幸運なのだ。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸運は、ノラは幸福であった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が謹直な技術家で、而も着實周到な處世家であるのと大體幸運に惠まれた家であるために、過去の家庭生活は極めて平穩無事で、多くの作家達が持つやうな世間的、人間的辛酸は殆ど知らなかつた。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸運悲運のけじめは勿論あるとしても、勝つ者が勝つには必ず當｜然の理由がある。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろかえってそうであったことが私には幸運であったと思っている。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生え抜きの上田市民で丁度この日他行のためにこの祇園祭の珍しい行事に逢わなかった人もあるであろうから一生におそらくただ一度この町へ来合わせて丁度偶然この七十年目の行事に出くわした自分等はよほどな幸運に恵まれたものだと思っても別に不都合はない訳である。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思いうる幸運な学者は、その仕事が自分で見て完全になるのを待って安心してこれを発表する事ができる。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは、幸運のしっぽを、たしかにつかんだ人のように、あわてずに、進んでいきました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果が良かった場合は、稀な幸運としても、大抵の場合は結婚成績が予想外に不良なもので、例えば配偶者の性質、人格、趣味などが自分と全く融け合わないものであったり、配偶者の境遇に自分が到底同化出来ないことが判ったとき、その女はどうなるでしょうか（これは男が嫁を貰う場合としても同じことです）。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、世の中の萬事は左樣幸運く行くかどうだか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの間は日出雄少年も私も互に顏を見合せては此不思議なる幸運をよろこび、大佐等の懇切なる待遇を感謝しつゝ、いろ／＼と物語つて居つたが、何時か十｜數日以來の烈しき疲勞の爲めに、知らず／＼深き夢に落ちた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復五日の豫定が、其二日目には首尾よく歸終に就くやうになつたのは、非常な幸運である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "此幸運に乘じて、吾等は温順に昨日の道を皈つたならば、明日の今頃には再び海岸の櫻木大佐の家に達し、此旅行も恙なく終るのであるが、人間は兎角いろ／＼な冐險がやつて見たい者だ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "君等の幸運を祝します。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帰途、電車の中にてつくづく思うに、われは今日まで差したる不幸にも出で逢わず、よろず順調に過ぎゆきて、身の幸運を誇りいたるに、測らずも英一の死によりて限りなき苦痛を味うこととなりたり。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨の山国の風雪の夕、この一軒家に於て稀有の悲劇を演じたる俳優の中で、僅に生残っているのは幸運の冬子｜一人に過ぎぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もうすっかり諦めてはいたのですが、一番最後の日になって、こんなに滅法すばらしく晴れ渡ったのを見ると、私はどうも今日こそはひどく奇蹟的な幸運に恵まれそうな気持を感じました。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人たちはアメリカへ行けば、幸運が、夢みている幸運が、花を開くものと思っていたのでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから赤々と輝く暁の光は、ふたたび訪れてくるであろう幸運の太陽の福音のように思われたのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまにも死にそうなナイチンゲールの歌声を聞いても、それは悪い予言者ではなく、幸運の告知者のように聞えたのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみの幸運にたいして、わたしはひじょうに、よろこんでいる。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一知の幸運の獲得手段はドコまでも陰性で消極的であった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸運の星の下に生れた人は、夜の夢の中でも幸福であり、惡しき星の下に生れた人は、夢の中でさへも、二重にまた不幸である。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この思ひがけない幸運に氣のついたとき、船の人人は思つた。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた（皮肉なことには）いやしくも易者を訪ふほどのすべての人は、過去にも現在にも不運であり、それ故にまた將來の幸運さへも、概して豫想できないところの人々である。",
              "citation": {
                "source": "易者の哲理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが人々は、それを預め自覺することによつて、來るべき災難を未然に防ぎ、大厄を小厄にし、幸運のチャンスを捉へ、すべてに於て將來を賢明に用意し得る」と。",
              "citation": {
                "source": "易者の哲理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
