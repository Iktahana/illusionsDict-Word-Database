    "definitions": [
      {
        "index": 1,
        "gloss": "tree whose leaves turn red in autumn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
