        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ニューヨークでも、ロンドンでも、高さ数十階を誇る高層ビルが、雪害のために、頻々として、灰の塊のように崩れだした。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "決然と分岐する鋪装道路や高層ビルの一｜聯が、その上に展がる茜色の水々しい空が、突然、彼に壮烈な世界を投げかける。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "決然と分岐する舗装道路や高層ビルの一連が、その上に展がる茜色の水々しい空が、突然、彼に壮烈な世界を投げかける。",
              "citation": {
                "source": "火の唇",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝都は、今ちょうど暮れたばかりで、高層ビルジングのあちこちの窓には、電灯の火が明かるくかがやき、その下で、いそがしい仕事をかたずけるため居残りをしている社員たちの姿さえ、はっきり見られた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこで下町と呼ぶ商業区域を、何のあてもなく歩いていた七月のはじめ、高層ビルの間から遠くの空に白い雲がむくむくと立っているのに気がついたとたん、私は日本郵船の支店へ行って横浜までの船室を予約した。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "街なかに入れば仰ぎみる、三十二階建ての高層ビル。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッピー・ヴァレーの素晴らしい環境を強制的に捨てさせ、こんな高層ビルに追いこむなんて精神的な殺人行為だ、と彼女は演説した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "超高層ビルというやつが、何本も建っている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "高層ビルに窓がいくつもあり、不規則に黄色く、明かりが輝いている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
