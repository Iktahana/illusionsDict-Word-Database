    "definitions": [
      {
        "index": 1,
        "gloss": "Koshi (former province located in present-day Fukui, Ishikawa, Toyama and Niigata prefectures; later split into Echizen, Etchū, and Echigo)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "民族的悲運に陥って居る国民が、生理的に優越国民を凌ぎ得ない事は、彼等の悲しめる魂の所産でございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩くと、決心すれば、一昨年の夏、私は、上越国境の三国峠を越えて、越後湯沢へ下駄履きのまま、出る事のできる男である）。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "浩平の話によると、長野から三四時間の旅程で、すでに越後の温泉ではあるが、信越国境を越えてまもない山のどん底に、松之山温泉といふものがある。",
              "citation": {
                "source": "逃げたい心",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊野から飯山鉄道に乗り換へて、信越国境をすぎたところに、外丸といふ重畳の山また山にかこまれた山底の村落があつて、一行はそこに下車した。",
              "citation": {
                "source": "逃げたい心",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、奥利根の上越国境の山から出てくる猟人が毎年、最も多く狸の皮を持ってくるところを見ると、やはり上州が狸の名産地であると思うと言うのである。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上越国境を信州の方へ、遠く走っているのは三国峠の連山だ。",
              "citation": {
                "source": "利根の尺鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚野川は、上越国境の茂倉岳から西へ続く谷川岳と万太郎山の裏山の谷間に源を発している。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上に、上越国境を遮る六千五百尺の中ヶ岳が、屏風のように乗りだしていて、それから北方へ八海山、越後駒ヶ岳が雄偉の座を構えて続いている。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の方、上越国境の山々はまだ冬の姿であるらしい。",
              "citation": {
                "source": "楢の若葉",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上越国境の山々が初冬の薄雪を装い、北風に落葉が渦巻いて流れの白泡を彩り、鶺鴒の足跡が玉石の面に凍てるようになれば、谷川の水は指先を切るほどに冷たくなる。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、私がかつて世に紹介したことのある飛越国境に近いおわら節が有名な八尾町の奥、神通川の支流室牧川の鮎に似て、良質の岩石から湧く麗水に育ったかを思わせた。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、手近の例が上越国境即ち白根火山の北方、信濃の渋峠を地点として東方へ走り岩代、上野、下野の三国境付近の尾瀬沼の東でつきる山脈の裏表は完全に、日本海へ注ぐ川と太平洋へ注ぐ川との分水嶺をなしている。",
              "citation": {
                "source": "水と骨",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が家の近くを、奥深い上越国境大利根岳から流れ出て、岩を削って迸り、関東平野を帯のように百里あまりも悠々と旅してゆく利根川のことはここに説明するまでもない。",
              "citation": {
                "source": "水の遍路",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅間山麓六里ヶ原から上越国境の山狩にも、銃を舁いで二人は歩き廻った。",
              "citation": {
                "source": "葵原夫人の鯛釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は秋が立つと、上越国境を越えて新潟県の魚野川へ鮎を求めて友釣の旅に出た。",
              "citation": {
                "source": "秋の鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幼いとき父に伴われて上越国境の四万温泉の奥の渓流へも、磯部鉱泉の碓氷川へも、足尾銅山の方から流れてくる渡良瀬川へも釣りに行った。",
              "citation": {
                "source": "利根川の鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "子持と小野子の二つの山は赤城の山裾が西へ長く伸びて、そこに上越国境から奔下する利根の激流を対岸に渡った空間に静座しているのである。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏とはいえど水源である上越国境の大水上山の雪を解かして流れくる水温は、摂氏の十度前後と思わんばかりに低い。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、奥利根の上越国境の山から出てくる猟人が毎年、最も数多い狸の皮を持つてくるところを見ると、やはり上州が狸の名産地であると思ふと言ふのである。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　上越国境は、渓流魚の巣であるかも知れない。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山から飛越国境の蟹寺までの間、二十里ばかり、宮川は奔馬のように急勾配の渓底を駆け下っている。",
              "citation": {
                "source": "雪代山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "北方には榛名山、上越国境の谷川岳、武尊山、赤城山。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その秋、母の許しを得て上越国境の四万温泉に遊び、十日間ばかりの田村茂三郎旅館に滞在して沼之上のわが家へ帰ってきた。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "裕八郎は、四万温泉から帰ってきてからというもの、いつも秋がくると三角州の果てに続く利根の河原に出て北の方を望み、榛名山と小野子山との峡に、遙かに綿々として聳える上越国境の国越えの三国連山の初雪に手を翳し、なにか口に低く唱えている姿を、幾人も村人が見て知っていた。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤谷川は、標高僅かに六千五百尺内外であるけれど、登山者の生命を奪うことで知られている上、上越国境の谷川岳と、その西に隣し万太郎山との間に割り込んだ深渓から源を発している水量豊富な、そして恐ろしく高い胸壁の底を縫って出る人跡を寄せつけぬ渓流である。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上越国境を、東から西へ縦走する三国山脈、この山脈の東端から南会津の方へ向かって続く万太郎山、谷川岳、茂倉岳、朝日岳、兎岳、牛ヶ岳、八海山、中の岳、駒ヶ岳、銀山平など、奥上州の裏側に並ぶ越後国南魚沼の山地には、昔から野猿の大群が棲んでいた。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、上信越国境の山々で五、六十の熊の穴を知っています。",
              "citation": {
                "source": "熊狩名人",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上越国境の清水山塊に位置する仙倉山は、三条の並行した残雪に依りて三之字之頭なる名があり、北麓｜土樽村の人はその一条ずつ消え去るに従って、農事の季節を卜するのは面白い、即ち三之字で苗代、二之字で豆蒔き、一之字で田植と言いならわされている。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚お蓮華温泉又は四ツ家の先の森上から信越国境上に在る俗称白馬の大池（実は乗鞍の大池）に出で、小蓮華山を経て登る道も開かれた。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　最後に上越国境の法師温泉。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
