[
  {
    "uuid": "3ef22c45-d611-5462-95d1-f632d9acab11",
    "entry": "講演会",
    "reading": {
      "primary": "こうえんかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
