    "definitions": [
      {
        "index": 1,
        "gloss": "fist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "郷土の名を、わが空拳にて日本全国にひろめ、その郷土の名誉を一身に荷わんとする意気込みが無ければ、とても自身の生れた所の名を、家の屋号になど、出来るものではありません。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今擲ぐらうか今擲ぐらうかと思つて拳固まで固めてゐたんだけれど、罰するのは神様の務めで人間のすることぢやないと思つたからギユーギユーいつて我慢したんだつたが……」　停留場に来るまでにＳ子の従兄に当る男が彼にこんなことを言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大泥醉の粹背肌、弓手を拳で懷中に蓄へ、右手を延ばして輪を畫くと、手頸をぐいと上げて少し反身のかたち。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『なぐれ』『たため』『しめろ』雜然たる叫聲の中、殺氣は既に滿ち渡つて、氣早の若者は行成横合から飛び出して、思ひ切り芳の天窓を擲つた、續いて何處よりともなく、拳の雨は彼の頭上に降り注いだのである。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という罪のない絵だろうとしばらく眺めていたが、名状の出来ぬ暗愁が胸にこみあげて来て、外套のかくしに入れたままの拳を握りしめて強く下唇をかんだ。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷土の名を、わが空拳にて日本全國にひろめ、その郷土の榮譽を一身に荷はんとする意氣込みが無ければ、とても自身の生れた所の名を、家の屋號になど、出來るものではありません。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよかなしきわが心いはれもなくて拳する誰をか責むることかある？",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氷河で思い出したが、私が桑港にいるとき、一九二四年九月十八日の夕、新聞の号外売りが、声高く「ラッセン火山大爆裂、シャスタ氷河大融解」と、大の字｜尽くしで呼んでいるので、耳寄りに思って買って見ると、いかにもシャスタ山の、氷河融解、大洪水来と、拳大の活字で見出しがついている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方の手で拳を固く拵えて、彼の部厚な胸を殴った。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お寒いのに、なぜ、おとり申上げた村里の宿へお出でになりませんの」　翁は頑是ない子供が、てれながら駄々を捏ねるように、掌に拳を突き当てつつ俯向き勝ちにいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薑、口｜疼く　男は、叫ぶと猛然、女の代りに鹿に飛びかかって、毛深く逞しい拳を振り上げて、丁々と撃った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが小さな、可愛らしい、夏夜の妖精の握り拳とでも云った恰好をしている。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方太陽が没してもまだ空のあかりが強い間はこの拳は堅くしっかりと握りしめられているが、ちょっと眼を放していてやや薄暗くなりかけた頃に見ると、もうすべての花は一遍に開き切っているのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカン・レビューにはそういう古典的な意味での音楽などはない代りに、オリンピックのグラウンドや拳闘のリンクに見らるる活力の鼓動と本能の羽搏きのようなものをいくらかでも感ずることが出来るのであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ロス対マクラーニンの拳闘　この試合は十五回の立合の後までどちらも一度もよろけたり倒れかかるようなことはなかった。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は拳闘のことは何も知らないが、しかしこの判定がやはり少し変に思われた。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し演壇をあちこち歩き廻ったり、拳固を振りまわす労力はこの外であるのは勿論の事だ。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地ノ果テヲ行ク、参照スベシ×月十五日「儂の拳骨は鉄砲の弾丸だ　武士の情けだ」　モンモンの兵、鉢巻をするあり。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして拳鬪試合に飛び入りをすることが、書いてあるのだが、鬪志といふものがさうした亂暴な荒療治を必要とするものかどうか、それが主人公の稱してゐる如く唯物論的なものであるかどうかはしばらくおくとして、作品の重心がまるで劍劇のやうな立廻りに置かれてゐるといふことは馬鹿々々しい氣を起させる。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "血まみれになつた手綱をしつかり拳に握りしめたまま。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "拳闘場では印度人の闘士が負ける度に歓声があがる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋々々の壁の伝説のニデイアの像のかけられた下を快楽のために奴隷にされたフィリッピン人の拳闘家が、床下を犬のように這いながらときどき兇暴なうなり声を出した。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾組かの拳銃隊が街の要所々々を発砲し、欧米人によって築かれた南京路のペーブメントは要撃された。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は虹のように地面に這入った彼の腕から拳銃をとると、虚空に一発打ち放して花火のように彼方に舞下りる弾丸を見つめながら、――何故死なねばならないのだ！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳独秀は虹のように地面に這入った彼の腕から拳銃をとると、虚空に一発打ち放して花火のように彼方に舞い下りる弾丸を見つめながら、――何故死なねばならないのだ！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "狼狽した女記者の太い拳が彼女の眼前につきだされた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しおれた女の足音が遠のくと、ミサコは女記者が青バスに太い拳をさしあげるのを見た。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には握つた拳で机の面を叩きつけた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時など、拳銃を握って、軍医を追っかけまわしたことがあった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黝き菅藻の袍はねて、　　　　叩きそだたく封介に、雲ののろしはとゞろきて、　　こぶしの花もけむるなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
