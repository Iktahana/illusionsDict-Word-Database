      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(your) perusal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いさぎよく御高覧に供する次第だ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "テイラー博士「実は本日ここへ試作のテイクロトロンを持参して、諸君の高覧に供したいと思っていたところ、出掛けるときまでに間に合わなかった」「それは残念だ」「形だけでも見たい」と叫ぶ者あり。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて先般御注意被下候護国寺境内石燈燈碑文此の程やうやく改彫を終り候間御序の節御高覧奉希上候。",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "『津軽藩日記』によると、元禄九年十一月に津軽外浜母衣月の蝦夷チヱヘカインが「代々持来候」陶器の花入を津軽侯に献上し、「高覧に入れ奉り候」ところ、「御機嫌の御事に御座候」とある。",
              "citation": {
                "source": "「あばた」も「えくぼ」、「えくぼ」も「あばた」",
                "author": "――日本石器時代終末期問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ今論文校閲中にて熟読のひまも無之ただ御高覧のために御廻し致候。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう中日はすんでいたが、演らないよりはまし、名誉挽回この機にありと、┌──────────────┐│　　　　　　今晩より御高覧に｜│新作道具噺　　　　　　　　　｜│　　　　　　奉供候　圓朝敬白｜└──────────────┘　こうした立看板を、麗々しく久保本の表へ飾らせた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なにか、奇妙なものを見せるということだったが……」　顎十郎はニヤリと笑って、「ですから、これよりおもむろにご高覧に供します。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "紙凧",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞘を触れられた侍　一つ、その兼定に鞘当てされた某の刀も、御列座の高覧に預かりたいもので、ははははは。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁船とともに腹を砂浜にのしあげ、子を返して賜わらぬならば、いっそひと思いにこの身も殺してくれといわんばかり、折よく通りかかりました当小屋の六兵衛どの、哀れと思い買いとりて母子もろとも江戸へ連れかえり、かくはご高覧に供しまする次第。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "両国の大鯨",
                "note": "青空文庫"
              }
            },
            {
              "text": "また沮授、郭図、高覧、張※、于瓊などという家臣も、みな天下に知られた名士である。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "河北軍からは、それと見て、「われ高覧なるを知らずや」と、槍をひねって向ってくる。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "高覧も来れ」　彼は、俄に呼んで、その二将に精兵をさずけ、兵糧隊を奇襲した敵の退路をたって殲滅しろと命じた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちかまえていた高覧、張※の二将は、「賊は小勢だぞ。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "高覧は仰天して、「これは及ばん」と、戦わずして逃げ去り、張※も、「むだに命は捨てられん」とばかり、逃げ鞭たたいて逸走してしまった。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "部将｜張※は、「すぐに烏巣の急を救わん」　とあせり立ち、高覧はそれに反対して、「むしろ、曹操の本陣、官渡の留守を衝いて、彼の帰るところをなからしめん」と主張した。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、確たる自信もなく、「張※、高覧のふたりは、共に五千騎をひっさげて、官渡の敵陣を衝け。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "張※、高覧も、官渡へ攻めかかって、手痛い敗北を喫していたのである。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてその張※、高覧が大敗してここへ帰ってきたら、必定、罪を問われるかも知れない。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「張※、高覧の軍も、今暁、官渡において、惨敗を喫しましたが、ふたりは元から、味方を売って曹操に降らんという二心が見えていました。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかになんでも、ああもろく小勢の敵に敗れるわけはありません」　袁紹は、真っ蒼になって、「よしっ、立ち帰ってきたら、必ず彼らの罪を正さねばならん」　と、いうのを聞くと、郭図はひそかに、人をやって、張※、高覧がひき揚げてくる途中、「しばし、本陣に還るのは、見合わせられい。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "高覧は、突然剣を払って、馬上の伝令を斬り落した。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると高覧は、つよくかぶりを振って、「われら、豈、死を待つべけんや。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "降将張※を、偏将軍都亭侯に、高覧を同じく偏将軍｜東莱侯に封じ、「なお、将来の大を期し給え」と、励ましたから、両将の感激したことはいうまでもない。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、高覧」　と、いうような声々が潮のように耳近く聞かれた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝南の残兵千余をつれて、まず関羽や、張飛と合流してから、再起の計を立てようものと、そこから三、四里ほど山伝いに行くと、敵の高覧、張※の二隊が、忽然、林の中から紅の旗を振って突撃してきた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "劉辟は、高覧と戦って、一｜戟のもとに斬り落され、趙雲は高覧へ飛びかかって、一突きに、高覧を刺し殺した。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
