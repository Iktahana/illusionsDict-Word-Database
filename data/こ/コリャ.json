        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "え、都合によると、こりゃ危いかも知れねえぞ）　だが、彼はそこでへまを踏むわけには行かなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ偉いわねえ」「おら貰うべえ」四郎は得意な顔つきをした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふーむ、こりゃ人間の相性とそっくりだねえ」　彼女の文化に対する驚異は一層深くなった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ」　「や、こりゃどうも」　「あら随分破けてんですねえ」　「え」　「縫いましょうか」　「いや、どうも済みません」　お静、糸と針を取りに立つ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛が、　「清水の次郎長さんとか仰言いましたが、お前さん、やくざ渡世の人だろう」　「そうだ、爺つあん」　お静戻って来て　「はい、縫いますわ」　「あ、こりゃどうも済まない」　源兵衛が、　「失礼だが、此処は堅気の年寄りの住居だ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次ジロッと其れを一瞥して「こりゃ何だ？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度持合せていたＭＣＣかなんかを進呈してマッチをかしてやったら、「や、こりゃあ有難う有難う」と何遍もふり返っては繰返しながら行過ぎた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「息子は相変らず精出して稼いでいるんですか」「ええ、あの人は感心によく稼ぎますよ」「こりゃあ此処だけの話だが……」と、熊蔵は声を低めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃあいけない、とうとう本降りになって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃあまあ、一体どうしたもんでございましょう」　お亀は声をふるわせて、いかにも途方に暮れているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勿論、あなたの方にもいろいろの御都合もございましょうが、いくら音信不通のお約束でも、せめて御奉公の御屋敷様の御名前だけでも伺って置きたいと存じますのが、こりゃあ親の人情でございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　清吉は、こういう想像を走らせながら、こりゃ本当にあることかもしれないぞ、或は、今、現に妻がこうやっているかもしれない。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃ、この下に一度かくして、また取り出したんだな。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）といって茶店の女に、（この水はこりゃ井戸のでござりますか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こちらの道はこりゃどこへ行くので、）といって売薬の入った左手の坂を尋ねて見た。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ貴僧には足駄では無理でございましたかしら、宜しくば草履とお取交え申しましょう。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてさて迷惑な、こりゃ目の前で黄色蛇の旨煮か、腹籠の猿の蒸焼か、災難が軽うても、赤蛙の干物を大口にしゃぶるであろうと、そっと見ていると、片手に椀を持ちながら掴出したのは老沢庵。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、行燈がまた薄暗くなって参ったようじゃが、恐らくこりゃ白痴のせいじゃて。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……また、こりゃお亡くなんなすった父様に代って、一説法せにゃならん。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と独りで極めて、もじつく女房を台所へ追立てながら、「織さん、鰯のぬただ、こりゃ御存じの通り、他国にはない味です。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「解るまい、こりゃおそらく解るまいて。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃ、いけない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ、もう駄目かも知れない。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近くになりますと、お父さんにあたるがん郎がへるが、「こりゃ、むすめ、むこどのはあの三人の中のどれぢゃ。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近くになりますと、お父さんにあたるがん郎がえるが、「こりゃ、むすめ、むこどのはあの三人の中のどれじゃ。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウム、こりゃあおもしろいな」と言ってしきりに感心していた。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飲めないことがあるものか、始終晩酌の御相伴はやっているくせに」「じゃそれで一杯いただくわ」　渡瀬はこりゃと思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃこうしちゃいられないぞ」……渡瀬の頭に咄嗟に浮んだのはこれだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おっかぶせるように）じつは君にはたびたび迷惑をかけているのですまないんだが、またすっかり行きつまっちゃったもんだから……西山か星野でもいるとどうにかさせるんだが（こりゃ少しうそがすぎたかなと思ったが園がその言葉には無関心らしく見えるのですぐ追っかけて）ちょうどいないもんだから切羽つまったのさ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時始めてそれに気がつくと、人見は話の糸目を探りあてたように思って、落着きを見せて畳の上の金を蟇口にしまいこみながら、「こりゃいよいよ冬が来るんだよ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
