          "literary": [
            {
              "text": "焦がれ死にするくれえに片思いの娘っ子たちが幾人いるかわからねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは焦がれ死にゝ死ぬまでも片思ひに思うて思ひ抜いて見せる。",
              "citation": {
                "source": "斑鳩物語",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おい、姐や、丸煮を二人前に、鬼菱を一升持って来まっせ、急ぎだ急ぎだ、焦がれ死にをしそうなのが、ここに二人いる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            }
          ]
        }
