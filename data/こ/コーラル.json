        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ローヤル・コーラル・ソサイティは『ハレルヤ・コーラス』（ＪＢ三三）と『天地創造』の「もろもろの天の神の栄えを顕し」「御業は成れり」（ＪＢ五四）を入れている。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "□ポリドール系　ドルトムンド市立音楽学校聖歌隊の『グレゴリアン・コーラル』（三〇〇五二―三）がある。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このレコードにパテルポルナー少年聖歌隊の『グレゴリアン・コーラル』（一〇三四〇）が一枚付いて日本では出たように思う。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じくポリドールにあるトゥルヌミールが演奏したフランクの『コーラル＝イ短調』（四〇四七四―五）その他を記しておく。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪ヲパーマネントニシ、耳ニイヤリングヲ下ゲ、唇ヲコーラル・ピンクダノパール・ピンクダノコーヒー・ブラウンダノニ塗リ、眉ニ黛、瞼ニアイ・シャドウヲ着ケ、フォールス・アイラッシュデ附ケ睫ヲ着ケ、ソレデモ足リナイデマスカラーデ睫ヲ長ク見セヨウトスル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
