    "definitions": [
      {
        "index": 1,
        "gloss": "waste-water container (tea ceremony)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
