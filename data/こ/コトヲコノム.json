[
  {
    "uuid": "533feea7-7855-5773-82da-715f5078db18",
    "entry": "ことを好む",
    "reading": {
      "primary": "ことをこのむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-マ行"
      ],
