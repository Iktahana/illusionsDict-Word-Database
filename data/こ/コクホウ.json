    "definitions": [
      {
        "index": 1,
        "gloss": "national treasure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "考えてみると、僕たちだって、小さい時からお婆さんに連れられてお寺参りをしたり、またお葬式や法要の度毎に坊さんのお経を聞き、また国宝の仏像を見て歩いたりしているが、さて、仏教とはどんな宗教かと外国の人に改って聞かれたら、百人の中の九十九人は、へどもどするに違いないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで書いて筆を擱くつもりでいたら、その翌日人に誘われて国宝展覧会を観に行った。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さて、毛越寺では、運慶の作と称うる仁王尊をはじめ、数ある国宝を巡覧せしめる。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "文楽は小屋が焼け人形衣裳が焼け、松竹会長の白井さんの邸宅や紋下の古靱太夫の邸宅にあった文献一切も失われてしまったので、もう文楽は亡びてしまうものと危まれていたが、白井さんや古靱太夫はじめ文楽関係者は罹炎に屈せず、直ちにこの国宝芸術の復活に乗りだしたのである。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘前城と、最勝院の五重塔とは、国宝に指定せられてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八師団は国宝だつて言はれてゐるぢやないか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺の薬師堂は、国宝に指定せられてゐるといふ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに入口の板の間が広く、柱が大きくて、ありゃ国宝ものですよ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処に役行者自作の像があって、国宝に指定せられているが、其の寺院に名音と云う老尼がいた。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、聖徳太子が自ら刻んだという如意輪観音の像だけは、寺院の近くに、今にその堂宇を残しているのであるが、最近、それが聖徳太子の作ではなく運慶の作であることが鑑定され、近く国宝に編入されるという噂である。",
              "citation": {
                "source": "荒雄川のほとり",
                "author": "――私の郷土を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ惜しむべきは、和歌山城近くに松生院とて建築が国宝になっておる木造の寺がある。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに何の心得なき姦民やエセ神職の私利のため神林は伐られ、社地は勝手に掘られ、古塚は発掘され、取る物さえ取れば跡は全く壊りおわるより、国宝ともなるべく、学者の研究を要する古物珍品不断失われ、たまたまその道の人の手に入るも出所が知れぬゆえ、学術上の研究にさしたる功なきこと多し。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすりゃ落語家も、人間国宝に成れるてえもんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な細工をすると、国宝｜鋳潰しという重罪に問われます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　がってんだとばかりにしりからげて走りだしたものでしたから、もうここまで道がひらけていけば、あとは、右門の国宝ともいうべき、鋭利｜犀抜なる手腕のさえを待つばかりとなりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾とあの人とはきっと知らずにすんだでしょうし、国宝的な経済学者を、犬ころか何かのように簡単に殺さずにすんだでしょうし、妾も、あんな有頂天の幸福も経験しなかっただろうかわり、こんな、堪えきれない苦しみを背負わされずにもすんだのでしょう。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風な絵は国宝だよ」そう言って見てゆく旦那様もありました。",
              "citation": {
                "source": "最初の悲哀",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一｜隅を照らすものを国宝となす」と伝教大師はいっていますが、この国宝こそ、今日最も要求されているのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "通貨をみだりに地金に変えることは、国宝鋳潰しの重罪に相当するのであるが、すでに金蔵を破るほどの重罪犯人であれば、そのくらいの事は憚る筈もない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "大発見12・15（夕）　近頃その筋の手で、大和唐招提寺にある国宝の修繕をするに就いて、偶然にもそこの金堂で素晴しい大発見をした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンの人差指８・13サンデー毎日　大和薬師寺の境内から発見されて、国宝の一つとなつてゐる吉祥天女の絵像は、今では日本の美術史の上で、なくてはならない代表作となつてゐるが、あの天女の指は、不思議なことに右左とも六本づつある。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "花見の折の諸大名の短冊の綴込みを見たことだけは、今でも覚えてゐるが古画のうちには国宝もあつたやうである。",
              "citation": {
                "source": "佗しい放浪の旅",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名であったり、国宝であったりしても美しくない美術品もある。",
              "citation": {
                "source": "国宝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府や文部委員会が、こんどの議会で現実に解決する能力のないこんにちの教育問題から逃げる楯として、国宝再認識問題を過度に利用しないようにわれわれは監視しなければならない。",
              "citation": {
                "source": "国宝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の「国宝」はあわれな歴史をもっている。",
              "citation": {
                "source": "国宝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそから教えられた日本美術の価値におどろいて、「国宝」をこしらえたのはいいが、「国宝」という封印だけがかたくされて日々の実際に適切な国家的な保護をうけていない「国宝」たちのきょうの運命こそ危機にある。",
              "citation": {
                "source": "国宝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
