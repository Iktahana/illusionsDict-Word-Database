[
  {
    "uuid": "68dd2883-a926-529b-9739-39f14956fd1d",
    "entry": "交尾",
    "reading": {
      "primary": "こうび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "copulation (among animals)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "杉山発情午後交尾さした。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷車で餌を買いに行ったり、小屋の掃除をしたり、交尾期が来ると、掛け合わして仔豚を作ることを考えたり、毎日、そんなことで日を暮した。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは日光のなかでは交尾することを忘れない。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は猫の交尾を見たことがあるがそれはこんなものではない。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼らは交尾した。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "交尾期にあるかとんぼが部屋の中に幾匹も飛び込んで来ます。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年の花どきが来て、雄魚たちの胸鰭を中心に交尾期を現す追星が春の宵空のように潤った目を開いた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝展の入選畫帳を父の本棚から持ち出しては、その中にひそめられた白い畫に頬をほてらせて眺めいつたり、私の飼つてゐたひとつがひの兎にしばしば交尾させ、その雄兎の脊中をこんもりと丸くする容姿に胸をときめかせたり、そんなことで私はこらへてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度満貫のスリルを味わってしまえば、もう交尾を終った昆虫のように、緊張は去り、ヒロポンの切れ目にも似た薄汚い粉だらけのような黄色い倦怠が来ていたのだろうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊「種馬の交尾でも見に行った方がよかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と生真面目になって、「種馬の交尾をないしょで見せたいといってるがね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "実いうと折角Ａ君が種馬の交尾を見せるというのを断ったくらいなんだからね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄大な自然の中で、奔放な種馬が跳躍し交尾し歓喜する壮観は、それは稀に見るすばらしさだろうとも思える。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鱒は清渓に生れて、荒海に出で、もとの清渓に戻りて交尾し終れば雄直に死し、雌も間もなく死す。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、「口まがり」を追ひかけると必ず一羽の雄※が背後から駆けついて交尾するのであつた。",
              "citation": {
                "source": "池のまはり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近ラッドレー附近の一種馬場に於て飼育せられし一｜牝馬は、今より三年以前に見世物用の斑馬と交尾して一匹の混血児を生み、飼主をして奇利を博せしめし事あり。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間街角で犬が交尾してゐた。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "雌山羊だけ一頭もらつて行つても交尾といふやうな厄介なこともあるし、それに何よりも、子供の時から自分の手で育てて見たいといふ氣持が強かつたのである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の構内に転がつてゐる物は、蜥蜴の交尾んだのでも鄭重に眼鏡を通して見るが、大学以外の物はみんな眼鏡越しに見る事に定めてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "△赤と黒との接触を観察した、赤い蝶と黒い蝶との交尾行動！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の交尾するところを研究する動物学者だって、虫以外の万事までにその態度を応用する勇気はないでしょう。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、日の出ないうちに、おれは南瓜の花の人工交尾なんかやるんだ。",
              "citation": {
                "source": "倒れた花瓶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　鶏の交尾してる小さな焼物。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大連』は全く交尾期のついた馬みたいに荷馬車を蹴飛ばして、シベリヤの曠野を突走りかねない量見を抱いているらしかった。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "傲然と君臨する雄の胸の羽は、交尾を繰り返すためにすり切れている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、交尾期の雄犬が、その鋭い嗅覚で雌犬の存在を知るように、行手では、どの男もどの男も顔をあげて彼女を迎えた。",
              "citation": {
                "source": "罠を跳び越える女",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちのと交尾わせると、きっといい仔が出来ますわ」　だが老嬢はプセットをしかと抱きしめ、顰めっ面をして拒ねつけた。",
              "citation": {
                "source": "老嬢と猫",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは、君長は、二人の童男に鹿の毛皮を着せて、交尾の真似をさせていた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の感動もなく、昼間から敷き放しの蒲団に二人は寄りそつて、こほろぎの交尾のやうな、はかない習慣に落ちてしまふのである。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男鹿がその威力を現すのは何といっても秋の交尾期だ。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
