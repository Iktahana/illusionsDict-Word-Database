[
  {
    "uuid": "894c8dc1-9cb0-5afa-ba74-79fff597e877",
    "entry": "小冠者",
    "reading": {
      "primary": "こかんじゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
