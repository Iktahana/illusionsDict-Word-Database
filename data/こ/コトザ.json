        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "明くる日、帰宅せられた時はなかなかの混雑でしたが、少しの合間に赤い袖無しを著て、ちょこちょこと座敷へ出て、「御無事でおめでとう」と、丁寧に挨拶をなさいました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "２人とも息苦しくなるまで長いこと座っていた。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんに気の強いお人とは、源さま、おまはんのことざます」　そんな下品なことは言いませんが、ぐっと恨みをこめて見上げるまなざしには、まさに千｜鈞の重みが加わって、大象をさえつなぐといわれる女髪一筋、伊賀の若様、起つに起てない。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寒いことざえ、凍えてうっ死んじあうべ――この寒い水ん中をなあ」　時は初秋とはいえ、北地は寒い。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しることざうに迄とって食ったので、ねむい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日劇地下の蛇の目ですしをつまみ、三ますでしることざうにを食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
