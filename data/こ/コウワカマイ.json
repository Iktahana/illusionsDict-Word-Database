    "definitions": [
      {
        "index": 1,
        "gloss": "style of recitative dance popular during the Muromachi period (often with a military theme)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは怪霊雑記にある話で、幸若舞の家元になった幸若八郎と云うのが、京都へ登って往く途中、木曽路で出会った出来事であった。",
              "citation": {
                "source": "人面瘡物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「未熟な芸を御所望とならば、今宵は朝まで御覧に入れましょう」　八郎は其の夜終夜病人の前で幸若舞を舞うて見せた。",
              "citation": {
                "source": "人面瘡物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした事実を尚深く遡って考えると、能が出来る迄には雅楽、幸若舞、田楽、何々舞、何々狂言なぞいう、能楽の前身とも云うべきものが非常に発達していたらしい。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば平曲から出た説教節や幸若舞曲風の要素が取入れられて、單純な物語の多少劇化したものをテキストに作りあげて、之れに依つて徐々に複雜な演出を試みたのであらうと思はれる。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八島」は幸若舞に出てゐるのが典型に近いものと思ふが、其他のものにも、同様なものがぼつ／＼頭を出して来る。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ形が、幸若舞の盛んだつた室町時代から江戸時代の初めにかけての人の心に適つてゐたのである。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八島」は幸若舞では大事なもので、又同時に幸若舞の盛んになつた一つの原因でもある。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸若舞が盛んになると、その台本も沢山出来るが、その僅かな昔の台本に溯ると、最大切なものとして現れて来るのが「八島」である。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸若舞の流祖といはれる桃井直詮は、もと叡山の喝食で、草子類に直ぐ節をつけて語るのが非常に上手であつたと言ふ。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸若舞は多く絵詞を読み上げてゐる。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は小さな原因で此を言ふ位なら、寧、幸若舞からした「八島」の勢力の大きさを語りたい。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "能楽・幸若舞との類似点が、此翁・三番叟よりも主な処は、若い衆の舞ひだけに、能でいへば四番目物である現在物と、殆、同じ様なものが沢山ある。",
              "citation": {
                "source": "根子の番楽・金砂の田楽",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体、幸若舞ひから出てゐるのだ。",
              "citation": {
                "source": "根子の番楽・金砂の田楽",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国の神事舞には、「立謡」を原則とするものがあつた様で、幸若舞などはとりわけ目につくものだ。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山三郎の表芸は、恐らく「立謡」を主要部とし、反閇流の舞台漫歩の形を持つた幸若舞にあつたものと思ふ。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "言はゞ赤穂一件・太平記、其に曾我（幸若舞）、この三つが絡み合つてゐる訣である。",
              "citation": {
                "source": "由良助の成立",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　幸若舞ひの影響能楽のあいが、間のつなぎでなく、前の舞台の説明であるとすると、能楽には既に一番の中に二つの副演出が重つてゐる。",
              "citation": {
                "source": "能楽に於ける「わき」の意義",
                "author": "「翁の発生」の終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸若舞ひの影響を受けて出来たものだからであらう。",
              "citation": {
                "source": "能楽に於ける「わき」の意義",
                "author": "「翁の発生」の終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "能楽の新作が、幸若舞ひの影響を受けた適切な例は、修羅ものである。",
              "citation": {
                "source": "能楽に於ける「わき」の意義",
                "author": "「翁の発生」の終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に幸若舞系統から出た江戸歌舞妓では大・少の舞以外にも、とりわけ「少」の勢力が増して来た。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の曲舞では、室町に興った「幸若舞」なる一流が最栄えた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い武家の無条件で娯めるのは、幸若舞であつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方盲僧の説経なる軍記類は、同じ陰陽配下の目あきの幸若舞などの影響から素語りの傾向を発達させた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の歌舞妓の本筋は、まづ幸若舞で、上方のものは念仏踊りを基礎とした浮世物まねや、組み踊りを混へてゐる。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "其蒲生に仕へたのは、幸若舞などによつて召されて居たらしく、早歌をお国に伝授したらしい。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "四江戸発生の舞踊がすべて、をどりと言はれて居るのは、其発生が皆、歌舞妓芝居にあつて、幸若舞系統なることは、絶対に否定せられてゐたからである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "其点でも、曲舞出の幸若舞よりも低く見られたのです。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は、幸若舞の最盛んな時代だつたので、舞ひと言へば幸若舞の事を言ふのであつた。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
