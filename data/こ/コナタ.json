  {
    "uuid": "0f159e52-d29c-55a8-a56b-3cb86e2ab80f",
    "entry": "此方",
    "reading": {
      "primary": "こなた",
      "alternatives": [
        "こんた"
      ],
      "is_heteronym": false
    },
    "grammar": {
