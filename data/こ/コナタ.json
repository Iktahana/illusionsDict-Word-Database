    },
    "definitions": [
      {
        "index": 1,
        "gloss": "this way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その沖の可なり此方と思はれるあたりに、海の中からマストがのぞいてゐる。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あら今お隣の窓から、若い男の人が此方みて嗤つてたわ、あたしたちの話を聞きやしなかつたかしら。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……フン、そりや彼奴の云ふのにも本当はある――」「けれどもだ、……けれどもそれでは此方が困る……」　そこへ、「何方にも一理ある場合は親の方を子は聴入れなくつちやァ不可ない」といふ、常々云つてる言葉が飜然浮ぶと、彼は解決を得た喜びに敷居の辺りを意気ある眼で睨んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他のことなら此方から訊いたつてロク／＼答へない男が、自分の好きなことならあんなに訊かない先に答へるんだ」と兄は思つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――耕二はそのガシヤガシヤの手を襖の把手に手を掛けた儘、此方を向いて口をムツチリさせてゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "見舞の人達が此方を見てゐたので私は大変気持が悪かつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は病室の人達が此方の話を聞いてゐると思つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれたちは内に用事があるわけぢやなし、此方が考へる程……」「いつたい何の用で来たの」　彼は分り切つてるのに、母をねぎらひたい気持から訊ねてみた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年くらい通って真面目に働いていたが、自分の骨折って書いたものが一度も紙上へ載らないので此方も出てしまった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方のレンズを覘いてみると西洋の美しい街の大通りが浮き上がって見える。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植半の屋根に止れる鳶二羽相対してさながら瓦にて造れるようなるを瓦じゃ鳥じゃと云ううち左なる一羽嘲るがごとく此方を向きたるに皆々どっと笑う。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側の水楼に坐して此方を見る老人のあればきっと中風よとはよき見立てと竹村はやせば皆々笑う。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々の視線一度に此方へ向かえば新郎のパナマ帽もうつむきける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要太郎は舌打ちをしたと云う風であったが此方を見て高く笑うた。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には可愛い眼で此方を覗いてゐるのもある。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○百貨店○○支店の一行は和服が多く、此方は藝者を揚げて三絃の音を響かせて居るが、肝心の本職の藝者の歌謠の節※はしが大分危なつかしく、寧ろ御客の中に一人いゝ聲を出すのが居て、それがやゝもすると外れかゝる調子を引戻して居るのは面白い。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのしぶきが散つて此方の頭上に降りかゝるのはそれ程潔癖でないつもりの自分にも餘り愉快でない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も戸外と云つても唯庭をあちらから見たり此方から見たり、或は二階か近所の屋根や樹の梢を見た處など、もしこれが本當の畫家ならば始めからてんで相手にしないやうなものを、無理に拾ひ出し、切り取つては畫布に塗り込むのであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝の此方に畫架を据ゑて對岸の榎と赤い倉庫と薄との三角形を主題にして描き始めた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方だと炭の棒の消費が少ない。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月寒の牧場へ行ったら、羊がみんな此方を向いて珍しそうにまじまじと人の顔を見た。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざとらしさが少しけ抜けたせいか、それとも此方の眼が少し教育されて来たせいかもしれない。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "訪問者のないのは此方から逃げてゐるからで、自分で孤獨を求めてゐるやうなものである。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでゐて不思議なことには、翌日はもうちやんと此方の理窟を知り、議論以上の眞理をすつかり會得してゐるのである。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「まッ、此方へ通せ」　「へッ」　と児分去る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の石松つあんの御宅は此方で御座いますね。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また無理にこんな本を讀んでしまひ度くもないので、回想の甘美な氣持に堪へなくなつて來ると遠慮なく頁から眼を離し、かういふ人間のものを讀んでゐるとどこまで此方の素朴な經驗の世界が侵されてしまふかわからないと思ふとまた本を閉ぢてしまふのだ。",
              "citation": {
                "source": "「親近」と「拒絶」",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中谷がやることになつてゐたこの批評を、中谷が小説をかいたため書けなかつたといふので、編輯の淺沼から此方へ廻された。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから此方まだ快くならない。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると軌道に沿ふて三｜人、田舍者が小田原の城下へ出るといふ旅裝、赤く見えるのは娘の、白く見えるのは老母の、からげた腰も頑丈らしいのは老父さんで、人車の過ぎゆくのを避ける積りで立つて此方を向いて居る。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
