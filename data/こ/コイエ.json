    "definitions": [
      {
        "index": 1,
        "gloss": "small and simple home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鶯のあちこちとするや小家がち「籬落」という題がつけてある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛蟻とぶや富士の裾野の小家より　広茫たる平原の向うに、地平をぬいて富士が見える。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山麓の小家の周囲を、夏の羽蟻が飛んでるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨や御豆の小家の寝覚がち「五月雨や大河を前に家二軒」という句は、蕪村の名句として一般に定評されているけれども、この句はそれと類想して、もっとちがった情趣が深い。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に夏の部で評釈した句「五月雨や御豆の小家の寝醒めがち」も、どこか色っぽい人情を帯びてはいるが、詩情の本質においてやはりこれらの句と共通している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水鳥や朝飯早き小家がち　川沿いの町によく見る景趣である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば鶯のあちこちとするや小家がち　　　蕪村春の海ひねもすのたりのたり哉　　　蕪村　の如く、「あちこちとするや」の語韻から、鶯のチョコチョコとする動作を音象し、「のたりのたり」の音調から春の海の悠々とした印象を現わしているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関車がすさまじい音をして小家の向うを出て来た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しも事情が許すなら、私は此の廣い平坦な高臺の森影の一つに小さな小家を建てゝ、一週の中の或一日を其處に過したいと思つたりした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　大家は大家で小家は小家、そして中家は中家で世紀はめぐる。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小家あちこち、このあたりに住むは、かたいというものなりとぞ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "川を隔てゝ霞の蒸したる一ト村の奥に尽頭に咲き誇りたるを見たる、谷に臨みて春風ゆるく駐まるべき崖下などの小家包みて賑はしく咲けるを見たる、いづれをかしき趣あらぬは無し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも事情が許すなら、私はこの広い平坦な高台の森影の一つに小さな小家を建てて、一週のうちのある一日をそこに過ごしたいと思ったりした。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どことも覚えない大溝が通っていて小橋がまばらに架り、火事の焼跡に休業の小さい劇場の建物が一つ黝み、河沿いの青白い道には燐光を放つ虫のようにひしゃげた小家が並んでいる。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この川沿は、どこもかしこも、蘆が生えてあるなれど、私が小家のまわりには、また多う茂ってござる。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたと、これに空想の前途を遮られて、驚いて心付くと、赤楝蛇のあとを過ぎて、機を織る婦人の小家も通り越していたのであった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇しあだ浪いとまなみ、がらがらと石を捲いて、空ざまに駈け上る、崖の小家の正面に、胡坐を総六とも名づけつびょう、造りつけた親仁のように、どっかりと臀を据え、山から射す日に日向ぼっこ、海に向うて朝から晩、暮れると、浪枕、やあ、ころりとせ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の小家は餘寒未だ相去り申さずだつたが――お宅は來客がくびすを接しておびたゞしい。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所によると、町が野になつた處もあるのに、覺えて一面に蘆が茂つた池の縁は、右手にその蘆の丈ばかりの小家が十ウばかり數を並べて、蘆で組んだ簾も疎に、揃つて野草も生えぬ露出の背戸である。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、たとへば薄青い樹の蔭の清らかなる境内を、左に、右には村の小家に添つて、流れがさら／＼と畔を走る。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、さきに、伊達の停車場を出て間もなく踏切を越して、しばらくして、一二軒、村の小家の前に、細い流に一際茂つて丈ののびたのがあつて、すつと露を上げて薄手ながら、ふつくりとした眞新しい蕾を一つ見た。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と云いながら、学円の顔をみまもり、小家の内を指し、うつむいてほろりとする。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百合、いきを切って、褄もはらはらと遁げ帰り、小家の内に駈入り、隠る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小家がちょっと両側に続いて、うんどん、お煮染、御酒などの店もあった。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ溝川にも、井戸端にも、傾いた軒、崩れた壁の小家にさえ、大抵皆、菖蒲、杜若を植えていた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いにしへは七堂伽藍、雲に聳え候が、今は唯麓の小家二三のみ。",
              "citation": {
                "source": "逗子より",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――薄りと廂を包む小家の、紫の煙の中も繞れば、低く裏山の根にかかった、一刷灰色の靄の間も通る。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――水上の奥になるほど、樹の枝に、茅葺の屋根が掛って、蓑虫が塒したような小家がちの、それも三つが二つ、やがて一つ、窓の明も射さず、水を離れた夕炊の煙ばかり、細く沖で救を呼ぶ白旗のように、風のまにまに打靡く。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側は、右のその物置に、ただ戸障子を繋合わせた小家続き。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年はポケットにつっこんでいた手を、そのまま二、三ど、前後にゆすり、人なつこいえみをうかべた。",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
