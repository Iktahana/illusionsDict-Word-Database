[
  {
    "uuid": "14151dbb-1622-5337-9d7f-93b71ee918c6",
    "entry": "行路病者",
    "reading": {
      "primary": "こうろびょうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
