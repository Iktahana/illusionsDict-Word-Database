        "examples": {
          "standard": [
            {
              "text": "17世紀のイギリスでは、航海法によって植民地貿易が厳しく規制されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アメリカ独立革命の遠因の一つとして、航海法による経済的制約が挙げられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の授業で、航海法がイギリスの海上覇権に果たした役割を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だから航海法は適用されなかった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間陸を見なかったと云っているのを見ると、岸伝いの航海法から脱却して広い大洋に出る自信が出来ているのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
