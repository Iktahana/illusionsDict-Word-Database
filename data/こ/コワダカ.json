    "definitions": [
      {
        "index": 1,
        "gloss": "loud (of a voice)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
