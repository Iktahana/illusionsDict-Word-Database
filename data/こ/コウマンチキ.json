        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "畜生こんな高慢ちきな奴。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "観念だけの生活で、無意味な、高慢ちきの知ったかぶりなんて、軽蔑、軽蔑。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年齢からいっても、また性質からいっても、豹一にとってはどんな女性も苦手だったが、ことにこのどうやら高慢ちきそうな（――おまけに美しいと来ている――）村口多鶴子のような女は体がふるえるほど苦手だと思われた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その高慢ちきな口調に、私のいらだちは収まりそうにないので、話題を変えるのが賢明だと判断した。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものことだ、性格は高慢ちきで自分本位、脳内へ新情報を書き入れるのは迅速にして正確だが、仕入れ先にはたいていお礼の言葉もない。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜見たらそれ程でもなかつたが、昼間見ると実に気障な奴だね、さうしてどうだ、あの高慢ちきの面は！",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "高慢ちきなＴ女史は姉のやうな態度で、屹度栄子を愛しようとするであらう。",
              "citation": {
                "source": "女流作家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らさまに言うと、その時私は君をいやに高慢ちきな若者だと思った。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな高慢ちきな乱暴な人わたしきらいですわ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番高慢ちきで忌味なのは法学士華尾高楠だ子。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「倭文子さんが、この覚悟なら、京子が逆さまになったって、恐くないぞ、見事に倭文子さんと結婚してあの高慢ちきな京子を、ギャフンといわせてやろう。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はしばしば京子の七三に結った高慢ちきな額際を思いきりなぐりつけたいような衝動を感じた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんな高慢ちきの画かきだって、ちっとは困るだろうて。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の高慢ちきな人払ひ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだか高慢ちきな娘だこと」と、母はあくる日そう言った。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今自分の実験室に入つて来た女の、高慢ちきな顔を見ると、例の癖がむつくり頭を持ち上げて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕は、そのどこかしら高慢ちきなのが、気に食わなかった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に高慢ちきな女だわ！",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼の話は高慢ちきで多少の不愉快さはあったようだが、私はその芸に対する落語家らしい彼の執着と意気に対して、随分愛好していたものだった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "お幸は冬子を高慢ちきだと言った。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "折々は学者のうちに高慢ちきな者があると、学者そのものを嫌い、進んでは学問そのものをすら罪する傾向がある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつもいつも、いやに落ちつき払ってさ、高慢ちきに取りすまして、天下で、わたしほど、武術も、芸も、すぐれたものはあるまいと、いわんばかりの顔をしておいでの、雪之丞さん、わちきは、刃ものを取っては、おまはんの敵であろうはずはないけれど、今夜は別だと思ってるのですよ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "返事をしなくても人造人間は、私を高慢ちきな奴だと腹も立てず、また返事をしてやっても、悦ぶわけではない。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方高慢ちきな釣道楽で、自分の釣る所をおれに見せびらかす積かなんかで誘つたに違ない。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方｜高慢ちきな釣道楽で、自分の釣るところをおれに見せびらかすつもりかなんかで誘ったに違いない。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳を見ろ、と私は彼女の高慢ちきな鼻に対して云ってやった。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに高慢ちきに私を抱きすくめてくれてもいゝのだ。",
              "citation": {
                "source": "花火",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　高慢ちきな鼻をつんと反らして、凹んだ眼で睥み返してくるのを、私はつと身を起して引捉え、膝の上に抱き上げてやった。",
              "citation": {
                "source": "悪夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お清は立上って、高慢ちきにつんと空を仰いだ。",
              "citation": {
                "source": "黒点",
                "author": "――或る青年の「回想記」の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがですよ、ふたりがあんまり腹いっぱい食べすぎたせいか、それとも、高慢ちきになってしまったためか、そのへんのところはよくわかりませんけど、とにかく、ふたりとも歩いてかえるのがいやになってしまったのです。",
              "citation": {
                "source": "ならずもの",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
