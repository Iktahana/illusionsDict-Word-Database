[
  {
    "uuid": "e538b0a9-2250-5a86-b15b-310d3d73fd2b",
    "entry": "古茶",
    "reading": {
      "primary": "こちゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "last year's tea",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この老人は、黒光りのする古茶棚と長火鉢の隅をとって、そこへ、一人で膳を構えて、こつねんと前刻から一人で、一口ずつ飲んで、飲んでは仮睡をするらしかったが、ごッつり布子で、この時である。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "備後は家へ帰って怪獣の話をして、持って帰った古茶釜の蓋を出した。",
              "citation": {
                "source": "猫の踊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新茶の頃が來ると、私はそれに古茶をまぜて飮むのを樂しみにしてゐる。",
              "citation": {
                "source": "短夜の頃",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月を迎へ、七月を迎へするうちに、新茶と古茶の區別がなくなつて來るのもおもしろい。",
              "citation": {
                "source": "短夜の頃",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　するうち古茶箪笥の上の方にかかっている時計が五時を打った。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆樣の顏古茶碗の澁茶店前の枯尾花共に老いたり。",
              "citation": {
                "source": "高尾紀行",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は此名刺の古茶けたのを受取つて、矢張詩人らしい無頓着な所があると思つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では利休の古茶碗を五千圓、六千圓と云ふやうな金を出して買求め、之を裝飾にして居るものがある。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では利休の古茶碗を五千円、六千円というような金を出して買求め、これを装飾にしているものがある。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれに古茶をすこし混ぜ入れて来たと言って見せるほど、注意深くもあった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐらぐら煮立った鉄瓶のふたを取って水をさすことも、煎茶茶碗なぞをそこへ取り出すことも、寺で製した古茶を入れて慇懃に客をもてなすことも、和尚はそれを細心な注意でやった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前には毛氈が一枚、所々破けたままの上へ、火鉢、小机、置物、目覚し時計、膳、椀、皿、古茶器、装身具、文具など、いずれも中古から大古まで、中には化けそうなのもまじえて、古道具の貧しい店をひろげ、五十位の人の好さそうな中老人が、ふところ手をしたまま、えりまきにあごを埋めて、ポツネンと坐っておりました。",
              "citation": {
                "source": "眠り人形",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その景色の上を、追込まれの坊主が、鰭のごとく、キチキチと法衣の袖を煽って、「――こちゃただ飛魚といたそう――」「――まだそのつれを言うか――」「――飛魚しょう、飛魚しょう――」　と揚幕へ宙を飛んだ――さらりと落す、幕の隙に、古畳と破障子が顕われて、消えた。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "※先や左程にも思やせぬのに、こちゃ登りつめ、山を越えて逢いにゆく。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の生れた大阪の方言でいえばおんべこちゃ、そう思って私はむしろおかしかった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくれんぼのとき、押入れの真っ暗い中に、じっと、しゃがんで隠れていて、突然、でこちゃんに、がらっと襖をあけられ、日の光がどっと来て、でこちゃんに、「見つけた！",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのお茶ぴいめ、ついこないだまで竹馬に乗ったり、学校の生徒に引張り出されちゃあ田圃でぶらんこをしていたっけが、どうだい、一番この男とおっこちゃあがって、それ、お歳玉に内証だよ、と遣りゃあがったんだとよ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に「上る箱根の御関所でちょいとまくり、若衆の物では受け取れぬ、こちゃあ新造でないかとちょと三島」てふ名句があった。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちゃおさん様にいうほどに。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねこめがピカピカ目を光らしゃがるんで、人ごこちゃなかったが、もうここへくりゃどんな音でも出らあな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何をクヨクヨ鳥が飛び、ほかの色木にとまろうと、こちゃ知らねえ、こちゃ知らねえ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうするって、こちゃ知らんわ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こちゃ知らんてことよ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お霜さんが安次の金とったなんて云われると、こちゃ困るわ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りは名高い大きな書店や、文房具屋や、支那料理などの目貫の商店街であったが、一歩横町へ入ると、モダアニズムの安価な一般化の現われとして、こちゃこちゃした安普請のカフエやサロンがぎっちり軒を並ベ、あっちからもこっちからも騒々しいジャズの旋律が流れて来るのだった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢、鍋、茶碗、棚、飲料、果物、匙やナイフさえ幾色か、こちゃこちゃ持ち込まれてあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の室へ出てみると、母親は台所でこちゃこちゃ働いていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "すんなり枝を延ばし梢高く、樹肌がすべすべで薄紅のに、こちゃこちゃ、こちゃこちゃとかたまって濃緑、臙脂、ぱっとした茶色などの混った若芽が芽ばえ出している。",
              "citation": {
                "source": "九州の東海岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月或日　Ｙ机の前で旅券下附願につける保証書の印を加茂へもらいに送るその用の手紙書きつつ「ねえべこちゃん、これ切手はらないでいいんだろうか――印紙を」「ハハハハもやでもそういう感違いするのね　ハハハハ愉快愉快」「いらないのか？",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁じゃない、碁じゃない、こちゃゴジャゴジャだ。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
