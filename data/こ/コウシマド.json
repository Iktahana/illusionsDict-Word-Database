        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "表の河沿いの道路に面した格子窓には風鈴が吊されて夜風に涼しい音を立てていたように思う。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝吉原神道流剣道指南　　　　　白倉源五左衛門の看板Ｓ＝道場の表　格子窓から覗き込んで居る人々。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふと煤煙にすゝけた格子窓のさきから、聞覚えのある声がした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中六番町の家を引き払おうという二三日ぐらい前の夜半に盗賊がはいって、玄関わきの書生部屋の格子窓を切り破って侵入した。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが家の格子窓から、子供らが顔を出して、別れを惜しむ。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝太郎がその挙動を、鋭い目で角の屑屋の物置みたような二階の格子窓に、世を憚る監視中の顔をあてて、匍匐になって見ていた、窃盗、万引、詐偽もその時｜二十までに数を知らず、ちょうど先月までくらい込んでいた、巣鴨が十たび目だという凄い女、渾名を白魚のお兼といって、日向では消えそうな華奢姿。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "門に向いた教室の格子窓には、窓を脊にして立つてゐる参観の教師達の姿が見えた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に往来の人の目に附くのは、裁縫を教えている女の家で、昼間は格子窓の内に大勢の娘が集まって為事をしていた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそこの家の格子窓の上に吊るしてある鳥籠である。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りに面した方が格子窓になつてゐる二階の六疊を借りて、お鳥はそこに落ち付くことになつたのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "格子窓の上に掛っている日覆にもその字があった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我々ふたりは目を格子窓の方へ向けた。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　依頼人の居間についた細長い格子窓が、玄関とともにこの歴史ある学寮の苔むす方庭へ面していた。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝室の窓をご覧になったかどうかはわかりませんが……」「鉛製の格子窓で硝子入り。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉の瞳はいつか物珍らしげに向ひの家を見下ろして、その格子窓から洩れる三味の音を聞いてゐるのであつた。",
              "citation": {
                "source": "三十三の死",
                "author": "素木しづ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日の後、我は新月の光を趁ひて、又同じところに來しに、こたびは自ら禁ずること能はずして、進みて灰色の寺壁の下に立ち、格子窓を仰ぎ視たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸御紹介をしましょう」　こう云って蔀君は先きに立って、「御免なさい、御免なさい」を繰り返しながら、平手で人を分けるようにして、入口と反対の側の、格子窓のある方へ行く。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔀君のさして行く格子窓の下の所には、外の客と様子の変った男がいる。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る見る歯医者の家の前を通り過ぎて、始終僕たちをからかう小僧のいる酒屋の天水桶に飛び乗って、そこでまたきりきり舞いをして桶のむこうに落ちたと思うと、今度は斜むこうの三｜軒長屋の格子窓の中ほどの所を、風に吹きつけられたようにかすめて通って、それからまた往来の上を人通りがないのでいい気になって走ります。",
              "citation": {
                "source": "僕の帽子のお話",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこのやつだッ」　恐々さしのぞいて、恐々探しましたが、丁度格子窓の出ッ張りの下に平みついているのですから、分る筈はないのです。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを見ろッ、あそこの格子窓の向こうからのぞいていらっしゃるだんなの顔をみろッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウフウフアハハハ……」　聞いて格子窓の外からおかしくてたまらないといったように、いとも朗らかにうち笑ったのは名人右門です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いながら、そしてその青白い顔を転じると、格子窓からぬか雨にけむる庭先のぬかるみに向かって、伝六の愚痴をさけるように面をそむけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "Tonka John の部屋にはまた生れた以前から舊い油繪の大額が煤けきつたまま土藏づくりの鐵格子窓から薄い光線を受けて、柔かにものの吐息のなかに沈默してゐた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "東向に格子窓があつて、室の中は暗くはない。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子を開けた格子窓の、直ぐ下から青田が続いた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ　木の　こうしまどの　むこうから　聞こえてくる　きんきん声に　がまんできません。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
