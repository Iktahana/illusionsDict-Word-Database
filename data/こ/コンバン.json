        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "されば今晩かなしげに、かうして沈んでゐる僕が、輝き出でる時もある。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――明日相談に出かけるとして今晩は一人で飲んで来よう。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今晩は、出掛けるために電車賃が一銭もないのであつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は」と彼は云つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――室チラケてゐる）女　今晩は。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今晩の御料理は何だね？",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩だけ、ふたりで仲よく遊ぼう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団だけは今晩荷を解かなければならないと思ふことが、異常な落胆を呼び起すのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "友よ、この一文を書きたくなつた今晩君が傍にゐて呉れたら僕は大変沢山なことが喋舌れた。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まああたしまだ、仕度なんてしてやあしないわ、それに今晩はあれですもの……夜間（撮映）……ねえ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "中で一番威張れる者が、その赤らんだ薄い皮膚の眼蓋の上にロイド眼鏡を掛けて、彼女が襖を開くや愛相よく「今晩は」と言つた時、彼女は漸く何だか嬉しくなつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腰が重さうだが、今晩泊ると言ひなさらなきや好いが……。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今晩かなしげに、かうして沈んでいる僕が、輝き出でる時もある。",
              "citation": {
                "source": "酒場にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩鴫の御化けが来るぜ。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩は銀河のお祭だねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その牛乳屋の黒い門を入り、牛の匂のするうすくらい台所の前に立って、ジョバンニは帽子をぬいで「今晩は、」と云ひましたら、家の中はしぃんとして誰も居たやうではありませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は、ごめんなさい。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっかさんが病気なんですから今晩でないと困るんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は、」ジョバンニは叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも今晩はありがたう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七五郎も石松と同じく百姓の伜であり乍ら、博奕打ったりして居る不良です）　「今晩は」　「あら今晩は」　お静、あまりよい顔はしない。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は」　「あら、おばさん」　お静、立って戸口へ行く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩は……まだ、起きて居たのかい？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩か、遅くとも明日の晩だから、そのつもりで……」　「御親切に有難う御座いました。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎長が、　「それで、今晩か明日の晩手を入れるから、それ迄に逃してしまえ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜んだ三次、Ｔ「ウチの旦那を呼んで来な」　と言って印籠を勝坊の手に握らせて、Ｔ「明日の敵討今晩に繰り上げだ！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「今江戸中、　人気の焦点、　評判男の中村仲蔵が……」　「その仲蔵が……」と過去を想い起すらしく、Ｔ「二十年以前、　貧に窮して、　おやじ橋に捨てた　我子、仲蔵とは……」　「わしはこんな嬉しい事はない」　聞いてた雪枝が仕事の手を止めて、Ｔ「今晩にでも、　兄様に会いに行かれては？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩は夕立ち、明日から四五日お天気は大丈夫よ」「まあ、そんなところですなあ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の瞬間私が青い窓から近東の藍色の空を眺めていると電流にのってアダがあらわれてきて、私の夜会服に一輸のネムの花をさすのであるが、忽ち私には彼女がマルセーユの金羊毛酒場の素足の美しい踊姿となって女の耳元で、おい、Ｙ、今晩おれにつきあえよ、と囁く追想の女となるのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おわあ、こんばんは』『おわあ、こんばんは』『おぎやあ、おぎやあ、おぎやあ』『おわああ、ここの家の主人は病気です』貝つめたきもの生れ、その歯はみづにながれ、その手はみづにながれ、潮さし行方もしらにながるるものを、浅瀬をふみてわが呼ばへば、貝は遠音にこたふ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
