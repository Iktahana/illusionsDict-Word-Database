        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それさへあれば事足りるのである。",
              "citation": {
                "source": "墓の上に墓",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しそれが純であるならば、誠実は微量であっても事足りる。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の世界はこの展望の一室だけで永久に事足りるであらう。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋が一つ、それでも事足りる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも問題は主として編輯及び出版の技術に関することと存じ候間御都合にて御多忙中｜態々御足労煩わさずとも、永田氏を煩わし下されば事足りることとも存じ候。",
              "citation": {
                "source": "岩波茂雄宛書簡",
                "author": "一九三一年八月十七日",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし覗き穴さえわかれば、それで事足りるではないか。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも雀や猫の建築家があるとしたならば、彼は平安快適な場所を指示するだけで事足りるであろう。",
              "citation": {
                "source": "文学精神は言う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くも、天下は二分してしまう」「それでも、三百万両で、事足りるか」「それは判らん」「足りぬ時に、何うする？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは私が昼間谷から自分で採ってきた僅かな焚木でも事足りる、わざわざ薪を買うほどのこともない……と、まあ、そういった位の余寒さだ。",
              "citation": {
                "source": "卜居",
                "author": "津村信夫に",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説で事足りるのである。",
              "citation": {
                "source": "新しき天地",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "三畳の間借りで事足りるんだからね。",
              "citation": {
                "source": "雨宮紅庵",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "計略とはいえ至極簡単なもので、女の髪の毛一筋あれば事足りるのである。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前述の通り花粉がここに捉わるれば忽ち顕微鏡的の花粉管を生じ、それが子房内の卵子を目がけて勢いよく進み行くのであるが、それは丁度娘一人に聟八人の有様で、その卵子と合歓を遂げるにはタッタ一つの花粉管があれば事足りるのである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "５．「學者には數言で事足りる」。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大石君の忠告によれば下町に仮住居して成るべく電車に乗らずして日常の事足りるやうにしたまへとの事なり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それに大弥太や左源太や、定遍坊の手の者や、玉置荘司の家来など、われら駈け散らす所存ならば、九人だけでも事足りる。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此道に從ふことによつて吾人は千頁讀む處を百頁讀んで事足りる樣になる。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番大きい東京をとって見ると、旧東京市は原子爆弾二個か三個で壊滅するであろうし、新市を含めて全部を潰すにも一五か一六個あれば事足りるのである。",
              "citation": {
                "source": "原子力の管理",
                "author": "仁科芳雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は一滴も飲まぬが、煙草は好物で、配給のキザミや金鵄ぐらゐで事足りるわけはないから、ひとから聞いたイタドリやフキの葉を乾かして吸ひ、山をうろつきながら、さまざまな雑草の葉を自分でためしてみては、最後に、ゴハといはれる茎の短い、大きな葉がカヘデのやうに五つに割れたヒダのある草を常用にした。",
              "citation": {
                "source": "秋の雲",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、もしこれらの点についてわれわれが一層多くの真の知慧をもっていたとしたらば、教育はもっと少なくてたぶん事足りる（なぜならば、ほんとのところ、それまでにもっとたくさんが獲られているだろうから）ばかりでなく、教育を受けるための金銭的費用も大半消えるだろうと思わざるをえない。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて重要で心からの交際のためには、たしかにこれほどしげしげとしなくても事足りるであろう。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林氏は「肉體の惡魔」の對譯シナリオを執筆されていたとき、代名詞の“Le”を、「あれ」と譯せば事足りるのに、そのあれが何であるかを究明する爲に、映畫會社へ幾度か足を運ばれたのであつた。",
              "citation": {
                "source": "字幕閑話",
                "author": "秘田余四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古作品が示すように、充分な美への表現は、単純な技巧によって事足りるであろう。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之によって囚人の社会的野心を抑えるに事足りるものらしい――つまりユニフォームは人間の階級性・社会秩序を最も露骨に意識的に云い表わすためのもので、学生のユニフォーム着用の事実から、日本に於ける学生層なるものの、階級的（？",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し限定は極めて簡単で事足りる。",
              "citation": {
                "source": "現代科学教育論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらを倒すには剣も槍も必要がなく、専ら忠誠心と揺るがぬ決意があれば事足りるのです。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、先にも説いたように、政治はただ現実を認識するだけで事足りるのではなく、その現実を理想に向かって引上げるところにその本質があるし、同時にそれが政治学の任務でもあるのである。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかには『シャコンヌ』一枚でも事足りる。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラフマニノフのレコードは、普通『前奏曲＝嬰ハ短調』と『三頭｜立の橇』だけでも事足りるだろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学は、英語を使用し、英語で使用される新しい大小の官僚、事務官を養成すればことたりるところという標準で組みかえられつつある。",
              "citation": {
                "source": "新しいアカデミアを",
                "author": "――旧き大学の功罪――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
