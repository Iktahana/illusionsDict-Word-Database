[
  {
    "uuid": "8f00cfed-0a8f-5844-b9e6-c9388cf10763",
    "entry": "こけつ転びつ",
    "reading": {
      "primary": "こけつまろびつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
