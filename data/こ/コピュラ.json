        "examples": {
          "standard": [
            {
              "text": "「〜は〜だ」という文で、「だ」はコピュラにあたります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この言語学の教科書には、コピュラに関する詳しい説明が載っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "述語の「〜です」は、主語と繋ぐコピュラとしての役割を果たしています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
