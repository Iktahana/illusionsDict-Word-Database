        "examples": {
          "standard": [
            {
              "text": "ベルギー国王レオポルド2世の私有地だったコンゴ自由国では、過酷な強制労働が行われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の授業で、コンゴ自由国の実態が国際的な批判を浴びた背景について議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コンゴ自由国からベルギー領コンゴへと統治が変わる過程で、多くの犠牲が払われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "コンゴ自由国、すなわち欧米九ヵ国が同盟しまして、プロテスタント主義の自由国をアフリカの中心に立つるにいたったのも、やはりリビングストンの手によったものといわなければなりませぬ。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "六週間、デンと一緒にコンゴ自由国の周辺をうろつき、本物の宝庫を探してきた。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            }
          ]
        }
