[
  {
    "uuid": "aa241435-9937-5dd5-ba0a-e2971630d816",
    "entry": "混用",
    "reading": {
      "primary": "こんよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
