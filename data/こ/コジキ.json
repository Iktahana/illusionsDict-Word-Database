[
  {
    "uuid": "545f1fc6-f8ad-5a34-a9ce-c368a08a277d",
    "entry": "古事記",
    "reading": {
      "primary": "こじき",
      "alternatives": [
        "ふることふみ",
        "ふることぶみ"
      ],
      "is_heteronym": false
    },
    "grammar": {
