  {
    "uuid": "042738f6-247f-5b22-aa17-e70f2432cd4f",
    "entry": "心持ち",
    "reading": {
      "primary": "こころもち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
