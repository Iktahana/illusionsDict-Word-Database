    "definitions": [
      {
        "index": 1,
        "gloss": "small bear",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小熊のひたいの　うえは　そらのめぐりの　めあて。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小熊のひたいの　うへはそらのめぐりの　めあて。",
              "citation": {
                "source": "星めぐりの歌",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると小熊が甘えるように言ったのだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地軸の北端の真上にある北極星は小熊星座の主星である。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この星座の形が小熊を聯想させるとは私にはどうしても受取れないが、小熊といふ名はいかにも北極の星らしく、その光質までが白光を帯びてゐるやうである。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その処を赤い瓢箪の上に小熊を附けた馬印を押し立て、兵五百に先頭して、馳け抜ける若武者がある。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで小熊座にあるという出版社は、この本を電子化して出すことに決めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版元は、小熊座の会社ではありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小熊(2)同じからざる敵を同じからざる味方をもつて迎へ撃つ、炸弾は個性的に跳ねとぶだらう、確固不動の精神に前進を命じよう、濶達な青年としてたたかふ場所は広い、撃たれるものも撃つものも豊富である。",
              "citation": {
                "source": "小熊秀雄全集-13",
                "author": "詩集（12）その他の詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "小熊(3)」はママ］資本の取引のやうに手軽にぶべつ的に我々の思想は彼等に受け渡されない文学への賞金とはいつたい何なのか？",
              "citation": {
                "source": "小熊秀雄全集-13",
                "author": "詩集（12）その他の詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "小熊秀雄全集−15−小説小熊秀雄-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）聞き惚た。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（小熊生）　絵といふものは作者が興奮しないときに、よく見るといふことが肝心である、さういふ状態までもつて来なければならぬ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "土の中の馬賊の歌小熊秀雄-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）聞き惚た。",
              "citation": {
                "source": "土の中の馬賊の歌",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は三木清次郎、母は小熊マツ。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二月二六日、小熊マツ私生子として入籍。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二一（大正十）年　徴兵検査をきっかけに小熊マツの私生子であることを知り、以後、三木姓を捨てて小熊姓を名乗るようになる。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "）一九三五（昭和十）年　五月に『小熊秀雄詩集』を耕進社から、六月には長編叙事詩集『飛ぶ橇』を前奏社から刊行。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　略年譜作成にあたり、『小熊秀雄全詩集』（思潮社）に収録されている遠地輝武氏による年譜を参照させていただいた。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "小熊秀雄全集-11詩集（10 ）風物詩篇小熊秀雄東京風物伝東京駅東京駅はウハバミの燃える舌で市民の生活を呑吐する玄関口、朝は遅刻を怖れて階段を一足とび夕は疲れて生気なく沈黙の省電に乗る所詮、悪蛇の毒気に触れて人々の痲痺は不感症なり。",
              "citation": {
                "source": "小熊秀雄全集-11",
                "author": "詩集（10 ）風物詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "小熊秀雄全集-12詩集（11）文壇諷刺詩篇小熊秀雄-----------------------------------------------------------------［表記について］●ルビは「」の形式で処理した。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢田津世子は芥川賞の候補になつたこんどは小熊賞の候補にしてやらう。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "（小熊夫人書き写し）------------------------------------------------------------------マナイタの化けた話　海の水平線に、小さな帆前船が現はれました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "（小熊夫人書き写し）------------------------------------------------------------------タマネギになつたお話　悪魔は、小さな村にやつてきました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "（小熊夫人書き写し）マナイタの化けた話　海の水平線に、小さな帆前船が現はれました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "（小熊夫人書き写し）タマネギになつたお話　悪魔は、小さな村にやつてきました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央に小さな空地があり、竹取翁が、後向に坐って、じっとこぐまったまま、無心に竹を伐る斧を振っている。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
