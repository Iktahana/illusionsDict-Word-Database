[
  {
    "uuid": "112b8c43-c9e3-5237-864e-46e18b32dad5",
    "entry": "細かい",
    "reading": {
      "primary": "こまかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
