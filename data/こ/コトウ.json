    },
    "definitions": [
      {
        "index": 1,
        "gloss": "old sword",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "＊鳶色の古刀の鞘よ、舌あまりの幼な友達、おまへの額は四角張つてた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワシは長巻直しの古刀を一本持っておった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊織は京都で其年の夏を無事に勤めたが、秋風の立ち初める頃、或る日寺町通の刀劍商の店で、質流れだと云ふ好い古刀を見出した。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「こいつは、何とかいふ古刀で、柄の処々に金などが巻いてあるから相当なものだらうと思つて持ち出して来たよ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ただし、その間には、古墳から掘り出したと思われる、石のからびつ、古刀剣、曲玉管玉、古甲冑、土偶、木乃伊、弓、矢の根、古い錦襴、銅板、鉄牌、古瓦、化石というような物が、整然と分類されて置かれてあった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊織は京都でその年の夏を無事に勤めたが、秋風の立ち初める頃、或る日寺町通の刀剣商の店で、質流れだと云う好い古刀を見出した。",
              "citation": {
                "source": "じいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は起きあがると片隅の腰掛に坐つて、新らしく交易した土耳古刀を磨きはじめた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒙古刀ださうです」と云ひながら、すぐ拔いて見せた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "書齋の柱には例の如く錦の袋に入れた蒙古刀が振ら下がつてゐた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は、「えゝ些と物數奇過ぎますね、蒙古刀は」と答へた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "古刀で周知の安綱、真守は伯耆の大原邑の出であり、山を越した山陽側の備前長船にはやはり名匠を多く生んだことも当然であるかもしれない。",
              "citation": {
                "source": "出雲鉄と安来節",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、横佩家へも出入りし、大伴家へも初中終來る古刀自の、人のわるい内證話であつた。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、横佩家へも出入し、大伴家へも初中終来る古刀自の人のわるい内証話であつた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、横佩家へも出入りし、大伴家へも初中終来る古刀自の、人のわるい内証話であつた。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、横佩家へも出入りし、大伴家へも初中終来る古刀自の、人のわるい内証話であった。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これは伯耆の安綱という古刀中の古刀、名刀中の名刀じゃ」「ええ！",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "名刀なら有っても決して邪魔にはならねえが、名刀にも品がある、お前たちのいう名刀は、あんまり大した代物ではあるまい」「それがなかなか素敵で、出処が確かなものなんですよ」「古刀か、新刀か。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "在銘のものか、ただしは無銘か」「古刀のパリパリで、たしかやすつなと言っていましたよ」「やすつな？",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月下旬のはじめには、半蔵らは二日ほど逗留した公郷村をも辞し、山上の家族にも別れを告げ、七郎左衛門から記念として贈られた古刀や光琳の軸なぞをそれぞれ旅の荷物に納めて、故郷の山へ向かおうとする人たちであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山の家に伝わる古刀、古い書画の軸、そのほか吉左衛門が生前に蒐集して置いたような古い茶器の類なぞを取り出して思案顔でいる半蔵をそこに見つけた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで妻子を養おうとするには、どうしても古刀の「にせもの」を作るよりほかにその日の暮らしようがありません。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には古刀と新刀の歴史が図でわかるように説き明かしてありましたが、それぞれの流儀のちがいと言いますか、図にあらわれた焼き刃の模様がちょうど海の岸に寄せてはかえる潮の花の紋のように見えました。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "古刀鍛はおろし鉄のいってんばりであったが、これはまず孫六あたりをもって終りとなし、新刀鍛となっては、正則のほかに大村｜加卜ほか武蔵太郎一派の真十五枚｜甲伏というのも出たが、多く伝わっているのは卸し鉄と新刀ぎたえのふたつだけだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣太刀作り、平糸まきの古刀――左膳が、独眼を据えてその剣姿を凝視していると！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒙古刀だそうです」と云いながら、すぐ抜いて見せた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎の柱には、例のごとく錦の袋に入れた蒙古刀が振ら下がっていた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は、「ええちと物数奇過ぎますね、蒙古刀は」と答えた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯耆の夜見浜なども、寛永十六年の大水を始め数度の地変を経歴し、今の浜の目十八ヶ村は多くは三百年来の新墾であるのに往々にして陶器・古刀を発掘しまた古墳に打ち当たることが多かった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "からくみやこにたどりける、　　　芝雀は旅をものがたり、「その小屋掛けのうしろには、　　寒げなる山によきによきと、立ちし」とばかり口つぐみ、　　　とみにわらひにまぎらして、渋茶をしげにのみしてふ、　　　　そのことまことうべなれや。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなことうたってるのは。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
