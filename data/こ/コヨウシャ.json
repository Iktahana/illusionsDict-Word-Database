        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雇用者は、従業員の労働環境を整える義務がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は優秀な雇用者として、地域社会に貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私、あの会社で働くの決まったの！雇用者さんも良い人そうだった！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
