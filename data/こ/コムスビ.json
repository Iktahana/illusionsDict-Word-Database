    "definitions": [
      {
        "index": 1,
        "gloss": "wrestler of the fourth highest rank",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
