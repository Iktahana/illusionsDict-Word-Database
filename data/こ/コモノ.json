    "definitions": [
      {
        "index": 1,
        "gloss": "accessories",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、小物には閉口であった。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゃれた小物で、詳しく見ようと私が手を伸ばすと――ものすごい叫び声が上がった――外の通りにまで聞こえそうなわめき声だ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごちゃごちゃ小物の多い仏壇に、新派のある老優にそっくりの母の写真が飾ってあったが、壁に同じ油絵の肖像も懸かっていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る晩圭子は蓮見と一緒に、時節の半衿や伊達巻のやうな子供たちの小物を買ひに、浅草時代の馴染の家へ行つて、序でに咲子の兵児帯や下駄なども買つた。",
              "citation": {
                "source": "チビの魂",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここもなかなか暑いね」道太は手廻りの小物のはいっているバスケットを辰之助にもってもらい、自分は革の袋を提げて、扇子を使いながら歩いていた。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "どいつが盗ったのか、怪しからん奴だ」　その二つの時計は父が畳廊下の小物箪笥の引出しに入れておいたのを、いつの間にか誰かに持ち出されてしまっていたのであった。",
              "citation": {
                "source": "わが父",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、三十年前に指環、カフス・ボタンのような小物を買った店が、現在でも同様趣味のある小物を売っているので、懐しがっておりました。",
              "citation": {
                "source": "写真に添えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリンで或る洒落た小物屋の店へ入って、むこうにも面白いハンド・バッグの並んだショウ・ケイスがあるからそちらへ行こうとして爪先を向けたら、いきなり鏡にぶつかった時にはほんとにおどろいた。",
              "citation": {
                "source": "この初冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "使わなければならない紐の数、小物の数、いかばかりだろう。",
              "citation": {
                "source": "働くために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "単純な統一の一点に利いている小物の濃いゆたかな色彩、というような整理は、案外されていない。",
              "citation": {
                "source": "働くために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大永四年に家康の祖父岡崎次郎三郎清康が、忠行の父忠茂の謀を用ゐて、松平弾正左衛門信貞入道昌安の兵を破り、昌安の女婿となつて岡崎城に入つた時、忠茂は岡崎市の小物成を申し受け、さて毫釐も徴求せずにゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "北側の壁に添って置き棚が二つ据えられ、小物の並べてあることは定った形式である。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "長居を詫びて帰りがけに、つい気が引けてタワシだの目笊のような小物を余分に買いこんでしまうのであった。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手元の小物だの惣菜だのを買う時にはその縫い賃を足し前にしている。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、小物をいれる、蓋のあるのや蓋のない、いろんな仕切りがあって、訪問用や葬式用の名刺や芝居の切符などが、ちゃんと心憶えにしまってある。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋品店と云つても、学生相手の安物ばかりで、襯衣とか、靴下とかの小物類が売れてゆく位で、陳列の中の鳥打帽子や、絹ポプリンのＹ襯衣なぞは、四年の間そこへ飾りつぱなしで、いくら陽がさゝぬとは云つても埃つぽくなつてしまつて色褪せてゐる。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "集団農場は小物売店の塩漬胡瓜じゃねえだ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は以前釣人を中心にして、「海鳥型」と「野猫型」に分類した事があつたが、海釣りの好きな人と、川釣りの好きな人があり、更に大物の好きな人と小物の好きな人とがあつて、その人の特有なコンデイシヨンで釣るのが、釣独得の興味のあるところである。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ上げたもの、ザイル、三ツ道具、サブルック、ビスケット全部、シュラフザック、毛糸靴下、燃缶十五個、その他小物。",
              "citation": {
                "source": "槍ガ岳",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩小屋に置いたもの、米五合、コッヘル、燃缶五個、木椀二個、スプーン、フォーク、地図、その他小物。",
              "citation": {
                "source": "槍ガ岳",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か二三泊の旅の小物類にしては、少し大きすぎる鞄を、秋子はさげて来たが、その中に、和服の袷や長襦袢がはいっていた。",
              "citation": {
                "source": "憑きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の横に置いた小物入れから作りかけにした衣装人形を取り出し、縁側に行って椅子にかける）真紀。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その兄はシャツ、ズボン下など莫大小物の卸売をして居るので、彼女も少しミシンを稽古して置きたいと云う。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おいかわや鮭の子など小物釣りにはいささか飽いてきたようである。",
              "citation": {
                "source": "那珂川の鱸釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は潮たるみとなったので黒鯛、イサギ、イナダなどの小物釣に移ったが、それも三貫目余り釣れた。",
              "citation": {
                "source": "葵原夫人の鯛釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一尾三、四百匁位までの小物は、まだ肉に旨味が乗ってこない。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "不破の関守氏は、その隠宅でしきりに小物の表具を扱っている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの方の吊台には夜具二人前を入れたもえぎ唐草の風呂敷づつみ、座ぶとん五枚、行李二つ位、もう一つの吊台には机や鏡台その他身のまはりの小物をのせる、これは沢山の物があるほどお嫁さんは調法するが、親の方が痛いから、まづ間にあへばよろしいといふところ。",
              "citation": {
                "source": "よめいり荷物",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天使がそれで天井にさわりますと、天井は高く高く上へのぼって行って、さわられたところは、どこものこらず金の星がきらきらかがやきだしました。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つて、すばしこく香盤の側へ飛んで行つたかと思ふと、にこにこもので燐寸を弄くりながら歸つて來た。",
              "citation": {
                "source": "西大寺の伎藝天女",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
