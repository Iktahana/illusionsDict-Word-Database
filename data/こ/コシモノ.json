    "definitions": [
      {
        "index": 1,
        "gloss": "something worn on the hip (e.g. sword, pill box, money pouch)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "渡辺金太夫は、感状の上に吉光の御腰物下され候事也」とある。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "金さへあげればいゝでせう、その言ひ方が癪だと云つて母親は凄い見幕で怒りだすが、さほど下卑た言ひ方ではないので、はすつ葉な物腰物の言ひ方にもまだどことなく娘らしさが残つてゐる。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大名高家への連絡を取つたのは、根津の大町人、公儀御用達を勤むる石川良右衞門で、諸大名は言ふに及ばず、公儀御腰物方の御用までも取次ぎ、長い間共々に結構な利分を見て居たのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "研屋五兵衞の遺書が表沙汰になると、御腰物方が三人、腹切り道具になるが――」　笹野新三郎が暗い顏をするのも無理のないことでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹野新三郎から町奉行に申入れ、町奉行から、御腰物方に傳へて、翌る日の午後にはもう、『拵へ不行屆』といふ名目で彦四郎貞宗を、もう一度、根津の御用達石川良右衞門の手に戻されたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――」「御腰物方から、貞宗はもう一度戻つた筈です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "御腰物方から、東照宮傳來の佩刀を頼まれたのは去年の夏、五兵衞に拵へを直させて、石川良右衞門の家へ持つて來ると、或る夜泥棒が入つて、それを奪られてしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速五兵衞に相談すると、僞物を作つて兎も角も一時は凌ぎ、そのうちにゆる／＼眞物の行方を搜し、金に飽かして買ひ戻すより外に途はあるまいと言ふことになり、五兵衞は早速僞物を拵へ上げ、鞘から鍔まで、寸分違はぬ物を持つて來て、石川良右衞門の手で、それを御腰物方に納めたのは去年の秋です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "御腰物方からは嚴重な談判だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "御腰物方御役人にしても、これが表沙汰になつては腹切道具だ」「――」　石川良右衞門は、奇怪至極なことを語り進みます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那、これを直ぐ御腰物方に屆けて下さい、此上魔がさしちやいけません」「有難い、平次親分、この御禮は――」　石川良右衞門は疊の上に手を突いて居りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大名高家への連絡を取ったのは、根津の大町人、公儀御用達を勤むる石川良右衛門で、諸大名はいうに及ばず、公儀御腰物方の御用までも取次ぎ、長い間ともどもに結構な利分を見ていたのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "研屋五兵衛の遺書が表沙汰になると、御腰物方が三人、腹切り道具になるが――」　笹野新三郎が暗い顔をするのも無理のないことでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹野新三郎から町奉行に申入れ、町奉行から、御腰物方に伝えて、翌る日の午後にはもう、『拵え不行届』という名目で彦四郎貞宗を、もう一度、根津の御用達石川良右衛門の手に戻されたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」「御腰物方から、貞宗はもう一度戻ったはずです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "御腰物方から、東照宮伝来の佩刀を頼まれたのは去年の夏、五兵衛に拵えを直させて、石川良右衛門の家へ持って来ると、ある夜泥棒が入って、それを奪られてしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく五兵衛に相談すると、偽物を作ってともかくも一時は凌ぎ、そのうちにゆるゆる真物の行方を捜し、金に飽かして買い戻すより外に途はあるまいということになり、五兵衛はさっそく偽物を拵え上げ、鞘から鍔まで、寸分違わぬ物を持って来て、石川良右衛門の手で、それを御腰物方に納めたのは去年の秋です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "御腰物方からは厳重な談判だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "御腰物方御役人にしても、これが表沙汰になっては腹切り道具だ」「…………」　石川良右衛門は、奇怪至極なことを語り進みます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那、これをすぐ御腰物方に届けて下さい、この上魔がさしちゃいけません」「有難い、平次親分、この御礼は――」　石川良右衛門は畳の上に手を突いておりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速秋月九十郎の引見となり、そして倅山城守意知を通じて、若年寄の耳に吹込まれ、翌月は早くも、秋月九十郎二百石に加増、御腰物方に登用され、その翌年の暮にはもう御使番衆、布衣千石高と出世しておりました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "枕の妖異",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の幕府では腰物奉行から町奉行の手を経て、例の山田朝右衛門がやること。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、御腰物番の大高源吾であった。",
              "citation": {
                "source": "※かみ浪人",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やまとうたあるじの守のよめりける、「都いでゝ君に逢はむとこしものをこしかひもなく別れぬるかな」となむありければ、かへる前の守のよめりける、「しろたへの浪路を遠くゆきかひて我に似べきはたれならなくに」。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "久野さんはおそらく私の生涯に只一人の音楽の先生として記憶される方であろうが、こちらがすこしものを考えるように成長して来た十八九歳の時分には、久野さんの気質やものの感じかたが何だか苦しくうけとられた。",
              "citation": {
                "source": "きのうときょう",
                "author": "――音楽が家庭にもたらすもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人たちは一銭、二銭のほどこしものをしてやる義務を感じる。",
              "citation": {
                "source": "砂書きの老人",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしては、すこしものものしい緊張ぶりだ。",
              "citation": {
                "source": "沈没男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこを見ても、ただ自分だけは生きなければならぬとあせっているので、すこしものんびりとしたところがない。",
              "citation": {
                "source": "アパートで聞いた話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつねめさん、　自分でない　やつが　のこしものを　するのは　ゆるせません。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛川へ行くことはできませんでございます」「掛川へ行けば、もうすこしものごとがはっきりいたすまで、柘植の財産に手をつけずに、やって行くことができるのだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
