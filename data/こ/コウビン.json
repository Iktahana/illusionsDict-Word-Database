[
  {
    "uuid": "a6c196ed-da26-5495-b699-3d12b1733d50",
    "entry": "後便",
    "reading": {
      "primary": "こうびん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "later mail",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "後便萬縷敬具明治三十五年一月",
              "citation": {
                "source": "熱海の春",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかり次第、後便でお知らせする、と言ってやったが、どうにも、彼等一家の様子をさぐる手段は無かった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また後便でゆっくり申し上げます。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……午後便で、“層雲”と“小さき者”と到着、層雲を手にすると、武二君の苦心を察しる、小さき者を読んでは微笑した、天地のかため男女のちぎりはおもしろかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、その後便利な世の中になって、写真版などで見たものは、その時はよく覚えていても、直にすっかり忘れてしまいます。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "申上レバかぎりも無事ニて候間、後便ニのこし候七月七日稽首謹白。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年九月七日　坂本権平、乙女、おやべあて",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、其御地ニ御留りニて、つがふよろしけれバ別に御出浮被成ずてもよろしく、小弟可後便申上候時を御まち奉願候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年二月十四日　河田左久馬あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "然りといへども後便ニ一つさし出し可申と存じ候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月二十四日　坂本春猪あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れ又後便で…………皆たっしゃか、気をつけて、僕は大変健在。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝便の配達のとき長兄から、午後便の配達のとき妻から、実父｜伝右衛門の死を報じて来てゐた。",
              "citation": {
                "source": "南京虫日記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお話は後便に譲りませう。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし他の異国船五、六艘も登り候うわさもこれあり、今後瀬戸通路つかまつり候えば皆々打ち払いに相成る様子、委細は後便にて申し上ぐべく候。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぎ業を卒へ後便是非差上げ申候。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "後便｜認め直し差上げ可く候。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "『湖山楼詩屏風』と申す中へなりとも編入｜相願申可く候間、何れ律絶共に五十首｜宛後便御送り下されべく候。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一｜詩箋後便｜迄に社中の者どもに書かせ差上げ申す可く候。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "万づ後便に申し洩し候。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "くわしいことは後便にゆずる。",
              "citation": {
                "source": "海難記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、明治以後便利で安價な外國時計の大量輸入と共に、和時計の製造は中止され。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御時計師",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ詳しくは後便に――　文句はこれで終って居りますが、文字の乱れや文章のあわただしさに、何んとなく不安を感じさせるものがあります。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "白髪の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "正造は灸点家の言葉をたけ子へ書き送り、つづいて一月二十日付で次のような後便をしたためた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は余は後便にてというのを利用した。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日伊賀の上野見物、余は後便にて」で充分用が足りる。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の約束には履行の責任が伴うけれど、後便丈けは催促を受けて裁判沙汰になったという例を聞かない。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後便なる哉後便なる哉！",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんへも三輪さんの家へも発明序に日本橋の鬼瓦のところへも後便で御機嫌を伺って、後便は最良の方法だと思っていると、松本さんが小便の話を始めた。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお細かく申しあげたいことがありますが、紙面に余白がないので、後便にゆずります。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他のことは、後便にゆずります。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
