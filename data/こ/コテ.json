    "definitions": [
      {
        "index": 1,
        "gloss": "bracer (arm guard used in archery)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さらに維新前はお面お籠手の真の道場であった。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "左舷の當番水夫は今や確に星火迸り、火箭飛ぶ慘憺たる難破船の信號を認めて居るには相違ないのだが、何故か平然として動ずる色もなく、籠手を翳して其方を眺めて居るのみ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "お面お籠手の声が止むと間もなく、道場の電燈がフッと消えて人声一つしなくなった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて出でける男は、『しれ者かな』とて馬の口に取り附く処を、同じ様に斬り給えば、籠手の覆より打ちて、打ち落されて退きにけり。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠手、臑當、腹卷したる軍兵二人、上下よりうかゞひ出でゝ、芒むらに潜む。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏帽子、直垂、籠手、臑當にて出づ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人数も、わずかに数人で、籠手臑当して、手槍を持ち、小銃を持っているものは、わずかに数人で、大砲は一門もなかった。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と訛みたることばにて語るは、かひもの籠手にさげたる老女なりき。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その火に映った侍は三十五六の小肥りの男で、諸籠手の上に朽葉色の直垂を着て、兵庫鎖の太刀を長く横たえていた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の知事は籠手田さんでした。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この籠手田さんからも、大層優待されまして、凡てこんな会へは第一に招待されました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし鎧を持って行かないでは困るので、鎧の袖や草摺をばら／＼に外して、籠手も脛当も別々にして、ほかの荷物のなかへ何うにか欺うにか押込んで、先ず表向きは何の不思議も無しに江戸を立つことになりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠手、臑当、腹巻したる軍兵二人、上下よりうかがい出でて、芒むらに潜む。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏帽子、直垂、籠手、臑当にて出づ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "那須の篠原に狩り暮らしている三浦、上総の籠手の上にも、こうした霰がたばしっているかと千枝太郎は遠く思いやった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "平舞臺の正面は板羽目にて、面、籠手、木太刀、竹刀、薙刀などの稽古道具をかけ、下のかたには杉戸の出入口がある。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（深堀平九郎、廿七八歳、先生の代稽古をしてゐる體、稽古着に胴と籠手を着けただけにて袴をはき、うしろ鉢卷きをして竹刀を持ち、高いところに腰をかけて見物してゐる。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そのうちに新吾は籠手を打たれて竹刀を落せば、長七は附入つて更に胴を撃つ。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）新吾　　籠手を撃つたらもう好いではないか。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（彌平次はあわてゝ籠手をつけ、まん中に出て待つてゐる。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（雄之助は面籠手の道具をつける。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彌平次等四人はいづれも竹刀又は木太刀を持ち、段八と郡藏は胴と籠手を附けてゐる。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……籠手すね当てのかずを調べ、野郎どもに渡して置け。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手にいるのは築土新吾、鎖かたびら、籠手脛当、陣羽織をはおっている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして件の青侍に導かれ、緩端に平伏したる齋藤茂頼、齡七十に近けれども、猶ほ矍鑠として健やかなる老武者、右の鬢先より頬を掠めたる向疵に、栗毛の琵琶股叩いて物語りし昔の武功忍ばれ、籠手摺に肉落ちて節のみ高き太腕は、そも幾その人の首を切り落としけん。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "）こてっとぶたれて散歩しながら豚はつくづく考えた。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "できることなら、すね当、こて当、かぶとをかぶって街を歩きたく思ったのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　園丁がこてをさげて青い上着の袖で額の汗を拭きながら向うの黒い独乙唐檜の茂みの中から出て来ます。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物をいうたびに腹へこたえて、こてえられねえ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれが出て行くとそこらを片着け多勢の手で夕飯の餉台とともにお櫃や皿小鉢がこてこて並べられ、ベちゃくちゃ囀りながら食事が始まった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
