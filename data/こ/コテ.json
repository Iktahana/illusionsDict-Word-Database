  {
    "uuid": "f3447a9f-ebd7-5136-bd5e-a2778403b1bf",
    "entry": "コテ",
    "reading": {
      "primary": "コテ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "user name (on an online forum like 2ch where the majority of users post anonymously)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ピナコテークの画堂ではムリロやデュラーやベクリンなどを飽くほど見て来ました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、逆にまた、今の近代嬢の髪を切りつめ眉毛を描き立て、コティーの色おしろいを顔に塗り、キューテックの染料で爪を染め、きつね一匹をまるごと首に巻きつけ、大蛇の皮の靴を爪立ってはき歩く姿を昔の女の眼前に出現させたらどうであったか。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、コテコテと白粉をつけていても、ふと鼻の横の小さなホクロを見つけてみれば、やはり昔なつかしい古女房である。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮子は念入りに化粧を済ませると、鏡台の抽出から、とって置きのコティの香水を取出して、胸や耳のうしろへ振りかけて、そして再び応接室へ戻って来た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "コティの香水の匂がハンカチからむせ返る程ふりまかれた。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎は、背負籠の上に板を置いてコテを並べてあツた。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "是と目に付く程の物もない、がらくた物ばかりコテ／＼並べ立てた店である。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白く痩せこけた上にコテコテとお化粧をした……鼻の頭がツンと上を向いた……眼の球のギョロギョロと大きい……年はいくつかわからない西洋人のようにヒョロ長い女であった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふ着きたまひしことなれば、『ピナコテエク』、また美術会の画堂なども、まだ見玉はじ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのをりは『ピナコテエク』に懸けたる画を見しのみにて、学校の人々などに、交を結ぶことを得ざりき。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ピナコテエク』の館出でし時は、雪いま晴れて、街の中道なる並木の枝は、一つ一つ薄き氷にてつつまれたるが、今点ぜし街燈に映じたり。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二図ヒラコテリウムは、欧州と北米に、遺骨の化石を留むる下エオシーン期の馬で、前足に四、後足に三の趾ある事、大いに現存馬属諸種の足の端に、趾一つのみあると差う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "第２図　馬の先祖ヒラコテリウム　現存する馬と同属ながら、過去世に栄えた現世化石となりおわったもの数あり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "工手がすぐにコテを取って鉄扉の隙間を塗込めはじめた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれからひときりついて、浅川さんが見巡りに出られますと、私は器具置場までコテを置きに行きましたが、その間にこんなことになったんです」　浅川と云うのは監督の名前であった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "発火坑の塗り込めに当って、丸山技師や監督の指図を受けながらも、直接その手にコテを掴んで粘土を鉄扉に塗りたくった峯吉生埋めの実行者は、外ならぬ古井工手ではなかったか。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとコティロンのようでまた変わっていますの。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度油をコテコテ塗って鬘のように美くしく結上げた束髪が如何にも日本臭いと同様の臭味があった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体に赤黒く日に焼けてはいるが肌目の細かい、丸々とした肉付の両頬から首筋へかけて、お白粉のつもりであろう灰色の泥をコテコテと塗付けている中から、切目の長い眦と、赤い唇と、白い歯を光らして、無邪気に笑っている恰好はグロテスクこの上もない。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ白粉をコテコテと塗るのであるが、大抵は斑になった上に、キメが荒いから粟肌が一面に出来ていて、首の方向を変えると白い皺の波が出来る。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛の強いお化粧をコテコテと塗って、青い事務服を着て、店一パイの硝子窓の前に並んでカチャンカチャンとタイプライターを打っていた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺のゴワ／＼した大きな風呂敷包みを背負つた、色眼鏡をかけた男や、白粉をぬつた頬骨の出てゐる痩せた男、三味線を肩から釣つた、これも色眼鏡をかけた女、それにコテ／＼と白粉をつけた十七、八の娘と七つ八つの女の子が三人程ゐた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コテン、さいさい、アッアッアッ……こう云って家出をしましたので、彼女――私の奥さんですがね。",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつさえ旨く用いたら、あべこべに此方が勝利を得る」「『コテン』というのは斯ういう意味なので……」私はお嬢さんへ話し出した。",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
