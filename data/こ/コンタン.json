[
  {
    "uuid": "a5857404-5570-5190-a9e8-2009ea325b74",
    "entry": "魂胆",
    "reading": {
      "primary": "こんたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
