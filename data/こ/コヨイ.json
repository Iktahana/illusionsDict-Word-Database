    "definitions": [
      {
        "index": 1,
        "gloss": "this evening",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二階の一室狭けれども今宵はゆるやかに寝るべしと思えば船中の窮屈さ蒸暑さにくらべて中々に心安かり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は今宵程自分といふものが大きく思はれた時はなかつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯山に、暫し岩根のまつ程に、暫し岩根のまつ程に、誰が夜舟とは白波に、楫音ばかり鳴門の、浦靜かなる今宵かな、浦靜かなる今宵かな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵のこの庭のかがり火は純粋な神のみが使う資格のある聖なる祭の火であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよ、今宵よりは一時づゝの仕事を延ばして、この子が為の収入を多くせんと仰せられしなりき。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもふ事なき身もと、すゞろに鼻かみわたされて、日記のうちには今宵のおもふこと種々しるして、やがて哀れしる人にとおもふ。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人宿だけに亀屋の店の障子には燈火が明く射していたが、今宵は客もあまりないと見えて内もひっそりとして、おりおり雁頸の太そうな煙管で火鉢の縁をたたく音がするばかりである。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の話しぶりはきわめて卒直であるものの今宵初めてこの宿舎で出合って、何かの口緒から、二口三口｜襖越しの話があって、あまりのさびしさに六番の客から押しかけて来て、名刺の交換が済むや、酒を命じ、談話に実が入って来るや、いつしか丁寧な言葉とぞんざいな言葉とを半混ぜに使うようになったものに違いない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は疲れた足をひきずって、日暮れて路遠きを感じながらも、懐かしいような心持ちで宮地を今宵の当てに歩いた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たまうごとく家という家いくばくありや、人数は二十にも足らざるべく、淋しさはいつも今宵のごとし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸助五六歳のころ妻の百合が里帰りして貰いきしその時｜粘りつけしまま十年余の月日｜経ち今は薄墨塗りしようなり、今宵は風なく波音聞こえず。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時若き男二人もの語りつつ城下の方より来しが、燈持ちて門に立てる翁を見て、源叔父よ今宵の寒さはいかにという。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや行き過ぎて若者の一人、いつもながら源叔父の今宵の様はいかに、若き女あの顔を見なばそのまま気絶やせんと囁けば相手は、明朝あの松が枝に翁の足のさがれるを見出さんもしれずという、二人は身の毛のよだつを覚えて振向けば翁が門にはもはや燈火見えざりき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔血のいろにゆがめる月は〕血のいろにゆがめる月は、　　今宵また桜をのぼり、患者たち廊のはづれに、　　　凶事の兆を云へり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときに足踏みならしてたぬきの歌う歌の文句が、「こいさ（今宵の方言）お月夜で、お山踏み（たぶん山見分の役人のことらしい）も来まいぞ」というので、そのあとに、なんとかなんとかで「ドンドコショ」というはやしがつくのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今宵は泊るのが小菅ひとりであるし、わざわざ隣りの病室を借りるにも及ぶまいと、みんなで相談して、小菅もおなじ病室に寢ることにきめた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵は月は異なれど、まことの心には又あらはれ給はぬことでない。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月二十六夜ならば、このお光に疾翔大力さまを拝み申すぢゃなれど、今宵とて又拝み申さぬことでない、みなの衆、ようくまごゝろを以て仰ぎ奉るぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵は月は異なれど、まことの心には又あらはれ給わぬことでない。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来月二十六夜ならば、このお光に疾翔大力さまを拝み申すじゃなれど、今宵とて又拝み申さぬことでない、みなの衆、ようくまごころを以て仰ぎ奉るじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵は月の光を杯に酌みて快く飲まん、思うことを語り尽くして声高く笑いたし、と二郎は心地よげに東の空を仰ぎぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "女星は早くも詩人が庭より立ち上る煙を見つけ、今宵はことのほか寒く、天の河にも霜降りたれば、かの煙たつ庭に下りて、たき火かきたてて語りてんというに、男星ほほえみつ、相抱きて煙たどりて音もなく庭に下りぬ。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュバちやんかベトちやんか、そんなこと、いざ知らね、今宵星降る東京の夜、ビールのコップを傾けて、月の光を見てあれば、ベトちやんもシュバちやんも、はやとほに死に、はやとほに死んだことさへ、誰知らうことわりもない……思ひ出お天気の日の、海の沖はなんと、あんなに綺麗なんだ！",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "外では今宵、木の葉がそよぐ。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵は三度目である。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵もおなじ樣に、白い窓掛の搖ぐほとりに倚子を並べた時、櫻木大佐は稍や眞面目に私に向つて。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヤと思つて、窓外を眺めると、今宵は陰暦の十三｜夜、月明かなる青水白沙の海岸には、大佐の部下の水兵等は、晝間の疲勞を此月に慰めんとてや、此處に一羣。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "理あるかな、今宵は館に来客ありとて、饗応の支度、拭掃除、あるいは室の装飾に、いずれも忙殺されつつあり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こよいの歓喜をさらにさらに誇張してみたかったのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こよいあなたは　ときいろの　むかしのきもの　つけなさる　かしわばやしの　このよいは　なつのおどりの　だいさんや　やがてあなたは　みずいろの　きょうのきものを　つけなさる　かしわばやしの　よろこびは　あなたのそらに　かかるまま。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
