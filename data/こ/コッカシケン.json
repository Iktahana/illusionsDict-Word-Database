          "literary": [
            {
              "text": "ハリ、マッサージ、揉療治、それだけは国家試験をパスしたが、彼は、すぐにそれで生活したいとは思はなかつた。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇三年二十歳七月、ローマ法、教会法、ドイツ法、オーストリア法制史に関する国家試験（前半二年間の修了試験に相当）を好成績ですます。",
              "citation": {
                "source": "「世界文学大系58　カフカ」年譜",
                "author": "原田義人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボンで学位を取り国家試験に合格するためにベルリンに移った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが試験をうけたものが、今度国家試験になるそうな。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
