    "definitions": [
      {
        "index": 1,
        "gloss": "to tickle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蒸すような、焼くような、擽るような、悲しくさせるようなその香り、……その花から、まだ誰も嗅がなかった高い香り……清逸はしばらく自分をその空想に溺れさせていたが、心臓の鼓動の高まるのを感ずるやいなや、振り捨てるように空想の花からその眼を遠ざけた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人見は不意を衝かれたように思って、ちょっと尻ごみをしていたが、慌て気味に手が襟巻のところに行ったと思うと、今まで少しも出なかった咳が軽く喉許を擽るのを覚えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを脣に受けると幽かな甘味が春の精のやうに舌を擽る。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松の上なが、興がった声をして、「松葉が私を擽るわよ、おほほ、おほほ。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　明眸の左右に樹立が分れて、一条の大道、炎天の下に展けつつ、日盛の町の大路が望まれて、煉瓦造の避雷針、古い白壁、寺の塔など睫を擽る中に、行交う人は点々と蝙蝠のごとく、電車は光りながら山椒魚の這うのに似ている。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこを両脇、乳も、胸も、もぞもぞと尾花が擽る！",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と若い職員は擽るやうにいふ。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその靴底から傳はつてくるモノトナスな響が、みんなの聽覺を擽るやうに刺戟した。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片隅で誰かの幽かな鼾聲が擽るやうな音を立ててゐる。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花和尚がその諸膚脱の脇の下を、自分の手で擽るように、ぐいと緊めて腹を揺った。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の下……板縁の裏の處で、がさ／＼がさ／＼と音が發出した……彼方へ、此方へ、鼠が、ものでも引摺るやうで、床へ響く、と其の音が、變に、恁う上に立つてる私の足の裏を擽ると云つた形で、むづ痒くつて堪らないので、もさ／＼身體を搖りました。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙って主婦を見たが、神月は下を向いて、「止そう、見ッともないから、擽ると最後、きゃっきゃっいってその騒々しいといったらないもの。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おや、いつも擽るんだと見えますね、あなたは。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と件の大笊を円袖に掻寄せ、湖の水の星あかりに口を向けて、松虫なんぞを擽るやうに笊の底を、ぐわさ／＼と爪で掻くと、手足を縮めて掻すくまつた、垢だらけの汚い屑屋が、ころりと出た。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、時にゃがらりと巫山戯出して、肩へつかまる、羽織の紐を引断る、膝を打つ、擽る。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　明眸の左右に樹立が分れて、一条の大道、炎天の下に展けつゝ、日盛の町の大路が望まれて、煉瓦造の避雷針、古い白壁、寺の塔など睫を擽る中に、行交ふ人は点々と蝙蝠の如く、電車は光りながら山椒魚の這ふのに似て居る。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "擽るような五月の軟風が咽せかえるばかりの草いきれを孕んで来て、かるく、白木綿の窓帷を動かしていた。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "板一枚隣りでは、まだ頭のてっぺんから搾るような笑い声がしたり、押し殺すような、擽るような笑い声が聞えて来た。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今に栄一が玩具にするかもしれない――私はも少しでそう言うところだったが、突然またあの「お伽噺」を思いだすと、自分で自分を擽るような思いがして、そのまま言葉を呑みこんでしまった。",
              "citation": {
                "source": "地球儀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今に英一が玩具にするかも知れない――私はも少しでさう云ふところだつたが、突然またあの「お伽噺」を思ひ出すと、自分で自分を擽るやうな思ひがして、その儘言葉を呑み込んでしまつた。",
              "citation": {
                "source": "地球儀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、女は、屡々、夜鳥の叫びに似た声を挙げたが、仔細に眺めると、それは、怖れや、苦悶の悲鳴ではなくつて、誰やらが、女の脚のあたりを擽る度に放つ馬鹿／＼しいわらひ声のようでもあつた。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひはまた廷臣の鼻の上を走る、と叙任を嗅出す夢を見る、或ひは獻納豚の尻尾の毛で牧師の鼻を擽ると、僧め、寺領が殖えたと見る。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」小僧「これが犯人の足の裏を、擽るのです。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はよく氣の毒な女だと思つてたが、それでも此滑稽な顏を見たが最後、腹の蟲が喉まで出て來て擽る樣で、罪な事とは知り乍ら、種々な事を云つて揶揄ふ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はよく気の毒な女だと思つてたが、それでも此滑稽な顔を見たら最後、腹の虫が喉まで出て来て擽る様で、罪な事とは知り乍ら、種々な事を云つて揶揄ふ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤児を可愛がる処女には男の心を擽る様な点がある。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は微醺を帯びて来て、些々擽る様な事を言つた事もある。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は微醺を帶びて來て、些々擽る樣な事を言つた事もある。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤兒を可愛がる處女には男の心を擽る樣な點がある。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "素脚の足の裏につめたい、やはらかな、擽るやうな感触を楽しむことができるのも、もうほどなくのことらしい。",
              "citation": {
                "source": "春の賦",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
