  {
    "uuid": "bde89184-c483-5565-8e0b-d8982e6fc40c",
    "entry": "国選",
    "reading": {
      "primary": "こくせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "selection by the state (esp. of a defense lawyer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白樺の林のなかに米国選手の宿舎がある。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリンピックで東京へ来た各国選手にのぼせて、サインを強要したり、恋愛事件をおこしたりしては国の恥であるから、そういう怪しからん娘は断然取締るべしという方針に立っての談話なのであった。",
              "citation": {
                "source": "日本の秋色",
                "author": "――世相寸評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "各国選手入場――ＡＢＣ順。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについてこの間「婦人評論」に掲げられた黒岩氏の「英国選挙婦人に同情す」と云ふ論文を読んで見た。",
              "citation": {
                "source": "最近の感想",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし外国選手はレース屋という点では、たいがい古橋に負けず劣らずだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の名前にはさまって、ヘルセット、スネルスルード、コルテルード等の外国名が入って来るのだから、アプローチを外国選手の名前と考えたのであろうが、これはいさゝか世界記録的の間違いである。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリッピン代表タン教授に由ると、かつてインド選手が参加出場したのは、体育協会会議に於て会員の賛同を得た結果であったのだから、満州国選手の参加出場にも亦支那の賛同が必要だということになって来たのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれが当時全国選挙区の範として語り伝えられたことだけに、正造には今日この結果がいかにも残念だった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
