        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところがそれらの森林は国有林になってしまった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもの登ってゆく大きな国有林も同じく二階から望んで呆れた山の一つであるのだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "国有林であるというこの森林を我等はただ黙々として一時間も一時間半も歩いて行った。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋ヶ谷の国有林を眺めつつ志戸坂峠へ登りました。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡山県の禁猟区の杭と兵庫県の国有林の杭が打ってあります。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国有林の杭が打ってあります。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森林の下を通って海抜四一三二尺もある峠へ登った、鳥取営林署、氷ノ山国有林の立札がある。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国有林の境界の標木が小高い塚の上に建ててある。",
              "citation": {
                "source": "奥秩父の山旅日記",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪にばかり拘泥するようであるが、何でも燃料対策の緊急措置として国有林か何かを伐って、応急的に薪の配給を最近した例があるが、そういう思い切った施策は、綜合開発だから出来たのであるという話なのである。",
              "citation": {
                "source": "琵琶湖の水",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の森林資源は、八五％が国有林で、営林局の管轄下にある。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の重要問題である植林においても、民有林の成長率は国有林よりもはるかに勝っているという事実がある。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
