    "definitions": [
      {
        "index": 1,
        "gloss": "to roll",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大宮町への道も、玉を転がす里の小川に沿うてゆく、耳から眼から、涼しい風が吹き抜ける。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "手唾をかけて、ヤ、曳、と圧しはじめ、ヨイシヨ、アリヤ／＼／＼、ザブーンと転がす。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "転がすと、一が出ようというやつを親指でなめずりながら、酒は鉢前で、焚火で、煮燗だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　運転手ははずしたタイヤをガバガバガバと地上にひっ転がすと、今度のまた破損の箇処にゴムの継ぎを当て当て、アラビヤ護謨で粘着けると、トントンと叩いて見た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車を転がすなか目に映るのは、ジョン・フェリアさんといとしのルーシィ、闇のなかから私を見つめ微笑みかけるその姿は、この部屋に皆さんを見るのと同じくらいはっきりでした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鵯が南天燭の実、山雀が胡桃ですか、いっそ鶯が梅の蕾をこぼしたのなら知らない事――草稿持込で食っている人間が煮豆を転がす様子では、色恋の沙汰ではありません。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "川舟が上り、雨が降って、眠れる天龍が、起こって雲を呼び、雨を降らし、川底の石を転がすようになっては、死体の捜索は困難というよりも、至難になるであろう。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば子供が雪の上に雪玉を転がすようなもので、雪玉は次第にその大きさを増し、その重さを増し、終には転がることも出来なくなる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かく小さな真珠の粒が軽く銀盤の上に転がすかのやうに、サラ／＼と池の面に音がありました。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいよ、いらないよ」　そういいながらも、慶一は「テイクアウト」ということばを記憶しようと、頭のなかで転がす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤井は両手で鼻を押さえて、仰向けに上体を転がす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が敷ける以前の軽便鉄道、またその以前の単に五六名の壮丁の人力を持つてレールの上をおし転がす人車鉄道の時代には、麦畑の中に棒杭の立つた停留場があつて人々は畑中に降り、崖を下つて部落に着いた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父たちに自殺を押し止められるよりは、電車に轢れた方がましだ、と思った喜助は、いきなり叔父を土間の上につき転がすと、裏口を開いて、真暗な往来へ飛び出した。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は誰かの首を二つ三つ転がすつもりと見えるぞ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "節廻しも巧だが、声を転がす処に何とも言えぬ妙味がある。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして露を吸うように、垂らされる雫が舌のさきに辷ると、　――富士の、白さけ……と幽な幽な声で転がすように唄った。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョンボリ、ほんの真似だけにしといておくんなさいよ」「何だい卑怯なことを、お前も父の子じゃねえか」「だって、女の飲んだくれはあんまりドッとしないからね」「なあに、人はドッとしなくっても、俺はちょいとこう、目の縁を赤くして端唄でも転がすようなのが好きだ」「おや、御馳走様！",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃお酒を飲んだら赤くはなろうけど、端唄を転がすなんて、そんな意気な真似はお光さんの格にないんだから」「あんまりそうでもなかろうぜ。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "盤上に玉を転がす……というのは、古くして新らしい譬えだ。",
              "citation": {
                "source": "球体派",
                "author": "豊島与志雄著",
                "note": "青空文庫"
              }
            },
            {
              "text": "千曳の大岩を転がすなどは朝飯前の仕事である。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、右手で、肩を掴んで真向けに転がすと、半分眼を開いて血に塗れた口を、大きく開けて死んでいたが、顔には、何処も傷が無かった。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮色の深い山際の上瀬から玉を転がすやうな河鹿が啼いてくる。",
              "citation": {
                "source": "三次の鵜飼",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは石を転がすようなものですよ。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると石の方はどんどん転がって行って、ほかの石を幾つも転がす。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪塔王は、俵を転がすように、ごろごろと転がっていましたが、やっと砂原の上に起きなおったところをみると、いつの間にか右手に、妙な形のピストル様のものを持っていました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "グワーンと音がするかと思いの外、呀ッと叫ぶ間もなく、扉はパタリと開き、三人の警官は勢いあまってコロコロと球でも転がすように、室内に転げ込みました。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何のことはない、損なことですけれど、つまりさいころを転がすこと自体が面白いのです。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "波がそれをごろごろ転がすように押して来て、とうとう、ハーキュリーズの立っているすぐ近くの岸に、その底がつきました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを転がすか投げ上げるかして動いている所を横から射止めるのである。",
              "citation": {
                "source": "初旅の大菩薩連嶺",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚は、手拭にくるんで日蔭へ転がす。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
