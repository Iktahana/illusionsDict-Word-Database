        "examples": {
          "standard": [
            {
              "text": "色とりどりの布を使って、素敵なコラージュ作品が完成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誕生日のプレゼントに、家族の写真で手作りのコラージュを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の個展では、複数の素材を組み合わせた実験的なコラージュが展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "△藤岡一氏――『マンドリン』『花甘藍』と題をつけるのはあまりにシャバ気がある、無題とまで徹底できなかつたら、かうしたコラージュ的な仕事を廃した方がいい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここからは音のコラージュだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "創刊号にはこれもなぜか、入れ歯をむき出しにしたカーク・ダグラスの頭を裸のランナーの首の上に載せたコラージュが掲載されている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "凝るとは、たとえば、ウクレレを中心にさまざまな物をコラージュのように配し、ぜんたいとしての雰囲気を出す、というような試みだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
