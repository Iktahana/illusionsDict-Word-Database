    "definitions": [
      {
        "index": 1,
        "gloss": "warp rib weave cotton fabric (from Kokura)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
