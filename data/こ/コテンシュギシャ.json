        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ダリは新しい衣を着た古典主義者にすぎない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルネサンスの古典主義者はラファエロでなくてリオナルド・ダ・ヴィンチであつた。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　先覚者としての薄田泣菫氏　薄田泣菫氏を古典主義者としたのは勿論詩壇の喜劇である。",
              "citation": {
                "source": "人及び芸術家としての薄田泣菫氏",
                "author": "薄田泣菫氏及び同令夫人に献ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし古語を用ひた為に薄田氏を古典主義者と呼ぶならば、「海潮音」の訳者上田敏をもやはり古典主義者と呼ばなければならぬ。",
              "citation": {
                "source": "人及び芸術家としての薄田泣菫氏",
                "author": "薄田泣菫氏及び同令夫人に献ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩壇はかう言ふ薄田氏に古典主義者の名を与へながら、しかも恬然と薄田氏の拓いた一条の大道に従つて行つた。",
              "citation": {
                "source": "人及び芸術家としての薄田泣菫氏",
                "author": "薄田泣菫氏及び同令夫人に献ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルネサンスの古典主義者はラファエロでなくてリオナルド・ダ・ヴィンチであった。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "古典主義者たるべく、あまりに規範を厭ひ、近代主義者たるべく、あまりに刺戟を忌むといふ類ひの人間である。",
              "citation": {
                "source": "十二月的感想",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、また、必ずしも、様式の混合を認めない古典主義者ではありません。",
              "citation": {
                "source": "劇作を志す若い人々に",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ意味で一種の古典主義者なんです。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "古典主義者はこれを指して、近代の批判精神はかくの如くに芸術の退化を意味すると云うかも知れぬ。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
