    "definitions": [
      {
        "index": 1,
        "gloss": "one's bosom friend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
