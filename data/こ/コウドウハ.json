[
  {
    "uuid": "2b0b332d-efa8-57be-8c7a-7a915b5bc05f",
    "entry": "皇道派",
    "reading": {
      "primary": "こうどうは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
