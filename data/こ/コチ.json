      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flathead (esp. the bartailed flathead, Platycephalus indicus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「鯒や黒鯛のぴち／＼はねる、夜店の立つ、……魚市の處は？",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の見は、雫するばかり、水晶の塔かと濡れて光つて、夜店の盤臺には、蟹の脚が白く土手を築き、河豚かと驚く大鯒が反つて、蝦のぶつ／＼切が血を洗つた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱚、魴※、鯒、あいなめ、目ばる、藻魚の類合せて七百籠。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ごとな鯒がその中に跳ねてゐた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、午飯のお誂が持出されて、湯上りの二人と向合う、鯒のあらいが氷に乗って、小蝦と胡瓜が揉合った処を見れば無事なものです。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者は貝のほかに小さい鰈や鯒をつかんだのを誇りにして、煮たり焼いたりして賞翫するのもあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰈の煮付、鯒ならば洗いにでも出来まする。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に夏は魚が豊富であるから、山へ行けば鮎、ヤマメ、イワナ、海へ行けば鯒、鯛、鱸、カイヅと定めて、鮎なら友釣りでやるか、どぶ釣りでやるか、蚊鈎は何を主として用ふるか、或は自分で作るか、カイヅの仕掛けは、餌は、場所はと、一種目を深く釣りこんでゆくことが肝要である。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海鳥型」の釣人は、主として海を翔り、十尋から三四十尋の深所で、赤鯛、スズキ、黒鯛、サバ、太刀魚、鰺、鯒、カレヒ、ブダヒ、モヨ、カサゴ、タコ、イカ、アイナメなどを釣る。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "川では鮎、鱒、鯉、鮒、ニゴヒ、ハヤ、モロコ、ヤマベ、イハナ、ヤマメ、タナゴ、鰻、鯰、鰌、ハゼ、イナ、などが釣れ、海では、鯛、鱸、鯒、鰈、鰺、鱚、烏賊、蛸、カサゴ、アイナメ、ソイ、平目、小松魚、サバ、ボラ、メナダ、太刀魚、ベラ、イシモチ、その他所によつて、百種以上のものが釣れる。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の沙魚釣に、沙魚船を呼ぶはまだしも、突船けた船の、鰈、鯒、蟹も択ぶ処なく、鯉釣に出でゝ鰻を買ひ、小鱸釣に手長蝦を買ひて帰るをも、敢てしたりし。",
              "citation": {
                "source": "釣好隠居の懺悔",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その骨格から判斷すれば、多分｜鯒だつたらうと思ふ。",
              "citation": {
                "source": "海螢の話",
                "author": "神田左京",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論海螢を採集するための餌は鯒ではないのだから、その鯒はどうかして採集用の甕の中に入つたものであらう　所が海螢を採集するために用ゐる餌は、流石の海螢にでも、中々容易に食へないものが選んである。",
              "citation": {
                "source": "海螢の話",
                "author": "神田左京",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に鯒が入つたのだから、鯒の運命は勿論きまつてゐる。",
              "citation": {
                "source": "海螢の話",
                "author": "神田左京",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらはもともと観念といふものを必要としてをり、衣食住だけを全てだとは思はない人種だからである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ舟にのりて行かば、くるほしきなみの亂れもここちよく、ちのみごの夜びえする、あやしきこゑもきかであるべきに、ふるとせひとにかくれて、わがはぐくみしいろぐさのはや涸れぬとぞ、けふきけば薄葉に涙しをるる、よしゑやし、悲しきものはあだがたき、君ならなくに、はやも我が世をのがれいでばや。",
              "citation": {
                "source": "浮名",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達がゐないのが淋しいきり、そのほかでは都よりも寧ろこちらにゐる方が退屈はしません。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それといふのが、これが都より田舎へ出すのであれば、何音楽会に行きました、何展覧会に行きました等々の、謂はば事件があるわけですが、こちらでは、何を豊富に感じてゐるとも、それが事件の形を採りませんので、書くことがまるでないやうな有様にもなるのだと、今更思ひ知る次第です。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろこちらから云へば、都の人が没個性的であるのでもあるのです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろはそれがたのしみさ」言い終えたら、鼠のような身軽さでちょこちょこ走り去った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらで、なんとか致しましょう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉と眉との間に皺を寄せたり伸ばしたりしながら、竿のあちらの端とこちらの端をかはるがはるに見てゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外の対坐は、こちらからは希望してかゝらないこと。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物の背後の、ブランコのある所を見たいと思つて建物の横を廻りかけたが、何しろ休暇中だし、朝の五時半であつたし、小使の女房か女学部の舎監であつたか知らないが、炊事場の小窓から一寸顔をのぞけて、ケゲンさうにこちらを見たから、諦めてコソコソと引返した。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯のあちこちとするや小家がち「籬落」という題がつけてある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あちこちとする」という言葉の中に、鶯のチョコチョコした動作が、巧みに音象されていることを見るべきである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ蕪村の句で「鶯の鳴くやあち向こちら向」という句も、同様に言葉の音象で動作を描いてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば鶯のあちこちとするや小家がち　　　蕪村春の海ひねもすのたりのたり哉　　　蕪村　の如く、「あちこちとするや」の語韻から、鶯のチョコチョコとする動作を音象し、「のたりのたり」の音調から春の海の悠々とした印象を現わしているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に深く交際のない人には、一層発作が出易く危険なので、自然こちらから交際を避け、つとめて会わないようにして来たのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ多くの一般の人々は、僕の変人である性格を理解してくれないので、こちらで自分を仮装したり、警戒したり、絶えず神経を使ったりして、社交そのものが煩わしく、窮屈に感じられるからである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
