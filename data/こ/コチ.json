[
  {
    "uuid": "13f39fc1-a87d-5a6e-902a-c1e2e71a006a",
    "entry": "鯒",
    "reading": {
      "primary": "こち",
      "alternatives": [
        "コチ"
      ],
      "is_heteronym": false
    },
    "grammar": {
