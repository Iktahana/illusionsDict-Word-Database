    "definitions": [
      {
        "index": 1,
        "gloss": "omitting the rest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この文は鹿持翁の筆なればおおよそ小百年前のことにして孕のジャンはこのほどの昔よりもすでにその伝があったことが知れる（後略）。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　むす子の手紙三――（前略）ですからもうあんな作品を書かないで下さい。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　むす子の手紙四――（前略）僕はいわゆる××と芸術と云うものの間に大きな溝があると思うのです。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　かの女はむす子が曾て、あれだけの感情家である自分の感傷を一言も手紙に書いて来たためしのないのを想い出しながら、書きかけの原稿紙にいつかこんな字を書いていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　このような思想を、古い人情主義さ、とか言って、ヘヘンと笑って片づける、自称「科学精神の持主」とは、私は永遠に仕事を一緒にやって行けない。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　あまり抜書きすると、出版元から叱られるかも知れない。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　べつに、いいところだから抜書きしたというわけではない。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう、只今徹夜にて仕事中、後略のまま。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）木のお扇子　坊や、　パパは豊原という樺太でのいちばん賑やかな町へ来ました。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、（前略）城より落つるもの三四人御座候処に、命を御助けなされ、其上金銀を下され、剰へその在所の内にて当年は作り取に仕り（後略）一、天下様仰出でられ候は（中略）、切利支丹の儀は、当歳子によらず御果しなされ候に相定め申し候。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）一、城中大将四郎と申す儀、隠れなく候。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　言々誠意の溢れるのを見る事が出来る。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）〔一九三六年九月〕",
              "citation": {
                "source": "「夜明け前」についての私信",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天は天民の後略である。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）』――第六巻第六号『愛生児童文芸』所載。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながらさういふ疑義があります以上は、これを明かにして置くといふことは法律を制定する上に必要でありますから……（後略）　因に水野氏はベルヌ条約にわが代表として出席され、日本における著作権法の起草者であり、またこの道の権威であることはいふまでもない。",
              "citation": {
                "source": "演劇・法律・文化",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　　　　　　　＊（前略）昨年は無経験に加ふるに、収穫半ばに不時の天災に出会ひし為め全く失敗したものの、今年は多少様子もわかり、且つは幾分考ふる所もあり、こゝ一番と努力せしこととて今後非常の天変などのない限りは多少の収益が見られることと思ふ。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　　　　　　　＊（前略）……もとより創業費とて不充分なりし事故、如何とも進退出来ざるやうになり、昨年｜極末遂に七百弗足らずの負債を背負ひ農業の方手を引き候。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　　　　　　　＊（前略）この五日より洗濯業研究に着手致し候。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　　　　　　　＊（前略）一昨々年春以来他へ転居候為め、御書面昨日｜漸く落手致し候次第、その後の御不沙汰何とも申訳｜無之候。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）（大正六年十月）",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　さて、大正七年五月には東京の帝劇へ出て、帝劇へはそれから毎年行くようになった。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "此書｜悉くを団子坂に送りやるべきか、奈何（後略）　次に昭和に入ってからのを数通載せます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く単純にギャバ族とかアプレとか一口に言って片づける筋合の物ではないと思う（後略）」（原文のまま）　この文章の要点を飜訳すると、若い者が今の社会に夢をもっても、社会の方が余りに物質的であるから、ロマンチックな夢はくずれ、リアリスチックにならざるを得ない。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の女（前略）夕日が我々の頭に落ちてくる度に彼の女達の肉体が一つづゝ田舎から失くなつてしまつて町の色香に呑まれてゆくのだ貧しい娘はすぐさらはれてこの世から色を失つては深夜の月のやうに燃え失せるのだ（後略）我身知らず彼女は玉のやうに掴みどころがなかつた。",
              "citation": {
                "source": "〈我が愛する詩人の伝記〉（補遺）",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　終戦後、私はたのまれて山村暮鳥や萩原朔太郎の詩の選詩集出版について、多くの出版書店から相談をうけたが、佐藤惣之助の詩の選集に就ては一冊もたのまれなかったし、それを出版する本屋は一軒もなかった。",
              "citation": {
                "source": "〈我が愛する詩人の伝記〉（補遺）",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　前橋市にはじめて萩原朔太郎を訪ねたのは、私の二十五歳くらいの時であり今から四十何年か前の、早春の日であった。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）　第二夫人と別れてから、だいぶ経ってからかれに愛人ができていた。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）」という一節がある。",
              "citation": {
                "source": "それからそれ",
                "author": "書斎山岳文断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後略）」『日本風景論』、『日本山水論』、『日本アルプス』その他の山岳書を読み耽った頃、私は『山恋ひ』という三分真実七分空想の中篇小説を書いた。",
              "citation": {
                "source": "それからそれ",
                "author": "書斎山岳文断片",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
