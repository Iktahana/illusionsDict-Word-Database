    "definitions": [
      {
        "index": 1,
        "gloss": "mixed race",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "露西亞人の混血兒で金髮に黄色い皮膚をした娘だつた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリアンとの混血児の上海からこの土地に稼ぎにやってきた踊子の鳩胸、その偉大な女性の耕作地にこだまするサキソフォンの反響、かの女は、いつも踊場に蜜月の旅をつづける。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い日本服をきた混血児が、なよ／＼とした腰に支那人の中学生の腕をからませて踊っていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペイン女が、ヴェリストのアメリカ女が、権能を知る英国女が、ユーモアを感じさせるロシア女が、流行の尖端を自覚した日本女が、弛緩したような朝鮮女が、ニグロの女が、そしてノラの属する混血種の支那女が黄浦灘を横切って蘇州路へ、北京路へ、南京路へと立ち去って行く。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の男の子はあの頃四つくらいで名はエンリコとかいうそうだが、当り前の和服を着て近所の子供と遊んでいるのを見ては混血児と思われぬようであった。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば要するに詩人とは、生活者と芸術家との混血児で、しかも両者の血を多量に受けた、矛盾の中の美しい調和である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山姫というのは神と山獣との混血児みたようなものだそうです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "褐色味を帯びた瞳が、青く底光る眼の中に、ぱちりと澄んで、何かうるんだような感触が、その瞳から迫り、ふと混血児のようであった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣人の宣教師、混血児のベンさん気まぐれな禿頭、青い眼鏡をかけては街を歩行き、日曜の日には御説教。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのアンというのはまだ十九か二十歳で、原住民には珍らしい色白の綺麗な俳優で、なんでも本当の原住民ではない、原住民とイタリアとの混血児だとかいう噂でしたが、なにしろ声もいい、顔も美しいというので、それが一座の花形で、原住民はもちろん、外国人のあいだにも非常に評判がよかったのです。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）通訳の混血児サレ・テーラー、外、少年二人。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間前、チーフ・ジャスティスは混血児の通訳をそそのかして、私に不利な証拠を掴ませようとあせっていたし、私は私で今朝も、此の男を猛烈に攻撃した第七回目の公開状をタイムズへ書いていた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラオ女には珍しく緊つた顏立で、恐らく内地人との混血なのではなからうか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ギボンと云はれても、私にはあの浩瀚なローマ衰亡史の著者しか思ひ當らないのだが、よく聞くと、パラオでは相當に名の聞えたインテリ混血兒（英人と土民との）で、獨領時代に民俗學者クレエマア教授が調査に來てゐた間も、ずつと通譯として使はれてゐた男だといふ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の養父たる混血兒のことは前に一寸述べたが、パラオは母系制だから、之はマリヤンの家格に何の關係も無い。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見日本人との混血と分る顏立だが、二人とも内地人の標準から見ても確かに美人である。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラオ女には珍しく緊った顔立で、恐らく内地人との混血なのではなかろうか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ギボンといわれても、私にはあの浩瀚なローマ衰亡史の著者しか思い当らないのだが、よく聞くと、パラオでは相当に名の聞えたインテリ混血児（英人と土民との）で、独領時代に民俗学者クレエマア教授が調査に来ていた間も、ずっと通訳として使われていた男だという。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の養父たる混血児のことは前にちょっと述べたが、パラオは母系制だから、これはマリヤンの家格に何の関係も無い。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見日本人との混血と分る顔立だが、二人とも内地人の標準から見ても確かに美人である。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラオ女には珍しく緊つた顔立で、恐らく内地人との混血なのではなからうか。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早よう云うてみたなら詐欺と盗人の混血児だすなあ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二年前に横浜の怪しい家で知つた獨逸人の混血児といふ女の肥つた肉体もその中に交つてゐた。",
              "citation": {
                "source": "青い紐",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度又ハ亞佛利加ノ住民ガ全然英人ト人種ヲ異ニセルニ對シテ、日鮮人ハ古來ノ混血融合ノミナラズ同一人種中ノ最モ近キ異民族ナル點ニ於テ屬邦タルベカラズ又植民地タルベカラズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも私は、その儘町の家へ行くのが厭で、港町の、混血児の酌婦がゐるホテルへ走つて、倒れるまで踊つた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "などゝ混血児の女給に賞讚されると、烏頂天になれるではないか！",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃Ｆの小さな従妹であつた混血児のＮが、今では大きな娘になつてゐた。",
              "citation": {
                "source": "悪筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｅ――といふ混血児の小娘だ、混血児は軽蔑されるかな、そんな馬鹿な話はあるまいな、だが頓興にも程があるぢやないか、そのＥ――が、Ｅ――が、俺の妹だなんて、気味が悪いな、気味が悪いな！",
              "citation": {
                "source": "明るく・暗く",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｎは、彼の見たことのない混血児の妹なのだ。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
