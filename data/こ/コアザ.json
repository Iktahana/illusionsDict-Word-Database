    "definitions": [
      {
        "index": 1,
        "gloss": "small administrative unit (of a village)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "景隆｜小字は九江、勲業あるにあらずして、大将軍となれる者は何ぞや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには館の内と云う小字があって、祐泰の宅趾と云われ、祐泰の力持をしたと云う石もあった。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは摂津国屋の嗣子で、小字を子之助と云った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "備前の国赤磐郡太田村大字万富小字梅という処に山形尊と云う盲人があった。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むづかしくいふと宮崎縣東臼杵郡東郷村大字坪谷村小字石原一番戸に生れた。",
              "citation": {
                "source": "鮎釣に過した夏休み",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小字に長者屋敷と云うは、全く無人の境なり。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――　利章の父栗山利安は、素播磨の赤松氏の支流で、小字は善助、中ごろ四郎右衞門と稱し、後に備後と名告つた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "川添家は同じ清武村の大字今泉、小字岡にある翁の夫人の里方で、そこに仲平の従妹が二人ある。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のゐる寄生木も隣りの怒山も、その他五つの字名の小区域と共に竜巻村といふものゝ中の小字であり、俗称であつて、登録された名称ではないのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は謹厳実直の郷士で、一滴の酒も嗜むことなく夙に竜巻村小字界隈の風教改革運動に東奔西走して寧日もなき人であります。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "発戸の右に下村君、堤、名村などという小字があった、藁葺屋根が晨の星のように散らばっているが、ここでは利根川は少し北にかたよって流れているので、土手に行くまでにかなりある。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "多く習ひて得たる様にはあらでただ無造作に書きなせるものから大字も小字も一様にして渋滞の処を見ず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎は小字を恒吉といった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉民は小字を銀之助という。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "津山邸に館はあっても、本丸に寝泊して、小字の銀之助を呼ばれていたものと見える。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "光徳は小字を徳治郎といったが、この時｜更めて三右衛門を名告った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "平井氏、名は｜俊章、字は伯民、小字は清太郎、通称は修理で、東堂と号した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小字は三吉、通称は道陸である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "令図は小字を慶次郎という。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六十五　抽斎は平姓で、小字を恒吉といった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三坊とは成善の小字三吉である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三坊は成善の小字三吉である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄三郎はよほど前に小字を棄てて徳安と称していたのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その八十四　小野元秀は弘前藩士｜対馬幾次郎の次男で、小字を常吉といった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次が二世勝三郎東成で、小字を小三郎といった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "壻は新宿の岩松というもので、養父の小字小三郎を襲ぎ、中村楼で名弘の会を催した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだ幾くならぬに、小三郎は養父の小字を名告ることを屑しとせず、三世勝三郎たらんことを欲した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "字は大升、別号は隆升軒、小字は門次郎、長じて元安と称し、後長安と改めた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二子義焉子元淵、名は兼時、小字は平二郎、後俳人落柿舎去来となつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小字は鉄三郎と云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
