    "definitions": [
      {
        "index": 1,
        "gloss": "good taste (food)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僅に醤油の味のみが數年來の彼の舌に好味たるを失はなかつたが、挽割麥の勝つた粗剛い飯は齒齦が到底それを咀嚼し能はぬのでこそつぱい儘に嚥み下した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "『韓非子』に、桓公好味。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうすることによって中身はエキス抜きにならないから、噛むと魚の好味が出て、歯ごたえもあり、至極美味い。",
              "citation": {
                "source": "道は次第に狭し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗寂の好味｜将に佳境に進まんとする時、破笠弊衣の一｜老叟わが前に顕はれぬ。",
              "citation": {
                "source": "松島に於て芭蕉翁を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくする中に、五右衛門はや帰りて、いざ／″＼殿下まゐり候へとて、いかにもきらびやかなる器物に、好味をつくしける美膳をぞすへにける。",
              "citation": {
                "source": "五右衛門と新左",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山と盛る鹿の肉に好味の刀を揮う左も顧みず右も眺めず、只わが前に置かれたる皿のみを見詰めて済す折もあった。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「降って十六七世紀の頃迄は全欧を通じて孔雀は宴席に欠くべからざる好味と相成居候。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "承りしところ、ことのほか御能達のよし、まず初めてのことなれば、互い先にて参るべし」と、口には言えど、心にはなんのへろへろ碁、ただ一番に打ちつぶしくれんずと思い、盤面に向かい始めしところ、さしたる好味の手も見えねども、ややもすれば危うきことたびたびなり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰻の如きは焼き方から蒸しの具合に好味があらうけれども蟇の如きに至つては、焼いて醤油をたらすや即ち彼のぜいたくな大谷光瑞伯をして舌鼓を打たしむる底の妙味を有するといへば坊やんさぞ満足して舌鼓を打ちつゝ大きくなつたことであらうと思ふ。",
              "citation": {
                "source": "秋風",
                "author": "飯田蛇笏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一たい僕は、なぜこうみんなにいやがられるのだろう。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうみえてもなあ、おれは天界ホテルの令嬢マリよ。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "与吉はとみこうみて、肩のあたり、胸のあたり、膝の上、跪いてる足の間に落溜った、堆い、木屑の積ったのを、樟の血でないかと思ってゾッとした。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうみだれてしまっては仕方がない。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とみこうみたる目の優しさ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうみえてもまだ貴樣等の臺所の土間におすはりして、おあまりを頂戴したこたあ、唯の一どだつてねえんだ。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは※の気の迷いだ」と言うと、渠は信じがたげな眼で、一同を見返し、さて、それから、なぜ自分はこうみんなと違うんだろうといったふうな悲しげな表情に沈むのである。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このおねえさまは、たれよりもむこうみずな子でしたから、大きな川が海にながれだしている、そこの川口をさかのぼっておよいでいってみました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、四ばんめのおねえさまは、それほどむこうみずではありませんでしたから、そこで、ひろい大海のまんなかに居ずくまったままでしたが、でもそこがどこよりもいちばんうつくしかったと話しました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "古高様の中間の六松めが、さっき見せびらかしていた品でごぜえますよ」　もっけもない事を言いましたので、何気なく手にとりあげて、とみつこうみつ打ち調べているとき、ころり、と叺の中から下におちたものは、丁半バクチに用いる象牙細工の小さな賽ころです。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "按摩でもいたしおるか」「じょ、じょうだんじゃござんせんぜ、こうみえても、この家の家主でござんすよ」「さようか、失敬失敬。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "はばかりながら、こうみえてもいきな江戸っ子ですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　竈神の話はこうみてくるといずれも福神の由来談になっている。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はこうみえても動物じゃないんだよ。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうみて来ると、民主主義文学の創作方法についていろいろ云われているその問題も自らはっきりしてくると思います。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうみても複雑なる差別的方面のあるとともに、単純なる平等的の方面を否定するわけにいかぬ。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "結論――自分の立場",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうはいっても須磨子自身も、先方の思いやりなどはちっとも出来ないたちで、噂だけか、それとも誠のことか、ある時抱月氏の令嬢たちに手紙をやって、これから貴女がたは私をお母さんと思わなければなるまい、といったとか、自信も勇気も、過ぎると野猪のむこうみずになるが、彼女が脱線したのには一本気な無邪気さもある。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こうみずからそれを打ち消した。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処へ」と聞きかえさざるを得なかった、彼は私の姿をとみこうみしながら、「いや私達はユンクフラウへ登るんですよ、明日の朝」、「ほう、登れますか……」は間がぬけた質問だったが、此の場合どうも已むを得なかった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの主婦は私達をとみこうみして、負傷の様子や戦場の模様を尋ねたりした、その頃はまだ戦争の初めで、印度人の加わらない時分であったが、どこの国民と間違えたかは、今だに二人の疑問になっておる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうみて来ると、なるほど、わが「新劇」だけには、在来の「翻訳調」なる生硬なお談義以外、われわれの耳に快よく響き、「考えさせる前に感じさせる」ていの、すぐれた雄弁の要素は、ほとんど見当りません。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
