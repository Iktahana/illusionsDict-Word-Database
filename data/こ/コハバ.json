        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お神が切れるところから、彼は来るたびに何かおつな手土産をぶら下げ、時には役者の描き棄てた小幅などをもって来て、お神を悦に入らせるのに如才がなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かの女と手を引き合ひながら、また稻の間のあぜ道を縫つて歩いたり、筆の軸の長さほどもない小幅の流れの小さい田螺を――お鳥の毎年起きる脚氣の藥りだと云ふので――拾つて見たりして、宿へ歸つて來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖母を畫けりと覺しき小幅の前に捧げし燈明は既に滅えて、燈心の猶｜燻るさま、一點の血痕の如し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "徽宗皇帝、梁楷、馬遠、牧渓、それから、この夏珪、みんな北宗画の巨頭なのだ、どんな小幅だって五千円もする。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭舜挙の筆だと伝えられたものに、大根と蟹とを配合して、鋭い線で描き上げた小幅を見たことがあった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな小幅だつて五千円もする。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、一つ何でも結構で御座いますから、先生の小幅と御交換が願へましたら……なに、ほんの一寸した小幅で結構でございますから。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつしよに裏山をぶらつく、墓場の徳利を拾つたり、或は竹田小幅を売り飛ばした不孝話を聞く。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして父がくれた濃い牡丹色のベルベットの小幅のリボンを飾り結びにしてつけた。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北側の間半の壁には坊さんの書いた寒山の詩の小幅が掛つて居るが極めて渋い字である。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "徽宗の桃に鳩の絵｜僅かに長さ五、六寸に広さ六、七寸なる小幅が同じく千両なり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "隱居と娘と下女は階下に休み、交代で泊りに來る男達は、二階の六疊に寢ることになつて居りますが、その二階もなか／＼に捻つて居り、その頃町家に珍らしく、孟宗竹の太い柱をつけた置床に、怪し氣な山水の小幅が掛けてあります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美男番附",
                "note": "青空文庫"
              }
            },
            {
              "text": "覗いて見ると、至つて簡素な佛壇で、阿彌陀如來の小幅を掲げ、佛具も貧しく、至つて粗末なものを並べてあるだけです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "隱し念佛",
                "note": "青空文庫"
              }
            },
            {
              "text": "放心状態でいたのでコマドの内側にある小幅のカーテンが、無慈悲にさっと怒ったように引かれたので、私は驚いてそこに顔をふりむけた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は元来この確信とそれからどうも従来の日本画には慊らぬところから、那辺までも新らしい絵を作つて見たい／＼と思つて居つたので、以前に描いた小幅の『落葉』『杉木立』などを参考にして、それに代々木附近の自然の景色から材料を蒐集して漸く出来上つたのが昨年出品した『落葉』であつたのだ。",
              "citation": {
                "source": "画界漫言",
                "author": "菱田春草",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時翁の言に「徽宗皇帝など真蹟はただの一つもありません、多分これはよかろうと思うのは小幅の山水が某家にあるだけですよ」と。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "七万円で売りたいという某子爵家の蔵品、華山の四季の花の屏風や、二千円の抵当に取った大雅堂の屏風がいずれも真赤な偽作で鑑定家を驚かした悲喜劇もあり、この種の偽物の小幅に至ってはその余りに多きに呆れざるを得ない。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人肌とはこれか欲のなかったその頃の画家　狩野芳崖先生が明治の初年に描いた「犬追物」の図、横物の小幅ながら極彩色の入念の作、今は遺作中の珍品だが、当時依頼主が謝礼として差しだしたのは金七円、先生見るより「これでは多過ぎます」と手を引っ込ましたという、うそのようだが事実である。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "老農火雲むらがり翔べば、　　そのまなこはばみてうつろ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは驚き慌てゝ探るやうに手舵を握ると、夫れを包んだカンバスはぐつしより濕つてかん／＼にこはばつてゐた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "緊張し切つた彼れの神經は不思議な幻覺に働かれて、妻のこはばつた手が力強く彼れの無謀を遮ぎるやうにも思つた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうマヂエル様と呼ぶ烏の北斗七星が、大きく近くなつて、その一つの星のなかに生えてゐる青じろい苹果の木さへ、ありありと見えるころ、どうしたわけか二人とも、急にはねが石のやうにこはばつて、まつさかさまに落ちかゝりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　姉さん、ここはばらがきで、「私にやろう……と云ったんですもの。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀と雪陽は薄し、庭の雪、凍みこほり、こはばりぬ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻穴がキン／＼して、口でも耳でも鼻でも、こはばつてちつとでも動かせば、それつきり、割れたり、ピリ／＼いひさうでたまらなかつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "……瞬間にその思ひがひらめくと、駿介の全身はへんにこはばつたまま動かなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはばつた表情で受けとめ、ふたたび視線のそれるまでの瞬間の激情におちかはからくも踏みこたへたのである。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "感情の波動のこはばつてゐる時は香水の表情は、よく聞きとれない。",
              "citation": {
                "source": "「香水の表情」に就いて",
                "author": "――漫談的無駄話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二者は、放射する外貌は同じやうであるけれど、後者の方は前者に比して、表情線がこはばつてゐて、前者のやうな豊富な言葉の波動と幻想量とを有してゐない。",
              "citation": {
                "source": "「香水の表情」に就いて",
                "author": "――漫談的無駄話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはばかに広かった。",
              "citation": {
                "source": "江木欣々女史",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
