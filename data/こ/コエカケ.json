    "definitions": [
      {
        "index": 1,
        "gloss": "saying something (to someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三人声かけあいて登るに道けわしければ汗は滝なして降る。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずかずかと歩み寄りて何者ぞと声かけ、燈をかかげてこなたの顔を照らしぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりよく似たれば、姉上と呼ばむとせしが、よしなきものに声かけて、なまじいにわがここにあるを知られむは、拙きわざなればと思いてやみぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「は、」と声かけて、するりと抜けた、土塀の上を足溜。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　玄関から声かけると、主婦らしい小肥りの女が出て来て、三村加世子がいるかと訊くと、まだ冬籠り気分の、厚い袖無しに着脹れた彼女は、「三村さんですか。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりよく似たれば、姉上と呼ばむとせしが、よしなきものに声かけて、なまじひにわが此処にあるを知られむは、拙きわざなればと思ひてやみぬ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　われは此方に居て声かけぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と高く声かけぬ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マダム、今夜はスキ焼でっか」階下から女給が声かけた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くそ、逃がすか」　広巳を追って出た定七は、そこでも大声かけた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端にちりりんと鈴の音、袖に擦合うばかりの処へ、自転車一輛、またたきする間もあらせず、「危い、」と声かけてまた一輛、あッと退ると、耳許へ再び、ちりちり！",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどれもみな疲れた風をして黙り込んでいる顔を見るとなく見廻していたが、やがてＫ―君に声かけた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えろう此頃は郵便船も見識が高うなったのう、万作さん」　伊勢崎君は汗を拭き拭き船頭に声かけた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、彼は吸い込んだ息がなくなってだんだんに苦痛が激しくなると、遠くに花江の顔のもう早や消えようとした瞬間を待ってはっとかけ声かけて竹を割った。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほっとした気持で「おい」と声かけると、彼女は振り返ったが、いくらか狼狽気味で顔を紅くした。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしている処へ、瑠美子が「まま、まま」と声かけながら段梯子をあがって来た。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は婦人休憩室へ入って、赤い縞の壁紙などを見まわしていたが、ふと庸太郎が父に声かけた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　などと湯殿の方へ声かけたりしていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と軽い東京弁で、若い衆に声かけながら降りた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と小野は向う側から高調子で声かけた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と舌のだらけたような調子で声かけた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国は、取っておいた鯵に、塩を少しばかり撒って、鉄灸で焼いてくれとか、漬物は下の方から出してくれとか、火鉢の側から指図がましく声かけた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女主は帳場の奥から、帰って来たお庄に声かけた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、下宿の主婦は裏口から声かけて上って来た。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて下から声かけられて、母親が板戸を締めはじめると、お庄もむっと黴くさい部屋から脱けて、足元の暗い段梯子を降りて行った。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　船長ノルマンは、船橋のうえから、甲板へこえかけた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
