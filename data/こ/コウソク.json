  {
    "uuid": "c6912e20-f883-51fb-8076-408eb2965f0b",
    "entry": "港則",
    "reading": {
      "primary": "こうそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
