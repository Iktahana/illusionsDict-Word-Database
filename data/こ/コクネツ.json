        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恐ろしき沈黙ふたたび酷熱の日ざしにただれ、ぺんき塗褪めし看板毒滴らし、河岸のあちこちちぢれ毛の痩犬見えて苦しげに肉を求食りぬ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "驟雨またひといくさ、走りゆく雲のひまよりかろやかに青ぞら笑ひ、日の光強く眩しく野はさらに酷熱のいろ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "酷熱の屋根裏に籠居をつづけた。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳩羽いろをした果しない蒼空が、エロチックな穹窿となつて大地の上に身をかがめ、眼に見えぬ腕に佳人を抱きしめながら、うつつをぬかしてまどろむかとも思はれる、静けさと酷熱の中に燃える日盛りの、この堪へがたい暑さ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十六日（晴）　酷熱。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十七日（晴）　酷熱、又、酷熱。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "酷熱の赤道の恐るべき芽生月。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらきのふまでの街頭歌曲の寵児たちは九夏三伏の酷熱裡を或は南方の野に転戦したり、或はまた埒もなき軍用工場で一職工として酷使されてはしまつてゐたことだらう。",
              "citation": {
                "source": "旧東京と蝙蝠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの人々は、乏しい水をたよりにして、百二十度の酷熱を冒し、各種の高級蔬菜の栽培に惨憺たる苦心を払った。",
              "citation": {
                "source": "アメリカの沙漠",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……汽笛の音をきいてたら、どこか遠いところへ行きたくなってんの」　久我は葵のそばへ椅子をひいてきて掛けながら、「……（風には竜眼の香り、雲にはペタコのこえ、酷熱のいいようなき楽しさ）……僕はもういちど亜熱帯で暮したい。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "当所は昨今酷熱の候にして、わが八月の暑気以上なり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃及人は仕合わせに、アッパア、イジプトの沙漠と石山とを持っていたために、酷熱や他の自然的運命に呑み込まれずに、あの愛すべき芸術を産んだのではあるまいか。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんぼなンでも、この酷熱に、昼休みも与えぬのは、余りにむごい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽が高くなると、きょうも酷熱である。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
