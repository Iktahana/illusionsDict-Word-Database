[
  {
    "uuid": "6a63aae6-e9fb-5496-8a6b-9a9b86967196",
    "entry": "公算",
    "reading": {
      "primary": "こうさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
