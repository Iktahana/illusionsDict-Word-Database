[
  {
    "uuid": "cde7ed64-fb72-597d-bc2b-ab6b16a0e94a",
    "entry": "交合",
    "reading": {
      "primary": "こうごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sexual union",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死者を納れる石棺のおもてへ、淫らな戯れをしている人の姿や、牝羊と交合している牧羊神を彫りつけたりした希臘人の風習を。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "交合至上主義と言っても、意味は同じである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し人間と猩々と交合させたら、其間に子が出来て、それが生存するだらうかと。",
              "citation": {
                "source": "尼",
                "author": "DAT FLEESCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "八足の正中に一足あるをいうと記せるごとき、どうもわが邦にも交合に先だって一足が特に長くなり体を離れてなお蠕動する、いわゆる交接用の足（トクユチルス（第五図））が大いに発達活動して蛇に肖た蛸あり。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "第５図　貝蛸の雄の交合用の足まさに離れ去らんとするところ『続歌林良材集』に、菖蒲が蛇になる話あり。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『松屋筆記』五に浅草観音に鶏を納むるに日を経れば雌鶏必ず雄に変ず、仏力にてかくのごとしとあるが、霊境で交合したり雛を生み、ピーピー走り廻られては迷惑故、坊主が私かに取り替えたであろう。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "西藏教の秘密神像には、交合を實現して居るのがある、またわが國でも、聖天の樣な教へには之を主として居るさうだ。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば僕も一茶のやうに交合記録を書いたとする。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又産児を免るべき科学的方法並びに道徳的論も略完全に具りたれば当代の女人の必しも交合を恐れざるは事実なるべし。",
              "citation": {
                "source": "娼婦美と冒険",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども畢に交合は必然に産児を伴ふ以上、男子には冒険でも何でもなけれど、女人には常に生死を賭する冒険たるを免れざるべし。",
              "citation": {
                "source": "娼婦美と冒険",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し常に生死を賭する冒険たるを免れずとせば、絶対に交合を恐れざるは常人の善くする所にあらざるなり。",
              "citation": {
                "source": "娼婦美と冒険",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし又天下の女人にして悉交合を恐れざること、入浴を恐れざるが如きに至るも、そは少しも娼婦型の女人の増加せる結果と云ふこと能はず。",
              "citation": {
                "source": "娼婦美と冒険",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば娼婦型の女人は啻に交合を恐れざるのみならず、又実に恬然として個人的威厳を顧みざる天才を具へざる可らざればなり。",
              "citation": {
                "source": "娼婦美と冒険",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして桂子との交合。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私は、桂子の肉体と違う女と交合する欲望はない。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子の話だと、世の中には、そうして他人が横に寝ていることに刺激を感じ、交合を好む男女がいるそうだが、私はふたりだけの時は、思い切って開放的で恥知らずの交合を好む癖、誰かに見られていると思うと、それだけで、まるで勇気を失ってしまう男なのだ。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雅は玉瀾を娶った時に交合のことを行わなかったかも知れない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその故に交合のことを知らずにいたと信ずるならば、――勿論その人はその人自身｜烈しい性欲を持っている余り、苟くもちゃんと知っている以上、行わずにすませられる筈はないと確信している為であろう。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雅は玉瀾を娶つた時に交合のことを行はなかつたかも知れない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその故に交合のことを知らずにゐたと信ずるならば、――勿論その人はその人自身烈しい性欲を持つてゐる余り、苟くもちやんと知つてゐる以上、行はずにすませられる筈はないと確信してゐる為であらう。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "quemoo の原形 quemal の訳は単に「生きる」と云ふよりも「飯を食つたり、酒を飲んだり、交合を行つたり」する意味です。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の神はこの二匹の河童に『食へよ、交合せよ、旺盛に生きよ』と云ふ祝福を与へました。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "quemoo の原形 quemal の訳は単に「生きる」というよりも「飯を食ったり、酒を飲んだり、交合を行なったり」する意味です。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の神はこの二匹の河童に『食えよ、交合せよ、旺盛に生きよ』という祝福を与えました。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見したところ、ダンスじゃなく、やゝ交合に近接した領域のもので、女学生、女事務員とおぼしき方々がしかと男にしがみついて恍惚のていでいらせられる。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さる夏の日、ウチの池で蛙のむれが交合し、恍惚と浮沈しつゝあったのを思いだしたが、あれよりも、ギゴチない。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "北斎は交合を描いて猥感を拒否しているが、これは作者の魂の深さと、趣味教養によるものであろう。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チークダンスは、ダンスを踊って交合の低さとワイセツでしかない。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその見えない天の川の水をわたって、ひとりのこうごうしい白いきものの人が手をのばしてこっちへ来るのを二人は見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりは、こうごうしい気分でいっぱいになりました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
