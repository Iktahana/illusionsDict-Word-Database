[
  {
    "uuid": "50030177-bcdc-5e6f-b8d9-f27cef0114de",
    "entry": "狐狸",
    "reading": {
      "primary": "こり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "foxes and tanuki",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "馬場の蒼黒い顔には弱い西日がぽっと明るくさしていて、夕靄がもやもや烟ってふたりのからだのまわりを包み、なんだかおかしな、狐狸のにおいのする風景であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼きましても狐狸の悪い臭がしましょうかと、心残りがしましたのに、貴下、よく、思い切ってそうおっしゃって下さいました。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論この内にも、狐狸とか他の動物の仕業もあろうが、昔から言伝えの、例の逢魔が時の、九時から十一時、それに丑満つというような嫌な時刻がある、この時刻になると、何だか、人間が居る世界へ、例の別世界の連中が、時々顔を出したがる。",
              "citation": {
                "source": "一寸怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……妖怪、変化、狐狸、獺、鬼、天狗、魔ものの類、陰火、人魂、あやし火一切、生霊、死霊、幽霊、怨念、何でも構わねえ。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊びに来て下さるも可し、夜伽とおっしゃるも難有し、ついでに狐狸の類なら、退治しようも至極ごもっともだけれども、刀、小刀、出刃庖丁、刃物と言わず、槍、鉄砲、――およそそういうものは断りました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "棄て置けば狐狸の棲処、さもないまでも乞食の宿、焚火の火｜沙汰も不用心、給金出しても人は住まず、持余しものになるのを見済まし、立腐れの柱を根こぎに、瓦屋根を踏倒して、股倉へ掻込む算段、図星図星。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「狐狸や、いや、あの、吠えて飛ぶ処は、梟の憑物がしよった、と皆｜気違にしなさいます。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白糸はうれしげに身を進めて、「あなた、その後は御機嫌よう」　いよいよ呆れたる馭者は少しく身を退りて、仮初ながら、狐狸変化のものにはあらずやと心ひそかに疑えり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は実にいまだかつて信ぜざりし狐狸の類にはあらずや、と心はじめて惑いぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐狸どもの我をたぶらかすにやと、その夜は湯にもいらで臥しぬ。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐狸の仕業はかならずあるものと信じて居た。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場の蒼黒い顏には弱い西日がぽつと明るくさしてゐて、夕靄がもやもや烟つてふたりのからだのまはりを包み、なんだかをかしな、狐狸のにほひのする風景であつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も體裁を言ふには當らない、ぶちまけて言へば、馬鹿な、糸七は……狐狸とは言ふまい――あたりを海洋に變へた霧に魅まれさうに成つたのであらう、然うらしい……　で幽谷の蘭の如く、一人で聞いて居た、卷莨を、其處から引返しざまに流に棄てると、眞紅な莟が消えるやうに、水までは屆かず霧に吸はれたのを確と見た。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "変化の術が人間にできずして狐狸にできるのは、つまり、人間には関心すべき種々の事柄があまりに多いがゆえに精神統一が至難であるに反し、野獣は心を労すべき多くの瑣事を有たず、したがってこの統一が容易だからである、云々。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐狸より貉の化ける話多し。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊遣の煙古井戸のあたりを籠むる、友の家の縁端に罷來て、地切の強煙草を吹かす植木屋は、年久しく此の森に住めりとて、初冬にもなれば、汽車の音の轟く絶間、凩の吹きやむトタン、時雨來るをり／＼ごとに、狐狸の今も鳴くとぞいふなる。",
              "citation": {
                "source": "森の紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち、縣下豐岡川の治水工事、第一期六百萬圓也、と胸を反らしたから、一すくみに成つて、内々期待した狐狸どころの沙汰でない。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月夜の陰、銀河の絶間、暗夜にも隈ある要害で、途々、狐狸の輩に奪ひ取られる、と心着き、煙草入の根附が軋んで腰の骨の痛いまで、下つ腹に力を籠め、気を八方に配つても、瞬をすれば、一つ失せ、鼻をかめば二つ失せ、嚏をすればフイに成る。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ狐狸の仕業とあっても、わたしゃ悦んで騙されよう。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一たい狐狸の化けたのは、人間の姿はしていても地に敷く影は正体のままと聞いたが、そなたは影までたおやかな女の影、よほど行亙った化け方と感心して見ていたのさ。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際又た狐狸の居さうな処がいくらもあるのです。",
              "citation": {
                "source": "夜の赤坂",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この河童の尻が、数え年二百歳か三百歳という未だうら若い青さに痩せていた頃、嘘八百と出鱈目仙（千）人で狐狸かためた新手村では、信州にかくれもなき怪しげな年中行事が行われ、毎年大晦日の夜、氏神詣りの村人同志が境内の暗闇にまぎれて、互いに悪口を言い争ったという。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐狸か、天狗か、森の精か」　と、呟いた途端に、カラカラと高笑いが聴えたが、姿は見えなかった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなうるさ草につくばふ下闇の蚊喰がへるが咽喉鬼灯狐狸横議の士続出し、新聞利用またしきりなり。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この狐狸の巣窟を発いて初めて拓いたのが三ツ家の漂流民だと伝えている。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お菊は与右衛門の顔を見ると、「おのれ与右衛門、おのれは、狐狸と云うて、村の衆の前をつくろおうとしておるが、おのれのしたことを何人も知らないと思っておるか、たしかな証拠人があるぞ」　と云った。",
              "citation": {
                "source": "累物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話帳に本名を出しとくような狐狸とは段違いの怪物だからウッカリした事は出来ないと思ったからだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが恐ろしさと馬鹿らしさに皆、忘れても和尚を負かさぬように気を付けているが、それでも時々大地震のような家鳴、震動が起るので、事によるとやはり狐狸の仕業かも知れない。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に名高き近藤勇、寸兵を労せず、縛に就くも、亦狐狸の数の尽くると一徹なり」と思ひ切つた酷評を下してゐる。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎はちょいちょい、猿も時々は見懸けますが、狐狸は気もつきませぬに、穴の中からでも魅りましたかな。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
