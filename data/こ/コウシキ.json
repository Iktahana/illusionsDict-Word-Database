        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "硬式と軟式とのあいだで、彼は少しだけ迷った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少くとも地理的にみても、考古学的にみても、それから人類学的にみても、即ちアントロポロジー的にみても、生物学的にみても……」　こうしきりに並べたてる時、角井ははたと学者的な良心に突き当ったので、「それは君、アントロポロジーじゃなくてアントロポロギーだよ」と訂正した。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そんなことより現在の俺は、早く人形を手に入れて、宥免状の安全を期したい）　こうしきりに思われるのであった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしきりに思われて来た。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
