    "definitions": [
      {
        "index": 1,
        "gloss": "leaf (of a tree)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木の葉が偶にそよいでゐる。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」父は遠くの木の葉でもみるやうな眼付をしていつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の池の水が緑黒くドロドロになつて、囲りの木の葉が動かずにヂツトそれを覗き込んでゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "塵埃にくすぶった草木の葉が洗われて美しい濃緑に返るのを見ると自分の脳の濁りも一緒に洗い清められたような心持がする。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山の法経堂に現れる怪火の話とか、荒倉山の狸が三つ目入道に化けたのを武士が退治した話とか、「しばてん」（木の葉天狗）と相撲を取る話。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の色でも木の葉の色でも、都会で見るのとはまるでちがっている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火が、ぴしぴし、音を立てて、盛に燃え出すと、樺の立木の葉が、鮮やかに、油紙の屋根に印して、劃然とした印画が炙り出される。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉一枚動かない沈鬱なる空の下に、案じたほどのこともなく向う岸へ渡り、崖の上へ立って振り返ってみると、白衣の道者の一連が来て、大沢の手前でうずくまり、先達がお祈りを上げている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の波紋が遂に汀に達すると、そこに浮いている木の葉や板片が動揺し少時してまたもとの静平に復する。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園にうず高く落ち敷く落葉、落ちる前の乾燥した黄褐色の木の葉を盛り上げた深い森林――この際、彼には何か神秘的な特殊性を包蔵する境区として結局はこの境区の何処かに彼の一寸ものに触れれば吼え出し相な頭の熱塊を溶解してしばらく彼の身心の負担を軽くして呉れる慰安の場所もあるように思えた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋雨の山の靜けさ、松の葉から落ちる雨滴が雜木の葉を打つ幽かな音は、却つて山の靜寂を増す。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、見つめていると、紅い一面の雲のような花の層に柔かい萌黄いろの桃の木の葉が人懐かしく浸潤み出ているのに気を取り倣されて、蝙蝠傘をすぼめて桃林へ入って行った。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れてまでどこ迄もデリカを失わない木の葉のなかへ、スマートな男女｜散策の人形を置いたりしている。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、よだかでないただのたかならば、こんな生はんかのちいさい鳥は、もう名前を聞いただけでも、ぶるぶるふるえて、顔色を変えて、からだをちぢめて、木の葉のかげにでもかくれたでしょう。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉をつたい歩く蟻にとりては一粒一粒の雨滴の落つる範囲を方数ミリメートルの内に指定する事が必要なれども、吾人人間には多くの場合にただ雨量と称する統計的の数量が知らるれば十分なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉のそよぐにも溜息をつき烏の鳴くにも涙ぐんで、さわれば泣きそうな風でいたところへ、お母さんから少しきつく叱られたから留度なく泣いたのでしょう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは書物で読んだことだが、樫鳥や山鳩や山鴫のような鳥類が目にも止まらぬような急速度で錯雑した樹枝の間を縫うて飛んで行くのに、決して一枚の木の葉にも翼を触れるような事はない。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年九月十二日『東京朝日新聞』）　　　　　　　　　二　　　　　　一葉『淮南子』には一葉落而知天下秋とあるが、植物学者に聞いてみると、木の葉が夏過ぎて落ち散るのは葉柄の根元の処にコルク質の薄い層が出来てそこだけ脆くなるから少しの風にでも誘われて天下の秋を示すものだそうだ。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草木の葉や土、石、藁のようなものは冷えやすいから露も多くつくが、光った金属例えば金盥などは冷えにくいから露も付きにくい。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙よ、わたしの心はお前から遠くはなれて居ない、わたしは手に燈灯をもつて、くらい庭の面を眺めて居た、雨にしほるる草木の葉を、つかれた心もちで眺めて居た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの夕暮のすばらしさに、その最も小さな一員として、つつましやかに、物靜かに參與してゐるところの、どんなに小さな木の葉の前にも、私は感動させられました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふくらはぎや腕のふくらみの處は老人のそれのやうにたるんで、觸つてみるとよごれた皮膚がまるで乾干びた木の葉のやうにかさかさしてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町を挾んだ丘の斜面の黄ばんだ木の葉の色も急に濃くなつたやうだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供部屋の裏の縁先にある花壇には、強烈な正午過ぎの日光が眩しいように輝いて、草木の葉もうなだれているようであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐に化かされたのだろうとお亀は云ったが、ふところに入れて来た目録は木の葉ではなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ林の濶い木の葉がぱちぱち鳴っている〔以下原稿数枚？",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人のお酒に酔った若い者がほおの木の葉でこしらえたお椀のようなものに顔をつっ込んで何か喰べています。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の響、瀬の音、木の葉ずれ、そんなものが旅に出た當初の鮮かさを持つて彼に歸つて來た。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷を距てた上野の動物園の仲間に比べるとここのは死刑囚であろう。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩に乗り上げた舟のように傾いた橇の底では兵士が、でこぼこのはげしい道に動揺するたび、傷を抑えて歯を喰いしばった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
