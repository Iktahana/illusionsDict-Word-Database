        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それゆゑに Epikuros の社會は功利主義の社會に外ならない。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、個人を個人たらしめる・最も普遍的な意味に於ての・功利主義が私には缺けてゐるやうだ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又はこれを資本として何等かの政権利権に接近し、ついこの間まで攻撃罵倒していた、唯物功利主義者のお台所に出入して、不純な栄華に膨れ返っている者も居る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来の日本は毛唐と同じような唯物功利主義一点張りの社会を現出するにきまっている。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃応援団というものに冷淡になった功利主義者や、事なかれ主義者が多くて困るのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はよく功利主義々々々々といって報酬を目あてにする行為を蛇蝎の如く忌み悪んでいる。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは比べものにならぬ程｜凡下の功利主義より高尚だといおうか。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に巧みな、そして狡猾な仮面の下に隠れた功利主義としか思われない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを以てかの報酬を目的にして行為を起す功利主義者と同一視するのは、人の心の絶妙の働きを知らぬものだと。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇　「文学派」の発生　功利主義に対する、反功利主義、形式主義に対する内容主義、これは、文学の弁証法的進化をつらぬく核心であるといえよう。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア文学の内容主義と功利主義とに対する反発である。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし反面西洋覇道文明の影響甚だしく、今日の日本知識人は西洋人以上に功利主義に趨り、日本固有の道徳を放棄し、しかも西洋の社会道徳の体得すらも無く道徳的に最も危険なる状態にあるのではないか。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学に対する統制は科学の発展を阻害して目前の功利主義へひきとめる形としてあらわれて来ている。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石原氏は、科学が軍事的功利主義で余り掣肘されることの害悪を主張しておられる。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "出しても用の足りぬ声を使うのは経済主義から云うても功利主義から云っても割に合わぬにきまっている。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は一種の卑近な功利主義、一種の上つらの実行主義の誘惑である。",
              "citation": {
                "source": "生産を目標とする科学",
                "author": "――再三「科学と技術」とについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうまでもなく一種の功利主義かも知れない。",
              "citation": {
                "source": "自分だけの世界",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "功利主義万能、唯物史観全盛時代である。",
              "citation": {
                "source": "錯覚自我説",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "教科書だけを勉強してきた人間は、そのことだけからも、功利主義者になってしまう。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスはこのような快楽主義的、功利主義的思想に対して手酷しい攻撃を加えており、それについてはつねに侮蔑と憎悪とをもって語っている。",
              "citation": {
                "source": "マルクス主義と唯物論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてプラグマティズムは、あの倫理學上の功利主義（Utilitarismus）が效果の倫理（Ethik des Erfolgs）であるのに對して、效果の論理（Logik des Erfolgs）であるといひ得るであらう。",
              "citation": {
                "source": "認識論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスはこのやうな快樂主義的、功利主義的思想に對して手酷しい攻撃を加へてをり、それについてはつねに侮蔑と憎惡とをもつて語つてゐる。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か目的がなければ読書しないというのは読書における功利主義であって、かような功利主義は読書にとって有害である。",
              "citation": {
                "source": "如何に読書すべきか",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国の箇人的教育は、各種の箇性を重んじながら、其の功利主義の伝統的暗示、或は宣伝に依て、箇人的気質が、公衆の不文律に順応して行ける程度の寛和、或は弛緩を加えて居ります。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
