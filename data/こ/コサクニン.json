        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小作人どもは、ワイワイ云ってるだけで、何とも手の下しようがなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵目ぼしい、小作人組合の主だった、（ならず者ども）は、残らず町の刑務所へ抛り込まれてしまった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、青年団や消防組員は、殆んど小作人許りであった！",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、当局が小作人組合に眼を光らさぬ筈がない。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "本田家の邸内を護衛していた、小作人組合に入っていない、青年団の青年たちや、消防組員までも、一応は取調べを受けた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七九年から翌年へかけては小作人がだんだん土地を返上して来たので、地主は自作するより外途がなくなった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "題材はある小作人の一家が先祖代々耕して來た土地を住み切れず、カラフトへ移住してゆく顛末を書いたのであるが、その晦澁を讀みこなせば描寫は甚だ通一遍で、眞に農民の生活のなかから書かれたものとしては首肯し難いものがある。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴衆の中には、一坪の田畑も所有しない純小作人もある。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人は、折角、耕して作った稲を差押えられる。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なる程、農民の生活から取材した作品、小作人と地主との対立を描いた作品、農村における農民組合の活動を取扱った作品等は、プロレタリア文学には幾つかある。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人は、皆な豚飼いに早替りしていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついすると、小作料を差押えるにもそれが無いかも知れない小作人とは、彼は類を異にしていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の小作人達は、百姓だけでは生計が立たなかった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、よせばいゝのに、『松葉屋』の小作人達が、また、親爺に投票した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年間に、彼は、全然の小作人でもない、又、全然の自作農でもない、その二つをつきまぜたような存在となった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人から、自作農に成り上って行こうと、あがいている者も僕の親爺一人に止まらなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦を踏み折られて、ぶつ／＼小言を云わずにいられなかったのは小作人だ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　麦を踏み荒されたばかりで敷地となる田も畠もない持たない小作人は、露骨な反感を現わした。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつを、高見の見物をしていられるのは、何にも持たない小作人だ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人も、はずされた仲間の方についた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから小作人の住宅や牛小屋、豚小屋、糞堆まで見て歩きました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人らに一々アローと声をかけて、一言二言話していました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "取残された僕は力味んではみたものの内内心細かった、それでも小作人の一人二人を相手にその後、三月ばかり辛棒したねエ。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それより彼は開墾の困難なことや、土地に由つて困難の非常に相違することや、交通不便の為めに折角の収穫も容易に市場に持出すことが出来ぬことや、小作人を使ふ方法などに就いて色々と話し出した、其等の事は余も札幌の諸友から聞いては居たが、彼の語るがまゝに受けて唯だ其好意を謝するのみであつた。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ハッハッハッヽヽヽ其なら初めから小作人｜任にして御自分は札幌に居る方が可からう。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、第二の農場を合して、約四百五十町歩の地積に、諸君は小作人として七十戸に近い戸数をもっています。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "農場の小作人に年賦か何かで土地を買はして、それでも未だ不可いからといふので、政府から補助を受けることになつてゐると聞きますが、これなんかは全く何うにかしなければ不可ませんね。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の場合は、勿論現代の資本主義といふ悪制度が、如何に悪制度であるかを思つたことゝ、直接の動機としては、資本主義制度の下に生活してゐる農民、殊に小作人達の生活を実際に知り得たからです。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
