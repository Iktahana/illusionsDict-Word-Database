[
  {
    "uuid": "b77f6560-7b87-57b1-b03d-7946a7e44660",
    "entry": "転ける",
    "reading": {
      "primary": "こける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to fall over",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」四　補祭はとても笑い上戸で、つまらぬことをいちいち、横腹の痛くなるまで笑い転ける。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "松村はあっけにとられて、笑い転ける私を見ていた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概の家では女中らはもちろん奥さんや娘さんまでのぞきに出て来て、道化た面をかぶった異風な小こじきの狂態に笑いこける。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもないことにでも大聲たてて笑ひこける。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで子供らは、そういういくつかの取っておきの話の中から、あれをこれをと注文して話させては笑いこけるのであった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また晴天の日、松林を走るやうな愉快な疳の高い日の氏は、腸の蟲まで笑ひこける、押へつけられないやうな氣がする。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私がその事を話すと男の児の様な快活な母は大きな口を開いて笑ひこけるのでした。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ばん先に欲しがられた雀こ、大幅こけるどもし、おしめの一羽は泣いても泣いても足えへんでば。",
              "citation": {
                "source": "雀こ",
                "author": "井伏鱒二へ。津軽の言葉で。",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　一日、雪降り凜※たる寒気の中を例の如く太七の家の前を通るうち、プッツと切れた下駄の鼻緒に転ぶ途端、無作法に笑ひこける太七の家の職人共に、何が可笑しいと詰り寄るうち、ふと一人の職人が細工場の戸を開けて外を窺つた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが大抵は語れば一座が皆どつと笑ひこけるやうなことのみに屬して居るらしい。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "この様子があまりに滑稽なので皆の笑いこけるのにつり込まれて自分も近ごろになく腹の中から笑ってしまった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれにしても、正直ずっこける。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "草刈籠がすつと地上にこける時蜀黍の大な葉へ觸れてがさりと鳴つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "親に成つた一人が八｜本の綱の本を掴んで一｜度ぎつと指へ絡んでばらりと投げ出すと、悉皆が一つづゝ掴んで此れも其の端を指へぎりつと絡んで一｜度に引くと七｜本の綱が空しくすつとこける。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を動かせばずる／＼と下へこける。",
              "citation": {
                "source": "痍のあと",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "あせればあせる程こけるのである。",
              "citation": {
                "source": "痍のあと",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "躰を屈めると荷物がぶらつと胸へさがつて蓙が前へこける。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "思え、ただ仮初めの恋にも愛人の頬はこけるではないか。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついて来た女将は立ったまましばらく二人を見くらべていたが、「ようよう……変てこなお内裏雛様」　と陽気にかけ声をして笑いこけるようにぺちゃんとそこにすわり込んだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が、他の女性のことを考えて、ボンヤリしているのを、可笑しいと云って無邪気に笑いこける妻のいじらしさが、分らない信一郎ではなかったが、それでも彼は刻々に頭の中に、浮んで来る美しい面影を拭い去ることが出来なかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは、みんなが笑いこけるだろうな」　といって、高志は満足げな笑みを泛かべた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝こけるなんてのは、予測不能だ」　兄妹は声をそろえて笑った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼女は潔に甘えかかって、到頭彼の首に手を廻す、さうして接吻を了ってしまふと、やはり何でもなかったので彼女は晴やかに笑ひこける、潔も淋しさうに笑ひ出す。",
              "citation": {
                "source": "淡雪",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪戯をして、一寸つッついても、何時でも身体をはずませて、クックッと笑いこけるのに、顎をひいて、身体をコッちりさせている。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間でも、獣でも、あまりこけると、不思議なことをするだでな。",
              "citation": {
                "source": "ある日の印旛沼",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の一日をたわむれ暮らしても、まだ歓楽の興をむさぼり足らない人びとは、酔いくずれて眠りこけるか、疲れ切って倒れるか、それまでは夜を昼についで浮かれ狂うつもりであろう。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が、他の女性のことを考へて、ボンヤリしてゐるのを、可笑しいと云つて無邪気に笑ひこける妻のいぢらしさが、分らない信一郎ではなかつたが、それでも彼は刻々に頭の中に、浮んで来る美しい面影を拭ひ去ることが出来なかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "都にござらしてお歴々のお方の前へ度重ねてまかったものとはずんと違うて、お勿体もない、かたじけない、と思うと涙をらちもなく霑すのと、他愛もなく笑いこける事より存じませぬ者ばかりでござりますもの。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は僕の顔を見るとすぐ、笑いこけるようにして言った。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to flop (e.g. of a play)",
        "register": "standard",
        "nuance": null,
