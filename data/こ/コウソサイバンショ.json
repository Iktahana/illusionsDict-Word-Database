          "standard": [
            {
              "text": "第一審の結果に納得がいかず、控訴裁判所に審理のやり直しを求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "控訴裁判所は、地方裁判所の出した判決を破棄し、差し戻しの決定を下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "法廷ドラマのクライマックスは、舞台を控訴裁判所に移して激しい論戦が繰り広げられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "此三円の財貨を被告が不法に窃取したために、郵便局長が調べ、警察が調べ、検事局が調べ、一審裁判所が調べ、今又控訴裁判所が調べた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
