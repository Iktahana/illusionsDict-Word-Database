    "definitions": [
      {
        "index": 1,
        "gloss": "there is no need to ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
