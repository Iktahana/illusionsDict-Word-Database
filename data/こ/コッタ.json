[
  {
    "uuid": "4a7bd391-7fe9-5eea-a614-1b9619f13c04",
    "entry": "凝った",
    "reading": {
      "primary": "こった",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-語幹"
      ],
