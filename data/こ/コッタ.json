    },
    "definitions": [
      {
        "index": 1,
        "gloss": "elaborate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
