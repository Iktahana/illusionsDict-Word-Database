    "definitions": [
      {
        "index": 1,
        "gloss": "ancient and modern times",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
