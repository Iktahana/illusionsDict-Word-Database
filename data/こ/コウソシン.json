        "examples": {
          "standard": [
            {
              "text": "控訴審では新たな証拠が提出され、一審の判決が覆る可能性が出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "事実誤認を主張する弁護側と、量刑不当を訴える検察側の主張が控訴審でぶつかり合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "裁判の長期化により、被告人は控訴審が始まるまで拘置所での生活を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アップルはこれを不服として上訴したが、一九九四年九月、控訴審も一審の評決を支持し、同社の訴えを棄却した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "川瀬林学博士が鑑定人として控訴審に招かれ、やはり平岩君と同じに、狸｜狢同一説を主張せられたが、判決は結局無罪であったように記憶する。",
              "citation": {
                "source": "狸とムジナ",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
