        "examples": {
          "standard": [
            {
              "text": "あそこにある、あのこんこんちきは何だ？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このこんこんちき、どうやって使うんだ？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "まったく、あいつのこんこんちきな言動には呆れるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "出ねえ出ねえと思つてゐたお化けが出て來たやうな、めつぽふ不思議なこんこんちきと云ふ世の中に變り果ててしまつた。",
              "citation": {
                "source": "なぐさめ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下を睨む、大伴の」「九郎助」「稲荷大明神」「こんこんちきな、こんちきな」「置きあがれ、馬鹿野郎――おやおや、喋ってる間に、定公め、一人で、煎餅を食っちまゃあがった」「手前の洒落より、煎餅の方がうめえ」　格子の開く音がして「頼もう」　若い侍の声であった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んだ料簡違いのこんこんちきだ」　誰にいうともない独言ながら、吉原への供まで見事にはねられた、版下彫の松五｜郎は、止度なく腹の底が沸えくり返っているのであろう。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
