          "literary": [
            {
              "text": "「あれは高速道路だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、道路をとび越えますよ」　庭の飛石を飛び越えるように、僕たちは高速道路から低速道路へと渡っていった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "高速道路を支えるコンクリートの大きな四角の柱の不吉な列。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "高速道路の周辺に、びっしりと建っている大小さまざまなビルは、排気と騒音の中で不気味な増殖をつづけているみたいに見える。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "無数のビルの壁面や、この高速道路の裏面や柱にこだまし、雲にとじこめられたスモッグの空に、やがて消えていった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
