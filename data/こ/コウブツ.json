[
  {
    "uuid": "73039b6b-b35b-5fef-b09e-d8fb2a915f65",
    "entry": "好物",
    "reading": {
      "primary": "こうぶつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
