[
  {
    "uuid": "499ad1db-7f00-5b62-8739-1144b26de3c8",
    "entry": "公約",
    "reading": {
      "primary": "こうやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
