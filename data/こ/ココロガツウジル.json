          "literary": [
            {
              "text": "片言のように――切れ切れに、お経の文句を覚えていた漁夫が「それでいい、心が通じる」そう皆に云われて、お経をあげることになった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "話せば心が通じるであろうと思い、ひそかに会見の日を愉しみにしておった。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "異性同士、心が通じるつてことは、やつぱりあるんだわ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
