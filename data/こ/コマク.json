        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山を下つて氣壓が變る爲に鼓膜の壓迫されたことを云つて居るらしい。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気圧の急変で鼓膜を圧迫されるのをかまわないでいたら、熱海海岸で車を下りてみると耳がひどく遠くなっているのに気がついた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音も鼓膜を動かして仕事をし、また熱にも変ずる。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼓膜の破れた人が耳を洗う時｜眩暈を感じたり、また健全な者でも少時間グルグル舞うた後には平均を失うて倒れたりするのは皆この三半規管を刺戟するためだという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顛覆した列車の窓からとび出た時の、石のような雪の感触や、パルチザンの小銃とこんがらがった、メリケン兵のピストルの轟然たる音響が、まだ彼の鼓膜にひゞいていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　機関銃の上等兵は、少尉に鼓膜を叩き破られた兄を持っていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそのうちに下り列車が、二人の鼓膜を震憾して通過したので、やっと話が途切れた。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲からは鼓膜でも破り相な勢で鉄と鉄とが相打つ音が逼る。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼓膜が千里の余も飛んじまつたべと思ふほどこゝんところをたゝかれた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梢にあたる風の音が入りまじつた雑音となつて彼の鼓膜に伝はつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その詞の中て、彼の鼓膜に響いたのは「死損の癖に」と云はれたそればかりであつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "雖然悠長な而して不斷の力は、ともすると人の壓伏に打勝ツて、其の幽韻は囁くやうに人の鼓膜に響く。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父はそれが又、大得意で、来るお客｜毎に吹聴しては店の信用を裏書きする材料にしていたが、何しろ距離が遠いのと雑音が烈しいのとで、並大抵の耳では相手の読む数字が聴き取れないのを、私の鼓膜は雑作なしにハッキリと受け入れた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼓膜が破れさうになる。",
              "citation": {
                "source": "艇長の遺書と中佐の詩",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "又某甲若し眼を失つたと假定すれば、視界は滅し、鼓膜を破つたとすれば、聽界は亡び、神經無く、而して又生殖能力を除去されたとしても、生命の存續だけは或は保ち得るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめやかに降り灑いでゐた戸外の雨の音が、彈くやうに私の鼓膜に響いて來た。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが春吉君の動悸を、鼓膜にドキッドキッとひびくほど、はげしくした。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生の丁寧に落着いた言葉が、初め鼓膜まで硬直した京子の耳底に微かに聞えて、だんだんはっきりと聞えて来た。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために彼の鼓膜はやぶれ、耳と鼻から、だら／＼と血が流れ出ました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「渡船……」　三度目の声が鼓膜を慄わして響いた。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（＝ヒガシハラ　モリタニボクジヨウナイ　タカオカマサカツ＝）　瞬間、敬二郎の耳は汽笛のように鼓膜を刺して鳴りだした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "測り知られざる真の静けさが、あらゆる現実の無気味さをもって、われわれの上に押しせまっているのは、ここ北極の海においてのみで、わずかなつぶやきの声をも捉えんとして緊張し、船中にちょっと起こった小さい物音にまで熱心に注意する、われと我が鼓膜に気がつくのである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に万籟寂として、地に虫の這う音も無く、天は今にも降せんずる、霙か、雪か、霰か、雨かを、雲の袂に蔵しつつ微音をだに語らざる、その静さに睡りたりし耳元に、「カチン」と響く鉄槌の音は、鼓膜を劈きて予が腸を貫けり。",
              "citation": {
                "source": "黒壁",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルトマイエル「えゝ騒がしい、綿をもつて来て呉れ、野郎共僕の鼓膜を破りやがる。",
              "citation": {
                "source": "喜劇考",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると畑を包む遠い近い林には嫩葉の隙間から少い日の光がまた軟かなさうして稍深い草の上にぽつり／＼と明るく覗き込で、松の木からはみんみん蝉の樣な松蝉の聲が擽つたい程人の鼓膜に輕く響いて凡ての心を衝動する。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處には毎日必ず喧※な跫音が人の鼓膜を騷がしつゝある其の巨人の群集が、其の目からは悲慘な地上の凡てを苛めて爪先に蹴飛ばさうとして、山々の彼方から出立したのだ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同様に鼓膜も、極めて微細な震動しかしなかった。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが今、声帯は躍動し、鼓膜は裂けるばかりに、同志の言葉に震え騒いでいる。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "また眼を失ったと仮定すれば視界は滅し、鼓膜を破ったとすれば聴界は亡び、嗅覚の障害を得れば香の世界は法滅する。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、微速度は、一秒二こまくらいに低める。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
