    "definitions": [
      {
        "index": 1,
        "gloss": "to be mixed in with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
