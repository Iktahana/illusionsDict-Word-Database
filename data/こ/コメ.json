[
  {
    "uuid": "434510b2-fede-5fde-8139-4881c1d2ed19",
    "entry": "米",
    "reading": {
      "primary": "こめ",
      "alternatives": [
        "コメ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
