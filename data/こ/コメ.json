  {
    "uuid": "5dfe7008-0afe-5092-91c3-f285ffa8dfc5",
    "entry": "個目",
    "reading": {
      "primary": "こめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "助数詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the nth (thing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翌朝雇人がパン／＼と電球の割れる物音に驚かされて眼がさめ、庭に出てみると、丁度二十個目の電球を投げつけようとしている豹一の姿が眼にはいった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "九個目で、いゝ加減にしとけと安二郎が呶鳴ったが、しかし安二郎は小さな豹一など明らかに無視していた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰せ承ったコン吉がクウル・ド・ラ・レエヌの花市を駆けずり廻って買い集めた三十六個の菊花の大鉢、――これを一個｜宛地階から六階まで担ぎ上げているうち、その二十八個目を三階の階段の七段目まで持ち上げたところで不覚にも眼を廻し、すなわち花もろとも、墜落。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "合乗り乳母車　――仏蘭西縦断の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいところは三個目位のところが要領をのみこんで一番うまくできるやうです。",
              "citation": {
                "source": "オルゴール",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二個目のグラスに注ぐとき、人差し指で星印を隠した。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "チルは六十三個目のタマゴを生み、新年を迎えることになりました。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "信じられないぜ、ロンドンに住んでる英国人が、ロンドン塔を見てないって」「スリムさん、本当に見てないのですよ」　アメリカ人は三個目の卵をむきながら、「ええっ、やぶへびだ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たち、さびしく無力なのだから、他になんにもできないのだから、せめて言葉だけでも、誠実こめてお贈りするのが、まことの、謙譲の美しい生きかたである、と僕はいまでは信じています。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻燈のまちの病気もなおらず、いつ不具者になるかわからぬ状態であったし、ひとはなぜ生きていなければいけないのか、そのわけが私には呑みこめなかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の脂で手が辷りさうなので直ぐにそれはこめかみに当て換へられた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、女性的とはいへ、山の温泉であるから、樹木が多く、雲や霧がふだんに立ちこめて、山巒といふ感じは充分にある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と千萬の（これもどうにもきざだが）祈りをこめて宮崎氏に言ひたい。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の雨の夜　冬の黒い夜をこめてどしやぶりの雨が降つてゐた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夕明下に投げいだされた、萎れ大根の陰惨さ、あれはまだしも結構だつた――今や黒い冬の夜をこめどしやぶりの雨が降つてゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雨の中を漂ひながらいつだか消えてなくなつた、あの乳白の※嚢たち……今や黒い冬の夜をこめどしやぶりの雨が降つてゐて、わが母上の帯締めも雨水に流れ、潰れてしまひ、人の情けのかずかずも竟に蜜柑の色のみだつた？",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯が炊けると、嘉代吉はお初穂を取って押しいただいた、山の神さまへ捧げるのだという、私も人夫も、それを四、五粒ずつ分けてもらって、同じように押し頂いて喰べた、奥穂高はと見ると、もういつの間にか、霧がかかった、きょうもまた雨の糸で縫いこめられる象徴のように。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽殿の傍には、周囲六丈四尺、根廻りは二丈八尺、と測られた神代杉がそそり立って、割合に背丈は高くないけれど、一つ一つの年輪に、山の歴史の秘密をこめて、年代の威厳が作り出す色づけと輪廓づけを、神さびた境内の空気に行わたらせている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "華々しいもの、潔いもの、勇壮なるもの、さう云つたものから、子供の家へ帰ると、ひつそりと沈んだ冷え冷えとしたものが、両親の体臭のやうに、家中を靄のやうに立ちこめてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後に気を付けて見ると同年輩の友人の中の誰彼の額やこめかみにも、三尺以上｜距れていてもよく見えるほどの白髪を発見した。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下駄の歯の根に血を持つような執拗な欲求をこめて彼はざくりと公園の落葉の堆積に踏み入った。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よこめでこっちを見ながら立ってゐる。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よこめでこっちを見ながら腕を組んだまま消えて行く。",
              "citation": {
                "source": "うろこ雲",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝港内をこめていた霧が上がると秋晴れの日がじりじりと照りつけた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根の鉄橋を越えて行くに夏｜蕎麦をつくる畑｜干瓢をつくる畑などあれば埼玉や古河のあたりの夏蕎麥のなつみこめやもおほに思はゞ麥わらをしける廣畑瓜の畑葉かげに瓜のこゝたく見ゆるなど口ずさむ。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "本能と良心と、わかちがたき一つの心をふたつにわかたんとする大人の心のうらさびしさよ、力をこめて引きはなされた二つの影は、糸のやうにもつれあひつつ、ほのぐらき明窓のあたりをさまようた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「我が慈悲道得の刀を　受けよと言うより早く」　と話す武蔵「スラリとばかりＴ「両刀抜き放ちて　飛びかかり」　身振り手振りも面白くＴ「この時妖雲　谷を覆い　山は轟々　と鳴り響く」Ｓ＝辻堂　猛々と立ちこめた白煙。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "男達の中には、甲冑の下に奧深く、あたかも囚人のやうに、その死を閉ぢこめて置いた者もあつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は倫敦の深い霧が立ちこめて、青い幻灯の街路を、外套の襟に顔をうずめて各国の女が相変らず男から男に身を売って、凍った地面を高い踵で音楽のように敲いて行ったり来たりしていた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　この夕ぐれを門司の港では木の橋の上で天主教の司祭様が新世界の魚、河豚を釣りあげていられるのであるが、この糸の垂れこめたなかには、鼠取の仕掛けになっていて餌に、触るたびに上から落ちてくる豚に河豚は頭を挟まれてしまうのである。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、縮こめた女の體をぐいと自分の胸に引き寄せて、二度目の接吻を交したかと思ふと、二人は身を搖す振つて一時に笑ひさざめいた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
