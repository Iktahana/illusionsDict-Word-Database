  {
    "uuid": "6c3f4fc3-51ad-5172-85d8-eef286dc6b71",
    "entry": "戸部",
    "reading": {
      "primary": "こぶ",
      "alternatives": [
        "こほう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Ministry of Revenue (Tang dynasty China)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "戸部は物憂そうに床の上に臥ころんでいる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたの、戸部さん、あなた死ぬとこなの。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともちゃんが家を出ようとすると、お母さんが「ともや、ここにこんなものが取ってあるから食べておいでな」といって、鼠入らずの中から、ラーヴェンダー色のあんこと、ネープルス・エローのきなこと、あのヴェラスケスが用いたというプァーリッシ・グレーの胡麻……戸部うなり声を立てる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　お母さん怒らないか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　じゃ君は、もうここには寄りつかなくなるね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　畜生……出て行け、今出て行け。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（悔しそうに涙をためる）戸部うなる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　俺たちの仕事が認められないからって、裏切りをするような奴は……出て行け。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部の気むずかしやの腹がすいたんだから、いわばペガサスに悪魔が飛び乗ったようなもんだよ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも子　だって戸部さんみたいなわからず屋ってないんだもの。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを人の気も知らないで……戸部　　貴様は（瀬古を指さして）こいつの顔が見たいばかりで……とも子　焼餅やき。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　（自分の画箱のほうに這いずって行って中を捜しながら）ない。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　ガランスか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢本と戸部と勢い込んで瀬古に逼る。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　俺によこせ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　ガランスかって聞いたのは、ガランスだと困ると思ってそう聞いたんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬古　　（沢本と戸部にチョコレットを食いかかせながら）最後の一片はもちろん僕たちの守護女神ともちゃんに献げるのさ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ僕が……沢本と戸部とが襲いかかる前に瀬古｜逸早くそれを口に入れる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　俺に用があるよ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　いいから……こいつら、うっちゃっておけ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部ひとりだけ、とも子をモデルにして描きはじめる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　貴様そういったか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　よくいった。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　できたものはみんないやだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部　　花田、貴様は残酷な奴だ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部は画箱の掃除をはじめる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸部さんは吃りで、癇癪持ちで、気むずかしやね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……戸部　　畜生……とも子　悪口になったら、許してちょうだい。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、これでも身のほどをわきまえて選ぶつもりですから……（急に戸部の前にかけ寄り、ぴったりそこにすわり頭を下げる）戸部さん、私あなたのお内儀さんになります。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日経よむと墓を弔いするで、よろこぶの生きるです』『あなた、ほかの世、坊さんと生れて下さい』『ああ、私願うです』　人間よりも、虫や鳥の方が幸福だと言ったヘルンは、人生について、悲哀の外の何物をも知らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
