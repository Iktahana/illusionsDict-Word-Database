[
  {
    "uuid": "7300f7db-953c-55f7-8119-e8b0c6212df2",
    "entry": "鼓舞",
    "reading": {
      "primary": "こぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
