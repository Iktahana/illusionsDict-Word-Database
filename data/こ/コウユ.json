[
  {
    "uuid": "8b58323b-c563-5608-ba6f-11a0a4e68f16",
    "entry": "香油",
    "reading": {
      "primary": "こうゆ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
