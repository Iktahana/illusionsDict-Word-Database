    "definitions": [
      {
        "index": 1,
        "gloss": "translation from a foreign language into Japanese",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "生活と密接な具体的関係にある言葉は雰囲気の情調を満喫していて他国語への翻訳が困難であるには相違ないが、それも程度の問題であって、外来語の国訳へ向って出来得る限りの努力が払われなくてはならない。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教関係の書物二十五冊以上、内、国訳一切経十四冊（阿含経10、四分律４）、諦観の「天台四教儀」（織田の「和解」による。",
              "citation": {
                "source": "獄中通信",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "本は東京より少し不自由だが、国訳一切経は続けてよむことにしている。",
              "citation": {
                "source": "獄中通信",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし来られたら金三―五〇〇円、合服三揃、スキー帽、手袋、襟巻、シャツ、ズボン下、カトリック辞典一二、英語のギリシャ語文典（机上）、机上の国訳漢文大成を、出来る限度に於いて領置しておいて欲しい。",
              "citation": {
                "source": "獄中通信",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "続国訳漢文大成、蘇東坡詩集、巻四、三〇八―九頁、註釈者、釈清潭。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな日本文が分かるやうなら、何も国訳本を必要としないであらう。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて余談のまた余談になるが、続国訳漢文大成に収められてゐる蘇東坡詩集を見ると、先きに引いた句が次のやうに講釈されてゐる。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一朶妖紅翠欲流、　　春光囘照雪霜羞化工只欲呈新巧、　　不放間花得少休　続国訳漢文大成を見るに、ここは岩垂憲徳氏の訳解になつて居り、そして私がここに引いた老学庵筆記が引用されてゐる。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し続国訳漢文大成では、自註に引く所の柳子厚の句が海上尖峰若剣鋩となつてゐる。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで続国訳漢文大成の蘇東坡詩集を見ると、岩垂憲徳氏は、之に対して次のやうな講釈を加へて居られる。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "国訳漢文大系本戦国策を読む。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の子供が折りかさなって、国訳『大唐西域記』を覗き込んで、「三蔵法師玄奘｜奉詔訳」という字に眼を光らせて、息をのんでいる。",
              "citation": {
                "source": "『西遊記』の夢",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばインドの原始仏教の文献的内容は、単にそのテキストが国訳されただけでは吾々の理解にとって不充分なので、更に之を現代的範疇と範疇組織によって解釈して呉れなければ、原始仏教の文化内容も遂に今日の吾々の文化内容と接続し得ないで終る。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし国訳（原文対照）支那文学古典をお読みになるのでしたら、国訳漢文大成の文学部が殆ど揃って居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
