[
  {
    "uuid": "76cf8edf-7b58-5218-8309-89d6174868ce",
    "entry": "口内",
    "reading": {
      "primary": "こうない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
