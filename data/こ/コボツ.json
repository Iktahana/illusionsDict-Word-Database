    "definitions": [
      {
        "index": 1,
        "gloss": "to destroy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "九年春、白龍庵｜有司の毀つところとなる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずこれ等を毀つことに孔子は決め、その実行に直接当ったのが子路であった。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず残存している教会堂を毀つとともに、大久保｜忠隣を奉行として近畿に送り、所司代板倉｜勝重と協力して、切支丹の嫌疑のある者を残らず捕縛さし、それを一人一人｜菰に巻いて、四条から五条の磧に三十｜石積、五十石積と云うように積んで、それを片っ端から転がした。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名器を毀つ１　勧修寺大納言経広は心ざまが真直で、誰に遠慮もなく物の言える人だった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "観る者｜眉を顰めて「かかることは曹長にても事足りなん箱を毀つに少佐殿の手を労するはいと恐れ多し」とてこの頃より誰が言ひ初めけん少佐殿の事を曹長閣下とぞ呼びける。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆自ら國を毀つなり。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "」武揚等の艦隊中蟠竜回天の二艦が機関を毀つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　青六と呼ばるゝ大字青柳の青柳六藏は、村長になると同時に、小學校の太鼓樓を取り卸し、二階を毀つて、平家にして了つた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に直接御身の上でなくとも、不都合な心を抱き、天子に對して不滿な心を抱いて宮闕に爆裂彈を投げるとか、山陵を毀つたと云ふものはこの罪に入るのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆自ら国を毀つなり。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は人の隱事を摘發し、或は其私の醜行を公布し、賄賂依托は尋常の事にして、甚しきは腕力を以て爭鬪し、礫を投じ瓦を毀つ等の暴動なきを期す可らず。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに名利はこちらから追い駆けて、あるいは他人を毀つけたり、また己れの本心に背いて得るものと、天より降る露のごとくにおのずから身に至るものとあろう。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸侯の国々の状況で目につくのは、九月十九日、仙石久利、但馬出石城を毀つことを請願して聴されてゐる。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "額ぎはからもみ上げへかけての具合、剃り毀つには堪へられない程の愛着が、師匠源内法師の胸にあつた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等進んで、石城を毀つて、新京の時世裝に叶うた家作りに改めよ、と仰せ下された。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等進んで、石城を毀つて、新京の時世裝に叶うた家作りに改めよと、仰せ下された。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等、天下百姓より進んで、石城を毀つて、新京の時世装に叶うた家作りに改めよと仰せられた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等進んで、石城を毀つて、新京の時世装に叶うた家作りに改めよと、仰せ下された。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる松陰が、「国に酬ゆる精忠十八歳、家を毀つ貧士二十金」の一聯はこの事を指すなり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "イエスはかつて「汝らこの宮を毀て、我三月の間にこれを起こさん」と言われたことがありますが（ヨハネ二の一九）、彼らはこの御言を曲げて、あたかもイエス御自身が宮を毀つと言われたかのごとくに誣いたのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "李斯・姚賈、之を害み之を毀つて曰く、『韓非は韓の諸公子也。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "老莊申韓列傳第三",
                "note": "青空文庫"
              }
            },
            {
              "text": "樋をつたふ雨のこぼつ、こぼつと、石穴にでも溢れてゐるやうな音がして、空は黄灰色に薄昏く、水氣がこもつてゐた。",
              "citation": {
                "source": "あひびき",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この建物は古くてもう役に立たなくなったので、取りこぼつのだとか噂に聞きましたが、それが事実ならば惜しい事実であります。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "今世界は黒い旗をおろし、青空の幕をかゝげ、その中天に仰げとばかり、破るゝがごとき光こぼつ日を照らし出した、ああこの最初のキス。",
              "citation": {
                "source": "展望",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……碩寿翁、碩寿翁、物をこぼつな！",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思ひ、これまでかかりつけの赤十字社病院前の歯科医を訪ねると、そこは強制疎開のために家を取りこぼつてゐる最中であつた。",
              "citation": {
                "source": "三年",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレキの光る星をあび、黒き海馬の護衞にて、くるひただよふ板小舟、それ七月は杖ふりて燃ゆる漏斗のかたちせる瑠璃いろの天をこぼつころ。",
              "citation": {
                "source": "醉ひどれ船",
                "author": "LE BATEAU IVRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやちな印刷機と鐵のステツキ　それにホンの少しばかりの鉛の花型　白い紙に黒いインキ　ただそれだけだ　正義を支持し不正をこぼつ　この印刷者の力に刄向ふ者は誰か？",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかその困難は、藩閥内閣を打ちこぼつよりは一層むつかしかろうと思います。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそび倦ば斯作りたるを打こぼつをもあそびとし、又他の童のこれにちかくおなじさまに作りたるを城をおとすなどいひてうちくるふもあり、そのまゝにおくもあり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
