        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "皇后宮も白い唐衣でお出ましになる。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森｜男の詰襟６・30　今度｜皇后宮大夫になつた大森鍾一氏は官吏は威容を整へなければならぬといふので、何時も葉巻を啣へる事に決めてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "時を移さず皇后宮｜大夫は御前に呼び出された。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇后宮大夫は二三度お辞儀をしたと思ふと、次に控へた皇后宮附の御寝間係を呼出した。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の御前揮毫の節に、当時の皇后宮太夫三室戸伯爵を通じて、改めて二幅双か、三幅双の揮毫を、上納申し上げるようにという御用命を拝したのでございました。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに燦として輝くのは、旭日に映る白菊の、清香｜芳ばしき明治大帝の皇后宮、美子陛下のあれせられたことである。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勧進帳」その他が、明治天皇陛下、皇后宮、皇太后の宮と、天覧につづき台覧になったことは、劇界ばかりではない、諸芸の刺戟になったのだ。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後に、皇后宮廷の饗宴に参上した氏々の女たちに、柏をとつて、御酒を賜ふ際、亡き女鳥王の珠を盗みつけた大楯連の妻を見つけられたことが語られてゐる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝謙天皇は即位の後に、皇后宮職を紫微中台と改め、その長官に大納言藤原仲麿を登用してゐた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古事談』に、　俊明卿（宇治大納言隆国三男、大納言民部卿皇大皇后宮大夫源俊明、永久二年薨）造仏之時、箔料ニトテ清衡令献砂金云々。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さざ浪や志賀の都は荒れにしを　　昔ながらの山桜かな経正都落　皇后宮亮経正は、幼い頃、仁和寺の御室の許で、稚児姿で仕えたことがあった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇后宮亮経正は、武蔵国の住人、河越小太郎重房の軍勢に取り囲まれて討ち死をした。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、越前三位通盛、弟蔵人大夫｜業盛、薩摩守忠度、武蔵守｜知章、備中守師盛、尾張守清定、淡路守清房、皇后宮亮経正、若狭守経俊、大夫敦盛といった名だたる一門の諸将も含まれていた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝謙天皇は即位の後に、皇后宮職を紫微中台と改め、その長官に大納言藤原仲麿を登用していた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "続紀にもしるされているように、「太后（光明皇后）仁慈志在救物、創建東大寺及天下国分寺者、本太后之所勧也、又設悲田施薬両院、以療養天下飢病之徒也」――皇后は慈心ふかく、諸寺建立のために力をつくされたのみならず、皇后宮｜職に悲田と施薬の両院を設け、天下の病者や飢えたる者を救い養われたのは事実である。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし次の孝謙天皇登位とともに、皇后宮職は紫微中台と改められ、不比等の子武智麻呂の次男たる仲麻呂がここにあって専ら内政のことに当った。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　弁信の喋った通り、平皇后宮亮経正は、竹生島で琵琶を弾じた時に、明神が感応ましまして、白竜が袖に現われたかも知れないが、弁信が六所明神で琵琶を奉納すると、白竜が現われないで、竹竿が現われました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "長秋は皇后宮の唐名であるから、皇太后宮大夫であった役名を冠したわけである。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は美福門院の女房｜加賀といって、はじめ皇后宮少進藤原｜為隆の妻であった。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――皇后宮（※子）も、この頃は遊義門院と申す。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
