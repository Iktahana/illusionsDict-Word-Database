    "definitions": [
      {
        "index": 1,
        "gloss": "fortune and misfortune",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
