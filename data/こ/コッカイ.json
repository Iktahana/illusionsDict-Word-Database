    "definitions": [
      {
        "index": 1,
        "gloss": "National Diet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は陸軍大佐となり王党の国会議員となり、Duke of Leinster の娘の Lady Fitzgerald と結婚した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃彼は国会議員として政治生活に入るように彼の父その他からも勧められた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治に対する興味はかなりあったが国会議員として立つ事は好まなかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結核病研究の万国会議　来年九月二十一日より十月十二日まで米国ワシントン府で表題の会議が開かれる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は直に飛行機で広東に行き重要な三国会議に列する。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの県会議員や、国会議員が口先で、政策とか、なんとか、うまいことを並べても、それは、その場限りのおざなりであることを彼等は十分知りすぎている。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この数は二、三、四、五、六のどれでも割り切れるから、一年おきの行事でも、三年に一度の万国会議でも、四年に一度のオリンピアードでも、五年六年に一度の祭礼でも六十年たてばみんな最初の歩調をとり返すのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとがき　この「惜別」は、内閣情報局と文学報国会との依嘱で書きすすめた小説には違いないけれども、しかし、両者からの話が無くても、私は、いつかは書いてみたいと思って、その材料を集め、その構想を久しく案じていた小説である。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、最後に、どうしても附け加えさせていただきたいのは、この仕事はあくまでも太宰という日本の一作家の責任に於いて、自由に書きしたためられたもので、情報局も報国会も、私の執筆を拘束するようなややこしい注意など一言もおっしゃらなかったという一事である。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治二十四年十一月―二十五年三月・四月「国会」）",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治二十五年五月「国会」）　　　　　彼一日　　　　　　　其一　頼み難きは我が心なり、事あれば忽に移り、事無きもまた動かんとす。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、征韓論で破れた板垣退助が、立志社を組織し、国会開設の建白を成すや、人心が翕然として集り、自由民権運動が、天下を風靡した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、明治十二年の夏、アメリカのグラント将軍が来朝するや、明治天皇は、将軍を浜離宮に召されて、政治上の事を、いろ／＼御下問になつたが、将軍の、「承るところに依れば、日本にも国会開設の議論がある由、いづれ憲法を御制定になることと存じますが、何事も忌憚なく言上せよとの御沙汰であるから、申上げます。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、憲法制定、立憲政体の実施については、政府に於ても、明治天皇の大御心に依つてその大方針が確立してゐたのであるから、当時に於ける自由民権運動の騒ぎは、藩閥政府の強権に対して、不平分子が国会開設の名を利しての抗争とも見るべきであらう。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、官民朝野の反目甚だしく、国会開設以来、議会は闘争場の観があつたが、一旦開戦となると、国民は斉しく起つて、渾然たる一体となり、広島で開かれた臨時議会は、僅かに五分間で、当時としては厖大なる臨時軍事費一億五千万円を可決したのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "著名の弁護士で国会議員である名望ある一市民の妻が、とつぜん不思議な病気にかかり、その病気には医師もすっかり悩まされたのであった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来有名なる、岩代国会津の朱の盤、かの老媼茶話に、奥州会津｜諏訪の宮に朱の盤という恐しき化物ありける。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "国立国会図書館は、保護期間を過ぎた書籍のページ画像をインターネット経由で提供する、「近代デジタルライブラリー」プロジェクトを進めている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は国民の団結を造りて、これが総代となり、時の政府に国会開設の請願をなし、諸県に先だちて民衆の迷夢を破らんとはなしぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（詩入）「国を去って京に登る愛国の士、心を痛ましむ国会開設の期」雲や霞もほどなく消えて、民権自由に、春の時節がおっつけ来るわいな。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "独逸、仏蘭西の戦ありし時、加特力派の国会に打勝ちて、普魯西方につきし、王が中年のいさをは、次第に暴政の噂に掩はれて、公けにこそ言ふものなけれ、陸軍大臣メルリンゲル、大蔵大臣リイデルなど、故なくして死刑に行はれむとしたるを、その筋にて秘めたるは、誰知らぬものなし。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "国会とか内地雑居とかいうものが極楽のように喜ばれたり地獄のように恐れられたりしていた。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫故、国会開設が約束せられて政治休息期に入っていた当時、文学に対する世間の興味は俄に沸湧して、矢野とか末広とか柴とかいう政治界の名士が続々文学に投じて来たが、丁度仮装会の興に浮れて躍り狂っていたようなもので、文人其者の社会的価値を認めたからではなかった。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃｜村山龍平の『国会新聞』てのがあって、幸田露伴と石橋忍月とが文芸部を担任していたが、仔細あって忍月が退社するので、（あるいは既に退社していたのか、ドッチだか忘れてしまったが、）その後任として私を物色して、村山の内意を受けて私の人物見届け役に来たのだそうだ。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分緑雨は『国会新聞』の客員という資格で、村山の秘書というような関係であったらしく、『国会新聞』の機微に通じていて、編輯部内の内情やら村山の人物、新聞の経営方針などを来る度毎に精しく話して聞かせた。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑雨の全盛期は『国会新聞』時代で、それから次第に不如意となり、わざわざ世に背き人に逆らうを売物としたので益々世間から遠ざかるようになった。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとまあ、美しいこっかい！",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
