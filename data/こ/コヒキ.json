        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "温かみのある白さが特徴の粉引の茶碗は、使うほどに味わい深い表情に変化していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "陶芸教室の体験で、素朴な風合いの粉引の皿を自作することに決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "料理好きな彼女は、手作りの和食がよく映える粉引の器を少しずつ集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "市木さんは引留めはしなかったが、びっこひきながら、階段を降りて下の縁側まで見送ってくれた。",
              "citation": {
                "source": "絶縁体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間はなんでも慣れっこになるなんて言うが、それはお人よしの言うことだよ」　びっこひきひきかれは食卓の回りを回って、さらやさじならべた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けにみんなが疲れてびつこひきながら野営へ戻つてくると、荒掠者は引あげていて、二人の人間は機嫌を悪くしていた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ひとりが、「まことに、ここひきつづいて、おもしろからぬことのみ、お耳にいれ、恐縮にござりまするが、いまは鎌倉の存亡にもかかわる大事と見えますれば、なにとぞ、ご勇断のもとに、さいごのおさしずを下したまわりたく」　と、さしせまった地方情勢の険を、絵で画くように、わかりやすく、上聞にいれた。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
