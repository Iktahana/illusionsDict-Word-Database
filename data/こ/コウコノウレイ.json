[
  {
    "uuid": "fae5d5d6-6e8f-5032-ba16-cfc62349f841",
    "entry": "後顧の憂い",
    "reading": {
      "primary": "こうこのうれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
