    "definitions": [
      {
        "index": 1,
        "gloss": "inside one's heart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「でも、自分の心の中は、無念さうなのではないのだがなあ。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔つて疲れて私の瞼はイラ痒いとは云へ、人よ汝がそのやうなことを気にするのであれば、あゝ、それは世間をばかり心の中に相手として置いてゐるからだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "女ははじめにはそれを少々心の中で笑つてゐたのだが、遂にはそれを信じたらしかつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼等の作家が居ない前から、本來子供自身の心の中に、童話が實在してゐたのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の心の中では固くその人物と握手をし、「私の愛する親友！",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "各自の望みを追うに暇のない世人は、たまに彼の萎びた掌に一片の銅貨を落す人はあっても、おそらくはそれはただ自分の心の中の慈善箱に投げ入れるに過ぎぬであろう。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心の中にはやつぱり臆病な御氣嫌買ひの蟲がゐる。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり心の中で泣いたから、外へ涙を流すことが出來ない。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "セコンドメイトは、私が、どんなに非常識な事をいっても「憤ってはならない」と心の中で決めているらしかった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の心の中にどっしりと腰を下して、彼に明確な針路を示したものは、社会主義の理論と、信念とであった。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "吠え面かくな――と彼は心の中で思った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちの心の中にも心細さが増したであらう、と云ふことも私には分つてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心の中は「心細さ」と云ふやうな感じはなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私より遙かに先きに立つて、暗闇の中に姿を消してしもうた子供たちの心の中に、私は入らうと努めた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何をあの子等は考へてゐるであらう――　だが、私は子等の心の中へだけ入り込んで終ふと云ふことは出来なかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子等の心の中に入り切る事は出来なかつたが、あの子たちよりも、もつともつと不幸な子供たちが沢山あるし、又、これからはもつと、ずつと殖えるに違ひない、と私は思つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして心の中で、わが眷属は、分身は、性格の一面は、と想った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の心の中に、表現し得ずして表現し度い必死の気持が、歯噛みをした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮のない相手に向って放つその声には自分が世話をしている青年の手前勝手を詰る激しい鋭さが、発声口から聴話器を握っている自分の手に伝わるまでに響いたが、彼女の心の中は不安な脅えがやや情緒的に醗酵して寂しさの微醺のようなものになって、精神を活溌にしていた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことがあるのでありますから、言語の音を区別して別の音とするのは、音自身のもっている性質というよりは、その音を聴き、あるいは使う人の心の中での心理的のはたらきであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、當時の友人や訪問者が、だれも皆心の中で考へたほど、室生の机の上にある時、それは魅力ある高價な藝術品のやうに見えた。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　背後姿を見ながら、私も心の中でさう叫んだ。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕はその言葉を、君の心の中に推察した。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の中でもさうしたことを考へてゐても實際の行爲では仲々できないのである。",
              "citation": {
                "source": "室生犀星の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かわからない、或る漠然とした一つの予感が、青ざめた恐怖の色で、忙がしく私の心の中を馳け廻った。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "――即ち、自分の中に閉ぢ籠つて、自分の心の中心から自分に云ひつけられた仕事を一氣に仕上げること。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつぱりあの時が臨終だつたのか――と、私は心の中で呟いた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何て噂話の好きな人達なんだらう……」と、私はふとそんな事を心の中で考へながら、武井さんの顏をちらりと見た。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は口を噤んで、お前の脱殼になつた寢臺の白い敷布を見詰めながら、心の中で暫くこの二面と爭ひ合つてゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はひよいと或る空虚を心の中に意識せずにはゐられなかつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
