[
  {
    "uuid": "685e88c8-e940-5b50-9789-180a19ed1a01",
    "entry": "小鰭",
    "reading": {
      "primary": "こはだ",
      "alternatives": [
        "コハダ"
      ],
      "is_heteronym": false
    },
    "grammar": {
