[
  {
    "uuid": "3d753148-503f-5613-a99f-f672e9b012c5",
    "entry": "肥やす",
    "reading": {
      "primary": "こやす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
