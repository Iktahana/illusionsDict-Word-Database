      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to fertilize",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "病院で手術した患者の血や、解剖学教室で屍体解剖をした学生の手洗水が、下水を通して不忍池に流れ込み、そこの蓮根を肥やすのだと云うゴシップは、あれは嘘らしい。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本には昔からずいぶんいろいろな危険思想が海外から幾度となく輸入されたが、それが抑圧に抗しながらやっと土着するころにはいつのまにかすっかり消化され日本化されてしまって結局はみんな大日本を肥やす肥料になっていた。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の財産のために、自分の財産を肥やすために、おれらの親父を突き落とした奴がいるんだ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで七匹の獣閣下は辞任して、新らたに七匹が選ばれた、然しこれまで森では自分の身を飾つたり、自分の腹を肥やすことにばかり熱中してゐるといふ、身勝手な獣ばかりが選ばれるので、森の獣達が今度選ばれた七匹も信用しなくなつてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "▲文人の資本は紙と筆ばかりのように云う人があるが、文人は常に頭脳を肥やす滋養代に中々資本が要る。",
              "citation": {
                "source": "駆逐されんとする文人",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳の米三郎は早くから絵事に志ざした風流人であって、算盤を弾いて身代を肥やす商売人肌ではなかった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京は、地方に芽ざした聖い仕事の種子を積上げて、腐らして、あらゆる不良政治家、不良事業家、不良学者、不良老年、不良少年少女の根を肥やすための大堆肥場である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちを空っぽにして遊ぶことばかり考えている……儲けた金で妻子を肥やすのをシミッタレと考えている心理状態がよくわかる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "羨ましいぞえ　製罐工場の女工さんは一度港出て罐詰になって　帰りゃ国を富まして身を肥やす無くちゃならない罐つくる。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "異人でもマドロスでも構わねえ、銭のある奴は相手にして、ふところを肥やすのが当世かも知れねえ」と、松吉は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "――秋はこんなやくざな小魚を養ひ肥やすことをも忘れないのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "堆肥ぎようさん入れて一寸でも二寸でも甘土あ肥やすし、上手の方さ土手作つて雨降つても大丈夫のやうな工夫もした。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "草鞋の緒きれてよりこむ薄かな　　　末枯や覚束なくも女郎花　熱海に着きたる頃はいたく疲れて飢に逼りけれども層楼高閣の俗境はわが腹を肥やすべきの処にあらざればここをも走り過ぎて江の浦へと志し行く。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆足万里はかつて留守居を罵って、国財を靡し私腹を肥やすものとした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを賠償することは出来ないが、相手に大きな損害をかけながら、自分は懐を肥やすと云ふのでは気が済まないから、せめて原稿料だけでも犠牲にしようと、私はさう思つたのである。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の根、草の根、肥やすか知れない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計の方は一切清水が握っていて、いわば先生は清水の懐を肥やす為に、毎日働いていなすったんだわ。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の人間だったら、どうせいくら稼いだって、他人の懐を肥やすだけですもの、働くのもいい加減嫌になるはずだけれども、先生は患者さんにはそれはご親切だし、前いったように、診察は名人だったから、なかなか流行ったわ。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからミサちゃんの都合さえよかったら、よそを肥やすより、うちをすけて貰えまいかしらと思って――」　ミサ子が急場の返事に困って黙っていると、「図々しすぎる？",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、支那の役人は上下を通じ自分の懐を肥やす事にのみ腐心し、儲けることなら少し位の悪事は何とも思っていないから、幇匪と通じて財物を掠めたのも寧ろ当り前の話であろう。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方村役人の身でありながら、従来村方の利益を計らず、村役人の権を笠に、賄賂を取り請託を入れ、私腹を肥やすこと著しかりしよし、よって今日天誅を加う！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "如才なく切って回す力量なきかわりには、主家の収入をぬすみてわがふところを肥やす気づかいなきがこの男の取り柄と、武男が父は常に言いぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、遠からず団栗も色づいて、猪の肉を肥やす季節がくるのであろうなどと、まことにのんきなことを考えながら、峠のてっぺんの茶屋の縁台に梨子を噛って、四方の風景にながめ入った。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、遠からず団栗の果も色づいて、猪の肉を肥やす季節がくるのであらうなどゝ、まことにのんきなことを考へながら、峠のてつぺんの茶屋の縁台に梨子を噛つて、四方の風景にながめ入つた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちカルタゴのごとき、ツロのごとき、もしくはアテネのごとき、あるいは地中海の沿岸に星羅したるツロ、ギリシアの諸植民地のごとき、自由の光輝を上古の社会に放ちたるものなきにあらずといえども、小魚は大魚の餌となり、小敵は大敵の擒となり、ついに近傍の腕力国の腹を肥やすの食物となれり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その獅子の後に従いて、獅子の獲物の残物に、其腹を肥やすことは、土人の常に目撃する所なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の継母は既に長年の間内証の貯金を肥やすことにのみ努めてゐることは親類中に知れてゐた。",
              "citation": {
                "source": "ある職工の手記",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子｜良望から正盛まで六代、諸国の受領として、私腹を肥やす傍ら、武門の名を次第に轟かしていったのである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか私達は、たこやす、おでん屋の段といふ長い名前の家に紛れ込んでゐた。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイのコサックや傑出した短篇「ハジ・ムラート」を読むだけでいい、帝政時代の権力は、自分たちをこやすために搾取するための植民地、属国、だましやすい辺土の住民としてだけ彼等を思い出した。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
