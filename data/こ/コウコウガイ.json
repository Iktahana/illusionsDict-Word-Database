        "examples": {
          "standard": [
            {
              "text": "歯科医は、彼の硬口蓋に小さな炎症があるのを発見した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この発音は舌先を硬口蓋に触れさせて行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "赤ちゃんが硬口蓋を傷つけないように、離乳食の温度には注意している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "つい先達て「歯」のことを書いた中に「硬口蓋」のことを思い違えて「軟口蓋」としてあったのを手紙で注意してくれた人があったが、こういうのは最も有難い読者である。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上あごの硬口蓋前半をぴったりふたをしてしまった心持ちはなんとも言えない不愉快なものである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯ぐきや硬口蓋への圧迫から来る不快の感覚が精神的不快の背景の前に異常に強調されて来るらしい。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
