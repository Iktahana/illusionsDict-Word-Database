    "definitions": [
      {
        "index": 1,
        "gloss": "computer output microfilm system",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
