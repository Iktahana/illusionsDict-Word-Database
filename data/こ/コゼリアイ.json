        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕とやつは何度か小競り合いをしたことがある。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "高貴の方の御着発の時などは、停車場のプラットフォームで、写真師と警察との撮ろう撮らせまいの小競り合いがいつでも行われています。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "めかし込んだ青年たちはこれまで小競り合いを傍観していたが、みんなして婦人を救い出し、負傷した男を介抱しようとした。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "首藤は、若者たちと太田一派の小競り合いを面白がって眺めていた。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "生地は甘うないけん、平気じゃ」　伯母と将昭がいつもの小競り合いをしている間も、健一は鯨羊羹に想いを馳せた。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはまだ最初の小競り合いにすぎなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断に小競り合いや打つかり合いがあつて、しじゆう紛争が起り、その影にはいつもバックが居た。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "「曳きだす」という文句について小競り合いがおきた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダガスカルの赤い斑点と小競り合いをしたときは全くもって気分が悪かったな。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに小競り合いは過ぎ去った。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "国境をどこに引くかをめぐる小競り合いは続いているし、これから数年の間は終わらないだろう。",
              "citation": {
                "source": "あなたと原子爆弾",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、大将は夢うつつ状態であり、平和だろうが、国家間の小競り合いがあろうが、分らない。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま舞台で小競り合いが行われているから、ライフルをぶっ放してもかき消されて、舞台の争いに聞こえるぜ」　ラッツィン大将がにやっと笑って言った。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い範囲で何千人がひしめき小競り合い、真っ白い静寂な空間は乱闘する人間で真っ黒になり、騒乱の声が遠くまで響いた。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "国境方面では、絶えずどこかで小競り合いがあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "織田家の出城と、三河方との出先の小競り合いなどは、勿論、熄むまもなかったし、それがいつ大きな発火点となって、両国の運命を賭すものとなるか、決して予測はできなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "美濃への出陣は、去年の秋ぐちから再三のことであって、その都度、木曾川の国境を、衝いては引き、また越えては退り、彼の反撥を小当りにあたってみるような小競り合いを繰り返していたものである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "小競り合いと見て、それには誰も動じなかったが、当面の問題には、まったく困憊のいろを漲らしていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "城中の結束のいかに強固なものかを、秀吉は、前の中村の惣領娘のときにも、手きびしく示されたが、その後の小競り合いにも、こんな一例があった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "小競り合いでも、敵が寄せてくると、俄然、飢えもつかれも忘れはてて戦える。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを遮ろうとする町年寄や、会所の者との間に、小競り合いが始まっているらしく、暴動的な殺気さえ漲って見えた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "呂布は、一大事とばかり、ようやく山間の小競り合いをすてて引返して来た。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「もはや事の半ばは成就したも同じだ」　曹操は左右へいって、「――だが、夜に入るまでは、息つきの小競り合いに止めておいて敵が誘うとも深入りはするな」　と、誡めた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日は小競り合いに過ぎた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "自ら階級文藝運動の戰士を以て任ずる人々にして往々これを理會しない爲めに大衆に對する運動を個人同志のこぜりあいと勘ちがいしているものがある。",
              "citation": {
                "source": "文藝運動と勞働運動",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "××と職工のこぜりあい。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
