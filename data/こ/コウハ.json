[
  {
    "uuid": "94d26304-e0cb-5190-afa7-5c4593e01cc1",
    "entry": "光波",
    "reading": {
      "primary": "こうは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
