[
  {
    "uuid": "71dc9bdb-bc6f-53c3-9606-9ccdf1a9ba32",
    "entry": "此れ",
    "reading": {
      "primary": "これ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "代名詞"
      ],
