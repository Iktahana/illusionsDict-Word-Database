  {
    "uuid": "b08e915e-5fa9-5a59-a336-c4ca350dd0db",
    "entry": "こね粉",
    "reading": {
      "primary": "こねこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dough",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一人別の職人が、パンのこね粉をむしって、なにかこしらえ、ナースチャに見せるように高くさし上げる。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石崖の下の雪どけで、道が餡このようにこねこねしている通りの旅人宿に、一泊三十銭で私は泥のような体を横たえることが出来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の下の、雪どけで、道がこねこねしている通りの、旅人宿に、一泊参拾銭で私は泥のような体を横たえた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こねこは　しろい　あしを　ぺろぺろするだけでした。",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こねこなんか　こわくありません。",
              "citation": {
                "source": "モペットちゃんのものがたり",
                "author": "THE STORY OF MISS MOPPET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで　こねこたちを　うちのなかに　いれて、　おきゃくさまが　つくまでに　よごれを　おとして　きがえを　させようとしたのです。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "３びきの　こねこの　したくが　できると、　ママの　タビサが　あろうことか　みんなを　にわへと　だしてしまって。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "３びきは　たちどまり、　よこに　ならんで　こねこたちを　みあげます。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへとうとう　ぐいぐいタビサが　にわへと　やってきて、　へいのうえで　はだかになっている　こねこたちを　みつけたわけです。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "へいから　ひきずりおろされ、　おしおきされ、　こねこたちは　うちへと　つれもどされました。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに　こねこが　４ひきも　うまれて、　おまけに　おやねこが　カナリアを　おそってしまって。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人何びき何ぶくろセント・イブへとわしがおまいりするときに、わしがあったは男ひとりにおかみさんが七人、そのどのおかみさんもふくろを七つ、そのどのふくろにもねこめが七つ、そのどのねこにもこねこが七つ。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
