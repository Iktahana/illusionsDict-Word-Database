        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このごろ、のら猫の連れていた子猫のうちの一匹がどうしたわけか家の中へはいり込んで来て、いくら追い出しても追い出してもまたはいって来て、人を恋しがって離れようとしない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の主人が一匹の子猫の頸をつまんでぶら下げながら橋の向う側の袂へ行ってぽいとそれをほうり出した。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまきは若いときから猫が好きであったが、それが年をとるにつれていよいよ烈しくなって、この頃では親猫子猫あわせて十五六匹を飼っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "満七年の間に三十匹ほどの子猫の母となった。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後妻が近所で捨てられていた子猫を拾って来た。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後｜仙台へ行ってＫ君を訪問すると、そこにいた子猫がこれと全く生き写しなのでまた驚かされた。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では「三毛」の孫に当たる子猫の雌を親類からもらって来てある。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "クねずみはだんだん四方の足から食われて行って、とうとうおしまいに四ひきの子猫は、クねずみの胃の腑のところで頭をコツンとぶっつけました。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其うしろ姿は正しく猫、加之も表通りの焼芋商に飼つてある雉子猫だ。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、すぐ眼の下になった怒濤の中に、船の破片らしい一枚の板に一匹の子猫がしがみついているのが見える。",
              "citation": {
                "source": "義猫の塚",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十一年四月、渋柿）　　　　　　　＊　子猫が勢いに乗じて高い樹のそらに上ったが、おりることができなくなって困っている。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子猫はとうとう降り始めたが、脚をすべらせて、山吹の茂みの中へおち込んだ。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、縁側におろされた子猫をいきなり嘗め始める。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子猫は、すぐに乳房にしゃぶりついて、音高くのどを鳴らしはじめる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある宵の即景名月や糸瓜の腹の片光り（昭和二年十一月、渋柿）　　　　　　　＊　子猫がふざけているときに、子供や妻などが、そいつの口さきに指をもって行くと、きっと噛みつく、ひっかく。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方家へ帰って見ると、見馴れぬ子猫が一匹いる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも以前に一度、やはり小鳥が死ぬか逃げるかした同じ日に、子猫が迷い込んで来たことがあったような記憶がある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに子猫はだんだんに生長して時々庭の芝生の上に姿を見せるようになった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青く芽を吹いた芝生の上のつつじの影などに足を延ばして横になっている親猫に二匹の子猫がじゃれているのを見かける事もあったが、廊下を伝って近づく人の足音を聞くと親猫が急いで縁の下に駆け込む、すると子猫もほとんど同時に姿を隠してしまう。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日妻がどうしてつかまえたかきじ毛の子猫を捕えて座敷へ連れて来た。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな子供らはこの子猫を飼っておきたいと望んでいたが、私はいいかげんにして逃がしてやるようにした。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこのほうは前のきじ毛に比べると恐ろしく勇敢できかぬ気の子猫であった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのきかぬ気の勇敢な子猫に対して何かしら今までついぞ覚えなかった軽い親しみあるいは愛着のような心持ちを感じた。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食のあとなどには庭のあちらこちらに伏兵のようにかくれていて、うっかり出て来る子猫を追い回してつかまえようとしていたが、もうおとなにでもつかまりそうでなかった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに募る迫害に恐れたのか、それともまた子猫がもう一人前になったのか、縁の下の産所も永久に見捨ててどこかへ移って行った。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子猫は見るたびごとに大きくなっているようであった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子猫をもらうという事について相談はしばしば受けたようであるが積極的に同意はまだしなかったはずであった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子猫がほしいという家族の大多数の希望が女中の口から出入りの八百屋に伝えられる間にそれが積極的な要求に変わってしまったらしい。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このぶんでは今に子猫は死んでしまいそうな気がした。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石崖の下の雪どけで、道が餡このようにこねこねしている通りの旅人宿に、一泊三十銭で私は泥のような体を横たえることが出来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
