          "standard": [
            {
              "text": "筋骨隆々とした特牛が、重い荷車を軽々と引いて坂を登っていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祭りの先頭を歩く特牛の角には、色鮮やかな飾りが付けられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その牧場で最も力強い特牛は、周囲の牛たちを圧倒する風格を持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……五月廿二日　あぶないお天気だけれど休めない、行乞しつゝ四里は辛かつた、身心の衰弱を感じる、特牛港、三国屋（三〇・中）此宿はおもしろい、遊廓（といつても四五軒に過ぎないが）の中にある、しかも巡査駐在所の前に。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
