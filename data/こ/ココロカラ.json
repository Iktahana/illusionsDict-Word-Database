    "definitions": [
      {
        "index": 1,
        "gloss": "from the bottom of one's heart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神は貴族とエゴイストとを罰するために彼等の心から愛憐の芽生をぬき去つた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようなこと、決してないのです』と夫人が言うに対しても、『心からの話、真面目のことです』と言い、『仕方ない！",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の平然と呟くところに依れば、彼がこのようにしばしば服装をかえるわけは、自分についてどんな印象をもひとに与えたくない心からなんだそうである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それは決して大隅君の本心からのものではなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京のいろは骨牌では、イが「犬も歩けば棒にあたる」であるが、大阪の方では「鰯の頭も信心から」で、絵札には魚の骨から金色の後光がさし、人々のそれを拝んでいる様が描いてある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが見るまに大きくなり、その中心から新しい芽が泉のわくようにわき上がり延び上がった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草も木も軒も障子も心から寒そうな身慄をした。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し謝源がこれを聞いたならキツと心からの苦笑を洩らしてしまふにちがひない。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とＮさんは、本心から同感を寄せて下さる。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふ言葉は、私の本心からのもので、それは、ちつとも變つてゐない。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物が高くなるほど、富士が見えなくなり、交通が便利で、東京富士間の距離が短縮されるほど、市民の心から富士は切り取られて、さらしッ放しの無縁塔となってしまった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が急いで急坂を上るのは、私の身心から発散する墓場の雰囲気が恐ろしかつたのだと、私は考へた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして同病相憐む心から私は急いで其處を通り過ぎねばならなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は生れ付きの女の防禦心から眼をわきへ外らした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡しを渡った向岸の茶店の傍にはこの頃毎日のように街の中心から私を尋ねて来る途中、画架を立てて少時、河岸の写生をしている画学生がいる。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「粋な浮世を恋ゆえに野暮にくらすも心から」というときも、恋の現実的必然性と、「いき」の超越的可能性との対峙が明示されている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の一昨年うせたる時も、母の去年うせたる時も、心からの介抱に夜るも帯を解き給はず、咳き入るとては背を撫で、寐がへるとては抱起しつ、三月にあまる看病を人手にかけじと思し召の嬉しさ、それのみにても我れは生涯大事にかけねばなるまじき人に、不足らしき素振のありしか。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "北原白秋氏が氏を訪うた時、氏は心から悦んで客をもてなし、年來の長い鬱憤をもらされたさうである。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は決して、心から人を憎むことの出來ない男で、何物に對しても涙ぐましく、情緒のいぢらしさで眺めてゐる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸途に再度大船で別れる時には、もはや心から諸君に握手して禮をのべた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや他の一般の敵に對しては、すべて皆心から抱擁し、最も憎むべき忘恩者や裏切者でさへも、降參する以上はすべてを許して優遇した。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはこの詩集に珍貴な値を求めたいといふ物好きな心からであつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの高い友情は今友の内心から突然に消え失せたとは思へなかつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　その重さこそ常々私が尋ねあぐんでゐたもので、疑ひもなくこの重さは總ての善いもの總ての美しいものを重量に換算して來た重さであるとか、思ひあがつた諧謔心からそんな馬鹿げたことを考えて見たり――何がさて私は幸福だつたのだ。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは履歴のない椅子に履歴を附けて遣らうと云ふ公平な心からである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "――即ち、自分の中に閉ぢ籠つて、自分の心の中心から自分に云ひつけられた仕事を一氣に仕上げること。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ずつと心からの祈りだつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ弟の身の上は、心から可哀相でならない。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生どうか私のこころからうやまいを受けとって下さい。",
              "citation": {
                "source": "マリヴロンと少女",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという事も無い、ただ、ただ、隠君子の心境を味わってみたいこころからである。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
