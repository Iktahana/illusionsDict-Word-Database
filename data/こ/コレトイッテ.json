[
  {
    "uuid": "55b28900-dbf3-52d4-8d30-3870c2dd0b1a",
    "entry": "これと言って",
    "reading": {
      "primary": "これといって",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "副詞"
      ],
      "ctype": null,
