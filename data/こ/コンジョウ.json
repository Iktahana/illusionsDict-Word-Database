[
  {
    "uuid": "4c21f516-c3e9-5fe6-9918-a55e8f50501d",
    "entry": "今生",
    "reading": {
      "primary": "こんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "this life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは校長が若い時分から、自分の生来根太い狡猾な性質に困り果てながら、聖賢の書を漁つた時に、始終心で云つてたことが、今生徒を前にした今、形を取つて表れて来たのである。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら彼等は、今日只今生れたばかりの、全く新鮮な自由の心で、一切の宇宙を見るからである。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿難　――わたしに今生れたこの心持は、あなたのいう恋とかいうものとは違うかも知れない。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今生きてゐるあらゆる人間に聞いたつて、誰も前途を見届けるまで命をもつて居るものはない。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私も今生きていると、いい年増の姉が二人もいたのよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今生きてゐる村人ばかりではありません。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ帰ることにきめて、バスの発着所のベンチに腰をおろし、十分くらゐ休んでまた立ち上り、ぶらぶらその辺を歩いて、それぢやあ、もういちど、たけの留守宅の前まで行つて、ひと知れず今生のいとま乞ひでもして来ようと苦笑しながら、金物屋の前まで行き、ふと見ると、入口の南京錠がはづれてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は空に湧く白い粉雪の一片一片を今生れたばかりの活きた羽虫の一匹一匹として喜び、大人は死んだ鵝鳥のそのむしり散らした羽毛の一片一片に譬へて観賞します。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "御迷惑でも今夜は当方に御泊りなされて、主人の願いを御聞き届けくださいますように」　八郎は不安に思わぬでもなかったが、立派な武士の病人が今生の頼みと聞いては、往ってやらないわけにもゆかなかった。",
              "citation": {
                "source": "人面瘡物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分今生の見納めであろう富士山が……。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今生の思い出に今一度、見たいと思うてはおりまするが、今の体裁では思いも寄りませぬ事で……」「……おお……それそれ。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今生の見納めに連れ立って見に参ろうでは御座らぬか。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この後信綱自ら四郎へ、降伏すべき手紙を送ったが、四郎の返書には、松倉氏の暴政を綿々として訴え、信仰の変え難きを告げ、「みな極楽安養すべきこと、何ぞ疑ひこれあるべく候｜哉、片時も今生の暇、希ふばかりに候」と結んで居る。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今生にて今一度竜顔を拝し奉らんために参内仕りて候ふと申しもあへず、涙を鎧の袖にかけて、義心其の気色に顕れければ、伝奏｜未奏せざる先にまづ直衣の袖をぞぬらされける。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ巣ごもり居て、薔薇の枝の緑の葉を啄めども、今生ぜむとする蕾をば見ざりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきの日尼寺の病室より、識らぬ女の文とゞきて、今生死の際に在るものなるが、マリアに逢ひて申し殘したき事ありといへば、舟にてかしこに伴ひゆき、われは尼達の許に留まりて、マリアを病人の室に遣りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも諾威に今生きてゐるだけの漁師の内の、一番の年寄を連れて来て聞いて見ても、あの時のやうな暴風に逢つたものはないだらうと存じます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手に――もう一度、今生の思出に、もう一度。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "満腔の不平を湛えて、かえって嫣然として天の一方を睨むようになり得ると、こはいかに、薄汚い、耳の遠い、目の赤い、繿縷を纏った婆さんが杖に縋って、よぼよぼと尋ねて来て、生の母親が大病である、今生でたった一目、名残が惜みたいという口上。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、今生きていて、そしてその子供がもう子供を持ってる、という、お祖父さん級の人間だ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "想ふに彼等の驚愕と恐怖とはその殺せし人の計らずも今生きて来れるに会へるが如きものならん。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやいやながらも接待係りを勤めたので、今生に北洲の自然粳を採り来て美食に飽き得たというのだ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かまきりはたった今生捕ったばかしの小さな赤とんぼを、大事そうに両手でもって胸へ抱え込んでいる。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしお骨折により、拝見が叶いますならば、今生の面目この上もない事かと存じます。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思えば、彼は今生の思い出としても、飽かずその懸物に見入りたかった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたっててまえはこれが好物でござりますので、もうお番所からさきほどのようにお使いがあった以上は、いずれてまえのお手当もそう遠くないと存じ、今生の思い出に腹いっぱい用いておこうと思いまして、やぶれかぶれにやっていたのでござります」「猥褻至極なやつじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のもとへ逃げ走って、今生の思い出に蛤鍋なぞをたらふく用いるとはなにごとじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "船井三郎という人間はつい三日前に死亡届が出ており、船井家には今生きている者は一人もないので戸籍は無くなってしまっているから抄本はつくれぬという通知であった。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "今生き残っているのは建具屋のおじいさん一人であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
