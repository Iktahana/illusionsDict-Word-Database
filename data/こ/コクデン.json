    "definitions": [
      {
        "index": 1,
        "gloss": "city electric train service operated by (former) Japanese National Railways",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "国電の初乗りが、三十円だった時期の話です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "国電のガードをくぐり抜けると、ファサードが丸みをおびた、異常に縦長の濃灰色のビルがある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サール博士は語る」と外国電話が入ってきた。",
              "citation": {
                "source": "ある宇宙塵の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "国鉄当局は九日―十一日の国電ストの損害賠償として組合あいてに二千万円の支払いを提訴した。",
              "citation": {
                "source": "「推理小説」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国電田町駅前の日本電気本社ビル。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密主義の軍閥政府は出兵についてまだ今日まで一言も口外しませんから、私たちは外国電報と在野の出兵論者の議論とに由って想像する外ありませんが、政府に出兵の意志の十分にあることは、干渉好きの政府が出兵論者の極端な議論を抑制しない上に、議会において出兵の無用を少しも明言しないので解ります。",
              "citation": {
                "source": "何故の出兵か",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は幸福な太陽と大空との恍惚からはなれて、パンをむしりながら、新聞の外国電報欄を注意深く読みながら壁間の世界地図の上にその一字一句を明確に具象化することのたのしみにうつつてゐた。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国電報で、ウィンの郊外に居る久野久子氏がホテルの三階からとび降りて自殺未遂をしたと云う。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "国電、都電にも近く、ドロボー君のアジトとしては日本有数の好点。",
              "citation": {
                "source": "吝嗇神の宿",
                "author": "人生オペラ　第二回",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃より国電の土手沿いまで大塚花街は発展したと聞くけれど、かの未亡人を思うにつけ坊野寿山子が川柳の巧さよ。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路と、濠を隔て、国電のホームが見えている。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "国電で四谷まで行き、地下鉄に乗換え、西銀座で降りる。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、この世には、殺されたって、言えないようなことだって、あるでしょう……逃げ隠れしたからって、そんなふうに、かたづけてしまわれるのは、つらいな」　二十時の国電の上りが、山々に警笛の音をこだまさせながら、亀ヶ｜谷のトンネルにつづく切取の間へ走りこんで行く。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――処で一方、レーニン等によれば、ソヴェート権力は全国電化と結合して初めて現実的な意味を得るのだった。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "フッコ釣りの早出に、舟宿へ行って泊まろうと、最終国電で酔って駅前までくると、非常警戒にぶつかった。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "国電などの場合と比較したら、予想外に、そんな被害はない。",
              "citation": {
                "source": "俗即菩提",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年の冬のことで、満員の国電の中で真理子は大声でトン子が、トン子を、と小田富子のあだ名を呼び、恋がどうの、愛がどうの、誠実はどうのと興奮して叫ぶような声をあげた。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは国電の線路に沿って歩きはじめ、渋谷から品川まで、しゃべりながら歩きとおした。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は同じ方向に向かう国電に、はなればなれに乗ることすら耐えきれなかったのだ。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何より大切なのは最近の外国電報だから、それを忘れないやうに持つて来給へよ。",
              "citation": {
                "source": "鰐",
                "author": "ドストエウスキー　Fyodor Mikhailovich Dostoevski",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗くなった秋空の下を、リュック姿で、何べんも振り返りながら国電荻窪駅の方へ歩いて行った。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "位置は、国電の線路をはさんで、東西に対照的になっている。",
              "citation": {
                "source": "乱歩分析",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "志田文雄は我が国電気工学の泰斗故志田林三郎博士の嗣子で、父君と専攻を同じくした。",
              "citation": {
                "source": "旧友の死",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "国電の渋谷駅東口のターミナルで都電を降りた彼は、国電の下を抜けて北口へまわり、東横百貨店の前へと歩いた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "西側の端をおさえる道のすぐ外側、つまりさらに西側は、歩道のある道をへだてて国電の高架だ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "国電で有楽町までいき、そこで降りた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっすぐいけば、神田駅のちかくで国電のガードをくぐる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "都心から国電の乗りかえなしでいける、東京のはずれに近い駅。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
