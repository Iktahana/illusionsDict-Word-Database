    "definitions": [
      {
        "index": 1,
        "gloss": "to make",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから拵える人は、おまえさんの母さんだよ。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アメリカ人がどうして、日本の偽札を拵えるの？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、どうして拵えるの？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから弗の偽札は拵えずに、円の偽札を拵えるんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この餅｜拵えるのは仙台領ばかりだもな。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の心中立を物珍らしそうに、世の中にゃあ出ねえの、おいらこれッきりだのと、だらしのねえ、もう、情婦を拵えるのと、坊主になるのとは同一ものじゃあございませんぜ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（指環も簪も拵えるのじゃ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれ、あんなあの、握飯を拵えるような手附をされる、とその手で揉まれるかと思ったばかりで、もう堪らなく擽ったい。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに道具を拵える暇がありますから、十日というけれども、せいぜい三日か四日で片附けて、あとはそういう方の暇を見てやらなければならない。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その見本によって衣裳屋が拵えるので、それも一人や二人じゃない、大勢出て来る連中のを皆画いてやるのだから大変です。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "汁でも拵える支度をして置くが可いさ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "春着をこしらえるなら拵えるように、せめて手付けの一両ぐらいこっちへ預けて置いてくれなけりゃあ、どこの呉服屋へ行ったって話が出来ませんよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験所前の曲ものや折箱を拵える手工業を稼業とする家の離れの小｜座敷を借りて寝起きをして、昼は試験所に通い、夕飯後は市中へ行って、ビールを飲んだり、映画を見たりする単純な技術家気質の学生生活が始まった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈四郎は白木綿で包んだ鼈を生埋めにする熱灰を拵える薪の選み方、熱灰の加減、蒸し焼き上る時間など、慣れた調子で苦もなくしてみせ、蛍雪は出来上ったものを毟って生醤油で食べると近来にない美味であった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸の肉は釦の筋に竪の谷を拵えるほどむっちり盛り上っている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして拵えると竹が熟した時に養いが十分でないから軽い竹になるのです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この面倒な法は加州やなんぞのような国に行くと、鮎を釣るのに蚊鉤など使って釣る、その時蚊鉤がうまく水の上に落ちなければまずいんで、糸が先に落ちて後から蚊鉤が落ちてはいけない、それじゃ魚が寄らない、そこで段々細の糸を拵えるんです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一つ拵える。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「どうしてったって、段細につなぐというのは、はじまりの処が太い、それから次第に細いのまたそれより細いのと段細の糸を拵えるんです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合へ来て見繕いで拵えるような、べらぼうな長生をするもんかい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の袂を、じっと引張って、（あれ、照吉｜姉さんが亡くなるんじゃなくッて）ッて、少し震えながらお三輪が言うと、（引潮時だねちょうど……）と溜息をしたは、油絵の額縁を拵える職人風の鉄拐な人で、中での年寄だった。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（では、ちょっと今のうち鋳掛屋さん、あなたお職柄で鍵を拵えるより前に、手で開けるわけには参りませんの。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、私と云うものは……若奥様には内証だが、その高崎の旦那に、頼まれまして、技師の方が可い、とさえと一言云えば、すぐに合鍵を拵えるように、道中お抱えだったので。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方が手遊びに拵える、五位鷺の船頭は、翼で舵取り、嘴で漕いで、水の中で火を吐くとな………』『天守の上から御覧なされ、太夫ほんの前芸にござります、ヘツヘツヘツ』とチヨンと頭を下げて揉手を為て言ふ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子だと、小さいうちに着物を拵えるのは損だと云う。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイタイ活動写真をこさえる事は、決してナマ易しい事ではありません。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもおれのきくとこに依ると、あいつらは海岸のふくふくした黒土や、美しい緑いろの野原に行って知らん顔をして溝を掘るやら、濠をこさえるやら、それはどうも実にひどいもんだそうだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにキャベジ一つこさえるには、百疋からの青虫を除らなければならないのですぜ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでネネムは一人の検事をつけてフクジロを張子の虎をこさえる工場へ送りました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私は二度と帰らないつもりだから――もしかすると何週間か帰らないつもりだから――またはあることをうまく隠せるようになるまでは帰らないつもりだから――時間をこさえることだけが、私の気をつかわなければならないことだ』というふうにね。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            }
          ]
        }
