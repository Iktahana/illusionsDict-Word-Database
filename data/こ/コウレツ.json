  {
    "uuid": "17144b87-95f5-5e3e-b7a1-62c7fd698ff3",
    "entry": "後列",
    "reading": {
      "primary": "こうれつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
