        "examples": {
          "standard": [
            {
              "text": "赤道付近では、一年中ほぼ同じ方向に恒信風が吹いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "帆船の時代、恒信風は航海にとって非常に重要な要素だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の気候は、恒信風の影響を強く受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また亞細亞からの冬から春にかけて吹く東北の恒信風を利用して、亞細亞の産物を亞弗利加東海岸に齎らす商船が、印度から出發する場合には、亞剌比亞半島の南にある阿曼、亞丁等の諸地方に寄舶する便宜上、必ず此のマラバール即ち摩頼耶國の何處かの海港に寄舶せねばならなかつた。",
              "citation": {
                "source": "金剛智三藏と將軍米准那",
                "author": "榊亮三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
