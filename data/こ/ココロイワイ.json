    "definitions": [
      {
        "index": 1,
        "gloss": "(informal) celebration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
