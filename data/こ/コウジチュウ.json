    "definitions": [
      {
        "index": 1,
        "gloss": "under construction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このあたり複線路の工事中と見えたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時忽ち私の眼に留つたのは此不思議なる洞中造船所の中央に位して、凹凸の岩の形が自然に船臺をなしたる處、其處に今や工事中の、一種異樣の船體が認められたのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――工事中土瓦のもり上つた海邊橋を、小山の如く乘り來る電車は、なだれを急に、胴腹を欄干に、殆ど横倒しに傾いて、橋詰の右に立つた私たちの横面をはね飛ばしさうに、ぐわんと行く時、運轉臺上の人の體も傾く澪の如く黒く曲つた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人々の阿父さんや祖父さんは、六十年｜前にここを過ぎて、工事中のお台場を望んで、「まあ、これが出来れば大丈夫だ」と、心強く感じたに相違ない。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな工場や、工事中のビルヂィングなぞには、地震でがらがらとつぶされて、一どに何百人という人が下じきになり、うめきさけんでいるところへ、たちまち火がまわって来て、一人ものこらず焼け死んだのがいくつもあります。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "充分に注意しますとは言っていたが、なお工事中にも時々忘れないようにこの点を主張しておいた。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の住職服部賢定氏これを嘆いて數年間に渉つて鳳來山の裏山にあたる森林の拂下げを願ひ出て終に許可を得、それより費用を得て目下本堂建築の工事中である。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "都の渾天寺は今や工事中で、役夫が数百人もあつまっている。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "天統の末年に、彼は官命によって、河の堤を築くことになったが、その工事中、幕下のものに昔話をして、彼は涙をながした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦を積んだ荷馬車が、何台も何台も、工事中の仮駅へ向けて行列をつくった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶だ工事中の新築の角を折れて、仮に新築の一部に設けた受附へ行くと、狭い入口が見舞人で一杯になっていた。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "工事中の新築の階下へ行って見ると、材木や煉瓦やセメント樽を片寄せて炭火を焚いてる周囲に店員が集って、見舞物の握飯や海苔巻を頬張ったり鯣を焼いたりしていた。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これはまだ工事中だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、左端のテニスコートから、畑のある段丘、寮、工事中の新寮、校舎の屋上をなめた寮わきの低い山へ、というパーンが十二秒。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行島の大秘密　ここ建設工事中の飛行島の最上甲板であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "工事中の騒音のなかで孫、南両氏がかけている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからはかなり遠く今工事中の道路のあたりが見えるのだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに工事中ろくろく家財や書物の整理もできなくて、裏の家へ積み込んであったので、紛失したものも少なくなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは今基礎工事中です。",
              "citation": {
                "source": "蒼白い月",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは工事中であった寄宿舎が落成したためである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授室の三方の窓には強い日光を受けた松の緑が眩しく波打っておりまして、早くも暑苦しい松蝉の声さえ聞えて来るのでありますが、南側に並んだ窓の一つ一つには、胡粉絵の色をした五月晴れの空が横たわって、その下を吹く明るい風が、目下工事中の解放治療場の作業の音を、次から次に吹込んで参ります。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私は現代にあって、最も困難な絵画芸術に志す若き人たちに対して、この工事中の混乱に向うべき心構えについて、いささか私の考えを不完全ながら述べたつもりである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲仙島原間の自動車道は五年｜前私の来た時は工事中であったのでそれまでは島原へ降るためには、かなり難儀な普賢｜下りをしなければならないのだった。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも総武鉄道の工事中にそこへ通つてゐた線路工夫の一人は宵闇の中に幽霊を見、気絶してしまつたとかいふことだつた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず工事中の鉄橋さへ泥濁りに濁つた大川の上へ長々と橋梁を横たへてゐた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも総武鉄道の工事中にそこへかよっていた線路工夫の一人は、宵闇の中に幽霊を見、気絶してしまったとかいうことだった。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず工事中の鉄橋さえ泥濁りに濁った大川の上へ長々と橋梁を横たえていた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の道は、工事中の活動写真館があったり、空地があったりするが、その先は人家が櫛比して省線の停車場になっている。",
              "citation": {
                "source": "秘められたる挿話",
                "author": "松本泰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
