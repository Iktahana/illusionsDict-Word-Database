    "definitions": [
      {
        "index": 1,
        "gloss": "by (from) choice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（しかし朝はウイスキイを用い、ビフテキも好んで食った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）住居は度々変ったが、純日本風の家を好んで、少しでも洋風を加味したものを嫌った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は立派な文明を持っていながら好んで野蛮人の真似をしたがると、彼は常に不満を述べていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ彼の好んで使ふ「鬼」といふ言葉が、その雅號の上でも文學上でも、また人物の風采上でもふさはしいことを強く感じた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に西洋の子供たち、科學の先進國たる獨逸や佛蘭西の子供たちでさへ、今尚好んで讀んでるものは、グリムやアンデルセンの童話であり、森の妖精や魔法使の話なのだ。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村は関西の人であり、元来が南国人であるけれども、好んでまた南国の明るい風物を歌ったのは、彼自身が気質的にも南国人であったことを実証している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して芭蕉は、好んで奥州や北国の暗い地方を旅行していた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの句で、蕪村は特に「酒肆」とか「詩」とかの言葉を用い、漢詩風に意匠することを好んでいる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした郷愁詩の主題として、蕪村は好んで藪入の句を作った。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水鳥や舟に菜を洗ふ女あり　と共に、蕪村の好んで描く水彩画風の景趣であって、薄氷のはる冬の朝の侘しさがよく現れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は好んで洞窟に棲んでるのではない。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の一生を小さい陥穽に嵌め込んでしまう危険と、何か不明の牽引力の為めに、危険と判り切ったものへ好んで身を挺して行く絶体絶命の気持ちとが、生れて始めての極度の緊張感を彼から抽き出した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "純情な恋の小唄を好んで口誦む青年子女に訊いてみると恋愛なんか可笑しくって出来ないと言う。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が好んで落ちつく長椅子の隅――罠はそこだ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも単に土地や時代の相違のみならず、意識現象には好んで「粋」の語を用い、客観的表現には主として「いき」の語を使うように考えられる場合もある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお竹のほかには杉皮も二元的対立の一方の項を成すものとして「いき」な建築が好んで用いる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に外来語が好んで用いられるかは、最近の新聞記事に「スラムのブルジョア、ルンペン群中のクイーン」と書いてあった一例によってだけでもわかる。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヴリンは音楽を好んでいたので、レーリーはヘルムホルツの書物を貸してやり、それが二人に共通の興味ある話題を提供した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は好んで行つたのではない。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私も昔はずゐぶんハイカラで、西洋の詩など非常に好んで讀みましたが、今ではちつとも面白くない。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代の厭人病者は、むしろ都會の雜鬧中に孤獨で居ることは好んでも、かういふ閑寂の自然の中に孤獨でゐることは好まないだらう。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧水氏はいつも好んで、場末の汚ない繩のれんで酒を飮んだ。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元來私は、私自身の言葉で言語を使用することを好んでゐる。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚一枚に眼を晒し終つて後、さてあまりに尋常な周圍を見廻すときのあの變にそぐはない氣持を、私は以前には好んで味つてゐたものであつた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が人を揶揄することを好んで人から揶揄されることを嫌うのは都会的｜諷刺家の性分で、父親はそれが娘だとぐっと癪に触った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その歌はお前が家にゐる時好んで口ずさむあの歌だつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、突然、中津を好きやこのんで家へ引っぱりこんでいるのではないんだ、と云いだした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達はすきこのんで、あいつ等をやっつける身分かい！",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕だって何も、好きこのんで、あの人たちと気まずくしているわけではないのですが、どうも、いけないのです。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、いつもひとりの部屋といふものは、好きこのんで心がらとはいふものゝ、とりとめもないものであり、傷ついた鳥に宿を与へるのかとおもふと、余程嬉しく、やがて、この鳥が翼も癒えて、独酌家の窓から飛び立つて行つた後のことまでが想像された。",
              "citation": {
                "source": "城ヶ島の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
