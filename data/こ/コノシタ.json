        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あちらこちらに切り倒された大木の下から、真青な羊歯の鋸葉が覗いている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "画はやはり田舎の風景で、ゆるやかな流れの岸に水車小屋があって柳のような木の下に白い頭巾をかぶった女が家鴨に餌でもやっている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車の往来が織るような街の両側の人道の並木の下には手を組んだ男女の群が楽しそうに通っている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉の大木の下に床几を積み上げたるに落葉やゝ積りて鳥の糞の白き下には小笹生い茂りて土すべりがちなるなど雑鬧の中に幽趣なるはこの公園の特徴なるべし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠が上り下りして、森らしくなる、杜鵑がしきりに啼く、湯治の客が、運んだ飜ぼれ種子からであろうが、栂の大木の下に、菜の花が、いじけながらも、黄色に二株ばかり咲いていた、時は七月末、二千｜米突の峠、針葉樹林の蔭で！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄妹は五尺にも足らぬ胡桃の木の下に、二尺角位に乾し草の屋根を葺いて、その下に雫で背中を濡らしながら、木の幹を抱き、向き合つて跼んでゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的百貨店、ウェルトハイムの大飾窓に煌めく満天の星、神木の木の下の女神を取巻く小鳥、獣類、人間の小児、それらを囲る幽邃な背景が、エンジンの回転仕掛けで、めぐる、めぐる。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁がこの木の下にしばし疲れを安めるために憩うたのは、一つは、葉の茂みの軟かさにもあるのだろうが一つは微紅色をした房花に、少女として自分の膝元に育て上げていた時分の福慈の女神の可憐な瞳の面かげを見出していたのではあるまいか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄助は、まるで電車を運転するときのように落ちついて、立って一あし水にはいると、すぐその持ったものを、さいかちの木の下のところへ投げこんだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぺ吉だの三、四人は、もう泳いで、さいかちの木の下まで行って待っていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ぺ吉が、また向うの木の下で云った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくらはみんな、さいかちの木の下に居てそれを見ていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原にあがった子どもらは、着物をかかえて、みんなねむの木の下へ遁げこんだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "困ったな、どこか栗の木の下でまこう。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな楢の木の下に、兄さんの縄で編んだ袋が投げ出され、沢山の草たばがあちこちにころがっていました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の木の下から背戸へ抜け槇屏の裏門を出ると松林である。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝（Ｆ・Ｉ）川端　柳の木の下に悲恋に泣く男女の姿。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時妾はふと、夜陰の無花果の木の下に潜む、黒衣の人間の険悪な顔を姿見に認めて、恐ろしい悲鳴をあげました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、パルチザンは、枕木の下へ油のついた火種を入れておくだけだった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」嘉ッコと嘉ッコの兄さんとは一所に叫びながら垣根の柳の木の下まで出て行きました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日にすかされたのを木の下から見ると何だか蛙の卵のような気がする。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）バキチが横木の下の所で腹這いのまま云いました。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ほんとうに、その雪は、まだあちこちのわずかな窪みや、向うの丘の四本の柏の木の下で、まだらになって残っています。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "溪ぎわの大きな椎の木の下に立って遠い街道の孤独の電燈を眺めた。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "工学士は、井桁に組んだ材木の下なる端へ、窮屈に腰を懸けたが、口元に近々と吸った巻煙草が燃えて、その若々しい横顔と帽子の鍔広な裏とを照らした。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから跣足になつて、抱へられるやうにして下つて、また、老樹の根、大巌の挟間を左に五｜段、白樺の巨木の下に南祖坊の堂があつた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に三｜段、白樺の巨木の下に、一｜龍神の祠があつた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひる近くなって、重大なニュウスが次々と聞えて来るので、たまらなくなって、園子を抱いて外に出て、お隣りの紅葉の木の下に立って、お隣りのラジオに耳をすました。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだんだん森の奥へ入って行きますと、一本の古い柏の木の下に、木の枝であんだ大きな笊が伏せてありました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながら柏の木の下の枯れた草穂をつかんで四つだけ結び合いました。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
