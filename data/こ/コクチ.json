    "definitions": [
      {
        "index": 1,
        "gloss": "notice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ａ新聞社の電気告知の綴文字が事件をたえまなく運搬した。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の朝Ｋ市の中学校の掲示場の前におおぜいの生徒が集まって掲示板に現われた意外な告知を読んで若い小さな好奇心を動揺させていた。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さなきだに葬礼法会ありしと聞けば、魚の腸に寄する鳶のごとく十里を遠しとせざる輩が、しかも丁寧に告知らせしに、召に応ぜざるはそもいかに、貴婦人方は本意なげなり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまにも死にそうなナイチンゲールの歌声を聞いても、それは悪い予言者ではなく、幸運の告知者のように聞えたのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の受胎告知記念日には私が引っ越すことに落ち着き、まったく提案通りの条件で開業することになりました。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした方針を定め、登録案内を用意してボイジャーサロンに告知を流しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを受けて八月、連邦地方裁判所のウィリアム・イングラム判事はＡＭＤに対し、インテルの著作権を告知すること、製品が８０２８７と同等、又は完全な互換性があると表示すること、同社がインテルから特許の使用許可を得ていると謳うことを禁止する命令を下した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟橋氏は、私が先頃報知新聞に九月の創作についての感想をかいた中で、「新胎」のテーマが含んでいる歴史的な方向、氏によって嘗て提唱された能動精神のその後の消長等に対する疑義をこの作品の内部に見たことを念頭において、告知板の文章を書いておられるのである。",
              "citation": {
                "source": "夜叉のなげき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、舟橋氏が告知板にかかれた文章そのものが、短い表現であるがそのものとして、私たちに一つの課題を呈出していると思う。",
              "citation": {
                "source": "夜叉のなげき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "省線各駅、町会の告知板に、徳川時代の、十手をもった捕りかたが手に手にふりかざした御用提燈が赤い色で描かれたポスターがはられた。",
              "citation": {
                "source": "世界の寡婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨は我が諫めを納れ給ひて屋島に歸られしか、然るにても一言の我に御｜告知なき訝しさよ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海上の安全を期するため、船客各位に対する重要告知」とあるから、何を措いてもあわてて読んでみる。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい告知板がところどころに建っていて、第×林区、広田兵治など書いてある。",
              "citation": {
                "source": "山峡新春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっそり砂利を敷きつめた野天に立つ告知板の黒文字　しらおか　寂しい駅前の光景が柔かく私の心を押した。",
              "citation": {
                "source": "一隅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "意識は事實が自己をその主體性に於て告知する唯一の場面である。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に、眞理を指導として主張することによつて、プラグマチズムは自己を單なる方法として告知する。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "この流動の連續、それは諸の状態の一繼起であり、その各はそれに隨ふところのものを告知し、それに先立つところのものを包含する。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "山地の慌しき秋の近よりを地上の人々へ告知するのである。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにこういう連絡訓練を要する偶発事件になると、瞬間の告知で整然たる行動を取り得る制度が完備しているのだ。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつじょ、警察の名で新聞広告を出して、チャアリイ・ロスの発見、ならびに誘拐者の捕縛に資する重要材料の提出者には、告知と同時に二万五千ドルを与えるというので、これはじつに、真正面から誘拐者を相手どった、思いきった挑戦だった。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ドクター・ドブズ・ジャーナル（ＤＤＪ）』の告知でフェアーの開催を知った西は、主催者に申し込んで確保していたブースに『Ｉ／Ｏ』を並べ、日本から仕込んでいったビデオのインターフェイスボードやライトペンを会場で売った★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな中、石田は『ＤＤＪ』の一九七六年十一／十二月合併号で、メンローパークに住所を置いているコミュニティー・コンピューター・センター（ＣＣＣ）を名乗るグループが、プログラムの配布活動を行うと告知しているのを目にした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでＣＣＣは、書き手が紙テープに収めてプログラムを登録してくれれば、注文に応じてきわめて安い値段でコピーして郵送すると『ＤＤＪ』に告知した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　小學校の二階の村役場では、折柄の納税告知書で忙がしいので、助役の野口が腋臭のする腕を高く捲くり上げて、臨時雇の數之介といふ老人を相手に、書くのと算盤をおくのとに忙がしがつてゐた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と野口助役は俄に眞面目な顏になつて、卓子の上へ堆かく積み重ねられた黄色い紙の納税告知書を見やりながら言つた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」と、助役は圓い眼をクリ／＼さして、自分の前に堆い納税告知書を見詰めた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と重吉もおなじく、納税告知書の山を見詰めてゐた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れかの吸ひ殼が、一束の納税告知書の上に落ちて、四五枚の黄色い紙にプス／＼と黒焦の穴をあけたのであると分ると、「あゝこれや／＼。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
