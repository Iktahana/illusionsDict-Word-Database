[
  {
    "uuid": "4c1173ce-2a56-5fcb-9e20-a76038c86cf3",
    "entry": "校風",
    "reading": {
      "primary": "こうふう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
