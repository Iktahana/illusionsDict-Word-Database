    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(telephone) call",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今はこれまでというので、王と将軍のコールビオルンは舷から海におどり入る。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球物理談話会もほんの五、六人の仲間であったが、その中にまだ若いコールシュッター氏も交じっていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの動物は、神経を切られたり、動脈へゴム管を挿されたり、病菌を植付けられたり、耳にコールタールを塗って癌腫の見本を作られたりする。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際蘭人達は日本酒、殊にアルコール分の強い泡盛は飲めなかつたのである。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、資本主義のアルコールで元気をつけて歩き出した。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "錆のとれた後は、一人の水夫が、コールターと、セメントの混ぜ合せたのを塗って歩いた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の腹の中では、百パーセントのアルコールよりも、「ききめ」のある、コレラ菌が暴れ廻っていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラのうちにはアルコールラムプで走る汽車があったんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかアルコールがなくなったとき石油をつかったら、缶がすっかり煤けたよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アルコールか電気だらう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕博物館でアルコールにつけてあるの見た。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコールで消毒はされるかもしれないがあまり気持の好いものではない。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばビーカーをアルコールランプで下から熱すると水蒸気が出てそれがビーカーの外側にあたって冷却され、水粒がビーカーに附着する。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見て児童はどうして出来るかと質問したときに、教師がそれをいいかげんに答えるのはいうまでもなく悪いが、これを知っている場合に、何でもないことだ、アルコールの燃える際に生ずる水蒸気がビーカーにあたって露になって着くのだといって、あまり無造作に片づけてしまうのは面白くないと思う。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の cold は冷肉（コールミート）のコールである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘブライ語の寒さも「コール」である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六三―六四年にマクスウェルその他の委員によって設定された B. A. 単位はその後コールラウシュ、ローランド、ウェーバー等の測定で十二パーセントの開きを生じていたのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これとは関係はないが、次の頁の脚註に、中世の博物学書に記述されたウニコール捕獲法というのが書いてある。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "純潔な処女をこの一角の怪獣の棲家へ送り込むと、ウニコールがすっかり大人しくなって処女の胸に頭をすりつけて来る。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手がウニコールであるとは云いながら甚だ罪の深い仕業であると云わなければならない。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内閣が変って、金解禁とともに現金通貨に需要が減退して、金融市場は、遊資のために市場金利においてコール貸日歩の急落、国債、市債の抬頭等の変化を見せたが、国内における購買力の減少は、街から街に黄濁の切断面をつくった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近にあったアルコールの数滴を机の上に垂らしてその上に玉虫の口をおっつけると、虫は活溌にその嘴を動かしてアルコールを飲み込んだ。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の表情というものがあり得るかどうか知らないが、ただ机の上のアルコールの減じて行く速度がそういう感じを起させたのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコールを飲んだ玉虫はとうとう生き返らなかった。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間だとしたらたぶん一ポンドくらいの純アルコールを飲んだわけである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母ア、コール天の足袋は？",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のコール天の足袋は？",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
