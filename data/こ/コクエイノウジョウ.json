        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ロストフ市から数十哩東にソヴェト一の大国営農場「ギガント」がある。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、来ていた人に、自分がソヴェト同盟の南の地方を見学旅行したとき或る国営農場で見たいろいろのことを話した。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟では、集団農場・国営農場があって、機械化された農業が行われている。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトは、社会主義生産の技術を高めて、やがて、一台のトラクターも外国から買い込まないようにするために、今暫く、国営農場「ギガント」に、アメリカ人技師の指導をうけているのだと。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しいソヴェトがどんないい工場を持ってるか、集団農場、国営農場はどんなにやっているか、都会の工場からの代表が一大隊繰り出すのにもよく出逢う。",
              "citation": {
                "source": "ソヴェト労働者の夏休み",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、その夏、ウクライナの大国営農場「ギガント」を見学に行った。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンバス炭坑区を近くに持ち、大国営農場、機械工場をもち五ヵ年計画とともにソヴェト同盟の南方地域では屈指の重工業、農業の生産中心地となった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロストフはウクライナ共和国の主都で、附近にはソヴェト第一の大国営農場「ギガント」があった。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏、クリミヤ及びドン地方の大国営農場「ギガント」へ見学旅行した。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ソフホーズ〔国営農場〕をテーマとする、全線の一部の撮映を見る、素人、今度始めて田舎から来たという、稽古をつけて居るが、なかなか根気しごと。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十五日　火　二人で ВОКС へ出かけ、ギガント〔ロストフの国営農場〕へ紹介状を書いて貰った。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月三十日　水　目っかちで совхоз〔国営農場〕とサナトリー〔サナトリウム〕を見物に出かけた。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが、わたしたちへの五ヵ年計画だったっていうわけね」　大国営農場ギガントの広大な美しい写真を眺めたり、富農からの没収品目を新聞でよんで、五ヵ年計画の奮闘に触れているように感じていた自分たち――少くとも自分というものを、伸子は段々自分の責任において批評し、滑稽を感じて笑えるようになって来た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どこでも今人が足りなくて騒いでるじゃないの、集団農場や国営農場へとられちゃって。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園の樹の梢へつるす鳥の巣箱を小学校の子供は手工でこしらえる仕度をし、中央児童図書館では、一つの本棚が五ヵ年計画、集団農場、国営農場、その他一般農作と春の動植物についての本でおきかえられた。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
