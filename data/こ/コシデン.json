        "gloss": "Commentary on Ancient History (by Hirata Atsutane, 1825)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
