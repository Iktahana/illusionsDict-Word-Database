          "literary": [
            {
              "text": "翌六日昼九つ時（正午）人数引揚申候。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "いましがた訴えた者があったんだそうで、なんでもそれが夜の九つ時分に決まって出るんだそうだがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "九つ時分御立なされ、御いとまごひ申候へども、とかく御名ごりをしく、尾道と申まで、西南六里、御あとより追かけ候｜而、また一夜御はなし申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「石之間より上り、御医師部屋へ通り、九つ時宗達と交代して、己旅宿夷川通堀川東へ入る町玉屋伊兵衛持家へ著く。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼九つ時頃讚州｜多度津湊へ著船。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "定番、大番、加番の集まつた所で、土井は正九つ時に城内を巡見するから、それまでに各持口を固めるやうにと言ひ付けた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "九つ時になると、両｜大番頭が先導になつて、土井は定番、加番の諸大名を連れて、城内を巡見した。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "相会する面々は、女隊ニては西川の二女及胡弓妓外一人、是又有名の一妓、其外下関の老婆、今日相会し次第但四時迄の心積なれども、九つ時ニも相成んか。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年九月初旬　佐々木高行あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "水野主馬はもと結城藩老、天狗の携ふる所となれる者、土浦より結城を志し、行々土兵に苦しめられつゝ、十日夜九つ時、猿島郡新和田にて捕へらる。",
              "citation": {
                "source": "天狗塚",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
