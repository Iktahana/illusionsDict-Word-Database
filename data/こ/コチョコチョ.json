          "literary": [
            {
              "text": "タキは、わらわさ、なにやらし、こちょこちょと言うつけたずおん。",
              "citation": {
                "source": "雀こ",
                "author": "井伏鱒二へ。津軽の言葉で。",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけて、得意の術というのは、尻尾の房毛の先で、相手の脇の下をこちょこちょとやる。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "乱視の奈翁　――アルル牛角力の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちょこちょと、台所へ、出ねえように」　きのうすでに、仕上げをすました十組の小柄を、卯黄木綿の端から巻いて、それを、腰帯のうえから、しっかりと背なかへ。",
              "citation": {
                "source": "野槌の百",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ復讐を始めるにしても、こちょこちょと小出しにこっそりやるので、自分の復讐の権利もその成功も、まるで信じてはいないのだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
