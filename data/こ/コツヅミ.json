    "definitions": [
      {
        "index": 1,
        "gloss": "small hand drum",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "園は従兄弟に、幸流の小鼓打がある。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田畑を隔てた、桂川の瀬の音も、小鼓に聞えて、一方、なだらかな山懐に、桜の咲いた里景色。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐にして、もとの野道へ出ると、小鼓は響いて花菜は眩い。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃孫に代を譲って、雪叟とて隠居した、小鼓取って、本朝無双の名人である。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御老体、」　雪叟が小鼓を緊めたのを見て……こう言って、恩地源三郎が儼然として顧みて、「破格のお附合い、恐多いな。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "店のすぐ鼻の先が先斗町であるからだろうか、それともこの店が小鼓の家元の美貌の三人兄弟が男手だけで経営しているからだろうか。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "久能の出入り先で今大路という堂上方の家に綾姫という小鼓に堪能な美人がいた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれとてもほんの一時のなぐさみであったらしく、間もなく同じ堂上方で、これも小鼓の上手ときこえた鶴原卿というのへ嫁づくこととなった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを東京の九段におられる能小鼓の名人で高林弥九郎という人が見かねて東京に呼び寄せ、牛込の筑土八幡の近くに小さな家を借りて住まわせて下すったので父はやっと息を吐いたという事である。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "前なるお美津は、小鼓に八雲琴、六人ずつが両側に、ハオ、イヤ、と拍子を取って、金蒔絵に銀鋲打った欄干づき、輻も漆の車屋台に、前囃子とて楽を奏する、その十二人と同じ風俗。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白の狩衣、紅梅小袖、灯の影にちらちらと、囃子の舞妓、芸妓など、霧に揺据って、小鼓、八雲琴の調を休むと、後囃子なる素袍の稚児が、浅葱桜を織交ぜて、すり鉦、太鼓の音も憩う。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金があるうち、どっかのんびりした田舎を遊んで帰りましょうよ」　山を野へ下り立つ人は山を振り返るに、惜しき訣れとらく／＼した気持とで、こころ小鼓の調べの緒の綾にうち返すといいます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "只だ見る粗造の木車一輛、之を挽くものは五十に余れる老爺、之に乗るものは、十歳ばかりも他に増さるべし、乗るものは小鼓を打つて題目を誦し、挽くものは家に就いて喜捨を仰ぐ。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちのくの牧の若人露ふみてもとほり心角吹けば、吹き、また吹けば、渓川の石津瀬はしる水音もあはれ、いのちの小鼓の鳴の遠音とひびき寄す。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時翁は藤堂伯（先代）から召されて「蝉丸」の道行の一調謡の御所望を受けたが、相手の小鼓は名にし負う故大倉利三郎氏で、予々翁の技倆を御存じの藤堂伯も非常な興味をもって傾聴された。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその後、各人の天分、好き嫌い等の色々な事情で次第次第に分業になって来ると同時に、その楽器の種類も太鼓、大鼓、小鼓、笛の四ツになってしまったらしい。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、前述の太鼓、大鼓、小鼓の三種は能楽演出のリズムを、打音の間拍子で囃すのであるが、そのリズムに対するタッチは全然能楽一流の行き方である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鼓も小鼓も、太鼓も四ツか三ツかの僅少な音の変化によって八、六、四、二の拍子を扱って行くに過ぎぬ。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄大いに喜び、斥候を放って、妻女山の陣営を窺わせると、小鼓を打って謡曲『八島』を謡っている。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十六日以来、謙信は只々山上を逍遙して古詩を咏じ琵琶を弾じ自ら小鼓をうって近習に謡わせるなど余裕｜綽々であった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事がすむと牀几に腰をかけて小鼓を取り寄せ、東向きになって謡曲『敦盛』をうたい出した。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒盃｜数献の後、幸村小鼓を取出し、自らこれを打って、一子大助に曲舞数番舞わせて興を尽した。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の方では、とん、とん、とん、と云う小鼓の音がしていた。",
              "citation": {
                "source": "鼓の音",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に小鼓を把りて、我等を要して卜筮せんとしつれど、馭者は馬に策ちて進み行きぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "息が切れて、もう小鼓を肩に振懸ける力もない。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と、いいつつ片手を肩に懸けて、小鼓を構える姿で屹と直った。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶だの、活花だの、それより、小鼓を打ってね、この方が流行ったそうです。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五年前に、神田の私の内へ訪ねて来た時、小鼓まで持参して、（八郎さん一調を。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりに小鼓と名づけるか。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "享保三年板｜西沢一風作『乱脛三本鑓』六に、小鼓打ち水島小八郎、恩人に頼まれた留守中その妻を犯さんとして遂げず、丹波の猪野日村に旧知鷹安鷲太郎を尋ねる。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
