    "definitions": [
      {
        "index": 1,
        "gloss": "sound of something small rolling once (often into a hole)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わけはない、ころっと死にさえすればいいんだよ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころっと死んだのだ。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の婿めが、あんた、マニラでころっと逝きよりましてな」「マニラ……？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子のお父つぁんも、わいが無理矢理｜横車振ってマニライ行かしたばっかりに、ころっと逝ってしまいよりました。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし、現像の方かてころっと忘れてしもたという訳じゃないですよ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "持子のお腹のこと考えてみイな」　口酸っぱく言われて、それでは謝ってみましょうと、おたかの腹がやっときまりかけた時に、幸か不幸か、持子の相手の男が盲腸をわずらって、ころっと死んでしまった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝転んで東西古今の小説を読み散らし、ころっと忘れてしまった人の方が、新しい文章が書けるのではあるまいか。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「娘の婿めがマニラでころっと逝きよりましてな。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の船乗りにでも渡して、おおかたそいつがころっと何日も忘れとったんだろう。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生懸命に靴下を摘んで、ながいことかかって或る程度まで脚を空に上げる事業に成功するんだが、そのうちにぽつんと切るように手が離れると、身体ぜんたいがころっと反り返って驚いて両腕をひろげる。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "“The rainy day”　白い小さい縫のセットの上に二三十ころっとしたサクランボーはほんとうにうれしかった。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後の幕で、肺病が重くなり、恋人の詩人ルドルオの許に帰って、恋人に看護されながら死ぬところで、まるで小鳥が死ぬように、可憐に枕からころっと落ちるうまさは、なんともいえない芸の味があり、思わず泣けてしまいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とうとう居ないのかもしれない」　こんな事を思いながら御土産のつづらをあけるようにそっとようじのさきでひらいて見ると思いがけなく茶色の小虫はころっとなって入って居た。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面には葉の隙間を洩れて来る夏の日光がキラキラときららかな色に跳ね廻り落ちた実が土の子の様に丸まっちくころっとしてあっちこっちにある上を風の吹く毎にすがすがしい植物性の薫りが渡って行った。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して三時は過ぎてしまった、三十分ばかりたつと、ころころっと可愛いらしい物音がして、何がやって来るのかと思ったら、おもちゃ箱みたいな汽車だった、しかもおもちゃにしては薄きたない。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなのにかぎって、ころっと死るものだ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "影人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この伝次は関脇で、二人で宇都宮まで相撲にいったこともありますが、旦那にはころっといかれたそうで、やっぱりお武家さんにはかなわねえと云いあって来たです」　重い口でそんなことを云った。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの重要な手紙は実質上紛失し回収は見込めないので、エイビスとバンストンは大胆に空売りし続け、ルペラ男爵が死んだと報じられたとき、地中海石油はころっと倒れるはずだった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
