        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東野は十九世紀初頭のフランスの文豪たちの、ずらりと並んだ彫像を眺めていても、別に何んの感動も顕さず、誰より先に公園の出口から出ていって、左側にある公衆便所に這入ってしまった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後のみではなく戦前においても銀座のスキヤ橋横の公衆便所など、東京の中心にありながら、常に悪臭を放つための存在でしかなかった。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "カッポ酒がいかに観光客にうけているかということは、この国見の丘という神話の地に大そう近代的な公衆便所ができていることで察せられたのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その公衆便所は高千穂町全体のうちでどの建物よりも近代建築といってよいぐらい。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第一回　高千穂に冬雨ふれり≪宮崎県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "青少年は公衆便所以外のどこで性教育を受けることができますか？",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "などなど……これみな公衆便所学校の卒業生が構成している社会だからです。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "性の問題を公衆便所から奪回することが急ぐべき仕事です。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな祝福された性を公衆便所のごときところに放置しておいて相すみますか？",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最近になり公衆便所が作られ、毎朝に彼らが水を汲んでいる地点の上で内容を川で洗っていた。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の歩いてきた方角には、公衆便所のある小公園があるのだ。",
              "citation": {
                "source": "待っている女",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
