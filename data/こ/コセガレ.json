        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、〆さん、笹原の小倅みてみイ、やっぱり金持の家でえいように育った子オはあかんな。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し返してねだるように願うと、忠利が立腹して、「小倅、勝手にうせおれ」と叫んだ。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝には頼家という小倅があるとやら……これも、助けては置かれぬ奴、勿論呪い殺しまする。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やいっ、仙波っ、小倅」　小藤次は、刀へ手をかけて怒鳴った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙波の小倅め、しおしおと引かれて行きあがって、いい気味だ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "無礼討ちになった、という噂もあるし――何れにせよ、牧の小倅の手にかかったことは、真実じゃ」　深雪は、俯向いていたが、泣いていなかった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この小倅は異相をしている。",
              "citation": {
                "source": "金将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよいよこの小倅は唯者ではない。",
              "citation": {
                "source": "金将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この小倅に何が出来るもんか？",
              "citation": {
                "source": "金将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな素晴らしい上玉を、あんな小倅に横取られた日にゃア、俺らの商売は成り立たない！",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう悪い小倅には、それだけの仕置をしなけりゃアならねえ。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は無我夢中で爪を噛んで、小倅めにだまされたか、口惜しや口惜しやと歯がみをしてゐたといふ。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は不利の境地に立つと夢中で爪を噛む癖があつたさうで、小倅めといふのは金吾中納言秀秋のことだ。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小倅は元来秀吉の甥で、秀吉の養子となつて育つたのだが、黒田如水らのとりもちで小早川隆景の養子となつた。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬儀の日に至つて小倅の霊前に日本中の大名共の髻が山を築くに至つたといふ。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレが鬼のウチから出たころ二十ぐらいの生意気な小倅だったが、まだ身持ちがわるくはなかった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚悟とはどうしようというのじゃ、小倅の分際で」「町奉行へ訴えて出まする」「町奉行へ何を訴える、誰を町奉行へ訴えるのじゃ」「あなた様のお屋敷へ火をつけた穢多非人の在所を、訴えて出ようと思いまする」「ナニ、穢多がどうした」　神尾主膳は歯をギリギリと噛んで、兵馬の面を睨めました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ迄は、父親のない、貧しい浪人者の小倅として、どこへ行っても、肩身が狭かったが、もうこれからはそんなことはないのだ）　こんなことを思った。",
              "citation": {
                "source": "鸚鵡蔵代首伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのタクラミは七重にも八重にもいりくんでいて、尋常ではあの小倅に太刀打ちできる者はこの小田原には一人も居なかろうと言ってましたよ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "難民の小倅どもがまだ諦めきれずに金帛の類を求めているのでございましょう。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "難民の小倅どもがまだ諦めきれずに金帛の類を求めてゐるのでございませう。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、乞食のお侍さん」　与の公は、泣きださんばかり、「あきれた小倅だ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わーん、ちゃんが、ちゃんが、親分」　小倅はもう他愛もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはチョークの片ら、これは門番の小倅へ返してやって下さい。",
              "citation": {
                "source": "判官三郎の正体",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は兵馬を小倅と侮っているが、なかなかそうでないぞ、あれほどに腕の立つ奴は、新撰組にも幾人とない」「…………」「始終、君をつけ覘っている、兵馬一人ある以上は、君の身は危ない」「今、どこにいる」「つい、この近いところにいる」　広間の方で哄と喊声が起る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともまた、あの公爵の小倅が今ここへ出てきて、もう一ぺんこの俺を侮辱して見ろ。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年たちは二十五六が大将株で、十七八の小倅まで、背広にクワエ煙草というアンチャンの方式通りの姿であった。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
