[
  {
    "uuid": "689a085d-9c82-5194-8fa3-5fe3f195fa56",
    "entry": "肥える",
    "reading": {
      "primary": "こえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to grow fat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「この牝はずか／＼肥えるじゃないかいや。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてそろ／＼膨れが目に付くやうになつた時は、かうして俺も肥えるのかと思つた。",
              "citation": {
                "source": "第十八號室より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "天高く馬肥えるってえいうくれえのものじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もそッと目の肥えるよう八ツ目鰻なとうんとたべい」「申したなッ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥えるひまなんぞありやしません。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすれば土地は自然に肥えるでせう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "修道院に若くて美くしい尼御前の大勢になるのもこの時でお寺の墓掘りの懐の肥えるのもその時でござりますじゃ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿の人が語る『酒は肥える、焼酎は痩せる』彼も亦アル中患者だ、アルコールで自分をカモフラージしなくては生きてゆけない不幸な人間だ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして富家と米商とが其資本を運転して、買占其他の策を施し、貧民の膏血を涸らして自ら肥えるのを見てゐる。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分で後悔しなきゃ、何やってもいいけれど、取るにたらないような感傷に溺れて、取りかえしのつかない事になるのは厭ね、ベニちゃんは、とても生一本で面白い人だけれど、案外貴女の生一本は内べんけいじゃなかったの、色んな事に目が肥えるまでは用心はした方がいいと思ってよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の御飯は贅沢に食べる、午の御飯は肥えるやうに食べる、夜の御飯は楽みに食べる、それは全く他人のこと。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……敵の兵糧で味方が肥える。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その食感を想えば、我が肉虜ひとりでに肥えるを覚えるのである。",
              "citation": {
                "source": "香魚の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、初めはいろいろ外国のものなどに魅惑されるのであるが、やがて眼が肥えるに従い、次第に日本のものがよいということが分って来る。",
              "citation": {
                "source": "味覚の美と芸術の美",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも元来自分が幸いに至極健康であるが故に今日のところ身体は別に肥える事はないけれど仕合せにはまた敢て弱りもしません。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "放し飼いにした伊那駒が、秋天高く馬肥える、今日この頃の野のように、長い鬣を顫るわせて、さも勇ましく駆けている。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歓喜中野鈴子思っただけでも胸がおどる裸一貫のわたしらが堂々と乗りこんでゆきおおこのわたしらわたしらのタコだらけの手真黒に焼けたおでこただ一つの心臓二本の足二本の腕にあらゆる権力と最上の美しさを打ちたてる日働いて笑える働いて肥えるおおその日、その世界よ思っただけでも胸がおどる",
              "citation": {
                "source": "歓喜",
                "author": "中野鈴子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうして、どうして」――フィリップが口を出す――「人の乳を飲んで、肥えるの肥えないの、水々しくはなる、色は白くなる、ひどく思召しにかなったわけですよ」「ところが、こう言っても信用はなさるまいが……」――お神さんは言う――「わたしは、頼まれればいやな顔もせずに、土地の女の乳を吸ってやったでしょう。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　結局、三好が僕の血を啜ると三好は肥える。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好が肥えるのは僕の肥えるのだ。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、僅々数日の間に、すべての名所古蹟といったようなものを見尽してしまうと、彼の天性の迅足の髀肉が、徒らに肥えるよりほかはせん術がなき姿です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして容易に安定の見えない風雲裡の歳月は、決して人に腿の肉の肥えるほどな暇は与えなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地方に行わるる茶揉み唄に、志摩のあねらは何｜食て肥える蕎麦のねりげに塩辛添へてうまい／＼といふて肥えると歌ったのは、もとより貧しい人々の自嘲の笑い歌であったろうが、かつてはまたそんな食物をもって米の消費を節約する必要もあったことを意味する。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐売りのラッパが聞こえる、今夜は豆腐が要るのだからラッパが近づくのを待つて呼びとめる――それならば文句はない。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の動物園の森で一度に鳴き出す色々の鳥類のけたたましい声が聞こえる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵のうちには鈴を振るような音がよく聞こえたが、しかしどうかするとその音がまるで反対の方向から聞こえるように思われた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつにそのかすかな音が丘の上の一｜本いちょうの木に聞こえるくらいすみきった明け方です。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "売店で煙草を買っていると、隣の喫茶室で電話をかけている女の声が聞こえる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の物いう声が遠方に聞こえる代りに自分の声が妙に耳に籠って響くので、何となく心細くなってしまった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、これから学位を取ろうとしている少数の若い学者と、それらの人々の学位論文を審査すべき位置にある少数の先輩学者との耳には一つの警鐘の音のように聞こえる言葉である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
