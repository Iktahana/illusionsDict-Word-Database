[
  {
    "uuid": "6f4f4d26-4596-50de-aa91-4db937d7ab68",
    "entry": "個別",
    "reading": {
      "primary": "こべつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
