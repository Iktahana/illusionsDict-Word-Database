        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……時たま彼の眼は、さっと血ばしって、満面に朱をそそぎ、今にもみんなに躍りかかって、わたしたちを木っ端みじんに八方へ投げ飛ばしそうな剣幕を見せたが、令嬢がちらりと彼を見て、指を立てておどかすと、彼はまたこそこそ隅っこへ引き下がるのだった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型やミニコンピューターのソフトエンジニアからアスキーへと転じたばかりだった間宮義文にとって、リサに盛り込まれたインターフェイスは、頭の中にでき上がっていたコンピューターのイメージを木っ端みじんに打ち砕く新鮮な衝撃だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "伐り倒すばかりか、薪なら薪、木っ端なら木っ端と、お望み通りにこなして御覧に入れます。",
              "citation": {
                "source": "古木",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一万二千石は三月経たないうちに木っ端微塵さ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の家がそれを見たら木っ端微塵になるようなものを目の当たりにしてきた家たちだ。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、あなたは工場に照準を合わせて、木っ端みじんに吹き飛ばす。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "木っ端、板切れ、枯枝、米俵や蓆などまで拾って来た。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の身体は木っ端微塵ですぞ！",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚らわしい、こんな木っ端役人にかかって、こんな浅ましい目に遭って」「黙れ、五月蠅い！",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この病気に罹っている人たちが「タランタティ」であるがもっと一般的に「折られた、へし折られた、木っ端みじんにされた、壊された、打ち壊された(18)」人たちと呼ばれた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろおまえさん、胆石病とくると木っ端へ火がついたようなもんさ、眉毛と眉毛の間に茶色の皺ができる、それが胆石病の始まりさね、うっちゃっとくとそれが黒味をもってくる、そうなったら療治はむずかしい、ぶち毀した長屋の古材木みたようなもんさ」　伊兵衛は例の如く感心し、巧みにおどろいたり感じ入ったりした。",
              "citation": {
                "source": "雪の上の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみはもっと自分の立場をよくみなければいけないな」と先生は云った、「いま公会堂へ集まっているやつらは小物だ、右翼団体などと僭称しておるが、人物らしい人間は一匹もおらん、みんな木っ端のようなやつばかりなんだ」「しかしですね、大義公平先生とか国粋純一先生とか」　先生は頭を振り手を振った。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーファーは木っ端みじんだった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、もしこの瞬間爆発したら、我々は木っ端みじんになるのみならず、過失島も吹っ飛ぶ。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "このボタンをちょいと押すだけで木っ端みじんだぞ。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆弾が落ちてグラントの足元で爆発し、計画が木っ端微塵だ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "木鹿軍が来れば、蜀軍などは木っ端微塵です」　彼の姉｜祝融夫人も、その良人｜孟獲も、今はそれだけを一縷の希望につないでいたところである。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「口ほどもない木っ端ども」　と、張※は眼尻で嘲りつつ、また先へ急いだ。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやしくも、正真正銘の大名が乗る金鋲駕籠だったら、どんな小禄のこっぱ大名だっても、お家の紋がねえはずあねえよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなこっぱ事件、おれが手にかけるがほどのものはねえと思っていたんだが、質屋のおやじのせりふが気に食わねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦隊をおどかしたら、大砲やロケット弾でうたれて、こっちはこっぱみじんだぞ」　サムはおそれをなしている。",
              "citation": {
                "source": "恐龍艇の冒険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "という風な英雄像に彫り上げられた一塊の石にしかすぎぬものが、余り市民の崇敬を受けてその栄耀に傲慢となり、もとは一つ石の塊であった台座の石ころたちと抗争しつつ、遂に自身の地位に幻滅してこっぱみじんに砕けてゆく物語は、平静に、諷刺満々と語られている。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵐もよいの湫々とした潮風が強く吹いていて、あんなにあこがれて来た私の港の夢はこっぱみじんに叩きこわされてしまった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母だけが、躯をすりへらしてこっぱみじんの働きぶりなり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタン屋根にそうぞうしくあたる雨脚に、頭はこっぱみじんに破れそうなり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっぱずかしいみてえにあそこあ、さっぱりしてる。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれにひかれて岩角にたたきつけられたら、富士男のからだはこっぱみじんになる。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ号は、このうえ何を考えだすか、知れないのだから、なんとかして、あいつをこっぱみじんに粉砕してしまわないと、どうしても安心はできないよ」　その声は、たしかに谷博士である。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械人間の手に持っていた爆薬は、大音響を立てて爆発し、機械人間の一隊は、こっぱみじんに吹きとばされたのである。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがわしはおまえの生みの親として、おまえを殺す、ただ一つの方法を知っている――」「それは――」「原子爆弾で、この研究所の建物といっしょに、おまえのからだをこっぱみじんに吹っとばす。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
