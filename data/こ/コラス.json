      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to concentrate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしさうするために、もはや工夫を凝らす余地もないなら……心よ、謙抑にして神恵を待てよ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜の砂庭に吹き散り、陸橋の下には傷つきし犬瞳を凝らす。",
              "citation": {
                "source": "庭園の雨",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎　多寡が面一つの細工、いかに丹精を凝らすとも、百日とは費すまい。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "史実なぞによって扮装を凝らす芝居なぞよりも遥かに舞台効果が大きいのである。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うと、格別大した意味のないところで技巧を凝らすなぞいう例がザラに在る。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは「息を凝らす」とか「詰める」とかいう言葉の代りに用いられるので、それよりももっと緊張した感じを見せる表現として認められているようであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのおの青くなって、息を凝らすうちに――「かの白き手、舳をはなし、水中に消入りぬ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ電子出版を業とする人たちは、動画を駆使して意匠を凝らす圧力を強く受け続けるはずです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこいつをうまく使いこなせるようにと、各社はそれぞれ工夫を凝らす。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の普通一般の人、却って才能・学識の低くても問うことなく、眼を聖経・賢伝から閉じて、思いを妄計憶測に凝らすのは、狂愚と云わないで何と云おう。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "到る處の子供、見付けては、近寄り來りて目を凝らす。",
              "citation": {
                "source": "風船玉",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を凝らする子供は幾十百人といふことを知らざるが、おくれよと云ひたるは、唯※この子のみ也。",
              "citation": {
                "source": "風船玉",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "其外にも如何なる貴女紳士の春の粧いを凝らすの料ともなるべき粧飾品や化粧品が焦げたり泥塗れになったり破れたりしてそこらこゝらに狼籍散乱して、恰も平家の栄華の末路を偲ばせるような心地がした。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "肚を据ゑて想ひを凝らすといふやうなことを呟いで能ふ限り悠悠たる妙境に耽らうとしてゐる岡の眼ざしは、なるほどひところのやうな炎えるが如き鋭さを消して、微妙な和やかさに沾んでゐた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も今度の不覚を恥じて、定めて懸命の秘法を凝らすに相違あるまいと考えられるから、枉げてもう一度、彼の願意を聴きとどけてやりたい。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼りない無能の夫の為に健気な祈念を凝らす――彼女はそんな想ひを拵へて、思はず自分自身に恍惚とした。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し分別を凝らす迄には至らなかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」男の児は両方の白眼を凝らすように気をいれて何か考えている風だったが、やがて、オリーヴ色のスウェタアから出ている小さな頭をふって、ちがうよ、と云った。",
              "citation": {
                "source": "くちなし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、お裁縫なんかするんだけど――一日根からして働いて来て、また肩を凝らす程やって見たって、ね……若し、あなたさえいやでなかったら本当に来ない？",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「禪は無論神經の刺戟を離れて、純粹の觀念を凝らすものだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやうな処へ趣向を凝らすのは月樵の月樵たる所で、とても他人の思ひ及ぶ所ではない。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくの如き者ならば料理屋に依頼せずして亭主自ら意匠を凝らすを可とす。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は死亡室の小さな建物に、とうの昔に死んでいる何十人何百人の人間を住まわせ、その地下室から庭の片隅に面して明いている小窓に、じっと眼を凝らすのだった。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまなパターンを使って、図形の表示に工夫を凝らすことも可能になった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいまも想をこらすわれのうへ、またえれなのうへ、愛は祈祷となり、賭博は風にながれて、さかづきはみ空に高く鳴りもわたれり。",
              "citation": {
                "source": "純銀の賽",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人の品位を保つ上にも貯金は不可缺のものであるのに、更にこのたびの大戰の完勝のために喫緊のものであるのだから、しやれや冗談でなく、この際さらに一段と眞劍に貯蓄の工夫をこらすべきである。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お國のためにも、なんとかして工夫をこらすべき時である。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯る深山に入りてみやびたるわざに心をこらす少女の心のうちを思うにいとなつかしく今｜迄は只いとわしき者にのみ思いし外国人の中にかかるやさしきもありけるよと心にくき事限りなし。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たべものにしても同じ事で、この地方の産物を、出来るだけおいしくたべる事に、独自の工夫をこらす。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して人間の娯楽にはすこしく風流の趣向、または高尚の工夫なくんば、かの下等動物などの、もの食いて喉を鳴らすの図とさも似たる浅ましき風情と相成果申すべく、すなわち各人その好む所に従い、或いは詩歌管絃、或いは囲碁挿花、謡曲舞踏などさまざまの趣向をこらすは、これ万物の霊長たる所以と愚案じ申次第に御座候。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
