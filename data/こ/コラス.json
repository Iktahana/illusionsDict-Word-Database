[
  {
    "uuid": "ae19120f-aba8-5096-b9d6-27fa00112b85",
    "entry": "凝らす",
    "reading": {
      "primary": "こらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
