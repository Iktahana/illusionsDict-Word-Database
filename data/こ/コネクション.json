        "examples": {
          "standard": [
            {
              "text": "彼はこの業界に強いコネクションを持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ネットワークのコネクションが不安定で、通信が途切れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいプロジェクトでは、様々な部署とのコネクションを築くことが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ＷＣＣＦのレポートがきっかけとなって編集部にコネクションを持った古川は、『ＡＳＣＩＩ』に連続して原稿を寄せるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "手配師として振る舞えるほどのコネクションはなかったが、一つだけ手がかりを思いついた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親の実家が須磨にあって、そこのコネクションで僕はきっと大工になる。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなコネクションがあり得るのか、いまはなんにも思い浮かばないですね。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
