          "standard": [
            {
              "text": "彼は上司の前ではコメツキバッタのようにペコペコしているが、部下には威圧的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
