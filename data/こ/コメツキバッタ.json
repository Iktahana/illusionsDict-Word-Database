        "examples": {
          "standard": [
            {
              "text": "仰向けに置くとパチンと音を立てて跳ね上がるコメツキバッタは、子供たちの人気者だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コメツキバッタの幼虫は、農作物の根を食べる害虫として農家に嫌われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャンプ場でテントの裏側に隠れていたコメツキバッタを見つけて、少し驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
