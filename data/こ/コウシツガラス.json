        "examples": {
          "standard": [
            {
              "text": "この試験管は、急激な温度変化に耐えられるよう硬質ガラスで作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スマートフォンの画面には、傷がつきにくい高強度の硬質ガラスが採用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "硬質ガラス製のボウルは、電子レンジでも安心して使えるので重宝している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "生きかえられたんでは、また大さわぎになる」　博士は、大きな硬質ガラス製のビーカーの中に、そのぐにゃりとしたうす桃色のものを入れた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁が建築の支柱的機能をもち、窓がそれに対して展望、採光、通風の機能をもっていたことは今やすでに硬質ガラスの出現によってその函数表をあらためることを要求されはじめる。",
              "citation": {
                "source": "壁",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "硬質ガラスは窓であると同時に支柱としての壁をも意味することとなる。",
              "citation": {
                "source": "壁",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
