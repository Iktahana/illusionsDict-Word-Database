  {
    "uuid": "d3a49dd1-e61a-56bb-b3f0-60e99310917b",
    "entry": "蝗虫",
    "reading": {
      "primary": "こうちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rice grasshopper (of genus Oxya)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雲霞のような蝗虫の発生があった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時の間にか彼女の心は、蝗虫を捕って遊んだり草を藉いて寝そべったりした楽しい田圃側の方へ行って了った。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが身はちやうど蝗虫のやうだ、こゝよ、かしこよと跳回る、唸つて歩く、また或時は色入の翅を拡げて、小さな頸の透きとほつて、空な処をみせもする。",
              "citation": {
                "source": "浮浪学生の話",
                "author": "RECIT DU GOLIARD",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝へ聞く聖約翰は荒野の蝗虫を食にされたとか、それなら余程食べずばなるまい。",
              "citation": {
                "source": "浮浪学生の話",
                "author": "RECIT DU GOLIARD",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は星の蝗虫になる。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
