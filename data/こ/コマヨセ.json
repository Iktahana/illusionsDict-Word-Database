    "definitions": [
      {
        "index": 1,
        "gloss": "small fence to keep out people and horses",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "土蔵の裾を囲む駒寄せの中に、柳の大木が生えている。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前の溝が空溝であることを知っている彼は、狗のように腹這いながらそっとその溝へもぐり込んで、駒寄せの石のかげに顔をかくして、二人の立談に耳を引き立てていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵の裾を囲む駒寄せの中に、柳の大木が生えてゐる。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "格子の内側にはいま黒｜繻子のカーテンが垂れて塞がれ、格子の前の土には縁起を祝って植えたらしい松竹梅の中の竹だけはどうも根附かないらしく、諦めた枯竿だけが他の二木に配されて駒寄せの中に黄ろく立っております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の館もやはり堀川のうちにあって、むかしは然るべき殿上人の住居であったのを無体に横領して、車寄せを駒寄せに作り変えたのであった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面はたかき石段にて、上には左右に石の駒寄せ、石灯籠などあり。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家では、まるで交通｜遮断とでもいうように表門には駒寄せまでつくって堅く閉じ、通用門をさえ締切ってしまった。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔駒寄せのあった向側に机を並べて、来会者に記名させる人々が待っています。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな姿で門前までも平気で出て、駒寄せの間なども丹念に掃除せられます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本舞台正面三枚橋上下駒寄せ、黒塗りに白く広小路と記せし用水桶、日覆より雲のかゝりし月をおろし、総て上野三枚橋夜更の体、時の鐘、水の音、犬の声にて道具留る」とあるト書が簡単ながらよく明治の初年のそのあたりの色彩と気もちとを感じさせる。",
              "citation": {
                "source": "上野界隈",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう駒寄せへ出てその姿は郎従たちの上に高くそびえ、すぐその手綱を館門の外から右へむけていた。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒寄せ桜の下に丸腰の男が低く腰を折っていた。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "大坂町の雷師匠は、冬でも表を明っぱなし、こまよせから、わざと見えるようにしてある。",
              "citation": {
                "source": "大門通り界隈一束",
                "author": "続旧聞日本橋・その一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
