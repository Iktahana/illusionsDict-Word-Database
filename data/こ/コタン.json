  {
    "uuid": "c02723d8-a76c-5aa0-ad2a-9c92ff7b9978",
    "entry": "古潭",
    "reading": {
      "primary": "こたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "old abyss",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神居山脈を貫く処に神居古潭あり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "神居古潭は北海道の勝地として世に知られたるが、深さの非凡なる外には格別の風致もなし。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "石狩川も神居古潭あたりは濁れり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈て着いた停車場は神威古潭駅と云ふ、音に高き奇勝は之かと思つて窓を明けた。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "車輪を洗ふ許りに涵々と波の寄せてゐる神威古潭の海岸を過ぎると、銭函駅に着く。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "車輪を洗ふ許りに涵々と波の寄せてゐる神威古潭の海岸を過ぎると、錢凾驛に着く。",
              "citation": {
                "source": "札幌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く迫つた方だけで云へば、北海道のこうえふの一名所｜神居古潭の景に似てゐて、ただ面白い釣り橋がないばかりだ。",
              "citation": {
                "source": "鹽原日記",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩の徹夜で、頬ツぽねが神居古潭の巖石の樣に出たと云はれた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのさわやかなヰスキに醉つた勢ひで、渠は再び汽車に投じ、紅葉に有名な神居古潭まで來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、伊納から古潭の下流に至る七八哩の間が絶景だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この古潭の脇に、停車場から向う岸に渡る爲めの釣り橋が足場高くかかつてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠が再び釣り橋を渡り、神居古潭の停車場から汽車に乘り、札幌へついたのは十月十六日の夜だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「全盛でした――もう、神居古潭に來た時は遲過ぎたです。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "十勝原野や神居古潭の紅葉がよかつたこと。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは神居古潭の釣り橋のうへででも思ひ出したところだし、また最近には、自分が雪の屋のゐる中學校へ演説しに行つた時、そのそばを通つてゐるところだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "東蝦夷からぐるりとまわって古潭の難所を抜け、こちら側までつづいているその海上に、去年の船が未だにさまよいつづけているような錯覚に取り憑かれて――「ああ、あのとき出直しておけばよかったものを――」　残された妻は深い溜息をついてそう云った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず鉄道線路を踏切って、伏古古潭の教授所を見る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神居古潭の鉱泉宿である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯後神居古潭を見に出かける。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然児のアイヌがさゝげた神居古潭の名も似つかわしく思われる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の神居古潭で中秋に逢うも、他日の思出の一であろう。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝｜神居古潭の停車場から乗車。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神居古潭の鑛泉宿である。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然兒のアイヌがさゝげた神居古潭の名も似つかはしく思はれる。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の神居古潭で中秋に逢ふも、他日の思出の一であらう。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝｜神居古潭の停車場から乘車。",
              "citation": {
                "source": "熊の足跡",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "図369はそれ等の景色の一つで、場所はカマコタン〔神威古潭〕と呼ばれ、長い、彎曲した浜を前に、高さ八百フィートの玄武岩の崖が聳えている。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ぎーこたん、ばつたりしよ……』狸婆々がうたふ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに竹刀でバシバシと、すこたんを遠慮なしに打ん殴りやがったっけ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "中将からまた折り返して、君にかく引き取られぬる帯なればかくて絶えぬる中とかこたんなんといっても責任がありますよ。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            }
          ]
