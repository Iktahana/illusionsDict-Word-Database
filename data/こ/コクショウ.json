          "standard": [],
          "literary": [
            {
              "text": "三つの王冠――瑞典の国章はどこにでも見受ける――が陽にきらめいている水辺高層の楼閣――ストックホルムが世界に誇る新築の市役所である。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリストフは車窓に顔をくっつけて、版図の境界を示す帝国章のついた標柱を見ようとつとめた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉のこくしょうぐらいは誰でも知っているが、何分にもさかなが大き過ぎるので、殺して食うのは薄気味が悪かった。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
