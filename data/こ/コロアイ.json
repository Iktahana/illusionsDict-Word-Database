        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると一軒｜頃合の家が見つかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイトの薄萠黄の――最も古ぼけては居たが――天鵝絨の劃を、コチンと窓へ上げると、紳士の作法にありなしは別問題だが、いゝ頃合の枕に成る。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）蓮月　――丁度頃合いのあたたか味になった。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると同じ頃合いに、逆コースから順コースの人込みに移ったらしい学生の後姿が五六のまばらの人を距てて、かの女の眼の前にぽっかり新しく泛んだ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "料亭など借りるのは出来過ぎているし、寮は人を介して頼み込むのが大仰だし、その他に頃合いの家を探すのであるが、とかく女の身は不自由である。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会津から佐沼への路は、第一日程は大野原を経て日橋川を渡り、猪苗代湖を右手に見て、其湖の北方なる猪苗代城に止まるのが、急いでも急がいでも行軍上至当の頃合であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの娘を拝むとも言いたくないから、似合いだとか、頃合いだとか、そこは何とか、糸的の心づもりで、糸的の心からこの縁談を思いついたようによ、な、上杉さんに。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸村は、漸く、敵の砲声もたえ、烟も薄らいで来た時、頃合はよし、いざかかれと大音声に下知した。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "珠子の兄が、頃合を見つけて、「南條さんとは、お知合いだったのですか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "計算によれば到着はちょうど朝食の頃合いだ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわかっている、ホームズはいつも自分の頃合と流儀で種明かしをしたい人間なのだ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃合いを見計らって毒蛇をあの通風口へ向かわせ、蛇は綱を伝い寝台へ下りる。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聖ルークへ出向く頃合いだ。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあきっと相手を捕まえてでもいる頃合なんでしょうが。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、実にいい頃合いだ、ワトソンくん。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚破、そのまぎれに、見物の群集の中から、頃合なものを引攫つて、空からストンと、怪我をせぬやうに落いた。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいって見れば臭味もそれほどでなく、ちょうど頃合の温かさで、しばらくつかっているとうっとりして頭が空になる。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の親父とは頃合いの飲み相手だ、薊は二つめにさされた杯を抑え、「時に今日上がったのは、少し願いがあって来たわけじゃから、あんまり酔わねいうちに話してしまうべい。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、午後の三時頃になると、疲れても来るし、ひとが恋しくもなるし、遊びたくなって、頃合いのところで仕事を切り上げ、家へ帰る。",
              "citation": {
                "source": "朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗いランプの蔭に隠れて判然解らなかったが、ランプを置いた小汚ない本箱の外には装飾らしい装飾は一つもなく、粗末な卓子に附属する椅子さえなくして、本箱らしい黒塗の剥げた頃合の高さの箱が腰掛ともなりランプ台ともなるらしかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "久方ぶりの退屈払いには先ず頃合いじゃ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "狙うなら恰度頃合い……。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はッ……」　もう頃合いです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を申すも十年分じゃ、三万両ではちと安いかな」「いや頃合いにござりましょう。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう頃合いでござりましょうぞ」　うしろに下がって声高に呼び上げた退屈男のその合図待ちうけながら、閉められていた御陣屋門がギイギイと真八文字に打ち開かれると、茶坊主お小姓一統を左右に侍せて、あの曲※にいとも気高く腰打ちかけながら、悠然として、その姿をのぞかせたのは、ぐずり松平の御前です。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ未だころあいを知らず。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "とおっしゃって、ちょうどいいころあいの、中ほどの瀬におおりになり、水をかぶって、おからだじゅうをお洗いになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつはころあいのうちが見つかったもんですからな」　西田の声がして家のなかの空気は見るまに変わってしまった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ねえ、だんな、ないしょにちょっと申しますが、ついでだからころあいなのをひとり見当つけておいたらどうですかい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "千萩がまたこの寺へ毎夜毎夜へびのえさのねずみ取りに来ることをかぎ知り、こっそりとこの寺に寝泊まりしておりまして、このとおり、毎夜毎夜ころあいを見計らっては意見に来ますけれど、千萩は相手になってもくれないのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            }
          ]
        }
