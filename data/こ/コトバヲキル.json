[
  {
    "uuid": "c778a5e1-d498-56da-b9f2-c28cb9f4f8df",
    "entry": "言葉を切る",
    "reading": {
      "primary": "ことばをきる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
