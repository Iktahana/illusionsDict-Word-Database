[
  {
    "uuid": "8c99462e-e519-59b1-902e-6163c6e7db45",
    "entry": "購買力",
    "reading": {
      "primary": "こうばいりょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
