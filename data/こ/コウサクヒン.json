        "examples": {
          "standard": [
            {
              "text": "幼稚園の文化祭では、園児たちが一生懸命作った可愛らしい工作品が展示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "押し入れを整理していたら、子供が小学生の時にプレゼントしてくれた工作品が出てきて胸が熱くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バザーに出品された手作りの工作品は、その温かみのあるデザインですぐに完売した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "このだんだん手のこんできた美しいおそえものは、三根夫が作る工作品にしては、少々できすぎていると思われた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち唐代の租・庸・調の制度は、人民は政府に對して地代を納め、力役に服し、工作品を提供する意味のものであつた。",
              "citation": {
                "source": "概括的唐宋時代觀",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            }
          ]
        }
