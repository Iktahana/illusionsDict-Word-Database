          "standard": [
            {
              "text": "古い米びつの底から米食い虫が湧いてしまい、全部処分する羽目になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "唐辛子を一緒に入れておくと、米食い虫の発生を抑えられるという生活の知恵がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "倉庫の隅に置き忘れた米袋が、すっかり米食い虫の住処になっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
