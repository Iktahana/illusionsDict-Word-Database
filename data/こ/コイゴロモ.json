        "examples": {
          "standard": [
            {
              "text": "彼女は恋衣を纏ったかのように、恋をしてからますます美しくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重い恋衣を脱ぎ捨てて、新しい人生を一歩踏み出す決心がついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "恋衣に縛られた不自由な生活も、彼と一緒なら耐えられると思っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この歌は第四集「恋衣」の歌だ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋衣｜裘より重ければ素肌の上に一つのみ著る　恋衣といふ衣は裘などに比べればとても重い衣なので私は素肌の上にたつた一枚著て居るだけです。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十二年五月二十七日『ホトトギス』発行所高浜虚子明治時代春雨の衣桁に重し恋衣明治二十七年夕立やぬれて戻りて欄に倚る明治二十八年　子規を神戸病院より、須磨保養院に送りて数日滞在。",
              "citation": {
                "source": "五百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
