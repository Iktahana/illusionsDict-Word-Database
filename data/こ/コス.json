  {
    "uuid": "0366b257-43ce-5217-b214-61fd83b1b9b6",
    "entry": "コス",
    "reading": {
      "primary": "コス",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cosplay (dressing up as a character from an anime, manga, video game, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "塚も動け我が泣く声は秋の風　芭蕉の悲哀は、宇宙の無限大なコスモスに通じている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の子供はコスモポリタンなお伽噺の洪水の波に押流されているようなものである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄雲を透した日光が暫く此の靜かな村里を照らして、ダリアやコスモスが光り輝くやうに見えた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭に下りて咲きおくれた金蓮花とコスモスを摘んだ。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海が彼女の舞台なら、そのコスチュームはノラの薄鼠色の皮膚だ。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "武井さんは雨にしほれたやうな白と赤のコスモスの花を手にして、傍に立つてゐた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、綺麗ですね……」と、私は花立に※さつたコスモスの花を眺めながら云つたが、何となく何時ものやうな明るいなごんだ氣持にはなれなかつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔をコスっているもの？",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯野のコスモスに行き逢うと、私は、それと同じ痛苦を感じます。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の朝顔も、コスモスと同じくらいに私を瞬時窒息させます。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は博多｜竪町の荒物屋渡世……当年五十六歳で……ヘエ……」　と淀みなく言ううちに涙ぐんだ赤んべえ面を上げて水洟を一つコスリ上げた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのような御大家でも縁辺のお話となりますと、一度はキット私の存じ寄りを聞きに御出でになりまっするで、私が、あれなら大丈夫と請合いますると、それからお話が進みまするような事で……ヘエ……」　と自慢そうにモウ一度、鼻の頭をコスリ上げた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い鼻の頭を今一度、念入りにコスリ上げると、炭俵の上からガサガサと一膝進み出た。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は悲しくなってシクシク泣き出しましたが、やがて花子さんはばあやのお庭の隅に、「メリーさんのお墓」と書いた木の札を立ててコスモスやケイトーの花を上げて拝みました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはコスモスと虞美人草とそうして小桜草である。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方珍しくないコスモスは取られないほうに属していた。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらくた壇上に張交ぜの二枚屏風、ずんどの銅の花瓶に、からびたコスモスを投込んで、新式な家庭を見せると、隣の同じ道具屋の亭主は、炬燵櫓に、ちょんと乗って、胡坐を小さく、風除けに、葛籠を押立てて、天窓から、その尻まですっぽりと安置に及んで、秘仏はどうだ、と達磨を極めて、寂寞として定に入る。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱を差したように両人気はしっくり合ってるけれども、その為人は大いに違って、島野は、すべて、コスメチック、香水、巻莨、洋杖、護謨靴という才子肌。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……失禮ながら、缺摺鉢の松葉牡丹、蜜柑箱のコスモスもありさうだが、やがて夏も半ば、秋をかけて、手桶、盥、俎、柄杓の柄にも朝顏の蔓など掛けて、家々の後姿は、花野の帶を白露に織るであらう。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になっては、コスモスと紫苑がわたしの庭を賑わした。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろの季節では、蓼、りんどう、コスモス、芒、石蕗、等々何でもよい、何でもよさを持っている。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩ちればコスモス咲いてそして茶の花も（「愚を守る」初版本）",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "高価なネクタイだのチェッコスロバキヤの硝子細工だのを売る店の様子は戦争に行く前とちっとも変っていませんでした。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸子は庭に降りて、誰も構うものがないので、延び放題に延びてたおれかけたコスモスの群れをいくつにもまとめて紐で縛りつけていた。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたの方がコスモスより、よっぽどヒョロヒョロのくせに。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "うるんだ瞼を片手でコスリまわして、暗くなりかけた意識を取り返しつつ、オズオズとそこいらを見まわした。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして結局何が何やら解らなくなったまま、銀貨の反射で痛くなりかけた瞼をコスリまわしているうちに、いつの間にか、乳母車の把手に捉まってコロコロと押し始めていた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯銭は払うてあるけに……」　お千代は濡れた手で眼をコスリながらうなずいた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからお千代は又コクリコクリと居ねむりを初めたが、そのうちに鼻から湯を吸い込んで噎せ返っているうちにスッカリ眼が醒めてしまったので、ヤット湯から上って、まだねむい眼をコスリコスリ身体を拭いた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
