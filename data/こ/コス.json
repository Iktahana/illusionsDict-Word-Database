[
  {
    "uuid": "ab2bd370-08af-5b23-b262-b80e6df4816c",
    "entry": "越す",
    "reading": {
      "primary": "こす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to cross over (e.g. mountain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "無事にトラックも一台で難なく積めると、引越す先は鍋屋横丁を這入つて左に曲つて、も一度左に曲つて一寸行つた右側であるさうな。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いつもながらこの大川を越す瞬間のときめき。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに素質は自覚されてからは物性を超越するもの、従て有意的に変るものであります。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした活気はすべてのものの勃興時代にのみ見らるるものであって、一度隆盛期を通り越すと消えてしまう。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "流しの板のすべりそうなのを踏んで向側へ越すと柵があってその上は鉄道線路、その向うは山の裾である。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大井川の水｜涸れ／＼にして蛇籠に草離々たる、越すに越されざりし「朝貌日記」何とかの段は更なり、雲助とかの肩によって渡る御侍、磧に錫杖立てて歌よむ行脚など廻り燈籠のように眼前に浮ぶ心地せらる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高阪橋を越す時東を見ると、女学生が大勢立っていると思ったが、それは海老茶色の葦を干してあるのであった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶頂をわざわざ越す鳥は純な鷺だけだといわれているが、あの鳥はそうなのか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの山を越す哀しい鳥の数も数え尽した」「もう、いいわ、じゃ、ね」さぬらくは玉の緒ばかり恋ふらくは不二の高嶺の鳴沢のごと駿河の海｜磯辺に生ふる浜つづら汝をたのみ母にたがひぬ",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはいまその電燈を通り越す。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は何として越す、三｜之助を貰ひにやろかとあれば、ほんに夫れで御座んす、常日さへあるに大晦日といふては私の身に隙はあるまじ、道の遠きに可憐さうなれど三ちやんを頼みます、晝前のうちに必らず必らず支度はして置まするとて、首尾よく受合ひてお峰は歸りぬ。",
              "citation": {
                "source": "大つごもり",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は何として越す、三之助を貰ひにやろかとあれば、ほんにそれで御座んす、常日さへあるに大晦日といふては私の身に隙はあるまじ、道の遠きに可憐さうなれど三ちやんを頼みます、昼前のうちに必らず必らず支度はして置まするとて、首尾よく受合ひてお峯は帰りぬ。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理学上の方則には誤りはないはずであっても、これを応用すべき具体的の「場合」の前提とすべき与件の判定は往々にして純正物理学の範囲を超越する。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は何として越す、三之助を貰ひにやろかとあれば、ほんに夫れで御座んす、常日さへあるに大晦日といふては私の身に隙はあるまじ、道の遠きに可憐さうなれど、三ちやんを頼みます、晝前のうちに必らず必らず支度はして置まするとて、首尾よく受合ひてお峰は歸りぬ。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の成果は箇々の科学者の個性を超越する。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の絵描きは自然や人間の天然の姿を洞察することにおいて常人の水準以上に卓越することを理想としていたらしく見える。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも人間の自然性がいかに「方則」の上に超越するかと言ふことを、君は僕に教へてくれた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次急に足を早めて侍を追い越すとその儘走り出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、いつ越すかわからないよ」　湊は珍らしく表で逢ったからともよにお茶でも御馳走しようといって町筋をすこし物色したが、この辺には思わしい店もなかった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫時くすると箱根へ越す峻嶺から雨を吹き下して來た、霧のやうな雨が斜に僕を掠めて飛ぶ。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州人と東北人と比べると各個人の個性を超越するとしてもその上にそれぞれの地方的特性の支配が歴然と認められる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画フィルムも現在のままの物質では長い時間を持ち越す見込みがないように思われるから、やはり結局は完全に風化に堪えうる無機物質ばかりでできあがった原板に転写した上で適当な場所に保存するほかはないであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲痛も、度を越すと、滑稽な姿にアウフヘーベンするものらしい。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤慨もまた度を越すと、滑稽に止揚するものらしい。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりして乗り越すようなあれじゃないが、……彼女は一方でこんなことも思った。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲はまばゆき墨と銀、　　　　波羅蜜山の松を越す。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝の葉書のこと、考えが変わってやめることにしたから、お願いしたことご中止ください」　今朝彼は暖い海岸で冬を越すことを想い、そこに住んでいる友人に貸家を捜すことを頼んで遣ったのだった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず前の世のこの白痴の身が、冥土から管でそのふくれた腹へ通わして寄越すほどに聞えましたよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その尻上がりの「ですか」を饒舌って、時々じろじろと下目に見越すのが、田舎漢だと侮るなと言う態度の、それが明かに窓から見透く。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階に昼寝してゐた汚ない顔の女給が、目をこすりながらいやみつたらしく出て来たのだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
