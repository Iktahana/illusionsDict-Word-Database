          "literary": [
            {
              "text": "どこかであんなコロタイプを見た。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "影も落ちてゐる、どこかであんなコロタイプを見た。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絵はがきの中に天文や地文に関する図解や写真をコロタイプで印刷した一組のものが目についた。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真といっても、神宮紙にコロタイプ印刷をしたものを用いるので、初めに胡粉で一応塗り潰してから描いて行くのである。",
              "citation": {
                "source": "壁画摸写",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、この短篇集の巻頭にはコロタイプ版の春泥の肖像が掲げられ、奥附には著者平田一郎と彼の本名が印刷されてあったことは、注意すべきであります。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
