        "examples": {
          "standard": [
            {
              "text": "落ち込む弟を励まそうとする、彼の兄心（このかみごころ）が伝わってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "つい口うるさくなってしまうのも、君を思う兄心（このかみごころ）ゆえだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "兄心（このかみごころ）から、彼は自分の貯金をはたいて妹の学費を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "賢兄心ニコノ義ヲ主トシサキニ先人ノ遺稿中ニ就テ曾撰ノ二首ト自ラ賦スルモノトヲ合セテ天下ノ一大壇場ニ上シ以テ不朽ニ垂レシム。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
