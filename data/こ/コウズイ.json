[
  {
    "uuid": "5f368d99-f799-5a8a-872c-b21297899d28",
    "entry": "洪水",
    "reading": {
      "primary": "こうずい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今の子供はコスモポリタンなお伽噺の洪水の波に押流されているようなものである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを陸上であけたら、奇怪な蜃氣樓が立ち昇り、あなたを發狂させたり何かするかも知れないし、或ひはまた、海の潮が噴出して大洪水を起す事なども無いとは限らないし、とにかく海底の酸素を陸上に放散させては、どうせ、ろくな事が起らないやうな氣がしますよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと槍ヶ岳の頂、といっても槍の穂先からは、まだ蛭巻ぐらいの位置に当る、平ッたい鞍状地に到着した、槍から無残に崩壊した岩は、洪水のように汎濫している、そうしてこれが巨大なる槍ヶ岳を、目の上に高く聳えしむるために、払われた犠牲であるかと思うと、私は天才の惨酷に戦慄するのである。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉はやはり、新湯に泊まった、去年（四十年）秋、笹子峠のトンネルを崩壊し、石和の町を白沙の巷に化して、多くの人死を生じさせた洪水は、この山奥に入ると、いかばかりひどく荒れたかということが解る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く洪水よりも怖しい沙の汎濫である。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、私は嘆息する、天地の間には、風が吹くのでなければ、霧が流れるのだ、そのたびに、天幕の中へ、ザアと小粒の雨がそそぎ入る、柱代りの金剛杖が、キュッと呻る、杭に纜われた小舟が、洪水に飜弄されるように、油紙の屋根が、ペラペラ動く。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "川楊の大木が、嵐にも洪水にも抵抗し抜いて、力も何も尽き果てたというように、ぐったりと根こそぎに、岸から川の中へ打ち倒れているのを、橋代りにして渡ったが、向う岸に着くまでには、三度ばかり冷たい水の徒渉をしないわけには行かなかった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氷河で思い出したが、私が桑港にいるとき、一九二四年九月十八日の夕、新聞の号外売りが、声高く「ラッセン火山大爆裂、シャスタ氷河大融解」と、大の字｜尽くしで呼んでいるので、耳寄りに思って買って見ると、いかにもシャスタ山の、氷河融解、大洪水来と、拳大の活字で見出しがついている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨山脈の槍ヶ岳から鎌尾根という山稜にかかる辺に、その岩石は洪水のように溢れている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "手水鉢を座敷のまん中で取り落として洪水を起こしたり、火燵のお下がりを入れて寝て蒲団から畳まで径一尺ほどの焼け穴をこしらえた事もあった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい洪水の後らしかった。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいつかの洪水でできてからもう余程の年を経たらしく高さも百尺はあった。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪水がいつまた黒い壁のやうになって襲って来るかわからないと考へた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらにひろがる高い雑木の梢を見た、あすこまで昇ればまづ大低の洪水なら大丈夫だ、そのうちにきっと弟が助けに来る、けれどもどうして助けるのかなとおれは考へた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　地獄変相図の世界国ノアの洪水、ソファの下から這出した蜘蛛蟹のお化け。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の病気の原因は洪水で、あの恰好を一月ばかり毎日続けたからです。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、彼女の涙の洪水に、僕の不徳が押し流されてしまうのだった。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に妾は温かいものが肩から乳房にかけて洪水のように流れかかるのを感じました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときによってジャズ・バンドがビビの音楽をやっているとき、死海の水に映って正気を失った士官に貴女が抱かれて、独逸仕込の接吻の洪水のなかで、彼奴がロメオとジュリエットの名台詞を彼がネロのようにそりかえって早口で喋舌るときは全く貴女を薄倖の踊子だとさえ思ったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　酒と歌と踊のなかからでてきた男女が熱い匂のする魅力にひかれて、洪水のようにながれる車体に拾われると、夥しい巡査がいま迄の蛮地のエロチシズムの掃除を始めて、街は伝統とカルチュアが支配する帝王色に塗りかえられた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラリーメンの洪水のために死骸のような建物の堰が破られて、空にそびえる高楼の窓が花のようにひらくと、女事務員の青と赤の色彩が花粉の媒介の役目をした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義運動勃興以前の各既成作家の行きづまりは、恐ろしく、水っぽい戦争小説の洪水をもたらした。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、もう一つ指摘するならば、一九三〇年頃より「日米若し戦はゞ」とか「米国恐るゝに足らず」とか云った日米戦争未来記が市場に洪水している如く、日露戦争前にあっては、日露戦争未来記が簇出して、いやが上にも敵愾心をあおり立てゝいたことである。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その川はふだんは水もすきとおり、淵には雲や樹の影もうつるのでしたが、一ぺん洪水になると、幅十町もある楊の生えた広い河原が、恐ろしく咆える水で、いっぱいになってしまったのです。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昔の川の流れたあとで、洪水のたびにいくらか形も変るのでしたが、すっかり無くなるということもありませんでした。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その滝が荒れましたと申しまして、ちょうど今から十三年前、恐しい洪水がございました、こんな高い処まで川の底になりましてね、麓の村も山も家も残らず流れてしまいました。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
