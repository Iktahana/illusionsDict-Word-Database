        "examples": {
          "standard": [
            {
              "text": "新鮮な海産物を全国に届けるため、航空輸送が積極的に利用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "緊急の医療品は、迅速な航空輸送によって被災地へ運ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "航空輸送の発展が、国際貿易の活性化に貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ポール・キャット　先日、航空に関する或る集まりで、日本の航空輸送の将来についての話が出たことがある。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本航空輸送会社の旅客機白鳩号が、昭和七年二月二十七日、九州の上空で空中分解を起し、山林中に墜落した事件である。",
              "citation": {
                "source": "「もく星」号の謎",
                "author": "――白鳩号遭難事件を回顧して――",
                "note": "青空文庫"
              }
            }
          ]
