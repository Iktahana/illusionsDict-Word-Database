[
  {
    "uuid": "03bc7d83-a406-5ae4-97cf-fb4c54b7834a",
    "entry": "口舌",
    "reading": {
      "primary": "こうぜつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
