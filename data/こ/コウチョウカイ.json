        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "適当な時期にこの法案に関する公聴会がもたれることが適切であろう。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る八月初旬に再び大規模の公聴会がひらかれるであろう。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十九日（火）　十二時　ソヴェト文化の夕七月三日（土）　午後一時　飛行館七月五日（月）　ラジオ公聴会全国ネンリョー会館　一時半　安田銀行となり七月十日（土）　母、隆治、着七月十三日（火）　放送委員会。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月四日（水）　公聴会午後一時半　蔵前工業会館　仕事八枚　けさ四時古田氏帰京。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖れたのは告訴公聴会がどうなることやら。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　もし簡易公聴会がハースコートに監視されていることを知っていたならば、グラスゴウ部長も心穏やかじゃなかっただろう。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも公聴会を聞いてちっとも困らないのは、間接的にしか関わっていないからだ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "公聴会で女が書類を持っていることを聞いた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日が正規の公聴会のはずだったのに。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
