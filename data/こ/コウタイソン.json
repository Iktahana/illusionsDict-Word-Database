        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翰林学士の劉三吾、御歎はさることながら、既に皇孫のましませば何事か候うべき、儲君と仰せ出されんには、四海心を繋け奉らんに、然のみは御過憂あるべからず、と白したりければ、実にもと点頭かせられて、其歳の九月、立てゝ皇太孫と定められたるが、即ち後に建文の帝と申す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇太孫｜允※、仁明孝友にして、天下心を帰す、宜しく大位に登るべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇太孫｜允踞するもの存し、太祖崩じて後二十余年にして猶大に興和に寇するあり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖崩じ、皇太孫立つに至って、廷臣｜交々孝孺を薦む。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇太孫｜九龍口に於て危難に臨む。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此月六日皇太孫ジョールジ（現在位英皇）の婚儀行列を見ん迚、ビショプスゲイト街、横濱正金銀行支店に往し時相識と成し也。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
