        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "多門通りより元の道に出てまた前の氷屋に一杯の玉壺を呼んで荷物を受取り停車場に行く。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の氷屋などでは、板に丸い穴をあけて、そこに幾つとなく、ラムネを逆さにして立てて居る。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒倒しそうになると氷屋へはいって休み休みしたので、とうとう一日に十一杯の氷水をのんだ。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ、と成れば、法もかく、手心は心得たが、さて指当って、腹は空く、汗は流れる、咽喉は乾く、氷屋へ入る仕覚も無かった。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの踏切のさきの処に、一軒氷屋がまだ寝ないでいましたが、水提灯が一つ、暗くついただけ、暖簾は掛ばなしで、誰も人は居ないのです。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もう氷屋の灯の届かない処へ消えたんですが。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい氷屋の車屋台が出ている。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾人の立ちン坊もここを稼ぎ場とし、氷屋も甘酒屋もここで一日の生計を立てていたのである。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は昔と違っているであろうが、氷屋や甘酒屋の店も依然として出ていた。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷屋も甘酒屋も影をかくした。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝月残る木槿が咲いてゐるながれ　島へ渡しの、氷や菜葉や郵便や・氷屋ができて夾竹桃の赤や白や・落ちてきて米つく音の水がながれる・近道のいちはやく山萩の花・水は岩からお盆のそうめん冷やしてある　　行乞雑感（一）　八月十一日晴、暑かつたが気持は軽かつた、仙崎町行乞、そして滞在、新相客は伊佐で同宿の老遍路。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ叔父の家に落着いて、其となく蓮沼＝綾さんの家の姓だ＝の家の樣子を聞くと、皆達者でゐるが、相變らず貧乏で、近頃小さな氷屋を始めて、綾さんは鉛筆を製造する工場の女工になツてゐるといふことであツた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂のあがり口の冬は「おでん屋」になる氷屋の一家は、寺の門の内の藤棚の下へ避難していた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに太った氷屋の老婆がおどおどして立っていた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷屋の青年は、そのまゝはやり歌を口笛で吹きながら対岸の方へ自転車を走り出さしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "双肌脱いだ儘｜仰向に寝転んでゐると、明放した二階の窓から向ひの氷屋の旗と乾き切つた瓦屋根と真白い綿を積み重ねた様な夏の雲とが見えた。",
              "citation": {
                "source": "氷屋の旗",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も其氷屋の旗が、何かしら為よう／＼と焦心り乍ら、何もせずにゐる自分の現在の精神の姿の様にも思はれた。",
              "citation": {
                "source": "氷屋の旗",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは縁日物の籠に入れられて氷屋の店に鳴くのである。",
              "citation": {
                "source": "氷屋の旗",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体何を自分は為る事があるのだらうと思ひ乍ら、私は復死んだ様な氷屋の旗を見た。",
              "citation": {
                "source": "氷屋の旗",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "病身の氷屋の女房が岡持を持ち、骨折れた蝙蝠傘をさしかけて門を出れば、横町の下宿から出て進み来る、夏の恐怖に物言はぬ脚気患者の葬りの列。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよツとした坂の、水で掘り崩れて大きな杉や檜の木の根が現はれてゐるのを登ると、氷屋がある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは義直の家の隣になつた氷屋であつた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（氷屋で聞けば、叔父の来たか来ないかが判るな、）　氷屋の老婆と娘とが自分のために叔父の見張をしてくれてゐるやうな感じがした。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷屋に来てゐる学生であらう。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは氷屋の娘であつた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎はあるデパートメントストアーへ出ているという夫婦暮らしの家へ、次郎は少し遠方のあるおやしきへ、赤はひとり住みの御隠居さんの所へ、最後におさるは近い電車通りの氷屋へそれぞれ片付いて行った。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさるの片付いた氷屋も便宜がいいので通りがかりに見に行くそうである。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になってその氷屋は芋屋に変わった。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五軒｜筋違の向う側に、真赤な毛氈をかけた床几の端が見えて、氷屋が一軒、それには団扇が乗ってるばかり、涼しさは涼し、風はあり、月夜なり。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
