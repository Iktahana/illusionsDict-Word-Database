    "definitions": [
      {
        "index": 1,
        "gloss": "cluster of trees",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "魚臭き村に出けり夏木立　旅中の実咏である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青葉の茂った夏木立の街道を通って来ると、魚くさい臭いのする、小さな村に出たというのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この村の人は猿なり冬木立　田も畠も凍りついた冬枯れの貧しい寒村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物園にて灼きつく如く寂しさ迫りひとり來りて園内の木立を行けば枯葉みな地に落ち猛獸は檻の中に憂ひ眠れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ少年の日は、常に麥笛を鳴らして此所を過ぎ、長き煉瓦の塀を※りて、果なき憂愁にさびしみしが、崖を下りて河原に立てば、冬枯れの木立の中に、悲しき懲役の人人、看守に引かれて石を運び、利根川の淺き川瀬を速くせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後に冬木立の逆様に映った水面の絵を出したらそれは入選したが「あれはあまり凝り過ぎてると碧梧桐が云ったよ」という注意を受けた。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左に近く大津の町つらなりて、三井寺木立に見えかくれす。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広々した畑地に霜解けを踏んで、冬枯れの木立の上に高い蒼空を流れる雲でも見ながら、当もなく歩いていたいと思う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今となつてみると、新雪の輝やく富士山がよく見えぬからと言つて、出洒張つた杉木立の梢を恨んだのは、勿体ない気がする。",
              "citation": {
                "source": "亡びゆく森",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢車草、車百合、ドウダンなどが、栂や白樺の、疎らな木立の下に、もやもやと茂っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸の如くに降りしきる雨の中にたたずんで、モミや落葉松の美しい木立に見とれる、この辺から、裾野式の高原を展開して、桔梗がさき、萩がさき、女郎花がひょろひょろと露けく、キスゲが洞燈のような、明かる味をさしている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ティアガルテンの冬木立や、オペラの春の夜の人の群や、あるいは地球の北の果の淋しい港の埠頭や、そうした背景の前に立つ佗しげな旅客の絵姿に自分のある日の片影を見出す。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分の経験によると、暴風の夜にかすかな空明りに照らされた木立を見ていると烈風のかたまりが吹きつける瞬間に樹の葉がことごとく裏返って白っぽく見えるので、その辺が一体に明るくなるような気のすることがある。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右から木立の茂った山の崖裾の間をくねって通って行く道は、ときどき梢の葉の密閉を受け、行手が小暗くなる。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外界よりの光を庇、袖垣、または庭の木立で適宜に遮断することを要する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、「キ、ヒ、ミ」も「月」が「月夜」となり、「火」が「火中」となり、「神」が「神風」となり、「身」が「むくろ」（骸）となり、「木」が「木立」になります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い共同椅子森の中の小径にそうて、まつ白い共同椅子がならんでゐる、そこらはさむしい山の中で、たいそう緑のかげがふかい、あちらの森をすかしてみると、そこにもさみしい木立がみえて、上品な、まつしろな椅子の足がそろつてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と杉木立の真黒な処から、　ニューと天狗が現れた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪こそは降り出さなかったが、その灰色をした雪雲の下に、骨を削ったような櫟や樫の木立は、寒い木枯に物凄い叫びをあげていた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼さがりからは冬の陽の衰えた薄日も射さず、雪こそは降り出さなかったが、その気配を見せている灰色の雲の下に、骨を削ったような榎や樫の木立は、寒い凩に物凄い叫びをあげていた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立ももうほとんど無い。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてペピイとクリストフとはいつもおぢいさんと小さい娘との後影が木立の向うに隠れるのを見送る。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから、だらだら坂になっているアカシア並木の赭土の途を揺られながら、ペル・※ュウ村の木立の上に風車の廻っているロダンさんの粗末なお宅につくと、薔薇園の木戸口に肉体の彫刻的に締った、銀髪のロダン夫人が立って、妾を迎えてくださいました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "水車は川向にあつて其古めかしい處、木立の繁みに半ば被はれて居る案排、蔦葛が這ひ纏ふて居る具合、少年心にも面白い畫題と心得て居たのである。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "水車は川向にあってその古めかしい処、木立の繁みに半ば被われている案排、蔦葛が這い纏うている具合、少年心にも面白い画題と心得ていたのである。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨晴れのから風の強い日であって、番町へんいったいの木立ちの青葉が悩ましく揺れ騒いで白い葉裏をかえしていたのを覚えている。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまたこの蜂が今現にどこか遠いところで知らぬ家の庭の木立に迷って、あてもなく飛んでいるような気もした。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立の向うにはいろいろの色彩をした建築がまともに朝の光を浴びて華やかに輝いていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲やうやう黄金にあかりぬ、花柏こだちのうへただよふ姫が歌ごゑ。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言いたいだけ言ってしまうと、怪物はクルッとむきをかえて、サーッと、庭のおくの、こだちの中へかけこんでしまいました。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
