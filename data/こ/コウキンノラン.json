  {
    "uuid": "22b1314d-0904-5a59-909d-84675398b9ed",
    "entry": "黄巾の乱",
    "reading": {
      "primary": "こうきんのらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
