  {
    "uuid": "6b07f2dd-853f-5301-8b88-b0ec7a5c5171",
    "entry": "校服",
    "reading": {
      "primary": "こうふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "school uniform",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「Ｆさんはジュンの学校服を借りて大学生になりなさいよ。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰め襟のホックをかけずに着慣れた学校服を脱ぎ捨てて、君は厚衣を羽織る身になった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服ひとつとっても、金糸のエンブレムがついた紺のブレザー、レジメンタル・タイ、グレイのスラックス、というフォーマルなもの、そして、ふだん学校や寮で着る、衿なし上着にオープンシャツの校服、という二種類があり、いろいろ行事のある入寮入学前後は指示が複雑で、新入生を悩ませた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさい、入寮二日目の夕食では、前夜の晩餐会であすからは夕食も校服着用のこと、といわれていたにもかかわらず、八人全員がネクタイをしめてあらわれた部屋が、ふたつもあった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "14おれの人生だ好きなようにする〈イッツ・マイ・ライフ〉アニマルズ　学園祭もとうに終わって、もう、校服の上着のしたにセーターを着ないと、校舎にいく短い坂道も歩きたくない、という季節になった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "校服のスカートには、ポケットがあるはずだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "校服はちゃんとはっきりしているのに、くびから上が、ぼんやりしているのだった。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に申上げたやうな品物に、小倉の校服の上衣だの、硯だのを加へて、値踏みをさせますと、四十錢の上は一文も出せないといふんです。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に申上げた様な品物に、小倉の校服の上衣だの、硯だのを加へて、値踏みをさせますと、四十銭の上は一文も出せないといふんです。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥にまみれた学校服の義夫が、戸板に載せられて、四五人の村人に運ばれて来たのです。",
              "citation": {
                "source": "安死術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "むずかしい将校服などにも、綺麗にミシンをかけることが出来てきた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈は母の紺色の襟飾が長く下まで垂れているのを見上げ、海軍の将校服に似ているねとひやかした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お徳に言わせると、末子の同級生で新調の校服を着て学校通いをするような娘は今は一人もないとのことだった。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "末子は女学生風の校服のまま青山の姪のうしろへ来て静かにすわった。",
              "citation": {
                "source": "分配",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、不意に道の角を廻り、この辺りに珍しい二頭立の、立派な馬車が現われたが、その上に海軍の将校服をつけた、半白の髪をした英国人と、支那少年とが同乗していた。",
              "citation": {
                "source": "鴉片を喫む美少年",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の向うの隅の所に一人の婦人と校服を著た青年とがいた。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　労農ロシアの影響だらうと思ふが、曾若夫人はすべての南京の若夫人のやうに「女同志」――即ち、准将校服に革ゲートルをつけた儘で出て来た。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "セエラは女中に紺の学校服を着せてもらい、同じ色のリボンを結んでもらってから、椅子の上のエミリイに本を一冊持って行ってやりました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷蒲団の上で重心をとりそこねて、ちょっと、よろけかかったが、そのまま泳ぐように壁ぎわに行って、そこにかけてあった学校服を着た。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そのうちに次郎もやっとあきらめたらしく、恭一の蒲団から身を起して、校服のまま自分の寝床にはいった。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いセーラーの校服がすこし汗ばんでいる。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が外套をとると、そこに現れたのは繻子や寶石で――無論私の贈り物ですが――まばゆいばかりのヴァレンと、將校服の彼女の連の姿でした。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "校服の少女汗くさく活溌に六月三日　家庭俳句会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そういって龍介は校服のポケットから、さっきの挑戦状を取り出して伯父に見せた。",
              "citation": {
                "source": "黒襟飾組の魔手",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子の行方　校服を清楚な散歩服に着換えたゆき子は、「ちょっと野河さんの家まで行ってくるわ」　と云い残して家を出た。",
              "citation": {
                "source": "劇団「笑う妖魔」",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう校服を着ていたが、帽子はかぶらず、手ぶらで、ゆっくりと階段をおりて来た。",
              "citation": {
                "source": "ばちあたり",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっと引くりかえして、ほら、こうふくれたら、またさっとかえして……。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
