    "definitions": [
      {
        "index": 1,
        "gloss": "recommendation of an influential person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
