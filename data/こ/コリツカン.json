        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この作品が、漱石の作家としての生涯の特に孤立感の痛切であった時代のものであるという小宮豊隆氏の解説も肯ける。",
              "citation": {
                "source": "漱石の「行人」について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実に対する適応性が全くなく、常に孤立感に囚われる。",
              "citation": {
                "source": "意欲の窒息",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその孤立感のなかで、内省へ内省へと不断に駆り立てられる。",
              "citation": {
                "source": "意欲の窒息",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "危く焼け残った一軒家のように、激しい孤立感を呼びおこす。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師が来るまで小一時間病人と二人ぎりで、伸子は名状し難い孤立感を覚えた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
