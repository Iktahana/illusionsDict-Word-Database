[
  {
    "uuid": "01408d79-718c-5b32-8db2-5add51237dfe",
    "entry": "国営",
    "reading": {
      "primary": "こくえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "government management",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "歌舞伎を国営とし、新劇を松竹と東宝に任すべきと思う。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "広場を前にして、三階コンクリート建の国営デパートメントの大きい硝子窓がある。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロストフ市から数十哩東にソヴェト一の大国営農場「ギガント」がある。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "収穫物の取引は集団農場と国営の生産組合とが直接やるのであるから、だまされる心配をする必要がない。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、来ていた人に、自分がソヴェト同盟の南の地方を見学旅行したとき或る国営農場で見たいろいろのことを話した。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国民経済の計画化」（日満北支一体）は、基礎産業の国営、輸入国営、輸出奨励、為替管理、軍需工業国営、中央銀行及び保険国営、工業商業農業各金融の調整、運輸産業の総合的改革、配給統制（専売制度の拡充）、政治機構の能率的改革、総合的国力発展計画、を含む。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには国営という観念の特殊な響きがある。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ無条件に国営を提唱することは、それだけでは結局は日本型ファシズムの結論とも一致するものでしかない。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る契機に於ては国営経済主義が中心となり、そこから民族主義や全体主義への通路も用意されているだろう。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大通りの商店――その多くは空っぽであり、ほとんど一軒おきにあき家だが――はみんな言うまでもなく国営で、売子も番頭もここではお役人である。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはグルドブロロプス・ヘメットという国営のアパアトメントで、大いに曰くがある。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟では、集団農場・国営農場があって、機械化された農業が行われている。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻馬車が、国営衣服裁縫所製のココア色レイン・コートを幾枚も束にして膝へ抱え込んでいる若者をのせてやって来た。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトは、社会主義生産の技術を高めて、やがて、一台のトラクターも外国から買い込まないようにするために、今暫く、国営農場「ギガント」に、アメリカ人技師の指導をうけているのだと。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しいソヴェトがどんないい工場を持ってるか、集団農場、国営農場はどんなにやっているか、都会の工場からの代表が一大隊繰り出すのにもよく出逢う。",
              "citation": {
                "source": "ソヴェト労働者の夏休み",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、その夏、ウクライナの大国営農場「ギガント」を見学に行った。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ギガント」から一時間ばかり汽車にのっかって行くと、「ウェルブリュード」という国営大耕地の真中に、農業機械専門学校がある。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟では、十四年来面倒な台所を、大仕掛の国営厨房工場というものに変えることをやって来た。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして丈夫に　医業国営＝誰でも無料で診察をうけ、入院出来るようにというのがソヴェト同盟の理想だ。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンバス炭坑区を近くに持ち、大国営農場、機械工場をもち五ヵ年計画とともにソヴェト同盟の南方地域では屈指の重工業、農業の生産中心地となった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は七月のある朝、ドイツからソヴェト同盟へやって来たドイツの労働者見学団といっしょにホテルを出て、ドン国営煙草工場見学に出かけた。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロストフはウクライナ共和国の主都で、附近にはソヴェト第一の大国営農場「ギガント」があった。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟ではわたしたちがどんなに生活するようになったか」　ドン国営煙草工場は生産高がソヴェト同盟一二を争うほどあり、労働者は全体で千何百人かいる。",
              "citation": {
                "source": "明るい工場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはただ一例を示しただけであるが、今日のドイツには、産業上すべての方面にわたって、かくのごとき国有主義、国営主義が実現されつつあるものと見て、大過はない。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともわが国においても、郵便、電信、鉄道等はすでに国営事業となり、塩、煙草、樟脳等もまた政府の専売になっている。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを補うために、国営、集団農場で行われた牧畜は僅か一パーセント増しているに過ぎない。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国営工業からはその生産品を出来るだけ安く、早く、便利に農村へ送るように。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
