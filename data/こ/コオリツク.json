    "definitions": [
      {
        "index": 1,
        "gloss": "to freeze (to something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
