        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恥辱であるにも関らず、ごろごろ世間にごろついているのは心得がたいと思う。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、われわれと顔回とを同一視して、彼の真似さえしていれば、それでいいような風に云われるのは、少々心得がたい。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、貴方のような高徳有能の士が、いつまでもそうして空しく時を過ごされるのは、心得がたい事です。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけて昼には名和長年が来て心得がたい意を洩らしていたことでもある。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを師直の曲事となすは心得がたい。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちがこれを不問にしておくのさえ心得がたい。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
