          "literary": [
            {
              "text": "その後もこの研究所の財政問題などで心を煩わすことが多かったようである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の言うべきことはただ「財欲を捨てよ、衣食に心を煩わすなかれ」の一語につきる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ただ任運にして心を煩わすなかれ。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりの港街に軒をならべているどの宿屋にも、決して宿料を払わないところのこういう種類の人間が二人や三人はごろごろしているということに彼等は心を煩わす理由がなかった。",
              "citation": {
                "source": "運命について",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
