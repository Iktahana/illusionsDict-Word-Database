        "examples": {
          "standard": [
            {
              "text": "言霊信仰が強かった古代、不用意な一言が国家の運命を変えると恐れられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "言葉に魂が宿ると考える言霊信仰は、原始的な宗教観とも深く結びついている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は言霊信仰の持ち主で、絶対にネガティブな発言を口にしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これを強く感じると言霊信仰ですが、兎も角、魂の這入つた言葉と言ふものがあるのです。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此信仰が展開して、言霊信仰が現れて来ることになる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
