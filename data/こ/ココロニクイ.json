        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "菱形の脚の間に見えてゐる風景、女の姿をかくしてしまふ砂埃、心憎いことである。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然というものは心憎い姿を持っている」　清逸はどんどん流れてゆく河の水を見つめながらこんなことを考えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房コンスタンチェが決闘の前夜、冷たいピストルを抱いて寝て、さてその翌朝、いよいよ前代未聞の女の決闘が開始されるのでありますが、それについて原作者 EULENBERG が、れいの心憎いまでの怜悧無情の心で次のように述べてあります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ近頃｜憂ひが添つて却つてあでやかな妹娘の富士額ひが宗右衛門には心憎いほど悲しく眺められたのであつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まどき」の老熟には及ばなかったが、折々心憎い事をいうので読者の注意を牽いた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "身共を横紙破りに致したは心憎いことを申す奴よのう。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "およろしかったら、わちきに酌なとさせておくんなまし……」「わはは、そうか、そうか、団十郎め、心憎い趣向をやりおった。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それにつけても――」　心憎いは今の二人です。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏場の酢だこは身の毒だとさ」　柳の葉かげをくぐって遠のいていく越後上布のうしろ姿が、心憎い涼しさでした……。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分とおなじように今夜の月に浮かれて出て、夜露にぬれながら吹き楽しむ者があるのか、さりとは心憎いことであると、喜兵衛はぬき足をして芒叢のほとりに忍びよると、そこには破筵を張った低い小屋がある。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして母が今迄周子に執つた態度を回想して、あれぢや周子が口惜しがるのも無理はないと思つたり、また母から見たら、さぞさぞ周子までが心憎いことだらう、何と浅はかな母親よ――などゝ思つて反つて母に同情を寄せたりした。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといふ精鋭な理論と、その理論の心憎いまでの實踐との融合であらう！",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという精鋭な理論と、その理論の心憎いまでの実践との融合であろう！",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉泉と緑青７・27（夕）　ある画家の使つてゐる紅の色が、心憎いまで立派なので、仲間は吸ひつけられたやうにその画の前に立つた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女流文学者はそれを心憎い事に思つた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "心憎いほどの空薫きをさせたり、姫君の座をつくろったりする源氏は、親でなく、よこしまな恋を持つ男であって、しかも玉鬘の心にとっては同情される点のある人であった。",
              "citation": {
                "source": "源氏物語",
                "author": "蛍",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれが第一の物とも決められない中にも斎院のお作りになった黒方香は心憎い静かな趣がすぐれていた。",
              "citation": {
                "source": "源氏物語",
                "author": "梅が枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に又杯盤狼藉の間に、従容迫らない態度などは何とはなしに心憎いものがある。",
              "citation": {
                "source": "久米正雄",
                "author": "――傚久米正雄文体――",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏が六條のほとりの、夕顏の宿に寢て、はしぢかにきこえてくる、物賣りの聲や、町人の話聲や、夜明けに隣家の下僕が嚔をするのや、唐臼の音がとどろいてくるのや、螽※が枕上ちかく飛んでくるのを見るあたりの、あの心持や、その書きかたが心憎いほどにまざまざと浮びあがつてくるのだつた。",
              "citation": {
                "source": "夏の夜",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "心憎いばかりうまい。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心憎いまでに落ちつきはらったその男振りにすっかり私の魂はつられてしまいました。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心憎いまで落ちつきはらったその男振りにすっかり私の魂はつられてしまいました。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "洵に大家の間吟として相応しい心憎い歌といふべきであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、藪木の花の※のする春の月夜に包まれながら、だんだんこちらへやって来る笛の声に耳を傾けるのは、彼にとっても何となく、心憎い気のするものであった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の大学生が髷を包んだリボンと同じ色の長い薄手の外套を着て、瀟洒とした所に素直な気取を見せたのは一寸心憎い様に思はれる。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかれと、かなしみと、ものおもひ、官能の欲…………こころにくいほど落ちついてしんみりと刺す盲人の手。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
