        "examples": {
          "standard": [
            {
              "text": "犯罪を犯した若者が、社会復帰を目指して更生施設に入所した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "更生施設では、職業訓練やカウンセリングを通じて、自立を支援している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は更生施設での経験を経て、新たな人生を歩み始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
