        "examples": {
          "standard": [
            {
              "text": "報われぬ想いに絶望し、かつての文学作品のヒロインのように恋死にしたいと嘆いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「恋死にするほど好きだ」と大袈裟に語る彼に、彼女は少し困ったような笑顔を見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "愛する人を失った悲しみのあまり食事が喉を通らず、衰弱して恋死に同然の最期を迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「怨めしきは判官殿、わたしを恋死にさせながら、あなた様にはノンキらしく、ほかに増花の女をつくり……口惜しい――ッ」　と幽霊女は云ったかと思うと、ピシャリ！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
