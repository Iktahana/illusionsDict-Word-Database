        "examples": {
          "standard": [
            {
              "text": "電気やガス、水道といった公益事業は、私たちの生活に不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地域住民の生活を支えるため、市は公益事業の安定供給に力を入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境保護と公益事業の発展を両立させるのが、現代社会の課題だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はその私財をもって方々に劇場や音楽堂を建てたり、競技場や競走路をつくったり水道や温浴場をこさえたり、ギリシャ各地の滅びた都市を復旧再興させたり、実にさまざまの驚くべき大規模な公益事業をしているが、もってその富のいかに巨大であったかが察せられる。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
