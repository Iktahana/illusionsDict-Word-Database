        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "中心市街地の地価高騰に伴い郊外化が進み、都市の周囲にベッドタウンが形成された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "郊外化によってドーナツ化現象が起き、夜間の都心部は閑散とするようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若年層の郊外化を食い止めるため、自治体は都心での子育て支援を強化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのかっこうがいかにもおかしかったので、奥様がクスクス笑いだした。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
