        "examples": {
          "standard": [
            {
              "text": "登山道の途中に広がる高層湿原では、都会では見ることのできない貴重な高山植物が咲き誇っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "尾瀬のような高層湿原は、長い年月をかけて蓄積されたミズゴケによって形成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、ここが高層湿原か。空気も澄んでいて、まるで別世界にいるみたいだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "長尾氏が高層湿原地といつた意味も、八島ヶ池と鎌ヶ池との水溜りをもつたこの一帯の沼地を見て成程と頷ける。",
              "citation": {
                "source": "霧ヶ峰から鷲ヶ峰へ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            }
          ]
        }
