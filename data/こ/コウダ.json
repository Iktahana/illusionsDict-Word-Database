[
  {
    "uuid": "9d9b0dcf-1066-514e-8e2d-3c25f9bc1899",
    "entry": "好打",
    "reading": {
      "primary": "こうだ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
