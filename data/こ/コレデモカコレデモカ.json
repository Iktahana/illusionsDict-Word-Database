    "definitions": [
      {
        "index": 1,
        "gloss": "as if it weren't already enough",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
