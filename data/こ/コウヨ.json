    "definitions": [
      {
        "index": 1,
        "gloss": "time or energy to spare",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
