    "definitions": [
      {
        "index": 1,
        "gloss": "to freeze (of one's body)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冬空に凍える壁、洋燈、寂しい人生。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は、もう泣き出しそうになって、日の眼を見ないから、手が凍える。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾たびとなく足をすくわれ、のめり、手を突きながらも、温度は手が凍えるまで下らなかったので、金剛杖や糸立を強くつかんで、大宮口の五合目へ、ほうほうの態でたどりつき、たき火でぬれた上衣を、かわかすのに暇取った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗ばんだ体は、急に凍えるように冷たさを感じ始めた。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "衰えた身体を九十度の暑さに持て余したのはつい数日前の事のように思われたのに、もう血液の不充分な手足の末端は、障子や火鉢くらいで防ぎ切れない寒さに凍えるような冬が来た。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かと云えば、風のない国の家屋は大抵少しの風にも吹き飛ばされるように出来ているであろうし、冬の用意のない国の人は、雪が降れば凍えるに相違ないからである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧十一月の末のことだから、ときどき凍えるような西北の風が来て、あたりを掃いた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九二三ヽ八ヽ一ヽ）津軽海峡夏の稀薄から却って玉髄の雲が凍える亜鉛張りの浪は白光の水平線から続き新らしく潮で洗ったチークの甲板の上をみんなはぞろぞろ行ったり来たりする。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "況て飛騨山中の冬の夜は、凍えるばかりに寒かった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたつき前の、あの日、忘れもせぬ、朝は凍えるように寒かったが、ひる少しまえから陽がさして、ぽかぽか暖くなって先王は、お庭に、お出ましなさったが、その時だ、その時。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上、書いたことで、私は、まだ少年の域を脱せず、『高所の空気、強い空気』である、あなたに、手紙を書いたり、逢ったりすることに依りて、『凍える危険』を感ずる者である。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ木をそよがせる風もないのに木はわななく、霧の群島を取り巻く凍える海のように！",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころは五月であるから凍えることもなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧の冷たい水にかゝつたら凍えるやうになることかと思つたのにさうではなくてほか／＼と温かい。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、おれたちは、凍えるような風と、メスのような浪と、雪のように冷たい資本家や、氷のように冷酷な船長の下で、労働をしているんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜帰れば途中で凍えるわい！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちゃ帰りに凍えるわい！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりきょうと同じ所に立って、凍える手に鉛筆を運ぶ事もできず、黙ったまま立って見ていたのだったが、その時の山は地面から静々と盛り上がって、雪雲に閉ざされた空を確かとつかんでいるように見えた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴の音が、空氣でもそのまゝ凍えるやうな寒い空に、朗かに、しかしそれだけブルツとするほど寒さうにひゞきわたつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まんのんが」を持つ手は時々感覚を失はんとするまでに凍える。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さに凍える手にかの風呂敷包みをしっかり抱えながら、忠三郎は路のまん中らしいところを歩いてくると、片側に薄く明るい灯のかげが洩れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬籠りする高瀬は火鉢にかじりつき、お島は炬燵へ行って、そこで凍える子供の手足を暖めさせた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は冬、三尺も四尺も雪が積って、まだ踏みかためられた道も何にもないところを、凍えるようになって通った。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神楽の太鼓や疳高くピイピイ鳴る風船の笛、或いは爆竹の音、アセチレン瓦斯、おでん屋の匂いなんかの中に、凍えるような夜をふかすのだった。",
              "citation": {
                "source": "雨の回想",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の雷雨のために、湿気が吹き払われたせいか、山峡の宵深くは、真夏とも思われぬ冷気に凍えるのを感じた。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妨げすれば一討ちと、丁と受けたる傘の骨を砕きし互ひの手練、雪は尚しも降りかゝり、凍える手先、傘も抜身も倶に取落し、一度につかむ髻髪、髦解けて乱れ髪、乱心か、白妙の雪を蹴立てゝ挑みしが、拾ひ上げた傘の柄に、羽曳野があばらを一当て。",
              "citation": {
                "source": "玉手御前の恋",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち四辺は瞑々たる白色の中に沈み、いまにも天外に吹き飛ばされようと思うばかりに、その風のすさまじさ劇しさ、コン吉は凍える指に力を集め、必死と岩にしがみつき、「オーイ、オーイ」と呼びかけると、はるか上の方からは途切れ途切れにガイヤアルの血声。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひしひしと迫つてくる夜寒さに、私はこごえるやうな足先の痛みを意識した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしらはスッパ抜いたぞわたしらは起ち上がる起ち上がり奴らを×しかえすしぼりかえすわたしらは　心をあわせ打って一丸となり奴らめがけてやり抜いて見せるぞひもじい腹かすむ目こごえる寒さその中でわたしの闘志はたぎる",
              "citation": {
                "source": "飢餓の中から",
                "author": "中野鈴子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パトラッシュが晩に横になったとき、本当にひどくお腹が空いていたこともしばしばありましたし、夏の昼の暑い中でも冬の明け方のこごえるような寒さの中でも、パトラッシュは働かなければなりませんでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
