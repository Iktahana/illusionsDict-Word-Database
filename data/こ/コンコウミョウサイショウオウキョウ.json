        "examples": {
          "standard": [
            {
              "text": "聖武天皇は、国ごとに金光明最勝王経を写経させたと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "金光明最勝王経は、仏教美術の主題としても多くの作品に影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は金光明最勝王経の研究に長年を捧げた学者だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さて『金光明最勝王経』と『妙法蓮華経』の名に因って光勝、法蓮てふ二僧を拵えたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば宜しく天下の諸国をして各々七重塔一区を敬ひ造り、並に金光明最勝王経・妙法蓮華経各十部を写さしむべし。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朕又別に金字もて金光明最勝王経を擬ひ写して塔毎に各一部を置か令む。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
