[
  {
    "uuid": "c8bff179-8790-5854-9a3b-a99d5736862e",
    "entry": "懇請",
    "reading": {
      "primary": "こんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
