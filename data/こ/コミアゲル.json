[
  {
    "uuid": "30e605aa-39f3-5e29-b292-1c7b094c6c86",
    "entry": "こみ上げる",
    "reading": {
      "primary": "こみあげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-自動詞"
      ],
