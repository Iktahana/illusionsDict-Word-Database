      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to well up (of tears, anger, joy, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鼈四郎はむっとしてお絹の方を見たが、こみ上げるものを飲み込んでしまったらしい。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子に対する不憫と困惑が加奈子の胸に一時にこみ上げる。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "隈と云へば未決監では面白かつたな、とクスクス皮肉な笑が咽喉のぐりぐりにこみ上げる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒ることを俗に腹立つと云い、こみ上げる事であるが、憤は胸の中の突っ張りがはじけて、噴水が地を破って噴き出すように、噴火が岩を巻き上げて噴き迸るように、止めても止まらない勢い以って盛り上がることをいう。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲だけが妙にもやもやして心のほうだけが澄みきった水のようにはっきりしたその頭の中には、貞世のとも、幼い時の自分のとも区別のつかないはかなさ悲しさがこみ上げるようにわいていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私はこみ上げるむず痒さを押しこらえた。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一度に悲しみがこみ上げる。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのときの順助や自分を思い出すと、何ともいえず懐しくまた滑稽で思わず笑えるのだけれども、笑いのなかには喉にこみ上げるような思いもこもっている。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に誰か僕の後ろで「御臨終御臨終」と言った時には一層切なさのこみ上げるのを感じた。",
              "citation": {
                "source": "点鬼簿",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬のみならず俺の喉もとにも嘶きに似たものがこみ上げるのを感じた。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は彼の一生を思ひ、涙や冷笑のこみ上げるのを感じた。",
              "citation": {
                "source": "或阿呆の一生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし老女は今更のように、こみ上げる涙を堪えるように、消え入りそうな返事をしました。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が、外から家へ入って来る時、どれ程こみ上げる程のなつかしさを持っていたか知れない。",
              "citation": {
                "source": "お母さんは僕達の太陽",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "と心中に叫んだ弥生は、きっと歯を噛んで駈け戻ったが、こみ上げる涙は自分の居間へ帰るまで保たなかった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前の映像が美貌をひけらかし、しかも実在しないのには激しい怒りがこみ上げる。",
              "citation": {
                "source": "理想",
                "author": "THE IDEAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い辻番の小屋の中、駄菓子と荒物と草鞋の中に、縛られたまゝ頑くなにうなだれてゐる伊三郎の樣子を見ると、お絹は先刻から、こみ上げる激情に唯もうおろ／＼するばかりでしたが、錢形平次の問ひを受けると、泣き濡れた美しい顏を擧げて可愛らしく泣きじやくりしながら、ヂツと自分の考へを整理するのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "小判の瓶",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しさがこみ上げるてえのはあの事だね」　ガラッ八の言葉を空耳に聞いて、平次は、「いよいよこの強盗は桔梗屋のお藤と引っかかりのある者に決った。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "赤い痣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だい、三つ股の兄哥」「それじゃ、徳松の野郎に、言い逃れの口上を教え込むようなものじゃないか」　源吉はこみ上げる激動を押えている様子です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "玉の輿の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "籐を張った冷たく堅い座席の上で、眼を瞑り、伸子は動揺につれてこみ上げる嘔気をやっと堪えた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとのことで、囚人の口の中にフェルトの栓を押し込んだのに、囚人はこみ上げる吐き気に我慢できなくなって、目を閉じたまま、栓から外したのだった。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　旅人はこみ上げる笑いを我慢した。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこみ上げるヒステリイを抑へつけ、昂然と頭を上げ、そして腰掛の上にしつかりと立つてゐた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "喉元にこみ上げるようなものがあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に彼女は自分でも一緒に歌おうとしたが、そのつどこみ上げる咳に妨げられ、第二句あたりでとぎれてしまった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーアがこみ上げる興奮をねじ伏せたのは狂乱寸前に追い込まれ、絶望になりながら、群がる悪魔の蛇と戦ったからだ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "こみ上げる感情は己の愚行に対する怒りと腹立ちであった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だい、三つ股の兄哥」「それぢや、徳松の野郎に、言ひ逃れの口上を教へ込むやうなものぢやないか」　源吉はこみ上げる激動を押へて居る樣子です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "玉の輿の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はこみ上げるように咽喉元を顫わせたまま、物を言うことも出来ず、唇を噛みしめているばかりであった。",
              "citation": {
                "source": "三等郵便局",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯を食いしばり、こみ上げる恥辱をこらえた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしテンプルがやめろと目配せしたので、こみ上げる怒りをぐっと抑えた。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
