[
  {
    "uuid": "cdfa1989-14bb-5305-923c-493e2cd60cb5",
    "entry": "国利",
    "reading": {
      "primary": "こくり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
