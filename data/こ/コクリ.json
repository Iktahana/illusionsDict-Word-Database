    },
    "definitions": [
      {
        "index": 1,
        "gloss": "national interests",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "故にもし諸君が意志するならば、芸術は売文のためであってもよく、ミツワ石鹸の広告のためであってもよく、或は共産主義の宣伝のためでもよく、社会風規の匡正や国利民福のためでも好い。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば仏人は国利の為に戦ふよりも、寧ろ戦ひの為に戦ふ。",
              "citation": {
                "source": "想断々（２）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟ふに、凡そ国利を護り、国権を保つには、国際公法などは実は糸瓜の皮、要は兵力よ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にあっても、この貧窮のさなかだから、先ず何を措いても国利民福のことを考えるべきではないか……。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして我ら「日本民族」は、相協同一致して、皇室を宗家と仰ぎ奉り、その家長と坐す天皇を元首と奉戴して、終始国利民福の増進を希望するの外、また他意あることを知らぬのである。",
              "citation": {
                "source": "「日本民族」とは何ぞや",
                "author": "日本民族の概念を論ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十六日（日）　東條の参謀は津雲（国利・代議士）だとのこと。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "又山村清助、画名国利なる人の「木版絵本」（明治十四年一月二十八日御届とある）には、珍らしく、本所側から浜町大川端一帯を見渡した景色が描いてあつて、川岸の頃合ひの所に大きな柳が見える。",
              "citation": {
                "source": "柳橋考",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "爰に坂東に名を得たる大河一つあり、此河の水上は上野国利根の庄藤原といふ所より落ちて水上遠し、末に下りて在五中将の隅田川とぞ名付けたる。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中ニ馬峠トテ上野国利根郡湯檜曾村ニ出ル路アリ。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅沼は上野国利根郡片品村大字東小川村の地内にある山湖にして、湖面は海抜千七百十九米の高さを有す。",
              "citation": {
                "source": "古図の信じ得可き程度",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根郡荒山噴火之儀ニ付群馬県ヨリ大蔵省ヘ御届之写当県下上野国利根郡東小川村地内荒山西面山腹ヨリ硫黄気燃立候趣、別紙之通図面並焼場石共相添、届出候ニ付、直ニ官員差遣シ、見分為致候処、右届之通相違無之ニ付、此段御届仕候也。",
              "citation": {
                "source": "望岳都東京",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだなかなか国利民福を増進するの機関として、遺憾なき活動を見るまでに至らぬは、知れ切つた事なれど。",
              "citation": {
                "source": "移民学園",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "政党そのものはかかる国利民福の発展を目的として存在しておるものである。",
              "citation": {
                "source": "〔憲政本党〕総理退任の辞",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、人選を決する事は非常に大切で、一たびその人選を誤れば、却って国利民福を傷つけ、国民を敵とするに至るのである。",
              "citation": {
                "source": "勢力の中心を議会に移すべし",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "この象徴には、どうも理窟なしに、かつての極端な指導者の軍国利用や虚構の翳がさす。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者もそこで一風呂あびて室に帰ってつめたいお茶をこくりとのみそれから椽側へ出てあまり栄えもせぬおがせが滝を拝見に出ると、これはまた、さっきの大天狗殿がやはり椅子にすはってシガーをくゆらして滝を見てござったのである。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こくりこくりしかけていた少年兵は、ふと頭をゴツンと打って眼をあけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして心配そうな息をこくりとのむ音が近くにした。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていっぱいに気兼ねや恥で緊張した老人が悲しくこくりと息を呑む音がまたした。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分遠い道のりだったので、私は歩きながら、何度も何度も、こくりと居眠りしました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は無言で仕事をしていたが、母の手は折り折りやんで、その度ごとにこくりこくりと居眠りをしている。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "入つて見よう……今前途を聞いたのに、道草をするは、と氣がさして、燒芋屋の前を振返ると、私に教へた時、見返つた、其のまゝに、外を向いて、こくり／＼と然も暖とさうな懷手の居睡りする。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども小一のははげしいので……お客様の肩へつかまりますと、――すぐに、そのこくりこくり。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯人の頭も、顔も、黒く塗りて、肩より胸、背、下腹のあたりまで、墨もていやが上に濃く塗りこくり、赤褌襠着けたる臀、脛、足、踵、これをば朱を以て真赤に色染めたるおなじ扮装の壮佼たち、幾百人か。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬被のずんぐり者は、腕を組んで立ったなり、こくりこくりと居眠る……　饂飩屋が、ぼやんとした顔を上げた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母は椅子に腰かけて、こくりこくりと眠りはじめ、術者のおごそかな問いに、無心に答えるのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々こくりとうなづくばかりで、あとは唖のやうに黙つてゐたからである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯笛の女の子は、手毬を見てのどをこくりと鳴らした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は滑らかな頸の奥で、喉頭をこくりと動かした。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車屋の戸口にしゃがんで、自転車のパンクしたところがつくろわれている工作をみていると、正九郎ののどはこくりと鳴るのだった。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
