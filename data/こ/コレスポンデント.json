          "standard": [
            {
              "text": "海外特派員であるコレスポンデントは、現地の情勢を詳しく伝えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その雑誌では、各国のコレスポンデントが執筆した記事が連載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、大学卒業後、ジャーナリストとしてコレスポンデントの道を歩み始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一八九〇年八月二十八日の『ユニヴァシチー・コレスポンデント』に仏人カルメットの蛇毒試験の報告出で、その中に家猪は蛇咬の毒を感ぜぬが、その血を人間に注射しても蛇毒予防の効なしとあったから見れば、家猪の根原種たる野猪は無論毒蛇に平左衛門であろう。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
