[
  {
    "uuid": "c319a3a5-b903-5ed0-b06a-220c4009bcbd",
    "entry": "拘り",
    "reading": {
      "primary": "こだわり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "obsession",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なんの拘りもしらないようなその老人に対する好意が頬に刻まれたまま、峻はまた先ほどの静かな展望のなかへ吸い込まれていった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はただ君の名が、それに拘り合いにならなければいいと思うのだが。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな小っちゃな煙突が、あなたとどんな拘りがあるでしょう。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "……自分はお納戸向きのお使番馬廻りの家柄……要らざる事に拘り合うまい……。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は、凡てに拘りなく、鬱屈なく、臆測なく、その日その日の仕事を綺麗に所置して、夕べとなればダンス・ホールへ、または酒場へ、または街の散歩に出でゝ、未来への不安を知らず、過去への悔なく、一勢に健やかなるエピキユリアンであります。",
              "citation": {
                "source": "附「歌へる日まで」",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ精に努めて深を努めなければ拘り滞る懼れがある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」『史記（廉頗藺相如伝）』ような愚かなことをするより、形式に拘る恐れはあるけれども、それは拘り過ぎることが宜しくないので、形式即ち非とするものでは無い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折角の所長の警報が痕形も無くなつては、私達の信用に拘りますから、せめて雨でも降らせたいと思つて。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方からは、その単調さと異様な鼓膜の震動とで神経も空想も麻痺するモウタアの響がプウ……と、飽きもせず、世間の不景気に拘りもせず一日鳴った。",
              "citation": {
                "source": "この夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単な言葉であったが、私はその時今までのごたごたした心の拘りをすらりと抜け、自分がまともな心持で久米さんに物を云い、その顔を見たのを感じた。",
              "citation": {
                "source": "田端の坂",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーラーブは、巧にシャラフシャーが持ち出した新しい話題に全心を奪われ、数分前の拘りを、さらりと忘れてしまうのであった。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は本当に拘りない心になって千鶴子を迎えることが出来るだろうか。",
              "citation": {
                "source": "沈丁花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、衝動的に、晴々と拘りない地平線を飽くほど眺めたい渇望を感じた。",
              "citation": {
                "source": "餌",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌よみは文法だの語格だの詠み方だのと、から威張に威張り、ひた拘りに拘りて、無趣味なる陳腐なる歌のみを作りしにあらずや。",
              "citation": {
                "source": "人々に答ふ",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活のよろこびは天真爛漫で、そのよろこびを合理的に現実的に自分たちで刻々につくっているものの寛闊な拘りなさもつよく感じられるのであった。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、後には、其々伝達者の地位・階級に拘りなく、おなじ言語効果が現ずることを器械的に考へるやうになつた。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日が『文芸春秋』、今日『文芸日本』、昨日『不同調』、ゴシップ雑誌が文学の本道に何の拘りありや。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファルスの作者といふものは、作中の人物を一列一体の例外無しに散々な目に会はすのが大好きで、自惚れる奴自惚れない奴に拘りなく、一人として偉いが偉いで、智者が智者で、終る奴はゐないのである。",
              "citation": {
                "source": "FARCE に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はなんとなく拘りのある足どりをして道の両側に立ち並ぶ家々の様子に、深い警戒を怠らないように見えた。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やつと、視線が合ひ、それでもこつちの感情に拘りなく、怪訝なといふ風を露骨に示し、もう一度ノートとレンズの数を数へ、「ぢや、たしかにお預りします。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえ、これは決してあなたに拘りのあることじゃアないんで。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたへの私の愛情の純粋さとなんの拘りもないことなの。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その足の捌きや、身の振り方はやや日本化しているが、それは彼らが自然に日本人に同化するうちに巧まずして多少の影響をうけただけのことで、その本来の骨法はまったく日本の現実に何の拘りもないことが分る。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "左衞門尉「――長崎以來の心盡しを不被顧、斯迄申談候儀をも、更に聞承不申候ては、拙者政府え對し申譯も無之、實に生死に拘り候次第に陷入候。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」　川路が「生死に拘り候」と云つたときの顏色はもはや切腹を覺悟してゐたにちがひない。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし純粋に前者であるならば、我々は「つひに一夜さも家の下で寝たことのない」、そうして産後幾日も経ずして「雪の蒲団に添乳する」この旅の女に、拘りなく同感することができるであろう。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下賤の者に楊弓で眼を射られたと知れては、御身分に拘りませう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然科学の思想化傾向や科学論的検討への参加は、知ると知らぬとに拘りなく、その任務が課せられた結果である。",
              "citation": {
                "source": "最近日本の科学論",
                "author": "――緒論の部―一般的特色について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のクリスチヤンとしての道心にも拘りなく、彼女が近づいて話しかけると、そして華やかに勵ますやうに、優しさうにさへ、彼の顏に微笑んで見せると、彼の手は顫へ、彼の瞳は燃えた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "人にこだわりながら花見をして帰ると頭が疲れてがっかりしたものである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
