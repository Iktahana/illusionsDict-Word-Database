[
  {
    "uuid": "7553dbf2-c1bc-5c7a-aee7-dab2defc0517",
    "entry": "硬水",
    "reading": {
      "primary": "こうすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hard water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "井戸の水で炊いたのと水道の水で炊いたのとは硬水と軟水ですから味も違いますし夏なんぞは水道の方が長く持ちます。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "マグネシアを調製するときに軟水ではなく硬水を使うと普通それによる石灰が含まれる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして硬水と軟水の違いを全ての人はよく知っている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "硬水で土地の物質を含んでいるような水は人体の重要な機能のあるものに疑いの無い影響を持っている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビールを醸造する過程において軟水は硬水よりも好ましい。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "染色業者の技術において硬水は幾つかの染色溶液の作用を妨害するだけでなく、繊細な色のあるものの自然な色合いを変えてしまう。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるときに硬水はそれに充満している土地の物質および塩類を材料の繊細な線維に沈殿させ、このようにして染料の柔らかさおよび華やかさを邪魔する。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "硬水中で線維は組織の傷害が起きるまで何月も浸すとしても木質の物質が分解して線維が適当に分離しない。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "良い純粋な水は硬水と呼ばれるものよりも動物の線維および野菜の物質を容易に柔らかくする。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての料理人は乾いた熟したエンドウ豆やでんぷん質の種は硬水中で煮ても柔らかくできないことを知っている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑色の野菜の物質は軟水で煮ると硬水で煮るより柔らかい。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし硬水を使うと色が良くなる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "硬水と軟水の影響は次に述べる　[実験]　茶葉の２つの部分を、全く同じ過程で似た別の容器に入れ、一方には硬水を入れ他方には軟水を入れて、高温でも低温でも良いが茶葉をふやかすと、軟水に漬けた方はずっと味が強いが、硬水に漬けたのに比べて色が薄い。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物のジェリー溶液を加えると、軟水は同じ条件における硬水よりも茶葉からもっと多くの褐色物質およびもっと多くの没食子酸を抽出することを直ちに示す。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟水を飲むのに慣れた多くの動物は硬水を拒否する。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハトは軟水に慣れさせると硬水を拒否する。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に部分的ではあるが重炭酸カリ溶液を滴下することによって硬水を良質にすることができる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "また硬度が石灰の重炭酸塩＝炭酸水素塩の存在だけによるとき（＊一時硬水）は、単に沸騰によって非常に良くすることができる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、含まれている成分の本質および程度によって、ある泉の水は硬水であり、あるものは軟水であり、あるものは甘く、他のものは塩辛い。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦は軟水を硬水にする。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに水が硬水ならば、湯ざましは軟水になっているから、ということを云っていた人がありました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
