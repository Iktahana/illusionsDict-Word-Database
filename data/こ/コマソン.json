    "definitions": [
      {
        "index": 1,
        "gloss": "loss of material",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "中盤のうっかりミスで角をタダで取られ、大きな駒損をしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この展開なら、多少の駒損をしても攻めを継続したほうが勝機がある」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "相手の猛攻を凌ぐために、あえて金銀を捨てる駒損を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "序番自分よく、中盤惡手から駒損となり玉再再ならず窮地に陷つて、梅原さん意氣大に上つてゐたが、自分屈せず腹を据ゑて長考幾度、やがて百二三十手頃の終番に近く、隙を見て奮然逆襲、敵の應酬の失を捉へて過に勝名乘を擧げてしまつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
