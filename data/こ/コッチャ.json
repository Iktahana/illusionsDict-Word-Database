        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誰が来たって、どいつが来たって、坊を渡すこっちゃねえからな」　彼は、子供を確り抱きしめた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一年や二年、シベリアに長くいようがいまいが、長い一生から見りゃ、同じこっちゃないか。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大したこっちゃないじゃないか！",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「洋服がなけりゃ会社イ出られんのじゃろうし……困ったこっちゃ！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前等、えい所へ行くんじゃ云うが、結構なこっちゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……勿体ないこっちゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「六人じゃというこっちゃ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、かまうこっちゃねえだ」　呉清輝は、実際、かげにかくれてこそこそと、あぶない仕事をやるために産れてきたような男だった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何て、縁儀の悪いこっちゃ、一と晩に二人も怪我をしやがって！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それゃ、云うまでもないこっちゃが、支那人は金にさえなると思ったら、どんなありそうなことでもねつ造して持って来る奴なんだから。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなこっちゃないよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつらのゴマすりは、今日に始まったこっちゃないやないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぼ田を買うたっていらんこっちゃ！",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、大変なこっちゃ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の奴等が、どう云おうがかもうたこっちゃない。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われにも覚えがあるこっちゃろうがい！",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の知ったこっちゃない。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも衣裳の整はないのがあっちゃ、こっちの失態ですしね、えゝ、どうもこんなこっちゃ困りますぜ。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは第一貴様たちの知ったこっちゃないや、なあ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老僧　――それにも一つ、あんたはいつも戸をあけ放しで寝なさるが、あれも悪いこっちゃ。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああ、毎日ここまでやって来るのも、並みたいていのこっちゃない。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わめくも歌うも容易のこっちゃありませんよ」　「そうでしょうね。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わめくも歌うも容易のこっちゃありませんよ」「そうでしょうね。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、あんたに気があんねやろ」　と、松本は笑って、かたわらの女の肩を敲きながら、あの男のやりそうなこっちゃと、顔じゅう皺だらけだったが、眼だけ笑えなかった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――しかし、掏ってみても、あの男のこっちゃさかい、新円の五十円もよう持っとらんやろ、朝の仕事はじめに、百円にもならん仕事をしたら、けちがつく」　そう考えると、――いや、そう考える余裕がこの際残っていたことで、豹吉はわずかに自尊心が慰められた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉の傍へ寄って来ると、「兄貴、えらいこっちゃ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "強盗と同じこっちゃさかいな」　そう言った時、次郎ははっと眼を輝かせた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三郎公、えらいこっちゃ、銭がない」「えっ……？",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず刺青をするこっちゃ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
