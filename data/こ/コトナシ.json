    "definitions": [
      {
        "index": 1,
        "gloss": "uneventful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西洋から帰って銀座通りが狭く低く感じるのも同じような事で別に珍しい事でもないかもしれないが、ともかくも一つの世界に常住しているものが、一度そこをはなれてその外の世界を見る事無しに自分の世界を正当に認識する事のいかに困難であるかという事実の一例にはなると思う。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野山に生ひたるは、画にこそ見たることもあれ、まことには眼にしたる事無し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し此方では何等の不思議を見た事無し、強て心当りを探り出せば、前に記した一件のみ。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "九、起きてみつ寝てみつ胸中に恋慕の情絶える事無し。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日、己亥、晴、将軍家聊か御病悩、諸人奔走す、但し殊なる御事無し、是若し去夜御淵酔の余気か、爰に葉上僧正御加持に候するの処、此事を聞き、良薬と称して、本寺より茶一盞を召進ず、而して一巻の書を相副へ、之を献ぜしむ、茶徳を誉むる所の書なり、将軍家御感悦に及ぶと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彬驚いて曰く、全く其事無しと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さまが鎌倉においでなされたら、わたし等も斯うはあるまいものを、名聞を好まれぬ職人｜氣質とて、この伊豆の山家に隱れ栖、親につれて子供までも鄙にそだち、詮事無しに今の身の上ぢや。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "此村の名主の家のほか他所には絶えて在る事無し。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨物車の機関車を利用して本職自らバートン・モスまで行く行く調査したるも何等の変事無し。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "美津田氏は質直不文の人なれど、假名付の小説を能く讀みたり、其談話は一に記臆より出し故に、誤謬も多少有るべきと同時に、虚構潤色を加る事無しと知らる。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初築いた時下手の高石垣が幾度も崩れて成らず、領内の美女一人を抽籤で人柱に立てるに決し、オヒヂと名づくる娘が中つて生埋され、其より崩るゝ事無し。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから露西亜の俘虜は何時でも借金だらけで「霊魂」が抵当になるものなら、書入れに少しの躊躇もしないが、可憎日本では「霊魂」の相場が安過ぎるので詮事無しに自分達が本国から送つて貰ふ筈の月給を抵当に、行きつけの店から借り出すものが多かつたが、独逸人は借金どころか毎週｜定つたやうに貯金をする。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「節斎の書には鰐水の不脱眼鏡而瞑を駁して、決して此事無しといへり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜次郎の腹痛は直ぐ治ったが、折角元の健康に復したのも、二日か三日で又衰え始めて、されば、何処が不良という事無しに、唯ぶらぶらの病に均しく、腑抜けのように日を暮らしていた。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "遮莫千年の後、天下｜靡然としてブウシエの見に赴く事無しと云ふ可らず。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　娘はしやう事無しに笑顏を見せて又頭をさげた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは我が母の涙を見たる事あれども怒れる聲を聞きし事無し。",
              "citation": {
                "source": "貝殼追放",
                "author": "「その春の頃」の序",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきにも云へる如くすべてに寛容なる我が父はわが文學を好む事にも何の干渉を加ふる事なく、我が筆執りて無益にも拙き小説書く事を知れど未だ曾て予をとがめし事無し、なんぞ予をして我が愛誦の書を燒かしむるが如き愚かしき事をし給はんや。",
              "citation": {
                "source": "貝殼追放",
                "author": "「その春の頃」の序",
                "note": "青空文庫"
              }
            },
            {
              "text": "司馬温公は閨中にて語りし言も、人に對して言ふべからざる事無しと申されたり。",
              "citation": {
                "source": "遺訓",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども現象有るか若しくは作用有れば、必ず之を生じ、之を起すの源由有らざる事無し。",
              "citation": {
                "source": "尚白箚記",
                "author": "西周",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔譯〕信上下に孚す、天下甚だ處し難き事無し。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜大風襲来の兆ありしが幸にして事無し。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "為めに小虫は身辺を囲みて離るる事無し。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（言ひながら阪井の方を覗ふ様に注意してゐる）お秋　さうね、（奥へ向いて）おかみさん、今何時です、おかみさん（返事無し）おや、居ないのかしら、――（奥へ入る）客二　（阪井に）阪井さんと言ふんでしたね。",
              "citation": {
                "source": "疵だらけのお秋（四幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "へい……（返事無し。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "住居の内たると外たるとを問はず裸体にて人の前に出づる事無し。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物質の器具に至つては未だ一品も出でたる事無し。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（返事無し）……くたびれただなあ。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月六日（木曜）　映画といふ奴はこれで困る、折角待機してゐても今日は仕事無し、早くから分ってれば旅ぐらゐ出来るのに。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "早ク見タイモノデス』という焼津の手紙でも解るように、妻と同伴することなしには、どんな旅行も楽しくないほど、夫人を熱愛していたからだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
