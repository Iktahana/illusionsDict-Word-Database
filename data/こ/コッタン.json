        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また炭は溶液の中にある有機性の色素を吸収する性質がある、殊に獣炭あるいは骨炭がこれに適しているので砂糖の色を抜く事などに使われる。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つその砂糖を清浄にするには骨炭で漉せば清浄になると云うこともチャント知て居る。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くれたもんを取り返しに来たの」「あまりだますから、おこったんだろう？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなわたしから起こったんだと思うと、どうしても幸福な気持ちにはなれませんの」「永峯はいったい、ぼくのことをどう思っているんでしょうね？",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何事がおこったんです」「まあ、お聴きください。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人は当日花川戸へ行って、その噂を聞いて来たと云うんですが、噂を聞いただけでなく、何もかも承知しているんじゃあないかという疑いが起こったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり高源寺に起こったんですか」「そうですよ」と、老人はうなずいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと困ったことが起こったんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をおこったんですかい」　めんくらったのも無理はない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、またここに一つの事件が起こったんです。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何事が起こったんですか、ワーナー博士」　ホーテンスが、待ち兼ねた質問の矢を放った。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部で爆発が起こったんだからね。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なぜ内部から爆発が起こったんですかね」「知らんね。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処にその女をかこったんです」とむきだしに迫った。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士はじぶんが助かる自信があったから、あの部屋にのこったんです。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠落しを掛けた奴が、自分でそいつへ落っこったんだからね。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事は、ブルブル慄う指先で室内を指し、「殺人事件がおこったんだ。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体どうして爆発がおこったんですか」「そのことだよ」と河原警部は首をかしげて「どうも原因がわからなくて困っているのだ。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって、わしは、この穴の上から、ここへおっこったんだもの。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで、大人たちの強欲から、戦争が起こったんだ。",
              "citation": {
                "source": "太陽と星の下",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと僕のポケットから落っこったんだろう、いつか草ん中を転がり廻った時……気違いの真似をして……。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっと見つめているうちに、すこしおどろきがおさまると、欲がむらむらっと起こったんだ」「その金貨を、じぶんのものにしようとしたのかい？",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いったい、どんな不幸がおこったんですか？",
              "citation": {
                "source": "りこうもののエルゼ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから婿のことが起こったんです」とお杉は続けた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "『だって……確かにこれはあのことから……昨日のことから起こったんだもの……さあたいへんだ！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、水へはいるとたんに、いきなり発作が起こったんだね！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何が起こったんだ」　と警官がつぶやいた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泥水がひいち、水道ん栓ばひねったら、きれか水がジャーッと出て来ち、あたしゃあぎゃんなうまか水ば、飲んだことはありまっせんと」「どうしてそんな大洪水がおこったんだろう？",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
