        "examples": {
          "standard": [
            {
              "text": "新しい国王のコロネーションは、世界中から注目を集めた壮大な式典だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コロネーションの準備は数ヶ月前から始まり、街全体が祝賀ムードに包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はコロネーションの記念コインを大切にコレクションしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "コロネーションに結った黒髪は、夫人の長身にピッタリと似合っていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロネーションに結つた黒髪は、夫人の長身にピツタリと似合つてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、アメリカのウイスキー、コロネーションとか、マウンテンデュウなどという、これが又安いんだ、それをガブガブ飲み、安い洋食を、ふんだんに食ってしまう。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからパラマウント・コロネーション他もう一つのバーを歩く、加藤弘三二十一才にすっかりアホられちまった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
