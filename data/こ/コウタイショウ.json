        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "独逸音楽と南欧音楽の特色は、エピカルとリリカルとの、最も典型的な好対照である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮮人宛の立札があるのは、諏訪神社に外人向のお※札（英語の）があると好対照だ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らば此のバアトンの訳本は、欧洲の天地を遠く離れて、而も瘴煙蛮雨の中で生れたもので、恰もタイチに赴いたゴオガンの絵と好対照である。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なほ又｜次手に一言すれば、「アララギ」の父正岡子規が「明星」の子北原白秋と僕等の散文を作り上げる上に力を合せたのも好対照である。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳富｜蘆花氏の「自然と人生」は「武蔵野」と好対照を示すものであらう。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ異うのは、そんな二人のそばに坐っているのが、一方はいつも髪の毛をくしゃくしゃにさせた、肥っちょの女房であったし、もう一方はそれと好対照をしている位に痩せっぽちの、すこし藪睨みらしい女房であることだ。",
              "citation": {
                "source": "美しい村",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その書は入宋しながらやわらかい和風を特色とし、大燈と好対照をなしている。",
              "citation": {
                "source": "南浦紹明墨蹟",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイゼンハワーとスティーヴンスンとは、好対照だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
