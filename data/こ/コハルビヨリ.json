    "definitions": [
      {
        "index": 1,
        "gloss": "Indian summer (around November)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
