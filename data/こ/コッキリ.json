        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一本を飲もうとするときに一本こっきりでは、その限数が気になり伸々した気持でその一本すら分量の価打ちだけに飲み足らうことができない。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も一枚こっきりのいわゆる常上着の晴着なしであったろうが、左に右くリュウとした服装で、看板法被に篆書崩しの齊の字の付いたお抱え然たる俥を乗廻し、何処へ行っても必ず俥を待たして置いた。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も公債もあり蓄財もあり、家屋も自分の所有であって、正味十一円こっきりの身代ではなかったが、割合に気楽な官吏の生活を送ったものが多年倹約して剰した蓄財を日に日に減らして行くは、骨を削り肉を刻むに等しい堪えがたい苦痛であるのが当然で、何かにつけて愚痴の出るのも無理ではなかった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜寝る前にも、からだじゅうが真赤になるまでこすって、一枚こっきりの布団に海苔巻きになって寝る。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなしゃれた訳にいくもんですか、ふだん着だって勤め着だって一枚こっきりだわ、私なんぞ。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "通り一ぺんの客は少ないんだから、店同士でお互に競争はしていても、客に対しては一ぺんこっきりの悪らつなことはしないそうだよ。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私こっきりの生きかた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここっきりなんぞでやって見ろ。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供なんか生まないでネエ、馬鹿な子供なんか生んで心配したりするより一代こっきりの方がようござんすよ！",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一度こっきりじゃ済みませんぜ」「じゃまたあるとでも云うのかい？",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに彼等が凶暴でも、三十人こっきりであったなら、捕縛えるに苦労はしなかったろう。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キンちゃん、あれから後、いくど気絶したの」　正吉がそういって料理番のキンちゃんをからかうと、キンちゃんは顔をまっ赤にして、「あのとき一ぺんこっきりだよ。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後黒の姿はこっきり見えなくなった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと間こっきりの家に住んじゃいなさらねえ」「…………」「としたら、八さんが、今日は――ッと声をかけたとき、オヤオヤこれはとすぐ隠居が顔を出して来る奴があるかい。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがどうです、私たちは日に三百五十どころか、ただの十ルーブリこっきりを出して、やれ救恤だとか、救済だとか、それであなたの奥さんはじめ私たちがみんなじつにどうも素晴らしい人間だとか、博愛万歳だとか言っています。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一回こっきりだ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間一度こっきりしか生きないんだから、ちっとはホントに、つまり、なによ――いつ死ぬとなっても、それほどアワテないで死にきれるような――もっとチャンとした暮らしをしないじゃ――花岡　ヒッヒ！",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、得意の投げ銭を飛ばすにしても、あと煙草入に小粒が二つこっきりでは、平次の戦闘力は半分になります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お局お六",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うまでもねえが、今日は元日だよ、八、勘定こっきりなんてみっともねえことをするな」「心得てますよ、親分。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自慢じゃねえが、昨夜たった一枚こっきりの袷は殺したが、人なんか殺した覚えはねえ、岡っ引｜奴どこへ眼玉を付けてやがる、周助の切支丹野郎が死んだのは仏様の罰だ、ざまア見やがれ――って」　ガラッ八の八五郎にとっては、銅六は自分の代弁者のような心持だったのでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "南蛮仏",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも俺がこうして生きているのは一遍こっきりなんだからね。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "演奏会の一回こっきりの演奏と違って、これは直ちに比較されるものである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな紙のじゃあ、一年こっきりでしょう」　おたがいの品物をなげくようにいうと、そうだというようにおじいさんは首をふり、「ヤミなら、なんぼでもあるといな」　そして、はっはっと笑った。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
