        "examples": {
          "standard": [
            {
              "text": "息子は来年から一年間、アメリカへ交換学生として留学することが決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学には世界各国から多くの交換学生が来ており、国際色豊かな雰囲気です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「交換学生として日本に来て、もう半年になるんだね。日本語も上手になったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "交換学生としてイタリーへ一人の日本の若い女性が派遣される誇りは、新潟から売られて東京へ出て来る三十人の少女の心が理解するには余り縁の遠い文化の一ポーズなのである。",
              "citation": {
                "source": "暮の街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子が交換学生として行っているイタリーにもゆき、ギリシアもまわって来て、かえりはアメリカを通る由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間あるところで、フランス文学専門で交換学生として行く女のひとに会いました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "従弟で、フランスへ交換学生になって行っていたのはグルノーブル（スタンダールの生れた町）にいてシベリアを経て帰りました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
