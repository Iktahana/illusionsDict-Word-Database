    "definitions": [
      {
        "index": 1,
        "gloss": "cowrie (esp. the chocolate cowrie, Mauritia mauritiana)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
