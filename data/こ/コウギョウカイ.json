[
  {
    "uuid": "fe29c67b-b94d-5d6b-9955-657bbac85475",
    "entry": "工業界",
    "reading": {
      "primary": "こうぎょうかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
