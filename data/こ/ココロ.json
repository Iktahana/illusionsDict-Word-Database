    "definitions": [
      {
        "index": 1,
        "gloss": "mind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "心は腐れ、器物は穢れぬ。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――心は寧ろ笛にまで、堕落すべきなり。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてしなき、そが心母にも、……もとより友にも明さざりき。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶も、去るにあらずや……湧き起る歓喜のためには　人の情けも、小さきものとみゆるにあらずやああ、神様、これがすべてでございます、　尽すなく尽さるるなく、心のままにうたへる心こそ　これがすべてでございます！",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神よ、私は人の世の事象がいかに微細に織られるかを心理的にも知つてをります。",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等の頭は言葉でガラガラになり、奴等の心は根も葉もないのだ。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "野望の上に造花は咲いて迷つた人心は造花に凭る。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹌踉めくままに静もりを保ち、聊か儀文めいた心地をもつてわれはわが怠惰を諫める、寒月の下をゆきながら、陽気で坦々として、しかも己を売らないことをと、わが魂の願ふことであつた！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経的、或は潔癖精神的に幻想のげにも脆い臍の緒を掴へることによつて、心境の一断想を歌ふばかりである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々と詩論は毎月の雑誌にも現れてをりますが、此の雑誌に訳載中のアランの論文と、それからこれは直ちに詩論と呼べる限りのものではありませんが、フィードレルの芸術論、まづまづ此の二つが此の数年来に読みました詩論の中で心に残つたものであります。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは、殆んど心に残つてをりません。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に反して、月末の支払ひだけ片付くとなれば安心の出来る人達は元気でゐる。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに猶、諸君も嫌ひではない冗舌は、此処に十分に按配されてをり、直き直きに抽象語を以てしなければ、かの「意味がない」と云つて嘯く、平盤な心情の人達のためには、十分哲学的学術的な言葉も此処には見出されるのである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の詩を辿り乍ら、この稿を書いてゐる今、色々と心に浮ぶことを、何の反省をも加へずに、唯々書誌してみたいと思ふ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "草野心平詩集『母岩』中原中也　草野心平君の第三詩集『母岩』が出た。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の感覚を通して這入つて来るものの中に安心立命してゐるのである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふつもりで付けたのかまだ訊ねてみないが、僕が勝手に想像する所では、無口でそつとしておいて貰ひたい男が、誰でもが多かれ少なかれ感じてはゐても余りに底深い、流れだとして殆んど全く触れないで過ぎる態の非情を、人目にも立たず浚渫してゐるといつた風の心得であらうと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすやみ萩原朔太郎うすやみに光れる皿あり皿の底に蟲かくれ居て啜り鳴く晝はさびしく居間にひそみて鉛筆の心をけづるに疲れ夜は酒場の椅子にもたれて想ひにひたせる我が身の上こそ悲しけれ",
              "citation": {
                "source": "うすやみ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにふるへ、かくれつつうかがひのぞく榎あり、いのりつつ、一心に幹をけづりしに、樹樹はつめたく去り行けり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分だけを恃むといふことは、如何にも立派な心懸けだが、全的な実現には到れぬものだと思ふ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "分りきつた芸術良心論だと思ふ人もあらうが、それならそれでもいいのだ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心があるだけで、既に結構なことではないか。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その良心さへ十分ではない所からして、十分に納得出来る詩が得難いのではあるまいか。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨それでは、その良心は如何にしたら十分になるであらうかと考へる時、私には他力の信仰といふことが思はれるのだ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて私は詩壇に、他力信心といふものを一度考へてみて貰ひたい。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、私としては、良心を澄ませる、即ち謙虚な気持を修熟させることが第一だと思ひ、従つて、当分発表するものは、旧作であるから、それがつまらないからといつて、如上の考へをも愚であるとされたくない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさて、今よりも、子供の時分の方が、よつぽど海は好きだつたやうだから、してみると今よりも、あの頃の方が「こころまゝ」だつたのだらうか？",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれは喜ぶなが影の、すがたの海に跳び入りて、眼に腕にかい抱き、それな固有のざはめきに、なれがこゝろはなごむなり、抑へがたなきはた荒き、浪の歎きのかの響き　もはや眺めてはゐられなくなつた、跳び込んで、眼に腕にかい抱き、それな固有のざわめきに、なれがこころはなごむのだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            }
          ]
        }
