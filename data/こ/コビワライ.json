        "examples": {
          "standard": [
            {
              "text": "彼女の媚び笑いは、多くの男性を惹きつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は営業先で、相手の心をつかむ媚び笑いを巧みに使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その女優は、媚び笑い一つで観客を魅了する力を持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "若し、思い設けなかった愛嬌で媚び笑いながら、彼女に今夜花束をすすめられたら、私は寂しくなり、恐らく買わずに過たろう。",
              "citation": {
                "source": "粗末な花束",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　男は鰐の媚び笑いとでも言えるように、歯をむき出して愛相笑いをしながら答えた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
