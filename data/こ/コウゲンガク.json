        "examples": {
          "standard": [
            {
              "text": "彼は都市の変化を記録するため、考現学的な調査を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "考現学は、現代社会の風俗や流行を研究する学問だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "街の片隅にひっそりと残る看板も、考現学の対象になりうる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の実証主義写実主義の現われとしてその筆によって記録された雑多の時代世相風俗資料は近頃ある人達の称える「考現学的」の立場から見て貴重な材料を供給するものであることは周知なことである。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを以て白銅貨の文化的価値を明かにしたものという可く、随って考現学の資料ともなるものである。",
              "citation": {
                "source": "白銅貨の効用",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
