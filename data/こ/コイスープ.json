        "examples": {
          "standard": [
            {
              "text": "冬の冷えた体に、ジャガイモをたっぷり裏ごしした濃いスープがじんわりと染み渡る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この濃いスープ、パンにつけて食べると最高だね」と彼は満足げに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高級フレンチで提供されたのは、ロブスターの旨味が凝縮された贅沢な濃いスープだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "体中に精力が欠乏し、何か濃いスープでも飲みたいような心持だ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アニュータの料理はわたしたちの自慢です」　耳飾をさげた細君のいうとおり、太ったアニュータのボルシチ（濃いスープ）やカツレツは、パッサージ・ホテルの脂ぎった料理よりはるかにうまかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはまだ濃いスープはだめなんだから、かすになりきっちゃいないわよ」　その年の冬は厳冬の季節がきびしくて、モスク※で零下二五度という日があった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
