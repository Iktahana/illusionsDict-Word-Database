          "literary": [
            {
              "text": "例せば、紀州地方より海外に出稼ぐ者多きが、つねに国元へ送金するに、まずその一部分をおのが産土神に献じ、また出稼ぎ地方の方物異産を奉り、故郷を慕うの意を表す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷を慕うほかには何も考えられないのです。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、故郷を慕うのあまり、病気になればとさえ考えていたのでした。",
              "citation": {
                "source": "風雨の晩の小僧さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
