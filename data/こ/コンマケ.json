      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being beaten by one's opponent's persistence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あいつらのしつこいのには根負けがしそうだぞ！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの返事がいつまでも渋っているので、旦那の方でもさすがに根負けがしたらしく、いつとは無しにその相談も立ち消えになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにも、うるさく頼みますので、とうとう昨夜、私も根負け致しまして、それでは王さまにお願いして見よと申し聞かせた次第でございます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど和太郎さんのおかあさんは、じぶんの考えをいつまでもいいはるので、芝田さんもとうとう根負けしてしまって、　「よし、それでは、そうさくすることにしよう」といいました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど和太郎さんのおかあさんは、じぶんの考えをいつまでもいいはるので、芝田さんもとうとう根負けしてしまって、「よし、それでは、そうさくすることにしよう」といいました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかしてそれを打落そうとして、源兵衛は幾たびか石を投げたり枝を投げたりしたが、不思議に一度も当らないので、とうとう根負けがしてやめてしまった。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度つづけて呼んでも返事はないので、彼は根負けがした。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父ももう根負けがして、そのままおとなしく蚊帳のなかにはいった。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その重なり合った拇指がいつ動くかと思って、大野君と二人で翁の背後の脇桟敷から長い事凝視していた事があったが、決して動かないので根負けした事があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでとうとうホームズも根負けがしてしまって、はなはだ気の進まないような微笑を漏らしながら、とにかく一応その話をきこうと云うことで、その美しい訪客を椅子に招じたのであった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも怪しい物の姿はみえず、怪しい声もそれぎりで止んでしまったので、彼らも根負けがして再び内へ戻ると、それを窺っていたように怪しい声はまた呼んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどこまで行っても際限がないので、こっちもしまいに根負けがして、途中から空しく引っ返して来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "おげんも根負けがして、雨戸を細目にあけながら、雪明かりの庭先をのぞいたかと思うと、忽ちあっと叫んで座敷へ転げ込んで来て、澹山の膝のうえに半分倒れかかりながら、彼を掩うように両手をひろげた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなも不思議だと云いながら、四ツ（午後十時）頃までは待っていたのですが、地蔵さまは冷たい顔をしてびくとも身動きもしないので、とうとう根負けがしてぞろぞろと引き揚げました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "林之助も根負けがして、仕方がなしに屋敷を出たが、どう考えても空手では行かれなかった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩のことであるから、どの人ももう根負けがしたらしく、特に進んでそれを詮索しようとする者もなかったが、そのなかで猪上なにがしという若侍が忌々しそうに舌打ちした。",
              "citation": {
                "source": "父の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女に似合わぬ根強さに、内でも少し根負けがしたらしい。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の底へ深く沈んでしまったのか、但しは岩と岩との下をくぐって川下の方へ遠く押し流されてしまったのか、侍従はついにその姿をあらわさないので、二人はもう根負けがしてしまった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "公平に見たなら二葉亭の方が暴君で、細君の方は極めて柔順な奴隷であったろうが、夫婦の間が暴君と奴隷との関係では互に満足出来るはずがないから、あたかも利刃を揮って泥土を斬るに等しい何らの手答えのない葛藤を何年か続けた後に、二葉亭は終に力負け根負けがして草臥れてしまった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日もその明くる日も毎日毎日根よく押掛けて来るので、源七｜老爺さんも仕舞には根負けをしてしまって、それほど執心ならば兎もかくも彫ってみましょうという事になりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "源七もいよ／＼根負けがして、まあなんでも可い、当人の註文通りに滝夜叉でも光国でも彫ることにして、例の筋彫りで懲りさしてしまおうと云う料簡で、先ず下絵に取りかゝりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局根負けがして瓦屋を廃業して、土地や畑を買って農業を営むこととなったが、その後は別に異変もなく、むしろ身上は大きくなる方で、それから十年あまりの後に主人は死んだ。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはもう苛々して来て、じいやの胸ぐらを捉らないばかりにして、無理無体に根ほり葉掘りの詮議をしますと、じいやもしまいには根負けがしたらしく、とうとうこれだけのことを白状しました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はもう根負けがしたのと、藪蚊に襲われる苦しさとで、思わず身動きをすると、かれらを包んでいるすすきの葉がざわざわと鳴った。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "成景はなんとかして主人に逢わせまいと考えているらしく、いろいろに詞をかまえて追い払おうとしたが、玉藻はなかなか動きそうもないので、彼もとうとう根負けがして又もや奥へ引っ返したかと思うと、今度はすぐに出て来て、玉藻を内へ案内した。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少しく根負けの気味になった。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふたりとも、一生けんめいにたのむものですから、マユミさんもこんまけして、明智探偵に相談したうえ、とうとうお弟子にすることを、しょうちしました。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
