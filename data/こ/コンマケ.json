[
  {
    "uuid": "d10abb5e-2fb6-5830-a5f0-c99fcf96e47b",
    "entry": "根負け",
    "reading": {
      "primary": "こんまけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
