[
  {
    "uuid": "5d3e2731-e375-5ef3-9087-07e98c513401",
    "entry": "心根",
    "reading": {
      "primary": "こころね",
      "alternatives": [
        "しんこん"
      ],
      "is_heteronym": false
    },
    "grammar": {
