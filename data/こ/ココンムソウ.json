    "definitions": [
      {
        "index": 1,
        "gloss": "unparalleled in history",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
