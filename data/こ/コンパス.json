    "definitions": [
      {
        "index": 1,
        "gloss": "compass (for drawing circles, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
