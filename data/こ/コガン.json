[
  {
    "uuid": "a04e7988-c284-5a39-8906-756d20500316",
    "entry": "湖岸",
    "reading": {
      "primary": "こがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lakeshore",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "湖に面した廣縁に置かれた籐椅子によつて眺めると、昨日は水の面をはつて一望をたゞ有耶無耶の中に埋めた霧が、今朝はあとも無く晴れて、大湖を繞る遠い山々の胸や腰のあたりに白雲が搖曳してゐるばかりで、男體山は右手の前面に湖岸から直ちに四千尺の高さをもつて美しい傾斜で、翠色｜滴るばかりに聳え立つてゐる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "車中から偶然見る湖岸に漣波が立つて赤腹といふ小魚が群騷いでゐる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖岸との間の橋桁を撤して、家々の窓を銃眼に、投石器や弓矢で応戦した。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖岸との間の橋桁を撤して、家々の窓を銃眼に、投石器や弓矢で應戰した。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壊れて浮く湖岸の一つ一つの氷片もだん／＼寄り集って大きな塊になって来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近江の湖岸で、里程は二十里。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一里あまり湖岸をつたひて、中宮祠に來り、一店に投じて、蕎麥を食ひ、且つ飮む。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖岸に在る宿屋も氣持のいゝものであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の頃と旅",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後七時、湖岸の中屋ホテルといふに草鞋をぬいだ。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから行つて泊らうとする湯元温泉はその湖岸であらねばならぬのだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから行って泊ろうとする湯元温泉はその湖岸であらねばならぬのだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "折しも、湖岸に此珍事を傍観て居た人があつて、艪で、其艪で殺しておしまひなさい、頭をなぐつてお遣んなさい！",
              "citation": {
                "source": "鼻で鱒を釣つた話（実事）",
                "author": "若松賎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けからそれを運んで湖岸の田圃に積み上げる。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖は人家を教軒湖岸に散在させた周圍一里の圓形である。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場から馬車は、ロォヌ河の落ち口を、ルゥソォの小島を、レェマンの湖岸を、オテルデザルプへ導いて行つた。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこと云うのは湖岸なので、水漫々たる湖が眼路遥かに開けている。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから中庭を突っ切って湖岸の方へ歩いて行く。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて本栖の湖岸へ来た。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私はここへ来て、湖岸の草へ跪き、湖水へ向かって呼びかけるのです。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ三十町、湖岸を離れて山に上る。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖岸は降りてゆくにむづかしい絶壁で、遠く地底に眺める湖だけに暗く秀いでゝゐる。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖岸にそってふたりは、力かぎりこぎすすんだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンガニイカ湖岸には、土人の丸木舟がたくさんつないであります。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大な樹木と深緑の草に蔽はれた山が湖岸まで裾をひき、絶壁をそばだたせ、岬をつきだし、夢のやうな美しい景色が次々に展けてきます。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖岸の平地には、果樹が植ゑられ、玉蜀黍、落花生、甘藷などがつくられてゐます。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日を重ねて北へ進むと、湖岸の土人は次第に狡猾で兇暴なものが多くなりました。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖岸には釣をしたり、網をうつたりしてゐる漁夫もゐました。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な××湖を傍にひかえていますが、湖岸から奥へ約十町ほど、昼なお暗き曲りくねった小径を入って行くと、突然密林荘の前に出るわけです。",
              "citation": {
                "source": "密林荘事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度三日目の朝のこと、僕たちは山荘を一緒に出て、羊腸の小径を湖岸へ抜け、そこで右へ行き、小瀬川を少し川上へ歩いたところで釣を始めました。",
              "citation": {
                "source": "密林荘事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は元の道を引返し、湖岸の左の方へ行った釣場所へ糸を下ろすのだといっていました」「ああ、そう。",
              "citation": {
                "source": "密林荘事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
