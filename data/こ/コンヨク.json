        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヤパンでは男女混浴だというがほんとうかなどと聞いたりした。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの塩の湯の谷合に湯が湧き出して、そこに大勢男女が混浴してゐるさまなども、明るい日影の下で見るとそのまゝ面白い絵になりさうに思はれた。",
              "citation": {
                "source": "女の温泉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、この浴室は昼間でも薄暗い穴倉のやうな場所で、三人は沈めさうもないほどの小さな浴槽に混浴であつた。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "好く炉端にあつまる村の人達がおそろしく卑猥な冗談などを饒舌つて、混浴場ではしやぎまはつたが、私はさういふ風景は抽象的に想像する場合には多少の長閑さを連想しないこともなかつたが、実際では単に不気味に過ぎなかつた。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "午后、宿のおかみさんに案内されて、しづかなきれいななぎの湯といふのへゆく、なるほど不便なだけしづかで、紙ぎれや綿きれがちらばつてゐない、しかしこゝもやつぱり特有の男女混浴だ、男一人（私に）女五人（二人はダルマ、二人は田舎娘、一人は宿のおかみさんだ）、ぶく／＼下から湧く、透き通つて底の石が見える。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い山の湯の男女の混浴は隔離した湯よりも、むしろ清浄な山川の匂いが強く肌に染み入り、互に羞らいのない心の爽かさが、また一層朝の人の眼醒めを美しくした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪の出たことや、この地の葱の特別の美味さや、馬橇の値の高さなど、湯の中の話を聞くともなく聞きながら、矢代は、朝の雪中の男女の混浴を俗情と見ず、こうしている人人も、健康な日のギリシアにどこか似ているなと思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "混浴とみえて、脱衣場の円い籠には、女や男の衣類がぬぎすててあつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に町の風呂屋は、町内浮世の混浴であるがために、その味は殊に深いものがある。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし近ごろは浮世の混浴から遠ざかっている事を遺憾に思っているが、といってわざわざ電車に乗って、大阪へ入湯に行くという事は、今もなお億劫である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうするのさ」　男女混浴の湯殿へ、男がはいって来るに不思議はなかったが、その男が、衣裳棚の中へ脱ぎ入れてあったお蘭の着物を抱えていたので、そう云ったのであった。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の内湯は昔ながらの男女混浴で、蒲原夫人と秋蘭はその習慣に馴れることができなかつた。",
              "citation": {
                "source": "逃げたい心",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物腰はあくまで自由で、男女混浴の浴室の中で隠すべきところを隠さうともせず、のびのびと歩きまはる様子には羞ぢらふ固さもないばかりか、強ひてする厭味なきつさもないのであつた。",
              "citation": {
                "source": "逃げたい心",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子のイレズミもはやったし、男女混浴という同権思想も肉体の探究もはやり、忙しく文明開化をとりいれて今にもまさる盛時であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の湯は男女混浴なので、私もこの女の裸体を見たが、すらりとして、はちきれさうな光沢があつた。",
              "citation": {
                "source": "山の貴婦人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海かなんかで、男女混浴の共同ブロへはいる方が、もっと、ええでしなア」　御説の通りである。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルカラの大浴場をはじめ、富者は各自善美をつくした浴室をもち、公共の浴場に於ても男女混浴の酒池肉林は当然のこととなった。",
              "citation": {
                "source": "人生三つの愉しみ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけず混浴である。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女混浴……国貞画くとまではいかないが、それでも裸形の菩薩が思い思いの姿態をくねらせているのが、もうもうたる湯気をとおして見えるから、与吉はもう大よろこび。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女混浴の風もはやった。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "算術に珠算を用い、湯屋は混浴を常とし、寺前に乞食の多き、商品に掛け値の多き、車夫の人を見て賃銭を高下するがごときは、みな東洋的なり。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに他に客が誰もいなかったが、この温泉は混浴だなどとスコット夫人にいうと吃驚していた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、残念ながら、全学生を収容できる混浴の温泉を、探すのが難しいと言われたのである。",
              "citation": {
                "source": "三重塔にて",
                "author": "福永信",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは高山あたりから来た、新婚らしい夫婦者、それから近在のお婆さんと、病気がありそうにもないに湯治だと言っている四十男、それと家の番頭、雇人、それらが、すべて隔てのない混浴でした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、若い白人の女奴隷たちが平気で男奴隷と混浴をして何の恥ずるところもなかった。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も鉱泉へはいってみたいと云って、私についてきたが、その日に限って案外の混雑で、私も少々うるさくて仕事ができなかったぐらい、湯ブネの方はいつも人がこみあっていて、男女混浴だから、あやかさんは入浴することができなかった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "安永頃にはもう江戸は混浴禁止になっている。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "右へ逃げれば右へ、左へ逃げれば左へ、おばあさんは、泰二君の身をかわすほうへ、まるでひもで引かれてでもいるように、こんよくつきまとってくるのです。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
