    "definitions": [
      {
        "index": 1,
        "gloss": "parenthood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "陸の上で会う松浦は、単にＳ会社の平凡で勤勉な妻子持ちの社員だけである。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しかし、お前は、子持ちだな？",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くに立っていたやはり子持ちの女のひとが見かねたらしく、「お乳が出ないのですか？",
              "citation": {
                "source": "たずねびと",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一軒屋は、その江見の浜の波打際に、城の壁とも、石垣とも、岸を頼んだ若木の家造り、近ごろ別家をしたばかりで、葺いた茅さえ浅みどり、新藁かけた島田が似合おう、女房は子持ちながら、年紀はまだ二十二三。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、それに答えて、あなたはそりゃ、お子さんも無いし、奥さんと二人で身軽にどこへでも行けるでしょうが、私はどうも子持ちですからね、ままになりません、と言った。",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃物の乞食の中から花田は、わたくしを倶楽部の娘に拾い上げたように、この町の乞食の、子持ちのお三も、タガメも、たんばも、瀬戸勘も、髭の兵庫島も――みな、それ／″＼拾い上げて花田と啓司の指図の何かしらの職持ちになったのは、二人の慈善心より、より多く市に人手｜払底のためでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は九州のＦという町でやはり弁護士を開業しているんですが、早い子持ちで、廿三の年にわたしを生んだのだから、去年は五十二で、土地の同業者間ではまずいい顔になっている。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十歳の娘をかしらにすでに三人の子持ちだ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "子持ちの牛はその子を振り返り見てしきりに鳴くのである。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし家におったころに毎日出あるいた田んぼ道、朝に晩にながめたこの景色、おもむきは昔の記憶に少しも変わらないが、あまたの子持ちとなった今のわが目には特別な意味を感ぜぬわけにゆかぬ。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぼ相談をくりかえしても、三人の子持ちとなった女はもはや動きはとれない。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんはもう三人の子持ちで、その話は奥さんがまだ女学校時代の若い頃の出来事だそうである。",
              "citation": {
                "source": "停車場の少女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れもせぬ二年まえ、父が他界いたしますといっしょに、生前なによりたいせつにして、父が秘蔵しておりました子持ちすずりという名のすずりが紛失したのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "お察しくだされませ」　言うまも悲しみ喜び、いちどきにこみあげてきたとみえて、おこよはよろめきながら床の間へ近づくと、子持ちすずりの桐箱を抱きすくめるように取りあげて、おろおろと泣きつづけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "おこよどのも参られよ」　あい、とばかりに、おこよは泣き喜びながら、子持ちすずりをしっかとかかえて、なわつきのふたりのあとを追いました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしそうに子持ちすずりを抱いていったはいいが、きょうから赤い信女のおひとり者になるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにあなた方は、いつも自分一人が子持ちになどなつて割がわるいのだといふやうな顏をしていらつしやるほんたうに罰があたりますよ。",
              "citation": {
                "source": "冬を迎へようとして",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はいお頭さん、子持ちお椀を」「ああなるほど、子持ちお椀か。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにいいなあ、子持ちお椀は。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうまでもなく、消防夫は鳶といって、梯子持ち、纏持ちなどなかなか威勢の好いものであるが、その頃は竜吐水という不完全な消火機をもって水を弾き出すのが関の山で、実際に火を消すという働きになると、今日から見ては他愛のない位のものであった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その頃の消防夫のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折ヘルバルトはもう相当の子持ちであつたが、それでも嬰児の顔を見ると、可愛さに堪らぬやうに、接吻をしたり、頬ずりをしたりした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁付き候ても子持ちのことにこれあり、且は年頃にても女子は親の家へ遊びに參るを樂みにいたし候よし世間にてほゞ承はり候へども、母なきところにては是等のこと一人の娘不便の事に候。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなに若くて子持ちかい。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私が子持ちになるなんて……。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年行った衆はたいがいもう三十越したったが……、私もこんど募集があったら行こうかと思っているが、どうも――子持ちだからねえ」　ネクタイをずらしたようにかけて、脱いだゴム長は坐席の下にたぐめたまま、此方を向いて紺足袋の片膝抱え、おとなしい口調で云っている。",
              "citation": {
                "source": "東京へ近づく一時間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラメルが欲しいと、大きい子供まである姉さんにたのまれた妹は、これももう子持ちになっていて、キャラメル一つを、大きい注文うけた気でさがして歩いた。",
              "citation": {
                "source": "諸物転身の抄",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう権利を守るために、ソヴェトの労働法は姙娠五ヵ月以上の労働婦人と生後十ヵ月の子持ちの労働婦人を解雇することを禁じている。",
              "citation": {
                "source": "ひとごとではない",
                "author": "――ソヴェト勤労婦人の現状――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから部屋へ帰って……独りぽっちで、あの子の物を片づけなければならぬのか……ああ厭だ厭だ、何て情けないこったろう」　これまでも左様だったが、これからも度々見せつけられねばならぬ世間の子持ち女というものに対して、彼女は一種の嫉妬と反感がむらむらと起って来た。",
              "citation": {
                "source": "小さきもの",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は一体遅い子持ちなのに、思いがけなく男の子が出来たので、興奮したのか、国会太郎としようかのと、変な名を言い出したりしたが、凡庸であった時に困るであろうから、きわだった名はつけぬものだと、祖母にいさめられていた。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は、意識しないで僕に甘ったれ、僕のたいこもちを勤めていたのではないだろうか。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
