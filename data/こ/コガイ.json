[
  {
    "uuid": "85a221b8-bf45-5ff4-927a-7e494cefc829",
    "entry": "戸外",
    "reading": {
      "primary": "こがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "open air",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "戸外は――地面は半ば乾いてあつたかい、空を風は、目標ありげにとぶ、梅雨期の或る一日だ。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後の壁には乾鮭がさがり、戸外には空也念仏の声が通る。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは毎日一日役所の殺風景な薄暗い部屋にのみ籠っているし、日曜と云っても余計な調べ物や内職の飜訳などに追われて、こんな事を考えた事も少ないが、病んで寝てみると、急に戸外のうららかな光が恋しくて胸をくすぐられるようである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壺や林檎も面白くない事はないが、折角「生きた自然」の草木が美しく、其れに戸外が寒くなくて好い時候に、室内の「｜死んだ自然」と首引をするのも勿體ないやうな氣がした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜物乃至自畫像などは寒い時の爲に保留するといふやうな氣もあつて、暖い内はなるべく題材を戸外に求める事に自然となつてしまつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も戸外と云つても唯庭をあちらから見たり此方から見たり、或は二階か近所の屋根や樹の梢を見た處など、もしこれが本當の畫家ならば始めからてんで相手にしないやうなものを、無理に拾ひ出し、切り取つては畫布に塗り込むのであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなものでも半年も戸外に吊して雨曝しにして自然の手にかけたら、少しは落着いたいゝ色調になるかも知れないと思つたりした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弧灯は何万燭光などという強い光を出すので、探海灯、灯台用その他すべて戸外の灯用に適している。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は相変わらず螺の腹にえび蔓の背をしてこそおれ、達者で、あさけ夕凪には戸外へ出て、山々の方を眺めた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この祭には諱忌のあるものは配偶さえ戸外へ避けしめる例であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはそのままでわしが貰おう」　翁は、瓜わらべを抱えて戸外へ出た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず一番の基礎的な事柄は教場でやらないで戸外で授ける方がいい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二十七日と二十八日とは好天気であったので、戸外の美しい日光の下でお茶に呼ばれるために、二階からやっと下りて来た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蛾は、戸外がすっかり暗くなって後は座敷の電燈を狙いに来る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もさつぱりとした氣持ちになつて、岡本君とも愉快な微笑を交換しながら、輕い歩調で戸外へ出た。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外には初夏のしつとりした空氣が流れてゐた。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "タキシードを着た富豪の下僕や雇人等は、乞食の客人を見て吃驚し、主人の制止も聞かないふりで、戸外へ掴み出さうとするのである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大聲で下僕を呼び、すぐに此奴を戸外へ掴み出せと怒鳴るのである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　彼女の二人の子供、十歳になった三郎と、まだ七歳の四郎は、その日昼飯が済んでから、戸外へ遊びに出たまま帰って来ないのであった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかへ戸外では、すべてが版畫の趣になつてゐた。",
              "citation": {
                "source": "冬",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかちつとも戸外にゐるやうな氣持がしません。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達戸外に這い出す。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然パーシの夜の鶏が戸外で鳴き出すと、アダはいらいらして、その他に別に用事はないかと私にたずねる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　戸外に彼女がでると、萎黄病のように燻んでしめった月が建物の肋骨にかかっていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな火鉢に僅かばかり燃やされた木片で暖まる譯もないがらんとした部屋の中は、凍るやうな戸外の夜氣と共に冷え渡つて、寒さがひしひしと身に迫つて來た。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外スポオツにしても、野球は勿論だが、近頃それと人氣を角逐しかけて來た蹴球にしてもその今日を見るまでには慶應義塾蹴球部の隱れたる長い努力があつた。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外に雨音が聞え出した。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、戸外の薄暗くなる頃まで自分はさりげなく先生との雜談に時を移してゐた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外には、谷間の嵐が団栗の落葉を吹き散らしていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時頃、まだ戸外は暗いのに、もう起きている。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
