[
  {
    "uuid": "56bb2137-0943-5506-bf93-25feadca8efd",
    "entry": "公敵",
    "reading": {
      "primary": "こうてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "public enemy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わたしは彼を同族の公敵と認めた。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "充実なき誇負は由来文化の公敵、真人の蛇蝎視する所に候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等二人の公敵が、それぞれ、厖大にして尊敬すべき二人の婦人に抱きかかえられつつ、手を組み足を蹴上げて跳ね廻る時、大法官も大作家も共に、威厳を失墜すること夥し。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかに世界の公敵が大手をふって闊歩するのを見おとしてはならない。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、銀行を支配しているイギリスやアメリカが、世界の者からいくらか公敵のように思われているのと同様に、頭数を支配している中国も各国の公敵だと思われたって、それは昂然として受け入れねばならぬ中国人の債務です。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が吾々の公敵と通信していることは、今日や昨日からのことではなく、昨年や一昨年からのことでさえない。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "選挙権をとられた」と訴えたが、ふたたび損害のことに言及して「ただ放棄して勝手にしろというような政治家があったならば、私は実に公敵として互に死を決してもこの人間を仆さなければならぬと存じます。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
