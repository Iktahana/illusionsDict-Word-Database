  {
    "uuid": "2edca9c8-65fc-53e0-b13f-5134918747a0",
    "entry": "コラ",
    "reading": {
      "primary": "コラ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "composite image",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "所でラヴェルなんてバッハが見たら苦労性なデコラトゥールだ。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道を折れて、少し下り坂になる道をスタコラと歩いてゆくと、街道でしてゐた豆腐屋の喇叭の音は急に聞えなくなり、道の傍の、森の葉擦の音に私は淋しくなるのであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処の景色を私は好きである、坂は段々勾配を増し、酔つて夕陽に照らされてスタコラゆけば、まるで我が身か、我が身が運ぶ箱か分らず、多分今飲んだビールを運ぶ容器であるに相違なからう。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙な桜の　アラ　ナントネ粋をきかした　縁むすびスッチョイコラ　スッチョイコラ　私の耳の奧にはまだ歌が響いていた。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコラ学派時代に科学の進歩が長い間全く停滞したのは、全くこの旋毛曲りが出なかったために外ならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コラァさっさと掃除をやってしまえ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジロジロ仲蔵の定九郎を見て「ヤイコラッ」　「ハイ」と仲蔵。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い男は、尚も仲蔵を責めて居る大吉の側へ寄って「コラッ」と胸倉掴んだ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、オドオドして居る仲蔵の所へ戻って、　「ヤイコラＴ「仲蔵！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその生前には、ただ、ニコラス・ド・フリエに就いての小論文を發表したにすぎない。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達はショコラ酒を飲んで、金盞花の花と共に寝床に埋れました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者では主役のピエールよりも脇役のニコラというロシア人がわざとらしくないいかにもその人らしいところがよかった。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウンコラウンコラ脚を飛ばして行くこと二里。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生懸命になって「ハイ、ッコラ、ヨッ」。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コラコラ、今から居眠りをするようでは駄目じゃッ」と、髯将軍の銅鑼声はまず車中の荒肝を拉ぐ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コラッ、貴様ッ、ろくろく働きもせぬくせに、生血のような水を唯飲みしようとは、怪しからん奴だ」と呶鳴り付けたが、考えてみればあれも人の子、咽の渇くのは同じだろうと惻隠の心も起り、「皆飲むなよ」と、長い竹筒の水を渡してやれば、先生竹筒に口を当てるが早いか、逆様にして皆ゴボゴボと飲んでしまった。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コラ、そんな事をいうと、天狗様の罰が当るぞ」と、未醒子は眼を剥く。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだよそうだよ」と、吾輩焼酎を吐出してしまったので大いに気持もよく、またもやスタコラ走って漸く雲巌寺の山門に着いてみると、先着の面々は丸裸となり、山門前を流るる渓流で水泳などをやっている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と声を震わし、畳を叩きていきまけば、ニタニタと北叟笑、「フフン、御恩ゴオンと、ニコライの鐘みたいにいけすかない音をお出しでない。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラコラム映画――そんなのあるかな」「いや、兵隊は活動写真なぞ見ている暇はない。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでね、大騒ぎになって、いろいろ調べてみると、莫迦げた話じゃないか、それは何でもトルキスタンあたりの或る活動会社が金儲けのために仕組んだ芝居だったのだ」「カラコラム映画会社に違いないわ」「そうかも知れない。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、やっぱりショコラアが引っぱって行ったのですが、ショコラアはもとっからそこの倶楽部員だったのですよ。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士方――左様、なかにはショコラアの様な水夫も大勢いましたが、本当に立派な上流の紳士方も沢山、それは殆ど世界中のあらゆる国籍を網羅して出入していました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその倶楽部で、「不正を悪くむ紳士方」の毎日やっておられる主な仕事は、ばくち、「麻雀」と呼ぶばくちなのだから面白いではありませんか――僕は間もなく、ショコラアに連れられることなくして勝手に、その薄ぐらい倶楽部の地下室に入り浸って、麻雀に時の過ぎるのも忘れ果てているようになったのでした。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホガラ／＼した秋の暖さが體に通ツて、何んだか生温い湯にでも入ツてゐるやうな心地……、幻から幻へと幻がはてしなく續いて、種々な影が眼前を過ぎる、……只見ると、自分は、ニコライ堂のやうな高い／＼塔の屋根に登ツて躍ツたり跳たりしてゐる。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コラッ……」　と巡査はヤケに靴の先で昂作の尻の骨を蹴った。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
