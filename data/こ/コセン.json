[
  {
    "uuid": "1c1e0f3b-dac2-5e4d-aa74-8c6ff3b4c5f2",
    "entry": "古銭",
    "reading": {
      "primary": "こせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "old coin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "迷庵も斎は古銭をも集めた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "抽斎も古書や「古武鑑」を蔵していたばかりでなく、やはり古銭癖があったそうである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古武鑑」、古江戸図、古銭は抽斎の聚珍家として蒐集した所である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近日児信重儲古銭数枚、朝夕翫撫、頗有似酒人独酔之楽、因賦一詩。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "註云、乞児猶乞古銭、事見蒙斎筆談、謝在杭五雑組、演為一話、世多以為始自謝氏者陋矣。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　蘭軒の三子柏軒が古銭を集めることを始めた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此詩の自註に、蘭軒は蒙斎筆談を引いて、「乞児猶乞古銭」と云ふ事の典拠を示してゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはこれを読んで、乞児も猶古銭を乞ふとはいかなる事を謂ふかと云ふ好奇心を発した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百五十二　わたくしは蘭軒詩註の「乞児猶乞古銭」と云ふことを知らんと欲した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭に相場の狂ふほどリボンを巻きつけ、頸飾や十字架や古銭を頸に掛けた娘たちは、少しでも内陣ちかく割りこまうとしてあせつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の外収蔵の物、本邦古人書画、近代儒家文人詩文、唐山真蹟書画、本邦諸国地図、唐山蛮方地図、草木金石珠玉点介鳥獣、古銭古器物、唐山器物、蛮方異産の類ありと雖も、皆考索の用とす。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "電灯公司の中村信さんは附近の古墳から近年出た古銭の数品、君林先生は清朝の乾隆帝の三十三年（西紀一七六八）に満洲の旗人福會と云ふ人に帝から与へた恩封の帛書一巻を携へて来て、何れも私達に恵まれた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤木さんは屋上の展望台へ私達を延いて長春全市の説明をされ、濱田氏は愛蔵の支那古陶器を携へて来て示され、本城氏も多年蒐集された古銭の代表的な物を持参して見せられた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "古銭ノ如ク紀元ヲ書セシ物ハ、一目瞭然ニ知ル可シトス。",
              "citation": {
                "source": "好古小言",
                "author": "※上漁史",
                "note": "青空文庫"
              }
            },
            {
              "text": "但シ古銭ハ鑑識頗ル難キモノニテ、古鏡古銅器ヲ観ルノ眼ニテ之ヲ観レバ、必ズ贋品ヲ攫ムニ至ル。",
              "citation": {
                "source": "好古小言",
                "author": "※上漁史",
                "note": "青空文庫"
              }
            },
            {
              "text": "此比俄ニ日本古銭ヲ玩ブ人多クナリテ、其価ノ十年前ニ四五倍スル様ニナリシハ、泰西ノ風ニ化シタルナリト云フモ、失言ニハ非ザル可シ。",
              "citation": {
                "source": "好古小言",
                "author": "※上漁史",
                "note": "青空文庫"
              }
            },
            {
              "text": "古銭蒐集という趣味ではないから、珍らしいものは殆んどなく、小額紙幣の間合に時折出てくる安っぽい貨幣を、見当り次第に貯えるのであり、桂介や久子から貰ったものが多い。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "古銭を蒐集することの好きな彼は、異国の銀貨を手に入れて、人知れずそれを愛翫するうちに、そんな古銭にまじる銀貨から西洋というものを想像するようになった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお古銭の出たということはひとりこの大原町山間の例ばかりでなく、多少価値が少いと思っていたかの青森県是川村〔八戸市〕堀田の竪穴出土のものも、この大原町の発見によって立派に生きて来る。",
              "citation": {
                "source": "「あばた」も「えくぼ」、「えくぼ」も「あばた」",
                "author": "――日本石器時代終末期問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや古銭が伴っていたという事実あるにおいてをやだ。",
              "citation": {
                "source": "人身御供と人柱",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに一つの特殊の建築物の下から数体の白骨が古銭とともに発見されたというのは事実である。",
              "citation": {
                "source": "人身御供と人柱",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその伴える古銭が寛永通宝鋳造以前の通貨であって、その埋葬がそう古いものであるとは考えられぬ事において、墳墓説は到底否定されざるをえぬ。",
              "citation": {
                "source": "人身御供と人柱",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって古銭と白骨とがどんな関係で発見されたかを詳かにせぬ。",
              "citation": {
                "source": "人身御供と人柱",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも特に古銭に精しく斯界での大家であった。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『古泉大全』と題する大著があって、その書中の古銭図は、もし間違いがあっては正鵠を失するといって、みな自身で手を下して丁寧正確に彫刻し、その書の印刷もまた活版印刷機を室内に用意し、下女などに手伝わせて自家の座敷、畳の上で印刷したものである。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また古銭を愛するものありしが、半両一枚を六百両に買入る。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも付加条件であったかと思うのは、私は当時やたらに雑書を読み、土中から金銀や古銭の、ざくざくと出たという江戸時代の事実を知っていて、そのたびに心を動かした記憶がたしかにある。",
              "citation": {
                "source": "幻覚の実験",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は古銭を集めるのが道楽でな、家を出る時は、充分金を持って出た筈なんだが、途中二三ヶ所で古銭に引っかかって、とうとうこの通り。",
              "citation": {
                "source": "古銭の謎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴鹿川八十瀬の波に濡れ濡れず伊勢までたれか思ひおこせん　簡単に書かれてあるが、貴人らしさのある巧妙な字であった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
