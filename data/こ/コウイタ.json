    "definitions": [
      {
        "index": 1,
        "gloss": "top board (of a table, counter, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
