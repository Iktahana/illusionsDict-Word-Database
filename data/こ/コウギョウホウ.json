          "standard": [
            {
              "text": "試掘権の設定期間については、鉱業法によって厳格に規定されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鉱業法は、資源の合理的かつ秩序ある開発を目的として制定された法律だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "休廃止鉱山の管理についても、鉱業法に基づいて適切な措置が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ウラニウムそのものについても、まったくの野放し状態で、鉱区をきめて掘るという、鉱業法の法定鉱物にすらなっていないのだから、誰がどこを掘ろうと勝手だし、買手があれば、外国へ売ることだってできる……だから、金ほしさに、外国へ譲渡する懸念のあるひとのところへ、鉱業権が移るのは好ましくない。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
