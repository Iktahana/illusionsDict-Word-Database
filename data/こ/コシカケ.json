        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕の直ぐ隣にはばかに肥つた男がゐて、僕は追ひ詰められたやうになつて腰掛けてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤坊の真ん前に腰掛けてゐるのは女の先生で、尤も先生だといふことは翌朝になつて分つたので、一寸見た所では薬専か歯科医専の生徒だらうと思はれた。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は前夜の飲過ごしでぐつたりして、少し卓子の割合には高過ぎる椅子に腰掛けて、煙草を喫つたり本を読みかけてみたり、と、急に思ひ出して此の日頃方々で受取つた名刺の整理をしたり、――要するに何の野心もなく、その日第一回の食事を済ましたばかりのところであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つに繻絆一枚で腰掛けて老人の読んでゐた新聞に、三十何年とか撒水車を挽いてゐるといふ男の笑つて汗を拭いてゐる写真が通りがかりに見えた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとどまる所を知らず――といふところです、をつホホホホ……」そして彼が上り口に腰掛けようとするのを見ると、「ま、まあ、お上んなさい」と云つた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ子は運転台の近くに、彼は車掌台の近くに、離れて腰掛けてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると途中からもう一人同じ帽章をつけたのが乘り込んで、いきなり入口に近く腰掛けて居た一人の肩をたゝき「オイ、どうした」と聲をかけた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸子の宿の名物とろろ汁の店といってももうそれを食べる人は少ないので、店はただの腰掛け飯屋になっているらしく耕地測量の一行らしい器械を携えた三四名と、表に馬を繋いだ馬子とが、消し残しの朝の電燈の下で高笑いを混えながら食事をしている。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "車室の中は、青い天蚕絨を張った腰掛けが、まるでがら明きで、向ふの鼠いろのワニスを塗った壁には、真鍮の大きなぼたんが二つ光ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」腰掛けたばかりの男の子は顔を変にして燈台看守の向ふの席に座ったばかりの青年に云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝茶店の外　夕やけ小やけ……　半五郎の帰った後、源兵衛一人、表に出て、しょんぼり床几に腰掛けている。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几に腰掛けた商人風の男二人話す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝荒物屋の階下　石松、上り框に腰掛けて草鞋をぬぎ乍ら親爺に　「爺っつあん、今日俺の来た事ァ内緒だ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝居酒屋（夜）　土間で三次が床几に腰掛けてチビリチビリやって居る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ「翌朝三次は久し振りでお稲荷様にお詣りした」Ｓ＝稲荷神社境内　お絹の腰掛け茶屋は閉っている。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光が「まあお掛け」と二人仲良く茶店の縁台に腰掛けて、何やら楽しげに、ペチャペチャ、誰が見たって恋人同士の甘き囁き。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉が又床几に腰掛けて茶を飲まんとした時、急ぎ足に半次が現れた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また時には窓際の曲木の椅子に腰掛けて、庭の景色や、向う側の病室の窓の中をぼんやり眺めてゐる事が出來るやうになつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣が附くと船客の人達も皆默つてしまつて、立つたのも坐つたのも腰掛けたのも氣の拔けたやうな顏をして海面を眺めてゐる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踵を失った大西は、丸くなるほど繃帯を巻きつけた足を腰掛けに投げ出して、二重硝子の窓から丘を下って行くアメリカ兵を見ていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部には、床も棚も、腰掛けも、木片一ツもなかった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、助役の傍に来て腰掛けている小川という村会議員が云ったのだ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラムハラドは長い白い着物を着て学者のしるしの垂れ布のついた帽子をかぶり低い椅子に腰掛け右手には長い鞭をもち左手には本を支えながらゆっくりと教えて行くのでした。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろへ腰掛けてこぼこぼはっていく温い水へ足を入れていてついとろっとしたらなんだかぼくが稲になったような気がした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生は地図を渡しながら云われた通りしきいに腰掛けてしまった。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車室の中は、青い天蚕絨を張った腰掛けが、まるでがら明きで、向うの鼠いろのワニスを塗った壁には、真鍮の大きなぼたんが二つ光っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」腰掛けたばかりの男の子は顔を変にして燈台看守の向うの席に座ったばかりの青年に云いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几の隅に腰掛けておふみが考え込んで居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "特別な設計をした振動台の上に固定された椅子に被試験者を腰掛けさせ、そうしてその台にある一定週期の振動を与えながらその振幅をいろいろに増減する。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっしろなさるのこしかけを見た。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
