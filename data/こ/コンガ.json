[
  {
    "uuid": "4bb5eedf-d247-53b0-a7f6-7e4d2cec7c91",
    "entry": "コンガ",
    "reading": {
      "primary": "コンガ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
