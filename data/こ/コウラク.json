[
  {
    "uuid": "8e14e7c2-ed28-5c45-aadd-c11c1c45ca9c",
    "entry": "行楽",
    "reading": {
      "primary": "こうらく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "outing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小春日和の日曜とて、青山の通りは人出多く、大空は澄み渡り、風は砂を立てぬほどに吹き、人々行楽に忙がしい時、不幸の男よ、自分は夢地を辿る心地で外を歩いた。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と行楽を共にする場合でも、決して他人の切符までは、買ってあげない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの巡礼の行楽、虎列拉避けの花火、さては古めかしい水祭りの行事などおほかたこの街特殊のものであつて、張のつよい言葉つきも淫らに、ことにこの街のわかい六騎は温ければ漁り、風の吹く日は遊び、雨には寝ね、空腹くなれば食ひ、酒をのみては月琴を弾き、夜はただ女を抱くといふ風である。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "窮屈な工場から来た者、陰気な屋根裏から出て来た者――皆光りに蘇つて行楽を満してゐる様は……」　斯うしてこのまゝ散歩を楽しみ帰路につけば無事だつたのを、不図その科白を口吟むと、調子づいて、別の科白が口にのぼつて来た。",
              "citation": {
                "source": "途上日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……海辺の行楽を知らずに過した。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の行楽に遊び疲れたらしい人の群れにまじってふきげんそうに顔をしかめた倉地は真向に坂の頂上を見つめながら近づいて来た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国橋の上に立って、そうした行楽気分を思い得る人は幸福である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本晴、ピクニツク日和、まさに人生行楽の秋。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月廿五日　晴、行楽日和だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日曜の祭日、絶好の行楽日だけれど、お天気が思はしくない、何だか気の毒に思ふ、嘆くなかれ、むろん悔いるなかれ、人々具足、ほどよく楽しめ。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽日和、掃除日、風の日。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽日和、学校には運動会が開かれ、山野には子供を連れてのハイカーが多い。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日はどうやら雨らしい、せつかく行楽日、降らなければよいが。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋季皇霊祭――彼岸の中日――行楽日和。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽日の行楽人、善哉、善哉。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行楽的な旅などする余裕はなかつた。",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "君と己とのはもう行楽の時代が過ぎ去らうとしてゐるのに、あの人のはまだ水の出端である。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "からッ風　武蔵野は筑波｜颪のからッ風、秋の暮から冬三月を吹いてふいて吹きとおして、なお且つ花さく日にも吹きやまず、とかくして三春の行楽をも蹂躙ろうとすること必ずしも稀らしくはない。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「簡合春川」の詩に「漸迫帰程発※期、江城梅落鳥鳴時」と云ひ、「留別真野先生」の詩に「帰期已及百花辰、恨負都門行楽春」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらにもこちらにも小さな人の渦が出来波が流れて、この狭い場末の一角にも、鄙びた、ささやかな、むしろ可憐な感じのものながら、流石に初夏の宵の縁日らしい長閑な行楽的な気分が漂っていた。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この竹屋の渡しで向島から向う岸に渡ろうとする人の多くは、芝居や吉原に打興じようとする者、向島へ渡るものは枯草の情趣を味うとか、草木を愛して見ようとか、遠乗りに行楽しようとか、いずれもただ物見遊山するもののみであった。",
              "citation": {
                "source": "亡び行く江戸趣味",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "古文古歌固より高尚にして妙味ある可しと雖も、之を弄ぶは唯是れ一種の行楽事にして、直に取て以て人生居家の実際に利用す可らず。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は外出や行楽は必ず日曜祭日以外においてすることにきめている。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく芸術の展覧会の観賞は華やかの如くであるが、あのトワールの裏を覗くと、古きも新しきも若きも老いもみな、頼まれもしない苦労を死ぬまで続けているところの、それらの画家の顔が潜んでいることである点、多少とも松茸狩や秋の行楽に比して鬱陶しいことであるかも知れない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の姉の水絵の具を行楽の子女の衣服だの草木の花だのになすってくれる。",
              "citation": {
                "source": "点鬼簿",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節は初夏ながら是れが大連の春祭であり、在留の邦人に取つて今年最初の行楽日である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "この嵐気とこの香魚と、殊に香魚の漁猟は、この地に古くより伝来する鵜飼によつて一層の興を助くるから、山間三次の行楽は正に夏において極まるといつてよい。",
              "citation": {
                "source": "三次の鵜飼",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
