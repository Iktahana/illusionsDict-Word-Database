    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浴衣一枚の胸をハダケて、恐らく我々が来るまで、彼は頭をカカへてゐたに違ひなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食住さへ足りればいゝ人達は、不景気にも関らず、昔日よりも元気でこそあれ落胆してゐるとは思はれぬ。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食住さへ足りればよい人達は、不景気なれば、尚更ボヤボヤしてはゐられないといふので、景気のよい時よりも当然意志的になるのであらう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらはもともと観念といふものを必要としてをり、衣食住だけを全てだとは思はない人種だからである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらでだに観念を必要としない衣食住万能派等が、一層観念なので、遊戯としてさへ取上げなくなるからである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食住さへ足りれば好い連中が、不景気のために一層意志的となり、それが世間一般の主調である場合、常識はまた一層のさばるのである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しもはや其処をさへ跳越えて、インテリ自身が、衣食住だけ足りればいゝ人達の人生観、所謂「ホガラカ」を以て、自分を律しようとするやうにさへなつてゐるのである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、自体インテリがインテリであるためには、衣食住の先のこと、換言れば観念を必要とし、それに就て仕事をする場合にインテリなのである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の云ひたいことは、今や、衣食住だけ足りれば好い人達の時勢だといふことである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何サ、芸術は衣食的実用品ではないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術といふものが、衣食的実用品ではなくて、謂はば臨時に生の余剰価値をこの人生に附加することであるから、つまり創造であるから、「存在の姿」を持つといふことは何を措いても必須のことである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護衣のまゝで抱かれるのは少しいやでもあつたけれど、心底可愛さうに抱いてるのにそんなことも云へなかつた……」と、母の話はマストの次には岡宮さんである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると私は白い糊の付いた看護衣の、長い四角い顔の、スリッパを穿いた男を想ひ出すのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私が衣食住してゆくといふことの上には大いに不便なわけである、それは年来の経験でいやが応でも知つてゐる。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも和服――特に浴衣を好んだ――を着、畳の上に正坐し、日本の煙管で刻煙草を詰めて吸ってた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寢衣をきて起きた僕と、暗い陰鬱な電氣の下で、約一時間ほど話をした。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう語つたあとで、顏も洗はず衣服も換へず、朝寢姿で訪ねたことの非禮を謝罪した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は馬場との約束どおり、午後の四時頃、上野公園の菊ちゃんの甘酒屋を訪れたのであるが、馬場は紺飛白の単衣に小倉の袴という維新風俗で赤毛氈の縁台に腰かけて私を待っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上衣をお脱ぎになって下さい。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸衣裳の用意も無い事はないのだが、それも一週間ほど前から申込んでいただかないと困るのです、という返事であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子の浴衣でした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、衣食住に就いては、全く趣味が無い。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに衣食住に凝って得意顔の人は、私には、どうしてだか、ひどく滑稽に見えて仕様が無いのである。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と母は父の汗づくになつた診断衣を脱がせながら言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりかうした作家たちが、詩や俳句を作るのは、飽食の後で一杯の紅茶をのんだり、或は労作の汗を流し、一日の仕事を終つた後で、浴衣がけに着換へて麻雀でもする気持なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や名も知らぬ虫の白き飛ぶ更衣野路の人はつかに白し絶頂の城たのもしき若葉かな鮒鮓や彦根の城に雲かかる愁ひつつ岡に登れば花いばら甲斐ヶ嶺や穂蓼の上を塩車　俳句というものを全く知らず、いわんや枯淡とか、洒脱とか、風流とかいう特殊な俳句心境を全く理解しない人。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更衣野路の人はつかに白し　春着を脱いで夏の薄物にかえる更衣の頃は、新緑初夏の候であって、ロマンチックな旅情をそそる季節である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいにく、私のところも、出張中で。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「緊張の足りないところもあるだろうねえ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
