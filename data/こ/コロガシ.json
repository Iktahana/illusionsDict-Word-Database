    "definitions": [
      {
        "index": 1,
        "gloss": "rolling (something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人間が球を飛ばせたり転がしたりする遊戯の種類が一体どのくらいあるか数え切れないほどあるらしい。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家畜の糞を丸めてボールを作り転がし歩く黄金虫がある。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の消えない吸殻を掌に入れて転がしながら、それで次の一服を吸付けるという芸当も真似をした。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風景にしても壊れかかった街だとか、その街にしてもよそよそしい表通りよりもどこか親しみのある、汚い洗濯物が干してあったりがらくたが転がしてあったりむさくるしい部屋が覗いていたりする裏通りが好きであった。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど、坂の上から小さい雪の手玉を転がし落すと、坂の下まで来たときには大塊の雪団になっているようなものです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧も薄し、こちらからは吃驚するほど、大きく見た、が、澄切った藍色の空を遥に来たように、その胸から上半分の娘の方は、さも深そうに下の墓を覗いて、帽子を転がして、ぼんやりうつむいている多津吉を打撞ったように見ると、眉はきりりとしたが優しい目を、驚いた様に※りながら、後退りになって隠れたが。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　成程、中折帽を転がしている人間らしい。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いや思出せば、なおその昔、伜が腹に居ります頃、女房と二人で、鬼子母神様へ参詣をするのに、ここを通ると、供えものの、石榴を、私が包から転がして、女房が拾いまして、こぼれた実を懐紙につつみながら、身体の弱い女でな、ここへ休んだ事もあります。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔醒にいいもの、と縁側から転がし出したのは西瓜です。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度のは余ほど大きいと見えて、投げると云うよりも、寧ろ転がし落したらしい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひょいと掌の上へ転がした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」氏は斯う云い乍ら床の間の奥から今まで私の眼に見えない処へ転がしてあったメロンを取出して来て、器用に皿へ載せナイフで割った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさあお起ッたらお起きナ、起きないと転がし出すよ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッパッと田舎の親仁が、掌へ吸殻を転がして、煙管にズーズーと脂の音。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "源助、それ、近々に学校で――やがて暑さにはなるし――余り青苔が生えて、石垣も崩れたというので、井戸側を取替えるに、石の大輪が門の内にあったのを、小児だちが悪戯に庭へ転がし出したのがある。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家数四五軒も転がして、はい、さようならは阿漕だろう。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、ぐるぐるまきのがんじがらみ、や、このしょで、転がし出した。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんは、身体を反り曲げて、おっほほと笑うと、何か歌の一くさりでも歌うように咽喉を転がした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして急いで、山の上へかけあがって、さかんにたき火をこしらえて、その火の中で、いのししのようなかっこうをしている大きな石をまっかに焼いて、「そうら、つかまえろ」と言いながら、どしんと、転がし落としました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "野袴をつけた若者が二人、畠の道具を門口へ転がしたまま、黒燻りの竈の前に踞んで煙草を喫んでいる。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで頸を押えて、項まで棒を転がして行って、頭の直ぐ根の処を掴むのです。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもまだ不安心ですから、そのからだを押し転がして、川のなかへ突き落して置いて、自分もあとから続いて飛び込もうと思いましたが、また急に考え直して、町の警察へ自首するつもりで暗い路をひとりで行く途中、ちょうどあなたにお目にかかったんです。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "叩いてみても、転がして見ても、それは確かに青い西瓜である。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず残存している教会堂を毀つとともに、大久保｜忠隣を奉行として近畿に送り、所司代板倉｜勝重と協力して、切支丹の嫌疑のある者を残らず捕縛さし、それを一人一人｜菰に巻いて、四条から五条の磧に三十｜石積、五十石積と云うように積んで、それを片っ端から転がした。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおけに」　熱い餅を掌の上へ転がしながら、横堀は破れたズボンの上へポロポロ涙を落した。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえが躓かせて、打ち転がしたんじゃねえか？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し細くて長いと、この指環を嵌めてやるんだが……それに爪が……」　彼は眉を寄せるようにしながら、掌の中に指環を振り転がした。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲鳴はやんでいたが、夫人は気を失って長椅子の上にのびており、もうひとりの方は片足を肘掛椅子の手すりへだらんと懸け、頭を炉格子の端近くの地面に転がしたまま、血だまりのなか、あいにく事切れていた。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "又少し離れた處には大きな土管がいくつも砂利の上にころがしてあつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "槓杆の効用は人の知る通り、昔の力学者が「適当な支点を与えてくれれば地球もころがして見せる」と威張ったのは槓杆の効能を極端に云ったものである、だから適当な槓杆と支点を与えれば虻の力で大象も動く、美人の繊手で横綱も釣上げられる。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
