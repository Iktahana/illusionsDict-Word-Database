        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんちは、こんちは！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さちよを見て、「こんちは。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽつぽは、「すゞ子ちやん／＼こんちは。",
              "citation": {
                "source": "ぽつぽのお手帳",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すゞ子ちやん私もこんちは。",
              "citation": {
                "source": "ぽつぽのお手帳",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽつぽはよろこんで、「すゞ子ちやん、すゞ子ちやん、こんちは。",
              "citation": {
                "source": "ぽつぽのお手帳",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すゞ子ちやん、こんちは、ぽッぽゥ、ぽッぽゥ。",
              "citation": {
                "source": "ぽつぽのお手帳",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カア、カア、こんちは。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の戸ではない、格子戸を開けたときの、前記の声が「こんちは、あの……居らっしゃいますか。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」訳して、「こんちは、あの、居らっしゃいますか。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんちは」　といふ低い叮嚀な聲である。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山薪炭はそばへよっていって、「こんちは、君ひとつ花子さんの町までいって貰えないかね。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこちらで何かやさしい事を言ってやれば、向うでもやさしい事を返してくるのじゃ」少年「おもしろいなあ」少女「兄さん、何かやさしい事を言って御覧なさい」少年（山に向い）「こんちは、ごきげんはいかがですか」山彦「こんちは、ごきげんはいかがですか」少年少女顔を見合せて笑う。",
              "citation": {
                "source": "春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉子売りのときのように知らない家の水口から一太が一人で、「こんちは」と訪ねるのではない。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かすかにかち合う壜の音と「こんちは」と呟く低い声がするのである。",
              "citation": {
                "source": "冬日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は一度でも、「こんちは」とか、「御めん下さい」とかいったためしがない。",
              "citation": {
                "source": "母親",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は這入ってゆくにも足音を忍ばせて、こんちはも言わないで壁にゆく。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば肴屋の小僧などの「こんちはア」と云ふ言葉に。",
              "citation": {
                "source": "僕は",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけて、入って、高い声で、「こんちは――いませんか」　呼んでいる。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪で生れたから、生れた時から、掌を握っていたとか、二つの時に「こんちは、儲かりまっか」と、云ったとか――いつまで、経っても、贅六根性が抜け無いものか？",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "益満から固く口止めされているのに――）　と、南玉が、乱れかかる心を、じっと、両腕で押えた時「こんちは」　富士春の声であった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤木の妻の嘉代さんが、「仲本の新治さんじゃないか、挨拶をなさい、」と促すと、彼女はにやりと笑って、「こんちは、」と言った。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんちはア」とかう言ひながら、四十五六の年配で鼻ひげなども生やしたくせに、御用聞と同じやうな笑ひ方して、左様、丁度その日の午頃であつたが、なにがし商店の店先へ顔をだした男がある。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓが、こんちは、というときの国のあの「あ」という顔を思い合わせ、Ｓ一しお可哀そう。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、「こんちは、まっぴら御免下さいまし」　障子の外から猫撫声がしました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイケル彼女の通りみちをあけようとして傍に退いて立つ）老女　　こんちは。",
              "citation": {
                "source": "カスリイン・ニ・フウリハン（一幕）",
                "author": "CATHLEEN NI HOOLIHAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピイタア　　こんちは。",
              "citation": {
                "source": "カスリイン・ニ・フウリハン（一幕）",
                "author": "CATHLEEN NI HOOLIHAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤ずきんちゃん、こんちは。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
