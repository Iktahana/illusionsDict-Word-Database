[
  {
    "uuid": "bcb18645-9628-5aae-937d-1c29a71fbbce",
    "entry": "国粋的",
    "reading": {
      "primary": "こくすいてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
