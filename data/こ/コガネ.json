[
  {
    "uuid": "3dc1ac84-9bf3-51a2-8284-f607b98a1242",
    "entry": "小金",
    "reading": {
      "primary": "こがね",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
