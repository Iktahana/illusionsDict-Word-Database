[
  {
    "uuid": "433ca16c-a71f-5c7c-a57e-25abf3ea22d2",
    "entry": "呼吸困難",
    "reading": {
      "primary": "こきゅうこんなん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
