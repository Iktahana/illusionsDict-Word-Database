    "definitions": [
      {
        "index": 1,
        "gloss": "cultivated land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "イタリアンとの混血児の上海からこの土地に稼ぎにやってきた踊子の鳩胸、その偉大な女性の耕作地にこだまするサキソフォンの反響、かの女は、いつも踊場に蜜月の旅をつづける。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその電気事業のために、蕃人の家屋や耕作地を没収しようとしたのだ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　一望の耕作地、鈴谷平野。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、この第四のパンクの時に、それこそ私たちはもう曠々とした平野の耕作地に辷り込んでいた私たち自身を見た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大西洋のある島の耕作地でやはり人間が紛失する。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "赭土の飛沫を運ぶ春先の暴風に、自然の屏風を備えたこの地帯は、部落中での優良な耕作地であった。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は何んの躊躇もなしに、小作人達からその耕作地を取上げ、そして更に地代を上げて、借手の出るのを待つことにした。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し高い所からは何処までも見渡される広い平坦な耕作地の上で二人は巣に帰り損ねた二匹の蟻のようにきりきりと働いた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しがたの煙草耕作地での出來事は彼の眼にも心にも灼きついてゐた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうするには先づ耕作地そのものからして共同の管理に移さねばならぬし、負擔を均等にすれば、生産の結果の配分をも均等にせねばならぬ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面はいかにも、耕作地の不足してゐる百姓が、不利な條件を忍んでも新しく小作地を得たいと望んでゐるといふ、ただそれだけのことですが、事柄の實際は、たとへ小さくても農村の生産力の問題に關係してゐると思ひます。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも耕作地は増えない。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "電力は二二〇億キロワットに、集団農場の耕作地面は二〇〇万ヘクターになるだろう。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊11　三圃農作　ロシアで最も普通に行われる耕作地の用い方で、最初の年に秋蒔麦を作り、次ぎの年に春蒔麦を作り、第三年目は農作を休んで、翌年から又、前述のように繰り返して農作をする方法である。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の話題は――鹿爪らしく切り出せば、土地整理問題、耕作地の半分は地主の所有地であるこの村の小作状況、それに起って来る経済の問題。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れが北と東へ広く伸びるに従つて、大小の山脈が無尽の森林地帯を重畳し、本流だけでも六百邦里に及ぶ松花江が豊饒な耕作地帯を形成してゐる事を想ふと、北満の未来は経済的に甚だ価値の高いものなのであらう。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてしもなく続いてる荒地の中に、狭い耕作地が散在し、粗らな木立や灌木の茂みも所々に見え、その間を、一筋の街道が真直に続いている。",
              "citation": {
                "source": "真夏の幻影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の手に成った耕作地か？",
              "citation": {
                "source": "真夏の幻影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕作地は陽炎の息を吐き、草原は凋びきって色褪せた匂いを立て、樹木の葉は力無げに垂れ下り、街道は白い埃に埋っている。",
              "citation": {
                "source": "真夏の幻影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の書物の中に、方々の耕作地や、牧場や、山林や、港やの写真が沢山載つてゐた。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような思い出を、彼、岸本省平が焼け跡のけちな耕作地の中に見出したのは、何故だかよく分りません。",
              "citation": {
                "source": "白蛾",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、この焼け残りの人家の聚落と焼け跡の貧しい耕作地との中から、静かに立ち現われてくる女があるとしたら、それは彼女のような者であらねばならないし、他の種類の者であってはならないと、そのようにも思われるのでした。",
              "citation": {
                "source": "白蛾",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼け野原はもう、処々に雑草の茂みを作りながら、小さく区切られた耕作地となり、麦や野菜類が生長していました。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼け跡の耕作地をまだらまだらに被っている淡雪を見ながら、木原は言いました。",
              "citation": {
                "source": "道標",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちこちに瓦礫の堆積があり、いら草の茂みが冬枯れのままに残り、小さく区切った耕作地には、麦が伸びあがり蚕豆の花が咲きだしている。",
              "citation": {
                "source": "白木蓮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が好んで身を置くところ、というよりは寧ろ、好んで身を隠すところは、焼け跡の耕作地でした。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で彼は、立ち後れながらも、あちこちに耕作地を占拠しました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一人で、時には淋しい憂苦に浸って、時には白けきった放心状態にあって、彼は耕作地の野菜を育てました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲み残しの焼酎を少し飲んで、直吉は自分の耕作地へ出かけました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "直吉は帽子を投げ捨て、強い陽光の中につっ立って、耕作地を見渡しました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
