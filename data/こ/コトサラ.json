        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "咲きおくれた桔梗の紫が殊更鮮かだ。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして殊更空の光が白く冷たかった。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし量子的の考えを用いずしてすべての現象が矛盾なしに説明され得るのであったら、何を苦しんで殊更に複雑な統計的の理論を担ぎ出す必要があるであろうか。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊更に家庭の円満とか家庭の趣味とか、八釜しく云うことが、却っておかしく思われて居った。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのずから人前を憚り、人前では殊更に二人がうとうとしく取りなす様になっている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "百八煩悩おのづから消えばこそ、殊更に何かは消さん。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し短くつまった顔の特殊なポオズも、少しも殊更らしくなくてただ気高いような好い心持がするばかりである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二個分の代価を払って、破片と、そうして破れないもう一つをさげて来るのも何だか殊更で、そこに説明の出来ない無理があるように思われる。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、私があの素ばらしい芸術に接して、どんなに驚異と嘆美の瞳をみはつたかと言ふことは、殊更らに言ふまでもないことであらう。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そんな氣配を今日殊更に先生にお見せるのは厭やだつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」おしかは殊更叮寧な言葉を使った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女事務員が為吉にだけは親切だったように、園子は両人に対して殊更叮寧だった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れかゞ金を紛失した場合、殊更、帳尻を合わしていない者に嫌疑が掛って来た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗本は、一本の藁にでもすがりたい気持をかくして、殊更、気軽く、「こっちの中尉がメリケン兵を斬りつけたんが悪かったんかい？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、山崎が、いつかの冗談への応酬をしていると感じながら、殊更、気づかぬ振りをしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊更、注意深く、工人達を観察した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁助は、従弟が皆に笑われたり、働きが鈍かったりすると、妙に腹が立つらしく、殊更京一をがみがみ叱りつけた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚き火の傍へ行って、殊更らしく訊ねかえすと、他の労働者達に笑われるので気が引けた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを殊更に醜く擴大した私自身のポンチ繪を見せつけられる樣な悔辱を感じる。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨模樣の空の間から射し出す太陽がいやに蒸暑くてあの單調な路が殊更長く思へた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は一度｜殊更に火鉢の傍に行って烟草を吸って、間の襖を閉めきって、漸く秘密の左右を得た。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は一度殊更に火鉢の傍に行って烟草を吸って、間の襖を閉めきって、漸く秘密の左右を得た。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ千年の深林を滅し、人力を以て自然に打克んが為めに、殊更に無人の境を撰んで作られたのである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲く花に人の集まる処を廻ったり殊更に淋しい墓場などを尋ね歩いたりする。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞くと子供はつけこむやうに殊更声を曇らしながら身悶えした。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊更らにその輪廓の大きさと重々しさとを増した蝦夷富士は、鋼鐵のやうな空を立ち割つて日の出る方の空間にそゝり立つてゐる。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の莊嚴さを持たない裸樹はぎこちなく筋ばつた枝を空に張つて立並び、糊を塗りつけたやうにべた／＼な黒土の上には、芥と枯葉と枯草とがいぎたなく粘り着いて居り、もうすつかり春らしくなつて來た大空に對し殊更ら憐れな對照を作る。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車窓を隔てゝゐる爲めに、聲が少しも聞えないので、殊更ら私の感じを不思議なものにしてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い額と、高く長い鼻と、せばまつた眉の下でぢつと物を見入る大きな隻眼とを持つた彼れの顏は、その日は殊更らに緊張してゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことさらに、映画と小説を所謂「極致」に於いて同視せずともよい。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
