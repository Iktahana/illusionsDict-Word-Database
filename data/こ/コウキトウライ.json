        "examples": {
          "standard": [
            {
              "text": "長い努力が実を結び、ついに好機到来とばかりに彼のビジネスは成功した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームは連勝中で、まさに好機到来、この勢いを逃してはならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい市場への参入は、我々にとってまさに好機到来だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "折からマニラのイスパニヤ商人達は、日本に於けるポルトガル商人の勢力を駆逐して貿易を独専したいと思つてゐたので、ポルトガルと関係密接なゼスス会凋落の報に好機到来と見て、自国の宗派によつて日本教会の再興をはかり、貿易の便宜を得ようといふ魂胆をもつに至つた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちヘロデヤのために好機到来、ヘロデ王の誕生祝いの座興として己の連れ子たる少女を踊らせ、それに対する褒美として洗礼者の首を求めさせました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
