    "definitions": [
      {
        "index": 1,
        "gloss": "to droop (e.g. ears of grain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "望んであまりに遼遠なるが故に、深く頭を垂れるのである。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "文枝――……（伏目になって頭を垂れる）　東山――文枝さん！",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は頭を垂れるように心を垂れた。",
              "citation": {
                "source": "春は馬車に乗って",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は其前に頭を垂れる心を持つべきではないだろうか。",
              "citation": {
                "source": "追慕",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪魔は畢にクリストの前に頭を垂れるより外はなかつた。",
              "citation": {
                "source": "西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は生きてゐた」といふ感慨の前に、われわれは頭を垂れる。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "定は静かに頭を垂れると次々にその創痕に唇を当てて行つた。",
              "citation": {
                "source": "水に沈むロメオとユリヤ",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "須永　いや、そんな……（省三の激しい視線を受けかね、助けを乞うように次の浮山を見る）浮山　……だけど、田舎にお母さんや弟さんも有ると言うんだから、この――須永　…………（恥じて頭を垂れる）省三　だけど、それをそういう形で解決しようとするのは間違いだ！",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "不憫ではあるが、生きて耻辱を蒙るより、この私に取つても、どれほど嬉しいことか判らない、――辱けないぞ」　内匠は格子に縋るやうに、宙に向つて頭を垂れるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十手の道",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飛んだお騷がせして相濟みません、――みんな私のせゐで――」　と頭を垂れるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "正月の香り",
                "note": "青空文庫"
              }
            },
            {
              "text": "不憫ではあるが、生きて恥辱を蒙るより、この私にとっても、どれほど嬉しいことか判らない、――辱けないぞ」　内匠は格子に縋るように、宙に向って頭を垂れるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十手の道",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ姿を見せないところを見ると、たぶん悪者に攫われたのであろう」　半之助はそう言って暗然と頭を垂れるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "狐の嫁入",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分に不当な苦痛や罵詈を与えた者達は、最後まで正しかった者の死屍に対して、どんな悔恨に撃たれながら、頭を垂れるだろう、白い衣を着せられ、綺麗な花で飾った柩に納められた自分が、最後の愛情によって丁寧に葬られる様子が、まざまざと目前に浮み上って来て、涙は一層激しくこぼれる。",
              "citation": {
                "source": "地は饒なり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、不正だと思うものの前には、私はどんなことがあっても頭を垂れることはありますまい。",
              "citation": {
                "source": "地は饒なり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはただ頭を垂れることを知るのみですぞ」　それから、彼はちょっと眉をよせて、しかし態度や声の調子は少しも変えずに、つけ加えた。",
              "citation": {
                "source": "青玉の十字架",
                "author": "THE BLUE CROSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ガクリと頭を垂れる。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い光りがティンタジェルで見えても、主がなされたことです」　頭を垂れる様は、心の祈りを黙祷しているかのようであり、頑固さと狂信が入り交じった表情は、メアリが以前見た顔だ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……由紀はそう心に誓いながら、客間へ戻ってゆく良人のうしろ姿へしずかに頭を垂れるのだった。",
              "citation": {
                "source": "日本婦道記",
                "author": "藪の蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人もまた同様、しずかにこうべをたれると、そっと目がしらを押しぬぐいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            }
          ]
        }
