        "examples": {
          "standard": [
            {
              "text": "山間部には、巨大な鉄塔に支えられた高圧電線が張り巡らされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "作業員が高圧電線の点検作業を行っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雷が高圧電線に落ち、広範囲で停電が発生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "高圧電線の支柱の所まで来ると、川から直角に掘り込んで来た小さな溝渠があった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五五（昭和三十）年、稲盛和夫は鹿児島大学工学部応用化学科を卒業し、高圧電線用の碍子メーカーである京都の松風工業に入社した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ地中のあちこちに高圧電線を走らせるだけだ。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由はここのトンネルが崩落してひん曲がり、あたり一帯に高圧電線が張り巡らされ、触れれば死ぬからだ。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
