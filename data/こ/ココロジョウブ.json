        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また、楽しい心丈夫な気持もする。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレットも、こんなにどしどし立派な後継者が出来て、心丈夫の事でしょう。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妓はふるえあがって心の中で念仏を唱えながら、婢に縋りつくようにして歩きあるき、やっと停車場へ往ったところで、待ちあわしている乗客の中に、やはりとんだ屋の客の一行がいたので心丈夫になった。",
              "citation": {
                "source": "とんだ屋の客",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまさか通りがかりの人声の、小荷駄馬でも曳き、蓆でも着て、裏の岨路を、えつちやほう、はいしとうとうと叱りながらに上り下りする、耳につき、つい目につくのも心丈夫な思ひがする。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だが、心丈夫ですな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生点けっぱなしにしない電燈が点いているのは老人がもう起きている証拠だと思って政雄は心丈夫に思った。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し其れ丈でさへ卯平は始終財布の錢の出入するのを心丈夫に思ふのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "不器用な少し動けば轉け相な繃帶であつたが夫でも勘次の目には心丈夫であつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お松も実は余り心丈夫でもなかったが、半分は意地で強そうな返事をした。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは追々年を取るばかり、お前たちは若しと云ふもので、ここに可頼い親類が有れば、どれ程心丈夫だか知れんて、なう。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究という点においては、決して東京の連中に負けはしないと、俺はあの研究室を見た時に、まったく心丈夫に思った。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えゝ、もう、それは尾原はあの若さですが、あたしは心丈夫で……。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな百姓でも、無知な人間でも、戦争ッていえば一生懸命ですからな……天子様も国民の後援があって、さぞ御心丈夫でいらっしゃるでしょう」と感嘆したような調子で言って、「日本は昔からお武士でできた国ですからなア！",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗賊や鬼はおろか、山犬に出逢っても果たして十分に警護の役目を勤めおおせるかどうだか、よそ目には頗る不安に思われたが、藻に取っては世にも頼もしい、心丈夫な道連れであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "提督が司令塔にお詰めくだされば、わが飛行島の当直全員もたいへん心丈夫です」　スミス中尉は、提督が悪夢におびえて睡られなくなったのだとは知らないから、リット提督が司令塔へ出かけるようでは、今夜はよほど警戒しなければならぬわけがあるのだと思った。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんにちと違いまして、その頃に一万人の兵があれば心丈夫です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だつて今夜はお前と同じ状態なんだ――と云つたら、お前も心丈夫だらう、何しろ、愛国心には予算はないからね。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに人の子にはやはり遠慮勝ちで……せがれに嫁でも貰って置いたら、こんな時にはさぞ心丈夫だろうと思います。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　笹村は心丈夫そうに笑って見せた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがにまだ夏の監獄の気が抜けずにいるんだと思って心丈夫に思って居たら、大晦日の晩から下り出して、とうとう本月の初めまで下痢で通した。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはしっかりした心丈夫な気がします。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃は、幸健康も確らしくなって来て居るから又とない心丈夫な事である。",
              "citation": {
                "source": "偶感",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は出来上りかけている製作をなほ子に見せながら、「姉さんいて呉れると、どんなに心丈夫だか分らない――話んなりゃしないんだから、間抜けばっかりで」と云った。",
              "citation": {
                "source": "白い蚊帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄は、このにほひが全身を以つて嗅げる限り、自分の神經は、他のもの等の習慣的に鈍り切つたのよりも、また鈍り切らないまでも部分的なのよりも、まだ／＼鋭敏に全人的な努力をしてゐるのだと心丈夫に思つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、その代り、反對的にでもカントやエマソンをそばに控へない放浪の身でありながら、今持つてゐる思想をまとめ得られるのは、自分の精神と神經とに獨創の情想が出來てゐるからであると、自分で心丈夫に思ふ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄は北劍の落ち入つてしまひさうな運命に思ひ合はせて、自分も渠と共に第二のアイノ人の部類に這入つた樣な幻影を浮べたが、その滲憺たる幻影の中にも自分はまだ最後の努力をしてゐるのを心丈夫に感じつつ、大通りに添うて東に進み、北一條に曲り、東二丁目に、遠藤の指定した人を訪問する。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、朝来た巡査は、今夜は御宅の周囲を注意して置きますと云って呉れた事を思い出してからは、益々心丈夫にならない訳には行かなかったのである。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、わたくしも、こころじょうぶですわ。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
