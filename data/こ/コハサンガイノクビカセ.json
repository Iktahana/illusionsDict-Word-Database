        "examples": {
          "standard": [
            {
              "text": "子は三界の首枷とは言うけれど、それもまた親としての喜びなんだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもが成人しても、親は子のことが心配でたまらない。まさに子は三界の首枷だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は「子は三界の首枷だから、まだ自由な時間が欲しい」と言って結婚をためらっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "東　子は三界の首枷西　これにこりよ道西坊　欲界より色界無色界に至りても、親子は恩深ければ、枷鎖相纏はりて脱せずといへるは東のなり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "子は三界の首枷なり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
