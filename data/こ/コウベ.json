    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Kobe (city)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "感想中原中也　地方の詩のグループも多いことだが、どういふものか、ずつと以前から大連と神戸にだけ面白いものが見られるのだつた。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "残夢再びさむれば、もう神戸が見えますると隣りの女に告ぐるボーイの声。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論その頃はまだ東海道鉄道は全通しておらず、どうしても横浜から神戸まで船に乗らねばならぬ。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海から近づいて行く函館の山腹の街の灯は、神戸よりもむしろ香港の夜を想わせる。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長ガ無電ヲ神戸港ノ司令部ニ打ツ　兵来リテ汽車ニテ○○へ急グ　航行中ノ運送船ヨリ縄梯子ヲ降シ、モーターボートヨリ兵乗リウツル。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会と郊外の境界線にある中流のホテル、時刻は東京駅を十時五十五分の神戸行急行列車の発車すこしまえの混雑時だった。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」啜泣くのをやめると、栗鼠の毛皮の外套をつけた女は、コンパクトで化粧をなおしてから、「――あたし神戸だわ、でも明夜の十時五十五分の列車で妾帰ります。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと神戸の元町のボントン・バーにいた、肥太った女がひどく酔って悪臭を放っていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　神戸――Ａオリエンタル・ハウスの踊子が私を占う。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・ハヤミの奴、大理石の経帷子きこんで昨夜｜晩く神戸へ行ったぞ、おい、君。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "空しく、僕は欧洲行の船を棄てて、マダム・ハヤミを追って神戸行急行列車に乗り込んだ。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――午後から神戸へ阪急電車で私はチタ子を連れて行きました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは姓と結び合せて自分を宮城縣人と思ふ人もあるらしいが、たゞ生誕の地といふだけで、三ヶ月後には仙臺を去り、それから土木技師である父の轉勤につれて東京・神戸・熊本・博多・長崎と轉住した。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸にゐた三歳の時器官支カタルがこじれて喘息が持病になり、とりわけ少年期から青年期にかけては三日おきぐらゐにくるその發作にみじめなほど惱まされた。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京や横濱、神戸、大阪などで、私は度々支那料理を食つてみた。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの神戸で頼んだ行李は盗まれやせんのじゃろうかな？",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十九聯隊の兵士たちは、神戸地方から入営している。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船で神戸まで来て、神戸から姫路へ行った。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わかったとも、大わかりだ、」と楠公の社に建てられて、ポーツマウス一件のために神戸市中をひきずられたという何侯爵の銅像を作った名誉の彫刻家が、子供のようにわめいた。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中漸く神戸行が新橋から來た。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "高知から三、四百トンくらいの汽船に寿司詰になっての神戸までの航海も暑い旅であった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛烈な日貨排斥運動に、皆目売れ口がない神戸マッチを輸入して、関税や、賦金や、附加税を取られるよりは、労働賃銀が安い支那人を使って、全く支那の製品と違わない「国産品」を、支那でこしらえ支那で売る方がどれだけ合理的なやり方か知れない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ東京を立って横浜までは汽車で行ったが、当時それから西はもう鉄道はなかったので、汽船で神戸まで行くか人力で京都まで行くほかはなかった。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜であったか、神戸であったか、それすらはっきりしないが、とにかくそういう港町の宿屋に、両親に伴なわれてたった一晩泊まったその夜のことであったらしい。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ西洋へ出発となって神戸まで行ったらあす船に乗るという日に、もう前歯の前面に取り付けた陶器の歯が後面の金板から脱落した。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてて神戸の町を歩いて歯医者を捜してやっと応急取り付け法を講じてもらったが、ベルリンへ着いてまもなくまたいけなくなった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エナメルの靴を穿かせて、細い、黒いステッキを持たせて、神戸の山の手や海岸通りを歩かせてみた。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸なる某商館の立者とはかねてひそかに聞き込みいたれど、かくまでにドル臭き方とは思わざりし。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後大学生時代に神戸と郷里との間を往復する汽船の中でいつも粗悪な平円盤レコードの音に悩まされた印象がかなり強く残っている。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はなぜこうべらべらしゃべってしまうのだろう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
