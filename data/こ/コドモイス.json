        "examples": {
          "standard": [
            {
              "text": "レストランには、子供用の椅子が用意されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この子供椅子は、高さ調節ができるので便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖母が、孫のために手作りの子供椅子をプレゼントしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "マニーロフの子供で、どちらも食卓に列なることは許されても、まだ高い子供椅子に掛けさせられるといった年頃だ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
