    "definitions": [
      {
        "index": 1,
        "gloss": "extinct plants and animals",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
