        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに本間の死んだことも聞かしてやったら、十に九つはこっちの物だ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようがす」　十に九つはこっちの物だという顔をして、松吉は威勢よく出て行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅かれ早かれ、こっちの物よ」　吉五郎は冷えた猪口を飲みほして、自信があるように微笑んでいると、兼松もおなじく得意らしく笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこっちの物だと云うような軽い心持になって、彼は堤のまんなかを飛んでゆく燕の影を見送りながら、ひとりで涼しそうにほほえんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜お前たちはあの砲台を、こっちの物にしてしまうのじゃ。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "22「ふん、こうなりゃアこっちの物さ。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの物にしようと考えているうちに、相撲に取られてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん別々の配給生活にして、大根一本やらないけれども、同じ屋根の下にいるから、子供たちは、こっちの物を盗み食いする。",
              "citation": {
                "source": "淪落の青春",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、電話の番号帳により、キヌ子のアパートの所番地を調べ、ウイスキイ一本とピイナツを二袋だけ買い求め、腹がへったらキヌ子に何かおごらせてやろうという下心、そうしてウイスキイをがぶがぶ飲んで、酔いつぶれた振りをして寝てしまえば、あとは、こっちのものだ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の、味方にしようと思えば、こっちのものなんざ皆味方さ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあ、こいつはきっと泥棒だ、そうでなければにせ金使い、しかし何でもかまわない、万一途中相果てたなれば、金はごろりとこっちのものと、六平はひとりで考えて、それからほくほくするのを無理にかくして申しました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいうものの鶴原家がこの鼓を売るわけはないし、どんなに考えてもこっちのものにする工夫が附かなかったので、おれはそのあくる日中野の鶴原家に鼓を持って行って奥さんに会ってこんな嘘を吐いた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちのものを、あっちへ持ち運び、あっちのものを、こっちへ持ち運び、まるで同じ事を繰り返して、独りで、てんてこ舞いをしているのである。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "取組めば、こっちのものだと、助七にはまだ、自信があった。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛は笑傾け、「旨いな、涙が出ればこっちのものだ、姉や、ちっとは落着いたか、気が静まったか。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「散々気を揉んでお前、ようようこっちのものだと思うと、何を言ってもただもうわなわな震えるばっかりで。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこっちのものだと言わないばかりに、権右衛門は頤の髭をかえして又言った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこれが出りゃこっちのものなんだッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると、なにかこの事件にひっかかりがあるかもしれねえなとにらみがついたから、ちょっと右門流の細工をしたまでさ」「ありがてえッ、そうと聞きゃ、もうこっちのものだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "神代直人が斬ろうと狙ったら、もうこっちのものじゃ。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうこっちのものだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきのどくだが、今度だけはこっちのものだぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "星雲先生は喜んで引き受けられたから、遠からず出来上って来るはずとか何とか報告して拍手させてしまえばもうこっちのものです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見て相手も立ち上れば、もうこっちのものだという。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして素破という場合にはいつ何時でも、手と身とツンツンで飛出しさえすればこっちのものになるというわけである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四百人が一緒になれば、もうこっちのものだ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "金にして持ってしまえば、こっちのものだった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといったって、大統領となってしまえばこっちのものだ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッ、ハッ、ハッ、邪推でござるよ」――お京様はどうせこっちのものだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まずあの女もこっちのものだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
