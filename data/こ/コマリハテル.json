          "literary": [
            {
              "text": "Ｔ「さすれば源兵衛貴様は打ち首」　と言われて源兵衛愈々困り果てる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "着手の処　着手の処が分らない教は、いかに崇高な教でも、荘厳な教でも、正しくて完璧な教でも、教えられる者にとっては差当たり困り果てる訳である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑務所から晴れて出て来たんだから、まことに結構なわけで、困る事なんかすこしもない筈だが、かれ烏啼は大いに困り果てるのだった、というのはこの義弟｜的矢貫一なる青年は一に二を足して三になったほどの非常に単純な男であった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が日本は非能率の條件に滿ちた國であつて困り果てる。",
              "citation": {
                "source": "素人圖書館人の手記",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
