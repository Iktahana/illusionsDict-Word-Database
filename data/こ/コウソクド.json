[
  {
    "uuid": "1481cb32-553e-5d0e-b4fb-bd68ac032d0d",
    "entry": "高速度",
    "reading": {
      "primary": "こうそくど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
