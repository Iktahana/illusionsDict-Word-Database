[
  {
    "uuid": "964c5b6b-11aa-56e4-9001-c537d773ebd7",
    "entry": "虎穴",
    "reading": {
      "primary": "こけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
