    "definitions": [
      {
        "index": 1,
        "gloss": "thoughtfulness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
