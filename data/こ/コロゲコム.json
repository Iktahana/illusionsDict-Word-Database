[
  {
    "uuid": "5ad7b389-9fe8-56bb-aafb-407038d0cfe4",
    "entry": "転げ込む",
    "reading": {
      "primary": "ころげこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to roll or tumble into",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大抵の地震が来たところで、このバラツクならば大して驚くこともないと多寡をくゝつて、わたしが真先に寝床へ転げ込むと、かみさんや娘も気味を悪がりながら寝てしまひました。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」佐伯は、障子をがらりと開けて転げ込むようにして部屋へはいった。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはおまえの肉体も諦めるし、わたしの結婚の申込なぞ、おまえがいろ／＼探して試みてよいところが見付からず、最悪の場合に転げ込む休息所として、数多い中に一枚加えといて呉れゝばそれで有難いと思っている。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行って今夜は泊めて貰おうと思いついて、転げ込むようにそこの門をくぐると、帳場でもおどろいた。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはずみに倚りかかっている襖がみりみりと揺れたので、彼女は這うようにそっとそこを逃げ出して、自分の部屋へあわてて転げ込むと、気味の悪い汗が頸筋から腋の下に湧き出しているのに初めて気がついた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "村瀬がふら／＼と眩惑を感じて、部屋の中へ転げ込むと、中で待ち構えてゐた大森と加藤が、「くすりが利き過ぎたかね、村瀬さん！",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼は夢中で逃げ出すと、あたかも自分の家の前に出たので、やれ嬉しやと転げ込むと、母も兄もその血みどろの姿を見てびっくりした。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏像はおそらく師匠の袂かふところに入れてあって、ここへ転げ込むときに水のなかへ滑り落ちたのを誰も見つけ出さなかったのであろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "狐と僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "剽軽な英吉利兵は麦酒壜を両腋に抱へ込むで、自分の塹壕へ転げ込むださうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "王様は転げ込むやうにその上へ横になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "句会から宴会、十時すぎて、私は一人街へ出た、酔ふた元気で、銀座のカフヱーに飛び込んだりしたが、けつきよく、こんな服装では浅草あたりの安宿に転げ込むより外なかつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ転げ込むか分ったものじゃないよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何とも言いがたいそのにおいの懐かしさにそのまま蚊帳の裾をはねて寝床に転げ込むと、初めの内はやさしく私を忍ばせたお前が何と思ったか寝床に横たわりながら「あなたあっちいってお休みなさい。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、その腕へ、転げ込むやうに、姉の千登世がからだをのり出して来た。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "配達夫、はづみを喰つて、転げ込む。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑波にゃ仏の滝次郎、いい顔の貸元で、つき合いの日は浅えが妙な縁で江戸で呑み分けの兄き分がいるから、どうせそこに転げ込むんだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉でも鮒でも構わないが、ここに魚がありさえすりゃ、三万両と転げ込むんだが、無住になった寺方じゃ、鰯の頭もねえ――」「黙らないか、八」　平次は八五郎の饒舌を封じて、凝と庵室の中を見廻しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "北冥の魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "露月町の大工の棟梁、辰五郎というのは、八五郎が銭形のところへ転げ込む前、しばらく世話になった男で、年は若いが侠気も思慮もあり、水茶屋の看板娘など争って、人を殺すような人間でないことは、銭形の平次も薄々知らないことではありませんでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "美女を洗い出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい遺産は、別居して居ると言っても、まだ離婚の手続を履んで居ない、夫人の浪子のところへ転げ込むでしょう。",
              "citation": {
                "source": "流行作家の死",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「土手の外へ転げ込むより外に工夫はありませんが、道傍の柳は植えたばかりのヒョロヒョロで人間を一人隠せそうもないし、所々にある茶屋は、夜っぴて商いをして居るか、宵だけで仕舞って帰るにしても、葭簾張りの見通しだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "髷切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "囚人は、兵士の前に転げ込むような恰好になって、兵士を見上げながら、身をよじって、かちゃかちゃという鎖の音を立てた。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑波にゃ仏の瀧次郎、いい顔の貸元で、つき合いの日は浅えが妙な縁で江戸で呑み分けの兄き分がいるから、どうでそこに転げ込むんだ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから伝公は気違いのようになって、湯屋湯屋と血眼で探して歩いたが、もう目眩と嘔吐気に堪らなくなったらしく、両手で頭を抑えたまま、真ッ青になって、自分の家に転げ込むや否や、「ウーム……」　と弓弦を張られたように身を反らして、柱の根元へ獅噛みついた。",
              "citation": {
                "source": "醤油仏",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは野育ちだからどうせ侍ではおさまるまい、もししくじって転げ込むようなことがあったら、これで舟宿の株でも買ってやって呉れ、そういうことでこれだけお預かり申しました」　仙吉はそこへ金を並べてそう云った。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、喜んで死刑執行を見に駆けてくるそれらの自由なそして看守などを知らない人々のうちには、その広場にいっぱいになる群立った頭のうちには、私の頭の後を追っていつかは赤い籠のなかに転げ込むように運命づけられてる頭が、一つならずあるだろう。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が、土間の中へ転げ込むと、女の影も、燈をふき消して、あわてて姿を隠してしまった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき高い笑ひ聲とともにドアがあき、飛騨と小菅が病室へころげこむやうにしてはひつて來た。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田に着いてからも篠つく雨は、いよいよさかんで、私は駅まで迎えに来てくれていた友人と共に、ころげこむようにして駅の近くの料亭に飛び込んだ。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は宝石鑑定家としては第一流の人間であって、他の宝石商からも鑑定に招かれたが、彼の鑑定した宝石が、時を経て彼の手中にころげこむことは、決して稀でなかった。",
              "citation": {
                "source": "変な恋",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車で京都へ、北朗居にころげこむ。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
