        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長時間同じ姿勢で座っていたら、首や肩が凝り固まってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寒さで体のあちこちが凝り固まってしまい、動きが鈍くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "緊張すると、全身が凝り固まってしまう癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
