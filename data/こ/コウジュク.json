    "definitions": [
      {
        "index": 1,
        "gloss": "ripening and turning yellow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
