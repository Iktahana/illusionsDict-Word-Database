        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "はなはだ無意味でつまらないようである意味で非常に進歩しているのはアメリカのナンセンス映画やミュージカル・コメディの類である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる新聞講談から茶番狂言からアリストファーネスのコメディーに至るまでがそうである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもこう寒いと、くしゃみばかり出て、せっかくの恋の道行もコメディになってしまう」　玄関の戸が内からひらかれた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならば考えても御覧なさい私はきのう　イリヤードと　ディビナ・コメディアをよむ。",
              "citation": {
                "source": "初夏（一九二二年）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オキュターブ・レネ 〔Rene'〕 のイラストレートしたディバァイン・コメディー大いによく、よんでみる気を起させた。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンテ「ディビナ・コメディア」斯う云うものを楽しんでよめるには、或年が必要であると思う。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲戦争中、マルヌの勝利を歌つた彼の詩が、ソルボンヌで行はれた戦勝祝賀会席上で、コメディイ・フランセエズの花形シモンヌ夫人によつて朗読された。",
              "citation": {
                "source": "女優と劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "処女戯曲「鷺の群とフィネット」が間もなくコメディイ・フランセエズで演ぜられた。",
              "citation": {
                "source": "女優と劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗濯代その他　国立劇場コメディイ・フランセエズでは、専属俳優の下着類は一切、劇場の方で洗濯してやることになつてゐる。",
              "citation": {
                "source": "ふらんす役者気質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく『予のために予は余りに偉大なり』は、コメディー・フランセエズの舞台にかけられ、新進作家として稀有の待遇を受けた。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "『別れも愉し』（Le Plaisir de Rompre）は一八九七年三月エコリエ社で上演せられ、現に、これも『人参色の毛』と共にコメディー・フランセエズの上演目録中に加へられてある。",
              "citation": {
                "source": "劇作家としてのルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはパリ滞在中にこの裁判所の前庭で、ラシーヌの唯一の喜劇『レ・プレーデュール』（訴訟きちがい）がコメディ・フランセエズの俳優たちに依って慈善興行として演じられるのを見に行ったことがある。",
              "citation": {
                "source": "パリの地下牢",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこのトラギコメディを抱いて涙を垂れる。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "国立音楽演劇学校（コンセルヴァトワアル）と国立劇場（コメディイ・フランセエズ、オデオン・オペラ、オペラ・コミイク、トロカデロの五座）は私の滞仏中の観察に拠ると、当時の情勢で、十分にその文化的意義を発揮しつつあるやうに思はれた。",
              "citation": {
                "source": "わが演劇文化の水準",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、「恋の女」がコメディイ・フランセエズの舞台にかけられてから、その人気は一時に沸騰した観がある。",
              "citation": {
                "source": "ポルト・リシュとクウルトリイヌ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　セシル・ソレル嬢といへば、パリ人ならだれでも知つてをり、アメリカ人と日本人とに多少名前を覚えられてゐるコメディ・フランセエズの幹部女優であるが、婆さんの癖に器量自慢で、いつもコケツトの役を得意になつて演じてゐる。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女、ある朝、寝床の中で、コオヒイかなんか飲みながらコメディア（演芸新聞）をひろげると、二段抜きで、だれかの漫画が出てゐる。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "正しく、コメディ・フランセエズ――セシル・ソレル嬢ではないか。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、もしもし、あんた、今朝のコメディア見た？",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がコメディイ・フランセエズで観た「人民の敵」も、その意味で、最も此の戯曲の喜劇的特質を活かしてゐたと記憶する。",
              "citation": {
                "source": "巴里で観たイプセン劇",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、嘗て千九百十年に此の戯曲が上演された時の記録によると、更にまた、千九百二十三年、国立劇場コメディイ・フランセエズが、特に此の戯曲をその上演目録中に加へた結果を見ると、私はやや自分の鑑賞眼を疑はないわけに行かなかつた。",
              "citation": {
                "source": "サン・ジョルジュ・ド・ブウエリエについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別れも愉し」（Le Plaisir de Rompre）は千八百九十七年三月エコリエ社で上演せられ、現に、これも「赭毛」と共にコメディイ・フランセエズの上演目録中に加へられてある。",
              "citation": {
                "source": "ジュウル・ルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在では、国立劇場コメディイ・フランセエズの上演目録に加へられてをり、ベルナアルとボヴィイの当り芸になつてゐる。",
              "citation": {
                "source": "ジュウル・ルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八六年、ヴィクトオル・ユゴオの誕生日に、「千八百〇二年」と題する対話劇をコメディイ・フランセエズで上演させてゐる。",
              "citation": {
                "source": "演劇より文学を排除すべきか",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "築地小劇場に於て最もその例が甚しく、その余波を受けて「大衆的」と標榜する諸種の新劇団――「新東京」にしろ、美術座にしろ、テアトル・コメディイにしろ、殊に、演劇集団の名に於て試みられた一、二回の興行は、その悪弊を露骨に示してゐた。",
              "citation": {
                "source": "通俗性・大衆性・普遍性",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋では、古典悲劇専門の俳優だけは、トラジェディアン、即ち悲劇俳優と呼んでいるけれども、その他の、一般の俳優は、コメディアンと称し、特に、「喜劇」のみをやらなくても、ただ「役者」という意味で通つていることも注意すべきである。",
              "citation": {
                "source": "演劇の様式――総論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、ここで、もし、これを「演劇」の一様式として、強いて、ジャンルの名を与えるとすれば、イタリアにその源を発した「コメディア・デルラルテ」であろう。",
              "citation": {
                "source": "演劇の様式――総論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、私の「好きだつた」テアトル・コメディイにも、今や、直面すべき危機が到来したことを告げておかう。",
              "citation": {
                "source": "テアトル・コメディイの二喜劇",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "テアトル・コメディイ岸田國士　先日、仁寿講堂で観たこの新劇団の仕事は、予て聞いてゐた通り、八分賛成でき、二分危険を感じさせるものだ。",
              "citation": {
                "source": "テアトル・コメディイ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新劇団の中で目星いものは、テアトル・コメディイと称する純素人劇団と、友田夫妻を中心とする築地座である。",
              "citation": {
                "source": "新劇復興の兆",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
