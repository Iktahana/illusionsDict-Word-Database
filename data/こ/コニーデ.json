        "examples": {
          "standard": [
            {
              "text": "コニーデは、富士山のような成層火山を指す言葉です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その地域には、過去の火山活動によって形成されたコニーデが点在している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "コニーデは、溶岩流と火山灰が交互に堆積して形成される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "三原山の最高所は波浮よりの外輪山の剣ガ峯という七五五米のところだが、新火口は現在に於てそれとほぼ同じ高さの山（コニーデというそうだ）をなしているそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
