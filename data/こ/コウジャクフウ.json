    "definitions": [
      {
        "index": 1,
        "gloss": "southeasterly wind blowing around the fifth month of the lunisolar calendar (when marine fishes allegedly turn into tree sparrows)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "五月の海に吹き抜ける黄雀風が、初夏の訪れを告げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この時期に吹く南東の風は黄雀風と呼ばれ、海魚が鳥に化すという伝承がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "黄雀風に吹かれながら海岸を散歩するのは、実に気持ちが良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "尤も、さういふ季題でも、一般の人々に實感の少ない特殊なもの、例へば虎が雨とか黄雀風とか云つたものは稀であるが、誰にでも濃厚な實感のある春雨とか秋風とかには古今を通じて非常に多數な句がある。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「黄雀風」とか「湖南の扇」とかの裏表紙にある詩は、芥川の好みや注文ではなく、全く僕が勝手にやつたものである。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            }
          ]
        }
