    "definitions": [
      {
        "index": 1,
        "gloss": "cocoa (beverage, cocoa solids)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
