    "definitions": [
      {
        "index": 1,
        "gloss": "Doctor of Engineering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
