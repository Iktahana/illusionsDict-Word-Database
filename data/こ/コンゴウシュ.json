          "literary": [
            {
              "text": "すなわち一体は文珠菩薩、次は観世音菩薩、次は金剛手菩薩である。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央にあるのが観世音菩薩、西にあるのが金剛手菩薩の像である。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
