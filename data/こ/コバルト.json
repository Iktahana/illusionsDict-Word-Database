        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぎょっとして振りむくと、馬場の右脇にコバルト色の学生服を着た背のきわめてひくい若い男がひっそり立っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルトの空には玉子色の綿雲が流れて、遠景の広野の果の丘陵に紫の影を落す。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スマ子女史はワイシャツの縫目からミス・フランセのコバルトの細巻をとりだして火をつけると、蒸気のこもった部屋に水沫のように緑色の煙を吐き出して、――だが、人に聞くと君はちかごろ恋のテクニックに夢中なんですって？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルト山地なべて吹雪のたえまより、　　はたしらくものきれまより、コバルト山地山肌の、　　　　ひらめき酸えてまた青き。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "画工さんは立処にコバルトの絵の具を溶いたし、博士は紫の蝶を追つて、小屋うらの間道を裏の林に入つたので。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝ころんで本を読んでいると白いページの上に投じた指の影が、恐ろしく美しい純粋なコバルト色をして、そのかたわらに黄色い補色の隈を取っているのを見て驚いてしまってそれきり読書を中止した事もある。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お日さまは、今日はコバルト硝子の光のこなを、すこうしよけいにお播きなさるやうですわ。",
              "citation": {
                "source": "まなづるとダァリヤ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プルシャンブリューでは無論なしコバルトでも濃い過ぎるし、こんな空色は書きにくいと小山はつぶやきながら行った。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の両岸に錯雑した建物のコンクリートの面に夕日の当たった部分は実にあたたかいよい色をしているし、日陰の部分はコバルトから紫まであらゆる段階の色彩の変化を見せている。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは、黒のラシャ地を敬遠して、コバルト色のセル地を選び、それでもって再び海軍士官の外套を試みました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋には大きい瓦斯ストーヴがもはやとうに火の働きを閉されて、コバルト色の刺繍をした小布を冠されていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は断髪を一筋も縮らせない素直な撫でつけにして、コバルト色の縮緬の羽織を着ている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルト色に深く澄み渡つた南の空に、大粒の宝玉のやうに燦々と光り輝く十字星は、天空一ぱいに散乱する群星を圧してゐた。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎよつとして振りむくと、馬場の右脇にコバルト色の學生服を着た背のきはめてひくい若い男がひつそり立つてゐた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、朝やけで赤かった空は、コバルト色になり、やがて、こい水色にかわっていきました。",
              "citation": {
                "source": "張紅倫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が出たので、狐の毛なみが銀色に光り、その足あとには、コバルトの影がたまりました。",
              "citation": {
                "source": "手袋を買いに",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の黒田清輝先生のスケツチに屡く見られたやうな、光線の為にコバルト色に輝いて居る一群の草刈女が、絵の中でのやうに草を刈つてゐる。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一つは黒田清輝さん流のコバルト色の著物の男が四斗樽へ一ぱい色々の切を入れて、それをこちこちと棒でかきの類はいかにも綺麗に並んで居るが、然し決してカン※スとテレビンで取扱ふ事の出來るものでは無い。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この背景としての窓の下の四條橋下の河原では、例のコバルト色に見える人の群が、ずらりと並べ干された友禪ムスリンを取込むのに忙殺せられて居る。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙々とコバルト色の無地のワンピースを着て、衿のボタン代りに丸紐をボウ（蝶結び）に結んでいると、上海帰りのルミが、「殺生やわ、ほんまに……」と、遅れて上って来て、ペラペラひとり喋った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルト色の無地のワンピースが清楚に似合う垢ぬけた容姿は、いかにも占領軍の家族が撮りたくなるくらい、美しかったが、しかし足には切れた草履をはいていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後には海が純粋なコバルト色になった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不純酸化コバルトを王水に浸し、その四倍の重量の水に薄めたものが、ときどき用いられる。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルトの※（11）を粗製硝酸に溶かしたものだと、赤色が出る。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡い牡丹色のぼやけたような毛糸で、私はそれに、コバルトブルウの糸を足して、セエタにするつもりなのだ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事な、しかし心持地味なお納戸の着物に、派手なコバルト色のパラソル、新しいフェルト草履、バスケット一｜個という姿の彼女がションボリと玄関に立った。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがそれぞれの調子と濃淡とで統一されて落付いて、繪具は草汁らしいが黄色の交らないコバルト系の色彩で、淡墨と墨とに實に、無類の調和をもつた繪だつた。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の知人の聯隊長が、ドイツから持つて帰つて下さいましたコバルト色の線の入つたナイフで、細かに細かに刻んでしまひ度うございます。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は聯隊長のコバルト色のナイフが恐ろしくてなりません。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
