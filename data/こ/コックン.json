          "literary": [
            {
              "text": "漢字としての意義は近くとも、国訓の上には、鬼をかみとした例はない。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人はこの漢字ゆえにただちに武士の居宅を想像するが、館は国訓タチであってタテではない。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
