[
  {
    "uuid": "1594e09e-9b29-5420-96a0-a2c59487654f",
    "entry": "後述",
    "reading": {
      "primary": "こうじゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
