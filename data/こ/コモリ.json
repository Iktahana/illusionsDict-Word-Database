    "definitions": [
      {
        "index": 1,
        "gloss": "looking after a baby",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
