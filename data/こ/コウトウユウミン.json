    "definitions": [
      {
        "index": 1,
        "gloss": "educated loafer (living off family wealth)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かういふ餘儀ない事情は彼等を驅つて放縦懶惰の高等遊民たらしめるより他はなかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう余儀ない事情はかれらを駆って放縦懶惰の高等遊民たらしめるよりほかはなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は画かきになる時、親爺が見限ってしまって、現に高等遊民として取扱っているのだ。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所で、遊民があるとして、無智で下等な遊民の方が好いか、智識ある高等の遊民の方が好いかと言えば云うまでもない高等遊民が好い、同じ貧乏人でも、無智で低級で下等な奴よりは、智識ある高等な貧乏人の方が好いのである。",
              "citation": {
                "source": "文明国には必ず智識ある高等遊民あり",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "智識ある高等遊民のあるのは其の国の文明として喜んで好い、遊民其の物を喜ぶのではないが、国が文明になれば遊民も亦智識が進み、文明になる。",
              "citation": {
                "source": "文明国には必ず智識ある高等遊民あり",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等遊民が出来ることを恐れて教育の手加減をするなどは愚の極だ。",
              "citation": {
                "source": "文明国には必ず智識ある高等遊民あり",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は高等遊民其の物を決して国家の為めに恐れるものではない。",
              "citation": {
                "source": "文明国には必ず智識ある高等遊民あり",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、高等遊民を恐れて、高等の智識に走らんとする国民の大勢を抑えんとするものあるを恐れるのである。",
              "citation": {
                "source": "文明国には必ず智識ある高等遊民あり",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方から上京した真剣な事業や運動が、東京と名乗る悪魔の乾児たる横道政治家の金儲けの種、高等遊民の飯喰い種として、片っ端から犠牲とされ、腐敗堕落させられて行く有様は、恰も地方から上京する青年処女の純真な志が、東京に入ると忽ち不浄化され、頽廃化させられてしまうのと同様である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをまた例の福本日南が、頭の禿に触られでもしたかのやうに博士に喰つてかゝつて、往時の事を疝気に病むよりは、寧そ博士の育てた高等遊民の救済法でも考へたがよからうと口を尖らせた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等遊民も部類分けにすると色々あるが、なかで法学士が一番多い。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家所生の言葉「振っている」「高等遊民」「露悪家」「月並み」等の言葉の文壇に行われるようになったのは夏目先生から始まっている。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫も杓子も帝国大学の門に集つて高等遊民が出て困ると言ふ。",
              "citation": {
                "source": "蘇峰先生の『大正の青年と帝国の前途』を読む",
                "author": "吉野作造",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家所生の言葉「振つてゐる」「高等遊民」「露悪家」「月並み」等の言葉の文壇に行はれるやうになつたのは夏目先生から始つてゐる。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニシアスというのは警句ばかり吐いているアレクサンドリアの高等遊民である。",
              "citation": {
                "source": "仏蘭西文学と僕",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり僕のような高等遊民でないからです。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら他の感情を害したって、困りゃしないという余裕がないからです」十「実は田口さんからは何にも伺がわずに参ったのですが、今御使いになった高等遊民という言葉は本当の意味で御用いなのですか」「文字通りの意味で僕は遊民ですよ。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬太郎は初対面の客を客と感じていないらしいこの松本の様子に、なるほど高等遊民の本色があるらしくも思った。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で高等遊民だと名乗るものに会ったのはこれが始めてではあるが、松本の風采なり態度なりが、いかにもそう云う階級の代表者らしい感じを、少し不意を打たれた気味の敬太郎に投げ込んだのは事実であった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失礼ながら御家族は大勢でいらっしゃいますか」　敬太郎は自から高等遊民と称する人に対して、どういう訳かまずこういう問がかけて見たかった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等遊民だからですか」「そう云う訳でも無いんですが、何だかそんな心持がしたからちょっと伺がったのです」「高等遊民は田口などよりも家庭的なものですよ」　敬太郎はもう何も云う事がなくなってしまった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら高等遊民だって、そんな暇の出るはずがないじゃありませんか」「御嬢さんはどうでしょう。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に高等遊民と自称する松本という男からその人生観の一部を聞かされた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう考へて来ると、明大演劇映画科の創設は、学校過剰といはれる現在、必ずしも高等遊民を世の中に送り出すことにはならぬと思ふ。",
              "citation": {
                "source": "明治大学文芸科に演劇映画科を新設する件",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ははあ、やはり君も高等遊民の類ですね。",
              "citation": {
                "source": "微笑",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し之がうまく行って教育の倫理化が阻止されるとなると、役に立たない人格者ばかりが卒業して、当局が気にしている「高等遊民」の数ばかりが殖えることは必然だが、それはどうなるというのだろうか。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼岸過迄」の中に「高等遊民」という言葉が出てくるが、「高等遊民ってなあに？",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
