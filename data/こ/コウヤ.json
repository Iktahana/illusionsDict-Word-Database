[
  {
    "uuid": "533b7e3c-571a-5896-b310-32f19a626cba",
    "entry": "広野",
    "reading": {
      "primary": "こうや",
      "alternatives": [
        "ひろの"
      ],
      "is_heteronym": true
    },
    "grammar": {
