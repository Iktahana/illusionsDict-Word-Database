        "examples": {
          "standard": [
            {
              "text": "金属加工用のドリル刃には、耐熱性に優れた高速度鋼が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この旋盤のバイトは高速度鋼製なので、硬い鋼材もスムーズに削れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工具の寿命を延ばすため、高速度鋼の表面にチタンコーティングを施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが高速度鋼のカッターは、鋳物を、ナイフで大根でも削るように削る。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこから持ってきたか、高速度鋼のはまった鋸を、一生けんめいにつかっているのは、外ならぬ水夫の竹見だった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
