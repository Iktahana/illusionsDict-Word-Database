[
  {
    "uuid": "8ee7027f-75b6-56d6-a297-eac7bd80cad1",
    "entry": "困る",
    "reading": {
      "primary": "こまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
