          "standard": [
            {
              "text": "プロレスラーの得意技であるコブラツイストが決まって、観客は総立ちになり、大歓声が沸き上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔のプロレス中継で、解説者がコブラツイストの難しさや効果について熱く語っていたのを思い出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゲームの中で、キャラクターが相手にコブラツイストを仕掛け、見事に一本勝ちを収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いつもなら、ここでヘッドロックか、コブラツイストでもかけにいくところだが、体力を使い果たしたところに不安が重なったので、完全に力が抜けて、慶一は教壇に腰をおろしてしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
