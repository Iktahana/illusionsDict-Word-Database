  {
    "uuid": "ed3decf0-0ce9-56da-8f7a-70b7f5f761cd",
    "entry": "コナ",
    "reading": {
      "primary": "コナ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Kona (variety of Hawaiian coffee)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ボーボラナンキン」といふのは「オタンコナス奴」といふやうな意味だ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は少年時代に黒岩涙香やコナン・ドイルの探偵小説を愛読し、やや長じて後は、主としてポオとドストイェフスキイを愛読したが、つまり僕の遺伝的な天性気質が、こうした作家たちの変質性に類似を見付けた為なのだろう。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」母は、ことし六十五歳であるが、デユマや、コナン・ドイルの傳奇探偵物語の類を好むのである。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」オニハ　コナヒダ　アヅカツタコブヲ　ツケマス　ミギノ　ホホオヤオヤ　トウトウ　コブ　フタツブランブラント　オモタイナハヅカシサウニ　オヂイサンムラヘ　カヘツテ　ユキマシタ　實に、氣の毒な結果になつたものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六ヶ月分の郵便物がぼつぼつ到着しますが慰問の小包なぞこの腹では到底コナセマセン。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "その緻密な推理力（無論探偵的な）に驚くべきものがあつても、全篇の面白味に至つては、コナン・ドイル到底ルブランの比ではないやうに思はれる。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "噴水の恍惚は醒めたあと愈々精神を明澄にします」　ちょうどこの時分英国にはコナン・ドイルの神秘主義というものが流行っていた。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "己が知己のやうに聞えるわ、コナ白癡が。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」オニハ　コナヒダ　アヅカツタコブヲ　ツケマス　ミギノ　ホホオヤオヤ　トウトウ　コブ　フタツブランブラント　オモタイナハヅカシサウニ　オヂイサンムラヘ　カヘツテ　ユキマシタ　実に、気の毒な結果になつたものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は少年時代に黒岩涙香やコナン・ドイルの探偵小説を愛読し、やや長じて後は、主としてポオとドストイェフスキイを愛読したが、つまり僕の遺伝的な天性気質が、かうした作家たちの変質性に類似を見付けた為なのだらう。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレデハ　コノ　コノ　トコロニハ　ウグヒスハ　アソビニ　コナカツタデセウカ。",
              "citation": {
                "source": "ウグヒスブエヲ　フケバ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――此の国ではコナンドイルがスピリチュアリズムに凝っていましたが。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コナンドイル未亡人からとどいた神秘主義実験報告のパンフレット。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は怜悧で、ココナットの実を日向に乾かして割る術をも心得ている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石竹をカラナデシコといふから全く、支那から来たと思ふ人も有らんが、故矢田部博士の日本植物編に、本邦自生のコナデシコ、花は淡紅で、栽培する石竹の原種だとみゆ。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "コナン・ドイルの小説にもそれによく似たような話があって、ジョン・ブリュー・ギャップというところに古代の大熊が出たと書いてある。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "コナン・ドイルは、今でもそうとう面白く読めますが、いささか千遍一律なのが鼻につきます。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度といえばコナン・ドイルの印度に関する知識はよほど深いようであるが、あまりに、それが神秘化されすぎていて、読者にアナクロニズムの幻覚を起こさせるきらいがあります。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ、コナン・ドイルは中々の学者であります。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "推理の算数的的確さと、それを潤飾する博識、これがコナン・ドイルのしんしょうであります。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "コナン・ドイルの神秘は理知で組み立てた神秘ですが、ポーの神秘は理知と融合しています。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の小説のシリーズ物などを見ると、トルストイとガボリオとが一緒にならんでいたり、コナン・ドイルとヴィクトル・ユーゴーとが背中あわせしたりしていることは珍しくない。",
              "citation": {
                "source": "現下文壇と探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "改造社の『世界大衆文学全集』中には探偵小説はだいぶ取り入れられているが、しかしこれは「大衆文学」というカテゴリーの中で初めて椅子を与えられているので、『ファウスト』や『ミゼラブル』とならんで、コナン・ドイルの『アドベンチャー』や『メモアール』が収録されているのとはわけがちがう。",
              "citation": {
                "source": "現下文壇と探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "コナラだのクヌギだのといった高い木、クワやアケビなどの低い木、笹や大きなシダ類などにさえぎられて、地肌こそ見えないが、ここからは、山裾が谷間にたたみこまれていくのが見える。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレモハジメノウチデ、工場ノ人モダンダンコナクナッテ、死ンダトキニハ、ミンナハモウ君チャンノオ父ッチャノコトヲワスレテシマッテイタノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に会うと、笠原は私の前に今迄になくチョコナンと坐っているように見えた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは如何にもチョコナンとしていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がものを考える考え方はいかにも分析的で、これは後にコナン・ドイルのシャーロック・ホームズに模倣されたところのものだ。",
              "citation": {
                "source": "ヂユパンの癖とヴァンスの癖",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "コナン・ドイルの『緋色の研究』や『四人の署名』やその他のものなどは印度と本国とに跨がったものだがそういう欠点の少ない傑作だと思う。",
              "citation": {
                "source": "私の要求する探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
