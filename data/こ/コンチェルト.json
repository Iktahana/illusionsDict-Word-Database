        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここまで書いた時に宅のラジオが鳴り出して、バッハのト短調、チェンバロ・コンチェルトというのを聞かせてくれた。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーツァルトのフリュウト・コンチェルトに眼を細める。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕は、かつぎ屋だから……」と、あまりに近づく、美和子の肌を遠ざけながら立ち上って、片隅のビクトロラの蓋を払って、バッハのコンチェルトをかけた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさい、トーイズの〈ラヴァーズ・コンチェルト〉なんて、ギターコードでゴリゴリとは、およそ無関係な曲も好きだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショルツ氏についてコンチェルトを弾く位だったひとが、結婚した良人がシントーイスムでピアノにさわれずいたずらに年を経ている例がある。",
              "citation": {
                "source": "きのうときょう",
                "author": "――音楽が家庭にもたらすもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ、ただ一本の線の上に奏せられていたアリアのような「伸子」の物語は、こうして、「二つの庭」においては、小さなクヮルテット（四重奏）となり、やがて「道標」では、コンチェルト（協奏曲）にかわってゆく。",
              "citation": {
                "source": "あとがき（『二つの庭』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなあるとき、自動車の中で自然に手の指の触れた肱つきのダイヤルを廻すと、突然バッハのコンチェルトが聴えて来たことがあった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上園子の演奏するコンチェルトを桃子は今夜特別深く心にうけとって聴き入った。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七交響楽、ヴァイオリンの為のコンチェルト、エグモント、（カチャロフが出る。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ケムプの第五（コンチェルト）をきいて来て、スエ子しきりに亢奮している。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャイコフスキーのコンチェルト。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "バッハのコンチェルトなどをきいてひどくその無意味性をうらやましく思うのです。",
              "citation": {
                "source": "詩について語らず",
                "author": "――編集子への手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす紫縮緬の肩にも模様のおかれている礼装の袂をひるがえしてベートーヴェンのコンチェルトが弾かれ、熱中が加わるにつれて、川辺みさ子のゆるやかに結ばれた束髪からは櫛がとんで舞台におちた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンチェルトはその時分誰の場合でもオーケストラはなしで、ピアノだけで演奏されていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で初演のが一つ、フリュートのコンチェルトが一つ、あとヴェトーヴェンの第三（エロイカ）。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリュートのコンチェルトなんかというものは、私が新響をききはじめてこの数年の間、今度で二度目ぐらいです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンチェルト・グロッソは他にもいろいろレコードされているが、互いに一得一失あり、結局まとまったボイド・ニールが一番良い。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じヴィヴァルディのコンチェルト・グロッソは、後にバッハに影響した重要な作品であり、レコードされている数も少なくないが、そのうちですぐれたものは、メンゲルベルク指揮の「コンチェルト・グロッソ＝イ短調作品三ノ八」（テレフンケン二三六六〇―一）などではあるまいか。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクターに入っているブライロフスキーのピアノで「コンチェルト＝ニ短調」がそれだ（ＶＤ八〇〇四―五）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌劇もコンチェルトもあるというが、レコードでは「メヌエット＝ト長調」が愛される。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガーシュウィン（George Gershwin 1898―1937）　ジャズのコンチェルトや歌劇を書いて一世を驚かした、一番アメリカ臭い作曲家だ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私をレコード道の底無し沼に引き込んでしまったのは、パデレフスキーの弾いたショパンの『ワルツ』や、イザイエの弾いたメンデルスゾーンの『コンチェルト』や、その後ビクターに入って来た、黒盤の『第五シンフォニー』であったかも知れない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その頃、レコード以外では、メンデルスゾーンの『コンチェルト』も、ベートーヴェンの『第五シンフォニー』も聴く工夫はなかった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルッフの『コンチェルト』を記憶している。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "クライスラーは新吹込みのコンチェルトにおいて、往年の甘さと若さを失ったことは当然であるが、甘さと若さに代るに、枯淡な滋味を加えたことも、また勘定外に置くわけには行かない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新旧三大コンチェルトが、管弦楽及び指揮の点においては、ブレッヒ指揮の古い方が優っていることは、百人が百人異論のないところだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のうち、バッハのコンチェルトは古典の名曲ではあるが、エルマンの演奏は艶麗を極めて、知的な少年メニューインの演奏以上とは思われない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フーベルマンの傑作は、なんと言っても、チャイコフスキーの『ヴァイオリン・コンチェルト』ほか二、三の大曲にある。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ・グラモフォンの、かき餅のような片面レコードに入った、『ラ・フォリア』や、パガニーニの『コンチェルト』や、『ツィゴイネルワイゼン』に、我らが驚異の眼を見張ったのも無理ではなかった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
