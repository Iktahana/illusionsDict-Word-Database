    "definitions": [
      {
        "index": 1,
        "gloss": "ancient belief",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "古説に三女ありて人生運命の泰否を掌る。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに歴史的視點よりすれば古説の解釋にも亦特殊の方法が可能となると思はれるが、現今の方法は之と趣を異にするものが多いやうなのである。",
              "citation": {
                "source": "哲學と哲學史",
                "author": "桑木嚴翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "其故に哲學史即哲學體系を主張することゝ自己が既に何等かの定説を立てゝ居ることゝは往々※離を免れず、隨て或る定説を以て古説に臨む者は終に古説の哲學史的意義を發見することが出來ないのである。",
              "citation": {
                "source": "哲學と哲學史",
                "author": "桑木嚴翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "是固より其の自ら期する所であるが、然しながら之と共に一面古説はたゞ其説の註脚若しくは支持として存するに過ぎぬことゝなり、同一の古説は種々に解釋せられるから、隨て其は同一の古説として存在するを得ざるに至るであらう。",
              "citation": {
                "source": "哲學と哲學史",
                "author": "桑木嚴翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば古説は其の客觀的實在性を消失して主觀的構成物となるに至るであらうと思はれる。",
              "citation": {
                "source": "哲學と哲學史",
                "author": "桑木嚴翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ此の如く古説其ものゝ唯一絶對的解釋の存在せぬことを承認したいと思ふ。",
              "citation": {
                "source": "哲學と哲學史",
                "author": "桑木嚴翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に斯く古説といふ一個の儼然たる事實的存在に對しても主觀的に解釋し得るとすれば、更に飜て是等諸古説の聯絡が一の論理的聯絡を有して歴史を形成するといふこと其自身をも亦一の主觀的見方の結果とすることは出來ないであらうか。",
              "citation": {
                "source": "哲學と哲學史",
                "author": "桑木嚴翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "此現在の立場が異なれば之によつて構成せられる哲學史も亦變更せらるべきものであるから、其論理的關係の内容は變更するが、然し各説の間に存する關係は依然として現今の或學説を生ずる爲に古説の系列を立てるものとなり、其間に存する目的觀的必然關係の存在には變化はない。",
              "citation": {
                "source": "哲學と哲學史",
                "author": "桑木嚴翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち古説を出來るかぎり古説其自身として再現せしめることは此主觀的構成の期する所であつて、古説を主觀的に解釋することは古説を自己の學説に適合するやうに改造する意ではない。",
              "citation": {
                "source": "哲學と哲學史",
                "author": "桑木嚴翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単な古い説経に、潤色を施して出した新しい正本では、古くから世間に耳馴れた古説経持ち越しの知識は、其儘にして居た事と思はれる。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此説もまた、盤古説話と同じく、容易に理解し得可し。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯この説話が海の分子を含むは、盤古説話と稍や同じからず。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その原形は恐らく盤古説話なる可く、此等の説話を以て、支那説話の模倣なりと論ずるは、盖し誤らざるに近し。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其二　支那神話の天地開闢説（下）　『三五暦記』に見ゆる盤古説話は、所謂天地分離の神話にして、屍躰化生説話とは、全く別個の形式に属す。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "盤古説話は、盤古の生長して、天地を割きしことを明言せず、盤古の樹木たること、勿論その説なし、然れども、盤古の生れし時は、天地混沌として開闢のはじめなりし事、天地の区別未だ判然たらざりしこと、盤古の生物のはじめなる事、此等の点に於ては、盤古説話は南洋説話と同じ。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "盤古説話を以て、直ちに樹木説話なりと説明するは、或は其当を得ざる可きも、其裏面に、「タネマフタ」説話と同様なる、樹木説話の存在を想像するは恐らく不当の解釈に非ず。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "盤古説話も、其一形式に於て、その形跡を示す。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして窃おもう、その立論の旨おおいに古説と同じからざるあるをもって、看者胸中の先入を一洗するにあらずんば、おそらくはその真意の向うところを認めざらんことを。",
              "citation": {
                "source": "教門論疑問",
                "author": "柏原孝章",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけで裾から上だけをかいた歌麿の女などが、こせつかない上品な美しさを感じさせるのではあるまいか。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一目見ると直に、少しあけツ放しの點のある代には、こせつかぬ、おツとりとした、古風な顔立であることを見て取ツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しもこせつかないで、運命のままに身をまかせてゐる。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "士農工商師匠のこせついたのは見苦しいが、ことの序でに戒めて置くぞ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭よりは休むことのあまりに久しければ籍を除きぬと言いおこせつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈籠やら、いくつにも分岐した敷石の道やら、瓢箪なりの――この形は、西洋人なら、何かに似ていると言って、婦人の前には口にさえ出さぬという――池やら、低い松や柳の枝ぶりを造って刈り込んであるのやら例の箱庭式はこせついて厭なものだが、掃除のよく行き届いていたのは、これも気持ちのいいことの一つだ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「又さうだこつたから仕やうねえ、勘次等懷工合えゝつちんだから、要らば何でも、汝れよこせつと斯ういふんだ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうだとも、錢でも何でも呉んなけりや、よこせつちばえゝんだ、錢ねえなんちへば米でも麥でも奪取つてやれ」爺さんは周圍へ唾を飛ばした。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭よりは休むことのあまりに久しければ籍を除きぬと言ひおこせつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭よりは、休むことのあまりに久しければ籍を除きぬと言ひおこせつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処は或る貴族の何万坪かといふ屋敷跡の分譲地で堂々たる邸宅ばかりが並んでゐて、その一隅の貸室館に、中でも小つぽけな一室に親と子が卓子をならべて、親は四角な区劃の紙片を一字一字埋めながら、こせついたりしてゐる光景を吾ながら傍見して僕はお気の毒見度いになるのであつた。",
              "citation": {
                "source": "自烈亭",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィンダー　こせついていた都会も、これで少しはからりと焼原になったな。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
