    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to row",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "帆をあげた舟、発動汽船、ボート、櫓で漕ぐ舟、それらのものが春のぽかぽかする陽光をあびて上ったり下ったりした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八百八｜島と言ふ島の間を、自由に青畳の上のやうに漕ぐんだと言ふから、島一つ一つ趣のかはるのも、どんなにいゝか知れやしない。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはなほも、語るでせう、よしないことや拗言や、洩らさず私は聴くでせう、――けれど漕ぐ手はやめないで。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの漕ぐ艇、わが漕艇と意識の区別は全く消え失せ、ただ一つのものが漕いでいる。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何、叔母さんさえ信用するんなら、船だけ借りて、漕ぐことは僕にも漕げます。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず休んで、」　と三足ばかり、路を横へ、茶店の前の、一間ばかり蘆が左右へ分れていた、根が白く濡地が透いて見えて、ぶくぶくと蟹の穴、うたかたのあわれを吹いて、茜がさして、日は未だ高いが虫の声、艪を漕ぐように、ギイ、ギッチョッ、チョ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手に漕ぐな、甘いものだ、感心なもんじゃな。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大丈夫｜漕ぐですから、あれに乗せてもらいましょう、どうです。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "波を渡るか、宙を行くか、白き鵞鳥の片翼、朝風に傾く帆かげや、白衣、水紅色、水浅葱、ちらちらと波に漏れて、夫人と廉平が彳める、岩山の根の巌に近く、忘るるばかりに漕ぐ蒼空。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで波の上を漕ぐ気だ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手な船頭は手先で漕ぐ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧者なのは眼で漕ぐ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが名人となると、肚で漕ぐッ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合には名人は肚で漕ぐから確さ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "果せる哉、殿の痩按摩で、恁う口をきく時、靄を漕ぐ、杖を櫂に、斜めに握つて、坂の二三｜歩低い處に、伸上るらしく仰向いて居た。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "総六は、崖の、と呼ぶ、熱海の街を突切って、磧のような石原から浪打際へ出ようとする、傍の蠣殻屋根、崖の上の一軒家の、年老いた漁師であるが、真鶴崎へ鰹の寄るのも、老眼で見えなくなったと、もう鈎の棹は持って出ず、昼は人仕事の網の繕、合間には客を乗せて、錦の浦遊覧の船を漕ぐのが活計。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "這奴横紙を破っても、縦に舟を漕ぐ事能わず、剰え櫓櫂もない。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉白き船頭の漕ぐにまかせ、蒔繪の調度に、待乳山の影を籠めて、三日月を載せたる風情、敷波の花の色、龍の都に行く如し。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御幣まで立って警戒をした処があっちゃあ、遠くを離れて漕ぐにしても、船頭が船頭だから気味が悪いもの。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "印半纏の威勢のいいのでなく、田船を漕ぐお百姓らしい、もっさりとした布子のなりだけれども、船大工かも知れない、カーンカーンと打つ鎚が、一面の湖の北の天なる、雪の山の頂に響いて、その間々に、「これは三保の松原に、伯良と申す漁夫にて候。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、操の糸の切れたがごとく、手足を突張りながら、ぐたりと眠る……俗には船を漕ぐとこそ言え、これは筏を流す体。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近寄って艫を漕ぐ女の姿が見えて来た。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小波軽く袖で漕ぐ浅妻船の調の雛。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが咲乱れた桜の枝を伝うようで、また、紅の霞の浪を漕ぐような。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "是等の船が動き出して、艪を漕ぐ人の姿は見えるけれども船は中々に近よらぬ。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――先刻ここで木の実を売っておった婦のような、丸い笠きた、白い女が二人乗って、川下から流を逆に泳いで通る、漕ぐじゃねえ。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "船一艘漕ぐなれば、蘆の穂の風に散る風情、目にも留まらず、ひら／＼と上下に翼を煽る。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、見さしつた通り、五位鷺が漕ぐべいがね。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「漕ぐのは鷺でも鳶でも構はん。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いんや、お前様、お天守の、」と声を密めて、「……魔の人が為業なら、同一鷺が漕ぐにして、其の船は光を放つて、ふわ／＼雲の中を飛行するだ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
