        "examples": {
          "standard": [
            {
              "text": "一人の魅力的な女性を巡って、二人の親友が激しい恋の鞘当てを演じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いい年をして、みっともない恋の鞘当てはやめなさい」と周囲から呆れられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歌舞伎の演目『鈴ヶ森』では、江戸っ子たちの粋な恋の鞘当ての場面が見どころだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ここに悲劇の発端が生じたのだが、長く良人と別れていた彼女も、性的な淋しさや何かから、病的にサミイへ近づいて行って、そこに、アン・ルロイとの間に恋の鞘当てが始まったのだ。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く“心臓盗難男の恋の鞘当て”曰く“奇賊烏啼も登場の今様四角恋愛合戦”また曰く“無心臓男の恋の栄冠”と。",
              "citation": {
                "source": "心臓盗難",
                "author": "烏啼天駆シリーズ・２",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
