    "definitions": [
      {
        "index": 1,
        "gloss": "to be completely satisfied",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんな厭な時候に、ただ一つ嬉しいのは、心ゆくばかり降る雨の夕を、風呂に行く事である。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢應の鯉魚は、三井寺の興義といふ鯉の畫のうまい僧の、ひととせ大病にかかつて、その魂魄が金色の鯉となつて琵琶湖を心ゆくまで逍遙した、といふ話なのですが、私は之をよんで、魚になりたいと思ひました。",
              "citation": {
                "source": "魚服記に就て",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし元来、御中道めぐりは、信神の道者を主とするので、近来盛んになった女人の登山も、ここへはほとんど影を見せず、森林と絶壁と深谷とで、四周を切り離されているから、山中の室としてのさびが、心ゆくばかり味わわれる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の窓に青田のながめ心ゆくさまなり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ、廻り縁の座敷に、畳屋の入つてゐたのも、何となく心ゆく都の時雨に似て、折から縁の端にトントンと敲いた茣蓙から、幽に立つた埃も青い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシアでもドイツでも、男どうしがおおぜい寄り集まったときに心ゆくばかりに合唱することのできるような歌らしい歌をたくさんにもっているということは実にうらやましいことである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "心ゆくまで泣かうと思つた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほこりっぽい、乾苦しい、塩っ辛い汗と涙の葬礼行列の場面が続いたあとでの、沛然として降り注ぐ果樹園の雨のラストシーンもまた実に心ゆくばかり美しいものである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角彼は心ゆく許り激情の弄ぶまゝに自分の心を弄ばした。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の死因が粟粒結核であるのを確めて、たつた先刻心ゆくまで味つた近頃にない喜び――一つは自分より熟練だと考へられてゐる多數の先輩に對して見事に占め得た勝利の喜び、一つは自分の妻の病症の眞相をしかと確めて何にともなく復讐をしおほせた喜び――その喜びは跡方もなく消えてしまつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷲になって、蔵の窓から翼をひろげて飛びあがり、心ゆくまで大空を逍遥した。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなかすかな哀れなものに、私の總體の重力で心ゆくばかりすがりつきたいのである。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心ゆくまで湯につかつたあとのやうに快い亢奮の余□が彼の心のすみずみまでゆきわたつてゐた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "駱駝に乗つてピラミツドの周辺を逍遥しての帰るさ立寄つたホテルの露台の籐椅子にもたれて私は埃及の空に輝く星々を心ゆくまで眺めることが出来た。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫はさてはそれからと、見る見る、心ゆくばかりに思うと、萌黄に敷いた畳の上に、一簇の菫が咲き競ったようになって、朦朧とした花環の中に、就中輪の大きい、目に立つ花の花片が、ひらひらと動くや否や、立処に羽にかわって、蝶々に化けて、瞳の黒い女の顔が、その同一処にちらちらする。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめてあの色調――あの枯草の束だけでも、心ゆく許りに、日本の油絵の上に見たいと望まずには居られなかつた。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は函館にゐる間、心ゆくばかり函館を愛しまた愛された。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "休息――しかし困つた事には、予の長く忙がしさに慣れて來た心は、何時の間にか心ゆくばかり休息といふことを味ふに適しないものになつてゐた。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "山に行きたい、海に行きたい、知る人の一人もゐない國に行きたい、自分の少しも知らぬ國語を話す人達の都に紛れ込んでゐたい……自分といふ一生物の、限りなき醜さと限りなき愍然さを心ゆく許り嘲つてみるのは其の時だ。",
              "citation": {
                "source": "硝子窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ嘘にしろ、この湖底に見えるという銀の鱗のことを考えて、心ゆくばかり身うちの血を氷らせていますと、「何にもない、つまらない景色」と葛岡に急き立てられ、わたくしはやっと惜しい湖辺を離れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "動きに動く物憎い抽象の恋人、わたくしはいつの間にかこの割りきれない落ちつきどころのない恋人の手管に翻弄され始め、翻弄されるのを心ゆくばかり楽しい思いがして来たのでありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "草仮名揉銀の消ししつやゆゑ墨のいろよくうつるらし、時雨月、かかるひと夜は草仮名に心ゆくなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "心ゆくうれしさの中、我はただ詩を思ふなる、汝また差しのぞくなる。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはフレップを摘み、トリップを探してまた心ゆくままに味い、かつ夢みた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は煙草の吸殻を心ゆくまで吸つた。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            },
            {
              "text": "心ゆくうれしさの中、我は唯詩を思ふなる、汝また差しのぞくなる。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、わが身も心ゆくまで冷水を飲み傾くるに、其の美味かりし事今も忘れず。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その痛快味、深刻味、悽惨味を心ゆくまで玩味させる読物ではないか。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして最早、スッカリ原始生活に慣れ切っている久美子と、四人の子供達が、澄み切った真夏の太陽の下で、丸裸体のまま遊び戯れている姿を、そこいらのトド松の蔭から、心ゆくまで垣間見た訳ですが、その時のＡの驚きはドンなでしたろう。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそこの指を火にくべて、われとわが生命の焼ける臭ひを嗅いだらどれほどこころゆくことだらう。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
