    "definitions": [
      {
        "index": 1,
        "gloss": "old castle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "灘山の端を月はなれて雲の海に光を包めば、古城市はさながら乾ける墓原のごとし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州は同じく紀州なり、町のものよりは佐伯附属の品とし視らるること前のごとく、墓より脱け出でし人のようにこの古城市の夜半にさまようこと前のごとし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "古城子の露天掘りだ！",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "名高い古城の片すみには昔の刑具を陳列した塔があります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日はレエゲンシタインの古城を見に行った。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュールンベルグの古城で、そこに収集された昔の物すごい刑具の類を見物した事がある。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の自分のこの「油絵」の貧しいコレクションの中には「シヨンの古城」があった。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖端のロマネスクの休亭は古城塞のように視覚から遠ざかって、これ一つ周囲と調子外れに堅いものに見えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやこれやで、私は、私自身、湖畔の或る古城に忍び入る戦慄の悪徳物語を、断念せざるを得なくなった。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古城には、オフェリヤに似た美しい孤独の令嬢もいるのだけれど。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中、湖畔の古城に住んでいる令嬢、そんな感じがある。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月　青碧澄明の天、雲端に古城あり、天守聳立てり。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝へ聞く沼の中へは古城の天守が倒に宿る……我が祖先の術の為に、怪しき最後を遂げた婦が、子孫に絡る因縁事か。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ふまでも無く、其の面影、其の姿は、古城の天守の囚と成つた、最惜い妻を其のまゝ、と豁然として悟ると同時に、腕には斧を取る力が籠つて、指と指とは鑿を持たうとして自然で動く――時なる哉、作の頭に飾るが如く、雲を破つて、晃々と星が映つた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸に近き山、山には松柏茂り、其頂には古城の石垣を殘したる、其麓の小高き處に立つて居るのが大島小學校であります。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つねのごと花輪編みつつ君おもひ水にむかへば、遠霞む山の、古城市の壁、森の戸までも、白寂の静けさ深さ、いと青に天も真澄みぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕の霧の中から浮び上る丘々や、その上に屹然として聳える古城郭から、遥か聖ジャイルス教会の鐘楼へかけての崎嶇たるシルウェットが、ありありと眼の前に浮かんで来た。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "加勢の大将は某なり、元就自身は、芸州神領｜表へ討出で、桜尾、銀山の古城を尽く攻落して、やがて山口へ攻入るべきの状、御用心これあるべし」と叫んだ。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この戦場より南一里の処に姑母山と称する古城がある。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "口津村の甚右衛門は、嘗つて有馬氏の治政時代に在った古城の原を無二の割拠地として勧め、衆みな之に同じたから、いよいよ古城を修復して立籠る事になった。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポリへ帰って、ポーシリッポの古城もただ外から仰いで見ただけで船へ帰ると、いろいろの物売りが来ていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の栄華を語る古城のほとり、朽ちかけた天守閣には蔦かずらが絡み、崩れかけた石垣にはいっぱい苔が生え、そのお濠に睡蓮の花が咲いていたら、私達は知らぬ間に、涙含ましい気持ちでいっぱいになっているに相違ありません。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に到るまで、この折の事は、埋沒したる古城の彩石壁畫の如く、我心目に浮び出づることあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――廬を結ぶ古城の下、時に登る古城の上、古城｜疇昔に非ず、今人自ら来往す――一九三二年、秋ちかきころ、私はそんな古詩を愛誦しながら、愛国の詩をつくりたきものよ！",
              "citation": {
                "source": "私の万年筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、読者は私の此処までの筆致や形容詞に依つて、実在のピエル・フオンの堂々たる古城の有様を連想されぬことを祈る。",
              "citation": {
                "source": "ピエル・フオン訪問記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷川なる邸内には、唐破風造の昔を摸せる館と相並びて、帰朝後起せし三層の煉瓦造の異きまで目慣れぬ式なるは、この殿の数寄にて、独逸に名ある古城の面影を偲びてここに象れるなりとぞ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してこの通りの口碑を持つ古城跡が諸国に多くある。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
