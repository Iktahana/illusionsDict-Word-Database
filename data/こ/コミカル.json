          "literary": [
            {
              "text": "飛んでいるようでもあり、踊っているようでもあり、舞っているようでもあり、そのコミカルな姿態をしばらく眺める。",
              "citation": {
                "source": "思索者の日記",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "食糧貯蔵室のぐちゃぐちゃぶり、特定の食品の紛失、最も相応しからぬ所から最も相応しからぬ方法でこじ開けた缶詰の忌まわしい程コミカルな山。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしコミカルであってね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後の歌はコミカルな歌だった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
