        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こうなると迂闊に小品文や随筆など書くのはつつしまなければならないという気がしたのであった。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると今度は、それに使うための蛆を飼育繁殖させる必要が起こってくるので、その方法が研究されることになる。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると大衆はだんだん黙ってしまって、ただただ驚嘆の眼を瞠るのです。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこうなるとせっかくの最初の空想も雲消霧散して残るものは世智辛い苦々しい現実である。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなるとよほど日本語に接近する。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、甲は味いがあるから佳作だと云い、乙は味いは無いが面白いから佳作だと云える訳である。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると「いろは」に現れているだけの音に関しては、今日の状態と同じで、「いろは」の中で同じ発音のものが三つあることになります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、一面解決の端緒が見えそうになると共に、一面問題はいよいよ大きくなるでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると運転手にも人間味が出て来るから妙である。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に吹かれるとかえって余計に暑くて窒息しそうで、こうなると街路の柳の夕風に揺らぐのが、かえって暑さそのものの象徴であるように思われた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、役人の方でも何が何やら判らなくなって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、苦情の理由が立派に成り立って、近所からたびたびねじ込まれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると近所迷惑で、長屋中のものはみな自身番の取り調べをうけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、かれの悪い癖はいよいよ増長して来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、昔の海賊も、いまの何をつかまえても儲けようとする種類の人間には顔まけするだろう。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると人間に眼のあったのは全く余り有り難くありませんね、盲目の方がよほど重宝です、アッハハハハ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなるとジャーナリズムはむしろ科学の学海の暗礁になりうる心配さえ生じるのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると今度はそれに使うためのうじを飼育繁殖させる必要が起こって来るのでその方法が研究される事になる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナマズだって、こうなると馬鹿に出来ませんよ。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺してください」女は、こうなると男よりも冷酷で、度胸がいい。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると自分は狼狽えざるを得ない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "実地に就ての益に立つ考案は出ないで、こうなると種々な空想を描いては打壊わし、又た描く。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "打っちゃっておくと、せっかく生長させようと思う草花がすっかり負かされてしまうので、こうなると気の毒でも雑草のほうはむしるよりほかはない事になる。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなるとさすがに雑草の脅威といったようなものを感じて、とうとう草刈りをはじめる決心をした。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこうなると自然に書物の種類にある限定を生じるに相違ないが、それでもかまわないと思うのである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は悪い人間だったと見えて、こうなると自分の命が助かりたかったのです。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
