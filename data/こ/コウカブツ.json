    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fallout (e.g. radioactive)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "噴火した火山から飛散した火山灰などの降下物が、近隣の農作物の成長を妨げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "原子力発電所の事故現場から数百キロ離れた場所でも、放射性降下物が検出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工場の煙突から排出される降下物を調査するため、定期的に大気サンプリングが行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これらの各種の降下物の成因は、空気中の水蒸気の濃度、温度、気流の問題などいろいろの事柄によって支配されるもので、此処ではそれらの詳しい点にはふれない。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
