[
  {
    "uuid": "5df1e4d8-93bf-577c-b339-51d0473707eb",
    "entry": "好下物",
    "reading": {
      "primary": "こうかぶつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "favorite snack to have with drinks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "脂の乗った旬のサンマの塩焼きは、冷えた日本酒にとって最高の好下物と言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "父はいつも「このピリ辛のメンマがあれば、他には何も好下物はいらない」と言って笑う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "珍しいカラスミを手に入れたので、今夜はそれを好下物にしてゆっくりと晩酌を楽しもう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "夏中の好下物、盆の贈答に用ふる事、東京に於けるお歳暮の鮭の如し。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、国森令弟わざ／＼海の幸――小鯛一籠――を持つてきて下さつた、魚に添へてある青紫蘇の香が何ともいへないフレツシユだつた、早速焼いて酢に漬けた、あゝ、この好下物あつて酒なしとは……、うらめしや。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しいことにこの幽霊は、足許は確かだが、眼が利かないから、眼前に横たわる好下物を、気取ったことは気取ったが、そのものの質を知ることはできないのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
