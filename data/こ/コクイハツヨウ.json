        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、そういう日本資本のひろがりを国威発揚と表現する方が便宜だった。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戦後日本青年の態度を示す」ということは、かつてベルリン・オリンピックのとき、軍国主義日本が示した国威発揚的示威に正しい批判をもつこんにちの日本青年は、世界平和のためにこそ、平和日本のためにこそ、世界の民主的青年とともに競技するものであるという態度を明確にする以外にないことを銘記してほしい。",
              "citation": {
                "source": "ボン・ボヤージ！",
                "author": "――渡米水泳選手におくる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士山や桜を自慢するやうな国威発揚がなにになる。",
              "citation": {
                "source": "風俗時評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が、それはスポーツとしてではなくて正に国威発揚の一手段としてであったのだ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
