[
  {
    "uuid": "425a1da4-0116-5407-aa1f-c7c4a8d724a3",
    "entry": "婚約",
    "reading": {
      "primary": "こんやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞",
