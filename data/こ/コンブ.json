[
  {
    "uuid": "dcffdb78-9ded-5415-a260-29de1237dbc6",
    "entry": "昆布",
    "reading": {
      "primary": "こんぶ",
      "alternatives": [
        "こぶ",
        "コンブ"
      ],
      "is_heteronym": false
    },
    "grammar": {
