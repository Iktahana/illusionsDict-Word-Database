      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kombu (usu. Saccharina japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "赤ン坊の泣声や、おひきずりの靴の音や、昆布や烏賊や洟紙や首巻や、みんなみんな、街頭沿ひの電線の方へ荷馬車の音も耳に入らずに、舞ひり吁！",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "杜の杉にはふくろふの滑らかさ、昆布の黒びかり、しづかにしづかに溶け込んで行く。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波が昆布だ、越して行く。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、ノルデはそれからまた十二年、森のなかで昆布とりをした。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこの坂なら杉の木が昆布かびろうどのようです。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "焔は、みるみるまっくろになり、海の底で昆布の林がうごいているような奇態なものに見えた。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昆布のような黒いなめらかな梢の中では、あの若い声のいい砲艦が、次から次といろいろな夢を見ているのでした。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時東には蝦夷富士、西にはニセコアン、北には昆布の山なみが、或は急な、或はなだらかな傾斜をなして、高く低く、私が眺め※はす地平線に單調な變化を與へる。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その甘ったるい夕方の夢のなかで、わたくしはまだあの茶いろななめらかな昆布の干された、イーハトーヴォの岩礁の間を小舟に乗って漕ぎまわっていました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ここで昆布がとれるの。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれでも昆布がとれるの。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれでも昆布がとれるのかって。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもどうして昆布を取るの。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく昆布がとれなくちゃだめだ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり昆布ははいりません。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昆布を一｜斤とらないうちは綿のはいったチョッキをやらんぞ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネネムはよろこんでたぐり寄せて見ますとたしかに大きな大きな昆布が一枚ひらりとはいって居りました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからよるもひるも栗の木の湯気とばけものパンと見えない網と紳士と昆布と、これだけを相手にして実に十年というものこの仕事をつづけました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの対手の中でもパンと昆布とがまず大将でした。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は森の中の昆布採りがいやになってこっちへ出て来た様子だが、一体これから何が目的だ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは昔は森の中の昆布取り、　その昆布｜網が空にひろがったとき　風の中のふかやさめがつきあたり　おれの手がぐらぐらとゆれたのだ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昆布のやうな黒いなめらかな梢の中では、あの若い声のいゝ砲艦が、次から次といろいろな夢を見てゐるのでした。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　雲平なるもの、板昆布のような袖口から、真黒な手を出して、図太く浚え込む形で手招く。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すでに、二日の日の午後、火と煙を三方に見ながら、秋の暑さは炎天より意地が惡く、加ふるに砂煙の濛々とした大地に茣蓙一枚の立退所から、軍のやうな人ごみを、拔けつ、潛りつ、四谷の通りへ食料を探しに出て、煮染屋を見つけて、崩れた瓦、壁泥の堆いのを踏んで飛込んだが、心あての昆布の佃煮は影もない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その上、式の如く、だし昆布を鍋の底へ敷いたのでは、火を強くしても、何うも煮えがおそい。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすると、ちよろ／＼、ちよろ／＼と草の清水が湧くやうだから、豆府を下へ、あたまから昆布を被せる。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、ぐら／＼と煮えて、蝦夷の雪が板昆布をかぶつて踊を踊るやうな處を、ひよいと挾んで、はねを飛ばして、あつゝと慌てて、ふツと吹いて、するりと頬張る。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小店の障子に貼紙して、　（今日より昆布まきあり候。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまが又かっと明るくなり、二人はむしろに座ってひばりもゐないのに、「ひばり焼げこ、ひばりこんぶりこ、」なんて出鱈目なひばりの歌を歌ってゐました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さまが又かっと明るくなり、二人はむしろに座ってひばりもいないのに、「ひばり焼げこ、ひばりこんぶりこ、」なんて出鱈目なひばりの歌を歌っていました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
