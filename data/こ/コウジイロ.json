        "examples": {
          "standard": [
            {
              "text": "夕焼け空が柑子色に染まり、とても美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は柑子色の着物を優雅に着こなしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この壁の色、柑子色で明るくていいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "雨全く収まりて、雲のうしろに朝日昇りたる東の天の美しさ、また紅に、また紫に、また柑子色に、少しづゝ洩るゝ其光りの此雲彼雲の縁を焼きたるさま、喩へん方無く鮮やかに眼も眩むばかりなり。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕は翔る、居留地の柑子色なす※玻璃ななめに高く。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "総身の羽が赤褐色で、頸に柑子色の領巻があって、黒い尾を長く垂れている。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして柑子色の帽子や、椎鈍の法衣なぞは、見慣れているだけに、有れども無きが如くである。",
              "citation": {
                "source": "鼻",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
