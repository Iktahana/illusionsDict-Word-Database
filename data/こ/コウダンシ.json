      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "handsome man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さあ、ちやんと胸を張つて、おれは日本一の好男子で、さうして、最上級の風流人だといふやうな顏をして威張つて歩くのですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少佐がどうして彼を従卒にしたか、それは、彼がスタイルのいい、好男子であったからであった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公の「野性的好男子」もわれらのような旧時代のものにはどうもあまり好感の持てないタイプである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりずっと若いロイド眼鏡、縞ズボンの好男子は、編集者。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文士、ひどく露骨で、下品な口をきくので、その好男子の編集者はかねがね敬遠していたのだが、きょうは自身に傘の用意が無かったので、仕方なく、文士の蛇の目傘にいれてもらい、かくは油をしぼられる結果となった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが好男子の田島も、それこそすごいほどのキヌ子の気品に押されて、ゴミっぽく、貧弱に見える。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田島の如きあか抜けた好男子の出没は、やはり彼女の営業を妨げるに違いないと、田島自身が考えているのである。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｒは当時有名な美少年であったがＫも相当な好男子であった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……好男子、惜しむらくは兵法を知らず……まあいい、もう行け」「僕も人見君といっしょに君を送ろう」「酔不成歓惨欲別か……柿江、貴様ははじめから黙ったまま爪ばかり噛んでいやがるな……皆な聞け、あいつは偽善者だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んで出たのは、玄関下足番の好男子で、近頃夢中になっているから思いついた、頭から顔一面、厚紙を貼って、胡粉で潰した、不断女の子を悩ませる罪滅しに、真赤に塗った顔なりに、すなわちハアトの一である。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と気軽に飛出し、表門の前を足早に行懸れば、前途より年｜少き好男子の此方に来懸るにはたと行逢いけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と敷居｜越に一礼する二十四五の好男子、伯爵｜太く渠を愛して才子々々と召たまう。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大木戸伯のか、百田時次郎、ね、御存じのあの好男子だか、どちらのだか知れますまい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "色白な細面で、髮を分けたハイカラな好男子。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ位のんでも大きな声で物もいえぬ程気が優しく、働く女への想いやりもあるようで、あまり好男子ではなかったがあちこちでもてた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ちやんと胸を張つて、おれは日本一の好男子で、さうして、最上級の風流人だといふやうな顔をして威張つて歩くのですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "是も不平を云はずに我慢してくれ玉へ　以上　　　　　　　　四月十四日夜金　　　　　三重吉樣　　　　　　　　　　三四六　明治三十九年五月三日　午前八時―九時　本郷區駒込千駄木町五十七番地より廣島市江波村築島内鈴木三重吉へ　［はがき］　寺田寅彦が千鳥をほめて好男子萬歳とかいて來た。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "好男子世に処して、屈託そうな面色で、露店の三世相を繰るとなると、柳の下に掌を見せる、八卦の亡者と大差はない、迷いはむしろそれ以上である。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今井田さんは、もう四十ちかいのに、好男子みたいに色が白くて、いやらしい。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど若いうち好男子ぶって加奈子を嫌がらせたってから、私あんまり好かないわ。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此人は色の淺黒い、氣の利いた好男子で、不斷身綺麗にしてゐる人のやうに思つてゐたが、病氣の診斷が極まつて餘程立つてからであつたにも拘はらず、果して少しも病人臭くはしてゐなかつた。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊長格は庄内の清河八郎で、丈のすらりとした面長の好男子、眼光鋭く人を射る男だつたと云ふ。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と云う内に自から真心が籠って、「一思いに好男子、粉にする処だっけ。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "半札の円輔三十六「さて早や、」と云う懸声で大和家の格子戸を開けて入る、三遊派の落語家に円輔とて、都合に依れば座敷で真を切り、都合に依れば寄席で真を打つ好男子。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "色は兀げたが、活きているようで、――（先には店頭にあったのだと後で聞いた）――息子は好男子なのに、……八郎の言った福助の意味も分ったが、どこに居ても、真夜中には、ふッと抜けて、屋の棟へちょんと乗って、ここの一家を守りでもしそうで、且つ何となく、不気味だった。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三枝の理想の好男子は絆纒着のうちにあると見える。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの常客に、稍や無頼漢肌の土地の好男子の連れて来る、凄味掛かった別品がいる。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでこそ貫目のある好男子になられたというものであると女たちがながめていて、指貫の裾からも愛嬌はこぼれ出るように思った。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "香峰は好男子にして、多情多恨の才子なり。",
              "citation": {
                "source": "月の隅田川",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "風采からいっても、美妙は色白な柔々しい、ドチラかというと少し柔気て、如何にも「詩人でございます」といったような美男であったが、紅葉は色の浅黒い、苦み走った、スッキリと背の高い江戸前の、美男というよりは好男子という方であった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
