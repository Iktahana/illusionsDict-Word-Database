[
  {
    "uuid": "e0344147-c9bb-591a-90e6-d25dc7f51cb5",
    "entry": "好男子",
    "reading": {
      "primary": "こうだんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
