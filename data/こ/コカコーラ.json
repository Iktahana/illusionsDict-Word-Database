        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "牛肉の大和煮、コンビーフ、ウィンナソーセージ、オイルサーディン、シャケの水煮、桃やミカンやパイナプルといった果物類、オレンジジュース、コカコーラ、そういった缶詰がほとんどだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラもそれにつられて、コカコーラをもってきた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コカコーラの缶なんかまぎれこんでいたら、疑われるって。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "義晴が、コカコーラの缶とクラッカーの箱を山崎に手わたした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日中は冷蔵庫にたやさずに置くコカコーラを愛用してゐる。",
              "citation": {
                "source": "飲料のはなし",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "コカコーラには今までの何ものにもなかつた新奇な味があつてわたくしの気に入つてゐる。",
              "citation": {
                "source": "飲料のはなし",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて冷えてゐないコカコーラを飲まされたら気分が悪くなるやうな味であつた。",
              "citation": {
                "source": "飲料のはなし",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動販売機で売っている一本のコカコーラが僕だと思ってくれれば間違いない。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔や体形やその他諸々のとるに足らない、言ってみれば製造番号のようなものでかろうじて他と区別できる以外、外見にせよ中身にせよ何の個性も持たないコピーされたコカコーラ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじくスロットにアルファベットをはめこんでいく方式であり、こちらのほうはコカコーラの広告をかねている。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "調理室のドアの左側の壁に、ソーダ・マシーンと丸い鏡とにはさまれて、コカコーラのマークが赤く入った縦長のメニュー・ボードがある。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二分十一秒のベティ・エヴェレットの歌の次は、コカコーラのコマーシャルだった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "コカコーラがあるとものごとはうまくいく、というコピーが、歌になっていた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このコマーシャルはアメリカに広くいきわたり、その結果として、ザ・ライムライターズのテナー、グレン・ヤーボロがグループを離れてソロになったとき、グレンは自分のレパートリーにこのコカコーラのコマーシャルを加えざるを得なかった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレン・ヤーボロとこのコマーシャルとがあまりにも強く結びついていたので、グレンを聞きにきた人たちは、ついでにコカコーラのコマーシャルも聞かないと、承知しなかったのだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四〇年代のコカコーラの宣伝用の看板さ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それが終わると、その男性は、店の主人に、コカコーラのロゴの入った看板や道具類を、すべて買いたいのだと、日本語で言ったんだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの取材を受けながら、その日本人男性は、この店にあったコカコーラに関係した品物すべてを、合計七千ドルで、買い取っていったんだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもいる若い女性の店員が、節子とヨシオにコカコーラを出してくれた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、名前も、コカコーラと、引っぱらずに、コカコラと縮めて発音していた（日本ではの話ですよ）。",
              "citation": {
                "source": "清涼飲料",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "春山行夫氏が東京新聞に書かれた「コカコーラの不思議」の中に、　……コカコーラは消防自動車のような赤いポスターや看板を出すので、美術の国イタリアは、その点を嫌がっている。",
              "citation": {
                "source": "清涼飲料",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
