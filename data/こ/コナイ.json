[
  {
    "uuid": "8f0177c8-498f-541f-8e9a-91ef47caf583",
    "entry": "庫内",
    "reading": {
      "primary": "こない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "inside (a refrigerator, warehouse, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また事務所内を調べたる所、気の毒なる見張人の惨殺されたる死体が、最大の金庫内に投げ込まれありたるを発見せり。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "金庫内には古き手紙若干と余り重要とも見えざる書類とあるのみ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、人目を避けて、車庫内の自動車の一つに乗り込んで、其処で話すことにした。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいか」　僕は、自分自身にこう云って、石油を浸して上衣に火を点けると同時に、それを格納庫内の飛行機へ投げつけた。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち、格納庫内は、火の海と化してしまった。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "課長は、もしや外に入れ忘れたのではないか、大金庫内の棚の引出などを念入りにしらべてみた。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "重要書類も文献抄も、この大金庫内には全く見えないのだ。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本生の応援で、書庫内の整頓に着手する。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よい気持に眠ってしまって駅に来たのも知らず、汽車は仕合せに山形止りであったので良かったものの、それでも危なく車庫内に運び込まれるところであった。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三、一九四　金庫内の現金の源泉と行方。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、私は、金庫内に入ってくる金額を現金勘定の借方に記入し、この金額がどこから来るかを示そうと欲し、また同様に金庫から出る金額を現金勘定の貸方に記入して、この金額がどこに行くかを示そうと欲していると想像する。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は、カラをつけ、襟飾を結び、背広を着たままで、地上六十｜呎、寂寞とした無人の大ビルディングの一角で――正確に云えば、Ｓ百貨店五階、洋家具売場附属倉庫内で、睡眠を摂っていたのだった。",
              "citation": {
                "source": "扉は語らず",
                "author": "小舟勝二",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は、今晩中を甘んじて此の倉庫内に過し、翌朝店員達が出勤し来る頃を見計らって、そしらぬ風を装おって出るのである。",
              "citation": {
                "source": "扉は語らず",
                "author": "小舟勝二",
                "note": "青空文庫"
              }
            },
            {
              "text": "金庫内に陳列されてある模樣は不明であるけれども、水素原子を單位としてはかれば、その貫目は若干、電子はあるかゞ判然してゐるのみならず、金庫外の商品に相當する電子が、幾何あるかも推定される。",
              "citation": {
                "source": "物理學革新の一つの尖端",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金庫内の價値は極つてゐるが、まだその蓋を開けて、中身を調べた人はない。",
              "citation": {
                "source": "物理學革新の一つの尖端",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金庫内に秘藏してある品物の状況はまだ判らぬものとして、その周圍にある品物はどうであるかと訊ぬるに、これらは順位が定つてゐて、容易に變換を許さない。",
              "citation": {
                "source": "物理學革新の一つの尖端",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一ヶ月ほどして内地から来た新聞に、『某信託会社の保護金庫内よりミイラ現わる』という大標題で、勝田家の借りていた大金庫内のトランクからミイラが出たということが出ていました。",
              "citation": {
                "source": "消えた霊媒女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、もりみつじゅんじは、青空文庫内にある「随筆計画２０００」や「青空文庫検索ページ」を作成した。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、意外にも突然連判状の所在が知れました、と云うのは自殺した運河会社社長の従弟であるジェルミノーさんが肺病で死ぬる間際に、警視総監に手紙を途って、実はあの連判状は自分の室の金庫内に保管してあるから、自分の死後取り出してくれと申したのでございます。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報はメイ発、金庫内の包みを大至急求めている。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、そのほかの庫内からも金繍綾羅、珠翠珍宝、山を崩して運ぶ如く、続々と城外へ積み出された。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――寿亭侯の印をはじめ、金銀緞匹の類、すべてを庫内に封じて留めおき、内室には十美人をのこし、その余の召使い二十余人、すべて関羽と共に、二夫人を車へのせて、夜明け前に、北門より立退いた由でございます」　こう聞いて、満座、早朝から興をさました。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いていよいよ薫しき武門の華、あなた如き人こそ真の大将軍というものであろう」　と、斜めならず、その労をねぎらい、なお庫内の黄金五十｜斤と絹一万｜疋を賞として贈った。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "金品はしばらく庫内にお返しをねがって、やがて冬の頃ともなり、なにかと物不自由になった時分、これを諸軍勢に少しずつでも頒ち給われば、寒軍の中に一脈の暖気を催しましょう」　孔明はふかく感嘆した。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり彼は詩人として第一に大事な点に於ては決してころがりつこないのだ。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　まああたし、小説家には叶ひつこないわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別役の精様がこないだから連れて行てくれい云いよりましたがのうし。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "な、お前がいくら頑張ったって、船長も云ったように、一億円の船会社にゃ、勝てっこないんだから」　セコンドメイトは、デッキの上と橋板の上とでは、レコードの両面見たいに、あべこべの事を云い始めた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけても其書いてゐたときの熱情と韻律とが二度と浮んでこないことを苦しんだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだから姉さんの処へ越して行こうかとも思って見ました。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
