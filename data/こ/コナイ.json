        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり彼は詩人として第一に大事な点に於ては決してころがりつこないのだ。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　まああたし、小説家には叶ひつこないわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「別役の精様がこないだから連れて行てくれい云いよりましたがのうし。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "な、お前がいくら頑張ったって、船長も云ったように、一億円の船会社にゃ、勝てっこないんだから」　セコンドメイトは、デッキの上と橋板の上とでは、レコードの両面見たいに、あべこべの事を云い始めた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけても其書いてゐたときの熱情と韻律とが二度と浮んでこないことを苦しんだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだから姉さんの処へ越して行こうかとも思って見ました。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、こないだから、子供の洋服や靴をあんなに買つてやりたいつて言つてたぢやないの？",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだ雜誌だか新聞だかでひよいと讀んだ話であるが、佛蘭西のある市のある家の一室である朝中年の紳士がピストルで顳※を貫かれて死んでゐた。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだ女中殺しのあつた……」「ははは、物騷な方か……」と、引き取つて咳き、水上さんが顏を笑ひ崩した。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こないだだって、靴直しに三円持って行って、あれで、一円くらいあまっとる筈だのに自分で取りこんどるんだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こないだ、土匪が三人、捕まったんだってよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街をもぐり歩いている陳長財が、まだ帰ってこないのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不機嫌なのは、一緒に出かける筈の陳がまだ帰ってこないからだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「王洪吉の女房、こないだ、女の子供、産んだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚がＴ「此処には居なくとも御仏の御力を借りて拙僧が」Ｔ「必ッとその御方を貴女の眼の前へ御連れします」　おふみ、　「馬鹿々々しい」Ｔ「お生憎さま、妾の想ってる御方ァね、和尚さん」Ｔ「仏さまが鯱立ちして力んだって、こんなケチなお寺へは来っこないの」　と云い捨てて、廊下へ出ようとする。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだからもな、風邪ひいとるんやけど、しんどうてな、おかあはんは休めというけど、うちは休まんのや」「薬は飲んでるのか」「うちでくれたけど、一服五銭でな、……あんなものなんぼ飲んでもきかせん」　喬はそんな話を聞きながら、頭ではＳ―という男の話にきいたある女の事を憶い浮かべていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために生物はその祖先の定型を保存し、できそこないの妖怪はできない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな巧妙なものでも、時代に合わず、西洋からはやってこない限りたいして商売にはならないらしい。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、日本は無条件降伏という事になり、私も故郷にかえり、Ａの郵便局に勤めましたが、こないだ青森へ行ったついでに、青森の本屋をのぞき、あなたの作品を捜して、そうしてあなたも罹災して生れた土地の金木町に来ているという事を、あなたの作品に依って知り、再び胸のつぶれる思いが致しました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお隣りの畳屋にも東京から疎開して来ている家族がおりますけれども、そこの細君がこないだうちへやって来て、うちの細君と論戦しているのを私は陰で聞いて、いや、面白かったですよ。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだは、ありがとう。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆不精の私は、未だにお礼状も何も差し上げていない仕末ですが、こないだの三宅島爆発では、さぞ難儀をなさったろうと思いながら、これまたれいの筆不精でお見舞い状も差し上げず、東京の作家というものは、ずいぶん義理知らずだと王様も呆れていらっしゃるだろうと思います。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだ、或る先輩が、よく、まあ、君は、生きて来たなあ、としみじみ言っていました。",
              "citation": {
                "source": "春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだの晩は、かなり飲みましたね。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬は私には、いまだ飛びかかってこない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
