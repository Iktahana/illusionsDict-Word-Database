[
  {
    "uuid": "a92d10d7-244a-526a-8bc9-2dbf3129c3ce",
    "entry": "骨",
    "reading": {
      "primary": "こつ",
      "alternatives": [
        "コツ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
