[
  {
    "uuid": "495a01c2-8d9d-517f-9122-c61d0a9d08e7",
    "entry": "公明",
    "reading": {
      "primary": "こうめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
