    "definitions": [
      {
        "index": 1,
        "gloss": "mild late autumn day (around November)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしただ一度ある小春日のわが家の門前で起った些細な出来事だけがはっきり印象に残っている。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の暖かい日にはうとうと居眠りをした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となしこの小春日にふさわしい長閑なものの名である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦播きがすむと、彼等はこんどは、枯野を歩いて寺や庵をめぐり、小春日和の一日をそれで過すのをたのしみとしているのだ。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の日曜とて、青山の通りは人出多く、大空は澄み渡り、風は砂を立てぬほどに吹き、人々行楽に忙がしい時、不幸の男よ、自分は夢地を辿る心地で外を歩いた。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し大庭真蔵は慣れたもので、長靴を穿いて厚い外套を着て平気で通勤していたが、最初の日曜日は空青々と晴れ、日が煌々と輝やいて、そよ吹く風もなく、小春日和が又｜立返ったようなので、真蔵とお清は留守居番、老母と細君は礼ちゃんとお徳を連て下町に買物に出掛けた。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和な小春日がのどかに野を照らしていた。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "警備の巡査、兵士、それから新聞社、保険会社、宗教団体等の慰問隊の自動車、それから、なんの目的とも知れず流れ込むいろいろの人の行きかいを、美しい小春日が照らし出して何かお祭りでもあるのかという気もするのであった。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も亦、寒い雨と荒い風とが見舞つて來る前の、なごやかな小春日向が續くのだらう。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和の午後の陽ざしは、トシオの広い賢げな額や、健康らしく肉付きの引しまった頬に吸い寄りました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時や冬、小春日の返り咲にも怪し何處にか取り得たる。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海の土地は気候が長閑で、寒の中も、水がぬるみ、池には金魚がひらひらと、弥生の吉野、小春日の初瀬を写す俤がある。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつその鳥は、小春日の朝、空が曇って、大島が判然と墨で描いたように見えた時、江浦、吉浜の空を伸して、遠く小田原の城の森から、雲の上を飛んで来て、ふうわり、足許へ来て留った、そこから苗が出来たというのであるが、鳥はこの親仁が、名を知らぬものだったかも計られぬ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "上等の小春日和で、今日も汗ばむほどだったが、今度は外套を脱いで、杖の尖には引っ掛けなかった。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は小春日の明い街道から、衝と入ったのでは、人顔も容子も何も分らない。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、やや立離れた――一段高く台を蹈んで立った――糶売の親仁は、この小春日の真中に、しかも夕月を肩に掛けた銅像に似ていた。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　這奴、窓硝子の小春日の日向にしろじろと、光沢を漾わして、怪しく光って、ト構えた体が、何事をか企謀んでいそうで、その企謀の整うと同時に、驚破事を、仕出来しそうでならなかったのである。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日や障子に人の影も無く　十一月二日、明治座の初日、わが作『小栗栖の長兵衛』を上場するに付、午頃より見物にゆく。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、産声が空に響くようなからりと晴れた小春日和だったが、翌日からしと／＼と雨が降り続いた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……晩に雪が来ようなどとは思いも着かねえ、小春日和といった、ぽかぽかした好い天気。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論誰も手を触れず、いつ研いだ事もないのに、切味の鋭さは、月の影に翔込む梟、小春日になく山鳩は構いない。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜというに、仕入ものの、おとしの浅い箱火鉢の前に、二十六七の、色白で、ぽっとりした……生際はちっと薄いが、桃色の手柄の丸髷で、何だか、はれぼったい、瞼をほんのりと、ほかほかする小春日の日当りに表を張って、客欲しそうに坐っているから。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、産声が室に響くようなからりと晴れた小春日和だったが、翌日からしとしとと雨が降り続いた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小春日和が続いて、窓を開けて置いても目立たぬので、お玉は又岡田の顔を毎日のように見ることが出来た。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは小春日和のうららかに晴れた日の午すぎで、当主の勘次郎は出番の日に当っているので朝から留守であった。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月のはじめで、小春日和というのだろう。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、産声が空に響くようなからりとした小春日和だったが、翌日からしとしと雨が降り続いた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓子台の上は冬の花野で、欄間越の小春日も、朗かに青く明るい。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
