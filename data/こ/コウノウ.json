[
  {
    "uuid": "119f3276-1a4b-5263-90cb-d202d738ca34",
    "entry": "効能",
    "reading": {
      "primary": "こうのう",
      "alternatives": [
        "くのう"
      ],
      "is_heteronym": true
    },
    "grammar": {
