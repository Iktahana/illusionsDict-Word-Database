[
  {
    "uuid": "5260c5e6-7310-5a8a-baa1-42cfd64d4465",
    "entry": "事になる",
    "reading": {
      "primary": "ことになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
      "ctype": null,
