    "definitions": [
      {
        "index": 1,
        "gloss": "approximately thirty minutes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
