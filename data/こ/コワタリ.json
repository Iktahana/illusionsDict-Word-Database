[
  {
    "uuid": "be5e8611-47c5-565c-aad3-88d5aa0f2618",
    "entry": "古渡り",
    "reading": {
      "primary": "こわたり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
