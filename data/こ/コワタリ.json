    },
    "definitions": [
      {
        "index": 1,
        "gloss": "old imported article (esp. a precious item imported during or before the Muromachi period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昔流行つた無地の面子の淡紫、淡紅の色、また古渡りの器皿の青貝の螺鈿の輝き、その惹起する感情は孰れも相似てゐるが、わたくしは其齎らす情緒の成因を分析する術を知らない。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻が咲いたと言へば、折詰をこしらへて青い古渡りの毛氈をぼんさんに持たせて、嵯峨の方へ出かけて、どこの田の畦でもピクニツクをはじめる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "軸は古渡りの唐更紗につつんで桐の箱に納めてあるのを、更にその上から風呂敷に包んだのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、骨董好きが古渡りの茶※でも見るやうな、うつとりした眼つきで自分の手首に穿つた手錠に見惚れてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "白牡丹で買ったばかりの古渡りの珊瑚の根掛けや、堆朱の中挿しを、いつかけるような体になられることやらと、そんなことまで心細そうに言い出した。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は色の浅黒い、小肥りに肥つた男で、形の如く結城の単衣物に、八反の平ぐけを締めたのが、上に羽織つた古渡り唐桟の半天と一しよに、その苦みばしつた男ぶりを、一層いなせに見せてゐる趣があつた。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "底を覗いてみると孔雀型の刻印があるからには勿体なくもイギリスの古渡りじゃないか。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの礼盤の中央には、五鈷鈴や経文を載せた経机が据えられ、右の座の端には、古渡りらしい油時計が置かれてあった。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古渡りの工芸品といへば、玉の類だが、之は古くは、首里王宮から下げられ、後には佩用者自身が買ひ求めるやうになつたらしいが、その水晶或はがらす玉を貫いた御統の珠の多くは、我々の夢にも知らなかつた間に、本土の玉磨りの手から交易して求めた物が多いらしい。",
              "citation": {
                "source": "沖縄を憶ふ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宋朝古渡りの素焼壺で、吉凶共に著しいもの、容易ならぬ器でございます」尚古堂は気味悪そうに云った。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着ている物も立派であって、腰につけている煙草入の、根締の珊瑚は古渡りらしく、これ一つだけで数十金はしよう。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って高価な古渡り珊瑚の、根締の玉も見当らない。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套の裏は繻子でなくては見っともなくて着られないと云ったり、要りもしないのに古渡りの更紗玉とか号して、石だか珊瑚だか分らないものを愛玩したりする話はいまだに覚えていた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "練物で作ったのへ指先の紋を押しつけたりして、時々｜旨くごまかした贋物があるが、それは手障りがどこかざらざらするから、本当の古渡りとは直区別できるなどと叮嚀に女に教えていた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月の邪気を祓うた薬玉は、万葉びとさへ既に、続命縷としての用途の外に、装飾といふ考へも混へてゐたのであるが、此飾り物も或は単に古渡りの舶来品といふばかりでなく、髯籠の形が融合してゐるのではあるまいか。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、右の神話は国産、民俗は古渡りの物というてもよろしからう。",
              "citation": {
                "source": "桃の伝説",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天日矛や、つぬがのあらしとなどを帰化民団と見ずに、侵入者と認めた時代の、古渡りの流寓民の村々にくつゝいて渡つて来たものと思はれる。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで幇間にその煙草入をくれてしまった、それが薄色珊瑚の緒〆に古渡りの金唐革というわけだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "以て当時の人々の鑑賞力のほどもわかって来るというもので、所謂古渡り物は、今日なお食器の最高権威として取扱われている次第である。",
              "citation": {
                "source": "料理と器物",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ古渡りの陶器だっただろうが、それだからとてそれを元禄時代と誰がゴッチャにするであろう。",
              "citation": {
                "source": "「あばた」も「えくぼ」、「えくぼ」も「あばた」",
                "author": "――日本石器時代終末期問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "古渡り紅地広東縞の羽織。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川左近将監自慢の、呂宋古渡りのお茶壺です。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その箱のふたをとれば、あかい絹紐のすがりがかかって、そのすがりの網の目を通して見える壺の肌は、さすがに朝鮮古渡りの名器、焼きのぐあいといい、上薬の流れあんばいといい、たとえば、芹の根を洗う春の小川のせせらぎを聞くようだと申しましょうか。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　顔見識りの朝湯仲間、あっちこっちから声をかけるなかを黙りこくった八丁堀合点長屋の目明し釘抜藤吉、対の古渡り唐桟に幅の狭い献上博多をきゅっと締めて、乾児の勘弁勘次を促し、傘も斜に間もなく紅葉湯を後にした。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、花嫁が駕籠の中で殺されるなんざ江戸開府以來でも古渡りの方ぢやありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、親分」「古渡りの江戸開府以來は嬉しいな。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "大變の申し子が、大變｜國から大變を賣りに來たやうぢやないか」　平次は古渡りの大變くらゐには驚く色もありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凉み船",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、起きろよ、大變も大變、古渡り大變だ」　平次は路地の中から、張り上げるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼女",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな古渡りの退屈を喰っちゃ、御用聞は腕が鈍るばかりだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも栄華の名残りの古渡りの唐桟に、博多の帯、少し薄い膝に手を置いて、色白の細っそりした顔が、男乍ら※たけてさえ見えるのに、何んと言うことでしょう、側には脱ぎ捨てたばかりの汚いねんねこと浅葱の手拭と、正護院の本尊なる弥勒菩薩の木像が、唐紙に凭せかけられたまま、慈眼を垂れて二人を見護って居るのでした。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
