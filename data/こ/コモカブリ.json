    "definitions": [
      {
        "index": 1,
        "gloss": "cask wrapped in straw matting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "正月の鏡開きで、威勢の良い掛け声とともに薦被りの蓋が割られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祝いの席には、やはり銘酒の詰まった大きな薦被りがよく似合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "薦被りから柄杓で汲み出された日本酒は、杉の香りが微かに漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "薦被りが転がり込む。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの角は河合という土蔵造りの立派な酒屋で、突当りが帳場で、土間の両側には薦被りの酒樽の飲口を附けたのが、ずらりと並んでいました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大玄関には薦被りがドカリとすえてあるんだ」「何んの薦被り？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「畜生ッ、薦被りは灘の生一本と極ってらア――ところで、おれの後ろにいる人の顔が見えねえのか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "beggar",
        "register": "standard",
