        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近代的のものでもゴルフの外に庭球野球｜蹴球籠球排球などがあり、今は流行らぬクリケット、クロケーから、室内用にはピンポン、ビリアードそれから例のコリントゲームまである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ヨーヨーとコリントゲーム　ヨーヨーがすたれて、コリントゲームがいまだに残存している。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしコリントゲームの方には公算的統計的の要素が入り込む。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーヨーの緊張時代のあとにコリントゲームの弛緩時代がめぐって来たものと見える。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び道具は豊富で、コリントゲームだのルーレットだのわたくしには始めてゞ珍しいものゝ外にいろはかるたやトランプのような馴染のものもありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愉快に飲んで酔ふ、街へその愉快を延長して、鮨を食べたり、コリントゲームを遊んだり、例の女を相手に飲んだり、……ホツトウヰスキーでおわかれ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつしよに出かけてＳさんを訪ねる、御馳走になる、それから三人連れで歩く、コーヒー、ビフテキ、コリントゲーム、等、等、等。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろになって、この原っぱへきはじめた、コリントゲームのおじいさんが、今日も店を出して、まわりには、もうたくさん子供たちが集まっていました。",
              "citation": {
                "source": "町はずれの空き地",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　さういふつもりはなかつたのだけれども、彼はふとそこに並んでゐる三台のコリントゲームをみつけ、覘きこむやうにしてその規則を読み、やがて五銭白銅をはめこんで、ガチヤリと玉を弾きだした。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
