    "definitions": [
      {
        "index": 1,
        "gloss": "single (room)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ホームズは戸を押して個室の方へ入り、ビールを二杯、赤ら顔で白いエプロンの亭主に注文した。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "四分の三は各自の個室におり、この中に美姫あることは必定ですよ」　そこで美姫をさがすことになったんだがね。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その方は、社長さんかどうかは知りませんが、立派な紳士で、筋向いの個室に入っていられますのよ。",
              "citation": {
                "source": "落日の光景",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はプラグマティズムを、一切の知識が一旦そこへ出なければ動きが取れないという意味で、多くの個室に通じる廊下に譬えている。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな石造りの個室をあてがわれてはいたようだが。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "この清潔無類の病院では個室にも何処にも瓦斯や電気はつかえないことになっている。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お客様は個室をお望みで？",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしてマニングツリーの個室に入った。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車の個室が自由に使えますし、旅の食事も用意してます。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしければ私の個室にいらして、昼食をご一緒しませんか。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミーファが個室の隅にどっかと座り、煙草をつけた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為に個室を予約したのです。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐにムーアは首相の個室に通された。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "当分の間、本物はジェノバの個室に監禁してある。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリーンバムが責任者に面会を求めると、すぐ個室に案内された。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食の時間、ヴァンシターがクロイドン司教の個室に疲れ切った様子でぶらりと入ってきた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "メアリはこれら全てを、友人達と自分の個室に座り、午後のお茶を飲みながら話していた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人のはからいで、初めは個室に入ったが、入った日から睡眠治療が始まったらしい。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角奮発してみた窓つき個室も、こうしてみると意味がなかった。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから窓つきの個室をとることにした。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコーヴごとに領域を設定できるし、そのなかにいるとなかば個室のようであり、本を選ぶ人の気持ちは落ち着く。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは個室にとおされた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下のこちら側の端は、校長のための応接室と個室になっていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "応接室に入った受付の女性は、個室との仕切りの壁にあるドアをノックした。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルのかたわらで待っていると、校長が個室から出て来た。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりの名刺と日比谷の本を持って、校長は個室に戻った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリム氏が個室で到着を待っており、ゆるい部屋着を着ていたので、一層背が高くやせて見えた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "当家の個室で、わたくしの叔母と二人きりで夕食をしておられました。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャロウェイお嬢様を個室へ移せないことはないでしょう。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "個室なら逃げ出せる機会があるし、ギャロウェイお嬢様を自宅へつれ戻せます」　地獄に仏だとロナルドが言って、再び赤い唇にキスした。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
