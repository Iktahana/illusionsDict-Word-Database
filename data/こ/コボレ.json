[
  {
    "uuid": "337382ea-0c53-5335-9a45-9acc97a8e09d",
    "entry": "毀れ",
    "reading": {
      "primary": "こぼれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
