[
  {
    "uuid": "6c36ff03-0f80-5574-9c89-2263ea76793a",
    "entry": "高校生",
    "reading": {
      "primary": "こうこうせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
