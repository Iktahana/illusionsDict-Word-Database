        "examples": {
          "standard": [
            {
              "text": "「この親にしてこの子あり」とはよく言ったもので、彼の子供もやはり音楽の才能がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の態度の悪さを見て、「この親にしてこの子あり」と嘆く人もいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "親子でそっくりな行動を見ると、「まさにこの親にしてこの子ありだね」と皆が笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さ、いつごろ安房守に叙爵したっけかな――トニカク、鳶が鷹を産んだのか、いや、この親にしてこの子ありか、人間の万事はわからぬものだ、と神尾が思いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
