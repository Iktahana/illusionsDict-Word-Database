          "standard": [
            {
              "text": "筆記試験を通過した者だけが、翌日の口述試験に進むことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "口述試験では、専門知識だけでなく論理的な説明能力も厳しく問われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "緊張のあまり、口述試験の最中に頭が真っ白になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし彼は恐ろしい口述試験まではゆけなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "北欧型顔回は口述試験に及第した。",
              "citation": {
