          "literary": [
            {
              "text": "（ポポーフという男のくせだ）それは奇麗ずきで、目先をかえたがってこせつくことだ。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は女で、こせつくようにと女がするのだから可笑しい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "関守氏は、目的地に着いたからといって、驀直に目的に向ってこせつくような軽策を取らない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
