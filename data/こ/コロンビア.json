        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ボブ・スタインとの出会い　コロンビア大学で心理学を、ハーヴァード大学の修士課程で教育学を専攻したスタインは、エンサイクロペディア・ブリタニカ社の社長にコンサルタントとして雇われていた時期、ヴィデオディスクとコンピューターを組み合わせて、新しい用途を開く研究に取り組みました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吾等万一今回の試合に敗れたるあかつきは翌年度の出場権をコロンビア大学に譲渡の止むなき絶壁に瀕せるなり。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "英領コロンビアのタクル人（Takullier）の観念は独特なものであって、すなわち、始めには水と一匹の麝香鼠の外には何もなかった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞で、彼の来朝を知り、Ａが、コロンビアの、プロフェッサー・ジャクソンの教室で紹介されたことがあるので、会ったら彼の為に何か助けられよう、と云うのであった。",
              "citation": {
                "source": "思い出すこと",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人はコロンビア大学に植物を教え、夫人は、同じ大学に、矢張り植物の一分科を受持っています。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生というはっきりした資格でもなくて、その寄宿舎に暮したりしたニューヨークのコロンビア大学も構内の芝生が美しかった。",
              "citation": {
                "source": "女の学校",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一次欧州大戦が終ったばかりで、人道的な英雄としてベルギーの皇帝・皇后がコロンビア大学に招待された初夏の光景は壮麗に思い出される。",
              "citation": {
                "source": "女の学校",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜の朝は七時頃起き朝飯を食つてからコロンビアまで仕事を探しに家具會社の監督さんに會ひに歩いて出掛けました。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロンビアでは知人には誰にも會はず麥酒を二三杯引掛け私は家の方へ歩いて歸つて來ました。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風趣の作品を書いた作者落華生が、コロンビア大学、オクスフォード大学に遊学して、専門は印度哲学の教授であるというのは面白い。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、コロンビアの大図書館の石階を登りつめた中央に、端然と坐して、数千の学徒を観下す、Alma Mater をも御存じでございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロンビアの高い壁　　三十一日　ミス　ダニエルに会う。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方場内には二十名ばかりの音楽隊が輪を作ってコロンビア・マーチを奏していた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへは、米国コロンビア大学の薬学部長ラマビー博士一行が探検したが、ついに瘴癘湿熱の腐朽霧気地帯から撃退されている。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａが、青山から帰って来ると直ぐ、コロンビアクラブに行くことになり、いそいで身なりを調え出かける。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、星の六階でコロンビア会。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、コロンビア会に彼がスペシアルゲストとして呼ばれて居る。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オペラ」のなかの「人さらひ」は、コクトオ自身の朗讀がコロンビア・レコオドに吹き込まれてゐるので、諸君も御存知だらう。",
              "citation": {
                "source": "ハイネが何處かで",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が僅か五ヵ月経験したコロンビアの寄宿舎生活の不快さが、充分それを、少くとも私には証明して居る。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パナマ」「オレゴン」「ゴールデン・ゲート」「コロンビア」などの当年切っての優秀船が就航して太平洋横断いつでも来いと待構えた。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "その実験的確認には、ウラニウム二三五を分離する必要があるが、それは次の年、一九四〇年三月に完成、すぐコロンビア大学で、前の理論を確認する実験が行われ、四月三日にはもう成功している。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロンビア大学の生化学講座は幸福なことにシェーンハイマーのその後の研究に便宜を提供することができた。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロンビア大学医学部生化学講座ハンス・T・クラーク（サイエンス, 94, 553, 1941 の訃報から）はじめに　この講義の原稿は1941年９月のはじめに思いがけなく世を去る前に Schoenheimer 博士が準備したものである。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピエールさんはコロンビアの大学のヒュウ・ボートン先生の日本の講座に出ていて、ひらがなを書けるのが自慢なのである。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大草原の旅行者はしぜんと猟師になり、ミズーリ河とコロンビア河との上流では罠をかけ、セント・メアリーの滝では釣りびととなる。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "例を挙げると「ブラウンの新兵さん」（ワーナー・ブラザース）は軍隊生活が漫画化されているというので、「セシリア」（コロンビア）は宮廷の低俗な描写があるというので、いずれも上映禁止。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
