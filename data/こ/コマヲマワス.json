        "examples": {
          "standard": [
            {
              "text": "公園の広場で、子供たちが紐を使って器用にこまを回して遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔ながらの木製のこまを回すのは、コツを掴むまでがなかなか難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お正月の伝統遊びとして、学校の授業でこまを回す体験会が開かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「先生こまをまわすことは、わるいことですか。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、ちょっと頭をかしげて、すぐには、返答をなさいませんでしたが、しばらくしてから、「こまをまわすことを、いけないというのではない。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくも、子供の時分は、こまをまわすのが大すきだった。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おら、子供の時分から、こまをまわすのが、大好きなのさ。",
              "citation": {
                "source": "こま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
