        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その時仮橋ががたがたいって、川面の小糠雨を掬うように吹き乱すと、流が黒くなって颯と出た。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小糠雨猶止まねど雲脚しきりに断れて西の方の空いよ／＼明るく、朝風涼しく吹きて心地よきこと云ふばかり無し。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "車窓には梅雨にはいつて間もない小糠雨がけむつてゐる。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真向うは空地だし、町中は原のなごりをそのまま、窪地のあちこちには、草生がむらむらと、尾花は見えぬが、猫じゃらしが、小糠虫を、穂でじゃれて、逃水ならぬ日脚の流が暖く淀んでいる。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾時仮橋ががた／＼いつて、川面の小糠雨を掬ふやうに吹き乱すと、流が黒くなつて颯と出た。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この柔し、小糠たつ杵、それすらや、さみし、このごろ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部には杵の音がし、小糠のにおいがこめ、男女の声がしていた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小糠雨の細いのが、衣服の上から毛穴を徹して、骨に染むやうで、天窓は重くなる、草鞋は切れる、疲労は出る、雫は垂る、あゝ、新しい筵があつたら、棺の中へでも寝たいと思つた、其で此の家を見つけたんだもの、何の考へもなしに駈け込んだが、一呼吸して見ると、何うだらう。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品は勘次が梯子を掛けて一つ／＼に大根を外すのも小糠を筵へ量るのも白い鹽を小糠へ交ぜるのも滿足氣に見て居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "プティ・ペダント」　二時頃から小糠雨が降り出す。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって――貴婦人が来たら困っちゃうのよ皆」　　　　　　　　第三日　長崎は雨の尠いところだそうだのに、今朝も、雲母を薄く張ったような空から小糠雨が降って居る。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は家のものに隠れて手拭につゝんだ小糠で顔をこすり出した。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人に別れて、やがて小糠雨を羽織に浴びながら、団子坂の文房具屋で原稿用紙を一｜帖買ってかえる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人に別れて、小糠雨を十ちゃんの羽織に浴びながら、団子坂の文房具屋で、原稿用紙を一帖買ってかえる。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "共同耕作の三十人は、小糠雨の中を躍るようにマンノーを振りかぶり、猶も、　うなっちゃえ！",
              "citation": {
                "source": "共同耕作",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から小糠三合もったら養子に行くなというくらいだから、御覧のとおり何一つないうちへ来てくれとは決して云わない。",
              "citation": {
                "source": "聟",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東條は依然としてヒステリックで、先ごろも閣議で内田農相が、食糧増産につき玄米よりも白米が小糠の利用その他で有利だと言うと、「そんなこと今ごろ言っているのか」と眞赤になって怒鳴りつけた。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "春さめ、さみだれ、しぐれ、驟雨、ゆうだち、霧雨、小糠雨、その外にもなおあるであろう。",
              "citation": {
                "source": "雨粒",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "さみだれの静かに降りそそぐ音とか、ゆうだちの激しくものを撃つ音とか、音もなくひっそりと濡らしてゆく小糠雨とか、みんなそれぞれの趣きをそなえているのである。",
              "citation": {
                "source": "雨粒",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "はて困つた、三合の、小糠はなぜに持たなんだと、思はず漏らす溜め息に。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小糠三｜合ということがある。",
              "citation": {
                "source": "ある温泉の由来",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝になると、昨夜は星が綺麗に見えていたのに、小糠雨が降っていた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝からの小糠雨はまだやまなかった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁子屋家付きの娘で、旦那は小糠三合の入聟ですもの、あんなに小さくなつて居なくたつて宜いやうなものですが――」　お若は自分のことのやうに憤慨するのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "三つの菓子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしからよく小糠三合なんて云うじゃないか。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "小糠のような雨が生暖かいむんむんするような春の気を部屋一杯に垂れ込めて、甘酸っぱい梔子の匂いが雨に打たれて、咽ぶように家の中じゅうに拡がっていた。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日の午後、正造は俥の幌もかけず小糠雨の中を渡瀬村の下早田へ来た。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は朝から小糠雨が降りしきっていたが、聴衆は泥濘を踏んでつめかけた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "この草はな、この草はな、こぬかぐさ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの人は、うそをつくと死んでから赤鬼に、舌べろを釘ぬきでひっこぬかれるといったものです。",
              "citation": {
                "source": "一年生たちとひよめ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
