        "examples": {
          "standard": [
            {
              "text": "過酷な迫害の中、多くの宣教師が「転び伴天連」となり、仏教に改宗した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の文献には、「転び伴天連」となった人物の名前がいくつか記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は「転び伴天連」の生涯を研究し、その背景にある社会状況を分析した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "又拷問の仕方や、始めの歴史叙説は無論、沢野忠庵と云ふ転び伴天連が踏絵を発明した事も事実であり、アントニオ・ルビノと云ふばてれんが殺された事も事実である。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            }
          ]
        }
