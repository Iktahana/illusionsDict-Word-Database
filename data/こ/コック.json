  {
    "uuid": "058ff36d-9203-5faf-864d-edd020fbe2ad",
    "entry": "コック",
    "reading": {
      "primary": "コック",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
