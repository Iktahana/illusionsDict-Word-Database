    "definitions": [
      {
        "index": 1,
        "gloss": "cook",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一つコックの工合の悪いのがあって、それから湯が不断に流出している。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時主婦のルコック夫人が甲高い声を張上げて Elle a rougi ! elle a rougi ! と叫んだ。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの巴里人のならわし通りこの男も老後を七、八十｜里巴里から離れた田舎へ恰好な家を見付けて買取り、コックに一人の女中ぐらい置いて夫婦の後年を閑居しようという人達だ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京虫や蚤蚊に攻められながら、野羊の乳を飲み、アラビア人のコックの料理を食って、一八七二年の十二月十二日から翌年三月中旬にわたる単調な船住いをつづけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お昼すぎ、飯盒で炊いた飯を食い、コック上りの吉田が豚肉でこしらえてよこしたハムを罐切りナイフで切って食った。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお黙ってはいたが、コックリと点頭して是認した彼の眼の中には露が潤んで、折から真赤に夕焼けした空の光りが華※しく明るく落ちて、その薄汚い頬被りの手拭、その下から少し洩れている額のぼうぼう生えの髪さき、垢じみた赭い顔、それらのすべてを無残に暴露した。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それならば……私は……どう致したら、よろしいので……」　赤猪口兵衛はコックリと一つうなずいた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "後藤さんのお手本のようにコックリとした演出味なぞ、いずれも立派な明るい、舞台表現として頭を下げさせられるが、実さんのお能を見ると、そんなものがちっとも感じられない。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてコックが上つて来て、我々の部屋の五つばかりの電灯を、三つも消してゆくと、我等の唄声は、益々大きく乱暴になつてゆくのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の仕込みの鰈は生きが悪かったとかコック頭とコックと喧嘩して青豆を茹で過ぎたとか、とかく店の為にならない話だ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台の上の二人は、手を握ったまま、ふいっとおじぎをして、それから、「バラコック、バララゲ、ボラン、ボラン、ボラン」と変な歌を高く歌いながら、幕の中に引っ込んで行きました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はもと船乗りで、子供の頃から欧洲航路の船に雇はれて、鑵炊きをしたり、食堂の皿洗ひをしたりコックをしたりしたが、四十の歳に陸へ上つて、京都の吉田で洋食屋をはじめた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、コックの腕に自信があり過ぎて、良い材料を使つて美味いものを安く学生さんに食べさせるといふことが商売気を離れた道楽みたいになつてしまつたから、儲けるといふことには無頓着で、結局月々損を重ねて行つたあげく、店はつぶれてしまつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンゲコックがその上を踊ってくれるだろうよ。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けさは燻製の鰊と、ボイルドした鱈とをコックさんが用意して来てるね。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那料理のコックででもあるかな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "給金を減らされたのは、ティアという老人で、サモア料理（召使達の為の）のコックだが、実に完璧といっていい位見事な風貌の持主だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智小五郎、手塚竜太、帆村荘六、俵巌、シャアロック・ホルムズ、アルセーヌ・ルパン、ルコック、ソーンダイク、エラリー・クイーン等々の名前は、単にその名前が紙面に顔を出しただけでも読者の血を湧かす。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変失礼な比喩ではあるが、とにかく恐ろしく古風な感じのするコックリとした型であったように思う。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鶴三「なァに気楽な商売をと考えたんですよ、陸へ上った時にね、コックの腕に覚えがあるんではやらぬ洋食屋をやったり、こんな柄にもないレコード屋をやったり……今にして想えば、もっと身体を責めて働かなきゃならなかったんですよ。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧院の廊下へはいって見ると、頭を大部分｜剃って頂上に一握りだけ逆立った毛を残した、そして関羽のような顔をした男が腕組みをしてコックリコックリと廊下を歩いている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルコックなら君の探偵像に合致するだろう？",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ルコックは哀れなへっぽこだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルコックは六ヶ月あたりはかかったな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "2012（平成24）年7月13日翻訳※挿絵は、ハワード・ケッピー・エルコック（1886-1952）によるものです。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "英人リチャード・コックス『江戸日本日記』一六二二年（元和八年）二月二十一日の条、コックス江戸にあり芝居に之く途上オランダ館に入り肥後か肥前の王に邂逅す、武勇な若い人で年々五十万石を領す、今蘭人に事え居る僕一人、先にかの王に事えた縁によりオランダ館を訪ねたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎途を横ぎるを忌む事欧州のほかインド、ラプランド、アラビア、南アフリカにも行わる（コックス、一〇九頁）。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
