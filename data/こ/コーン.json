    "definitions": [
      {
        "index": 1,
        "gloss": "(ice cream) cone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "またビルマ語で「コーンダーン」は小さき山脈。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その三原山行きの糧食としてＮ先生が青木堂で買って持って行ったバン・フーテンのココア、それからプチ・ポアの罐詰やコーンド・ビーフのことを思い出したので、やっとそれが明治四十二年すなわち自分の外国留学よりは以前のことであって帰朝後ではなかったことがわかった。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人でありながらロシア人やアメリカ人になったような気持ちで浮かれた事を満載した書物はよく売れると見えて有り過ぎるほどあるのに、連句の本などはミイラかウニコーンを捜す気で捜さなければ見つからない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時にはコーン・フレックスといって玉蜀黍の沢山入ったパン菓子の暖め立てのものを食べます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩等は握飯を失ったので仕方なく、コーンビーフの缶詰を切り、握飯の中の梅干だけはまさか汗漬にもなるまいと、塩からい冷肉をパク付き、梅干をしゃぶっている心細さ！",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはラオコーンの群像を照らしました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の全身からは滝のやうなあぶら汗が流れ、私はラオコーンのやうに身悶えた。",
              "citation": {
                "source": "小田原の夏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄音機のダイナミックコーンからはジャズや流行小唄が飛び出しておりからの鐘楼の時の鐘の声に和している。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコットランドで押し込み強盗をしたと思えば、次の週はコーンワルで孤児院の設立資金とかぬかして金を騙し集めていたりしやがる。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "はなはだしきは、コーンウォール州に、他州人の破船多くて獲物多からんことを祈り、立てた寺院すらあるなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーンウォールの鉱夫金掘りに之く途中老婆または熟兎を見れば引き還す（タイロル『原始人文篇』巻一、章四）。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてアサー、ロンドンに諸侯を会した宴席で、コーンウォール公ゴーロアの美妻イゲルナに忍ぶれど色に出にけりどころでなく、衆人の眼前で、しきりに艶辞を蒔いたを不快で、かの夫妻退いて各一城に籠り、王これを攻むれど落ちず。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "球は、また高く、澄むだ空にコーンと鳴つて飛むでゆきました。",
              "citation": {
                "source": "初夏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は口惜しさの余り、その手紙を引き裂かうとする――未練さの余り、役者のやうに醜い顔付をして仰山にも、手紙に接吻をする――すると私は、このやうに悲嘆の余り胸をかきむしつて、無気味な肉体をのたうちまはし、ラオコーンのやうに怖ろしい苦悩に虐げられてゐる光景が――何だか猛烈に痛快なやうな気がして来る。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小さなちゃぶ台には、コーラやオレンジジュースの缶、ポテトチップスやポップコーンの袋がのっていて、あちこちから頻繁に手が伸ばされている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プールのむこう端を仕切る、アイスクリームのコーンを伏せてならべたような植えこみの先端と、巨大な空とにはさまれ、小さく、男子寮の上端の光がのぞいている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志の書置きに目を走らせるやいなや、ポップコーンをぶちまけるように、ワラは、ありとあらゆる単語を、ひとまとめにして慶一に投げつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に公爵夫人ヴォルコーンスカヤをよんで、途中で巻をおくことが出来ませんでした。",
              "citation": {
                "source": "私は何を読むか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜もお前は、あんな英雄達の気楽な仕事はおろか、クレメント噴水の馬にでもイダーリア通りの表口に近々建つことに決つたラオコーンにでもなることを厭はない！",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラオコーンが務まれば毎日金貨が一袋｜宛儲かるわよ。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前だつて、ラオコーンにでもなれば毎日毎日好きな自由なお酒の栓が抜けるんだよ、斯んなに可愛好い妾のために――」　踊子やソフイストの言葉を上の空に聞き流しながら水夫はパトロンのチユニツクの広袖にかくれてゐる娘を覗いた。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモ・ファーベルはゾーン・ポリティコンであり、その故にまたロゴン・エコーンである。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーナス、コーンのようにユークリッド空間の先験性を主張する時（J. Cohn, Voraussetzungen und Ziele des Erkennens, S. 249）このように質と量とを区別してユークリッド空間は質的に先験的となるというならばそれは一層明らかとなるであろう。",
              "citation": {
                "source": "物理的空間の成立まで",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまドロップスの入っていた空き缶の蓋を払いのけて底に小さな孔をあけ、そこに糸をさし入れて缶を逆さに釣り、鉛筆の軸かなにかでコーンと一つ叩いてみるがいい。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が理想的実行家としてリンコーンを愛好すると同じ程度に於て、ここに理想的思想家の真意義をソクラテスの人格に見出して、すべての他の偉人にも増して、これが尊崇の念を禁じ得ないのである。",
              "citation": {
                "source": "ソクラテス",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の罰より覿面にアタル……この通り……ポコーン……』とか何とか仰言って、買ってくれた人の横ッ面を……」「ハハハ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の所蔵品をしらべると、ビスケット、ハム、腸づめ、コーンビーフ、魚のかんづめ、野菜等、倹約すれば二ヵ月分はある。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上には湯気が立つスープ、コーンビーフ、小鳥やき、チーズ、ゼリー、水をわったぶどう酒などがある。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
