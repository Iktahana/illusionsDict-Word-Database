[
  {
    "uuid": "e288cdd5-3d61-5a23-9415-4232ea4a1ad5",
    "entry": "穀粒",
    "reading": {
      "primary": "こくりゅう",
      "alternatives": [
        "こくつぶ"
      ],
      "is_heteronym": false
    },
    "grammar": {
