      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kernel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それはたちまち器械の中で、きれいな黄色の穀粒と白い細長い芯とにわかれて、器械の両側に落ちて来るのでした。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝来たばかりの赤シャツの農夫は、シャベルで落ちて来る穀粒をしゃくって向うに投げ出していました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝来たばかりの赤シャツの農夫は、シャベルで落ちて来る穀粒をしゃくって向ふに投げ出してゐました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠の中に散って居るばかりか、一尺も間のある床の間まで、黄色い穀粒は飛んで居る。",
              "citation": {
                "source": "餌",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ鶏だけは、暑さにもめげずに、台所の登り口の下のからからにかわいた地面を、しきりにあしでほじくりながら、どうにか時間つぶしをしていましたけれど、そこにはもう鶏たちも先刻ご承知のとおり、穀粒ひとつだって残ってはいないのです。",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ鶫が、鳥籠の底にまいてある穀粒を拾う嘴音がコツコツと聞こえるだけであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "キプルスでは口に入れた穀粒に、唾のついていない時には、その人間が犯人なんですってね。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下部放大せる処は子房にしてその形小に後穀粒を成す処の者なり。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に穀粒は種子に非ずして果実なり。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その穀粒の状図中の「ホ」の如し。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵が孕めば間もなくそれが種子となり子房の皮は果皮と名を換え、子房はそこで果実となるが、禾本類の果実は特に穎果と呼ばれ、すなわち通俗にいえば穀粒で、米麦の穀粒とあえて異なる所はないが、その形が極めて微小だからあえてこれを利用するには足りない。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空飛ぶ鳥が、そのあわて急ぎの穀粒を遠方へ運んでゆくうちに、鳥が偶然に種子を蒔くことがあるように彼の上に一粒を落したのであろうか？",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "苞状をなした一空頴は小穂より少しく長く、穀粒は小形で長楕円形を呈し白褐色である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この毒麦がよく小麦畑に生えるので、その収穫のさい毒麦の穀粒が一緒に小麦の穀粒にまじることがある。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその毒麦の穀粒は刺激性、麻酔性の毒分を有し、それを食うとよく口に譫語を発し、胃に苦しい痙攣がおこり、心臓が衰弱し、睡気を催し、眩暈がしあるいは昏倒し、悪寒が来、嘔気を催しあるいは嘔吐し瞳孔が散大する。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この記念すべき実生モウソウチク林は大正元年（1912）に実すなわち穀粒を播いてはやしたものだが、次第に生長繁茂して今日にいたったので、今はまことに立派なモウソウ藪となっている。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甞て照らせし日輪は、甞ての日、その尖に穀粒さやぎし詰藁の中にくるまり今も猶、燃つてゐるのでございます。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "白さおよび多孔性をつくるのに必要な明礬の量は小麦粉の本物さおよび小麦を得る穀粒の質によっている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "製粉業者は同じ種類の穀粒から種類が違う小麦粉を作る。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "パン小麦およびパン小麦粉の良さを判定する易しい方法　粉屋はパン小麦の質の良さを穀粒が作る籾の質によって判断する。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「積み藁で熱されたり燃やされた穀粒は次のようにしてパンにするのに適したようにされる：「小麦は少なくとも３倍の量を入れることができる器具に入れ、沸騰水を満たす。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "穀粒は単なる加熱によって完全に水溶性のガム状の物質に変化し、これによってこのビールは普通の褐色モルトよりも酢酸発酵に移り易かった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし褐色モルトは一般に質が悪い大麦から調製され、特許モルトは良質の穀粒からのみ作られるので、この点で醸造者にとって有用な産物（少なくともビールにとって色と本体を与えるもの）ではあるが、良質のポーターを作るのに必要なモルトの量を節約することはできなかった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三年、穀粒と名のつくものはただの一口も咽喉管を越させていないので、身体にたあいがなく、若いものでも一俵に二人、年寄りどもは四人がかりで一俵の米にとりつき、八日かかって、ようやく運び終った。",
              "citation": {
                "source": "藤九郎の島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "穀物を一粒も失うまいとして、彼らはあらゆる種類の野生の穀粒を穀物の中に入れたままにしておくので、これはしばしば悪い結果を生ずる。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然的肉体から霊魂の姿に復活するということは、それ自身としては、穀粒から小麦の葉が生じたりどん栗から樫の木が生ずること以上に不思議なこととは、思われない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以上精密にできているのはないようなふるいをするりとすり抜けるためには、陳情人はどんなに特別な、まったく特定の形をした、小さい巧みな穀粒でなければならないでしょうか？",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
