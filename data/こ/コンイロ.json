        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "チタ子は断髪にしたうなじを紺色の海にむかってこころよさそうに左右に振って見せました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側の岸には真黒な森が高く低く連なって、その上に橋をかけたように紫紺色の夜空がかかっていた。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫紺色に寒々とさえた空には星がいっぱいに銀砂子のように散らばっている。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は紺色の長いマントをひつかけ、純白の革手袋をはめてゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は紺色の長いマントをひっかけ、純白の革手袋をはめていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろのまっ黒なびろうどの幕が両方にさっと開いて顔の紺色な髪の火のようなきれいな女の子がまっ白なひらひらしたきものに宝石を一杯につけてまるで青や黄色のほのおのように踊って飛び出しました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り合せの木綿の布切を、家の者が紺色に染めて、ジヤンパーみたいなものと、ズボンみたいなものにでつち上げた何だか合点のゆかない見馴れぬ型の作業服なのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもあとで、たけから聞いた事だが、その日、たけの締めてゐたアヤメの模様の紺色の帯は、私の家に奉公してゐた頃にも締めてゐたもので、また、薄い紫色の半襟も、やはり同じ頃、私の家からもらつたものだといふ事である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の色は次第に黒みを帯びた紺色に変りつつあった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船には二三十人の木偶の坊が紺色の繪の具で並列せしめられた。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船宿には派手な縞の外套を小脇に抱へた大學生や、鼠の二重廻の男、洋服を着た十三四の女の子、その紫紺色の外套が殊に美しかつたことやなどが大勢集つてゐて、一種の繪模樣を造り出して居た。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその上の梁の一つに紺色の可憐な燕の雛が懐かしさうに、牡丹いろの頬をちらりと巣の外に見せて、ついついと鳴いてゐる日もあつた。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、めぐみが濡らした墓の上はいちめんに紫紺色の罪の靄、神經のきみぢかな花が顫へてゐる。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜かな晝間、人のゐない官舍の裏に南瓜の蔓が伸び、その黄色い花に、天鵞絨めいた濃紺色の蝶々どもが群がつてゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな昼間、人のいない官舎の裏に南瓜の蔓が伸び、その黄色い花に、天鵞絨めいた濃紺色の蝶々どもが群がっている。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……水色の襟と、紺色の着物と、桐油合羽の黄色を襲ね合わせた白い襟筋のなまめかしかったこと……。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨が涎をば流すかいな……」「流すにも何にもハンボン・エッキスちうて欝紺色のネバネバした涎をば多量に流す」「……まあ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆牛の頭のように角のある顔の恐ろしい、それで体の青い紺色の髪の毛の、頭にも手足にももじゃもじゃと生えた者で、それがそれぞれ戟のような物を持っていた。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな洋服が近頃流行なのか、そんなことは私も知りませんが、ヒラヒラとした、裾の怖ろしく短い白いスカートと、バンドのついた紺色の上着です。",
              "citation": {
                "source": "心配な写真",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間、深い紺色の空の彼方から、小石のようなものが一つ飛んで来て、ひょいと上枝にとまって、身軽に立ちなおったのを見ると、それは一羽の小鳥であった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてその上の梁の一つに、紺色の可憐な燕の雛が懷かしさうに、牡丹いろの頬をちらりと巣の外に見せて、ついついと鳴いてゐる日もあつた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもいつも日中はどんよりと曇りつづけ、それが夜になると皮肉にもカラリと晴れて、月や星が、冴えた紺色の夜空に冷く輝きはじめる。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど朝顔の花は紺色のものもやはりその朝限りの命にて強くもあらずとおどけ興じたるなり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺色に染めた真綿を亀の甲のやうに背中に負つて、手拭を頭に巻きつけて、私達に茶をすゝめて呉れる休茶屋の婆さんが居る。",
              "citation": {
                "source": "突貫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方には二人とも山本さんの旅舎で、お牧の方は流行｜後れの紺色のコオトを脱ぎ、お新の方は薄い鼠色のコオトを脱いだ。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方には二人とも山本さんの旅舎で、お牧の方は流行後れの紺色のコオトを脱ぎ、お新の方は薄い鼠色のコオトを脱いだ。",
              "citation": {
                "source": "船",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "父のところには、とにかくそういう英語で、しかも絵入りのがあるので、何か欲しいとせがんだら一冊の紫紺色表紙の本を貸してくれました。",
              "citation": {
                "source": "写真に添えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平凡でただゆったりしているのが便利な私の机の上にいつもあるのは、山羊の焼物の文鎮、紺色のこれも焼物の硯屏。",
              "citation": {
                "source": "机の上のもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うこんいろにそめられたくさむらであり、まぼろしの花花を咲かせる昼のにほひであり、感情の糸にゆたゆたとする夢の餌をつける五月、ただよふものは　ときめきであり　ためいきであり　かげのさしひきであり、ほころびとけてゆく香料の波である。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
