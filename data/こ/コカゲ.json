    "definitions": [
      {
        "index": 1,
        "gloss": "shade of a tree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木陰に短銃を手にしたなりひらが立って居た。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "背｜格好から歩きつきまで確かに武だと思ったが、彼は足早に過ぎ去って木陰に隠れてしまった。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱漆で塗った地に黒漆でからすの絵を描いたその下に烏丸枇杷葉湯と書いた一対の細長い箱を振り分けに肩にかついで「ホンケー、カラスマル、ビワヨーオートー」と終わりの「ヨートー」を長く清らかに引いて、呼び歩いていたようにも思うし、また木陰などに荷をおろして往来の人に呼びかけていたようにも思う。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桃や李は、物を言わないのに木陰にはひとりでに道ができる。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "急ぎて裏門を出でぬ、貴嬢はここの梅林を憶えたもうや、今や貴嬢には苦しき紀念なるべし、二郎には悲しき木陰となり、われには恐ろしき場処となれり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時｜青年の目に入りしはかれが立てる橋に程近き楓の木陰にうずくまりて物洗いいたる女の姿なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはかれが家の庭を流れてかの街を貫くものとは異なり、遠き大川より引きし水道の類ゆえ、幅は三尺に足らねど深ければ水層多く、林を貫く辺りは一直線に走りて薄暗きかなたより現われまた薄暗き林の木陰に隠れ去るなり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅の葉、黄色の葉、大小さまざまの木の葉はたちまち木陰より走りいでてまた木陰にかくれ走りつ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はある百姓の軒下、明日は木陰にくち果てた水車の上というようにどこという事もなく宿を定めて南へ南へとかけりましたけれども、容易に暖かい所には出ず、気候は一日一日と寒くなって、大すきな葦の言った事がいまさらに身にしみました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど峠の頂上に近かき所において、路傍の木陰より一頭の兎が飛び出した。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ひたひたと木陰地に寄せて、足もとの朝草小露明らみぬ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動場のすみの木陰では楽隊が稽古をやっているのをシナ人やインド人がのんきそうに立って聞いている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな枝を張った木陰のベンチに人相の悪い雑種のマライ人が三人何かコソコソ話し合っていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころにあるステーションだけにはさすがに樹木の緑があって木陰には牛や驢馬があまり熱帯らしくない顔をして遊んでいた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三の丸の石段の下まで来ると、向こうから美しい蝙蝠傘をさした女が子供の手を引いて木陰を伝い伝い来るのに会うた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日暑い盛りに門へ出たら、木陰で桶屋が釣瓶や桶のたがをはめていた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿になった自分は窓から中庭にのがれて、アカシヤの木陰をかけぬけ、古い井戸の側に行って、釣瓶から滴る水が身体の上に落ちると、自分はいつか美しい女になって歩いてゐる。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の木陰から朝日がさし込んできた。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は研桶と唄との二つの聲が錯綜しつゝある間にも木陰に佇む男のけはひを悟る程耳の神經が興奮して居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の木陰に身を避けてしんみりと互の胸を反覆す時繁茂したの木であれば梢からまだ青い實を投げて、其の瞬間驚き易い彼等が欺かれて、彼等の伴侶の惡戯であるかを疑うては慌てゝ周圍を見る時、繁茂した大きな葉が凉しい風にさや／＼と微笑する。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し熊手の爪が速かに木陰の土に趾つける其の運動さへ一｜度は一｜度と短い日を刻んで行く樣な冬の季節は餘りに冷たく彼等の心を引き緊めて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は其を耳に感ずる瞬間右の手が壁際の木の根に掛つて、木の根は彼の力一｜杯に木陰の闇に投ぜられた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると闇い木陰に潜伏して居て嫁の車が近づいた時突然、其の車を顛覆させてやれといふやうな威嚇的の暴言をすら吐くことがある。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年極つた踊の場所は村の社の大きな樅の木陰である。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れが月光を遮つて居る樅の木陰に著るしく目に立つて、身を動かす度に一｜齊にがさがさと鳴りながら波の如く動いて彼等の風姿を添へて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄商人はカンテラの光明と木陰の薄い闇との間に立つた其の姿が明瞭と見極め難いので、頻りに目を蹙めつゝ求められる儘に筵の端に立つて西瓜を出して遣る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊子は其れを手にして慌しく木陰に隱れる。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラの光の爲に却て眼界を狹められた商人は木陰の闇から見れば滑稽な程絶えず其の眼を蹙めつゝ外の闇を透して騷がしい群集を見て居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次は俄に眼を聳かすやうにして木陰の闇を見た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま奥の間の、一枚開いた障子のこかげに、机の上にそろばんをおいて、帳面を見ながら、パチパチと玉をはじいてる。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
