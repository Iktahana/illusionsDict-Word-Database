[
  {
    "uuid": "4188c2c2-f467-5011-85f9-e971be98e9d3",
    "entry": "戸数",
    "reading": {
      "primary": "こすう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
