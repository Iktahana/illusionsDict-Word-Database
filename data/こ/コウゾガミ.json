        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "證票は強靱な楮紙から出來てゐて、印紙が貼つてあり、等級を現す數字が、青いゴム印でべつたり捺してある。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "楮紙の最上なものは全州産だという。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の楮紙の多くは流漉であって、これは外国にない特色あるやり方であります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉書は楮紙でありますが、これに米の粉を加えて抄造します。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "純楮紙で甚だ厚みがあり色はやゝ黄ばんだ調である。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に見事な楮紙であると云はねばならぬ。",
              "citation": {
                "source": "和紙十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一片の楮紙でも無駄にするには忍びない。",
              "citation": {
                "source": "和紙の教へ",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁皮紙は上位を、楮紙は右位を、三椏紙は左位を占める。",
              "citation": {
                "source": "和紙の美",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
