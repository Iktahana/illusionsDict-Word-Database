[
  {
    "uuid": "4e85fb27-f666-54ed-84b1-43a5faf00516",
    "entry": "告白",
    "reading": {
      "primary": "こくはく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "confession (to a crime, wrongdoing, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みたばかりの死に茫然として、卑怯にも似た感情を抱いて私は歩いてゐたと告白せねばなりません。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自らその門弟と称したルモオルに於てであつたと告白してゐる。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の苦い経験の全て、やさしい告白の全ては、アムール・ジョーヌの中にある。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此の書物こそは」私は言ふ「日本人が日本語で書いた告白の最初の真実であり、そして日本に於ける、最初の感情生活の記録である」と。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の住持になって世を隠遁し、読経と墓掃除に余生を送りたいといった彼の言葉は、決して一時の戯れではなく、彼の心の無限の悲哀を告白した言葉であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は自らそれを告白して、良人の気性をすっかり呑み込むようになるまでは、一通りでない努力をしたと言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の告白によれば、自分の良人に対する真の愛は、その時初めて起ったという。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを私は告白します。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に告白すると、かうした訳を読んで滑稽になり、いつも失笑を禁じ得ないのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来言へば、すべての良心のある翻訳者は、小宮氏が言つた位のことは自分で訳本の序に書いている筈である、堀口大学君の如きも、その訳詩集に「失はれたる宝石」といふ題をつけてゐるし、故上田敏博士も、訳詩集を出す毎に翻訳の不可能に属することを、自ら告白して謝罪されてゐた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻、菊池寛氏へもわが生きかたの粗雜貧弱を告白して、いまは大事の時だ、めそめそ泣いて歩きまはつてゐたつて仕樣がない。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と狸はほくほくして、「でも、あの鮒つてやつは、素早いもんでなあ、おれはあいつを捕へようとして、も少しで土左衞門になりかけた事があるけれども、」とつい自分の過去の失態を告白し、「お前に何かいい方法があるのかね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして正体もなく、今｜茲に告白をする、恥もなく、品位もなく、かといつて正直さもなく私は私の幻想に駆られて、狂ひ廻る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの種の批評は必ずしも無責任とは云えない、ただ当然な事実の正直な告白に過ぎない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内省の結果をここに告白しようとは思わないが、ただこれだけ云っておきたいと思う事がある。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時中原君は、強度の神經衰弱で弱つてることを告白し、不斷に強迫觀念で苦しんでることを訴へた。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが實際のところを告白すると、僕はあまり多く彼の作品を讀んでゐなかつたのだ。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに告白すると、當時僕は甚だ不愉快の印象を君から受けた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今僕はすべて此等のことを、明らさまに僞らず告白する。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼の小説は、正直に告白して殆んど讀んでないのである。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は現に、魚の心を知つてると告白してゐる。",
              "citation": {
                "source": "橋上",
                "author": "――詩壇の議論家に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五歳のとき某氏に自ら身を委したことを告白す。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、某氏との関係はいまもつづいていることを告白す。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、某私立大学生、某会社員、某教師等々と関係したことを告白せり――。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに甚だをかしい告白だが本場の北京、天津、上海、杭州、乃至は奉天などで支那料理を食つたその晩やその翌日なりは、私は、いつもとなく色欲の興奮を感じさせられた。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下はある男の告白である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は嘘がうまいから、行いだけでもよくなさい」　知っていながらその告白を強いる。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一言だけ、告白する。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとたびあざむけば、君、死ぬるとも告白、ざんげしてはいけない。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜に三つも四つも「妙な縁」やら「ふとした事」やら「思わぬきっかけ」やらが重って起っても、一向に恋愛が成立しなかった好例として、次のような私の体験を告白しようと思うのである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
