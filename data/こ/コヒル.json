        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "農作業の合間に、温かいお茶と握り飯で小昼をとった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは遠足の途中で、お母さんが作ってくれたお菓子で小昼にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山登りでお腹が空いたので、持参したパンで小昼を済ませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
