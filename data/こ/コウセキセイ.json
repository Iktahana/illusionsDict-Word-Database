        "examples": {
          "standard": [
            {
              "text": "洪積世に生息していたマンモスの骨格標本が、シベリアの永久凍土から発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "人類が道具を使い始めたのは洪積世のことであり、過酷な氷河期を生き抜く知恵だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洪積世から沖積世への移行期に、地球の気温は急激に上昇し、植生が大きく変化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "人間性というのは、これが洪積世以後人間にまで進化してから各種の体験に依って作り上げた特性で、こんなのが通有性と固有性とを問わずゴチャゴチャと遺伝されている事は申すまでもありませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをむずかしくいうと、第四期の洪積世であって、旧石期時代にあたる。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
