[
  {
    "uuid": "0eb0323c-1887-5b2e-b02e-43576de36de2",
    "entry": "事柄",
    "reading": {
      "primary": "ことがら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
