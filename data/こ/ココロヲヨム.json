    "definitions": [
      {
        "index": 1,
        "gloss": "to read (someone's) thoughts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
