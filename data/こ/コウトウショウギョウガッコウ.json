    "definitions": [
      {
        "index": 1,
        "gloss": "higher commercial school (pre-WWII)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
