  {
    "uuid": "986e101a-3379-5b0d-adc3-c420ace67343",
    "entry": "木枯らし",
    "reading": {
      "primary": "こがらし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
