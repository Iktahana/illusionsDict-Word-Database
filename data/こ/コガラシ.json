    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cold wintry wind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "美代が宿入りの夜など、木枯らしの音にまじる隣室のさびしい寝息を聞きながら机の前にすわって、ランプを見つめたまま、長い息をすることもあった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯らしの吹くたそがれ時などに背中へ小さなふろしき包みなど背負ってとぼとぼ野道を歩いている姿を見ると、ひどく感傷的になってわあっと泣き出したいような気持ちになったものである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ふけて人通りのまばらになった表の通りには木枯らしが吹いていた。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死に物狂いの大晦日の露店の引き上げた跡の街路には、紙くずやら藁くずやら、あらゆるくずという限りのくず物がやけくそに一面に散らばって、それがおりからのからび切った木枯らしにほこり臭い渦を巻いては、ところどころの風陰に寄りかたまって、ふるえおののきあえいでいるのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし木枯らし吹く夕暮れなどに遠くから風に送られて来るラッパの声は妙に哀愁をおびて聞こえるものである。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五人、五六人という群れになって北山おろしの木枯らしに吹かれながら軒並みをたずねて玄関をおとずれ、口々にわざと妙な作り声をして「カイツットーセ」という言葉を繰り返す。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯らしにまたたく街路の彩燈の錦の中にさまざまの幻影が浮かびまた消えるような気がするのであった。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田の夜店の木枯らしの中に認めたこの青衣少女の二重像はこのほとんど消えてしまっていた記憶を一時に燃え上がらせた。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいちょうも次第に落葉して、箒をたてたようなこずえにＮＷの木枯らしがイオリアンハープをかなでるのも遠くないであろう。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かよわい糸でつるされているように見えるが、いかなる木枯らしにも決して吹き落とされないほど、しっかり取りついているのであった。",
              "citation": {
                "source": "簔虫と蜘蛛",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に権田原の広い野原を近所に控えている此処らは、木枯らしと云いそうな西北の風が身にしみた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "山里は冬ぞ寂しさまさりける――まさかにそれほどでもないが、庭の枯れ芒が木枯らしを恐れるようになると、再びかの荒涼索莫がくり返されて、宵々ごとに一種の霜気が圧して来る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は薄い月が行く手を照らして、もう木枯らしとでもいいそうな寒い風が時どきに木の葉を吹きまいて通った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の奥の住まいには、毎日木枯らしが吹いて、木の葉も落ちつくすと、やがて深い雪が森をも谷をもうずめつくすようになりました。",
              "citation": {
                "source": "葛の葉狐",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十一月には木枯らしが吹き、一荒れごとに淋しい落葉の音もまれに、梢越しにははや雪が見え出してくるし、安曇野の村々には冬篭りの用意ができ、どの家にも暖い炬燵が仕切られてくる。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月の中旬、木枯らしは梢の効用を吹き飛ばした頃は、まだ湖面に氷が張っていないから小舟を水に浮かべて釣ったが、一月に入ると湖はすっかり氷結するから、厚い氷へ、一尺四方くらいの穴をあけて、そこへ鈎を下ろすのである。",
              "citation": {
                "source": "榛名湖の公魚釣り",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　晴れた空に星が冴えて、木枯らしが水の面に、はらはらと落ち葉を降らせてくる夜である。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある冬の、木枯らしの吹きすさむ晩のことでありました。",
              "citation": {
                "source": "酔っぱらい星",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩には、寒い木枯らしが吹きすさびました。",
              "citation": {
                "source": "山へ帰ったやまがら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　政ちゃんは、寒い、木枯らしの吹きそうな、晩方の、なんとなく、物悲しい、西空の、夕焼けの色を、目に描いたのです。",
              "citation": {
                "source": "ペスをさがしに",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い晩で、木枯らしの音がきこえていました。",
              "citation": {
                "source": "ペスをさがしに",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、中にも、達ちゃんと正ちゃんは、ペスを助けなかったのを、後悔しながら、木枯らしの吹く中を、みんなと歩いていたのです。",
              "citation": {
                "source": "ペスをさがしに",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のうちから木枯らしが吹きつのり、日中も人通りが、絶えたのです。",
              "citation": {
                "source": "とうげの茶屋",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき、おびやかすように、ものすごい木枯らしが、吹かなければ、なおよかったのです。",
              "citation": {
                "source": "どこかに生きながら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて、寒い、寒い、木枯らしの吹く夜、そして、霜のしんしんと降る夜明け方、母ねこに抱かれて、安らかに眠った、なつかしい記憶が、はしなくも風の音によって、思い起こさせられたのでありましょう。",
              "citation": {
                "source": "どこかに生きながら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯らしは、そのさびしいほかにはだれも人影のいない墓地に吹きすさんで、枯れた葉が、空や、地の上にわびしくまわっていました。",
              "citation": {
                "source": "星の世界から",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊の花は既に萎れ山茶花も大方は散って、曇った日の夕方など、急に吹起る風の音がいかにも木枯らしく思われてくる頃である。",
              "citation": {
                "source": "枇杷の花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋も老けて、末になると、いつしかかきの木は坊主になってしまって、寒い木枯らしが、昼も夜も吹きさらしました。",
              "citation": {
                "source": "お化けとまちがえた話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりだつたから、私は川筋を兩方にながめて、――あゝ、おもひ起す、さばけた風葉、おとなしい春葉などが、血氣さかんに、霜を浴び、こがらしを衝いて、夜ふけては蘆の小窓にもの思ふ女に、月影すごく見送られ、朝歸り遲うしては、苫で蟹を食ふ阿媽になぶられながら、川口までを幾かへり、小船で漕がしたものだつけ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの声は、こがらし。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
