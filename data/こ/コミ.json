    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Komi (Russia)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　コミックの女のように肩をゆすって彼女は立ち上ると、部屋の把手をあらあらしく廻した。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこれは余程コミ入った容易ならぬ事件じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまらなくコミ上げて来る笑いと一緒に、身体をよじって腹を押えて、しまいには畳の上にたおれてノタ打ちまわりながら、ヒステリー患者のように笑いつづけた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "オトウサンハ、タキクンノ　カホヲ　ノゾキコミナガラ、「オトナシク　シナキヤ　イケナイヨ。",
              "citation": {
                "source": "センセイノ　コ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "変り種は地方廻りのオペラコミックの女役者と乞食が一人あった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに横腹がザワザワと粟立って、何かしら悲痛な熱いものが、胸先へコミ上げて来るのをグッと嚥み下した。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四百億円というと大戦後の独逸を、カイゼルもヒンデンブルグもヒトラーもコミにして丸ごと買える金額だからね。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「え、駄目なの――切符を、十枚も売って上げたのに、少しコミッションよこしてもいいわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この木を伐らせ、コミッションを得んとする役人ら、毎度合祀を勧めしも、その地に豪傑あり、おもえらく、政府真に合祀を行なわんとならば、兵卒また警吏を派して一切人民の苦情を払い去り、一挙して片端から気に入らぬ神社を潰して可なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "少部数のミニコミなら、コピーでも作れるようになったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の『しかし』は、勝手に集まった連中が気ままに出していったミニコミで、教師の指導とも無縁です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生時代のミニコミ作りや出版社でのアルバイトでじょじょに慣れていったせいか、私自身はそれほど驚いた記憶はありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミニコミの質も、間違いなく上がる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のマスコミからは、船舶電話での現場リポートを求められました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "核攻撃を受けて通信線の一部が途絶えても、全面的なコミュニケーションの途絶に陥らないよう備えた、網の目状の〈打たれ強い〉通信網が原点だったと言うのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "東芝はコンピューターやワープロの開発、製造を青梅工場に集約しているが、徹底してコンピューターによる自動化を推し進めたこの工場のマスコミ向け見学ツアーが催されたのが一九八九年の十二月四日。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六八年頃、ゼロックスのパロアルト研究所（この世界の『虎の穴』のようなものだ）に入る前、一九六八年頃にダイナブックについて考え始めたころ、アラン・ケイはこれを「サービスやコミュニケーションのアイデアとして想定した」という。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "）」を訴えたマンは、七〇年代に入って筆を折り、マスコミとの縁を断つ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『朝日新聞』（を典型とするマスコミのかなりの部分）には、パーソナルコンピューターに関する世界観（がオーバーなら土地勘）を持つ記者がそれほど払底しているのだろうか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけはないのだが、コンピューターに対する過剰な期待と過剰な反発をキメラ化させたマスコミ精神のカーネル・コードを書き直すほどの勢力を、連中は大組織の中で確保しえていないということなんだろうな。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついには「日米マスコミ騒然※」とオビに大書された本まで出た。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「名前を付けるとすればパーソナル・インテリジェント・コミュニケーターとでもなるんでしょうか」という開発中のマシンを、ビル・アトキンソンはマニュアルを読む気などもうとうないバアチャンだって、にっこり笑って一日中使ってくれるものにしたいという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして第二は、コミュニケーション。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの難関がクリヤーできれば、パーソナル・インテリジェント・コミュニケータはまったく新しい道具の世界を開くだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パーソナル・インテリジェント・コミュニケータは複数のメーカーから販売されるだろう」とのビル・アトキンソンの指摘を思いだせば、後発からきっちりと文脈を付けてコンピューターに乗りだしてきたＳ社（繰り返しになるがソニーである）あたり、当然このアイデアを逃すはずはない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊一九九一年十一月二十八日、ソニーとモトローラーはジェネラル・マジックへ資本参加し、パーソナル・インテリジェント・コミュニケータの開発に向けて両社の技術を提供していくとの方針を明かにした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に触れたジェネラル・マジックのパーソナル・インテリジェント・コミュニケータの開発プロジェクトが目指すものは、大つかみにして言えば、パーソナルコンピューターと電話が出会って生まれるスーパー情報引き出し機である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここからでてくるものがコミュニケータだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずこのコミュニケータには当然、デジタル化された電話帳が組み込める。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
