[
  {
    "uuid": "33e29eb2-6111-53f7-bf4d-aa9e014a4ebb",
    "entry": "古記録",
    "reading": {
      "primary": "こきろく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
