    "definitions": [
      {
        "index": 1,
        "gloss": "Federacio de Proletaj Kultur-Organizoj Japanaj (1931-1934)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
