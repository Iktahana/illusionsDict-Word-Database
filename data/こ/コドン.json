        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつも何かと言うと私の知恵袋にしておったアンタを、直接に松倉｜様に引合わせて、私とも膝をば突合わせたなら、三人寄れば何とやら、よい知恵が出まいとも限らぬ……と言う私の一生涯の知恵を絞ったドンドコドンのドン詰めの思い付きじゃが、ドウかいな。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "全山ウチワ太鼓に埋まっていると見えて、一歩々々と久遠寺の七｜堂伽藍が近づくに随い、ドンドンドドンコ、ドドンコドンと、一貫三百どうでもよいのあのあやに畏こい法蓮華囃子が、谷々に谺しながら伝わりました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドコドコドンドン、ヒュウヒョロヒョロと、朝ごとに角兵衛獅子の囃子がその柳原お馬場の近くの旅籠町からわびしく流れだして、西に東に江戸一円へ散らばっていくのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ドヾドコドン、ドコドン――）と新しく太鼓が鳴り出す。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ドヾドコドン、ドコドン――）と新しく太皷が鳴り出す。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "底のドン底のドンドコドンまで。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁塚産業課長の膝詰談判が、今度は「内地モンロー主義」にぶつかっていた事実を、ドンドコドンまで気付かずにいたのだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドドンガ、ドドンガと太鼓を打って、サイコドンドン、サイコドンドンと囃した。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズイとこきゃ――と一人が唄うと、サイコドンドン、サイコドンドンとやかましく囃したてた。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーン、ドーン、ドンドコドン、ドーン、ドーン……　太鼓の音がするようだ。",
              "citation": {
                "source": "田園の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーン、ドーン、ドンドコドン、ドーン、ドーン……　かすかに、八幡様の方では太鼓が鳴っていた。",
              "citation": {
                "source": "田園の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンドン、ドンドコドンドン」　辻へ箱を下し、人をあつめて、皿まわし、タマの使い分け、虫の鳴きマネ、などをやってみせる。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "兆青流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐龍も雷龍もトラコドンも大砲の音に驚いたと見えて水から姿を出そうともしない。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私の友達と云えば予言者のような老人と尾を持っている原始人と湖底の怪物トラコドンなどで、友達と云えば友達ではあるが、いずれも縁遠い者どもであった。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドドンコドンコドコ。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもヒャラリコドンツク、百姓の合間に、神楽囃子をやッていれば、すぐ五十年の年貢納めが済んでしまう。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
