  {
    "uuid": "a41d0563-68b4-5bb7-88e5-149e69d08f63",
    "entry": "甲巡",
    "reading": {
      "primary": "こうじゅん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "armored cruiser",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此軍艦、排水噸數二千七百ばかり、二本烟筒の極めて壯麗なる裝甲巡洋艦である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　死を以て生を　五千の大砲、三万の機関銃、三千の投擲弾、二千の飛行機、五千の機関車、十五万の客貨車、五千の自動車を、連合軍に引渡し、潜水艦の全部、装甲巡洋艦六隻、海防艦十隻、小巡洋艦八隻、新式駆逐艦五十隻の破壊。",
              "citation": {
                "source": "世界の裏",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと、両者の海軍力は、戦艦九対十四、装甲巡洋艦九対二の比率で、伊太利側が一倍半の優勢を持していたのである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
