    "definitions": [
      {
        "index": 1,
        "gloss": "invented story",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いや、拵え事では決してないのです。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの地蔵は自分の家で新らしく作ったもので、墓地の土中から掘り出したなどというのは拵え事である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいい加減の拵え事をして主人の金を掠めようなどという、そんなさもしい怖ろしい心は微塵も持っていない。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更そんなあさはかな拵え事で、自分を欺くことはできまいと又あざ笑った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃ、拵え事だ。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、気がついて見ると――拵え事だ！",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは浪人達が好い加減の出鱈目で、つまりは無銭宿泊の口実に、何か彼か拵え事を云うのであろうとも思ったが、一体それはどういう訳か、後日の為にそれだけでも聴いて置きたいと考えて。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあれやこれやその時のことをさらに精しく思い出して、「じゃ、何もかも私のことが原因で屋形と捫着を惹き起しているようなことをいって手紙をよこしていながら、それは皆な拵え事で真相は三野村のことが原因だったのですな……どうも、そうでしょう。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人はかねて濠州へ行きたい希望があったので、それをゆうべの事件に結び付けて、こんな拵え事をしたのではないかとも疑われるが、私はそれについてなんにも言わない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "貸家",
                "note": "青空文庫"
              }
            },
            {
              "text": "命惜しさの拵え事、この甚五衛門は瞞されぬぞ……さあ手を合わして尋常に成敗の刃を受けるがよい。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、拵え事を話してもらおうとすれば、奥さんからその理由を詰問されるに極っています。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林なんて人はここへ来た事も何にもないのに、あなたはあたしをごまかそうと思って、わざわざそんな拵え事をおっしゃるのよ」「拵えたって、別におれの利益になる訳でもなかろうじゃないか」「いいえほかの人が来たのを隠すために、小林なんて人を、わざわざ引張り出すにきまってるわ」「ほかの人？",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "作りもの、拵え事、馴れ合いの狂言とは、どうしても受け取れなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草屋の年寄りが、いい含められて拵え事をいってる様子じゃなかったか」「それは大丈夫、十手を見せての上の話で、拵え事する隙もありませんよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、伊勢屋が憎くて言った拵え事に、おやと思った」「…………」「あとは知っての通りさ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "仏喜三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら大黄だって、そんなに急に腹が痛くなるわけはないし、怪しい安倍川を川へ捨てたというのもテニハの合わない話だ、――これはやはり二人で逢引するための拵え事だろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金の鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見付けなきゃ、お前の言う事はみんな拵え事じゃないか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "路地の小判",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがいけないよ、――そんな拵え事を言うから、お寿が疑われるんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "小唄お政",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆んなの思いも寄らない事をしているに違いない」「…………」　噛んで含めるような平次の言葉に、かりそめの拵え事を言ったのを愧じて、お文は丸い顎を襟に埋めました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "小唄お政",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐胎の様子はなかったが、取逆上て少し気が変になったらしく、昼でも行灯を点けておいたり、草履を縁側へブラ下げたり、無暗に逃出そうとしたり、ずいぶん閉口した――と大した拵え事らしくもなく言うのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二階の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に一度の大島通いの御用船が、三崎の沖で拾い上げて、まだ呼吸があるようだから可哀想に捨てもなるまいと、大島へ持って行って、漁師に世話を頼んで江戸へ帰ったそうでございます」　千之助の話は奇っ怪でしたが、決して拵え事とは思われません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "地獄から来た男",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶四郎兵衛が殺されたと聴いて、捨鉢な心持ちが言わせる拵え事だろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "欄干の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "拵え事の縁結びの事、金の力で丹次をさらって行った事、有馬屋｜父娘に対する怨みは、まだまだうんとあるにしても、それはここで言う筋ではなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "縁結び",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いたね、どうも、なんだってあんな拵え事を言ったんで？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩見重太郎のように、乗込んで退治というわけにはいかないが、事と次第によっちゃ、お化けを縛るのも洒落ているだろう」「親分、冗談や、拵え事じゃございません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪伝白い鼠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「拵え事だよ、自分で自分の髪を切ったのさ――井戸端で風呂敷を冠せられて髪を切られたと言ったが、風呂敷を冠せて髪が切れるかどうか、ちょいとやってみるがいい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「するとお前は、髻を切られたの、白装束の男がいたのと言いふらしたのは、あれは拵え事だったと言うのか」「相済みません」　喜三郎はこうくり返すばかりです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "笛吹兵二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはこしらえごとでございます。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事は、ちょうど戸をあける時に、寝台が倒れて、その下にちょうど被害者がたっていて、しかも倒れた寝台の框が被害者の急所へぶっつかるというようなことは、とてもこしらえごととしか考えられんというのです。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、心の中で肯いて、それじゃ、八月の末にここの所帯を畳んでしまって母親もいなくなったと言ったのは、皆なこしらえごとであったかと、合点しながら、さあらぬ風に、「ああそうですか。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
