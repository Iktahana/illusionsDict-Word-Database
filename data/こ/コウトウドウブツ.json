[
  {
    "uuid": "7e128eb6-51cf-576c-954a-6aa3d6914b4d",
    "entry": "高等動物",
    "reading": {
      "primary": "こうとうどうぶつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
