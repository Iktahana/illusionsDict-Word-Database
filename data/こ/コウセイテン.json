    "definitions": [
      {
        "index": 1,
        "gloss": "sphere of fixed stars (in the Ptolemaic system)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "天動説によれば、恒星天は宇宙の最も外側に位置する球殻である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古代の天文学者たちは、恒星天が地球を中心に一日で一回転すると信じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ダンテの『神曲』において、恒星天は天国の第八天として描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『コンヴィヴィオ』に出づ（二、一四・六九以下）六四―六六〔第八の天球〕恒星天。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "不滅の生命（人の魂）は神の直接に造り給ふものなれば滅ぶる生命の父といふ一一八―一二〇〔貴き天〕恒星天一二一―一二三〔己が許に引く〕難所が魂を引くとはダンテをしてその心を悉くこゝに集めしむるをいふ〔難所〕天堂の旗の殘の部分即ち特に崇高にして敍し難きところ一二四―一二六〔救ひ〕或ひは福。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒星天を司る天使一〇〇―一〇二〔絆〕かれらを神と結び合はす愛の絆。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
