        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ずらりと並んだコピー機に学生たちが張り付き、吐き出されてきたコピーを専用の機械が製本のためにばたばたと二つに折っていく光景を思い浮かべると、なんだかその様が、書き手と読み手の願いのすれ違いを象徴しているように思えてきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちいち原紙を切らなければならないガリ版に比べれば、ボタン一押しで複写が取れるコピー機は、実に便利です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、コピー機の技術を応用して開発が進んでいる〈レーザーライタ〉には、従来とはけた違いの精密な仕上がりが期待できるというのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリ版やコピー機、せいぜいプリンターどまりだ。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフィス機器のレンタル会社から、僕は白黒のコピー機を一台、借りてきた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "コピー機やファクシミリ、ワード・プロセサー、プリンターなどの機器。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三枚の白黒のプリントは普通のコピー機で、二倍に拡大してみた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二枚のカラー・プリントはカラー・コピー機で拡大複写した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "村田からもらって来たものをコピー機で複写した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
