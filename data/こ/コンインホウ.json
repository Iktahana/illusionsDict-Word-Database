        "examples": {
          "standard": [
            {
              "text": "その国では、婚姻法が近年改正されたばかりだという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "婚姻法に関する専門書を読んで、制度の歴史的背景を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "弁護士は、新しい婚姻法が個人の権利をより尊重するものだと説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第二巻法律篇は、婚姻法概論からはじまって、妻の無能力（法律上）。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の馬鹿侍が酔狂に路傍の小民を手打にすると同様、情け知らずの人非人として世に擯斥せらる可きが故に、斯る極端の場合は之を除き、全体を概して言えば婚姻法の実際に就き女子に大なる不平はなかる可し。",
              "citation": {
                "source": "新女大学",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり女が盛んに働く故に、成るべく永く生家では留めて置きたい人情が、自然に武家風の輿入婚姻法を、採用することを遲くせしめたのであらう。",
              "citation": {
                "source": "瀬戸内海の島々",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
