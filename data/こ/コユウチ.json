        "examples": {
          "standard": [
            {
              "text": "固有値問題は、物理学や工学の様々な分野で現れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "行列の固有値は、その変換の特性を示す重要な指標だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "固有値を計算することで、システムの振動モードを分析できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしてそれはある方程式の固有値と称するものと連関していると考える。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしたとえば液体の渦の生成や分布や相互作用については、やはり前述の割れ目などと共通な「固有値」の問題の伏在することが想像され、あるいはまたマトリッキスの概念の導入可能性も考えられる。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
