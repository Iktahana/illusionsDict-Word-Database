          "standard": [
            {
              "text": "広大な風景を一枚の大きな写真に収めるために、今日は広角レンズを持ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "狭い室内での撮影では、被写体全体を写せる広角レンズが非常に重宝する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "広角レンズ特有のパースペクティブを活かして、建物の高さを強調した写真を撮った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "広角レンズによって二十フィートから三十フィートの横幅でフィルムにカラーでとらえられた海が、左右へ不規則なテンポで交互に傾き始めた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に向けて位置を固定し、広角レンズを取り付けた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
