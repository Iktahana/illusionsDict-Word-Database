[
  {
    "uuid": "21ec3eb8-5d6f-5d81-9019-cdd317498124",
    "entry": "香華",
    "reading": {
      "primary": "こうげ",
      "alternatives": [
        "こうばな"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flowers and incense (given as a Buddhist offering)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ故郷にあればいのち青ざめ手にも秋くさの香華おとろへ青らみ肢體に螢を點じひねもす墓石にいたみ感ず。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通は、本堂に、香華の花と、香の匂と明滅する処に、章魚胡坐で構えていて、おどかして言えば、海坊主の坐禅のごとし。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地は香華の色の海、また、象なき声の網。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "香炎、香華、香雲、香海。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、血に染まった権兵衛の錦の小袴を小さく裂いて、家の守神にすると云って皆で別けあうとともに、その遺骸を津寺に葬って香華を絶さなかった。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前に香華を手向けて礼拝を遂げた老僧と新発意二人。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――能登路の可心は、僻みで心得違いをしたにしろ、憎いと思った女の、過って生命を失ったのにさえ、半生を香華の料に捧げました。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの願掛けをする者は、まずその古い面をいただいて帰って、願望成就か腫物平癒のあかつきには、そのお礼として門番所から新らしい面を買って奉納し、あわせて香華を供えるのを例としている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間るんは給料の中から松泉寺へ金を納めて、美濃部家の墓に香華を絶やさなかつた。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大日如来が香華燈塗の四菩薩を出して四仏を供養するは上に述べた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて妻女の始末ぐらいは、当然もう始めているべきが定なのに、香華一つたむけようともせずほったらかしておいたまま、女中のお葉を、ぽちゃぽちゃッとしたべっぴんなんで少し気になるがと仙市座頭がいったお葉なるその女中をそばへ引きつけて、妻女の品とおぼしき形見の着物をたんすの中から取り出しながら、「どうだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "水から水へつづく秋のその向島に、葦間を出たりはいったり、仏にたむけた香華のけむりを艫のあたりにそこはかとなくなびかせながら、わびしいその土左舟が右へ左へ行き来するさまは、江戸の秋のみに見る悲しい風景の一つでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御靈前に香華を手向くるもの明日よりは有りや無しや。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "香華を具えた聖母マリアの像がその辻堂の中に祠ってある。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは自己の敬愛している抽斎と、その尊卑二属とに、香華を手向けて置いて感応寺を出た。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　爺が苔を掃つて香華を供へるを待つて、わたくしは墓を拝した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しく此寺に居る老僕の言ふ所によれば、従来豊洲の墓に香華を供したものはわたくし一人ださうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "壽阿彌の墓は香華未だ絶えざるに厄に罹つて、後僅に不完全なる代償を得たのである。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしのために香華を墓に供へた媼は、「蝋燭を點してまゐりませうか」と云つた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間るんは給料の中から松泉寺へ金を納めて、美濃部家の墓に香華を絶やさなかった。",
              "citation": {
                "source": "じいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏像を売る家、香華を商う店、様々の商店が並んでいたが、けばけばしい色彩は見られない。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お貞さん香華もあげやせん。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "香華を手向けないゆえ不貞だというようにもきこえたが、あれほど立派に川上の意志をついでいれば、それをこそ川上は悦んでよいのである。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏壇には、これら聖者の禅に対する貢献を記念して香華がささげてある。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこに手ぬかりがありましょう……九大、屍体冷蔵室の屍体紛失事件が、若林博士以外にはタッタ一人しか居ない係りの医員に、不審の頭を傾けさしたまま、永久の闇から闇に葬られて行く時分には、行衛不明になった少女の虐殺屍体は既に、一片の白骨となって、立派な墓の下に葬られて、香華を手向けられている訳であります。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "閼伽、香華の供養をば、その妻女一人に司らしめつゝ、ひたすらに現世の安穏、後生の善所を祈願し侍り。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからその死骸を丸｜裸体にして肢体を整え、香華を撒じ神符を焼き、屍鬼を祓い去った呉青秀は、やがて紙を展べ、丹青を按配しつつ、畢生の心血を注いで極彩色の写生を始めた」「……ワア……凄い事になったんですね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お熊は泣く泣く箕輪の無縁寺に葬むり、小万はお梅をやっては、七日七日の香華を手向けさせた。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ程でなくても、墓石一基に香華一本位の手向のあるのは普通であろう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りどこもかしこも荒っぽく殺気だっている明暮だから、せめて台所ののれんぐらいはと、仮に「こうげい」でそんなものでも買う人々の暮しは、現実にはその台所の戸棚に相当な食糧の補充も蓄えられている人々のことである。",
              "citation": {
                "source": "生活のなかにある美について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
