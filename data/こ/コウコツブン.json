        "examples": {
          "standard": [
            {
              "text": "甲骨文は、亀の甲羅や動物の骨に刻まれた、漢字の最も古い形態の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "殷の時代の王たちは、占いの結果を甲骨文として記録に残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "書道家である彼は、甲骨文の素朴で力強い造形に魅了されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "殷墟の甲骨文字の研究も、シェバの女王の生い立ちを伝える楔形文字の土板も、『暁の女王と幻の王の物語』も、ただその題目を見るだけで、もう充分たのしいのである。",
              "citation": {
                "source": "千年の時差",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例を挙げると、いわゆる殷墟出土の甲骨文字の取扱いかたの如きにもそれがあるのではなかろうか。",
              "citation": {
                "source": "日本に於ける支那学の使命",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一々それを述べないが、そういう研究を経ず、それらの問題に一々明かな解釈を施さずして、甲骨文字を遠い上代のものとするのは、学術的の取扱いかたとして周到な用意があったとはいいかねる。",
              "citation": {
                "source": "日本に於ける支那学の使命",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
