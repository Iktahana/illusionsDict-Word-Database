        "examples": {
          "standard": [
            {
              "text": "初期不良だったため、メーカーに連絡して交換品を送ってもらいました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "返品された商品のうち、まだ使えるものは修理して交換品として再利用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「注文した商品の色が違ってたから、交換品が届くまでしばらく待っててね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ヨーロッパに輸出するタバコの交換品としてアフリカの黒人を受けとり、その彼らは、奴隷として、こんどはタバコを栽培するための労働力となった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
