[
  {
    "uuid": "98f898a1-8319-5ea1-9b6a-804b1fb2edf1",
    "entry": "細細とした",
    "reading": {
      "primary": "こまごまとした",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
