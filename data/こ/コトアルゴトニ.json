[
  {
    "uuid": "0aa4aa1a-c4e7-5413-ab3c-30567e04b824",
    "entry": "事あるごとに",
    "reading": {
      "primary": "ことあるごとに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
