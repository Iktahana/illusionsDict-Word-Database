  {
    "uuid": "827206ce-f256-5d58-bfe4-7fb42bbeeeb5",
    "entry": "個食",
    "reading": {
      "primary": "こしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "meal with family members eating separate foods",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが百五十五個食えるようになる。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの晩たしか幾個食べたから、まだ幾個残ってるはずだ……。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の子供が母から九年母を親戚に贈る使いを言いつけられて、途中風呂敷包を開けてみると九個ある、一個食べておいて、「八年母を差し上げます」と差し出したという話。",
              "citation": {
                "source": "九年母",
                "author": "青木正児",
                "note": "青空文庫"
              }
            },
            {
              "text": "六年の間に餅菓子を一万個食った男と、ざれうたがあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "座へ出る前に、名物食堂の金ずしで、すし数個食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の栄ずしでひらめ五六個食って座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回すんで、食ひ物で悩む、結局、中華丼に野菜スープ、久ずしのすし三四個食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしずし一個食ひ、演舞場の「冬の夜の出来事」を見に行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "定食食って、金ずしでひらめ数個食ひ、座へ帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽い昼食が恒例で、温室栽培の桃を二個食べ終わり、テーブルでのんびり煙草をふかし、小さなカップでブラックコーヒーを飲んでいた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
