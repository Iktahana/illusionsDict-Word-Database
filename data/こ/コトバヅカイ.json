[
  {
    "uuid": "ea640800-213b-54c0-8f22-d8f4d6572c23",
    "entry": "言葉遣い",
    "reading": {
      "primary": "ことばづかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
