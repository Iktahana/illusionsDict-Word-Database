        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "風やや起こりて庭の木末を鳴らし、雨はぽっつりと白糸の面を打てり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なむぢ嵐に揺いでは翠光を机上の黄巻に飛ばせば、我また風に托して香烟を木末の幽花にたなびかす。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "板塀の上に二三尺伸びている夾竹桃の木末には、蜘のいがかかっていて、それに夜露が真珠のように光っている。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の庭の木立ちだけは春らしく見えて、咲いた紅梅なども賞翫する人のないのをながめて、ふるさとの春の木末にたづねきて世の常ならぬ花を見るかな　と源氏は独言したが、鼻の赤い夫人は何のこととも気づかなかったであろう。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "そよ吹く風は忍ぶように木末を伝ッた。",
              "citation": {
                "source": "あいびき",
                "author": "イワン・ツルゲーネフ　Ivan Turgenev",
                "note": "青空文庫"
              }
            },
            {
              "text": "其枝の延し所を涼木といひ（船木より四里）木末の倒し所を木の末といふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度昔スウイフトの見た、木末から枯れて来る立ち木のやうに。",
              "citation": {
                "source": "或阿呆の一生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "うるはしく紅に白きをうちまぜて残る紅葉に初雪ぞ降る天霧ひ時雨の降れば狭丹づらふ紅葉は散りぬ山はさびしも日ならべて大雪ふれり奥山の松の木末も土につくまで膝を枕にわが命終らんと思ひし子の照幢を、明治十九年の春、周防徳山なる徳応寺の養子に遣すとて。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "×高い木末に葉が落ちてあらはに見える、小鳥の巣。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥の巣落葉して人目に附きぬ、わが庭の高き木末に小鳥の巣一つ懸かれり。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初春ひがむ気短かな鵯鳥は木末の雪を揺りこぼし、枝から枝へ、甲高に凍てつく冬の笛を吹く。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白茶けた苔に掩われた木々と木末に咲いた藤の花と木々の間に仄めいた池と、――画面にはそのほかに何もなかった。",
              "citation": {
                "source": "春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」　棕櫚の木はつい硝子窓の外に木末の葉を吹かせていた。",
              "citation": {
                "source": "彼",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の際の遠き木末の咲き行く　見れば（万葉巻十）の如き歌もあるが、此は花を讃めた歌ではない。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしびきの山の木末のほよとりて、かざしつらくは、千年｜祝ぐとぞ（万葉巻十八）家持の歌である。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "○み芳野の象山の際の木末には幾許も騒ぐ鳥のこゑかも　〔巻六・九二四〕　山部赤人　聖武天皇神亀二年夏五月、芳野離宮に行幸の時、山部赤人の作ったものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○暁と夜烏鳴けどこの山上の木末の上はいまだ静けし　〔巻七・一二六三〕　作者不詳　第三句、「山上」は代匠記に「みね」とも訓んだ。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木末の上」は、繁っている樹木のあたりの意、万葉の題には、「時に臨める」とあるから、或る機に臨んで作ったものであろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○うち靡く春来るらし山の際の遠き木末の咲きゆく見れば　〔巻八・一四二二〕　尾張連　尾張連の歌としてあるが、伝不明である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木末の咲きゆく」などという簡潔ないいあらわしは、後代には跡を断った。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○夏山の木末の繁にほととぎす鳴き響むなる声の遙けさ　〔巻八・一四九四〕　大伴家持　大伴家持の霍公鳥の歌であるが、「夏山の木末の繁」は作者の観たところであろうが、前出の、「山の際の遠きこぬれ」の方が旨いようにもおもう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、「夏山の木末の繁に」といって生かしているのを後代の吾等は注意していい。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が男の帰るのを惜しんでなるべく引きとめようとする歌は可なり万葉に多く、既に評釈した、「あかときと夜烏鳴けどこのをかの木末のうへはいまだ静けし」（巻七・一二六三）などもそうだが、万葉のこういう歌でも実質的、具体的だからいいので、後世の「きぬぎぬのわかれ」的に抽象化してはおもしろくないのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏がよく其枯れた木末にとまる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島崎氏の歌は森の中にこもる鳥の歌、その玲瓏の囀は瑞樹の木末まで流れわたつて、若葉の一つ一つを緑の聲に活かさずば止まなかつた。",
              "citation": {
                "source": "新しき聲",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏をうたはんとては殊更に晩夏の朝かげとゆふべの木末をえらぶかの蜩の哀音を、いかなればかくもきみが歌はひびかする。",
              "citation": {
                "source": "詩集夏花",
                "author": "伊東静雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "真午時にまどろみ給へば、木末の一葉だに動くことなし。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして両側の、茂り交した柳の木末に早くも、「夕暮」は下りた。",
              "citation": {
                "source": "夜店ばなし",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャンと末吉と、荒木末吉と、ここに書いてありやす。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮の曲　　　　シャルル・ボドレエル時こそ今は水枝さす、こぬれに花の顫ふころ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
