  {
    "uuid": "0c8eceb7-96b2-5e78-a66f-0fbdf1e47e41",
    "entry": "転び",
    "reading": {
      "primary": "ころび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
