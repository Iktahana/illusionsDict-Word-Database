[
  {
    "uuid": "a77664ce-f26e-5df6-a80e-aac9b82ad345",
    "entry": "侯爵",
    "reading": {
      "primary": "こうしゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
