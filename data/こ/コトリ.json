    "definitions": [
      {
        "index": 1,
        "gloss": "with a (light) tap",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
