    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ancient times",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "古昔は水の清かりしをもて人の便とするところとなりて、住むもの自ら多かりけむ、この川筋には古き器物を出すこと多し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古昔の預言者は近世に望むべからず、近世の預言者は文字の人なりと言へる、己れ自ら一預言者なるカアライルの言を信ずることを得ば、我は徳川氏時代に於ける預言者を其思想界の文士に求めざるを得ず。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この血痕、この紅涙こそは、古昔より人間の特性を染むるものならずんばあらず。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "古昔のユダヤ人のいわゆる完全ならずとするも、今日のわが国の如きよりは遥かに高き道徳的標準に照らしての完全であるに注意すべきである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは古昔より女のあることを許さねば、酌するものなどすべて男の児なるもなかなかにきびきびしくて好し。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古昔｜希臘人は以為らく、人智の得て思議すべからざる者是れ則ち運命なりと。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども是れ古昔陳腐の解にして近世詩学家の採らざる所なり。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "古昔の尊き使徒が異教人の国を望んだ時の心地だ。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「で、古昔から智仁勇と文字通りに順序を付けて、智を第一位に置いたやうぢやが……」と侯爵は前に突出した腕をだらりと狐の尻尾のやうに卓子の上に投げ出した。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "海は初め全地球を覆っていたから今日至る所で古昔の貝殻が発見される。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "（古昔穴国穴済穴海和武尊悪神を殺戮するの地なり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "土人の説に古昔宇佐八幡の神飛び来て此石上にとゞまるなりといへり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此寺古昔大内義隆の所造なり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古昔寧楽朝山上憶良詠秋野花草七種。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "府中はいまさら説くまでもなく、古昔の国府の所在地で、六所明神は府中の惣社。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "高松宮家より頂いた麻布の公園や、井の頭の恩賜公園や上野や芝など、どうかあんまりもとの自然を損じないでその土地の、古昔のままの樹木や、土の起伏を保存したいものだ。",
              "citation": {
                "source": "東京に生れて",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　古昔、この洞窟内に、一人の老僧が行い澄していた。",
              "citation": {
                "source": "「沈黙」の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "古昔、舜帝が齢尽きて此世を去り、遺骸は珠丘の上に葬られた時、後に残った二人の妃は、その丘上に相擁して三昼夜ほど泣き続け、涙が尽きると次いで血が流れた。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の場合は之と違つて、支那の國粹は支那人が古昔から持つて居たもので現朝は異人種で支那人を征服しながら却て支那の文明に征服されて其恩惠に浴した譯である。",
              "citation": {
                "source": "支那近世の國粹主義",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局李軌の考では、此二章は意味聯屬したもので、古昔が南正重に天を司らせ、北正黎に地を司らしたが、後堯の時に至り羲和の官が出來て、天地を分掌することゝなつた。",
              "citation": {
                "source": "楊雄と法言",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しそれでも直に皇帝の位には即かず、古昔周公が成王に代つて政を攝した故事に則とり、當時義士が莽に對して兵を擧げたのを討伐するにも、周公が管蔡を討つた態度を氣取り、周書大誥に傚つて、大誥を作つた。",
              "citation": {
                "source": "楊雄と法言",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノ間古昔｜信夫文字摺ヲ出セシ所。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "（山重なって森深く、岩たたなわって谷をなし、天龍の川の流るる所、古昔より神仙｜住居して、深紅のぼたんの花を養う。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶元以還、民間｜俗楽種々起り、楽器もまた増加し、古昔に比すればいっそう進みたりというべし。",
              "citation": {
                "source": "国楽を振興すべきの説",
                "author": "神田孝平",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元前五六世紀ごろ、ウパニシャド製作の時代に極度の形而上学的思弁に化しおわったバラモン教は、生の実感に充ちた仏教によって一時押されたが、しかしギリシアの神々に似た人間的な神を崇拝する古昔の伝統は、なお一般に勢力を持ちつづけ、ヴィシュヌ、シヴァ等の崇拝となって紀元後に及んだ。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにシヴァ神が勢力を持っている北インドで新しく造られた宗教であるがゆえに、大乗仏教は著しく古昔のバラモン神話を取り入れたのであるとも言える。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠に月氏についで北インドを統治したグプタ朝のバラモン的インド教は、古昔のバラモン教と全然面目を異にして、むしろディオニュソス礼拝やアフロディテ礼拝に近い。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは中門前の池の傍を通って、二月堂への細い樹間の道を伝いながら、古昔の精神的事業を思った。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界は確かに古昔の元子論者が見たごとくある基本要素の離合散集によって生じたのである。",
              "citation": {
                "source": "『偶像再興』序言",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし古昔｜羅馬にありては政権を有する士君子即ちいはゆる良家子に当つるにこの称を以てして、以為らくわが天然に得る所の情性に従ふてその真を保つことを得る者｜独り以てこの称に当るべしと。",
              "citation": {
                "source": "『東洋自由新聞』第一号社説",
                "author": "中江兆民",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
