    },
    "definitions": [
      {
        "index": 1,
        "gloss": "historic spot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
