  {
    "uuid": "f0659659-a41d-5676-9768-62eb963454ce",
    "entry": "古跡",
    "reading": {
      "primary": "こせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
