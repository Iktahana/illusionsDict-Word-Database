        "examples": {
          "standard": [
            {
              "text": "小判鮫はサメだけでなく、カメやクジラにも吸い付いて移動の足に利用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "漁網に掛かった大きなエイを引き上げると、そこには数匹の小判鮫がくっついていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、あそこに小判鮫がいるよ！」とガイドが指差す先に、悠々と泳ぐサメが見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
