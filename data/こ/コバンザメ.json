        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海蛇の名に誓い椰子蟹と小判鮫の名にかけて、夫と其の情婦とを呪った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ水先の小判鮫、真黒の鰭のひたうへに、沈々として眠るのみ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ水先の小判鮫、眞黒の鰭のひたうへに、沈々として眠るのみ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばには二匹の灰色のコバンザメがまとわりついている。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバンザメはどちらも三フィートくらいの大きさで、速く泳ぐ時にはウナギのように全身をしならせていた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
