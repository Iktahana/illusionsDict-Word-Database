        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水族館の巨大な水槽で、大型のサメの腹にピタリと吸い付く小判鮫の姿が観察できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小判鮫は頭部にある吸盤を使って他の魚に付着し、餌のおこぼれを頂戴する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ダイビング中にジンベエザメに遭遇したが、その周りには何匹もの小判鮫が群れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "海蛇の名に誓い椰子蟹と小判鮫の名にかけて、夫と其の情婦とを呪った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ水先の小判鮫、真黒の鰭のひたうへに、沈々として眠るのみ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ水先の小判鮫、眞黒の鰭のひたうへに、沈々として眠るのみ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばには二匹の灰色のコバンザメがまとわりついている。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバンザメはどちらも三フィートくらいの大きさで、速く泳ぐ時にはウナギのように全身をしならせていた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
