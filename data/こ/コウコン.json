    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dorsal root",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "恐らくは大震災後根が絶えたのであらう。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからその後根岸のあたりをぶら／″＼歩行いていよ／＼といふことを突き止めたといつては變だが、そこらの模樣を見て三月二十七日それは明治三十三年の三月二十七日に染筆を乞ふ積りで、短册を用意して半ば畏を懷いて先生を訪問に行つた。",
              "citation": {
                "source": "竹の里人〔二〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "憙は老後根岸の隠宅から小島の家に引き取られて終つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂昌功は初め淺草黒船町河岸に住し、後根岸に遷つた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "道徳教育のかゝる観念的傾向をこそ、今後根こそぎ改めなければならぬのであつて、平和的、民主的といふやうな題目それ自身の「権威に頼る」教育の、更に恐るべき結果を生むであらうことは、もうすでに予想できるものにはできるのである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "果たして、その後根気よく、何枚も何枚も撮っているうちに、焼き付けが出来る程度の写真が撮れるようになった。",
              "citation": {
                "source": "写真と暮した三十年",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後根岸へ行った時に、「割合元気にあったそうだな。",
              "citation": {
                "source": "富士登山",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ママが病気だって言うと、パパはこうこんなにして両手で頭を抱えて……それから、そこらじゅう歩き廻るんです。",
              "citation": {
                "source": "小波瀾",
                "author": "ЖИТЕЙСКАЯ　МЕЛОЧЬ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
