[
  {
    "uuid": "1e4e8b3e-f724-5ef0-bb5c-5425276afe92",
    "entry": "事欠く",
    "reading": {
      "primary": "ことかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
