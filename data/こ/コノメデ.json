    "definitions": [
      {
        "index": 1,
        "gloss": "with my own (two) eyes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この目で何ほどのものをにらみ殺したか、恐ろしいことぢゃ。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この目で手近な平凡なものをのぞいて見ると自分のいる周囲の世界が急に全然別物のように見えて来る。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは、この目で見たもおんなじなの。",
              "citation": {
                "source": "ほんとにそのとおり！",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "二代以前の当城殿様、お鷹狩の馬上から――一人｜町里には思いも寄らぬ、都方と見えて、世にも艶麗な女の、一行を颯と避けて、その宮へかくれたのを――とろんこの目で御覧じたわ。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水が、音もなく這い、伸びている様を、いま、この目で、見てしまったから、もう、山師は、いやだ。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風俗はこの目で確に睨んだが……おやおや、お役人の奥様かい。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、お前さんが何と言ったってね、私は、ちゃあんとこの目で、シンドバッドが海に沈んだところを見たのだぜ。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はたしかにこの目で、二人が小径を下りて行って、あとそのどちらも帰って来ないことを、見届けたのだがね」「それはこう云うわけさ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "御者は客がどうなったか思いもつきませんし、なかに入るのは確かにこの目で見たと。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "現場をこの目で見たよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "長年、やつを追っているんだが、まだこの目で見た事がない。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてオレが東京駅から地下鉄の大手町駅まで走り、九段下で降りてまたホテル・グランドパレスまで駆けたのも、ＦＭ　ＴＯＷＮＳという名の原石がどう化けたのか、この目で確かめたかったからである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしは初めからこの目で見てたんだから、よく知ってますがね、あの若衆の御主人様が、お微行でどこかへお遊びに来ていらっしゃると見えましてね、そこへの御用の帰りにあそこの角迄やって来たら、あの四人連れがひょっこり面出しやがって、やにわと因縁つけやがるんですよ。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この目で男は出てきたところをたしかに見たが、逃げこんだお高祖頭巾の女は、半匹だって出てきたところを見ねえんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに、あのお高祖頭巾の女ですぜ」「なにッ、見まちがいじゃねえか」「この目でたしかに見たんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、もう一度念を押してきくが、朝来たとき、たしかに錠はおりたままになっていたというのじゃな」「へえい、ちゃんとこの目で調べ、この手で調べたうえに、てまえがこのかぎであけたのでござりますゆえ、おりていたに相違ござりませぬ」「そうか、よしよし。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つぼ半」の女将が、又しても裁判所へやって来たんです……いや、今度は私が、この目でみつけたんですよ……　と云うのは、そうそう刑事部の廊下でしたよ。",
              "citation": {
                "source": "あやつり裁判",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときドレゴは突然頭を獅子舞のようにふりたて、「いや、何といっても僕はこの目で見て勘定して来たんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時私はスコールによつて海がいかに激しく荒れるかといふことをはつきりこの目で見た。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそこへ首を突つ込んだ人達の成行きといふものは彼等はこの目で見て來てるんだから。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分では、はっきりとこの目で日本の戦争の実相を見てきた、と思っていたのである。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "復員して戻ったばかりの僕は惨劇の日をこの目で見たのではなかった。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "復員して戻つたばかりの僕は惨劇の日をこの目で見たのではなかつた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォズニアックもまた、この目で自分が見たものがどうにも信じられなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "が氣がついてみると、そのどちらも私が、この目でぢかに見た姿ではない。",
              "citation": {
                "source": "爐邊",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等は実際勝利をこの目で見るまでは安心出来ないのだ。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、この目で眺めたら、とても怺えてはおられまいと、師匠も、大方、今日まで、わたくしの江戸下りを、止めていてくれたのでございましょうが、今度、一緒に伴れて来てくれましたはあの仁も大方、もうわたくしに、望みを晴らせよ――と、許してくれたのだろうと思います。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のきいた若い者が、このめでたい春先に、今ごろから寝るって法がありますかッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように実生から出足して明かにその年数のわかっている竹林は恐らく日本国中この中山の斎藤君宅地よりほかにはない珍らしいものであるから、私の切に希望するところはその持主の斎藤君がこれまで通り今後も永くこれを愛護せられて、このめでたい竹林とともに同家の益々繁栄せんことを切に祈るのである。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このめでたい吉日に」「きょうが吉日とお考えになられるのからして、もう死神につかれているのです。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
