        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "市役所に出す婚姻届が絶大の権威を持つ法律では、こんな研究が八釜しい研究材料となるかも知れませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業式のあと、その足で婚姻届けを出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな届出がある中で良人がわずか張りを覚えるのは婚姻届を扱うときだった。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちこちで召集が下るようになってから、村役場で婚姻届の受付が殖えた。",
              "citation": {
                "source": "鏡の中の月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤浪君は満足だったが、婚姻届を出す時に、貞江さんの年が自分より三つ多いことを発見した。",
              "citation": {
                "source": "善根鈍根",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　世田谷区役所へふたりで婚姻届を提出しにいった帰り道、舞子はかたわらを歩く彼に次のように言った。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
