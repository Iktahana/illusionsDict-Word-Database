    "definitions": [
      {
        "index": 1,
        "gloss": "(verbal) message",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やんちゃんもここに至っては棄置かれず、言付け口をするも大人げないと、始終｜蔭言ばかり言っていた女房達、耐りかねて、ちと滝太郎を窘なめるようにと、夜に入ってから帰る母親に告げた事がある。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イチローさん、この方たちになんでも好きな飲みものでも取ってあげなさい」　むす子がかの女の言付けを取次ぐと、めいめいおとなしく軽いアルコール性の飲みものを望んだ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は山賊に捕われた事を、小児心にも知っていたけれども、堅く言付けられて帰ったから、その頃三ヶ国｜横行の大賊が、つい私どもの隣の家へ入った時も、何も言わないで黙っていました。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は中單の鈕を半分掛けた儘で、手早く式部職へ當てた所勞の屆を書いて、用箪笥の抽出から、御門鑑を出して、女中を呼んで、車夫に持たせて遣るやうに言付けた。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は「玉の處へ手焙を持て來て置け」と言付けた。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、丸山は勇造に言付けて、ひとりの原住民を呼ばせた。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の朝、会うって言付けし、た、じゃ、ない！",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言付け加えると、その者はひどくなまくらな小振りの刃物を持っています。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "雛妓に言付けて、座敷を斜に切って、上口から箪笥の前へ引返すと、一番目の抽斗が半ば開いていた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あの皆神月さんに言付けてやるから覚えているが可い。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらば車にてレオニに行かばやとて言付けぬ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内せる附添の婆は戸口の外に立ちて請じ入れんとすれば、客はその老に似気なく、今更内の様子を心惑せらるる体にて、彼にさへ可慎う小声に言付けつつ名刺を渡せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人もそれを聴いて、すぐにその蟹を下げるように言付けましたので、祖母も心得てその皿をのせたお膳を片付けはじめると、与茂四郎はまた注意しました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に一言付け加えておきたいことは、私は日本の現今の探偵小説雑誌を読んでいないから分からぬが、かかる雑誌において、探偵に関した事項についての考え問題を掲げて、読者に考えてもらうようにしたいことである。",
              "citation": {
                "source": "科学的研究と探偵小説",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かまた御用がありましたら、言付けてやって下さい」　こう言って、看護婦なぞの往ったり来たりする庭の向うの方から一人の男を連れて来た。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "小母さんは神様に言付けるような調子で、制え難い女の胸の中を熱心に訴え、田辺のお婆さんや姉さんまで改宗させずには置かないという語気で祈った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに張詰めた気は、まだ緩まないといふ風で旦那さんに代つて訪ねなければ成らない家があり、言付けられた用があり、書くべき手紙の数からして増えた。",
              "citation": {
                "source": "出発",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ、その膳をここへ持って来てくれ」と私は家内に言付けた。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泉ちゃんが打った――」と繁は父に言付けるようにして泣いた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "肚の蟲を殺して翌日は午前に出向くと、Ｚ・Ｋ氏は大層喜んで、君昨夜は失敬、僕醉拂つてゐたもので、それにしても好く來てくれましたと丁寧に詫びて、夫人に向つて、これ／＼、酒屋の爺さんにＫさん來てくれたことを傳へて來い、爺さんひどく氣遣つてゐたから、と言付けた。",
              "citation": {
                "source": "足相撲",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、顔を洗ふと直ぐ床の間に据ゑてある私専用の瀬戸焼の天神様に、どうぞ学問が出来ますやうと祈願をこめるのが父の言付けであつたが、私は、どうぞ今日一日ぢゆう色の黒いことを誰も言ひ出しませんやう、白くなりますやう、と拍手を打つて拝んだ。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇足とは知りながら一言付け加えれば、灰になっても忘れることのなさそうなジャニスの「サマータイム」は、ビッグ・ブラザー＆ザ・ホールディング・カンパニー時代の佳作である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹愼從爾姑之言」と言付けられたのであつて、舅姑には絶對に服從しなければならぬのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "箸と命じられれば茶碗を、下駄と言付けられれば、草履を揃えておくという風である。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりもさきに、此処へ、守備隊長をよんで、このことを話して兵隊を二三人つれて来させ、それから厩頭のウラップに、アルライを此処へつれて来るやうに言付けて下さい」　ニナール姫の手配はまるで、りつぱな警察署長のやうに、よく行きとゞいたものでした。",
              "citation": {
                "source": "ラマ塔の秘密",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄がおやぢに言付けた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄がおやじに言付けた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田屋清左衞門の番頭も、其の頃大名の御家老などが来ると家の誉れ名聞だというので、庭の掃除などを厳しく言付けぐる／＼見廻って居ります。",
              "citation": {
                "source": "菊模様皿山奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　不器用長二の話を、其の頃浅草蔵前に住居いたしました坂倉屋助七と申す大家の主人が聞きまして、面白い職人もあるものだ、予て御先祖のお位牌を入れる仏壇にしようと思って購めて置いた、三宅島の桑板があるから、長二に指させようと、店の三吉という丁稚に言付けて、長二を呼びにやりました。",
              "citation": {
                "source": "名人長二",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんか、ことづけはないかい？",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
