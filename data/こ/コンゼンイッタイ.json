        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "心と物は「人」に於て渾然一体である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "国策と国防はかくて全く渾然一体となるのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛のように人間の総和的な力の発動を刺戟する場合、今日の私たちは自分たちの全人間が、その精神と肉体とが互に互のけじめもつけかねる渾然一体で活躍し、互が互の語りてとなって、愛する者に結合することを知っているのである。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の紺碧さは大きくなって、電気的に融合してスパークした閃光の中で、虚ろな空の青色と溶け合って、空と渾然一体ならんとしている。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギターとベースを弾き、ドラムを叩くことはけっして伴奏ではなく、歌うことと渾然一体となった演奏だったのです。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、肉体と精神、姿態と性情との、渾然一体となつた「人間美」の典型が浮びあがるでせう。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ程真に迫った生命力がカンバスの上に渾然一体となっているのを見たことがなかった。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
