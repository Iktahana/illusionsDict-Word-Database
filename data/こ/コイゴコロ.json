    "definitions": [
      {
        "index": 1,
        "gloss": "(feelings of) love",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
