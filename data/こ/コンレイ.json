[
  {
    "uuid": "36f149c0-5e5b-5883-9fc9-674d5fa8d4ed",
    "entry": "婚礼",
    "reading": {
      "primary": "こんれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
