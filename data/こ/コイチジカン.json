        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はそんなものを見るのに小一時間も費すことがあつた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそんなものを見るのに小一時間も費すことがあった。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小一時間經つて、家内が髮結さんから歸つて來た。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "井深君はその小一時間の間、ブライヤアのパイプと一緒に甃石の上を歩き続けながらも、喫茶店でポスタムを啜り乍らも、如何にもそのへんな娘の姿が気になってならなかった。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふ間に小一時間の時間が經つ。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗換えや色々で小一時間の行程と、絶えず左右から挟まれて感ずる異性の漠然とした刺戟のために、彼女は可なり疲れて居た。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもの時からあまり上手でもなかったが、年を取ってからいよいよ下手になったとみえて、小一時間も糸をおろしていたが一向に釣れない。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが英国大使館前の桜の下を涼みながらに散歩していると、伊佐子さんがあとからついてきて、一緒に話しながら小一時間ほど歩きました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは我れ知らずに小一時間も眠ったらしい。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私が此処に佇んでいた小一時間の間、この獣は私に一瞥さえ与えなかったのだ。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小一時間もかゝつて漸く彼は戻つて来た。",
              "citation": {
                "source": "晩春日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小一時間ばかりで吾手は木の様な物に触つた。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、いつもより小一時間遅いんですよ、」　という時、二枚｜立のその障子の引手の破目から仇々しい目が二ツ、頬のあたりがほの見えた。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな筈ではなかつたが、すぐわかるところにある筈だと思つたが、新しい家が沢山出来たゝめか、それとも昔の記憶がおぼろげになつたためだか尠くとも栄輔君の家をさがし当てるまでに小一時間もかゝつた。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　彼これ小一時間も□□のホクロに花を咲かして三人は別れ／＼に帰つた。",
              "citation": {
                "source": "人相見",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　この時は小一時間も話した。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからかれこれ小一時間も悠然と腰を落付けて久しぶりで四方山の話をした。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれこれ小一時間も自分たちと一緒に避難していたろう。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パパ、グッドパパ』『スウイト・チキン』と申し合って、子供等と別れて、いつのように書斎の廊下を散歩していましたが、小一時間程して私の側に淋しそうな顔して参りまして、小さい声で『ママさん、先日の病気また帰りました』と申しました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島から大仁までたった小一時間、それが私に取っては堪えられないほどに長い暗い佗しい旅であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に深田君の座敷を受持ちの女中もいたので、一体どうしたのかと訊いてみると、今から小一時間も前に、この座敷でけたたましい叫び声がきこえた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから小一時間も過ぎてまた小用を足しに來た。",
              "citation": {
                "source": "佛法僧",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまだ小一時間もトラックはごとごとと走った揚句、ごろごろと下り坂を下りてゆくような気がしたと思ったら、やがて車はごとんと停った。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事がすんで時計を見ると、列車にのるまでまだ小一時間もたっぷり余裕があったので、彼は窓ぎわに涼をとるような恰好をしながら、その実、例の鏡の裏から読みとった新しい暗号の発展を脳裡に描いていた。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、裏畑の中の材木小屋に入つて、積み重ねた角材に凭れ乍ら、雨に濕つた新しい木の香を嗅いで、小一時間許りも密々語つてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、お定も急がしく萠黄の大風呂敷を擴げて、手※りの物を集め出したが、衣服といつても唯六七枚、帶も二筋、娘心には色々と不滿があつて、この袷は少し老けてゐるとか、此袖口が餘り開き過ぎてゐるとか、密々話に小一時間もかゝつて、漸々準備が出來た。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、裏畑の中の材木小屋に入つて、積み重ねた角材に凭れ乍ら、雨に湿つた新しい木の香を嗅いで、小一時間許りも密々語つてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あめが　ぽつぽつ　せなかに　おちるなか、　こいちじかん　じっと　うきを　みつめます。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
