  {
    "uuid": "8281ef55-792e-51f9-b322-4f7134a24a25",
    "entry": "口吻",
    "reading": {
      "primary": "こうふん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
