        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仕方なしにバイブルのコンコーダンスを左右に置いたりクラシカル字彙といふやうなものを机上に具へたりして、何うか斯うか御茶を濁して通りました。",
              "citation": {
                "source": "『傳説の時代』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なになに、「日本初のテープレコーダー？",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁につけて、レズリー・スピーカーのついていないハモンド・オルガン、アップライト・ピアノ、ヴィデオコーダーと呼ばれる、小さなトランクほどの大きさがある重い機械がおかれ、天井近くに十九インチのテレビがある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "国産のテープが発売されるので、高志はカセット・テープレコーダーを買うといっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィデオコーダーはあれ一台しかない」「ほしくないかって、どういうことさ」　慶一は、そういいながら、ああ、もう手に入れたも同然なんだ、高志は、いつもの秘密主義で、段取りを終わったから「議題」にしたんだ、と直観した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "テープレコーダーみたいなもんだろ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "各人が「ヴィデオコーダー」の角をもって、汗だくになっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメラとレコーダーをつなぐケーブルは、一〇メートル近くあるので、レコーダーは扉口においたまま、カメラとライトだけが、塔上にあげられた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志の命令｜一下、三人は超特急で荷物をたたみ、警備員に電源を入れてもらい、エレヴェーターで一階におり、台車にレコーダーをのせて寮にもどった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかになんでも、台車にレコーダーをのせて、校舎への坂を駆けあがるなど、むりな話だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「脚本」はワラが管理していて、つねにレコーダーのそばにおかれていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カセットのほうはマイクで録るんだから、みんな入っちゃうよ」　全員に注意をあたえ、ワラは二台のレコーダーをまわした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　柾生が不満そうにいい、ワラがふたつのレコーダーをとめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日四回の上映の合い間を縫って、冗談のように重い「ヴィデオコーダー」（と呼んでいた）をかかえ、慶一たちは校舎のなかを右往左往した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、森本が工場の入り口で「タイム・レコーダー」を押していると、パンパン帽をかぶった仕上場の職長が、　――大変だぜ！",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "針金に情報を書き込むワイヤーメモリーを用い、記憶させた検査のためのプログラムをデコーダーを使って読み出すＩＣテスターの頭脳の開発にあたった後藤は、意識しないうちにコンピューターの基礎技術を身につけていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間のテープレコーダーは動いているにもかかわらずアルテアが反応しないという謎は、コンセントはじつはみんな死んでおり、レコーダーは電池が動かしていたと気付いてようやく解けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三に、これまで補助記憶装置として使われてきたカセットテープレコーダーも、接続できるようにする。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "競合による業績の悪化に直面させられたホレリスは一九一一年に会社を売り払い、新しいオーナーはこれを自動はかりの会社、タイムレコーダーの会社とまとめてＣＴＲ（コンピューティング・タビュレーティング・レコーディング）社を設立した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キーボードはビジネス用を意識して、大きめのタッチのよい本格的なものが用意されており、従来のマシンで一般的だったカセットテープレコーダーもつながるようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―８００１は、標準でカセットテープレコーダーをつなぐインターフェイスを備えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＣ―20の本体には、液晶のディスプレイに加えて、補助記憶として使うマイクロカセットレコーダーと小さなプリンターまで組み込まれており、西はこのマシンにもマイクロソフトのベーシックを売り込んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五に、これも八ビット機で外部記憶装置として使われ、アプリケーション供給のベースとなってきたカセットテープレコーダーを接続できるようにすること。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフィスコンピューターの製品計画に携わってきた小澤は、従来機からの継承性を重視するという方針は承知していたものの、まがりなりにもコンピューターに家庭用テレビやカセットテープレコーダーへのインターフェイスを用意せよという注文には違和感を禁じえなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カセットテープレコーダーがパーソナルコンピューターの外部記憶装置として今後どれほど使われるかには大いに疑問があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭用テレビやカセットテープレコーダーといったアナログの機器をつなぐのには当初戸惑いがあったが、着手してみればこれも間もなく解決できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カセットテープレコーダーを持っていなかったウォズニアックは当初、マシンをセットするごとに三Ｋバイトほどのベーシックインタープリターをキーボードから入力せざるをえなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "入出力にはテレビタイプライター、外部記憶装置としてはカセットテープレコーダーを使った意欲的なシステムを用いて、『ＰＣＣ』の呼びかけに応えて８０８０用に初めて書いたタイニーベーシックを、グリーブは地元のデンバー・アマチュア・コンピューター協会に公開していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
