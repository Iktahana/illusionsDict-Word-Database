          "literary": [
            {
              "text": "――卓子さん（卓をたゝく）殊にお前さんは三ツ脚で、狐狗狸さん、其のまゝだもの。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとで狐狗狸さんが来た。",
              "citation": {
                "source": "勝川花菊の一生",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は井上円了の心霊学に反対して立会演説などをやったらしいが、祖父の留守の夜の茶の間では、祖母が三味線をひいて「こっくりさん」を踊らしたりした。",
              "citation": {
                "source": "繻珍のズボン",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
