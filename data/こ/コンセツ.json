    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kind and careful (instruction, explanation, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "素直に讀者の聲を聞き、自身のまづしい仕事を、そんなにも懇切に讀み、考へて呉れたことに就いては、どんなに感謝するかわからない。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生の卒業論文などについても指導甚だ懇切であった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし先生は、「むだ」や「余白」だらけのだらしのない弟子たちに対して、真の慈父のような寛容をもって臨み、そうしてどこまでも懇切にめんどうを見てやるのに少しも骨身を惜しまれなかったように見える。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上村海軍少佐の懇切なる教示と、嚴密なる校閲とを受けたるは、啻に著者の幸福のみにはあらず、讀者諸君若し此書によりて、幾分にても、海上の智識を得らるゝあらば、そは全く少佐の賜なり。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの間は日出雄少年も私も互に顏を見合せては此不思議なる幸運をよろこび、大佐等の懇切なる待遇を感謝しつゝ、いろ／＼と物語つて居つたが、何時か十｜數日以來の烈しき疲勞の爲めに、知らず／＼深き夢に落ちた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも厚情、懇切のお見舞である。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老師は、両方の縷述と哀訴を懇切に聴き取つた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと私は汗を拭きながら、しきりに病状を訴え、女医の手当のわずかでも懇切ならん事を策した。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、このたびの御手簡には、小生ごときにまで誠実懇切の御忠告、あまり文壇通をふりまわさぬよう、との御言葉。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又只圓翁以外の千代造氏の輔導役は幼少の千代造氏を遇する事普通の弟子の如く、嵩にかかった手厳しい薫育を加えたものであるが、これに反して只圓翁は極めて叮嚀懇切なものがあった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「只圓は私を教えてくれた他の故老たちと違って、傲った意地の悪いところが些しもなく、極めて叮嚀懇切に稽古をしてくれましたよ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が入ってゆくと、アッシャーはながながと横たわっていた長椅子から立ち上がって、快活な親しみをもって迎えたが、そこには度をすぎた懇切――人生に倦怠を感じている俗人のわざとらしい努力――が大分あるように、初め私には思われた。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "あってみない前の思いほどでなく、お光さんもただ懇切な身内の人で予も平気なればお光さんも平気であったに、ただ一日お光さんは夫の許しを得て、予らと磯に遊んだ。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今おうちではああしてご無事で、そうして河村さんもちゃんとしているのに、女としてあなたから先にそんな料簡を起こすのはもってのほかのことですぞ」　予はなお懇切に浅はかなことをくり返してさとした。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小室はこれ等の人々を庭内に誘ひ入れ、最も懇切な態度で、暫時の休息を求め、自分達は奧へ上つて終つた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "懇切に使いの人の労を感謝したうえに、こまごまと死者のうえについての話を聞こうとする。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は懇切に奥に招じて、花前の一｜身につき、問いもし語りもした。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概の文科の教授は学生が居眠りをしてゐようと落書をしてゐやうと平気で自己の講義をすゝめてゐたし、また何んな愚問を発しやうと、懇切に答へるか、失笑するかで、憤慨の気色を現はすなどゝいふことはなかつた。",
              "citation": {
                "source": "文学とは何ぞや",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品の母の懇切な介抱から彼は救はれた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "博勞が遭うた其日から懇切であるのも宿屋で出掛に必ず草鞋を一足くれるのも小木の宿屋の美人が洗濯をしておいてくれたのも皆此の優しい心の發動でなければならぬ。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "『Furz !』『Was? Bitte, noch einmal !』『Furz !』　教師はやっと分かったので顔を真赤にして、そんな詞を使うものではないと、懇切に教えてくれた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "農業者に於いてもその通りで、従業員に対し肥料商に対し種苗供給者に対し、常に福を分かとうとする温な感情を持つ時は、従業員の耕耘も懇切丁寧になるからその農事は十分に出来、肥料商も粗悪な品質のものを供給しないからその効果は十分に挙がり、種苗供給者も良好な種子や苗を供給するから収穫も多くなる道理である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常にお美しい方でございます」　もしそんなことがあったらと大御心が動いて、先帝の后の宮へ姫宮の御入内のことを懇切にお申し入れになった。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "故院がこの御｜同胞がたを懇切にお扱いになったことによって、今もそうした方々と源氏には親しい交際が残っているのである。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "少弐家の姫君のことを大夫の監は聞きつけて、「どんな不具なところがあっても、自分はその点を我慢することにして妻にしたい」　と懇切に求婚をしてきた。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人、君の如き異才を見るの明がなくして意外の失礼をしたと心から深く詫びつつ、さてこの傑作をお世話したいが出版先に御希望があるかと懇切に談合して、直ぐその足で金港堂へ原稿を持って来た。",
              "citation": {
                "source": "露伴の出世咄",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが故国へ帰着した時、先ず第一に同胞へ説き明かさねばならぬ事は、院長及び副院長の此の上なき懇切な御所業である……云々……　　　　　九　最後に、私は此処で、ラ氏が言い遺した一つの思念を想起する。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に当年が五十回忌に相当するというもいよいよ不思議と、何れも奇異の感に打れて、兎も角もそのお住の得脱成仏するように、仏事供養を営むが可かろうという事に一決して、一同その墓所へ参詣し、懇切に回向した。",
              "citation": {
                "source": "お住の霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもね、原稿紙六枚では」そこで私は懇切におことわりの手紙を出しました。",
              "citation": {
                "source": "又復与太話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元來が懇切な人柄の上に、彼はその若い時代に、駿介の祖父には世話になつた一人であつたから、駿介を粗略に扱ふやうなことはなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
