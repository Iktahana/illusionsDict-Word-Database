[
  {
    "uuid": "dd1f828b-620d-585b-9eb5-15d11bac6c46",
    "entry": "懇切",
    "reading": {
      "primary": "こんせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
