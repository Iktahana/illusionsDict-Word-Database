    "definitions": [
      {
        "index": 1,
        "gloss": "to go ahead",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それには僧は一々、相手方の女に問い訊しては、事を運ぶのであった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのように事を運ぶものだから、こちらにも残る手立てが一つしかない。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんにだけ少し拵えてあげますべい」　話す間もお小夜は油断なく手早に事を運ぶ。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行ってから小半月ほどは、お通も唯ぶらぶらしていたんだそうですが、それから寮番夫婦に云い付けられて、土蔵のなかへ三度の食事を運ぶことになりました」「土蔵の中へ……」「土蔵の中には大きな蛇が祀ってあるんだそうで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "向島の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までもよく外国がえりの人たちが、あっちでは市民の訓練がよくゆき渡っていて、何かあると誰云うとなく皆整然と列をつくって事を運ぶ、と褒めた。",
              "citation": {
                "source": "列のこころ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく支障のないように事を運ぶため、彼は自分の同僚の、もう一人の役人を抱きこんだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事を運ぶニウも、まるきり人が変つてしまつてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、かあつとなるよりも、それを通り越してもう一つ心の奥で冷たくなつて、二人が黙つて、事を運ぶンぢやなくちや、いけないのぢやないかしら……。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時も相当の人を見立てゝは、その人の名で仕事を運ぶ。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいちいち家内と相談をして内外の事を運ぶといふ方ではなかつた。",
              "citation": {
                "source": "妻の日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、国民の総力を最高度に、しかも、永続的に発揮する態度を備へなければならぬ今日、あまり性急に、ものの一面だけを考へて事を運ぶといふことは、注意しなければならないことであります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "契約が無いといふことは、特別な契約以上に、「人間」の本性と社会の常識とに従つて事を運ぶ暗黙の理解があつたとみなければならぬからである。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "というは、亭主多吉が町人の家に生まれた人のようでなく、世間に無頓着で、巡査の言い置いて行ったような実際の事を運ぶには全く不向きにできているからであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお江戸の地へ着いたならば、大先生の指揮の下に、何かと事を運ぶよう。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカウトなんて、人目を忍んで仕事を運ぶ必要がありますから、たいがい人に知れないアジトを持っているものです。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "にんじんは、しびれを切らし、手っ取り早く事を運ぶ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、写真で第一印象をきめられるの、女は損だわ」「そんなこと云つたつて、お前、写真も見ずに……」　二人は、すつかり呑み込んでしまひ、もう、勝手に事を運ぶ気でゐるらしいので、千種は黙つてゐるわけにもゆかず、「ちよつと、お待ちになつてよ。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こゝまで事を運ぶのに、一番手こずつたのは、あくまでも結婚という形式で二人が同棲することを拒みつゞける小萩を、ともかく療養所からこの山小屋へ連れて来ることであつた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし実隆がかく公武の間にひっぱり凧になって、用いられたので、おのずから朝廷と幕府との間に立ち、円滑に事を運ぶに与って功を立てたこともある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事を運ぶ順序もいいし、記憶力もよく、監督としては大変便利で使いやすい。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい娘のお頼は、あまりの事に泣いてばかり居る有樣で、跡部滿十郎が何も彼も一人で引受けて仕事を運ぶ外はありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下は大方雜用の物置とお勝手で、格子窓が一つあるのも、こゝに幽閉されたお喜代に、三度の食事を運ぶ役に立つたのは皮肉なことでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鍵の穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい娘のお頼は、あまりの事に泣いてばかりいる有様で、跡部満十郎が何もかも一人で引受けて仕事を運ぶ外はありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "竹光の殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は語らいまた笑いつつその仕事を運ぶ。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは、事を運ぶように、総督には毎日、千ポンドも送ってるんだがねえ」彼女は彼に手紙を書いて、ただちに敵の首都アルスタアに向かって進軍すべきことを命じた。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルとよばれているけれども、どこにもホテルらしい設備も見当らないこんな建物の中で、臥たきりの野沢のために食事を運ぶ誰かがいるのだろうか。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるじおゆみの夕食を取りに来て、戻るところだろう、猪之の提げている手籠は食事を運ぶもので、まえから登は見馴れていた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなはち、法律案として議會に提出すれば否決されると豫想された場合に、緊急勅令として、政府の獨斷で事を運ぶやうな事例も、しば／＼見受けられたのである。",
              "citation": {
                "source": "新憲法の解説",
                "author": "解説",
                "note": "青空文庫"
              }
            },
            {
              "text": "で今や単刀直入に事を運ぶべき場合であると考えた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は走るように戻って来ると、召使の者に客間へ食事を運ぶように云いおいて、自分はそのまま外へ出ていった。",
              "citation": {
                "source": "日本婦道記",
                "author": "尾花川",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
