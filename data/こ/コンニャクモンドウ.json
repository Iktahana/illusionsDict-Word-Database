          "literary": [
            {
              "text": "そして二人はとりとめもなく、こんにゃく問答をしながら、ネクタイを結んで出勤の用意をした。",
              "citation": {
                "source": "残雪",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "げんじつ主義も自分には分らなければ、ぐたいとか空体とかも分らないので、ただかの落語家のこんにゃく問答を思いだしていた。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとこんにゃく問答の神経質を思いだすと、天神さまといっしょに前方を語り合って行く声がしている。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "問う者も問う者なら、答える者も、こんにゃく問答以上の、やみくも問答に暫し市が栄えた。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでこんにゃく問答で、僕にはさっぱり通じやしない」　と、土居が二人の間へ割りこんで来た。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君、これからすぐ出かけて、蟻田博士がなにをしているか、様子をみてきてくれ」「ははあ、いよいよまた始りますね」「なにが、始るって」「いや、変な人相手の、新こんにゃく問答が始るんでしょう。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "めでたし、めでたしだ」　エドガーがこんにゃく問答にじれた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんにゃく問答をしている場合ではあるまい、すぐに行こう！",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
