[
  {
    "uuid": "01d50269-da20-5eda-a52a-f1db9ea2dc9c",
    "entry": "小粒",
    "reading": {
      "primary": "こつぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
