      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "horses 4 or more years old (usu. in racing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　　　　　三　戸外で蒙古馬が嘶いた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がた／＼の古馬車と、なたまめ煙管をくわえた老馭者は、乗合自動車と、ハイカラな運転手に取ってかわられた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大阪から主人が戻って五六日たった今日の午前十時頃、Ｈ屋の門前に一台の古馬車が止った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして拵えますかというと、鋏を持って行って良い白馬の尾の具合のいい、古馬にならないやつのを頂戴して来る。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この馬車を動かす蒙古馬の速力は、刻々ニューヨークとロンドンの為替相場を動かしているのである。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中はハイハイとうけ合って居たっけがそのまんま忘れて午後になって見ると大根の切っ端やお茶がらと一緒に水口の「古馬けつ」の中に入って居る。",
              "citation": {
                "source": "秋毛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がついに、胸悪くなるほど汚ない古馬車を駆ってる御者を呼び止めることができた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その馬車屋はかつて破産したことがあったが、まだ小屋の中には四、五台の古馬車を持っていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん聞く必要も無いでしょうが、どっちが若駒で、どっちが古馬か。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまちそばを駆け抜けて、古馬が数馬身早かった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しむ、私よろこばないです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この認識論は、多くの詩人を、よろこばせるにちがいない。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "デコブラ先生にも送ってやってよろこばせてやるか、可哀そうに。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "物々しい番兵の交代はベルリン名物の一つであったが、実際いかにも帝政下のドイツのシンボルのように花やかでしかもしゃちこばった感じのする日々行事であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花やかにしゃちこばった気分がドイツ大学生特にいわゆるコアー学生の常住坐臥を支配しているように思われるのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニラの帰休兵とかで茶色の制服に中折帽を冠ったのがここばかりでない途中でも沢山見受けた。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とつぶやき、さうして何だか、胸の奧底から、妙なよろこばしさが湧いて出て來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒飮みといふものは、よそのものたちが醉つてゐるのを見ても、一種のよろこばしさを覺えるものらしい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鼻の穴に指を突っ込んで、鉄筋コンクリートのように、鼻毛をしゃちこばらせている、コンクリートを除りたかったのだが一分間に十才ずつ吐き出す、コンクリートミキサーに、間に合わせるためには、とても指を鼻の穴に持って行く間はなかった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "たん架ではこばれて行くＡ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "この渓間ではなにも俺をよろこばすものはない。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと手伝えよ、そんなに日向ぼっこばかりしとらんで。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今まで僕をよろこばして居た自然は、忽ちの中に何の面白味もなくなつてしまつた。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、まだここばかりじゃあない、この頃この近所でも、たびたび飼い鶏を取られるんですよ」　寺内の鶏をぬすみ、人家の鶏を盗み、その悪事重々の奴であるから、そのくらいの仕置は当然であるというような彼の口ぶりであったが、それならば猶更のこと、土地の者がわたくしの刑罰を加えるのはよくないと半七は思った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄土にふくらんだ、麻袋は、工場の前へ、はこばれる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この溪間ではなにも俺をよろこばすものはない。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともあのこれから冬になりまして山がまるで氷ってしまい、川も崕も残らず雪になりましても、貴僧が行水を遊ばしたあすこばかりは水が隠れません、そうしていきりが立ちます。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷い、しゃちこばった顔付が見えるようだ。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人によると妙にしゃちこばって土偶か木像のように硬直して動かないのがある。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩時間に廊下へ出て腰かけて煙草でも吹かしていると、自然にのどかなあくびを催して来る、すると今までなんとなしにしゃちこばってぎこちないものに見えた全世界が急になごやかに快いものに感ぜられて来て、眼前を歩いている見知らぬ青年男女にもなんとない親しみを感じるようになるのがわれながら不思議なくらいである。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
