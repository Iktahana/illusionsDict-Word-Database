[
  {
    "uuid": "3b63afd1-11a7-50c0-8c47-5ae852f5ae8c",
    "entry": "古馬",
    "reading": {
      "primary": "こば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
