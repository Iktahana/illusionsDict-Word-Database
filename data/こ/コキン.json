  {
    "uuid": "ce6dcbb5-8383-5de7-9b1b-fd2834c2ceef",
    "entry": "胡琴",
    "reading": {
      "primary": "こきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
