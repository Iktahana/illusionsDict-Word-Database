          "standard": [],
          "literary": [
            {
              "text": "僕は毎晩のように鉱石の上を針でさぐりながら、銚子局の出す報時信号のリズムに聴き惚れたものです。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "銚子局を経て、本社へ届くことでしょう」「そうか。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夕、さらに銚子局と無線電信の往復あり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
