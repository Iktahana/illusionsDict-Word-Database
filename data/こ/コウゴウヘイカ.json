    "definitions": [
      {
        "index": 1,
        "gloss": "Her Majesty the Empress",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
