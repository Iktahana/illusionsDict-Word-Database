    "definitions": [
      {
        "index": 1,
        "gloss": "high salary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なりひらは高禄の御武家様が御忍びと言った形、半次はお供の下郎である。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "高禄をくれても家隷に有ちたいほどの者ではある。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほかの方々は高禄を賜わって、栄耀をしたのに、そちは殿様のお犬牽きではないか。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、彼は家中の高禄の士の娘を、後房へ連れて来させた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "武家の妻女ならば、まず二百石どころから上の高禄をはんだものにちがいない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しがたいとするなら、いうまでもなく高禄の者が、それもよほどの数寄者好事家が、買うか、鍛たせたかに相違ないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が祖先以来、高禄を頂いて、安閑と妻子を養ってこられたのは、こういう時のために、一命を捨てて、将軍家へ御奉公するためではなかったのか。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇を揮って功を現わし、高禄を得て世を渡る。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "益満は首を振って「いいや、代々上に立って、徒らに、高禄を食んだ奴は、こうした激変の時代に当って、只、失わんことを恐れて、事大的になる。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が市井の出身で、芸藩の儒官、郡宰となり二百五十石の高禄を食むに至つたのは当時としては異常な出世であつたに違ひないが、これは曩に長兄春水が藩に召されたのが機縁となつて居る。",
              "citation": {
                "source": "頼杏坪先生",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "高禄の武家の奥方のような、威も品もある装いであった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一介の郷士にしてたとい名目上とはいえ（「新地」すなわち未開墾地を給された）百石の高禄に擬せられた栄誉の根源は、ほかならぬそのブルジョア的な側面による致富にあった。",
              "citation": {
                "source": "加波山",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "不肖なれども新十郎、剣をもって高禄をいただき居る身、いかなる妖怪か存じませぬが適わぬまでも剣の威をもって取り挫ぎますでござりましょう。",
              "citation": {
                "source": "善悪両面鼠小僧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹腰但馬、渡辺半左衛門、平岩｜図書、成瀬｜監物、等々の高禄の武士たちは、主人東市正と同席し、まことに上品におとなしく昔話などに興じていたが、若侍たちは若侍たちで、少し離れた別の座敷であたかも無礼講の有様で、高笑、放談、自慢話――女の話、妖怪変化の話、勝負事の話などに興じていた。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三位以上のきわめて少数な皇族貴族及び高官に至って、初めて数百石より数千石に至る高禄がある。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、我が一門は、あまりに短時日の内に、この世の栄華富貴を極め過ぎたようです、この家には、高禄、高位が重なり合っております、一年に二度実のなる木は、その根が必ず傷むという言い伝えがあります。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにこの時節は戦国の後で、諸国旧家の主人の新領を失って諸方を流浪して歩くもの、すなわちいわゆる浪人の数が非常に多くして、そのある者は器量次第すこぶる高禄を得たがために、差引残りはまだなかなか多く、何ほど抱えても江戸・大阪に集って来る無足の輩がはなはだ多かったのである。",
              "citation": {
                "source": "名字の話",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖先の手柄で高禄を喰み、ノラリクラリと遊んで暮し、その上女郎買とは何んというタワゴトだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "髷切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "御｜槍奉行原田鉄兵衛の推挙で、一浪人からいきなり二百貫という高禄をたまわった伝九郎、どんな勇士かとねたみ半分で見張っていた人たちが、まっさきになって嘲笑を投げつけた、――だんまり伝九というあだ名が、いつか『逃げ足の伝九』となり、『足なめ伝九』となった。",
              "citation": {
                "source": "だんまり伝九",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもこれも、上様より戴く高禄に安んじ、子に愚かなるこの父の許にいて、修行の精進を心に失うておる証拠でのうて何であろう。",
              "citation": {
                "source": "柳生月影抄",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長島藩は三万八千石、城代家老の忍田外記でさえ五百石とちょっとだから、土田の四百石は高禄の内にはいる。",
              "citation": {
                "source": "饒舌り過ぎる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼はいつも云っている、あれで誰にも恥じず、平気で高禄をいただいているとすれば……いや、おれにはそのあとは云えない」　千久馬はやりきれないという手振りをした。",
              "citation": {
                "source": "はたし状",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にこの人が、この、父が特によびよせ・高禄を以て召抱えた・人が、しじゅうその腕に私を抱いていたのでございます。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそうとわかったら、高禄で彼らを召しかかえたであろう人々も、（c）少なくともその場の急を救ったであろう人々も、（a）たくさんあったにちがいないとわたしは信ずる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれば忽ち、家の子郎党の厄介者付きでも、何百石、何千石の高禄で、すぐ売れ口がついてしまう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "有能の人物は、諸家でも、争って高禄をもって誘いますゆえ」「それほどな者かどうか？",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "松代藩では、それより数年前に、家老の矢沢｜監物の周旋で、初代｜水心子正秀の直門、荘司箕兵衛直胤を、かなり高禄で、招聘していた。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――先は、天下の刀匠水心子の高弟として、藩から高禄をいただいている本業の刀鍛冶ではございませんか』『猶のこと、そのような名だたる者が、卑劣な、刀試しを開いて、しかも大勢の前に、こちらの恥を曝しなどする事が、黙って、捨て措ける事であろうか』『知らぬ顔していればよいのです。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不束な不奉公を以て、高禄を喰むのは心ぐるしくてならないから――という一書を、内蔵助に残して、不破数右衛門は、その後、松山城受取の藩の大任がすむと程なく、赤穂にも江戸にも、その姿をかくしてしまった。",
              "citation": {
                "source": "※かみ浪人",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "では千五百石の高禄を与えると申しても、まだ不足じゃと申しているのか」「いえ、それならばまだしも、実は度々当家からのご催促に、仙石家でもお執做下されたのでござるが、不意に今朝姿を隠してしまった由でござります」「何？",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
