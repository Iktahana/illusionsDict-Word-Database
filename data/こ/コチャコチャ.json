    "definitions": [
      {
        "index": 1,
        "gloss": "cramming in (many small things)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "表通りは名高い大きな書店や、文房具屋や、支那料理などの目貫の商店街であったが、一歩横町へ入ると、モダアニズムの安価な一般化の現われとして、こちゃこちゃした安普請のカフエやサロンがぎっちり軒を並ベ、あっちからもこっちからも騒々しいジャズの旋律が流れて来るのだった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢、鍋、茶碗、棚、飲料、果物、匙やナイフさえ幾色か、こちゃこちゃ持ち込まれてあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の室へ出てみると、母親は台所でこちゃこちゃ働いていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "すんなり枝を延ばし梢高く、樹肌がすべすべで薄紅のに、こちゃこちゃ、こちゃこちゃとかたまって濃緑、臙脂、ぱっとした茶色などの混った若芽が芽ばえ出している。",
              "citation": {
                "source": "九州の東海岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱い弱い視力を凝らして、堅い字を、罫紙にならべて行くうちに眉間が劇しく痛んで、疲れのために、字のかくは離れ離れになり、字と字の間から、種々なまぼしい光線が出て、こちゃこちゃに入り混って、到底見分けて居られなくなった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスに一区のって山門の石の標が見えるところへ来ると、左手の広い畑の面に一ヵ所こちゃこちゃ色とりどりの人間のかたまりがある。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は朝顔の鉢が沢山あります、おじさまの御秘蔵であったシャボテンのこちゃこちゃした小さい鉢はやっぱり棚の上や庭にあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のような人間におそらく分らないほど意味あることらしくて、やがて窓口は変りもうこちゃこちゃしたところへは出て来ないようなことになるらしい風です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、玄関のドアのところへいくと、ポケットから、まがったはり金をとりだし、かぎ穴にさしこんで、しばらく、こちゃこちゃやっていましたが、やがて、カチンと音がして、錠がはずれ、ドアがひらきました。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
