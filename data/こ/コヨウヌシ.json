        "examples": {
          "standard": [
            {
              "text": "優良な雇用主は、従業員の福利厚生に力を入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は新しい雇用主のもとで、充実した毎日を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雇用主と従業員の間で信頼関係を築くことが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この男は雇い主の役だが、そのあとで第三者をこの筋へ入れなければ、あなたを雇用主に会わせられないと気づいた。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてここに雇用主、それも雇用主の権化たるミリアムがおり、飢餓こそが働く一番の原動力とみなしている。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私の雇用主ですから。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "今からレースの間に、最善を尽くしますが、やりたいからじゃなく、あなたが雇用主で、私は命令に従わざるを得ないからです」　マロウはそれ以上言わなかった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに言うことがあるか」「雇用主の俺に対して、いい度胸だ」「雇われているんだったら、そういうことだろう。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "バレリイ嬢から妙な仕事を頼まれ、自由裁量に任されても、雇用主のバレリイ嬢には忠誠を尽くさねば。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
