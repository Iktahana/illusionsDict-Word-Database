        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一つの同じテーマからこの二つの俳句が同時に出来たため、蕪村自身その取捨に困ったらしい。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが一番困ったのは、意識の反対衝動に駆られることだった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々記入する書式の中の宗教という項に神道と書いたら、それはどういう宗教だと聞かれて困った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ会って名刺を貰ってその名前をよんだときに思わず顔中が笑い出しそうになって困った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も教授が厳粛な顔をしてこの人の名を呼びかける度に笑いたくなって困ったのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理教室の図書の管理をしていた、オットー・バシンという人も同じ仲間であったがこの人は聴講に身が入って来ると引切りなしに肩から腕を妙に大業に痙攣させるので、隣席に坐るとそれが気になって困った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイヤーの講義はザクセン訛りがひどく「小さい」をグライン「戦争」をグリークという調子で、どうも分りにくくて困った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計は父の命令で自分の方でもつことになっていたので、甥がひどく悄気て困ったことを思い出す。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、困った事には父上の外は揃いも揃うた船嫌いで海を見るともう頭痛がすると云う塩梅で。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし考えたら何もなるものが無くて困ったかも知れぬ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、困った事には、怨霊の手段としての、言論や文字や、棍棒は禁圧が出来たが、怨霊そのものについては？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし困ったことには「自然」は過去の習慣に忠実である。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、ひょっとしたら始めからない生れつきだったかも知れない」「そんなこともなかろうが、しかし、もしそうだったら困ったものだね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はしばらく困ったやうすでしたが、眼をカムパネルラの方へ向けて、「ではカムパネルラさん。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鼻の尖った人は、少し困ったようにして、また云った。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困ったねえ、えらい人が来るんだよ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "困ったな、どこか栗の木の下でまこう。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある家では牡蠣を入れたのを食わされて胸が悪くて困った記憶がある。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツに居た時は、どういうものかいつも心持が緊張し過ぎて困った。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり緊張が弛んだために眠くなって困った。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困ったなア困ったなア」　お松はくりかえしくりかえし云って溜息をついた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう人に笑われてもかまいませんの」　困った事になった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がなくちゃ弁当が食べられないから、困ったなア、民さん、待っていられるでしょう」「政夫さん、後生だから連れて行って下さい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは衛生問題に関することであったが、云いたいと思うことは皆口止めされて結局何も云うことがなくて困ったと云ってこぼした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛾の襲撃で困った時には宅の猫を連れて来ると、すぐに始末が着く。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼎をかぶって失敗した仁和寺の法師の物語は傑作であるが、現今でも頭に合わぬイズムの鼎をかぶって踊って、見物人をあっと云わせたのはいいが、あとで困ったことになり、耳の鼻も※ぎ取られて「からき命まうけて久しく病みゐる」人はいくらでもある。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが困った事にはそういう罪人をつかまえる為政者の方でもちゃんとそれを承知しているから、あらかじめ犬の糞を用意しておいて、すぐにそれを食わせ、そうしてすっかり毒を吐き出させてしまう。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃の話だが、米国のある夜学校で強い電灯を点じてやっていたが学生中に眼病が非常に出来て困った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴又出て行きゃあがったな」　「え、たった今」　「毎晩、毎晩、困った奴だ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こまったわ、わたし、どうしてもないわ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
