        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし自分たちが迂濶に釣ったり、網を入れたりすると、商売柄だけにすぐに眼につくという懸念から、ふだんから心安い藤吉を抱き込んで、こいつにそっと釣らせていたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの非人を御存じで……」「知っておるにも何も、私とは極く心安い仲で……ヘヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人ばかりでたよりにはならぬが、近い上に心安い。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方にこうして頂きますより殺されます方がどんなに心安いか分りません。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも何だか気味がわるくなって、忽々に逃げて帰りました」「おめえはお鎌と心安くしているのか」「別に心安いというわけでもありませんが、あの婆さんは小金を持っているので、時々ちっとぐれえの小遣いを借りることもあるのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "みればやあ公はいつもの、あの心安いやあ公である。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならばお心安い。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野さんと戸塚の野郎は前から心安いんか」　三好が仄白い光りの中で片目をつぶって笑った。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の両隣には心安い人がいたが、もう夜が更けているのでその夜はそのまま寝ることにして寝た。",
              "citation": {
                "source": "山寺の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕頭には心安い隣家の下駄屋の主翁や、荒物屋の主翁などが二三人坐っていた。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は心安いような態度で茶碗を口に近づけて、一ト口飲む真似をした。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんは光井さんと心安いようではあるし、犬も朋輩、鷹も朋輩、いわば朋輩同士のことだから、なんとかわたしに手伝って、そのお鷹を早く見つけ出す工夫をしてくれませんか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか格別に心安いのかえ」「はい、おまえさんですから申し上げますが、実はわたくしには十八になる娘がございますので……」「十八になる娘……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "心安いばかりでなく、それ者あがりのお定の年増姿がかれの浮気を誘い出して、お駒がほかの座敷へ廻っているあいだに、時々に飛んだ冗談を云い出すこともあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして一家の人々から款待されて、澹山の方でもひどく喜んで、自分の居間として貸して貰った離れ座敷を画室として、ここでゆっくりと絵絹や画仙紙をひろげることになると、伝兵衛も自分の家の屏風や掛物は勿論、心安い人々をそれからそれへと紹介して、澹山のために毎日の仕事をあたえてくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人共留学中は伯林にゐたので、非常に心安い。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思ふと同時に、そんなら何故心安い杉村の声がするのに、顔を出さずにゐたか知らんと疑つた。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様をはじめ、どんな心安い人にでも、今日の事を話すのではありませんよ。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は君を、私の心安い宿屋に紹介する。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "出迎をした親類や心安い人の中には、邸まで附いて来たのもあって、五条家ではそう云う人達に、一寸した肴で酒を出した。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『ええ、直ぐ近くですし、それにとても心安い間柄でしたから寄って呉れたんです。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛したものの死ほど心安い潔い死はない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行つた先は、父のゐた時分から家の行きつけの心安い海水浴の宿屋であつた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、女はもう先から心安い間のやうに口を聞く。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風船玉のようなフワフワした文化気分が、例のバラック気分と心安いのは云う迄もないので、東京人の魂はバラック生活と文化生活との間をフラ付いている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬至の柚湯――これは今も絶えないが、そのころは物価が廉いので、風呂のなかには柚がたくさんに浮かんでいるばかりか、心安い人々には別に二つ三つぐらいの新しい柚の実をくれたくらいである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの事情をかんがえると、お留はふだんから心安いお春に頼まれて、なにかの毒剤を富子の飲食物の中へ投げ込んで置いたかとも見られるので、彼女はすぐに下座敷で厳重な取り調べを受けた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの記念ですから、などといふ心持でないことは心安いが、こんな着古しをきてゐる彼女は、いまあまり豐かに暮してゐないのだらうか。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に心安いという仲じゃあねえ」「どこまで行っても喧嘩腰だな」と、吉五郎はまた笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田にこころやすい家がある、そこで待っていて下さい、と平八が云った。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
