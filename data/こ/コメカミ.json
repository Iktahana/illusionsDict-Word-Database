    "definitions": [
      {
        "index": 1,
        "gloss": "temple (on side of head)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
