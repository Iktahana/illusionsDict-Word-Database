  {
    "uuid": "816c07b9-f26e-5383-a89e-e7b3f3475424",
    "entry": "黒土",
    "reading": {
      "primary": "こくど",
      "alternatives": [
        "くろつち"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
