[
  {
    "uuid": "c98d324e-1d06-545b-b1bc-5c8ab4ab11b4",
    "entry": "古材",
    "reading": {
      "primary": "こざい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
