          "literary": [
            {
              "text": "肥溜めさえ見えなければ、日本とは思えない」　といいながら、高志も慶一のとなりにきて、手すりにもたれかかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのフキやシダのあいだに、低い藁屋根をさしかけた肥溜めがひとつ、もうすこしいくと、炭焼き小屋もあるが、煙は出ていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたの立っているところは、むかし、肥溜めがあったところだ」　まんざらウソではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これなら、肥溜めのほうがましだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "樫の木の下の肥溜めに向って放尿しながら答えた。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "路地や拱門路からは、それだけの数の下肥溜めがあると同じように、疎らに家の立っている街上へ、胸の悪くなるような臭気と、塵埃と、生物とを吐き出していた。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻道傍にあった肥溜めなんかは原始的家屋の標本さ。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "付近に肥溜めなぞがあって、むろん若様がたの立ち入るところでない。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
