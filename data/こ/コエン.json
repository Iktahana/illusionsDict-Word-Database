        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なぜ仲間が、土牛をすぐれた作家だと強調することをしなかつたのか、そして奥村土牛といふ作家に院展に「孤猿」といふ性質の作品を描かせておいて平然としてゐたかといふことに疑をもつ、当然世に押しださなければならない作家は、画商の手を藉りるまでもなく、作家同志の協力と愛情に依つて行はれるべきであらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "きんのは朝から耳ん中で蠅が一｜匹ぶんぶんいってやがって、いっこう聞こえんだった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……屋根へ上っとると人の声はきこえんのや、まるで夢中になっとるんや。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレコレここ、離しおれと云うたら……云うたて聞こえんけに往生するのう。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう始まったですか」　「聞こえんかあの砲が……」　さっきから、天末に一種のとどろきが始まったそうなとは思ったが、まだ遼陽ではないと思っていた。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄屋どんも、きこえんぞ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上のなされ方がきこえんわ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "海浜にさすらひ、去年の秋江上の破屋に蜘蛛の古巣をはらひてやゝ年も暮れ、春立てる霞の空に白川の関こえんと、そゞろ神のものにつきて心をくるはせ、道祖神のまねきにあひて取るもの手につかず。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "名も知れない男から度々電話で指令が来るなんていうのはまず出たらめとしかきこえんからな。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実主義者が恋愛は性慾と生殖作用の上部構造にすぎないといっても、精神的憧憬の深いイデアリストは恋愛が性慾をこえた側面を持ち、むしろそのこえんとする悩みにこそ、恋愛の秘義があると主張してやまないであろう。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖母にまで高まり、浄まらなければならない娘の恋が肉体と感覚をこえんとする要請を持っていなければならないのは当然である。",
              "citation": {
                "source": "女性の諸問題",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣いても、どこにも泣き声がきこえんわ」「怖しい人だわねえ。",
              "citation": {
                "source": "保久呂天皇",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一丈五尺をこえんとはげむべし。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕草子に、チユウゲンなる折に大進物聞こえんとありと、人の告ぐるを聞こしめして、……めのありしをたゞ取りに取りて喰ひまぎらはしゝかば、チユウゲンにあやし（賤）の食ひ物やと人も見けんかし。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、遠くから近づいて来る世の大変革の跫音が、君にはすこしも聞こえんのかなあ。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "この声が貴様に聞こえんか」「事は好まん……が、やむを得ん！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、あんなに憎んでいながら何の手紙かと思いつつも、急いで見る気にはならず、「いね、今きこえん」と言って手紙を懐へ入れて引っ込んでしまう。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猶みおくりきこえん」（いいえ、まあ見送ってあげましょう）。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
