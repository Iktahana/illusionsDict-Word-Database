          "literary": [
            {
              "text": "「風がなくなったら、たこあげができない」　と善金が心配そうにいった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "たこあげ天へ上りたかネオルガンの鳴っとる如たる凧の踊っとるもん天へ上りたかネ　　注上りたか…………上りたいごたる……………ようだハタ………………たこ踊っとるもん……踊っているから完全な幸福　真実孤児の道はさみしい。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ここでも経済的な意味ばかりでなく、性来の世話やき好きでお文が采配を振り、総ざらいが終るなり師匠を拉して来て、「さあこれからお師匠さんのとこあげ祝いよ」　などと気勢をあげた。",
              "citation": {
                "source": "寒橋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
