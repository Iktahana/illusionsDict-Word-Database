          "standard": [],
          "literary": [
            {
              "text": "おい、此処いらで一服しようか」　そう云いながら、忠次は足下に大きい切り株を見付けて、どっかりと、腰を降した。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "不図したら、猟銃を肩にしたツルゲネーフが、人の好ささうな、髯の長い、巨人の如く背の高い露西亜の百姓と共に、此処いらを彷徨いて居はせぬかといふ様な心地がする。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処いら――江の島、七里ヶ浜あたりの波は随分と低い。",
              "citation": {
                "source": "冬の海",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流し元と、女中部屋との間の板の間に、薄く泥のあとが付いて居るけれ共、それもぼんやりして何がどうだか分らないので、「此処いらを余程行ったり来たりした様ですなあ。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処いらは海アルプス。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっき此処いらで昼顔を見たんだけれど、もうないわね」　私はそんな考えから自分の心を外らせようとして、殆ど口から出まかせに云った。",
              "citation": {
                "source": "楡の家",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ、こんなばかばかしい寒さは此処いらだけと我慢してゐたが、みんな、その日ざしを慕ふやうに、向うがはの座席に変はつた。",
              "citation": {
                "source": "辛夷の花",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体此処いら界隈が学者町で、相当に落つきのある生活をして居る人が多く、したがって、それ等の人達の娘だとか妻君だとか云う人で暇仕事に音楽などをする人が多いので、東京の音楽の盛な区の中に入って居るとか云う事をきいた事があった。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体此処いらで、そう云う調子のさわぎをきく事はまれなので、私などは、蟻の足ほど短かい今日までの生涯の中初めてきいたさわがしさであった。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処いらの純農民は、随分と貧しい生活をして居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の職人も煙草を吸う時間の永いには驚く様だけれ共、まして此処いらのはひどい。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処いらの人から見れば、随分はでに見える着物を着て、大股にスタスタ歩く私を、いつまでも見て居るのが気に障った。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処いらの家では大抵自分の家でつくので、中学の教師の家だの何かでそう沢山頼まれもしないのだそうだ。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一盃おとそを飲めば後は熱酣でなければ飲んだ気のしない此処いらの連中のために酒が珍らしくまとまって台所にあるけれ共、それも、女ばかりの処であんまりお心よくして、酔いしれて、管でも巻かれると始末が悪いと云って加減がしてある。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処いらの正月は、盆よりはにぎやかでない。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処いらの一体の子供が、はにかみやのくせに悪口をつくから、何だか私にいい感じを与えない。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ、こんなばかばかしい寒さは此処いらだけと我慢していたが、みんな、その日ざしを慕うように、向うがわの座席に変わった。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……Ｔ君もひさしぶりにこの辺まで上って来たものらしく、さっきからしきりに此処いらまでよく遊びに来たことのある昔のことを思い出してはひとりで懐しがっている。",
              "citation": {
                "source": "旅の絵",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしらだけで無く、此処いらん小商人の内幕なんぞ、そんなもんさ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "港町と言やあまた此処いらとは一倍人気も荒いだらうし、お客も性の知れない人が多い。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪のあるのは旧大きいお邸の医者様の跡でな、ここいらはこれでも一ツの村でがした、十三年前の大水の時、から一面に野良になりましたよ、人死もいけえこと。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなかここいらは合理的である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここいらで一服してみよう。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここいらで成仏してくれませんか。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここいらは叔母さん、海岸の一筋路ですから、岐路といっては背後の山へ行くより他にはないんですが、」「困りましたねえ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを怨んで、未練も有って、穴から出たり入ったり、ここいらつけ廻しているに違いない。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここいらじゃあ尾鰭を振って、肩肱を怒らしそうな年上なのを二人まで、手もなく追帰したなあ大出来だ、ちょいと煽いでやりたいわねえ、滝さんお手柄。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――むかしここいらで、小学校へ通うのに、いまのように洒落た舶来ものは影もないから、石盤、手習草紙という処を一絡めにして……武者修行然として、肩から斜っかけ、そいつはまだ可いがね、追々寒さに向って羽織を着るようになるとこの態裁です。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、ああ、ここいら、一面に、己達の巣だったい。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだって空な事過ぎるが、むかし懐かしさに、ここいら歩行かないとは限らない。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
