    "definitions": [
      {
        "index": 1,
        "gloss": "bottom of one's heart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
