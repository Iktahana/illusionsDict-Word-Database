          "literary": [
            {
              "text": "過去四年の間、喉頭炎と思わされて来たものが肺であることも分った。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その頃、まるで故意とのようにちょっと風邪を引いたのが因で、歯槽膿※と軽い喉頭炎に悩まされていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の知るとおり、今から三十五年前に、クルプ性｜喉頭炎が非常に流行して、パリーのセーヌ川付近を荒したことがあった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
