        "examples": {
          "standard": [
            {
              "text": "私の祖父は大変な交際好きで、家にはいつも誰かしら客が訪れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "交際好きの彼女は、週末になると必ず友人たちを集めてホームパーティーを開く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は交際好きな性格が災いして、毎月の交際費が家計を圧迫している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "交際好きの人になると、自分の両隣ばかりでなく、他の座敷の客といつの間にか懇意になって、そことも交際しているのがある。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "交際好きの人になると、自分の両隣りばかりでなく、他の座敷の客といつの間にか懇意になって、そことも交際しているのがある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御存知の通り、あの人は交際好きで、男の友達も少くありませんし、それに、ひどく気まぐれなたちですから、長く留守にする間に、どんな事が起るまいものでもありません。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
