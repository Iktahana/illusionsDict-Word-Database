[
  {
    "uuid": "3835a261-8439-5cc2-9a89-7e2afaebf5fa",
    "entry": "越したことはない",
    "reading": {
      "primary": "こしたことはない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
