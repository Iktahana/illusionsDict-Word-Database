    "definitions": [
      {
        "index": 1,
        "gloss": "cooling pillow (often rubber)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "本田家の当主は、家族の者と主治医とに守られて、陶製のもののように、何も考えることも感じることも出来なくなった頭を、氷枕と氷嚢との間に挟んでいた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "義枝はしきりに氷枕へ氷をいれたりした。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀相に豹一は氷枕をあてがわれた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦さんが持ってきてくれた氷枕に頭を沈めてから、二本目のカンのプルトップを開けました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "話に疲れると病人は、長い溜息を吐いて、水蒸気の立つ氷枕に、痺れたような重い頭顱を動かした。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "三階の六畳に、彼は氷枕をして仰向きに寝てゐた。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで枕を氷枕に換えて、上からもう一つ氷嚢をぶら下げさせた。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は氷枕の位置を直しながら、蚊帳ごしに明るい空を見た。",
              "citation": {
                "source": "田端日記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱の高い時は、夜遅くまで起きていてくれ、夜中にも起上って氷枕を取り代えてくれた。",
              "citation": {
                "source": "新妻の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――女中が恐る恐るやって行くと、父はもう寝所に寝ていて、氷枕を用意せよと命じた。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷枕で頭を冷やし、また額も冷してやった。",
              "citation": {
                "source": "生と死との記録",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頭の下には氷枕があてがってあることに気付いた。",
              "citation": {
                "source": "蘇生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれをまぎらすためか、敬助の頭の下の氷枕に触ってみた。",
              "citation": {
                "source": "蘇生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団の中にはいると、敬助は氷枕がいつのまにか普通の枕に変ってることに気付いた。",
              "citation": {
                "source": "蘇生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦が氷枕を下げて戻って来ると、「あり難う、」と啓介は云った。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷枕の上に頭をかすかに震わせながら、じっと眼を閉じた。",
              "citation": {
                "source": "二つの途",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷枕をさしてやった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "吸入に湿布に、熱があれば氷枕、過激な運動を避けること、それだけが手当の全部だった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "隆吉は氷枕を止して空気枕で寝ていた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂積と六弥は親切に氷嚢や氷枕など、なにくれと無く心配してくれたが、こんな時には、女手で無ければ、痒い所に手が届かないと栄一は思つた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "達ちゃん、鷹なんていやしませんよ」　火のような頭をそッと氷枕の上におさえつけ、額にも氷嚢をあてがった。",
              "citation": {
                "source": "美人鷹匠",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽井沢では毎晩の湿布とか氷枕とか、うがいなぞを自分からはじめていたが、此処ではにわかにどうなったっていいや、此処は患者という名の意志のない奴の寝ころがっている一つの断崖なのだ、此処から転がりこむところは決っている。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷と氷枕を買って戻れ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午頃浦安に帰り床に就いたが三十八度を越す高熱で氷枕もなく大変に不自由な苦しさを味わった。",
              "citation": {
                "source": "青べか日記",
                "author": "――吾が生活　し・さ",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ昏睡におちいつてわからなくなり、氷袋や氷枕で冷したり、注射をしてもらつたりしてをりますけれども、生命體そのものは外部のものと猛烈に鬪つてゐる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が台所で氷嚢や氷枕を捜していると、彼女は氷を提げてはいって来て、それを走りの板の上に置き、私がどんな表情をしているかを、光る眼で素早く看て取ってから、そ知らぬ風をして氷を割り出した。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二人で寝室へ行き、麻痺の側と反対の側を特に冷やすように氷嚢と氷枕を当てた。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑くて／＼氷枕で寝る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "必要なのは看護人と、氷枕だ。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
