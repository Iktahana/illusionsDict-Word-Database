        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "洒落た切子細工や典雅なロココ趣味の浮模樣を持つた琥珀色やひすい色の香水壜。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女たちは小指のような微生物まで琥珀色の液体で染めた。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、テエブルの上にあつたグラスの、琥珀色の酒をぐいと呑み干すと、いきなりまた男の首筋に白い手を卷きつけて、じやれつくやうに短い接吻をその唇に與へた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "洒落た切子細工や典雅なロココ趣味の浮模様を持った琥珀色や翡翠色の香水壜。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清酒と同様に綺麗に澄んでいて、清酒よりも更に濃い琥珀色で、アルコール度もかなり強いように思われた。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "末の妹のカロラインが、つきまとわるサン・ベルナール種のレックスを押しのけながら、逸早く戸を開けると、石油ランプの琥珀色の光が焔の剣のような一筋のまぶしさを広縁に投げた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、東のそらは、お「キレ」さまの出る前に、琥珀色のビールで一杯になるのでした。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もろもろの陰は深い瑠璃色に、もろもろの明るみはうっとりした琥珀色の二つに統制されて来ると、道路側の瓦屋根の一角がたちまち灼熱して、紫白の光芒を撥開し、そこから縒り出す閃光のテープを谷窪のそれを望むものものに投げかけた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「をぢさま、よくご存じでいらつしやるわ」　陽は琥珀色に輝いて、微風の中にゆらぐ芍薬と少女は、閃めいて浮き上りさうになつた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍ったような姿勢で、琥珀色の干涸らびた身体に向いあって立っている。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "義直はをかしな声だなと思つてゐると、洋服の女はやがてビールを入れた琥珀色に透きとほつて見えるコツプを持つて来た。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い、黒い睫毛が、柔い、琥珀色をした頬の上に垂れてゐます。",
              "citation": {
                "source": "尼",
                "author": "DAT FLEESCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "琥珀色を帯びた円い顔の、目の縁が薄赤い。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡村と云われた青年は、中肉の身体にスッキリと合って居る、琥珀色の、瀟洒な夏服を着て居た。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い男は、何にも云わずに、手に持った琥珀色の櫛で軽く自分の頭を叩いた。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の青年畫家は、フランスからこの町へ來て、こゝの女のしめりつぽい碧い目と、琥珀色の絹のやうなふさ／＼しい髮と、純白な裾長い着物を着た、典雅な姿を寫し取るために止まつてゐた。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ泣いておいで、おまへの琥珀色の涙へ、わたしは指環の印を押してあげる、後の思出の種として。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "水戸君も愕くことがある筈だ、なぜといってこのゼムリヤ号は、調べれば調べるほど、なかなか興味ぶかい船だからね」　水戸が酒壜を持ってホーテンスの盃に琥珀色の液体を注ぎそえた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "形にして穹窿型、光にして琥珀色、それが朦朧と現われたのである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑤珞を持った南蛮製の、ギヤマン細工の巨大な龕灯で、そこからさしている琥珀色の光が部屋全体を輝かせている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「袴氏」と城之介、隣室から来る琥珀色の光に、ぼんやり半身をひからせながら、広太郎を上から見下ろしたが、「一切万事浮世のこと、愛欲の目もりをはずしては、物の値打ちをはかることは出来ぬ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると、若者の目の前には大きな大きな琥珀色の石の砦が現れて来た。",
              "citation": {
                "source": "忘れがたみ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に接している砂浜は金色に輝き、飛び交うている信天翁の翼から銀の光を発するかと疑われ、いつもは見ることを厭っていた硫黄ヶ岳に立つ煙さえ、今朝は澄み渡った朝空に、琥珀色に優にやさしくたなびいている。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "田といふ田には稻の穗が、琥珀色に寄せつ返しつ波打つてゐたが、然し、今年は例年よりも作が遙と劣つてゐると人々が呟しあつてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "田といふ田には稲の穂が、琥珀色に寄せつ返しつ波打つてゐたが、然し、今年は例年よりも作が遙と劣つてゐると人々が呟しあつてゐた。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "人気ない卓の上で、酒はいよいよ愛らしい琥珀色に輝いた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "PANTOMIME富永太郎うす暗い椽側の端で、琥珀色した女の瞳が光つた――夫に叛いた。",
              "citation": {
                "source": "PANTOMIME",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
