[
  {
    "uuid": "a2d8cf37-cf98-5547-8e8d-f70fc15c1748",
    "entry": "挙る",
    "reading": {
      "primary": "こぞる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行"
      ],
