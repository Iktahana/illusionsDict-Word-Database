        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "料理に香辛料を加えることで、味が格段に引き立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世界各地の市場では、珍しい香辛料が豊富に売られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「このカレー、香辛料が効いててすごく美味しいね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "心の底に押籠められながら焦々した怒ろしい想いはこの豊潤な肉体に対し、いよいよその豊潤を刺激して引立てる内部からの香辛料になったような気がする。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "香辛料の好きな花田は、そういう種類の草木が在るところをよく知っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "素晴らしい黄色はターメリック（ウコンの地下茎から得られる香辛料）から辛子に与えられたものであるとしばしば言われている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は不満の程度を探ろうと、夫がカイエンヌ香辛料を回してくれと言ったついでに、聞いてみたが、失敗だった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "香辛料としてはデーツ・シロップとハチミツが使われた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしば種々の香辛料で味付けをしたブドウ酒はギリシアおよびローマの発酵飲料であった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
