    "definitions": [
      {
        "index": 1,
        "gloss": "\"grain rain\" solar term (approx. April 20)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「穀雨前一日、与木村駿卿、狩谷卿雲、及諸公、同集菊潭吉田医官堂、話旧」として七絶二首がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "穀雨は三月二十五日であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに鉱毒被害深さ八九寸より三尺に渡り候田圃には、さらに陽気の立ち登るを見ず」二月の啓蟄、三月の穀雨と読みたどって、「小満四月、中の節。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、しつこくうるさいので、見物のなかでたしなめた者があったのを、相手欲しやの酔いどれ士は、忽ち目くじら立てて立ち上り、掴みかかろうとする。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど清三の心はもうそれがために動かされるほどその影がこくうつっておらなかった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "権十の大漁着を借りて磋磯之介は、苫の蔭に丸ッこくうずくまっていた。",
              "citation": {
                "source": "旗岡巡査",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
