        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "春松は遊びが好きで困り者だったが、その代り、白金分離の仕事はまことに鮮かだった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は夫を持つと気が小さくなるというが、娘の時のあれは困り者のほどな大気の者であったが、余程聟殿を大事にかけていると見えて、大層女らしくなり居ったナ。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "困り者だ」　などと冷評する者があって人々は笑っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し又そのなかには随分だらしのない困り者があったのも事実で、それを証拠にして、さあ何うだと云われると、まったく返事に詰まるわけです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、たゞ一口にだらしのない困り者だと云ってもいられません。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも酒を余程飲んで居た風だつた」「誰が酒を飲ましたのか知らん」「誰がツて……野郎、又｜威嚇文句で、又兵衛（酒屋の主人）の許へ行つて、酒の五合も喰つて来たんだ」「困り者だナア」　と根本は心から独語いた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "著作家や牧師のやうな始終家ばかしに燻つてゐるのは一番の困り者で、出来る事なら船乗や海軍軍人のやうな月の半分か、一年の何分一かを海の上で送つて、滅多に家へ帰つて来ないのへ嫁きたがるといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時｜兄は叱るかと思ひの外、さうか、困り者だな、親爺には内々で置けと云つて嫂を通して、奇麗に借金を払つてくれた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞之進はそれが冗談に聞たくなく、又｜聞かれずに心懸に顔｜赧らめ、困り者ですとタッタ一言の調子が合せられずに、虚実の闘いは一先消滅し、かえってそれがために陰然地を造って、小歌を二無き者とそこへ祀ってしまった。",
              "citation": {
                "source": "油地獄",
                "author": "斎藤緑雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時兄は叱るかと思いの外、そうか、困り者だな、親爺には内々で置けと云って嫂を通して、奇麗に借金を払ってくれた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来たわ」「どうだい様子は」「やっぱり相変らずですわ」「あれにも、本当に……」で薄く八の字を寄せたが、「困り者だね」と切った時、八の字は見る見る深くなった。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（其も困るが）つつぱつてあかぬ　末」（此奴も困り者だ）。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "困り者だといふので町中の者から町奉行へ申出た。",
              "citation": {
                "source": "物貰ひの話",
                "author": "三田村鳶魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の事ではあり、病気と皆が承知して居るので、表沙汰にはならなかったが、一同困り者にして居た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「真実に、宗蔵の奴は困り者だよ。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物の表紙やら小口などを穢くしたりするから困り者の一つではあるが、それよりはもっと書物を害するヤツがいるに関らず誰れもが一向その名さえ言わぬのは片手落ちというもんだ。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「宿元へ残して参りましたが、それが殿様、ほんとに困り者なんでございますよ」「どうしてだ？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男はグヅでいかん、次男は反抗的で困り者だ、三男だけがよく言うことを聞き、才能もあるようだとなると、ついこの三男を偏愛する、というような実例はどこの家にもありがちであります。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし將來、どんな困り者になつても、確實に１であることもまた、何か恩惠すぎて、社會にすまない氣もしたことであつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のしっかり者が、ほんとうは困り者さ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "――噂によれば、僧正ヶ｜谷や、貴船の里人どもも、もてあましている暴れン坊とか」「さればさ、寺でも、困っておるらしい」「その困り者へ、眼をつけて、はるばる奥州路から年ごとの鞍馬｜詣では……。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに、世評にもお聞き及びでしょうが、私という人間は、実に、矛盾だらけな、そして、自分でも持てあます困り者です。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、平常、平和な内地にあつては、家庭で困り者のどら息子も居よう。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、家庭の臺所口へ出入りする八百屋、肉屋の御用聞きでも、應接へ來て、飮んだり遊んだりの話ばかりしてゐる男にでも、知己のあひだで、困り者になつてゐる札ツキにでも。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時から、血の気ばかり多くて、困り者だと思っていたが』『そう云わないで後生じゃ、この母に免じて、彼の子を家へ』『いけません。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――困り者の光圀が一転して学問に心をひそめ、こんどは体でもわるくせねばよいがと案じていたが、それくらいな望みなれば、叶えて遣わしてもさしつかえないではないか）　親馬鹿とは、かかるお方のことをこそいうのであろう。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが、何とはなく、世間の目を忍ぶらしい身の上にある事を知っても、かれを疑わないばかりか、ここの裏店も、夫婦して借りうけ、朝夕の洗いもの、酒屋の借金にいたるまで、（又さんは困り者だよ）　と、いいながらも、その困り性を愛して、世話してくれるのであった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ返すには返しましょうがね」「ま、いいじゃありませんか」「役には立つ男だが、牢城の困り者です。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だからたとえ鬼小島弥太郎のような習性でも、しばらくその中に棲息をゆるされ、また一人前になるまでは、「困り者」　の代名詞となるほどでも、朋友から上役まで、「いつか、何かのときには、お役に立とう」　と、その短を扶け合っていてくれるという風だったのである。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれ一人が文明人という顔つきで、『世界｜国尽』などをちょっと口元ばかりのぞいて見た知識を振り回し、西洋のことならなんでも来いと言い触らすこまりものだともある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
