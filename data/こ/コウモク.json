[
  {
    "uuid": "8b6c616a-2537-523f-9f21-0a668317e0b2",
    "entry": "項目",
    "reading": {
      "primary": "こうもく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "item",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一通りの定まった版行で押した項目だけを暗誦的に説明してしまえばそれでもうおしまいで先様御代りである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上述べたような項目の外に著しく多数に散在しているのは有職故実その他あらゆる知識に関するノートと云ったものである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "限られた紙幅の中に規定されただけの項目を盛り込まなければならないという必要からではあろうが、実にごたごたとよく色々のことが鮨詰になっている。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結語　科学と文学という題のもとに考察さるべき項目はなお多数であろうが、まずこのへんで擱筆して余は他の機会に譲ることとする。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただある、割合に少数な項目の、多数な錯列によっていろいろの顔の印象ができている。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に若干「相似」を決定するために主要な項目の組み合わせがあってこれだけが具備すれば残りの排列などはどうでもいいのだろう。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭祀その他宗教的儀式と連関していろいろの巫術魔術といったようなものも民族の統治者の主権のもとに行なわれてそれが政治の重要な項目の一つになっていたように思われる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら、自分のような門外漢がこの講座のこの特殊項目に筆を染めるという僣越をあえてするに至った因縁について一言しておきたいと思う。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（付記）　紙数に制限のあるために省略した項目の中にはたとえば「字幕」の問題や、映写幕の形状の問題のごときものがある。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画と連俳との比較については岩波版日本文学講座中の特殊項目「映画芸術」の中に述べてある私見を参照していただきたい。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「禅関策進」にはこの項目以外にも肉体の自然の要求を退けて悟りの道に進んだ幾多の事例が載っていた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして不思議の沈黙に陥つたかと思ふと、彼は負けた仏蘭西に課すべき条件の項目を其間に調べ出した。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、いまの私にとって、最も大切な項目である。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そのほか、甚だけちのようなれども、題名を言われぬもの、十七八項目くらい。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上三項目、入院の前夜したためた。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なんと愉しげに、また、なんと数多くの項目を彼は数え立てたことだろう！",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等のうちで後の三つは別として、初めの三つの項目中に於ける各季題の分け方は現代の科學知識から見ると、決して合理的であるとは思はれない。",
              "citation": {
                "source": "天文と俳句",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を伸ばしたまえ、ワトソン、Ｖの項目の確認だ。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ホームズは最後の項目に苦笑したが、「まあ、」と言って、「あのときと同じように言わせてもらうと、人間が頭脳という屋根裏の小部屋にいつも置いておかねばならぬのは、よく使う道具だけ、それ以外は書斎という物置に片づけておいて、入り用の際にそこへ取りに行けばいい。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新聞の議論の項目を調べてみようじゃないか。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行者が必要とするあらゆる知識と知恵の宝庫として評判の高い『ガイド』の本文には、百科事典流の項目別記述が採用されています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "見出し項目としては「ヴォゴン開発船団」が立てられているようで、入力した「ヴォゴン」そのままではありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと紙の本のままでは、索引で関連する項目のありかを調べ、該当する巻にたどり着いて目指すページを開くまでに、とんでもないエネルギーを要したでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめリンクを仕込んでおけば、マウスのボタンの操作で、ある項目から一瞬に別の項目にジャンプできるのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "各項目に付ける言い訳の原稿が、今日はすいすい書けそうな気がした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "木津田さんたちのサイバーブックセンターがスタートした直後にまとめた企画書には、エキスパンドブックをインターネットで売るという項目も加えていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "資料提供に際しては、「どんな外字が、どの本に収録されているなんという作品の何ページ、何行目に出てくるか」を確認し、「その字が、どの漢和辞典のどの項目で確認できるか」という情報をそえることを求められた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日、事務局が用意した「著作権法に関する今後の検討課題（素案）」には、法制問題小委員会が検討を行っていく「基本問題」八項目の一つとして、保護期間の延長が盛り込まれていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇〇五年秋までは、この二項目に関する作業が、集中して進められる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうかんしんな兄妹を、こうもくるしめるのは、一体誰のせいでしょうか。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
