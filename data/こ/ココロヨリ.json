    "definitions": [
      {
        "index": 1,
        "gloss": "heartfelt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頻繁なる対人圏にあつて、各人が各人で朗らかであり得ぬ程度に比例して人々は互の「顔色を覗ふ」こと盛となる、即ち相対的となる、即ち創作的気心より遠ざかるわけである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の慰安の心よりは、余義ない気持の勝った歌である。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿躰なき罪は我が心よりなれど、桜町の殿といふ面かげなくば、胸の鏡に映るものもあらじ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるに、「ダス・ゲマイネ」の註釋などせよとの親切心より發せしお言葉ならむ。",
              "citation": {
                "source": "「地球圖」序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学は十分に尊敬し、十分に愛護し、そして其の生長して偉才卓能をあらはすのを衷心より歓迎せねばならぬ。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは慌だしい心よりもなほ慌だしく。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別して造塔、起仏に御熱心にて、自ら七寺（四天王寺、法隆寺、中宮寺、橘寺、蜂丘寺、池後寺、葛城寺）を建立せられた外、諸国にも寺院の配在を奨励せられたのは、国家鎮護の役目とともに、庶民をして和恭の心を発得せしめん御心よりであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心よりか形だけを代えました青道心でございます。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大佐は沈重なる聲で『左樣、私は君を確信します、若し君は我等の同志の士として、永久に此の秘密を守る事を約束し玉はゞ、請ふ誠心より三度天に誓はれよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを拒もうとする羞恥心よりも、何かにすがりつきたいという本能の方が強いというのが、女の本性であることを、小沢は知っていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本能の如何に義務心より強いかを証明するに足るべき有力な出来事である。",
              "citation": {
                "source": "文芸とヒロイツク",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にやら花も散つて、自分の焦る心より先に季節が先走りするのが、ひし／＼と桂子に感じられた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑜伽論にも『出世ノ名声ハ譬ヘバ血ヲ以テ血ヲ洗フガ如シ』とございまするやうに、この名誉心といふものは、金を欲しがる心よりも、さらに醜く奇怪にして、まことにやり切れぬものでござりました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、これらのお慈悲、ひねこびた倒錯の愛情、無意識の女々しき復讐心より発するものと知れ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源信の方が寂心よりは少し年が劣って居たかも知らぬが、何にせよ幼きより叡山の慈慧に就いて励精刻苦して学び、顕密｜双修、行解並列の恐ろしい傑物であった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "定基は其の傍に昼も居た、夜も臥して、やるせない思いに、吾が身の取置きも吾が心よりとは無く、ただ恍惚杳渺と時を過した。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の飢渇に忍びざるの心よりして人の飢渇を救ふのは、即ち人の禽獸と異なる所以のものを發揮したので、是の如き人類の情懷の積り累なりて、人類の社會は今日の如く成立つて居るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば疾病の爲に、大なり小なり、長い間なり短い間なり、人類が或る影響を受くるのが、通常有勝の事である以上は、疾病と云ふ事に就て多少の考量思慮を費すのは、疑心より生じたる暗鬼に就て、思慮考量を費すが如きことでは無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "轉地、湯治、海水浴等は、其の土地状態、温泉成分、海潮刺激等が有效なるのみならず、新境の現前といふことが、直ちに人の外境に對する對抗應變の自然の作用を開始せしめて、そして其の爲に張る氣を致さしめ、其の張る氣の生ずると同時に疾病や疲憊をして吾が身心より去るを致さしむるのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地宇宙に其の心とか非器分とかいふものの存するを認めること、吾人の心より非器とかいふものを認むるが如くには、吾人に近證親覺が無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "見つゝ思はず悚然として、いしくも咲いたり、可愛き花、薊、鬼百合の猛くんば、我が言に憤りもせめ、姿形のしをらしさにつけ、汝優しき心より、百年の齢を捧げて、一朝の盛を見するならずや、いかばかり、我を怨みなんと、あはれさ言ふべくもあらず。",
              "citation": {
                "source": "草あやめ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「未墾地」のネシユダノフがロココ趣味の老夫婦が家に入る時の心より更に不思議な情調に捉へられた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今私の心より君に望む所の一つは、ただ、君がいつまで經つても自己に忠實なる人であらむことである、何事をなすにも先づ自己に聽き、何事を言ふにも、はた歌ふにも先づ自己に聽かむことである。",
              "citation": {
                "source": "歌集「嘲笑」序文",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは濶達で派手な庭の中心よりこの部分を一層好きになりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃物の乞食の中から花田は、わたくしを倶楽部の娘に拾い上げたように、この町の乞食の、子持ちのお三も、タガメも、たんばも、瀬戸勘も、髭の兵庫島も――みな、それ／″＼拾い上げて花田と啓司の指図の何かしらの職持ちになったのは、二人の慈善心より、より多く市に人手｜払底のためでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "教室に慣れ候に從がつて心よりも形を教へたく相成る傾き有之、以後も御注意願上候。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は心より畏れ、妻は心より淫る。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は右の二件を難じたるものにあらず、余が今日の文学の為に、聊か真理を愛するの心より、知交を辱うする愛山君の所説を難じたるは、豈に虚空なる自負自傲の念よりするものならんや。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して数百数千の細流は其中心より出でゝ金環を周綴し、而して又た再び其の金環より中心に帰注するものなり。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれみをものに施すこころよりほかに仏の姿やはある　で、あわれみを施す慈悲の心こそ菩薩のこころです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
