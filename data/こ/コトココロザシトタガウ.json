        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "時局収拾のため合体尊攘即行に望をかけた水戸派および肥後守のたてまえをそのまま表現したものだが、いつまで経っても事志と違うにつれて、芹沢派はいよいよただの乱暴者に還ってしまった。",
              "citation": {
                "source": "新撰組",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "自ら顧るときは不徳｜※才事志と違うこと多しと雖、而も寸善を積みて止まざるときは、何れの日｜乎必成の期あるべきを信ずる事深し。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "事志と違うために」と、答えた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
