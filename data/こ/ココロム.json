    "definitions": [
      {
        "index": 1,
        "gloss": "to attempt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ物理学上の立場より卑近なる考察を試むべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方においては統計的にいわゆる第二次原因の分析を試むるも有益なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は遂に一口を試むるの勇気もなかった十四日　暖かであるから出産牛のあと消毒を行わせた。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や漸く、我々の時代の詩壇が、これの正當な評價を試むべき時期ではないか。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさえたるわが手には血の色つかぬに、燈にすかす指のなかの紅なるは、人の血の染みたる色にはあらず、訝しく撫で試むる掌のその血汐にはぬれもこそせね、こころづきて見定むれば、かいやりし夜のものあらわになりて、すずしの絹をすきて見ゆるその膚にまといたまいし紅の色なりける。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "デイアボロス、ベリアル、ベルゼブル、悪鬼の首、この世の君、この世の神、訴うるもの、試むる者、悪しき者、人殺、虚偽の父、亡す者、敵、大なる竜、古き蛇、等である。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾時幼君おほせには、「汝が獻立せし料理なれば、嘸甘からむ、予も此處にて試むべし」とて御箸を取らせ給へば、恐る／＼「御料理下さる段、冥加身に餘り候へども、此中にて給はる儀は、平に御免下されたし」と侘しげに申上ぐれば、幼君、「何も慰なり、辭退せず、其中にて相伴せよ」と斷つての仰。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややありて泰助は、表門の方に出で、玄関に立向い、戸を推して試むれば、固く内より鎖して開かず。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巷の風説に耳を聳て、道｜行く人にもそれとはなく問試むれど手懸り無し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と最後の運命に問い試む。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ二目三目より、本因坊膏汗を流し、額に湯煙を立てながら、得たる祕法を試むるに、僅少十餘子を盤に布くや、忽ち敗けたり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさへたるわが手には血の色つかぬに、燈にすかす指のなかの紅なるは、人の血の染みたる色にはあらず、訝しく撫で試むる掌のその血汐にはぬれもこそせね、こころづきて見定むれば、かいやりし夜のものあらはになりて、すずしの絹をすきて見ゆるその膚にまとひたまひし紅の色なりける。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其去つて暫時來らざる間を窺うて、老若爭うて散策野遊を試む。",
              "citation": {
                "source": "蛇くひ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其日の中に逃帰らむかと已に心を決せしが、さりとては余り本意無し、今夜一夜辛抱して、もし再び昨夜の如く婦人の来ることもあらば度胸を据ゑて其の容貌と其姿態とを観察せむ、あはよくば勇を震ひて言葉を交し試むべきなり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、恰もかの法廷に於ける罪人が、自己に不利益なる證據物に對しては全然關知せざるものの如く裝ひ、或は虚構の言を以て自己の罪を否定せむと試むるが如く、その矛盾極まる主戰論を支持せむが爲には、トルストイ翁が如何に酷烈にその論敵を取り扱ふ人であるかの事實さへも曲庇して省りみなかつたのである。",
              "citation": {
                "source": "トルストイ翁論文",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　何をか試むる、と怪んで、身を起し汀に立つて、枯蘆の茎越に、濠の面を瞻めた雪枝は、浮脂の上に、明かに自他の優劣の刻み着けられたのを悟得て、思はず……『はつ、』と歎息した。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに近頃吾人を評難する者あり、吾人「文学界」の一団を以て、ライフに関する、すべての事を軽んずる者の様に言ひ做して、頻に攻撃を試むると覚えたり。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに世間には「人生」といふ字の誤り易きところから、往々にして吾人を以て、ライフといふものを軽んずる者の如く認めて、気早なる攻撃を試むる者あり。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は如何に禅僧の如くに悟つてのけんと試むるとも、我が心宮を観ずること甚深なればなるほど、我は到底悟つてのけること能はざるを知る、風流の道も我を誘惑する事こそあれ、我をして心魂を委ねて、趣味と称する魔力に妖魅せらるゝに甘んぜしめず。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ第三のそれであって、すなわち信仰を試むるために下る苦難である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに信仰を試むるための苦難の襲来は予示されているのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あだかも好しこの理不尽ぞ彼が愛の力を試むるに足るなる。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "晋の司馬休、敵に殺さるべきを一向気付かず、その馬食事をやめて鞍に注目するを見て乗り試むるとすなわち急に十里｜奔り、後を見れば収兵至った、かくて難を免れた酬いにその馬に揚武と加号した。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃わが邦へ渡ったかの国人が、奥羽地方で合歓木をかかる難地へ植えて砂防を完成すると聞き、帰国の上官へ告げて試むると果して竣功したという。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "予欧州にあった日、大高名の学者と伴れて停車場へ急ぐ途中種々の事を問い試むるにその返答は実に詰まらぬものばかりだった。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩に至って果核水食の類を与え試むるに皆飲食せず、さてはと人を走らせ覗うとこの客果していまだ行かず、帰り報ずると、呉、猴を打ち殺ししまったと出づ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗に陰嚢の垂れたるは落ち着いた徴で、昔武士が戦場で自分の剛臆を試むるに陰嚢を探って垂れ居るか縮み上ったかを検したというが、パッチ股引ジャあるまいし甲冑を著て容易く探り得ただろうか。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "由って掘り試むるに、銀あって中に夥しく金を裹めり、その銀数片を夢判じにやると、銀より金が欲しい思し召しから、卵黄の方も少々戴きたいものだと言うたそうな。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝えいう東方朔、漢の武帝に語り、これを試むるに験あり（『博物志』四）といえるは、蚤く守宮の名あるについて、かかる解釈を捏造したのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その時が日本の驥足を伸ぶべき時、自分が一世一代の飛躍を試むべき時だ」と畑水練の気焔を良く挙げたもんだ。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
