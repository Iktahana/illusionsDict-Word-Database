[
  {
    "uuid": "26c3eb0a-6f5e-5944-bd4c-6ed7a9e8ab47",
    "entry": "公文",
    "reading": {
      "primary": "こうぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
