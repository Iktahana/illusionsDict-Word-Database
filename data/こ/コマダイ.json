    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Komazawa University (abbr)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「駒大の選手たちは、どんなに苦しい場面でも決して諦めない強さがある」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "駒大の付属高校から、そのまま推薦で大学に進学することに決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日は駒大の近くの喫茶店で、友人と待ち合わせをしているんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "毅堂の新に居を卜した竹町四番地の家は旧｜寄合生駒大内蔵の邸内に祀られた金毘羅神社とその練塀を連ねた角屋敷で、旧幕府｜作事方の役人が住んでいた屋敷であったということである。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
