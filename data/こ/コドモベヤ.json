        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "引っ越しを機に、子供部屋の壁紙を張り替えることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子ども部屋は、子供が安心して過ごせるような空間にしたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の部屋は、まるで秘密基地のような子供部屋だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "乳母と主人はふたり子ども部屋に駆け込みました。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶がすむと、みんなはそろって子ども部屋へひきあげた。",
              "citation": {
                "source": "少年たち",
                "author": "МАЛЬЧИКИ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは、ひどく心配そうな顔をして子ども部屋へかけこみ、こうたずねた。",
              "citation": {
                "source": "少年たち",
                "author": "МАЛЬЧИКИ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度など、彼は子ども部屋の聖像の前に立ちどまって十字を切り、こんなことを言いさえした。",
              "citation": {
                "source": "少年たち",
                "author": "МАЛЬЧИКИ",
                "note": "青空文庫"
              }
            },
            {
              "text": "子ども部屋をゆかいなさわぎ声で、その心の奥の奥を、安らかな幸せでいっぱいにしてほしいんです！",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "にせものの光子さんと、銀一君は、一階の子ども部屋の窓から、庭をながめていました。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ただ残るものは君命を違背したわしの罪があるのみ」　半右衛門は黙然とそこを退って彼方の子ども部屋の方へ足を運んで行った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどもべやは　ひともなく　ひっそり。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどもべやに　だれも　いないことを　たしかめると、　おもいきって　せきたんいれの　したに　しいてある　オイルクロスに　とびおります。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネズミたちが　あなに　とんでかえると、　おにんぎょうたちが　こどもべやに　かえってきました。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
