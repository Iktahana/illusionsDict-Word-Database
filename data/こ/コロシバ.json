    "definitions": [
      {
        "index": 1,
        "gloss": "murder scene (in kabuki, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
