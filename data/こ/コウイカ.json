          "literary": [
            {
              "text": "「まるで生きものだね、ふーム、物事は万事こういかなくっちゃ……」　その感じから想像に生れて来る、端的で速力的な世界は、彼女に自分のして来た生涯を顧みさせた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるで生きものだね、ふーむ、物事は万事こういかなくっちゃ……」　その感じから想像に生れて来る、端的で速力的な世界は、彼女に自分のして来た生涯を顧みさせた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやもうこれが当然で、こういかなければおもしろくない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういかなくっちゃならない。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういかなければならない筈だ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世は万事がこういかなければいけない」「何も私だって争いたくはないよ。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋の口説に限って、こういかないのが残念である。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういかなければいけません！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういかなければいけません。",
              "citation": {
