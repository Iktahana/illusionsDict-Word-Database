          "standard": [
            {
              "text": "天文学者は、恒星表を参照して新しく発見された天体の位置を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ヒッパルコスが作成した古代の恒星表は、当時の観測精度の高さを示している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コンピュータ化された現代の恒星表には、数億個もの星のデータが記録されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "第八・九・十・及び第十一図四つの星座図――蛇遣い、大熊、オリオン、龍――アル・スフィの恒星表による。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後間もなくブラドリー（Bradley 一六九二―一七六二年）が従来には類のない精密な恒星表を編成した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            }
          ]
