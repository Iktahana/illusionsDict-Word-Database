        "examples": {
          "standard": [
            {
              "text": "満月の夜、皓月が空に輝き、あたりを幻想的に照らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中秋の名月、湖面に映る皓月の美しさに息をのんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "詩人は、夜空の皓月を見上げながら静かに筆を走らせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "谷あいの小径は、そうしてよもの山々は、すでに皓月の下にくっきりと照らしだされているのであった。",
              "citation": {
                "source": "紫大納言",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天も、神も、皓月も、また悪鬼も、この怖ろしい無道を、よく見ているがいい。",
              "citation": {
                "source": "紫大納言",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "暈さえもない皓月をふり仰ぎながら、それに向って、声一杯訴えたい切なさが、胸をさき、あふれでようとするのであった。",
              "citation": {
                "source": "紫大納言",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
