[
  {
    "uuid": "5c735038-9bc3-5e37-b1cd-336300f5f2e0",
    "entry": "顧慮",
    "reading": {
      "primary": "こりょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
