      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "concern",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "故に、生活を、殊には虚栄を、顧慮する限りに於て衰褪する底の、呆然見とれてゐる世界のことである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまた、審査する方が濫造の世評を顧慮して審査の標準を高め、上記の比率を低下させるようにするかも知れない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういう僻説を少しも修飾することなしにそのままに記録するということが、かえって賢明なる本講座の読者にとってはまた特殊の興味があるかと思うので、なんら他を顧慮することなくして、年来の所見をきわめて露骨に、しかも無秩序に羅列したまでである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　べつにいいところでも無いけれど、そこだったら、まえにもしばしば行っているのだから、私がこんな異様な風態をしていても怪しまれる事は無いであろうし、少しはお勘定を足りなくしても、この次、という便利もあるし、それに女給もいない酒だけの店なのだから、身なりの顧慮も要らないだろうと思ったのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の不幸や、零落につけこんで、その秘密まで聞こうとするのは、決して心あるもののすることでないとは承知しながらも、彼に二度まで遇い、その遇うた場所と趣とが少からず自分を動かしたために、それらを顧慮することができなかったのである。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでともかくも、全く顧慮なしにいつでも来かかった最初の電車に飛び乗る人にとっては、すいたのにうまく行き会う機会が少なくて、込んだのに乗る機会が著しく多い。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "連歌に始まり俳諧に定まった式目のいろいろの規則は和声学上の規則と類似したもので、陪音の調和問題から付け心の不即不離の要求が生じ、楽章としての運動の変化を求めるために打ち越しが顧慮され去り嫌い差合の法式が定められ、人情の句の継続が戒められる。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな顧慮や思いやりが結局何になる。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その得意さうな笑声を俺がどんな邪み根性で聞いて居たかと云ふことは、彼の顧慮する所では勿論ないらしかつた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "挨拶を受けた相手の名誉を顧慮しているのである。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも冷たく忍従して、そのくせ、やるとなったら、世間を顧慮せずやりのける。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子を女として少しも顧慮されない自分を、急に魅力のない卑しいものに感じて、弟に対して感じてゐるふだんの心の底の寂しさを一層深めた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや顧慮する母親達も無いので二人は故郷に帰つて本性を明すの冒険をも試みようとするのかもしれません。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、メリメにしろ、ゴオゴリにしろ、――また、いま、ふと頗る唐突に思い浮んだのであるが、シャトオブリアン、パスカルほどの大人物でも、――どのように、その時代の世評を顧慮し、人しれぬ悪戦苦闘をつづけたことか、私はそれに気がつき、涙ぐましくさえなるのだ。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの築城の大家は、城の設計にあたって、その城の廃墟になったときの姿を、最も顧慮して図をひいた。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の心の醜さと、肉体の貧しさと、それから、地主の家に生れて労せずして様々の権利を取得していることへの気おくれが、それらに就いての過度の顧慮が、この男の自我を、散々に殴打し、足蹶にした。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時のジャアナリズムが、政府の方針を顧慮し過ぎて、自分の小説の発表を拒否する事が、もし万一あったとしても、自分は黙って書いて行きます。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲の思惑を少しも顧慮せず、それこそ、ずっかずっか足音高く遊びます。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「支那南北記」や「大同石佛寺」のうちに植物の事を顧慮することの出來たのは、洵に是人のお蔭である。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の蒙つた強大なる刺戟は、彼等をして何の顧慮もなく平時の虚禮の一切を捨てさせた。",
              "citation": {
                "source": "所謂今度の事",
                "author": "林中の鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義者は明確なる反省を以て、今、其の最初の主張と文藝の本性とを顧慮すべきである。",
              "citation": {
                "source": "硝子窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にこの恐怖の吾人に要求する所は、躊躇にあらず、顧慮に非ず、因循に非ず、退嬰に非ず、自失の予感に非ず、小成の満足に非ずして、実に完全なる努力の充実を促がすの戒心なり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧慮する勿れ、因循なる勿れ、姑息なる勿れ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『今般帷子小路の四畳半より加賀野｜川原町四番戸に転居｜仕候』と云ふ知人への知らせの端書に何の事はなけれど、然もこの表面は何の事もなき変化が、やがて人生と云ふ大走馬燈の一齣々々を成し行くものなるを思へば、我は実に其変化の内容に重大の意義あり、活動あり、目的あるの事実を驚嘆し、顧慮せずんばあらず。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮坂は彼が熱心になるときの子供のように顧慮しない性癖を丸出しにして老文豪の八ツ手の葉のような扁平な開いた手をつまんで地図を見るように覗き込んだ。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "KUKKUTA　　（梵）　　COCK　　　　（英）　最後に注意すべきは語原の穿鑿上、諸方の言語の同系異系を顧慮することを要する一事なり。",
              "citation": {
                "source": "「言語の起原」附記",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは、こんな事を言い出してはますます若い者に嗤われることを知って、自ら抑えるようにしているのだが、病気のためにそんな顧慮も忘れてしまったらしい。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ南洋の官吏でゐながら、まるで方面違ひの、おまけに極く新米の私は、そんな事に全然無知だつたので、少し訊ねて見たかつたのだが、相手の機嫌を幾らか損じたらしい際でもあり、傍にゐる島民巡警への顧慮も手傳つて、それは控へることにした。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうちんとばっかしだが、こりょおめえに預けとく。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
