    },
    "definitions": [
      {
        "index": 1,
        "gloss": "strainer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……性質はよさそうだけれど、すこし器量がよくなくってとか。",
              "citation": {
                "source": "三つの挿話",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "話がたまたま被害民三千人の出京のことに及んで、隣席の西郷従道が微笑をふくみながら、「このあいだの仕事はありゃすこし器用すぎる。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きくなれば、もうすこしきれいにもなりましょうし、時がたてば、小さくもなりますでしょう。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "マタンは、もたせた車の輪のこしきの上に、よじのぼりました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとな、坊」　男の人は、少年がそばにくると、すこしきまりのわるいような顔をしていった。",
              "citation": {
                "source": "うた時計",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お二人とも、何時も仲の好いお朋友がどうしたのですよ、おかしいじゃありませんか、私に話してくださいよ、ぜんたいどうしたのですよ」　益雄はそう云われるとすこしきまりがわるかった。",
              "citation": {
                "source": "草藪の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくさんの蛇がうず高く盛りあがって大きい輪をつくっているのは蛇こしきとかいって、そのなかには、珍らしい玉がかくれていると、昔の人たちは云ったものです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しくも唯ひとり、唯ひとり、きのままに、棺のうち、唯ひとり、唯ひとり、のこしきて、朝まだき、はなやかに、はなやかに、うちつれて、歌ふやう「時くれば、時くれば、ゆくみちぞ、このをとめ、みまかりぬ、みまかりぬ、戀やみに。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしき善法ありて堅固なることをえん、と。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "善本徳本の真門に廻入して、ひとへに難思往生の心をおこしき。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "御奉行様御おぼえもめでたく、あまりにしたしくなし下され、同行のてまへすこしきのどくなるくらゐに御坐候よし。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまりにしたしくなし下され、同行のてまへすこしきのどくなるくらゐに御坐候よし。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャックは、いったいどこまで行くのかとおもって、すこしきみがわるくなりました。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下第一おふあらくれ先生を初めたてまつり、きくめ石の御君ニもよろしく、むバにもすこしきくめいしの下女とくますやへいてをりたにしざいごのこんやのむすめにもよろしく、そして平井の収次郎ハ誠にむごい／＼。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月二十九日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややこしき漫筆　近頃あの銀行はややこしいといえば、よほど内容が危険でいつ休業するかわからないから、今のうちに預けてあるものなら早く取り出しなさいということまでも含まれているところの複雑な言葉である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしく、すこしきをあやまりだ、と、排してしまふのはよくはあるまい。",
              "citation": {
                "source": "わかしとおゆと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの方は丁ねいに、あとから面倒になったんですこしきたなくなってしまったけれども誰が見るもんでもないからと思ってまに合わして置く。",
              "citation": {
                "source": "日記",
                "author": "一九一三年（大正二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わっはっはっ」「えへへへへへ」　と、青江三空曹は、すこしきまりわるそうに笑いました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くねたまえ」　そこで春夫少年は、すこしきゅうくつですが、防毒面をかぶったまま、きかいときかいの間に毛布をしいて、その中にもぐりこみました。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の中でも兄さん顔の次郎なぞは、五分刈りであった髪を長めに延ばして、紺飛白の筒袖を袂に改めた――それもすこしきまりの悪そうに。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）もっとも私の見方は、すこしきびしすぎるかもしれない。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすこしきれいな言ひ方をすると、それは姉さまの幸福を傷つけたくないといふ気持――そんなふうにも言へるのかも知れません。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も薄情な罪つくりだな」女はすこしきっとなった。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その前にすこしききてえことがある。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すこしきいてもらいたい話があるんだが、そんなことをしてる時間もないな」　山瀬は口を動かしながら、「かまやせん。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　森川夫人は弱りきった心をおしかくそうとするように、すこしきつい口調になって、「あたし、あまりあなたを甘やかしすぎたようね。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐伯氏は、両膝を抱いて、ゆるゆると身体をゆすりながら、「こんな話は、お聞きになりたくもないでしょうが、でも、我慢して、もうすこしきいてください。",
              "citation": {
                "source": "キャラコさん",
                "author": "蘆と木笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじや、すこしきゆうくつだけれど、お隣りへヒデ子ちやんのおふとん敷きましようか」　と、康子は、中園に笑いかけながら、譲歩した。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "おえはわたしたちのことばがわからないのだから、はじめはすこしきまりが悪いかもしれないが、じきにイギリス語を覚えて、兄弟たちと話ができるようになるだろう。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると祖父はわたしたちの一人がイギリス語を話したので、すこしきげんを直したように見えた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
