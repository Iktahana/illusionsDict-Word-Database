    "definitions": [
      {
        "index": 1,
        "gloss": "to row up to (e.g. a ship)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども葉ッパを見つけて漕ぎ寄せるうちには、もう沈んでいる。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "シトカで買い入れた丸木舟はつまりはお前らが奥蝦夷の岸まで漕ぎ寄せるためのものであるといい、「難船の人を救いとった上は、その者らが、本国の土を踏むところまで見届けるのが、われらの義務である」といい添えた。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見た源氏の侍、渡辺源五｜馬允が小舟を漕ぎ寄せると、門院の髪を熊手に引っ掛けて引きあげた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "閏十月一日、水島の瀬戸目指して漕ぎ寄せる一艘の小舟がある。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろからは伊三松の船、向うからはガラツ八の船が、これは灯を滅茶々々に點けて、篝船ほど川面を照し乍ら、「御用ツ」「神妙にせい」　と漕ぎ寄せるので、その人數はざつと二三十人。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "双生兒の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろからは伊三松の船、向うからガラッ八の船が、これは灯を滅茶滅茶に点けて、篝船ほど川面を照らしながら、「御用ッ」「神妙にせい」　と漕ぎ寄せるので、その人数はざっと二三十人。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "双生児の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで米友は、程近いところへ漕ぎ寄せると共に、いっちかばっちか、舟から飛び上って、そうして、何はともあれ、まっしぐらに右の垂綸の浪人の座元まで走せつけて行ったものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原の砂利に腰をおろして待っているとはるかな向うぎしに灯のちらちらしている橋本の町から船がその洲へ漕ぎ寄せる、と、客は船を乗り捨てて、洲を横ぎって、こちら側の船の着いている汀まで歩いて来る。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなたの岸へ漕ぎ寄せるや否、「乗り給え。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "桟橋へあやしげな小船をこぎよせる者があるから見ていると盛装したシナ婦人が出て来た。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "林をではずれるとすぐ水で、そこまで木のえだがのびているみぎわちかく、帆をかけたまま、大きなふねをこぎよせることもできました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいわい、川の上には朝ぎりがもやもやとたちこめたので、うまく敵兵の目をくらまし、ぶじに中の島にこぎよせることができました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
