        "examples": {
          "standard": [
            {
              "text": "この山は針葉樹と広葉樹が適度に混ざり合った混合林で、多様な動植物が息づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "混合林を散策していると、季節によって異なる種類の木々が色づく様子を楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "災害に強い豊かな森を作るため、単一の植林ではなく混合林への再生が進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "野面は寂しく人気なく、落葉松、山榛の混合林が諸所に飛び飛びに立っているのが老人の歯が抜けたようだ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
