[
  {
    "uuid": "508bddbc-5330-53b1-a87b-35a919bf9fdb",
    "entry": "懇親",
    "reading": {
      "primary": "こんしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "friendship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "運動会の終了後は、賞と書いた胴巻きのある酒瓶を中心に、各区の集会所で一同持ち寄りの懇親会が開かれた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "周防山口の地方裁判所に父が奉職して居た時分、馬場金之助という碁客が居て、父と非常に懇親を結び、常に兄弟の如く往来して居たそうです。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "懇親の間柄とて案内もなく客間に通って見ると綾子と春子とがいるばかりであった。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし山男が来なかったら、仕方ないからみんなの懇親会ということにしようと、めいめい考えていました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうあとはおれたちの懇親会だ、と云うつもりでめいめい勝手にのんで勝手にたべました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全集の第三巻に「懇親会」という短篇がある。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに拠って見ると、かの「懇親会」なる小説は、ほとんど事実そのままと断じても大過ないかと思われる。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳善院は早くから政宗と懇親である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何卒了休禅坊御懇親の御縁に寄り、私の至情御汲取り下されまして、私めまで右品御戻しを御願い致しまする。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「英吉君には御懇親に預ります、早瀬｜主税と云うものです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭は町から町へ日を異にして準備される、さうして彼我の家庭を挙げて往来しては一夕の愉快なる団欒に美しい懇親の情を交すのである。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "築地の水交社に國風家懇親會の催しがあつた。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本県の壮士と玄洋社の壮士とが博多東中洲の青柳の二階で懇親会を開いた時に、熊本の壮士の首領で某という名高い強い男が、頭山の前に腰を卸して無理酒を強いようとした。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、準之助氏は、素直にうなずきながら、「しかし、今日は貴女が初めて来た晩だし、懇親の意味で、ここで一しょに食事をして頂いた方がよかったねえ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　納涼会　同じ年の夏、自由党員の納涼会を朝日川に催すこととなり、女子懇親会にも同遊を交渉し来りければ、元老女史竹内、津下の両女史と謀りてこれに応じ、同日夕刻より船を朝日川に泛ぶ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来東京に大阪に将た神戸に、妾は表面同志として重井と相伴い、演説会に懇親会に姿を並べつ、その交情日と共にいよいよ重なり行きぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　川上音二郎　これより先、大阪滞在中和歌山市有志の招待を得て、重井と同行する事に決し、畝下熊野（現代議士山口熊野）、小池平一郎、前川虎造の諸氏と共に同地に至り同所有志の発起に係る懇親会に臨みて、重井その他の演説あり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お亡れになった少弐は人情味のたっぷりとあるりっぱなお役人でしたからぜひ御懇親を願いたいと思いながら、こちらの尊敬心をお見せできなかったうちにお気の毒に死んでおしまいになったから、そのかわりに御遺族へ敬意を表しようと思って、奮発して、一所懸命になって、しいて参りました。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方閉會、續いて近所の料理屋の懇親會、それが果てゝもなほ別れかねて私の部屋まで十人ほどの人がついて來た。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方閉会、続いて近所の料理屋で懇親会、それが果ててもなお別れかねて私の宿屋まで十人ほどの人がついて来た。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は同級生の懇親会がある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が今夜ここへ寄って、懇親のために、一夕の歓をつくすのは、それ自身において愉快な事であるが、この懇親が単に社交上の意味ばかりでなく、それ以外に一種重要な影響を生じうると偶然ながら気がついたら自分は立ちたくなった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭は町から町へ日を異にして準備される、さうして彼我の家庭を擧げて往來しては一夕の愉快なる團欒に美くしい懇親の情を交すのである。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "年賀状は廃するつもりであったが、さりとて平生懇親にしている人々に対して全然無沙汰で打ち過ぎるのも何だか心苦しいので、震災後まだほんとうに一身一家の安定を得ないので歳末年始の礼を欠くことを葉書にしたためて、年内に発送することにした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "年賀状は廃するつもりであったが、さりとて平生懇親にしている人々に対して全然無沙汰で打過ぎるのも何だか心苦しいので、震災後まだほんとうに一身一家の安定を得ないので歳末年始の礼を欠くことを葉書にしたためて、年内に発送することにした。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれは皆新年官民懇親会に行くのヨ。",
              "citation": {
                "source": "初夢",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩九時に、学校時代の友人たちと日比谷のＳ楼で懇親会を催すことになっていたので、省線電車で駆けつけたのであります。",
              "citation": {
                "source": "玉振時計の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はちやうど附近の小學校の先生達の懇親會もあつて、私達の船が西海岸を※る時にはそれらの人達をも一緒に載せて行つたが、中途ですこし風が出て來たのと、船醉するものもあつたのとで、元來た濱邊をさして歸りを急いだのである。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝返りを打った途端に、右の手の傷がヒリリと痛んだために夢が破れた竜之助は、こんしんからの深い息をついて、痛む傷を押えようともせずに、見えない眼を見開きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
