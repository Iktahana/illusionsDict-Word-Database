        "examples": {
          "standard": [
            {
              "text": "物置になっている小屋裏に上がると、子供の頃の懐かしいおもちゃが出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "断熱材をしっかり入れることで、小屋裏の熱が部屋に伝わらないようにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小屋裏をリフォームして、自分専用の隠れ家的な書斎を作りたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その死骸は山番小屋裏の荒地に埋めてござりまする」と又鸚鵡石が人語を発した。",
              "citation": {
                "source": "丹那山の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、お駒ちゃんが、宝もののように大事にしている記憶であったが、そのために、木更津屋やこの小屋裏で日本一太郎とならんで寝ているときに、お駒ちゃんは夜中に眼が冴えて眠られないで困ることがあった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ちょうどそのとき、私は甚助の小屋裏の畑地に出ていた。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
