    "definitions": [
      {
        "index": 1,
        "gloss": "kind, careful, and thorough (of an explanation, advice, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
