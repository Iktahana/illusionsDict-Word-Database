        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水が豊富で土地に楮が植えられる関係から昔からこの界隈には手工業の和紙工場が在りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花楮白蛾眉の毛深い白の蛾は熊の翁を思はする。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "花楮黄鳥ねむる花楮、月は翁の面のうへ、鼓うてうておもしろく、春はふたたび、花楮。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『白い花鳥図』『月光の谿』『童話の月』『花楮』等の諸篇の中にさうしたものがある。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "花楮うたうたはただほのぼのとの、よいにほひでの、さいたばかしのはなのやうでの、しなのたかい、いきづかひでの、それはさびしいたましひのほほゑみでの、さうありたいとおもふがの、みなさまどうぢやの。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐中ノ楮墨ヲ探リテ予ト筆談ス。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は打ち連れて興娘の位牌を置いてある室へ往って、その前で楮銭を焚いたが、三人の眼には新しい涙が湧いていた。",
              "citation": {
                "source": "金鳳釵記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしが死んだ後に、家内の者が仏事をやって、しこたま紙銭を焚いたので、冥府の役人が感心して、それで送り還してくれたのだよ」　※は烏老のいうことを聞いて、馬鹿馬鹿しくもあったが、正直な男だけに、楮幣を焚いたがために貪欲漢を甦らしたということがぐっと癪に触った。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右眼が明を失ったのは九輯に差掛った頃からであるが、馬琴は著書の楮余に私事を洩らす事が少なくないに拘わらず、一眼だけを不自由した初期は愚か両眼共に視力を失ってしまってからも眼の事は一言もいわなかった。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "證票は強靱な楮紙から出來てゐて、印紙が貼つてあり、等級を現す數字が、青いゴム印でべつたり捺してある。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その旅客の迹に、貴い多くの小判が、外に積んだ楮のなかから、二三日たって発見せられた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "薮畳を控えた広い平地にある紙漉場の葭簀に、温かい日がさして、楮を浸すために盈々と湛えられた水が生暖かくぬるんでいた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は楮の煮らるる釜の下の火を見ながら、跪坐んで莨を喫っていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう楮のなかから小判の出て来る気遣もないからね」「真実だ」お島は鼻頭で笑った。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日かかって四十｜把の楮を漉くのは、普通｜一人前の極度の仕事であったが、おとらは働くとなると、それを八十把も漉くほどの働きものであった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日かかって四十把の楮を漉くのは、普通一人前の極度の仕事であったが、おとらは働くとなると、それを八十把も漉くほどの働きものであった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇書を獲た喜が楮表に溢れてゐて、其意気の旺なること病褥中の人の如くでは無い。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ自強して息まざらむと欲する意が楮表に溢れてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて心のみはやりて、こゝろならずも日をすぐせる内に、當時、楮幣洋銀の差大に起りて、備へつる腰纒は、思ひはかりし半ばかりとなり、幾程なく富田君も歸朝せられて、いよ／＼呆然たり、さてこそ、この願望は一睡妄想の夢とは醒めたれ。",
              "citation": {
                "source": "ことばのうみのおくがき",
                "author": "大槻文彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが子供のときから躾けというものによって自分を殺し切り、人の思惑や人の好みを察して酌取ることにだけ発達させられて来たわたしの心というものが何でこのポーズを見破らずには置こうぞ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でかの女がその社会の名手にならずに置こうぞ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心も軽き一葉船、風のまにまに散って行こうぞ』源兵衛『もうすっかり、気が落附きました。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どういう目に逢うても、兄弟離れ離れに相手にならずに、固まって行こうぞ」「うん」と権兵衛は言ったが、打ち解けた様子もない。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家にゆかりある者は、ここを去ってどこへ行こうぞ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ出てゆきゃ、出て行こうぞ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人妻に懸想してその夫をほろぼすほどの無道人に、誰が親しみ懐こうぞ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし心の底の恐ろしく物質的な葉子にどうしてこんな辛抱がいつまでも続こうぞ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が、都見物に行きたいのなら、明日にも連れて行こうぞ。",
              "citation": {
                "source": "三人兄弟",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "退こうぞ」　物見高く囲りに集って、なすところもなくわいわいと打ち騒いでいる群衆を押しのけながら、退屈男はのっそりと露払いの弥太一といった、その若者の傍らに歩みよりました。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞こうぞ、聞こうぞ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
