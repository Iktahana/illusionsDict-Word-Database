          "literary": [
            {
              "text": "「お前なんどは肥たご桶を叩いて甚句でもうたつてお出でなさりや善いのに。",
              "citation": {
                "source": "素描三題",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけても若殿の時之助には、足を一本叩き折って、肥たごへ投り込みたいほどの怨みがある」「黙れッ」　孫三郎は我慢がなり兼ねました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "紅筆願文",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が高荷を背負っていたために、馬が驚いて狂奔したというのを理由に、気の立っていた時之助は、怪我をして肥たごに落ちた女を見捨て、そのまま屋敷へ引揚げて来たのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "紅筆願文",
                "note": "青空文庫"
              }
            }
          ]
        }
