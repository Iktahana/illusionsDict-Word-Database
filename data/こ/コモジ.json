      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "kanji (as opposed to kana)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "漢字ばかりの古文字で書かれた古文書を解読するのは、至難の業だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は仮名混じりの現代文よりも、格式高い古文字の漢文を好んで読む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館には、石碑に刻まれた力強い古文字の拓本が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "起てる丘、伏したる谷、おほよそ眼に觸るゝもの、一つとして史册中の奇怪なる古文字にあらざるなし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　壁法の発見　一八八四年の夏、クレート島のハギオイ・デカ(Hagioi Deka)なるゴルチーン市の古址においてレートホイズ河から引いた水車溝の中に、偶然にも古文字の彫刻してある壁石が現われた。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　壁法の発見　一八八四年の夏、クレート島のハギオイ・デカ（Hagioi Deka）なるゴルチーン市の古址においてレートホイズ河から引いた水車溝の中に、偶然にも古文字の彫刻してある壁石が現われた。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこもかしこもじめじめしたもので、こゝにスキイヤアが、多勢泊ることもあるらしいが、無論都会人向きではない。",
              "citation": {
                "source": "霧ヶ峰から鷲ヶ峰へ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
