        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "麺を作るために、良質な「こ文字」を求めて市場を歩き回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
