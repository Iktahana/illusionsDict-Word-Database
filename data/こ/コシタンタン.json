[
  {
    "uuid": "2672177a-c50e-5d58-8d4c-d2a203919c5d",
    "entry": "虎視眈々",
    "reading": {
      "primary": "こしたんたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞-と",
