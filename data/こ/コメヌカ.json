        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "川では流しのウキ釣り、潮入りの池ならネリといつて米糠の団子で釣る。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「米糠三升持ったら何とかって昔の人はよくいったもんだ」と呟きながら彼は沼へ下りて行った。",
              "citation": {
                "source": "おびとき",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "食うに足るものはなにによらず、恐ろしいような値がつき、米糠、麦糠すら百文と、はねあがった。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "米糠や麦糠を湿して蒸す。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどきやる餌は、台所の不要野菜を細かく切るか、米糠がなければ、米のとぎ水の沈澱物、粉食のコボレ、牛乳ビンのゆすいだ水、粉ミルクなど……。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
