        "examples": {
          "standard": [
            {
              "text": "会議では、各自の意見を積極的にコミュニケートすることが求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ちゃんと自分の考えを相手にコミュニケートしないと、誤解が生まれるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業は、顧客に対して製品情報を分かりやすくコミュニケートすべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ずっと待っていたところから察するとよほど重要な用件があるんだろうが、残念ながら今日はどうしても君とコミュニケートすることができない。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が持っている不安をなくすため、私たちはおたがいに常にコミュニケートしあう。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（グレース・スリック、ジェファスン・エアプレーン）　すべてのロックンロール・バンドは、聞いたとたんに、いや、見たとたんに、なにかをコミュニケートする。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
