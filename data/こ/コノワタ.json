    "definitions": [
      {
        "index": 1,
        "gloss": "salted entrails of a sea cucumber",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
