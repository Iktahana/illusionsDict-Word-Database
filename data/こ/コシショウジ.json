    "definitions": [
      {
        "index": 1,
        "gloss": "shoji screen with a wooden panel in the bottom part",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
