        "examples": {
          "standard": [
            {
              "text": "子供の頃、ドイツの民話に出てくるコボルトという精霊の話を読んで怖かったのを覚えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ダンジョンズ＆ドラゴンズでは、コボルトはしばしば敵キャラクターとして登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家の地下に住み着いたコボルトが、いたずらを仕掛けてくるという物語を読んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "……この小児コボルト空に往交へば、野に蒼白のこの小児。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「水を喰べ、コボルト！",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼我が魂よ、コボルトの如く躍れ跳れ。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
