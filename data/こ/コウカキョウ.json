          "literary": [
            {
              "text": "心当たりの辻々を縫い歩いているうち、ようやく高架橋の畔りに、置き忘れられたようにポツンと立っている公衆電話函を見つけることができた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この高架橋を渡って、私ははだしで学校へ行った事を思い出す。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑らかに軽く地下や高架橋を辷って行く。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
