        "examples": {
          "standard": [
            {
              "text": "鉄道弘済会の売店は、かつて駅の風景になくてはならない存在だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "弘済会が主催する奨学金制度のおかげで、多くの学生が学業を継続できている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "福祉活動を支援するため、弘済会のチャリティイベントに寄付を行うことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "とうとう探しくたびれてしまったところ、ちょうどそのころ今里保育園の仕事に関係していた弘済会の保育部長の田所さんがこの話を聴いて、――というのは、谷口さんも当時今里保育園の仕事に関係していて田所さんと親しかったので、――これは警察に探してもらう方がよかろうと、府の警察部へ話してくれました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
