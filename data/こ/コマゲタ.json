    "definitions": [
      {
        "index": 1,
        "gloss": "low wooden clogs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
