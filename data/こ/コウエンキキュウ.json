          "standard": [
            {
              "text": "アレルギー反応が起きると、血液中の好塩基球が増加することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "好塩基球は、免疫反応において重要な役割を果たす細胞だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顕微鏡で血液を観察すると、好塩基球の存在が確認できた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "血液にはアルカリ性色素と親和性をもつ細胞（好塩基球）があり他の種類の細胞（好酸球）は酸性色素に親和性がありさらに他の種類の細胞（好中球）は中性色素と親和性があった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
