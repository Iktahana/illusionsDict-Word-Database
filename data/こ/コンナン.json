    },
    "definitions": [
      {
        "index": 1,
        "gloss": "such a thing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まあ、こんなんでしょうな。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何故、こんなんだらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何て圖々しいんでせうね」そうして半ば獨白のやうに「自分でこそ毎日のやうにやつてる癖に」「人間つて、みんなこんなんでせうか」「さあ」「それはさうとなかなか長いね」「どうでせう、あの態は」　喧嘩はすぐには止みませんでした。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなんですけど、寛げるかと思って、自分で縫って見たの。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「慶一、こんなんで、よかったか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなんなら俺でも這入りたいが。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあ、ヘェ、あてらうちにこんなん五匹いるわ」　それは普通の出目金で、真黒なのが、自分の黒さに間誤付いたように間を元気に動き廻っている。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、自分の荷物を出そうとして、ひとの子をやき殺しちゃあ寝ざめがよくないと思って、我慢してしまいましたが……それもいいがまあ貴女、その小僧が朝鮮人の子だって云うじゃあありませんか、私口惜しくって口惜しくって、こんなんなら放ぽり出してやればよかったと思ってね、傘一本、着換え一枚ありませんや。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛がって、自分の子を殺して仕舞う女はこんなんだろうと思うと、只無智と云う事のみが産む種々雑多のさい害のあまり大きいのを怖ろしがらずには居られなかった。",
              "citation": {
                "source": "黒馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日こんなんじゃ、あたし、どうしたら良いかしら。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなんやったら十姉妹でも飼うといたら！",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、よさこい節ってあるんでしょう」「ええ、こんなんですわ」とあなたは、悪戯ッ児のように、くるくる動く黒眼勝の、睫の長い瞳を、輝かせ、靨をよせて頬笑むと、袂を翻えし、かるく手拍子を打って『土佐は良いとこ、南を受けて、薩摩颪がそよそよと』と小声で歌いながら、ゆっくり、踊りだしました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの釣らうとするのはこんなんぢやない、決して。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手も足も出なくなるって言う言葉がありますが、こんなんだと思いますね。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなんなら、始めから何にもしなかった方がずっと、気が楽で愉しかったのよ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなんやったら、あの子の匂いを嗅ぎたいばっかりにフルーツポンチ一杯で利太郎から宝塚まわりを譲ってもらうんやなかった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、かれの呼吸が急にこんなんになった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろルナビゥムがなくては、どうすることも出来ませんよ」「その仕事は、なかなかこんなんだ。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいこんなんか百ぺん鯱っちょこ立ちしたって及ばない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、そろそろ〈だいこん〉はやめてやらなくてはかあいそうです」「だが〈だいこん〉といいだしたのはだいこんなんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてこんなんだらう。",
              "citation": {
                "source": "顏",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなんなら、もっと早くできてくれればよいのに、わるいお父さんだ。",
              "citation": {
                "source": "童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "欣二　酔うなんて言うなあ、こんなんじゃねえよ。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらあ、嬉しいな、こんなん欲しいと思いよった」　高子は嬉々として夫のもとへ帰っていった。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「きせちというものは正直なものですね」と女中がしらのおわきが云った、「ふんとに、八月にはいったとたんに、こんなんも涼しくなるんですもの、ばかみたようですわ」「正直なのか、ばかなのか」　おわきは燗徳利へ手を伸ばしかけて、「え」とけげんそうに振り向いた。",
              "citation": {
                "source": "滝口",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
