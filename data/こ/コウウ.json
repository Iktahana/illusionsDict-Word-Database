[
  {
    "uuid": "4c997550-61aa-5c43-9d72-c89ba818fce3",
    "entry": "航宇",
    "reading": {
      "primary": "こうう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
