        "examples": {
          "standard": [
            {
              "text": "原稿の校正が終わり、校正室からは安堵のため息が漏れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜遅くまで校正室の明かりがつき、締め切り前の緊迫感が伝わってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は校正室で、印刷前の最終チェックに集中していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "四階でエレヴェーターを降りると、エレヴェーターのすぐ前が改造の校正室だった。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこに……」「向うの部屋に罐詰中です」　教えられた部屋は硝子張りで、校正室から監視の眼が届くようになっていた。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "随いて行くと、校正室へはいるなり、「出来た！",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの校正室は風通りがよくていゝ気持ちに眠れるのです。",
              "citation": {
                "source": "編輯室より（一九一三年七月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "建坪の工合で、校正室は、社長室を抜けてでないと行けなかった。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "校正室では備えつけの筆がすっかり痛んでいる。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなら校正室のソフアの上に寝かして遣り給へ」と云つたのは、書肆であつた。",
              "citation": {
                "source": "板ばさみ",
                "author": "オイゲン・チリコフ　Evgenii Nikolaevich Chirikov",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
