        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "火を起こしてそれから僕は近所の乾物屋を探し、コンビーフと福神漬を買つて来た。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛肉の大和煮、コンビーフ、ウィンナソーセージ、オイルサーディン、シャケの水煮、桃やミカンやパイナプルといった果物類、オレンジジュース、コカコーラ、そういった缶詰がほとんどだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これって、馬肉入ってないだろうな」　と、広岡が最後のコンビーフをあけながら、ぶつぶついっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして、ビートルズとコンビーフが頭のなかで連続するんだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい、高志のコンビーフにケチをつけるなんて、めずらしい奴だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "各自の勉強机におかれているはずの、卓上ランプがふたつ、「壁」と「天井」のあいだから吊るされているので、いちおう、コンビーフと大和煮の区別はつくが、「平凡パンチ」のグラビアを見ても、乳首と目玉の区別がつくかは、さだかではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬肉抜きの馬肉入りコンビーフ」　と、広岡がコンビーフの缶をもちあげる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は、パラフィン紙にコンビーフをのせ、それをランプの台におき、ランプの先を折り曲げて至近距離に近づけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして数分ほうっておくと、温かいコンビーフが食べられる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "メグが心配すると、「だいじょうぶ、コンビーフも、じゃがいももある。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "この調子では今にトマトの寿司、コンビーフの寿司、サンドイッチの寿司、トンカツの寿司など、創意創作がむやみやたらと現われ、江戸前を誇った勇み肌の寿司屋など跡を絶たねばならなくなるだろう。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、犬のそばにあった、コンビーフのかかったご飯や、餅の残りなどがほしかったのです。",
              "citation": {
                "source": "からすとうさぎ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそう、いつかあなたを追いかけた犬までが、コンビーフのかかったご飯を食べていましたよ。",
              "citation": {
                "source": "からすとうさぎ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪人たちは、なにをたべているのか、わかりませんが、井上君には、パンやミルクやコンビーフなどを、たべさせてくれました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴、食堂へ、スクラムブルエグとコンビーフハッシュ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりこゝのオードヴル、キャベツのスープに、コンビーフキャベジとプディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
