[
  {
    "uuid": "6bb4a181-c9e5-51d6-9169-9a31962e1de2",
    "entry": "小楯",
    "reading": {
      "primary": "こだて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
