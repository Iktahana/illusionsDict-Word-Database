[
  {
    "uuid": "90376bab-574f-56e1-891f-a812ef1f4013",
    "entry": "籠もる",
    "reading": {
      "primary": "こもる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
