          "standard": [],
          "literary": [
            {
              "text": "』　小憎らしい程落ち着いた、冷靜な人だつたが、ちよつと興奮した聲でかう詞を結ぶと、その嬉しさの味のためには一生その仕事を止めないだらうと云ふ風に、彼は靜かな微笑を唇に浮べた。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラッパズボンの後襞が小憎らしい。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ふざけて、とぼけて、その癖何だか小憎らしい。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "予が見送ると目を見合せ、「小憎らしいねえ。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたもんだ、他人のこと使つて小憎らしいこと、そんなこと云ふとおつけて遣つから」おつぎは燻つた薪を兼博勞の近くへ出した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "対手は小憎らしいことにも馬上なのです。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも彼女は、髪は蓬々としてゐて、顔色は蒼黄色く、そして顔だちだつて頤が尖つて、眼も鼻も寧ろ小憎らしい程殺風景で見るからに貧相だつた。",
              "citation": {
                "source": "街角",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ただ何処にでも沢山いて、小憎らしい程卵を産んで、毎朝毎朝｜鬨の声を上げて、平凡主義を発揮するので、それで珍重されない迄さ。",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に小憎らしい父親の顔が髣髴としてきた。",
              "citation": {
                "source": "スプリングコート",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮見はそれが小憎らしいやうな気もした。",
              "citation": {
                "source": "チビの魂",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、文吾は母の前に片肱怒らして、小憎らしいことを言つた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "小憎らしいところ確にあり。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小憎らしい程うまいと思つた。",
              "citation": {
                "source": "貝殼追放",
                "author": "泉鏡花先生と里見※さん",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄昏の暗さに大槻の浴衣を着た後姿は小憎らしいほどあざやかに、細身の杖でプラットホームの木壇を叩いている。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "根性曲がりの悪垂れ小僧め、ほんとに小憎らしい小僧じゃアねえか！",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桀紂と云えば古来から悪人として通り者だが、二十世紀はこの桀紂で充満しているんだぜ、しかも文明の皮を厚く被ってるから小憎らしい」「皮ばかりで中味のない方がいいくらいなものかな。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ほんとに小憎らしい子だよ。",
              "citation": {
                "source": "シンデレラ",
                "author": "水谷まさる",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学だの芸術などゝ力むところのない、軽快な、小憎らしいゲームなのである。",
              "citation": {
                "source": "探偵小説とは",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう未成品のジロリは小憎らしいもので、衣子家飼いならしのよく吠えるフォックステリヤ、その程度のチンピラ小動物に心得て、かねて私の敬遠していた存在であった。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "威張つてゐる奴だ、生意気な奴だとか、小憎らしいと思はれるのが嫌だと思ふから、枉げて言ふ言葉と言ふものがあります。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふところが「劇作」のなんとなく小憎らしいところで、私などもつい遠慮がちになり、グループとして昂揚する精神のなかに自他ともに引入れられる若々しさがもうちつとあつてもいゝのではないかと、老婆心ながら、気を揉んでゐた次第である。",
              "citation": {
                "source": "劇作と私",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりパキパキした子ではないけれ共小憎らしいと云う様なところの一寸もない子であった。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、その時ふいに口を噤んで黙り込んだ老婆の奴は、又例の変な工合に唇を歪めて小憎らしい冷笑を浮べてゐるのではあるまいかと思はれたので、チラリと一瞥を呉れてみたら、思ひがけなく黄色い板のやうな顔付をして、まるで表情を失つたままヂッと一つところを凝視めてゐた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ気持であつたのだが、其の小憎らしい・冷笑らしい顔付を見たら、つい、いまいましい気分になつて、別に言ひたいのでもないが自然に大人振つた呟きを浴せてしまつた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのものに対して、秋子が全身を挙げて奉仕してることが、彼にとっては、秋子をいつまでも掌に握りしめていたいだけに、小憎らしいほど秋子が可愛いいだけに、一層気持を脅かされる種となった。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "またしても、明智のやつのおせっかいさ、それに、こにくらしいのは、あの小林という小僧だ。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
