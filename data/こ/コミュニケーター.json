        "examples": {
          "standard": [
            {
              "text": "彼女は優れたコミュニケーターで、複雑な内容も分かりやすく伝えることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害時には、正確な情報を伝えるコミュニケーターの役割が非常に重要になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はチームと顧客の間を取り持つ、信頼できるコミュニケーターだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「名前を付けるとすればパーソナル・インテリジェント・コミュニケーターとでもなるんでしょうか」という開発中のマシンを、ビル・アトキンソンはマニュアルを読む気などもうとうないバアチャンだって、にっこり笑って一日中使ってくれるものにしたいという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
