[
  {
    "uuid": "1fdff81a-c6cb-5d76-947c-b85b420fc0d4",
    "entry": "後任",
    "reading": {
      "primary": "こうにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
