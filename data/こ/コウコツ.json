    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "貧乏のうちは硬骨なのが金持ちになって急に軟化するようにともかくも軟化しそうである。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "硬骨漢汲黯が退いた後は、帝を取巻くものは、佞臣にあらずんば酷吏であった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "片意地でさばけないところはあるにせよ、確かにまれに見る硬骨の士であることは疑いないと陵は思っていた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お隣りの「白鳥の間」には、前から硬骨漢がそろっていて、助手さんたちに人気のある固パンさんなどは、その「白鳥の間」にいたたまらなくなって、こちらの「桜の間」に逃げて来たような按配でもあったのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ならこんな専制的命令が行われるはずもなく、そういう場合学生は聯合して示威運動でもする処だが、当時の学生は尚だそういう政治運動をする考がなく、硬骨連が各自に思い思いに退校届を学校へ叩きつけて飛出してしまった。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴族院第一の硬骨と云われた唐沢が、あのザマだと、世間から嘲笑されることを考えておくれ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "或新聞紙は貴族院第一の硬骨を以て、称せらるゝ唐沢男爵に、そうした卑しい事のあるべき筈はないと、打消した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦令、それが娘自身の発意であるにしろ、男子として、殊に硬骨な父として、どんなに苦しい無念なことであろうかと思った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、詩歌の思想界を嘲るものは、その余りに狭陋にして硬骨なきを笑ふにあらずや。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "正義会には、私は度々入り度いと思つてゐたのでしたが、その部員が控所にビラを貼つたり、教室に演説に来るところを見ると、多くは如何にもその会員らしい硬骨漢ばかりで、柔弱さうな自分の様子を知つてゐる私は決心がつき兼ねたものでした。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴族院第一の硬骨と云はれた唐沢が、あのザマだと、世間から嘲笑されることを考へておくれ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "或新聞紙は貴族院第一の硬骨を以て、称せらるゝ唐沢男爵に、さうした卑しい事のあるべき筈はないと、打消した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦令、それが娘自身の発意であるにしろ、男子として、殊に硬骨な父として、どんなに苦しい無念なことであらうかと思つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉山氏は硬骨に、そういう態度に対する軽蔑をその文章の中で示しているのである。",
              "citation": {
                "source": "冬を越す蕾",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その人間どもの中で、少し硬骨でそして衆望のあるのが出ると、すぐにそれをパリへ留学させる。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは上級生の運動家で、男色家で、校内で一番幅を利かせていた野蛮な、横田という寮生を、吉本という通学生の硬骨漢が発頭になって、同級生一同とはかって校庭でリンチした事件であった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "累代の四臣と云われたところの馬場虎貞、山県虎清、工藤虎豊、内藤虎資、四人ながら手討ちになり、この他硬骨の士五十人、刀の錆となったのであった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡本さんや眞山さんといつた硬骨の人がなければ、作家へ對する態度は、もつと、傍若無人で惡い状態でつゞいたかもしれない。",
              "citation": {
                "source": "八歳の時の憤激",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五月二日）巴里のいろいろ　ル・バルヂイ氏は仏蘭西一の喜劇役者だが、硬骨な氏は去年の春舞台監督と衝突して即座に辞職を申出で、多勢の名士の仲裁も其効なく、昔女優サラ・ベルナアルが奮然辞職した以来の大悶着を惹起して居た。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからか命知らずの硬骨漢があらわれて躍りこむかも知れなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時までわが輩はおおいにこの政治家の人物を尊敬したが、このいわゆる強さを見て、「ハハア、かねて聞き及べる某の硬骨とはこのへんが程度かな。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと会っては虫も殺さぬような柔和な、ほとんど女のごとき人でも、だんだん交際ってみるにしたがい、なかなか硬骨で、一たび言い出すと決してあとへ退かぬ人もあるし、また外部から見るといかにも凛々しく、衣は骭に至り袖腕に至り、鬼とも組打ちしそうな風采をなしていても、内心柔和な女のような人を往々見受ける。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏がかつて心を宗教に寄せる前には、剛情で始末におえぬ硬骨漢であったが、ひとたび信者となってからは手を覆したごとく温和な柔順な、涙もろい人に変った。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの同じ人が自己のやわらかいことを仮りに他人を欺かんがために隠し、すなわち悪意をもって硬骨を衒ったならば、これ悪い意味における表裏の初段である。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭は古くて偏狭だったが、自分に信ずることは一歩もまげないという、清廉硬骨の老人だった。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、こんなことをわざわざ申しあげたくはございませんが、わたくしが貴族の出であるからして仲間入りはさせんとか、常田先生のやうな、これも一例でございますが、つまり硬骨漢をですな、漢文を教へてをられるから旧思想の持主だなどといふ論法はちとをかしい。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ今度の戦争の原因が、清国の国禁を英国商人が破り、広東で数万函の鴉片を輸入し――しかも堂々たる密輸入をしたのを、硬骨蛮勇の両広総督、林則徐が怒って英国領事、エリオットをはじめとして英国人の多数を、打尽して獄に投じたことなのだからね。",
              "citation": {
                "source": "鴉片を喫む美少年",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "化石として残るのは、たいてい硬骨部分の一部と、その他の部分のかすかな痕跡とである。",
              "citation": {
                "source": "イグアノドンの唄",
                "author": "――大人のための童話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概の気強い威丈夫な男連が、一生粉身砕骨しても別れられない夫婦関係を、萩原は美事に二度までやって退けたのは、よくよくの事情があるにしても彼自身のぐにゃぐにゃが、いかに硬骨のお偉ら方にくらべて大したぐにゃぐにゃであったかが判るのだ。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜子夫人のほうも、寛大で謙譲で、そのくせ、どこは硬骨のあるこのキャラコさんが大々のひいきで、進級祝いなどには、あッと眼を見はるような豪勢な祝品をかつぎ込んだりする。",
              "citation": {
                "source": "キャラコさん",
                "author": "ぬすびと",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
