[
  {
    "uuid": "4ba3f553-79a8-5dbf-92d5-c08d2a11f205",
    "entry": "言葉を交わす",
    "reading": {
      "primary": "ことばをかわす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-サ行"
      ],
