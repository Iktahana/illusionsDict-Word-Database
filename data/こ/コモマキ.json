        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬の風物詩として、庭園の松の木に害虫を越冬させるためのこも巻きが施された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「もうすぐ立冬だから、そろそろ公園の木々にこも巻きを準備する時期だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "こも巻きの中に集まった害虫は、春先にこもごと焼いて処分される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "名古屋では町屋川から阿下喜地方まで行ったが、どこもまき餌をする。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
