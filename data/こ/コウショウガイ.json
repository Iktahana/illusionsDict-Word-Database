[
  {
    "uuid": "a40eccf7-d8fe-55be-9b99-2d5d888dcf7c",
    "entry": "公生涯",
    "reading": {
      "primary": "こうしょうがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
