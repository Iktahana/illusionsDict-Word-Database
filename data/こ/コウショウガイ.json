      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "public life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は今日を以て私の何十年の公生涯を終ったのである。",
              "citation": {
                "source": "或教授の退職の辞",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "して、それと同じ興味と熱を以て政治的公生涯に邁進するに至つたのである。",
              "citation": {
                "source": "趣味としての読書",
                "author": "平田禿木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして此公生涯の裏面に、綱宗の気遣ふも無理ならぬ、暗黒なる事情が埋伏してゐた。",
              "citation": {
                "source": "椙原品",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して所謂勤向覚書が此年の二月に起藁せられてゐて、蘭軒の公生涯を知るべきギイドとなる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡船は自動車や電車に乗って馳せ廻る東京市民の公生涯とは多くの関係を持たない。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡船は自動車や電車に乗つて馳せ廻る東京市民の公生涯とは多くの関係を持たない。",
              "citation": {
                "source": "水　附渡船",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等列車の事とて風采だけは其れ相當にして居るが、私生涯と公生涯との差別を知らない國民の常とて、中にはもう大きな鼾を遠慮なく轟かせるものがある。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隈伯の公生涯に於て、其の歴史的價値の最も大なる部分二つあり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に於てか、伯が内より政治を改革せむとするの計畫は失敗に歸し、時代は伯を促がして國民と握手せしめ、以て伯の公生涯に分界線を劃したりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯は夢の如き理想を以て夢の如き公生涯に浮沈したに過ぎないのである。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ伊藤公爵も、大隈伯爵も、其の私生涯と公生涯とを問はず、均しく之れを公處の白堊光裡に展開して彼等の自由批評に任ずと雖も、山縣公爵に至ては、公私の生涯に截然たる分界あるが故に、其の私生涯は醇粹なる私生涯にして殆ど公衆と何の交渉する所なし。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隈伯の公生涯に於て、其の歴史的価値の最も大なる部分二つあり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に於てか、伯が内より政治を改革せむとするの計画は失敗に帰し、時代は伯を促がして国民と握手せしめ、以て伯の公生涯に分界線を劃したりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ伊藤公爵も、大隈伯爵も、其の私生涯と公生涯とを問はず、均しく之れを公処の白堊光裡に展開して彼等の自由批評に任ずと雖も、山県公爵に至ては、公私の生涯に截然たる分界あるが故に、其の私生涯は醇粋なる私生涯にして殆ど公衆と何の交渉する所なし。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "自家の経済よりもかえってこの方を苦に病んでいた彼が、公生涯の持続に絶対に必要なその百円を、月々保険会社から貰うようになったのは、当時の彼の心中に立入って考えて見ると、全く嬉しいに違なかった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十八年は、イエスの公生涯に対する重要な準備の期間であった。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点をたしかめておくことは、今後のイエスの公生涯にとりて絶対に必要なことであった。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら神の意思に己が意思を合致せしめ、神との愛の全き結合に生きることが神の子たる者の本性であるとするならば、公生涯の出発点において与えられたイエスの神の子たる自覚は、終生彼を欺かなかったと言える。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
