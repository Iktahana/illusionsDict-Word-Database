[
  {
    "uuid": "6cbbe399-118c-51da-8f78-7589ed1dfc82",
    "entry": "黒闇",
    "reading": {
      "primary": "こくあん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
