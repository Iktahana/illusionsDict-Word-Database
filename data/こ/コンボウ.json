[
  {
    "uuid": "a8d08f23-bcc7-59e8-934b-d3147f450c86",
    "entry": "混紡",
    "reading": {
      "primary": "こんぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mixed yarn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "殺人という緋色の糸が、現世という無色の綛糸に混紡されている。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手拭はスフ三分混紡で、今にこれでも珍しいものとなるわけですが、使って御覧になりましたか？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星兵は、どこにかくしもっていたか、先の太いこんぼうのようなものを、ほそながい手に、にぎって、蟻田博士たちをめがけて、おしよせて来た。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんぼうみたいなものを、ふりあげて来るところは、なかなかすさまじいものであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それというのが、火星兵のもっているこんぼうみたいな武器は、先生の酸素かぶとを、上から、うちくだいてしまうだろう。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭へ出ると、なんともえたいの知れない、まっ黒なばけものが立っていて、こんぼうをふっるて、したたかなぐりつけました。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずやってきたのが、こんぼうをかまえた１０まいの強者たち、すがた形は庭係３まいと同じで、ぺらぺらの長四角、角のところに手足がついててね。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずやってきたのが、こんぼうをかまえた１０まいの強者たち、すがた形は庭係３まいと同じで、長四角のぺらぺら、角のところに手足がついててね。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
