    "definitions": [
      {
        "index": 1,
        "gloss": "(this) small amount",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「これっぱかしのことで、死んでしまうなんて！",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、訓練がこれっぱかしもできてねえんだ。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし、しょっちゅう遊びに行ってお話ししているんですけれど、そんなところはこれっぱかしでも見えませんわ。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理アねえ、おれがこれっぱかしも疑らなかったほどのお人好しだからなア。",
              "citation": {
                "source": "生さぬ児",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか、これっぱかしの石ですがね……。",
              "citation": {
                "source": "必要以上のもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の事はこれっぱかしもしないで、人の事ばかり世話を焼いて、いつも懐中はピイ／＼の癖に大きな事ばかりいって、信造さんの懐中ばかり当にしてるんですよ。",
              "citation": {
                "source": "青服の男",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあなたに何一つ束縛は加えませんし、第一、いつまでも、あなたと云い、奥さんとよび、遊びは二人だけのこと、死に至るまで、これっぱかしも人に秘密をもらしは致しません。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "衒うことなんか、これっぱかしも出来そうにない人だわ。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕という職務にたずさわっており、しかも優しさだとか献身的な愛情をこれっぱかしも持っていない。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日はどうも、麻薬で失敗いたしましたが、あれなんかも、私自身は、これっぱかしも用いたことがございません。",
              "citation": {
                "source": "日月様",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁に耳あり徳利に口だぞ」「…………」　何をどう小勇の圓太がいったかしらないが、天地の神も照覧あれ、いつまあ私が師匠の悪口なんかこれっぱかしでもいったことだろう。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の癖に世帯の話や米の値なんか、これっぱかしも出ませんよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達の心のこれっぱかしも分らねえ奴で……」それから後は唐突な慟哭になる。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこれっぱかしもがまんできない。",
              "citation": {
                "source": "漁師とそのおかみさんの話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの後、あなたがお帰りになってから、何かの点に対して、なかなかどうもつじつまの合った答弁を始めたので、さすがのわたしも驚いたくらいですが、しかしこれっぱかしも本当にはしませんでした！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こっちは見えねえし、あけて置くのはむだだからねえ」爺やは付いて歩きながらおけいにそう云った、「――これっぱかしでも旦那や御新造さんのあがるくれえは作れるだから、それにおらあも手がすいてるだからよ」　おけいは来たときから吾平ととみの人柄をみていた。",
              "citation": {
                "source": "追いついた夢",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな高いところにぶらさがっているきさまらには、地面なんかはこれっぱかしも見えやしないんだ！",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、灰色ネズミたちはそんなことはこれっぱかしも考えてはいませんでした。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしぐらい年とってるものが、これっぱかしの災難でまいってたまるもんですか。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のすそには、荒らい海の波をふせいでくれるような陸地は、これっぱかしもありません。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂うのは虎の方ばっかり、然し、お前、どんなに大虎になったところで、翌日の仕事が、それで、これっぱかしも間に合わなかったということがないぜ。",
              "citation": {
                "source": "出家物語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　当時としては決してハシタ金ではなかったが、これっぱかしじゃ駄目だと俺が言うと、「素敵ねえ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "（c）わたしが始めにしたようにあんまりしばしば章を分けると、かえって読者の注意をそれが生れ出るに先んじて挫折するように思われたから、またその注意がこれっぱかしのものに専心し集中するにも当るまいとそのまま消えてなくなりそうにも思われたから、こんどは各章をずっと長くすることにした。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとは」「へン、これっぱかしの酒が何でえ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちもきざで鼻持ちがならないのみか、凄味というものが不足だから、これっぱかしのことを糺すにもこの騒ぎだ――と見ている態度だ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
