    "definitions": [
      {
        "index": 1,
        "gloss": "head of an organizational section",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
