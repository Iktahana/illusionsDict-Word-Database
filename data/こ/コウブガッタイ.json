[
  {
    "uuid": "aae72319-38db-5259-bdcb-70f7c4b7d78b",
    "entry": "公武合体",
    "reading": {
      "primary": "こうぶがったい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
