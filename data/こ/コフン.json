    "definitions": [
      {
        "index": 1,
        "gloss": "ancient burial mound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
