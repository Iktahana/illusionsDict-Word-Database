    "definitions": [
      {
        "index": 1,
        "gloss": "bradawl (woodworking tool)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
