[
  {
    "uuid": "d7a98b8b-6d53-53ca-b6be-c91efc5d5013",
    "entry": "光明",
    "reading": {
      "primary": "こうみょう",
      "alternatives": [
        "こうめい"
      ],
      "is_heteronym": false
    },
    "grammar": {
