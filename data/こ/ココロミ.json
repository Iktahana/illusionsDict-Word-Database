    "definitions": [
      {
        "index": 1,
        "gloss": "attempt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "試みに、呑気にブラブラしてみて下され。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてはＢ君、俺の金がツケメかな」とＡ君が試みに思ふとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は憤怒し、そして一つの超人的勇躍を試みた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとがひとの能力を試みるなんてことは、君、容易ならぬ無礼だからね」「そうです」「と言ってみただけのことさ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という下手な忠告を試みた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、彼は自分がかういふ場合修正しようとして試みると却て悪くなることを所謂、経験で知つてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（茲で証明を試みることは無暴である。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "では試みに、一度西欧もヘチマも全然忘れてみてはどうであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みにその「定評」の内容をあげて見よう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風馬堤曲は、蕪村の試みた一種の新しい長詩であって、後に紹介する如く、彼のポエジイの最も純粋な主題的表現である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むさしや」といふ家のはなれを借りて根合せならねど、あやめの歌合といふを試みけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みたとたんに、あなたの運命がちやんときめられてしまふのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生には試みなんて、存在しないんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は言うまでもないとして、三月四月頃、試みに郊外に出て見給え、遠くに碧い山か、斑らな雪の縞を入れて、菜の花の末、または青葉若葉の上に、浮ぶように横たわっている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ俺は行こうってんだ」　樫の盆見たいな顔を持った、セコンドメイトは、私と並んで、少し後れようと試みながら歩いていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長、機関長、を初めとして、水夫長、火夫長、から、便所掃除人、｜石炭運び、に至るまで、彼女はその最後の活動を試みるためには、外の船と同様にそれ等の役者を、必要とするのであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、火夫が、憐を乞うような眼で、そこら中を見廻しながら、そして、最後の反抗を試みながら、「勝手」に飛び込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちに追ひつかうと試みたが、駄目な事が分つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに御自分の両眼の間に新聞紙を拡げて前に突き出して左右の眼で外界を御覧になると御疑問が解決せられるのです。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御試みありたし、（下略）」　魚や鳥のように人間の両眼の視界がそれぞれに身体の左右の側の前後に拡がっていたとしたら吾人の空間観がどんなものになるかちょっと想像することが六ヶしいという意味のことを書いたのに対して、こういう実験をすすめられたのである。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして試みにその眼鏡を借りて掛けて見ると、眼界が急に明るくなるようで何となく爽やかな心持がした。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分らない問題を解く試みの方法として、私は今一つの実験を行ってみようとしている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立入った理論はぬきにして、試みにある一つの歌を一遍声を立てて、読み下した後に、今後は口をむっと力を入れてつぶって黙読してみるといい。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう事を完全に仕遂げる事はなかなか容易な事ではないが、そういう方向への第一歩として、私は試みに次のような事を考えてみた。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはもう誰か試みた人があるかも知れないと思われる。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七重の瀧の茶店で「燒饅頭」と貼札したものを試みに注文したら、丸いパンのやうなものに味噌※を塗つたものであつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の行詰まりを救ふサム・シングを世界中の爲政者や思想家やが試みてゐるが、此の利目は未だわからないやうである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは子供の時分に何か長く欲しがつて居た新しい玩具を手に入れて始めて其れを試みようとする時、或は何かの研究に手を付けて、始めて新しい結果の曙光が朧に見え始めた時に感じるのと同じやうなものであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに宅の蚊帳の目を数えてみたら一寸四方の中に平均九百ばかりの目がある。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが近頃この事について斬新な力学的の方面から説明を試みた人がある。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
