    "definitions": [
      {
        "index": 1,
        "gloss": "as stated",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうした彼の言葉通りに、現実の心配が迫って来た。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "広小路の松坂屋へはいって見ると歳末日曜の人出で言葉通り身動きの出来ない混雑である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在既知の科学的知識を少しの遺漏もなく知悉するという事が実際に言葉通りに可能であるかどうか。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁天の白露を帯びたこの花の本当の生きた姿が実に言葉通り紙面に躍動していたのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして上陸早々ホボケンの税関でこのチューインガムの税関吏のためにカバンを底の底まで真に言葉通り徹底的に引っくり返されたのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎに上野へ出掛けたが、美術館前の通りは自動車で言葉通りに閉塞されていた。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大噐氏は自然に叩頭をさせられて、その言葉通りになるよりほかはなかった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら大きな波が来てよ」　と沖の方を見ていた妹が少し怖そうな声でこういきなりいいましたので、私たちも思わずその方を見ると、妹の言葉通りに、これまでのとはかけはなれて大きな波が、両手をひろげるような恰好で押寄せて来るのでした。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は言葉通りに新たに甦って来る。",
              "citation": {
                "source": "北海道に就いての印象",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は、其處に、此の話をする按摩の背後に跪い居て、折から面を背けた婦が、衣服も、帶も、まさしく、歴然と、其の言葉通りに目に映つたためばかりではない。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言ふうちに、フト其の（おなごり）と云つたのが氣に成つて、此だと前方の言葉通り、何うやら何かがおなごりに成りさうだ、と思つて默つた。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ、別して酔った時は、幾度も画工さんが話したから、私たちはほとんどその言葉通りといってもいいほど覚えている。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚悟だから、その言葉通りには参らない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、これはその時の二人の言葉通りではない。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、青年の言葉通り、赤い煙突は再び煙を吐くことがなくなった。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は銀子を追究して真相をはっきりさせることも怖く、それかと言って商売人の銀子の言葉を言葉通りに受け容れることもできず、病院の仕事もろくろく手に着かないのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、――またその翌日の夕方になると、私は姉の後姿を窓から見送って、それからさて、れいの並木の方を眺め渡すのであったが、女はその言葉通りあの夜以来とんと姿を現わさなかった。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうところは、あたし敵わないと思うわ」　かの女は言葉通り尊敬の意を態度にも現わし、居住いを直すようにしていった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは賢秀の心を攬る為に云ったのでは無く、其翌年鶴千代丸に元服をさせて、信長の弾正忠の忠の字に因み、忠三郎｜秀賦と名乗らせて、真に其言葉通り婿にしたのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆歩に歩むとは記してあるが、それは言葉通りに身構は南へ向い歩は北へ向って行くことであるか、それとも別に間隔交替か何かの隊法があって、後を向きながら前へ進む行進の仕方が有ったか何様か精しく知らない。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "炒り焼きして心見よ、と云うと、情無い下司男は、其言葉通りにして見て、これはことの外に結構でござる、生身の炒り焼きは、死したるのよりも遥かに勝りたり、などと云った。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は合点して、「あいよ」とその言葉通りに実に巧く振込みましたが、心中では気乗薄であったことも争えませんでした。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大器氏は自然に叩頭をさせられて、其言葉通りになるよりほかは無かつた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常の言葉通りである。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉通りにしていただければ、迫りくる危険はすぐに取り除かれ、安心できるようになりますので。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "業腹ながら爺さんの言葉通りに、荒壁の上塗だけは越してから塗ることにして、九日曉荷物を運び込む故、疊だけは必ず敷いておいて呉れ、と固くも頼んで、看護の片手間にこそ／＼と荷造りにかゝつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "木槿の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜の起原と発達（続き）　上に引いたフィリップ氏の言葉通り、今の世界に絶迹たる過去世期の諸爬虫の遺骸化石が竜てふ想念を大いに助長したは疑いを容れず。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うにあの晩、そなたとふたりでこの倉へ調べに来たときも、きっとボリボリやっていたに相違ないが、気がつかなかったか」「さよう……いえ、おことばどおりでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも深川先で、おことばどおり、わたくしの身がわり仏を使いましたはまことでござりまするが、でも、わたくしがあやめたのではござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "術は老雲斎先生のことばどおり、うれしくも破れました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
