        "examples": {
          "standard": [
            {
              "text": "放課後の工作室から、リズミカルな金槌の音と木の香りが漂ってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自宅のガレージを改造して作った工作室には、あらゆる工具が整然と並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工作室で模型を組み立てている時だけは、日常の嫌なことをすべて忘れられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "博士は心得て、うしろを向いてペンとバラの両人に、隣りの工作室に行っているようにと命じた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜二十時にうかがいます」　隣りの工作室では、ペンとバラが熱心に計算をつづけていた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はやむなく次の工作室から始めて、ミルキ閣下の一行を各室に導いていった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は一家の暇のある姉娘のように、誰彼の服装について遠慮のない口をきくかと思えば、針と糸とを持ち出して、綻びを繕ったり、そうかと思うと、工作室から鉋や鋸を借りてきて、手製の額を壁にかけたりした。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
