    },
    "definitions": [
      {
        "index": 1,
        "gloss": "imperial grandchild or descendant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翰林学士の劉三吾、御歎はさることながら、既に皇孫のましませば何事か候うべき、儲君と仰せ出されんには、四海心を繋け奉らんに、然のみは御過憂あるべからず、と白したりければ、実にもと点頭かせられて、其歳の九月、立てゝ皇太孫と定められたるが、即ち後に建文の帝と申す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "懿文太子の薨ずるや、身を挺んでゝ、皇孫は世嫡なり、大統を承けたまわんこと、礼｜也、と云いて、内外の疑懼を定め、太孫を立てゝ儲君となせし者は、実に此の劉三吾たりしなり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖の治を思うの慮も遠く、皇孫を愛するの情も篤しという可し。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖｜其の挙止端整なるを喜びて、皇孫に謂って曰く、此荘士、当に其才を老いしめて以て汝を輔けしめんと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝は太祖の皇孫と生れさせたまいて、金殿玉楼に人となりたまいたれども、如是因、如是縁、今また袈裟念珠の人たらんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が海と大君宣らす、我が空と皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見はるかし大君宣らす、四方つ海｜皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国と大君宣らす、我が土と皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見はるかし、大君宣らす、四方つ国｜皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が國と大君宣らす、我が土と皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "見はるかし、大君宣らす、四方つ國｜皇孫領らす。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "萬づ世の皇統、皇孫や天津日繼。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "万づ世の皇統、皇孫や天津日継。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十五年七月廿八日神武天皇の御創業　皇孫｜彦火瓊瓊杵尊が、天照大神の神勅を奉じ、日向の高千穂の※触ノ峰に降臨されてから御三代の間は、九州の南方に在つて、国土を経営し、民力の涵養を図ると共に、周囲の者どもを帰服せしめ、之を化育することに依つて、いよ／＼興隆の基礎を築かれたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "上は則ち乾霊の国を授けたまふ徳に答へ、下は則ち皇孫の正を養ひたまひし心を弘めむ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、天皇は天つ神の神意を受けて、大八洲国に降臨せられた皇孫の御後裔であらせられるから、常に天つ神を祭り、その神意を奉体せられるのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "有田郡なども南朝の皇孫が久しく拠りたまえる所々を合祀のために分からぬことと成り果たしたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "村上天皇の第七子｜具平親王六｜世皇孫である俊寛が、南蛮の女と契るなどは、何事であろうと考えた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからの新富座は、外賓接待には洩らされない場処となって、ドイツ皇孫ヘンリー親王の来朝の時から、我国の宮殿下方もお揃いにて成らせられ、その時の接待係は、鍋島、伊達の大華族であり、そのあとへは香港の太守、その次へは米国前大統領グラント将軍という順に、国賓たちを迎えた。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "すめみま記・紀すでにさうした解釈を主として居り、後世の学者又其を信じてゐる所の皇孫即すめみまとする語原説は、尠くとも神道の歴史の第二次以下の意義しか知らぬものである。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其血は、皇孫行平・業平にも引いて居る。",
              "citation": {
                "source": "万葉集のなり立ち",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしほみゝの命が、大神と皇孫との間に介在せられるのは、みまを御孫と感じた時代からの事であらう。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "持統天皇の在位は皇孫珂瑠の保育にあつたが、太政大臣に高市皇子を任じ、補佐するに葛野王あり、家族政府として極めて鞏固な団結であつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇孫珂瑠は譲を受けて即位し文武天皇となる。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　道鏡は天智天皇の子、施基皇子の子供であり、天智天皇の皇孫だつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何よりも、彼は天智の皇孫だつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女帝は道鏡が皇孫であり、たゞの臣下ではないことを、そのしるしを、天下に明にしたかつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら科学者が防止法を発見しても、政府はそのままにそれを採用実行することが決してできないように、また一般民衆はいっこうそんな事には頓着しないように、ちゃんと世の中ができているらしく見えるからである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、兵太郎君はおんちで、君が代もろくろくうたえなかったが、いっこうそんなことは気にせず、みんなが声をそろえてうたっていると、すぐ唱和するので、みんなは調子がへんになって、やめてしまうのであった。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の場合ならば、お互い先にねたをあげたものがてがらとなるんだから、負けるまでにも競争するのは当然なのに、われらのむっつり右門にかぎっては、いっこうそんなけぶりすらも見えないで、涼しげにばたばたと胸もとへ白扇の風を入れていたものでしたから、敬四郎はむッとただ右門をにらみかえしたばかり――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
