    "definitions": [
      {
        "index": 1,
        "gloss": "round dumpling (made of rice flour, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ソーダの瓶と菓子｜麺麭の籠とが縞のエプロンの上で日の光を受け止めている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十一月十一日『東京朝日新聞』）　　　　　　　　　三十六　　　　　　ドイツの製粉研究所　ドイツ人がすべての工業の発達を計るためにその根本たる科学的の研究に注意する事は今に始めぬ事だが、今度また麺麭粉の研究所を新たに設立し既設の製糖並びに醸造研究所とともに三幅対を作るそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また麺麭製造部もあって大仕掛けの研究をやるようになっている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この設立に際して農務省は三十万円ほどの費用を支出し、なお年々保護を与えるはず、そしてドイツの製粉組合や製麭組合等の合同で維持して行くとの事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貯蔵、製粉、製麭に関するあらゆる科学的並びに実用的の研究をする外、なお広く民間の需に応じて雑穀、粉、麺麭等の分析等をするそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "麺麭と肉やサラドの盛つた皿が備へてあつた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一餐の時に一品、即ち麺麭なら麺麭、野菜なら野菜と云ふのが定めです。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、丘を登りしなに、必ず、パンか、乾麺麭か、砂糖かを新聞紙に包んで持っていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は乾麺麭を一袋握って、あとから追っかけた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松木は息を切らし切らし女に追いつくと、空の洗面器の中へ乾麺麭の袋を放り込んだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、昼に、パンと乾麺麭をかじり、雪を食ってのどを湿した。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また夢のようだけれども、今見れば麺麭屋になった、丁どその硝子窓のあるあたりへ、幕を絞って――暑くなると夜店の中へ、見世ものの小屋が掛った。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "多稜形をした外面が黒く緻密な岩はだを示して、それに深い亀裂の入った麺麭殻型の火山弾もある。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、ヴォルガ河で船乗りの生活をして、其の間に字を読む事を覚えた事や、カザンで麺麭焼の弟子になって、主人と喧嘩をして、其の細君にひどい復讐をして、とうとう此処まで落ち延びた次第を包まず物語った。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引続いては兵隊饅頭、鶏卵入の滋養麺麭。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな水ッぽいもんじゃあねえや、べらぼうめ、そこいらに在る、有平だの、餡麺麭だの、駄菓子で結構だ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵粮だって餡麺麭を捻込んで、石滝の奥へ、今の前橋を渡ったんだ、ちょうど一足違い位なもんだ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "重湯か、薄粥、或は麺麭を少量と言はれたけれども、汽車で、そんなものは得られなかつた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ぐら／＼と來るか、おツと叫んで、銅貨の財布と食麺麭と魔法壜を入れたバスケツトを追取刀で、一々框まで飛び出すやうな卑怯を何うする。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真赤な達磨が逆斛斗を打った、忙がしい世の麺麭屋の看板さえ、遠い鎮守の鳥居めく、田圃道でも通る思いで、江東橋の停留所に着く。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして軍隊の精神は麪麭を燔くやうに急造し得るものでは無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃弱を患ふる人がタカヂアスターゼを服し、苦味丁幾を服し、ペプシンを服し、粥を※て吸ひ、フランス麪麭を購ひて喫ひ、壓し麥を喫ふのを見ることは多いが、咀嚼時間を長くして、丁寧に咀嚼することを敢てするのを見ることの少いなどは其の一例である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽が西の海に入って、麺麭の大樹の梢に大蝙蝠が飛び廻る頃になって、漸く此の男は、犬猫にあてがわれるようなクカオ芋の尻尾と魚のあらとにありつく。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁から椰子蜜採りから椰子縄作りから麺麭の実取りや独木舟造りに至る迄、ありとあらゆる労働が彼に課せられる。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の譯した「麺麭の略取」の如きも、佛語の原書で、英、獨、露、伊、西等の諸國語に飜譯され、世界的名著として重んぜられてゐるので、之を亂暴に禁止したのは、文明國中日本と露國のみなのです。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "お弁当の麺麭のジャムの多い少いを争う女学生でもありますまい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はあけぬ、麺麭種の粉かとも花は咲きて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の中央にタロ芋田が整然と作られ、その周圍を蛸樹やレモンや麺麭樹やウカル等の雜木の防風木が取卷いてゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
