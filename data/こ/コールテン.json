        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「お母ア、コール天の足袋は？",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のコール天の足袋は？",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……コール天の足袋、今日じゃなけりゃいやだ！",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母あ、コール天の足袋は？",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コール天の足袋は？",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕、コール天の足袋がいるんだ！",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鳥打に紺飛白、小倉袴、コール天の足袋、黒の釣鐘マントに朴歯の足駄といういでたちでお菓子らしい包みを平らに抱えながら高林家のカブキ門を出た。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ君は継ぎはぎだらけのコール天の上衣を着て、目まぐるしく廻転する巨大な精米機の傍に、両腕をうしろにまはし、仔細らしい顔をして立つてゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コール天のズボンにジヤンバーを着た、二十三四の若者である。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコール天国、そしてアルコール地獄、よからう、よいとしなければ生きてゐられない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴穿きのまま、ダブダブのコール天のズボンと上衣を着て、その上から妾の古いショールをグルグルと捲き付けた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあなんでも五〇銭位と思いますがと答えると「そうですか、すると……」と彼はコール天のズボンから銅貨銀貨を一掴み玄関へずらりと並べました。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "白エプロンをくるくるとまいて、下からメリンス友禅の派手な前垂を出した弁当屋の女中が、足は紫のコール天足袋だが、頭だけは艶々した島田で、留置場わきの小使室のところから出て来た。",
              "citation": {
                "source": "鏡餅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くのバタ製造所の技手、印半纒を着た男、コール天のズボンをはいた男、などが通りがかりにひょっこり入ってきて、三十分も一時間も坐りこんで話してゆく。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんは五十四五ぐらゐで、メリンス友禪の色のさめた長襦袢一つに、紺のコール天の足袋はだしになり、手には花やかな舞扇を持つて舞つてゐる。",
              "citation": {
                "source": "二月堂の夕",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の服装が異様であって、この近所には珍しい断髪の頭に、派手なメリンス友禅の、それも色の褪めかかった、ひどく古ぼけた振袖を着て、紫のコール天の足袋を穿いた風つきはなかなかの美人であるだけに、どう考えても癲狂院のしろものであった。",
              "citation": {
                "source": "日本に於けるクリップン事件",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれもコール天の半ズボンに長靴下。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所へゆくために暗い廊下を歩いてゆくと正面の帽子かけに、コール天の小さい俵的の帽子のかかっているのが眼についた。",
              "citation": {
                "source": "親馬鹿入堂記",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "コール天のズボンにエンジ色のビロードのロシア服をきた女のような顔をした男だった。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　今の修造は、いつか本郷であったおかっぱの男と同じように、コール天のズボンに黒いルパシカのきたきり雀だった。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを言おうとすると、丸万が、「川向うの女にラツて（惚れて）夢中だというじゃないか」「そうなんだ」と俺はコール天のズボンの膝をたたいて、「その女を見せたいんだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恋のカレンダー」は伊藤松雄の演出で、昔に帰ってコール天の服でマスクして、やってゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
