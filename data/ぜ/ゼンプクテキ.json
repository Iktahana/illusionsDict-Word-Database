        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから、体力や精神力に全幅的な大きさが無い。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼を良しとして擁護することは、彼のこの通俗的なゴシップ的なもの、或は彼自身の画壇的な行動といふものと、すべて全幅的に容認し、擁護する立場に立たなければならないといふことがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼我々はさういふ意味で全幅的な期待をこれらの作家にかけるわけにはゆかない。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る程度までは誰についても云われることだろうが、うちの父や母は自分たちの時代のいろいろな歴史の性格というものを自分では其と知らず、しかも全幅的に生きた人たちであった。",
              "citation": {
                "source": "親子一体の教育法",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの文学愛好者達は、発表の機会を考えてそこに集り、だが必ずしもその統率者に対して人間及作家としての尊敬を全幅的に捧げているとは限らない。",
              "citation": {
                "source": "今日の文学の鳥瞰図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書かれた感想の中に母の性格が全幅的に反映している事はもとよりであるが、子として更に懐かしい一人の婦人としての母の或る力は、雑多な困難と闘いながら一つの旅日記にせよ、よく最後まで書きとおした一事にこもっていると思われるのである。",
              "citation": {
                "source": "葭の影にそえて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十年ばかりは、友達の価値を全幅的に知りながらの生活である。",
              "citation": {
                "source": "なつかしい仲間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場で愛の全幅的な表現を求める関を、真知子は「あなたと結婚した以上もう家には帰らない。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを全幅的に現わすには、非凡の才能が必要であるかも知れない。",
              "citation": {
                "source": "性格を求む",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "短篇では、分量の関係上、或る人物なり或る事件なりを全幅的に描くことは困難であって、多くは、人物や事件の断面図となる。",
              "citation": {
                "source": "長篇小説私見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に反して長篇は、普通の人物の普通の場合を取扱っても、それが比較的全幅的に書き生かされる時、それ自体の限定によって、より多く特殊的となる。",
              "citation": {
                "source": "長篇小説私見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は国民の一人として、この内閣を全幅的に信用しようと思ふ。",
              "citation": {
                "source": "一国民としての希望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "○全幅的に生きることのむずかしさ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○「西沢のことで宮本を全幅的に信頼していなかった」という秋笹。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "又彼女はそれを全幅的に受け入れ、理解し、熱愛した。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合において輸出という形の予備は何も残されていないのであるから、気候の不順によるあらゆる食物不足の結果は、必ずや全幅的に感ぜられなければならない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "全幅的に恒常的に永続的に劇団活動をすることを命ずるであろう。",
              "citation": {
                "source": "俳優への手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「作品はどうも全幅的には感心できない。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（危急の際だから毛利の援助を仰いだが、何も全幅的に、毛利と同盟したわけではない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかんずく東海の徳川家康とは、全幅的な攻守同盟をむすび、家康もまたようやく、彼本来のうごきを明らかにしかけている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
