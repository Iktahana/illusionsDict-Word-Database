        "examples": {
          "standard": [
            {
              "text": "砂漠の真ん中に設置された前哨地は、水や食料の補給が極めて困難な状況にあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は最前線の前哨地での任務を志願し、過酷な環境の中で己を鍛え上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "敵の包囲網を突破し、孤立していた前哨地にようやく救援物資が届けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "スペインの前哨地点であったプロヴァンスのモンペリエはサレルノがコンスタンチヌスの飜訳によって肥料を得たのと同じように飜訳の波によって強く影響された最初の場所であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
