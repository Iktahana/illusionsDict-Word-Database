[
  {
    "uuid": "3749660d-dc42-5be1-aea4-97fed47994c5",
    "entry": "全体",
    "reading": {
      "primary": "ぜんたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
