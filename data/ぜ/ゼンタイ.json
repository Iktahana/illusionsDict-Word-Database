      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "whole",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで、芸術が向上するとすれば、何時も全体的にであつて、要素々々の注入は、却て芸術家の統一を破るくらゐのものである。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は今此の問題を全体的に扱はうとする気持をなるたけ自分から排除したいやうに思ふ。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂといふ人間全体として何も無邪気ぢやないまでも、文学にしか頭が向かないところから、その他のことでは、尠くも不慣れくらゐのことはある。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで不満なのだつたら、困難も出て来ない、困難だといへば文学全体が困難な俺なぞは、どうすれあいいのだ」。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと悪い場合を想像すれば、文学の雑文を書かうとして、何の文学に関するネタもない所から、どうも鬱々として、その揚句、「一体全体文学が陰気だぞ！",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その由を弁解したら、それもさうかと一応は分つたらしかつたが、それでも猶そのお説教を続けるのは、僕にやつぱり一体全体「誠意がないのか」それとも、大概の老人がさうであるやうに、たゞもう剛情なのか。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲシュタルト心理学が持ち出され、全体主義という合言葉も生れて、新しい世界観が、そろそろ登場の身仕度を始めた。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体主義哲学の認識論に於いて、すぐさま突き当る難関は、その認識確証の様式であろう。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉にたよる他、全体認識の確証を示すことができないのか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉より他になかったとしたなら、この全体主義哲学は、その認識論に於いて、たいへん苦労をしなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、全体主義そのものを、どんな様式で説明したらいちばんよいか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外、こんなところに全体主義の困惑があるのではないか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンチテエゼの成立が、その成立の見透しが、甚だややこしく、あいまいになって来て、自己のかねて隠し持ったる唯物論的弁証法の切れ味も、なんだか心細くなり、狼狽して右往左往している一群の知識人のためにも、この全体主義哲学は、その世界観、その認識論を、ためらわず活溌に展開させなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲシュタルト心理学や、全体主義哲学に就いて、知っているところだけでも講義しなければならなかった。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ名辞以前にこそ全体性はあるのである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、統一だの全体性だのと称ばれるものは、其処に欠乏してゐたのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体に縹渺とした詩境であって、英国の詩人イエーツらが狙ったいわゆる「象徴」の詩境とも、どこか共通のものが感じられる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく彼は、心境の静寂さにおいて芭蕉に近づき、全体としての芸術を、近代の象徴詩に近く発展させたか知れないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに表現の構成を分析すれば、「柚の花」が静かな侘しい感覚を表象し、「母屋」が大きな旧家――別棟や土蔵の付いてる――を聯想させ、「乾隅」が暗く幽邃な位置を表象し、そして「ゆかしき」という言葉が、詩の全体にかけて流動するところの、情緒の流れとなってるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東附近の村は全体に荒寥として、この種の南国的な暖かい情趣に乏しい。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポオはそれを意識的に反復させて、詩の全体のモチーフを、その語の表象する気分の週期的反響によつて構成させてゐる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に白状すると、これはポオの翻案であつて、鶏の朝鳴を、とをてくうる、もうるとうなどの音韻で表象させ、全体にポオの「大鴉」と似たやうな詩想を、似たやうな表現技巧で出さうとした。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで僕の家の家風全体が、一体に訪問客を悦ばなかった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、箱根あたりとくらべれば、全体に田舎めいてゐるが、併しそれも、悪い意味での田舎くさい感じはあたへない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体に明るくて、新緑といふやうなフレツシユの気分が高い。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また伊香保の町は、全体に細い横丁や路地の多い、抜道だらけの町である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体に伊香保の人は、自然の美を人工によつて開発することを知らない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏伊香保へ行つた人は、たいてい宿屋のことから気分を害し、順つて伊香保全体を悪く見てしまふ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）之れを全体から言へば、温泉としての伊香保は、すべてに於て箱根に劣るが、他の塩原等にくらべれば、よほど優つてゐるやうである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ学生の中にはずいぶん不真面目らしい茶目や怠け者も居て一体に何となく浮世臭い匂がこの教室全体に漂っているのを感じた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
