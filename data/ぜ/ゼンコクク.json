          "standard": [
            {
              "text": "そのアイドルグループは、テレビ出演をきっかけに全国区の人気を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地元で有名だったパン屋が、メディアに取り上げられ全国区になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの芸人は、ついに全国区の顔になったね。すごい活躍だ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
