  {
    "uuid": "3f621f85-c8e0-5e0b-a9aa-34f937f0b25e",
    "entry": "漸漸",
    "reading": {
      "primary": "ぜんぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gradually",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは成る程、君も僕もぜんぜん生産にあずかっていない人間だ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれはブルジョアジイを支持しているのとはぜんぜん意味が違うのだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからさき、生きていられるのか、死ななければならないのか、ぜんぜんわからないのです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "年よりは、ぜんぜん団体精神を知らんので駄目である。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二人は耳をすましてきいていたが、余韻がわあんわあんと波のようにくりかえしながら消えていったばかりで、ぜんそく持ちの痰のような音はぜんぜんしなかった。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、ちっとも、何にも、ぜんぜん、その作品と関係の無い夢でした。",
              "citation": {
                "source": "小説の面白さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石太郎にすまないという気持ちや、石太郎はぎせいに立ってえらいなという心は、ぜんぜん起こらなかった。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような想像は、物語では読むことはあるが、ほんとうの生存とはぜんぜん矛盾するものである。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、私の前の牢は、トレード（３）にあるすべての監房と同じように、石の床であって、光線がぜんぜんさえぎられてはいなかった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "その低い小さな室にはランプは一つもかかっていないので、そのときは、一つの半円形の窓から射しこんでくるごくかすかな暁の光のほかには、光はぜんぜん入っていなかった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私がどこにいるのか、そしてどうなるのか、ということを知らなかったら、その場所がどんなところかぜんぜんわからなかったことでしょう。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "また私は自分が一つの大きな疾患にかかっているとはぜんぜん考えることができなかった、――ただ私の普通の睡眠の特異性がもっとひどくなったものと考えられることをのぞいては。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに眠っている者は、ぜんぜん眠っていない者よりも何百万も少なかった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣がそれを体につけているなんてことについては、問題にしなくてもいいんでしょうな」「ぜんぜんないね」と総監は言った。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「屋敷をもう一度完全に捜すんですな」「それはぜんぜん不要だ」とＧ――が答えた。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、それの発見は、ちっとも探索者の明敏さいかんによるのではなくて、ぜんぜん単なる注意と、忍耐と、決意とによるのだ。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけだから、もしあの盗まれた手紙が総監の調査の範囲内のどこかに隠してあったなら――言葉をかえて言えば、それの隠匿の方針が総監の方針のなかにあるものだったなら――それの発見はぜんぜん疑いの余地はなかったろう、と僕の言おうとしたことは君にはもうわかったろう。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "お世辞のほうは友はできるだけ受けながしたが、申し出のほうは、その利益はぜんぜん仮定的のものではあったけれど、彼はすぐさま承諾した。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "』ということよりも、『起ったことのなかで、いままでぜんぜん起ったことのないのはどんなことか？",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある事情ではこの結果は一時間たたぬうちに起るだろうし、また他の事情ではぜんぜんそれが起らないかもしれない。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーヴェエ氏がマリーの死体を捜しているうちに、体の大きさや顔つきがその行方不明の娘に似ている死体を発見したなら、（服装の問題にはぜんぜんふれないでも）これこそ彼女だ、と思いこんでもまあ仕方ないだろうよ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの大事な問題にぜんぜん証拠が挙がっていないのだ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "無頼漢の数について彼が発表した推測なるものが、パリのあらゆる令名ある解剖学者たちから、でたらめで、ぜんぜん根拠のないものとして当然いい笑いものにされている、ということだけを言っておけば十分だ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者はぜんぜん彼らの意のままになったにちがいないよ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、数学的なものとは一見ぜんぜん別な思考力に訴えるもののように見えるが、しかも数学者だけが完全に理解できる変則的な命題の一つである。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "原注一九　ムネエは、初めに嫌疑を受けかつ拘引されたが、証拠がぜんぜんないために放免された者の一人であった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま述べた驚くべき事実を、自分の良心にたいしてはぜんぜんできなかったとしても、理性にたいしてはこんなにたやすく説明したのであるが、それでも、それが私の想像に深い印象を与えたことに変りはなかった。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのつぼは多種多様で、しかも多くの場合、普通の理解力ではぜんぜん近づきがたい思考の奥深くに隠れているのだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "レスパネエ夫人の力では、娘の死体をあんなふうに煙突のなかに突き上げるなんてことはとてもできまいし、また彼女自身の体についている傷の性質から言っても、自殺などという考えをぜんぜん許さないものなんだからね。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
