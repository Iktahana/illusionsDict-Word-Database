[
  {
    "uuid": "23d2a1b3-ecdf-5cd1-a2f1-76a571f1087b",
    "entry": "税制",
    "reading": {
      "primary": "ぜいせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
