    "definitions": [
      {
        "index": 1,
        "gloss": "forehead",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大隅君の厳父には、私は未だお目にかかった事は無いが、美事な薬鑵頭でいらっしゃるそうで、独り息子の忠太郎君もまた素直に厳父の先例に従い、大学を出た頃から、そろそろ前額部が禿げはじめた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男子が年と共に前額部の禿げ上るのは当り前の事で、少しも異とするに及ばぬけれど、大隅君のは、他の学友に較べて目立って進捗が早かった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武村兵曹は前額を撫でゝ『やあ、だん／″＼と目出度い事が集つて來ますな。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の隆くしかも翼孔の小さいのと前額の広いのとだけは幾分此者の顔面の違常性を調和して居るが、短く刈つた毛髪の下からすぐ看取することの出来る頭の形は又直にその不均斉を思はせる。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "前額と胸とを鋭い岩角に打ちつけて、それが致命傷らしかった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の牛九郎の方は仰臥けしたまま、禿上った前額部の眉の上を横筋違いに耳の近くまでザックリと割られて、鶏の内臓みたような脳漿がハミ出している。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの音も数本の指と、腕と、人の若者の前額を斬り割いた。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう六十を越えて、それで前額は禿げているが、矍鑠としたシャンとした老人である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "前額の禿がてらてらと光る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　イフェミヤはその乱れた前額の毛をわざと巫山戯てその手で掻き散らした。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても夢中で」　とその従兄の民謡詩人がツルリと禿上ったその前額を指で弾く。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青黒い地獄色の皮膚、前額に乱れかかった縮れ毛。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、李張の手にした矢が飛んでその前額から後脳にかけて貫いた。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその頑丈な磁鉄の灰皿のために、前額部を完全に割り砕かれていた。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　前額部を割り砕かれて死んだ永峯の死体が取り片づけられると、吉本はすぐに病院に入れられた。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾丸は彼の女の前額を貫通していたが、たぶん彼の女はしばらくの間は、意識を失ったに相違なかった。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の両側から禿上って行く禿頭の、黒い髪が中央に残っている前額部の形だった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相者は更に一歩を進めて『アナタの前額には（何とかいふ相学のテクニツクを使用して）といふ不幸の相が現はれてをる。",
              "citation": {
                "source": "人相見",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫から日本にも来てゐるが、矮狗位な大きさで頭の毛が長く幾｜条となく前額に垂れて目を覆してゐる「スカイ、テリヤー」といふ奴、彼奴はどうも汚臭くて、人間なら貧乏書生染みて不可んな。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人沼南と同伴でない時はイツデモ小間使をお伴につれていたが、その頃流行した前髪を切って前額に垂らした束髪で、嬌態を作って桃色の小さいハンケチを揮り揮り香水の香いを四辺に薫じていた。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "内新好が『一目土堤』に穿りし通仕込の御作者様方一連を云ふなれば、其｜職分の更に重くして且つ尊きは豈に夫の扇子で前額を鍛へる野幇間の比ならんや。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルマン氏は、禿げ上った前額に滲み出る汗を無雑作に手帛で拭きとりながら、ぶっきらぼうに答えた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀行家は、禿げた前額を撫上げながら、ちょっと言葉を切って、にやりとした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はとりあえず眼の前の白鷹先生の前額から後頭部へかけて些なからず禿げていられるのに驚いた。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレット風な憂悶は絶えず私の前額を蔽い、眼の光りを曇らせた。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれやな、かしらの角はとがりまさり、　　前額のしわはいやふかし。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "血海の中に冷く光っているガラス瓶の欠片でつけたものであろう、顔から頭へかけて物凄い掻傷が煮凝のような血を吹き、わけても正視に堪えぬのは、前額から頭蓋へかけてバックリ開いた大穴から、なんと脳味噌が抜きとられて頭の中は空っぽだ。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですが警視庁のお見込はどうなったんですか」「そいつを聞かれると、大いに憂欝になるのですがねエ」と大江山課長は禿かかった前額をツルリと撫であげた。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の丸い、髪の前額を蔽つた二十一二の青年で、これは村でも有数の富豪の息子であるといふ事であつた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "前額から切りつけられて、後頭部まで真直な太刀痕が通っているという物凄い切られ様をした権四郎の死骸の上に、同輩の一人がソッと羽織を被せてやった。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
