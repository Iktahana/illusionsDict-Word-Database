  {
    "uuid": "87bc6510-9a72-56eb-b829-0bb37b547b43",
    "entry": "全艦",
    "reading": {
      "primary": "ぜんかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
