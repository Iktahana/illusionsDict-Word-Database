      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "well done!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文殊師利嘆じて曰く善哉善哉。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右にこの轡を取って、ちょっと振向いて、菩薩にものを言いそうなのが優※玉、左に一匣を捧げたのは善哉童子。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私をはげますように、「織田はん、また夫婦善哉書きなはれ」と言ったので、私は、「サアナア、しかし、夫婦善哉といえば、あの法善寺の阿多福の人形は助かったらしい。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、武田さんは私の「夫婦善哉」という小説を、文芸推薦の選衡委員会で極力推薦してくれたことは、速記に明らかである。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夫婦善哉」を小山書店から出さないかというような手紙もくれた。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夫婦善哉は、何故か、評判がよくなかったが、大阪のああいう世界を描いた限り、私は傑作だと思った。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八歳で「夫婦善哉」を書くのはおかしいと言うが、しかし、それでは、東京に現在いかなる二十八歳の青春の文学があるというのか。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年二つの小説を書いて「海風」に発表したが、二つ目の「雨」というのがやや認められ、翌年の「俗臭」が室生氏の推薦で芥川賞候補にあげられ、四作目の「放浪」は永井龍男氏の世話で「文学界」にのり、五作目の「夫婦善哉」が文芸推薦になった。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夫婦善哉」を書くまでは、一人の作家とも知己がなかった。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "西鶴を本当に読んだのは「夫婦善哉」を単行本にしてからである。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後不覚になつて、どうして寝床にはいつたやら、いつ寝たやら、一切合切不明なり、しかも些の不都合なし、善哉々々。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心たいらか、行乞相も行乞所得も上上来、善哉、々々。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こ、こ、ここの善哉はなんで、二、二、二杯ずつ持って来よるか知ってるか、知らんやろ。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "咸言う、善哉、この言甚だ快しと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "善哉々々と今宵も早く戸をしめて円陣を作つた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "善哉々々、鰯で一杯。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も酒なしか、――などと考へてゐるところへ、Ｋさん来訪、まだ酒があるから、樹明君を誘うて、もう一度（二度でも三度でも）忘年会を開かうといふ、大賛成で待ち受けてゐると、暮れないうちに、樹明君は魚の包を、Ｋさんは罎詰を持つて来庵、それからおもしろおかしく飲んで解散した、めでたやめでたや、善哉々々！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "足が痛い、善哉々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるだけ飲む、酔ひつぶれてしまつた、善哉々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポストまで、すぐ戻つた、善哉々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出途中、今日はとても飲みたかつたが、ぢだんだ踏んで我慢した、善哉々々！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "空々寂々、善哉々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後また街へ、だいぶ飲んだ、――まづＳ店で、それからＷ店で、さらにＮ店で、そしてＴ店で、――今日は一升近く呷つたらう、酔うた、久しぶりにいゝ気持になつた、それでもおとなしく戻つて来てすぐ寝た――善哉々々、山頭火バンザアイ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は近来水の句がだん／＼出来るやうになつた、善哉々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学生が隣寺境内清掃、善哉々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり飲み、ひとり酔ひ、ひとり寝る、善哉々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔うた、酔うて悠然として雲を眺めてゐた、善哉善哉、そして唄つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "手品か軽業か足芸のようなものを見て、帰りに葦簾張りの店へはいって氷水を飲むか、あるいは熱い「ぜんざい」を食った。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この熱いぜんざいが妙に涼しいものであった。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年東京会館の屋上庭園などで涼みながら銀座へんのネオンサインの照明を見おろしているときに、ふいとこの幼時の南磧の納涼場の記憶がよみがえって来て、そうしてあの熱い田舎ぜんざいの水っぽい甘さを思い出すと同時になき母のまだ若かった昔の日を思い浮かべることもある。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
