          "standard": [
            {
              "text": "全国農民組合は、農家の生活改善と農業政策への意見反映を目指して活動してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦後の食糧難の時代、全国農民組合は食料増産運動に貢献した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史資料には、全国農民組合が小作争議で果たした役割が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その後、昭和五年、日本農民組合（労農党系）と全日本農民組合（日労系）が合同して全国農民組合ができたが、私は争議部長に選ばれ、全国の小作争議をかけ回らされた。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
