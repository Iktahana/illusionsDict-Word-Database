[
  {
    "uuid": "9a40ff62-d09f-5a4c-8f9e-7063ebb60ef3",
    "entry": "是",
    "reading": {
      "primary": "ぜ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "righteousness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先づ第一に、是等の詩を書いた人は豊富である。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "是等の作品が、一般に愛されるべくそれ程難解なものとは思へぬ。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて芸術上の新様式の発生期に当つてその新様式を是非することは、予想外の困難を伴ふことだし、大概の場合正鵠を射当てることはない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ是等三様式は極めて短い詩形であるから、語自体の力が、語を駆使する作者の力よりも存外に大きいものであることは明瞭であらう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはつまり是等の一呼吸詩歌が十分に人一人の仕事となる性質のものでなくて、生活の余暇に出来る――といつて語弊があるならば、生活に随伴的に出来るものとして意義のあるものだといふことを証示する、一つの事ではあるまいか？",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今仮りに某が、興味を以て是々の文学書を読んだり、是々の作品を物したりして暮してゐるとして、其処へもつてきて「陽気な文学を」、なんて声がして来たらどんなものだらう。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れる時その話のことで「明日かあさつては是非訪ねるから」と三田村自身云つたのだが未だに来ない。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家、私是非見る好きです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれではあまり体面に関するので、夫人が是非フロックコートを新調するようにすすめたが、頑として中々きかない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた是非に参る、と、話のお土産』など言いながら、後ではいつも少し凋れて『しかしあなたの帰り、十時、十一時となります。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、大隅さんから、是非、という御返事がまいりました。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くいふは世人屡々芸術作品を以て、箒なら箒、手拭なら手拭といふ一定のテーマがあつて、それの種々なる解説（インタプリテイション）が彼是の作品だとなしがちだからである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には自分の珍しい是等の聴手は如何思ふことだらうと僻まれた、その訓辞の大体はかうだつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正門が立派でなければ愛校心が湧くものではない」といつて是迄の木の門は打倒され、石の門が建てられた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師も生徒も、抜出して見れば是といつて悪くなつたわけではなかつたが……可なり目に立つのは小使共のずぼらであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が只、もはや自分の口に何が合ふかも分らなくなつてゐる程に、尚彼是と食はうとはしない方がよいのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちつとも見通しといふことがない、子供が何になるかと云はれて大将と答へる如く、あ、これが大将かなと思つてはＡ書を読み、是こそが大将であると思つてはＢ書を読む。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非いちど小生の東京の母を訪ねなさい。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佛蘭西文學の旺盛時代たる路易第十四世の朝に於て、突如として一世の耳目を聳動し來れる一書あり、其の簡淨痛快にして靈犀奇警なる人世批評は、天下驚畏の中心となれり、本書是れ也。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく經つて、とんと輕く足踏みして、おもむろに呻き出すは、「是は阿波の鳴門に一夏を送る僧にて候。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、是非書かなければならぬ、といふ理由は無い。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀明水に達したるは午後七時に垂んとす、浅間社前の大石室に泊す、客は余を併せて四組七人、乾魚一枚、麩の味噌汁一杯、天保銭大の沢庵二切、晩餐の総べては是の如きのみ、葉マキ虫の葉を綴りて寝ぬる如く、一同皆｜蒲団に包まりて一睡す。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、シャスタに登る人は、一と夏を通して、百人か百五十人位と登録せられていたし、殊に日本人の登山としては、私たちが初めてのものであった（前に日本人が登っていたという記録があるならば、是非知らせていただきたい）。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "此セメントを使った月日と、それから委しい所書と、どんな場所へ使ったかと、それにあなたのお名前も、御迷惑でなかったら、是非々々お知らせ下さいね。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の主人は禿頭の工合から頬髯まで高橋是清翁によく似てゐる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺憾ながらまだ颱風の深度対頻度の統計が十分に出来ていないようであるが、そうした統計はやはり災害対策の基礎資料として是非とも必要なものであろうと思われる。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の主人は禿頭の工合から頬髯まで高橋｜是清翁によく似ている。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなるべくなら船に乗りたくないと思うが、海国の悲しさには、ちょっと踏み出せば是非とも船でなければならぬ。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕さむしい Hotel の臺所で、のすたるぢやのメリイが泣いて居る、ほんのり光る玉菜のかげから、ぜんまい仕かけで、鼠がひよつくり顏を出した。",
              "citation": {
                "source": "玩具箱",
                "author": "―人形及び動物のいろいろとその生活―",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
