    "definitions": [
      {
        "index": 1,
        "gloss": "unrestricted admission (to a school)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "少子化の影響で、私立大学は全入時代に突入したと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学の全入時代は、教育の質の低下を招くとの指摘もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は全入制の専門学校に入学したが、そこで本当に学びたいことを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "全受験者即ち全入学者の内に優良児と中以下の子供との間の大きな開きがある以上、或る学校には比較的優良な子供だけが入学するという可能性が、段々著しくなるというのが、ブルジョア自由社会の例の自然法則だったのである。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
