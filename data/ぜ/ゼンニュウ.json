        "examples": {
          "standard": [
            {
              "text": "このレシピでは、コクを出すために全乳を使用します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "全乳は、成長期の子どもにとって良い栄養源となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コーヒーに全乳を加えると、まろやかな味わいになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼らはパンまたはオートミールと全乳を与えた子犬は、室内で飼って戸外で散歩させないと、くる病になると1908年に報告した。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
