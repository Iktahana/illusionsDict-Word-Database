  {
    "uuid": "40dc3642-c286-5a7e-9164-f1cbd2f683cb",
    "entry": "全科",
    "reading": {
      "primary": "ぜんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "complete course",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いわゆる全科的じゃないんだね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者か――全科診療の開業医と見た。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は大正×年、秋の初め、場所はＢ全科病院の長い廊下であった。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、大英帝国が莫大な費用と全科学力とをかたむけて造っただけの大飛行島である。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも一カ月ばかりしてから、仏人教師のジャクレエの心配で、卒業の時には本科卒業として出すという約束で全科目選集の選科生として、二年へ進級したが、その二年ももとより大したことではなかった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "保は四月に第二等に進み、七月に破格を以て第一等に進み、遂に十二月に全科の業を終えた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ、いろはのいの字一つ知らないでも、品行さえ方正な生徒には、わしは全科目に満点をつけてやる。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ出來たばかりの全科學が、吾々の父祖の夢にも思ふことの出來なかつた廣大な地平線を、吾々の前に開いた。",
              "citation": {
                "source": "革命の研究",
                "author": "ピョートル・アレクセーヴィチ・クロポトキン　Pyotr Alkseevich Kropotkin",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうできたばかりの全科学が、われわれの父祖の夢にも思うことのできなかった広大な地平線を、われわれの前に開いた。",
              "citation": {
                "source": "革命の研究",
                "author": "ピョートル・アレクセーヴィッチ・クロポトキン　Pyotr Alekseevich Kropotkin",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、全科目、級で一番っていうのは受合えないよ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして全科を修了するに三年間を要するのみに候。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「燃焼的形態において逆立ちしていた全科学をばここにはじめて直立せしめた」と。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも、これでも、職務外のことをせねばならない必要を感ぜんか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしやわざくれ、作品のモチーフとなる切情に殉ぜんかなと）　からし菜、細根大根、花菜漬、こういった旬の青味のお漬物でご飯を勧められても、わたくしは、ほんの一口しか食べられなかった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、兵太郎君はいぜんから、死んだふりや、腹のいたむまねが、ひじょうにうまかったからである。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　のうぜんかずら　小学時代にいちばんきらいな学科は算術であった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにのうぜんかずらが下からすきまもなくからんで美しい。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しく世の人に立ち交りて、氣鬱を散ぜんかた、身の爲めに宜しからん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざそんな遠方へ行かなくとも、近くになじみのお湯がちゃんとあるじゃござんぜんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかにそのだきみょうがでございました」　聞くや、名人はとつぜんかんからと笑いだすと、吐き出すようにいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙覧の歌の調子につきて例を挙げて論ぜんか。",
              "citation": {
                "source": "曙覧の歌",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちこれを生産者の責任について論ぜんか、すでに述べしがごとく、需要と生産との間にはもとより因果の相互関係ありといえども、しかもそのいずれが根本なりやと言わば、需要はすなわち本で、生産はひっきょう末である。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "願くば一生｜後生を云はず、紛々たる文壇の張三李四と、トルストイを談じ、西鶴を論じ、或は又甲主義乙傾向の是非曲直を喋々して、遊戯｜三昧の境に安んぜんかな。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "するすると船は進んだ、とつぜんかすかな音を船底に感じた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と悲鳴をあげたウエップが、とつぜんかけだした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことはいぜんから行われている。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れ然り、然りと雖も話術家にして巧に話の筋を作為し、自ら之を演ぜんか、是れ素より上乗なる者、彼の旧套を脱せざる昔話のみを演ずる者に比すれば同日の論にあらず。",
              "citation": {
                "source": "名人長二",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、とつぜんかれは、服の下から、針金を輪にしたようなものをとりだし、頭上高くあげた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいぜんから、お前たちのしゃべっていることは、わしのこの胸の中に、ちんちん煮えたっているものと、全く同じことじゃ」　そういって、虎船長は大きな拳固をかため、自分の幅広いむねを、どんとたたいた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀川青年は、艇長の方をふりむいて、「さあ、ダン艇長、早く麻綱をもってきてください」　ダン艇長は、さいぜんから太刀川青年の胸のすくような応対ぶりに見とれていたが、はっとわれにかえり、いいつけどおり、この操縦室の網棚から麻綱の束をかかえおろした。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
