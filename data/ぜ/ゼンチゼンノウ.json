    "definitions": [
      {
        "index": 1,
        "gloss": "omniscience and omnipotence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
