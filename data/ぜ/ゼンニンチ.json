        "examples": {
          "standard": [
            {
              "text": "彼は前任地での経験を活かし、新しい職場で活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "転勤で、私は前任地を離れることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "前任地で知り合った友人と、今でも連絡を取り合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "氏が前任地｜広東から奉天への赴任途中久し振に郷里の鹿児島へ廻り道をした事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "前任地では管内の博徒を顫え上らした人で、真っすぐな竹を割ったような気性の人で、よく物の分る半面には中々譲らない所があり、場合によると非常に熱狂的な快男児だった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前任地の知事の娘を貰ったのである。",
              "citation": {
                "source": "首切り問答",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
