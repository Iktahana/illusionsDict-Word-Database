    "definitions": [
      {
        "index": 1,
        "gloss": "front gate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "前門の経済通報社の万事相談室には早朝から夥しい人がつめかけていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は、前門牌（煙草の名）を出してマッチをすった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前門牌が一本なくなるのは五分間だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、自分の煙草に火をつけると、口を切った前門牌の袋をそこに居る者達の前に出してすゝめたが、陳以外、誰も貰おうとする者がなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三丁行くと、或る重役邸の前門の建て換え場だ。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "細川越中守忠利は、地白、上に紺の九曜の紋ある旗を掲げ、狸々緋の二本しないの馬印を立て、黒白段々の馬印従えた肥後守光利と共に、三の丸前門を攻撃した。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先鋒の部将長岡式部、城中に烟が起るのを見て、直ちに前門に進撃した。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いのを着た姿は、前門の虎に対して、荒神様の御前立かと頼母しく見えたので。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し斯くの如き紹介状を享くる人が、温厚篤實にして萬中庸を尚ぶ世上の士君子、例へば我校長田島氏の如きであつたら、恐らく見もせぬうちから玄關に立つ人を前門の虎と心得て、いざ狼の立塞がぬ間にと、草履片足で裏門から逃げ出さぬとも限らない。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し斯くの如き紹介状を享くる人が、温厚篤実にして万中庸を尚ぶ世上の士君子、例へば我が校長田島氏の如きであつたら、恐らく見もせぬうちから玄関に立つ人を前門の虎と心得て、いざ狼の立塞がぬ間にと、草履片足で裏門から逃げ出さぬとも限らない。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "：訓点送り仮名　（例）早々-------------------------------------------------------彼吉田の千両を以て、家を御求の御論おもしろそふなれども、是必、前門の虎は退ぞけしに後門の狼の入り来り候咄しならんか。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年八月十六日　陸奥宗光あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は、あちこちに転針してやっと遁れたが、じつに前門の虎去れば後門の狼のたとえか……極鯨吹きあげる潮柱のむこうに、ポツリと帆影のようなものを認めたのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "前門外の老舗には、それぞれ専門の豪華な商品が豊富に並んでいるが、店員のみいて客の姿はめったに見えない。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京の前門外の暢園茶社には、大勢の客が茶を飲みに行く。",
              "citation": {
                "source": "北支点描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　前門外という言葉は、北京旅行者にはただ遊里と響くことが多い。",
              "citation": {
                "source": "北支点描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "前門外は元来、こうした老舗の町である。",
              "citation": {
                "source": "北支点描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "前門外を少し出れば、日本人から俗に盗坊市場と云われてる安物市場のある、天橋一帯の貧民街があり、更に他方には、琉璃廠一帯の骨董街がある。",
              "citation": {
                "source": "北支点描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　黄河　汽車の黄河を渡る間に僕の受用したものを挙げれば、茶が二椀、棗が六顆、前門牌の巻煙草が三本、カアライルの「仏蘭西革命史」が二頁半、それから――蠅を十一匹殺した！",
              "citation": {
                "source": "雑信一束",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　前門　僕――おや、飛行機が飛んでいる。",
              "citation": {
                "source": "雑信一束",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとこの前門を御覧下さい。",
              "citation": {
                "source": "雑信一束",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、昨日｜梅蘭芳や楊小楼を見たる東安市場の吉祥茶園は勿論、一昨日｜余叔岩や尚小雲を見たる前門外の三慶園よりも一層じじむさき位ならん。",
              "citation": {
                "source": "北京日記抄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の人が『前門の虎、後門の狼』とよんだのは、今の日本の戦略態勢（戦略上のありさま）だ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れもしない北京前門外で商人宿がずらっと並んで、表の狭い通りには荷物を背負った駱駝がのそのそと通って、支那人ばかりがおし合いへしあいするほど、雑踏している町へうろうろと私は進入した。",
              "citation": {
                "source": "怪談",
                "author": "平山蘆江",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩田大尉ののっている司令機のうしろについていた五機の操縦士は、前門の機銃の引金をいつでも引けるように用意をして、あとの命令をまちました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに前九・後三の両役ともに、いわゆる前門の虎を防いでこれを後門の狼に譲り渡したという結果となってしまったのである。",
              "citation": {
                "source": "奥州における御館藤原氏",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくは彼らが前門に「概念法学」を打破しえた暁には「公平」と「自由」との要求が後門よりただちに攻めきたりて彼らを撃つであろう。",
              "citation": {
                "source": "嘘の効用",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――最後に私は巡警の物々しい北京前門停車場で、苦力の人力車に包囲されてしまつた。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "――北京を発つ時には前門停車場で、もう奉天へ引きあげる仕度のすつかり整つた張作霖の特別列車といふのを眼のあたり見て来たのだが、いま私の着いたこの江蘇の市は、それに引き替へ革命軍事成功祝賀会の準備で雑沓してゐた。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "双剣一に収まって和平を楽しむの期いまだ到らざる証であろうが、前門に雲舞いくだって後門竜を脱す。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことわざにもいう前門の虎、後門の狼！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
