[
  {
    "uuid": "a184849b-a563-50f4-8f28-992b73d9ac25",
    "entry": "前古",
    "reading": {
      "primary": "ぜんこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
