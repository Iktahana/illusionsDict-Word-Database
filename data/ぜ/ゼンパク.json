        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この前泊った川岸の宿は満員というので名も知らぬ小さな船宿へ入る。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "まづ、富岡は、以前泊つた宿に着いた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより文治は彼方此方と尋ね廻りまして、漸く此の前泊りました旅籠屋へまいりました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでちょっと以前泊ったことのある富士屋の主婦さんを訪ねた。",
              "citation": {
                "source": "別府温泉",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
