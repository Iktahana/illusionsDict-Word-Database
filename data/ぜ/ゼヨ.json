        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「俺達の教会」では思わず吹き出し、そして感心しちまった――何とおめえ達そうじゃあねえか、信ぜよ、そして働けよ、だ。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "神もおはしまさば我家の檐に止まりて御覽ぜよ、佛もあらば我が此手元に近よりても御覽ぜよ、我が心は清めるか濁れるか。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧ぜよ、奥方の御目には我れを憎しみ、殿をば嘲りの色の浮かび給ひしを」　女子は太息に胸の雲を消して、月もる窓を引たつれば、音に目さめて泣出る稚児を、「あはれ可愛し、いかなる夢をか見つる。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿も我が心を見給へ、我が良人も御覧ぜよ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神もおはしまさば我が家の軒に止まりて御覧ぜよ、仏もあらば我がこの手元に近よりても御覧ぜよ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君にして若し、月夜笛を聞いて、諸君の心に少しにても『永遠』の俤が映るならば、戀を信ぜよ。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　祖母は、顔を見て、しばらく黙って、「おお、どうにかして進ぜよう。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅びても変態人情の美に殉ぜよという強いての好みを持つならばとにかく、人生の本道を歩もうとすれば、「無明」を憎む憎しみは、やはり生かさなければなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょいとかやが首を出すと吉蔵が、「だから、おかやちゃん、お宮（鎮守の杜）へ行ったら、ようく、婆やを見張らねえじゃいけませんぜよ」と云う。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛惜の一念のみは、魔界の塵にも曇りはせねば、我が袖、鏡と御覧ぜよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ教えて進ぜよう。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが今その者のために心経を供養して進ぜよう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此勢に乗ぜよやと、張玉、朱能等、いずれも塞北に転戦して元兵と相馳駆し、千軍万馬の間に老い来れる者なれば、兵を率いて夜に乗じて突いて出で、黎明に至るまでに九つの門の其八を奪い、たゞ一つ下らざりし西直門をも、好言を以て守者を散ぜしめぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（つかつかと寄って獅子の頭を撫で）まず、目をあけて進ぜよう。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、もそっと、その上にも清い目にして進ぜよう。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "信ぜよ、花ひらく時には、たしかに明朗の音を発する。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような、げす共の言葉なぞ……」「聴かざったとあれば、教えて進ぜよう。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の文よ、そよかぜよ、ただ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛鳴るに太鼓とよむに、水祭また御｜覧ぜよ、舟よしと、さて棹さしぬ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その海人が、大雀命のところへ伺いますと、命は、それは若郎子皇子に奉れ、あの方が天皇でいらっしゃるとおっしゃって、お受けつけになりませんし、それではと言って皇子の方へうかがえば、それはお兄上の方へ献ぜよとおおせになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁天の鳥居の前を通る時、岡田は強いて思想を他の方角に転ぜようとするらしく、「僕は君に話す事があるのだった」と言い出した。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて上の思惟者と中の防禦者とのために金錢と婦女とを私畜することを禁ぜようとした。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは私が秦泉寺へ送って進ぜよう」「それは有難うございますが、遠い処を、そんなことをしていただきましては済みません」「何、今晩は別に用事もないから、送って進ぜよう」「では、お詞に甘えますが」　女はこう云ってまた何か困ったような顔をしながら脚下に眼を落した。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことなら、負うて進ぜよう」　女は恥かしそうにして笑った。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして、神を信ぜよ。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、群臣は礼を重んぜよ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かしこに住みて即興詩を吟ぜよ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
