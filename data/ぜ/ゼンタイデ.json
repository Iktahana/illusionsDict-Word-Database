        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「故致数車無車」を「部分の総和は全体ではない」と訳しているのでも、当否は別としてやはり面白い。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだ全体で拍子をとるようにして小枝をゆさぶりながらせっせと働いているところは見るも勇ましい健気なものであった。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜軒のうちで三十円ずつ得してもこの部落全体では四百五十円になる。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはただ極端な一例をあげたに過ぎないが、この仮想的の人間の世界と吾人の世界とを比較してもわかるように、吾人のいわゆる世界の事物は、われわれと同様な人間の見た事物であって、それがその事物の全体であるかどうか少しもわからぬ。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お帰りなさいまし」　と簡単にいうと、奥さんは体全体で媚びながらいそいそと立ち上った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げおくれた連中だけで十五万本、だから大阪全体でどれだけの横流し（などといやらしい紋切型言葉だが）の煙草があるか、想像も出来ないくらいだ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "〜〜〜〜〜〜〜〜〜〜〜〜〜〜〜　無論、用語の問題は詩の革命の全体ではない。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」これじつに今日比較的教養あるほとんどすべての青年が国家と他人たる境遇においてもちうる愛国心の全体ではないか。",
              "citation": {
                "source": "時代閉塞の現状",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "〜〜〜〜〜〜〜〜〜〜〜〜〜〜〜〜〜　むろん、用語の問題は詩の革命の全体ではない。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この肉は鯨の全体でドコの肉に当るのかね」　サア事だ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と身体全体で、前川をグッと押した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "神戸で乗った時は全体で九人であったのに。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河岸地区全体でも最低最悪の地獄の馬車で、僕もネヴィル・シンクレアが入ったきり出てこないのではと心配している。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとはただ、沈黙と、静止と、夜とが、宇宙全体であった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると全体で百歩あることになる。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "――弱い、あまり正気でもない、あまりはっきりしないものであったが、――それでもとにかく全体であった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、――この声についての証言全体ではなく――その証言のなかの特異な点を、注意してみようじゃないか。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとがきに代えて　本書は、全体で一つのあとがきのようなものになっている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが柔らかさというか、だらしなさの度合いにおいて、本書はやはり「全体で一つのあとがき」にふさわしいように思う。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビル・アトキンソンが一台の小型マシンで世話を焼こうとするのに対し、坂村ＴＲＯＮはシステム全体でサービスに当たろうとする。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さながら天地震動という勢いで、久兵衛の家は勿論、その近所二丁四方は家屋も土蔵も物置も、みんな吹き飛ばされて滅茶滅茶になってしまいましたが、全体では四丁四方の損害でした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田駅に近付いたとき、彼女は、自分の左脇に腰をおろしている男が、顔全体で痛さを堪えながら指先を握っているのに気がついた。",
              "citation": {
                "source": "指",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるから、人の一時の所思や所言や所為を捉えて、その人の全体であるかのように論議して批判するのはもとより当を得たことではない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の作用の中で、極めて小さい、極めて短い、極めて弱い、極めて薄い地位を持つのが人事の全体である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "賞の出し方の無方針極まるやり方や、毎回厳選主張を標示しながら、厳選、厳選をいつも会全体でなく、個人にもつてゆくやり方は会を全体的に進歩せしめることが出来ないだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風でこの伊豆には模範村と表彰された村が全体で何個村とかあると云う事であった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の力で、どんなことでも出来るような不正な不当な社会全体です。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "娯楽室組は、概して平和に暮らしていたが、寮全体では、つねになにかが起こり、だれかが罰せられていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ならその生徒を同級生が擯斥するか、ブン殴るところを、反対に級全体で同情して先生に迫り、「罰した理由」を責め問うたという事実がある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局帆村探偵が到着した結論では、　――この漫画の暗号だけがこの密書の中に書かれている通信文の全体ではない！",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
