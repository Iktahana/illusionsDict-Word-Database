[
  {
    "uuid": "8639a4ed-5075-5a64-a56d-f658891260be",
    "entry": "前人",
    "reading": {
      "primary": "ぜんじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "predecessor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "過去未來の因果の絲を斷ち切り、純粹刹那の愛と美とを、ぴつたり正確に固定せしめようと前人未踏の修羅道である。",
              "citation": {
                "source": "檀君の近業について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一評者が「一時は紀行文は前人の未だ踏まない深山幽谷の奇景を、紹介するのを職とするような傾向であった、いや今でも、そういう好奇心で、紀行を書いている人もあるようだが、これはつまらぬことだろう」と言って、明らかに私に当たっている。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いなことには、映画という新しいメジウムの世界には前人未到の領域がまだいくらでも取り残されている見込みがある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は、以前人間であった時とそのままそっくり生れ変るのではないでしょうが、以前人間であった当時のある経験の一部分が残っていて、相当役に立つものと私は信じております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "応接間を出ると左は玄関と、以前人力車を入れたらしいタタキの間がある。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども弘前人は頑固に何やら肩をそびやかしてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども其の文章｜亦おのずから佳、前人評して曰く、醇博朗」］、沛乎として余有り、勃乎として禦ぐ莫しと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に名言多きは、前人既にこれを言ふ。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは皆前人の植福の結果である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に前人の植福の庇陰に依る、吾人も亦植福の事をなして子孫に貽らざる可からずである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の聖代になってから以還、分明に前人の迹を踏まない文章が出でたということは、後世に至っても争うものはあるまい。",
              "citation": {
                "source": "鴎外漁史とは誰ぞ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして予はこの好処の我を動かすことが、昔前人の好著を読んだ時と違わぬことを知った。",
              "citation": {
                "source": "鴎外漁史とは誰ぞ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしくは居るとしても、天下を憂い、国を想う志士の気骨が筑前人には欠けていたのかというと、ナカナカそうでない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "前人未踏の、奇想天外の手であつた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時試験官は熟れた題では受験者が前人の文章を模倣するの弊があると思って、力めて変った題を出した。",
              "citation": {
                "source": "阿宝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは何か書いて見ようと思っているのだが、前人の足跡を踏むような事はしたくない。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此事は前人にかゝる言を爲したものは無いが、精しく墨子を讀んだ人ならば自分の言を首肯して呉れるだらう。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此事は前人が墨子を論ずるに當つて誰も指摘して居らぬが、孫子が女兵を調練して軍律を用ゐんとした談と共に、周秦の間の世相に就いて或種の考を抱かせる。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは皆｜前人の植福の結果である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に前人の植福のお陰である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなので、全氏のこの章の解説は別に前人に加えるところは無いに近い。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "感謝す、予はこの驚絶、駭絶の意識をば、直接に、端的に、神より得たり、一毫一糸だに前人の証権を媒とし、若しくは其の意識に依傍したる所あらざる也。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "後深く内部生活に沈潜するに及びては、一切前人の証権を抛ち去つて、自ら独立にわが至情の要求に神の声を聴かむとしぬ。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る人は前人が残し置いた材料を利用して、愛の（即ち個性の）表現を試みようとする。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又或る人は愛の純粋なる表現を欲するが故に前人の糟粕を嘗めず、彼自らの表現手段に依ろうとする。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
