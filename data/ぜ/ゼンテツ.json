      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "former men of wisdom and virtue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "我々は前哲の教えに耳を傾け、その知恵を現代に活かすべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の思想は、多くの前哲の哲学から影響を受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史書には、国家を導いた前哲たちの功績が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここに素朴といふのは、前哲學的といふことであつて、單に我々の日常の經驗ばかりでなく、また科學の立場をもいふのであり、從つてそれは一層適切に自然的な態度（〔natu:rliche Einstellung〕）と名附け得るであらう。",
              "citation": {
                "source": "認識論",
                "author": "三木清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
