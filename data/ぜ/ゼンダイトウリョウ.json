      {
        "index": 1,
        "gloss": "previous president (immediately preceding the incumbent)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
