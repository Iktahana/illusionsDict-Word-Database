        "examples": {
          "standard": [
            {
              "text": "頭部の保護において、前頭骨は非常に重要な役割を果たす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "CTスキャンで、彼の前頭骨に微細なひびが見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人間の頭蓋骨は、前頭骨を含め複数の骨が組み合わさってできている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "創傷は、顱頂骨と前頭骨の縫合部に孔けられている、円い鏨型の刺傷であって、それが非常なお凸であるために、頭顱の略々円芯に当っていた。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニウジヤアシイにては人類の前頭骨に石鏃の立ちたる儘の物を發見し、チリのコピアポにては人類の第二の脊椎に石鏃の立ちたる儘の物を發見し、フランスのフヲンリヤルにては人類の脛骨に石鏃の立ちたる儘の物を發見したる事有り。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
