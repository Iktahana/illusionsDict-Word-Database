[
  {
    "uuid": "8106a00c-b040-5d20-8a0f-5fc431803385",
    "entry": "前置",
    "reading": {
      "primary": "ぜんち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
