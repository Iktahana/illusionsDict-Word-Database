        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その前夜、大使パット氏は、ＡＫのスタディオから全国中継をもって、忠魂記念塔の到着を披露し、「――どうか御安心下さい。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていずれも昨年ＪＯＡＫから全国中継で放送されたものである。",
              "citation": {
                "source": "『十八時の音楽浴』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "『百年後の世界』はＡＫから「子供の時間」に全国中継で放送したものの原稿である。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは同時に全国中継でもって放送されたが、スピーカーの前に集った群衆は早慶戦以上だったという。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは全国中継です」　といって彼は、パンフレットの頁を一枚めくった。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は昼の「昇給」が全国中継になる（70）。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホールで今日全国中継放送する「或る恐ろしきスパイ」のテストをするため。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
