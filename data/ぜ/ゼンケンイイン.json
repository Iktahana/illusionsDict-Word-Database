          "literary": [
            {
              "text": "一そ徳山あたりからというのだそうで、それには岩本のおばさんが全権委員の由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤、陸奥の全権委員に衆望を落すことなく、任務を尽させようとして、国を強く見せかけるという立派な仕事もしたのである。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "各国の全権委員のあいだで、カイゼル処罰の議論がもちあがった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
