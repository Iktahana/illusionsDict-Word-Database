          "literary": [
            {
              "text": "捉へられなければ全力を挙げることが出来ないと言ふであらう。",
              "citation": {
                "source": "生滅の心理",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "捉へられなければ全力を挙げることが出来ないといふ若い心よりは、ぐつと理解のある聡明な活力を揮ふことが出来るのである。",
              "citation": {
                "source": "生滅の心理",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "津留木署長は青眼鏡の賊の捜索を担任している戸塚警部に全力を挙げるべく命じた。",
              "citation": {
                "source": "黒白ストーリー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論できる限り、それ等の材料に補修改造を施し、且つ真理に対する新見解を、これに注入すべく全力を挙げる。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
