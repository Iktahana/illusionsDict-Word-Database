    "definitions": [
      {
        "index": 1,
        "gloss": "end of life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "同時にばたばたと飛び立った胸黒はちょうど真上に覆いかかった網の真唯中に衝突した、と思うともう網と一緒にばさりと刈田の上に落ちかかって、哀れな罪なき囚人はもはや絶体絶命の無効な努力で羽搏いているのである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の一生を小さい陥穽に嵌め込んでしまう危険と、何か不明の牽引力の為めに、危険と判り切ったものへ好んで身を挺して行く絶体絶命の気持ちとが、生れて始めての極度の緊張感を彼から抽き出した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一時間半ばかりたって遂に絶命した。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう絶体絶命の暴れ方をしだした。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "数時間後に絶命した後にもまだ涙は見せなかった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勧進帳」で弁慶が泣くのでも絶体絶命の危機を脱したあとである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきらかに善人、女将あるいはギャング映画の影響うけて、やがて、わが悪の華、ひそかに実現はかったのではないのか、そんな大型の証拠、つきつけられては、ばからしきくらいに絶体絶命、一言も弁解できないじゃないか、ばかだなあ、田舎の悪人は、愛嬌あって、たのもしいね。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "良助どんには気の毒ながら、黒田五十五万石の絶体絶命を非人の俺が知った事かえ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物や動物が、無知無学なまま生きよう生きようとする切ない努力によって、今日のように美しい形態にまで進化して来たように、能は芸術的に生きよう生きようという絶体絶命の努力のうちに、世間の一切を無視した全くの無知無学のまま今日の程度にまで進化して、まだまだ進化して行きつつ在る舞台芸術である。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶体絶命の苦悶でついに自殺を思うまでに立ち至る記事が何ゆえにおかしいのか不思議である。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "逞ましい雄獅子が自分と妻の致命的な傷口を嘗め労わりつつ呻く、絶体絶命の呻きです。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士と自分は、いま絶体絶命の試錬を受けつつあるのだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の一生を小さい陥※に嵌め込んで仕舞う危険と、何か不明の牽引力の為めに、危険と判り切ったものへ好んで身を挺して行く絶体絶命の気持ちとが、生れて始めての極度の緊張感を彼から抽き出した。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はハツト思つて一時は遁出さうとしたが、今更遁げたとて何の甲斐があらう、もう絶體絶命と覺悟した時、猛狒はすでに目前に切迫した。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と文彦は側に打ち仆れている助手の杉田を抱き起して見ると、もうすでに絶命れて身体は氷のように冷え切っている。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋山男爵はこの言葉を聞いて、「チェッ残念※」と一言叫んだと思うと、急所の傷手にはかなく絶命して終った。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一尺五寸、剣を逆手に握れる海賊の一人は、眼を怒らして余を目懸けて飛び込まんとす、もはや絶対絶命なり、余は思わず呀と叫んで船底に逃げ込まんとせしが、その途端！",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児のうちから知ってもおろうが、絶体絶命の旱の時には、村第一の美女を取って裸体に剥き……百合　ええ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この拷問をうけるものは、はじめは惣身が赤くなり、更に暗紫色に変じて冷汗をしきりに流し、それがまた蒼白に変じるときは即ち絶命する時であるといい伝えられているので、皮膚に蒼白の色を呈するのを合図にその拷問を中止することになっていた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しながら今や絶體絶命の場合となつて、何方とも身の振方を付けなければならぬ破目に押付けられてゐる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから彼は、殺人の嫌疑を受けた星田が、警視庁の裏手で自動車から降りた時にヤット気付いた最後的なヒントを、絶体絶命の思いで村井に伝えて貰おうとした。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一知にとって絶体絶命の最後の楽しみを奪われる宣言に外ならなかったからであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣くにも泣かれぬ絶体絶命になった春夫さんは、この時思い切って高らかに叫びました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも構わず元来吾輩は何だと考えて行くと、もう絶体絶命にっちもさっちも行かなくなる、其所を無理にぐいぐい考えると突然と爆発して自分が判然と分る。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶体絶命の承諾といふ境地には入つた形になつて居たんだな。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝孺｜慨然、絶命の詞を為りて戮に就く。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等はわたし共が來た時には全く絶命してをりました。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「たしかですとも‥‥」　と、醫師はソオルの問ひに答へて、「二人の死體の模樣では、男爵が戸口をはひつた時には全く絶命してゐたことでせう。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お勝は絶体絶命であった。",
              "citation": {
                "source": "放生津物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶体絶命の人間が二人出来ているんだのに――」　と、あとは力も脱けて言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
