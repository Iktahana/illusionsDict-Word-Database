    },
    "definitions": [
      {
        "index": 1,
        "gloss": "muzzle loading",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この装置も主意は前装置と全く同様である。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内山が不思議がるのもその道理で、これは「引落し式」と名づけられた前装の六連発であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "三輪の神杉の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどはもっと愉快な話をしよう」　博士は、とつぜんそういった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はははは」　ポコちゃんは、とつぜんそういう結論をこしらえあげた。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなところで何をしているんだい」　とつぜんそう呼びかけられて、秀之進ははっとわれにかえった。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が身命をうちこむのは、家をまもり良人に仕えることだけです、そこから少しでも心をそらすことは、眼に見えずとも不貞をいだくことです」「母上さま」　加代が、とつぜんそう云いながらひれ伏した、つきあげるような声だった、そしてひれ伏したその背がかすかに顫えた。",
              "citation": {
                "source": "日本婦道記",
                "author": "梅咲きぬ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
