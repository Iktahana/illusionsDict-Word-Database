  {
    "uuid": "b5df9d8d-f24a-524f-a758-671f1cfbc7db",
    "entry": "禅僧",
    "reading": {
      "primary": "ぜんそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Zen priest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この点では禅僧と収賄議員との間にもいくらか相通ずるものがあるかもしれない。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "足利時代に禅僧が輸入したような話があるかと思うと、十四世紀にある親王様が輸入された説もある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はある日、与えられた詩文の題に就いて調べる必要があって、巌頭という偉い禅僧の伝記を読んだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一七課　誘惑　むかし、あるところに老婆がありましたが、一人の禅僧に庵を建ててやり、衣食を送って修業を資けておりました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで老婆が思うのには、もうあの禅僧もかなり修業が積んだであろう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆はどんなメンタルテストをしたかと言うと、自分の腰元の中でも、年頃で一番美人の女を選びまして何やらそっと命令け、かの禅僧の修業している庵室へ行かせました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへずかずかと寄って行って彼女はいきなり禅僧にもたれかかり、「あなた、こうして、どんな気持ち」と言いました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅僧の謹厳な様子に、感心すると思いの外、老婆は大変怒りまして「思いの外俗物の僧を永らく優待していた。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが本当の仏教が勇ましく私たちに教え勧める処世法であり、先刻の禅僧といえども、この事を体得しなければ俗人に劣ると言わねばなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗は古禅僧の徳山の意気である、それも慥におもしろい。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其六　何事に罵り騒ぐぞ、と上人が下したまふ鶴の一声の御言葉に群雀の輩鳴りを歇めて、振り上げし拳を蔵すに地なく、禅僧の問答に有りや有りやと云ひかけしまゝ一喝されて腰の折けたる如き風情なるもあり、捲り縮めたる袖を体裁悪げに下して狐鼠と人の後に隠るゝもあり。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "円通の方は無頓着、飄逸という方です、或る人が此の禅僧に書を頼んだ事がありました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどうやら、二禅僧の耳にも入りました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「私は摂津国法福寺の円通と申す禅僧、これなるは紀州光明寺の法眼と申す連れの僧、御主人も在らばお目にかかり度い」　と堅苦しく申入れました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は如何に禅僧の如くに悟つてのけんと試むるとも、我が心宮を観ずること甚深なればなるほど、我は到底悟つてのけること能はざるを知る、風流の道も我を誘惑する事こそあれ、我をして心魂を委ねて、趣味と称する魔力に妖魅せらるゝに甘んぜしめず。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯だ夫れ老荘の、心を以て太虚となし、この太虚こそ真理の形象なりと認むる如き、又は陽明派の良知良能、禅僧の心は宇宙の至粋にして心と真理と殆一躰視するが如きは、基督教の心を備へたる後に真理を迎ふるものと同一視すべからず。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来義元は兄氏輝が家督を継いで居るので自分は禅僧となって富士善徳寺に住んで居った。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "其六　何事に罵り騒ぐぞ、と上人が下したまう鶴の一声のお言葉に群雀の輩鳴りを歇めて、振り上げし拳を蔵すに地なく、禅僧の問答にありやありやと云いかけしまま一喝されて腰の折けたるごとき風情なるもあり、捲り縮めたる袖を体裁悪げに下してこそこそと人の後ろに隠るるもあり。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争に出て却って丈夫になった者がどれほど多くあるか知れないし、有能な禅僧などは風邪にも余りかからないという面白い現象が有る。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "松吟庵は閑にして俳士髭を撚るところ、五大堂は寂びて禅僧尻をすゆるによし。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし、善光という禅僧があった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ頃に、蘭坡和尚という禅僧があった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのひそやかな世界では、床の間に懸つた古い禅僧の法語の軸物。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅僧と扇８・30（夕）　熊本といふところは、海と市街との間に屏風のやうな山がぬつと衝立つてゐるので、凉しい海の風はそれに遮られて吹いて来ず、夏になると、市街の人はフライ鍋で熬りつけられる肉のやうに、真赤になつて汗をかいてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚は多くの禅僧と同じやうに酒が大好きだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上人は言ふ迄もなく越後｜国上山の五合庵に棲むでゐた名高い禅僧である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚い弾き丸は、ある時は禅僧のやうな露伴の懐中に飛び込み、ある時は山狗のやうな緑雨の襟首に滑り込み、またある時は気取屋の紅葉の鼻先きを掠めて飛んだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅僧と靴　つい先日亡くなつた丹波国何鹿郡東八田村安国寺の住職梅垣謙道和尚は、今一休と言はれただけに、いろんな逸話に富んだ坊さんであつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "托鉢の途中なので、胸には南禅僧堂の頭陀袋をかけ、足には草鞋を穿いてゐた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある禅僧の語録で古本屋から見つけて来たという古本までも青木は取出して来て、それを捨吉に読んで聞かせた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
