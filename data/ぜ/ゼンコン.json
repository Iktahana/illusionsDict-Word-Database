[
  {
    "uuid": "a09614ba-499c-5ea8-94f9-92c3e6e5565f",
    "entry": "善根",
    "reading": {
      "primary": "ぜんこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
