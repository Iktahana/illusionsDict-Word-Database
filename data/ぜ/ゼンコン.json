    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good deeds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いや、追ってその許に、恩賞の御沙汰これあるよう、僕から上申を致そう、たしかにそれが見たいものじゃが、というに亭主はほくほく喜び、見事善根をしたる所存、傍聞する女房を流眄に懸けて、乃公の功名まッこのとおり、それ見たかといわぬばかり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの無限者のうちへはおいでなさい、なか／＼の善根家で、たくさんくれますよと教へて下さつた深切な人もあつた。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "二生の人というのは転生を信じた印度に行われた古い信仰で、大抵二生の人は宿智即ち前生修行の力によって聡明であり、宿福即ち前世善根の徳によって幸福であり、果報広大、甚だ貴ぶべき者とされて居る。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "真暗な地獄の底から一目貴女を拝むのを、仏とも、天人とも、山の端の月の光とも思って、一生の思出に、莞爾したいと云うのですから、お聞届け下さると、実に貴女は人間以上の大善根をなさいます。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "新内と商人と、ふたりの生活人に自信を与えた善根によっても、地獄に堕ちるうれいはない。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」四十四　美女は世にも嬉しげに……早や頼まれて人を救ふ、善根功徳を仕遂げた如く微笑みながら、左右に、雪枝と老爺とを艶麗に見て、清しい瞳を目配せした。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の宮に入りたる真理は、未だ以て其人を生かしむるものにあらず、又た死せしむるものにあらず、喝、第一の宮に善根を種き懺悔をなすは、凡人の能はざるところにあらず、この凡人豈に大遠に通ずる生命と希望とを、いかにともするものならんや。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しでも善根を積んで、罪障を消滅したいと思っている長者は、これを見ると己の家へ泊めて病気の手当までしてやった。",
              "citation": {
                "source": "鮭の祟",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長吉、そちはよほど、人に善根を施しているのだな」「善根とは……」「人に情をかけたことじゃ。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人も語らず、またかかる善根功徳、人が咎めるどころの沙汰ではない、もとより起居に念仏を唱える者さえある、船で題目を念ずるに仔細は無かろう。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾時辟支仏あって城下に来りしを、かの五百｜牧牛人供養発願して、その善根を以てたとい彼女身死するとも残金五百銭を与えて、約のごとく彼と交通せんと願懸した。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "履工これは畏れ入ります、もとより手と足ばかりの貧乏人故何たる善根も施し得ませぬ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "善根を蒔く為につかふといふのか、これはしたり、それはまた大したこつたな、さうともそれなら、うつちやるもんぢやないとも。",
              "citation": {
                "source": "黄金機会",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ着き升と母は他出して留守でしたから、早速祖父に見せますと、これも別段よく買つて来たとも、わるかたつともいはず、善根を蒔く為につかはうといつた言葉を無にしたといつて驚ろく様子も有ませんでしたが、さりとて私は心の中に何となく咎められてソロ／＼風琴を買つたことが嫌になつて来｜升た。",
              "citation": {
                "source": "黄金機会",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして、畿内から、中国を通して、ひたすら善根を積むことに腐心したが、身に重なれる罪は、空よりも高く、積む善根は土地よりも低きを思うと、彼は今更に、半生の悪業の深きを悲しんだ。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "市九郎は、些細な善根によって、自分の極悪が償いきれぬことを知って、心を暗うした。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "善根を施しておきゃ、来世は人並みの背に産んでくれるに相違ねえから、もっと仏心出して相手になれよ」「…………」「耳ゃねえのか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、だんなを前にして講釈するようですが、こじきに善根を施して、観音さまへお参りをすまして、いいことずくめのそのけえり道にお会い申す日の出の景色ぐれえいい心持ちのするものは、またとねえんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらは日ごろ善根を施してあるんで、ちゃあんとこういうとき、暑くねえようにお天道さまが特別にかばってくださるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "なさけも善根も銘々の力に能うかぎりで済ませればよし、程を過ぎたら却って身の禍いになる。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が善根するのに、なぜまた俺が礼を言はんければならぬのか。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月十七日　曇――時雨、行程四里、川口在善根宿。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何時迄も居り度うござります」「成程」　と僧は復笑って「併し私にはそうは見えぬ、お前は何うやら厭飽たらしい」「いえいえ、そんな事はございません」「では何故善根を積まぬのじゃ？",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「え、善根と仰有いますと？",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたの善根は、ちやうど、ルカ伝にも言つてある、第十三章……十三……叩いてゐますよ、ほんとに叩いてをる！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「善根を積んだと云う気がするだろう？",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり仏性の藤六が、閑暇さえあればソンナ善根をしているものと思って誰も怪しむ者なんか居なかった。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼岸仏参し、施しをなし、善根をすべしとある。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜあいつは、とつぜんこんなところへ姿をあらわしたのか。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつぜんこんなお便り差しあげ、さぞ意外に思召すことゝ存じます。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
