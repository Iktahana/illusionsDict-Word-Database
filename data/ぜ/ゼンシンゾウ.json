    "definitions": [
      {
        "index": 1,
        "gloss": "full-length portrait or statue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勿論、私は常に全身像を製作しろといふやうなことを云つてゐるのではなく、トルソも結構、手だけでも結構だが、トルソならトルソで、それが全一的な感じを与へるものではなければならぬと云ふのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "居心地よく飾られた部屋で、加えて疑念が一気に強まったのは、見ると、炉棚の上に妻の全身像の写真が飾ってあったからです。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどキュヴィエが骨一本の検討から動物の全身像を正しく描けるのと同様、観察する者は、ひとつながりの出来事の一環さえ完全にわかれば、前後含めたすべての輪を狂いなく言い当てることができよう。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "方形をなして、いろ／＼なる全身像、半身像を据ゑつけたる、白塗の※廊のいと高きが、小き園を繞れるあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「君のまだ見ない絵がもう一つある」そして一枚の被覆をさっと取り除けると、彼は侯爵夫人アフロディーテの全身像を現わした。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一見純金に見え、実はメッキに違ひない高さ一尺程のナポレオンの全身像であつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でもタイムスと「Ｗ」日報は「Ｗ」大のＦＷの全身像を、その傍らに併載して、「無保険の選手、日本人、Ｈ・大津の当日の奮戦振りは恰も満洲の戦塵に全く自己を忘れて戦ひ抜いてゐる日本兵士の大和魂を目のあたりに見る慨があつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絵はどれもこれも、昔の勇士や、ギリシアの将帥たちの全身像の銅版画ばかりであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後からその人の全身像がじっとこちらを見ている人と対談するのはつらいことである。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそ裸体の全身像を描いて戴きませうかしら。",
              "citation": {
                "source": "静物",
                "author": "十一谷義三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨美しい熱もゆる、全身像を更めて、私は胸に描きます。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　装いをこらした若い女の全身像である。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "元々はそれがぼくといふ相手なりぼくに先づ印刷紙面の愛情を通じて浮かび上つた「鏑木清方」の蜃気楼は、やがて時と共に鮮明確実となり、通夜物語の丁山の五寸に充たない木版立姿が樋口一葉の全身像にまで盛り上る、「清方」の歴史。",
              "citation": {
                "source": "鏑木さん雑感",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕ハ結婚後始メテ、自分ノ妻ノ全裸体ヲ、ソノ全身像ノ姿ニオイテ見タノデアル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はしばしば自分の素裸の体をこの人に見られ、何十回となく写真にまで撮られているのであるが、自分は彼の素裸の体を、こういう角度で全身像の形においてしげしげと観察したことはない。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が裸でいる時はできるだけぴったり寄り添って抱き着くようにし、全身像が見えないようにした。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の構内に立つ、若い女性の全身像の作者ではないか。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性の全身像が立っているところまで、足早に歩いて七分かかった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「直子さんの裸の全身像を僕は描きましたけれど、現物とはまるで違っていました。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもう一枚のカードには、誰が見ても小夜子に見える女性の全身像を鉛筆で見事に描き、彼女の前に幼い少女をひとり立たせ、その肩に小夜子の両手の指先をかけさせた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦の長方形の画面のなかに、若い女性の全身像が描いてあった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "異邦人の入口の前に立っている、美樹子の全身像だ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつに可愛い、頭の良さそうな、姿のいい十二歳のホミが、カメラのレンズに視線をむけて、にっこりと微笑している全身像だ。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚目とおなじ下着的なスポーツ・ウエアを身につけ、クロゼットのドアらしいものに軽く背を預けて立っている、後藤美代子の全身像だ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡のなかには彼女の正面全身像が虚像として映っている。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "花壇から少し離れた正面に、一メートルほどの高さの台座に載せて、若い女性の等身大の全身像が立っていた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりの若く美しい女性の等身大の全身像、という結論になったのです。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "掲載されていたのは全身像だった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時のアメリカで最先端だったはずの女性ファッションを身につけてポーズをとった、ひとりのモデルの全身像だ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在、ボルドー市キャンコンス広場に立っている全身像の顔はこれをモデルにしたものと思われる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
