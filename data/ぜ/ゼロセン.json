          "literary": [
            {
              "text": "だが「零戦だって三度作りなおしている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「零戦も三回作りなおしたんや。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "零戦闘機のような技術的製作でも、四十年以上義務教育のある国家の文化雰囲気でないと製作できなかったそうである。",
              "citation": {
                "source": "図書館法楽屋話",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「『零戦』のような飛行機ができるためには、五十年位義務教育が行われている、文化の高い国でないと出来ない。",
              "citation": {
                "source": "図書館法の成立",
                "author": "――燃えひろがる火は点ぜられた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「敵のＢ29が何だ、われに零戦、はやてがある――敵はつけあがっている、もうすこし、みんなもうすこしの辛棒だ――」　と絶えだえの熱い息。",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
