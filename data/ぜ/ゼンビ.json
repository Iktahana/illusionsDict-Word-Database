    "definitions": [
      {
        "index": 1,
        "gloss": "completeness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "貧景全備　入梅の日、雷雨至り屋漏ること滝のごとし。",
              "citation": {
                "source": "貧を記す",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "写して意形を全備するものは上手の作なり。",
              "citation": {
                "source": "小説総論",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "意形を全備して活たる如きものは名人の作なり。",
              "citation": {
                "source": "小説総論",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に三十巻全備の本に宋槧と元槧とがある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ金沢文庫の零本第一巻の貴いことは論なく、次に三十巻全備の書としては、北宋槧本の未だ世に出でざる間は、元槧本を以て第一に推さなくてはならなかつたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち誰にでも好かれる資質を全備している。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども就中英は海軍の全備せるを以て、直に米国の大西洋に対したる海岸の諸港を襲はるる事疑なしと云へり。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "是を火車落とて宝物とする由来は、むかし天正の頃雲洞庵十世北高和尚といひしは学徳全備の尊者にておはせり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
