[
  {
    "uuid": "3e2ead85-772b-5520-a252-0d5ca90ddda4",
    "entry": "善美",
    "reading": {
      "primary": "ぜんび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
