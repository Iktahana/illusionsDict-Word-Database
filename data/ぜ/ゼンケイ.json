        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ホームズに目をやると、その顔はこわばり、極度の興奮のため前傾姿勢で身構えている。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "人影が部屋の中へはいって来て、前傾りに床の上へ仆れたのである。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "房一にはしなやかなだが強い張りのある首が疾駆の時にどんなに強く前傾し、どんなに直線的になるか、どんなに風を切り、どんなに躍動するか、まざまざと目に浮ぶやうであつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
