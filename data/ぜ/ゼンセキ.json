          "literary": [
            {
              "text": "ただ陳慧君だけが、女のなかでは一人、全席の話題の中心にも言葉を出すのでした。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "由緒ある大広間は真夜中の十二時に全席が食事中だ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "この飛行機は、全席が禁煙席だった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
