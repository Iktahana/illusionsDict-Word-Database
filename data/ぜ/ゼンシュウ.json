        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "going around the entirety (of a place)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "壁の全周囲は二十五ヤードを超えていなかった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に新しき彼女等は、自己と自己の全周囲との関係を自覚したのであった。",
              "citation": {
                "source": "新しい女",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "直径三十メートル、高さ十五メートルに及び、全周に渉って背の低い拱道が口を開け、丸天井の対称性を損ねる形で唯一拱道を欠く部分には高さ四メートル近いアーチが洞穴のように黒々と口を開いていた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなふうに　まけても　かっても　こだわらないで　よろこんで　いるのが、ぜんしゅうと　いう　しゅうしの　えらい　ところです。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "びょうぶの　とら　そのころは、ぶっきょうの　なかでも　ぜんしゅうが　とても　さかんでした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜんしゅうを　しんこうする　ひとたちは、もんどうが　大すきでした。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜんしゅうでは　さかな　にく　からいもの、おさけ　などを　たべたり　のんだり　することを　きんじています。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
