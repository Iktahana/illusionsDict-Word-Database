    "definitions": [
      {
        "index": 1,
        "gloss": "woman of unmatched beauty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
