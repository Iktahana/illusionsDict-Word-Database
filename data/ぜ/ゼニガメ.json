        "examples": {
          "standard": [
            {
              "text": "池で小さな銭亀が甲羅干しをしているのどかな風景だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お祭りの縁日で、子供が欲しがったので銭亀を買ってあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "銭亀は比較的飼いやすく、ペットとしても人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ちやうど、こどもが銭亀を見つけたやうに、水に泳がしたり、桶の椽に匍はしたり、仰向けにしてみたり、自分と同じ大きさの人間でないのが気になるのだ」　小布施は欧洲の桂子から精力的に書き寄越した新興画派の紹介なり、自説の感想なり、意見なりに、どの位悩乱され衝動されたか知れないのであつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭亀ほどのわりがらこに結って、小楊子の小々太い位なのではあるが、それこそ水の垂れそうな鼈甲の中差と、みみかきのついた後差しをさした。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲虫といえばいくら大きくても、せいぜい銭亀ぐらいのものだった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
