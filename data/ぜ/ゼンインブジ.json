        "examples": {
          "standard": [
            {
              "text": "「全員無事です！」という救助隊の報告を聞いて、家族たちは安堵の涙を流した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "激しい火災に見舞われたが、幸いにも建物の中にいた人は全員無事だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "登山中に天候が急変したが、ガイドの適切な判断により全員無事で下山できた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かくして渡河の先陣三百余騎は全員無事対岸にたどりついた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど安土のセミナリヨは覆滅したが、全員無事に京都へ逃げて来て、やがて高槻の城にセミナリヨを移した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、諸君、全員無事で、元気でまた会えて嬉しいですな。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
