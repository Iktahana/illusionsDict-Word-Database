        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "カントは、個人的な欲求に関わらず、人間が常に従うべき道徳的な法則を「絶対命令」と呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「自分の行動の原理が、そのまま普遍的な法則になることを望めるか」という問いが、絶対命令の核心である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "倫理学の授業で、損得勘定に基づいた仮言命法と、無条件の義務である絶対命令の違いを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
