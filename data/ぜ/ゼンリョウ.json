[
  {
    "uuid": "c14d3ad6-493c-558c-9e2c-100df5869c12",
    "entry": "善良",
    "reading": {
      "primary": "ぜんりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
