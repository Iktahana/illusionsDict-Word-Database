    "definitions": [
      {
        "index": 1,
        "gloss": "taking something as absolute truth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
