      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Zen temple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "うなだれて、そのすぐ近くの禅林寺に行ってみる。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬祖の弟子百丈（七一九―八一四）は禅宗｜叢林を開創し、禅林清規を制定した。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅林の組織はこういう見地から非常に意味深いものであった。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖師を除いて禅僧はことごとく禅林の世話に関する何か特別の仕事を課せられた。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "大門を這入ると、半丁ばかりは樹木は繁茂致して、昼さえ暗く、突当りに中門がございまするが、白塗りにて竜宮の様な妙な形の中門で、右の方はお台所から庫裏に繋っており、正面は本堂で、曹洞派の禅林で、安国山総寧寺と云っては名高い禅寺でございます。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅林寺のは、製作動機から見れば、稍後出を思はせる発展がある。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅林寺の方で見ると、二脇士は山の曲に関係なく、山肌の上を降つて来る様に見える。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅林寺のは、製作動機から見れば、稍後出を思わせる発展がある。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅林寺の方で見ると、二脇士は山の曲に関係なく、山肌の上を降って来る様に見える。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はこのたびの出陣に当り、余が修学の禅林の池底に秘かに埋蔵して出発すべき秘密の誓文の文案をねっていたのである。",
              "citation": {
                "source": "決戦川中島　上杉謙信の巻",
                "author": "――越後守安吾将軍の奮戦記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう因縁があって法然歿後の法要の導師を勤め前非を懺悔し、念仏の行怠りなく、建保四年｜閏六月二十日に七十二の年で禅林寺のほとりに往生を遂げられた。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから幾らも立たない頃に墓参に行きましたが、まだ道順もよく分らず、吉祥寺で省線を降りてから、禅林寺まで行く道の細い流の中で障子をせっせと洗っているのを、秋も深くなったと思いながら、佇んで見ていましたが、傍に小綺麗な百姓家があって、荒い生垣から中がよく見えます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の禅林寺は、本堂の藁葺は崩れかかり、鐘楼の鐘は土に置いてあり、ひどく荒れ果てた様子でした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹洞派の禅林である。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぞわたしに、急な用事でもできたのでございますか」　若松屋惣七方のうら手、小石川上水堀の端にある金剛寺は、慧日山と号し、曹洞派の名だたる禅林だ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "九老僧　　　　　　一　そのころから、一空さまは諸国の禅林をまわって、相良寛十郎はもとより、おゆうとも音信不通であったというのだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをあわれむゆえに自分は大宋国の禅林の風を記しておこうとするのである（正法眼蔵弁道話）。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を出づれば禅林に嘯く風が、「道え道え」と言うが如く聞える。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都禅林寺や金戒光明寺のものなど代表的であろう。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし茶祖が今甦ったら、あの禅林で説かれる「婆子焼庵」の物語りのように、早速茶室に火を放って茶人達を外に追いやるでしょう。",
              "citation": {
                "source": "民藝とは何か",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅林寺の鐘の音が、吠える風の中で二更を告げた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時宗に、一語を贈って激励した仏光禅師を見ても、当時の禅林の気骨稜々な風は窺える。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその自然な行為のうちには、故信玄の恩顧に対する厚い情誼もあったし、平常、禅林の堕落に対して訓えたい気もちもあったに相違ない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、禅林のうちには、詩画をたのしむ者が多く、およそ禅僧であって詩も絵も解さないという者はなかったのではあるまいか。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、剣の悟道の話は、即、禅に通じるし、禅林の佳話は、また、そのまま剣人のそれに共通する。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚堂和尚讃「二天画祖師像」について　　　――武蔵と禅林との交渉の宿題　わかっていそうで、皆目わかっていないのが、武蔵と禅門との交渉である。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ首をひねった揚句、ありあわせの禅林諸家の名や、仏家人名辞書までひっぱり出してみたが「東寔」という僧名はいっこう見あたらない。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨相寒厳といった風貌の人で、逸事も非常に多く、わけて、後水尾上皇の御信任厚く、古来禁中での内裏殿上の説法は、禅林では愚堂を以て嚆矢とするといわれている。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ見ても、いかにも素朴な、禅林の人によくあるいかつさや誇筆の風もなく、素直で淡々たるものが、そのありのままな墨色と共に、見ていていい気もちを与えてくれるのである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか折があったら、そんな方面からも、武蔵と禅林との交渉の謎を、もう少し闡明してみたいと思っている。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
