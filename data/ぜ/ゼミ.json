        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "きょうは快晴とはいきそうもないが、スズメやアブラゼミは、もう仕事にかかっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アブラゼミと鳥の啼き声にまじって、けっこう頻繁に車の音がきこえてくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉市は僕の腕の中で、クマゼミのやうに激しく泣き出した。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昔ペルシャ（現今のイラン）にゼミールという王さまがありました。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "年若きゼミール王は、「即位」の大典をあげるや、ただちに天下の学者に命じて、最も精密なる「人類の歴史」を編纂せしめたのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し大袈裟に言つたら十二頭の駱駝の背に積み分けてもいゝ程｜嵩高な書物で、福田博士は波斯王ゼミイルの御殿へ、人間の歴史を献上に出かけてゆく学者の一｜人ではあるまいかと思つた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後私はドイツに留学した時、リッケルト教授のゼミナールに出席し、左右田博士のリッケルト批評について報告したことがあるが、リッケルト教授も左右田博士も共に喜ばれた。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "リッケルト教授のゼミナールは自宅で行なわれた。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのゼミナールで左右田喜一郎先生のリッケルト批評について報告したが、教授も左右田先生のことはよく記憶しておられたので、嬉しそうであった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "リッケルト教授のゼミナールにはいつもマックス・ウェーベル夫人が出席していられたが、その時のゼミナールの台本として用いられたのは、ちょうど新たに出版されたウェーベルの『科学論論集』であった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はヘリィゲル氏のゼミナールでボルツァーノについて報告した。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイデッゲル教授のゼミナールでもアリストテレスの『自然学』がテキストに用いられた。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおそのゼミナールで使われた他の書物はフッサールの『論理学研究』であった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が出たゼミナールで使われたのはカントの『純粋理性批判』とヘーゲルの『論理学』とであった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど大学のゼミナールでは何処でも好んでヘーゲルを用ゐてゐます。",
              "citation": {
                "source": "消息一通",
                "author": "一九二四年一月一日　マールブルク",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も私たちがひとの顔に於いて感情を視、ひとの手に於いて欲望に触れることが出来るやうに、私たちは大学やゼミナールや書物に於いてひとつの学問的意識を視たり、それに触れたりすることが出来るのです。",
              "citation": {
                "source": "消息一通",
                "author": "一九二四年一月一日　マールブルク",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生と教授とゼミナールの三つがいつでも親密な関係を保つてゐると云ふのもそのひとつです。",
              "citation": {
                "source": "消息一通",
                "author": "一九二四年一月一日　マールブルク",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へばひとつのゼミナールの文庫をよくするためには、成長しつつある学者を必要とします。",
              "citation": {
                "source": "消息一通",
                "author": "一九二四年一月一日　マールブルク",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は去年の秋マールブルクに来て、この二人に逢ひ、その講義に出たり、ゼミナールに加はつたりしてゐます。",
              "citation": {
                "source": "消息一通",
                "author": "一九二四年一月一日　マールブルク",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼミナールでは彼は自分の弱味をみせることを嫌がり過ぎてゐます。",
              "citation": {
                "source": "消息一通",
                "author": "一九二四年一月一日　マールブルク",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京にはジイジイ、アブラ、ミンミン、ツクヅクボウシ、カナカナ位しか居らず、ハルゼミ、チッチゼミ、クマゼミ、エゾゼミなどは居ないようである。",
              "citation": {
                "source": "蝉の美と造型",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が実際手にして見たのはそれ故甚だ種類少く、この中でもハルゼミ、エゾゼミはまだ見ない。",
              "citation": {
                "source": "蝉の美と造型",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クマゼミは先年熱海で松の木のてっぺんに鳴いているのを見たが竿が届かず、手にはとれなかった。",
              "citation": {
                "source": "蝉の美と造型",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クマゼミ又の名シャンシャンゼミはセミの中で一番巨大で色も黒、緑の外に橙色が交り、翅も透明でしかも強く、形もよいようであるが、此は手にとって見たのでないから詳細は知らない。",
              "citation": {
                "source": "蝉の美と造型",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
