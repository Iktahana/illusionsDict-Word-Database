          "standard": [
            {
              "text": "戦後の混乱期に、前衛美術は社会に対する批判的なメッセージを込めて発展した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このギャラリーは、抽象彫刻を中心とした前衛美術を専門に扱っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "前衛美術の作品を解釈するには、作者の背景や思想を知ることが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "職場からの絵画のなかに、むしろ絵画以前のエネルギーとして表われている可能性は、現実会の作品や前衛美術会の雰囲気のなかに立ち混って、決して容易でない民主的芸術の前途を暗示しているようでした。",
              "citation": {
                "source": "第一回日本アンデパンダン展批評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
