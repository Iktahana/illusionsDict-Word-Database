    "definitions": [
      {
        "index": 1,
        "gloss": "preceding issue (of a magazine, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
