    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(of a kind) never to be seen again",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "むしろ空前絶後と言いたいくらいに考えていた筆者であった。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗けたのか」　と頬を膨らましてスゴスゴ引き退るトタンに大爆笑と大拍手が敵味方から一時に湧き返るという、空前絶後の不可思議な盛況裡に、無事に予定の退却となった。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "清談、閑談、俳談、其中庵空前の――敢て絶後とはいひきらない――賑やかさ喜ばしさであつた。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義初期の文壇は、吾人の知る限り、日本に於ける最初の、そして絶後の主観的高調時代であった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の眼球を一転して、吾国の歴史に於て空前絶後なる一主義の萌芽を観察せしめよ。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも「絶後の悲哀を覚悟していい加減な相伝者を残さぬ」という翁の行き方の方が、真の能楽の精神を後世に伝うる所以であったかも知れぬ。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等はすべて、この空前絶後の鼻の裁判開始前の光景であります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "検事が真先に被告の無罪を主張するという事も空前絶後の一つに数えられたからであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにその死後に於ける裁判に於ても、この本領を空前絶後にまで発揮し得た事を嘉する。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唐代は詩文ともに最も隆昌をきわめ、支那においては空前絶後ともいうべき時代でありますから、小説伝奇その他の文学に関する有名の著作も甚だ多く、なにを紹介してよろしいか頗る選択に苦しむのでありますが、その中でわたくしは先ず『酉陽雑爼』のお話をすることに致します。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもその時の怕さつたら全く空前絶後だつたわ。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『近江輿地誌略』に、ある説に鐺は、蒲生忠知の室は内藤帯刀女なり、故に蒲生家断絶後内藤家に伝う、太刀は佐野の余流赤堀家に伝う（蒲生佐野ともに秀郷の後胤だ）。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな場合は空前にして絶後なんだから弱輩共は精々喜んでおいたらよからうよ。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門の出馬するにいたったこの少年｜誘拐事件の発端が、すなわちその故障に基因していたのですが、すでに知らるるとおり、あれなる青まゆの女は、生まれが葉茶屋の多情者でしたから、お家の断絶後における淫楽の自由を得んために、じゃまな嫡子はもとの忠僕であったあの質屋、すなわち三河屋へくれてしまったのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は人類の歴史で空前絶後の重大な時期であります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "最終戦争即ち王道・覇道の決勝戦は結局、天皇を信仰するものと然らざるものの決勝戦であり、具体的には天皇が世界の天皇とならせられるか、西洋の大統領が世界の指導者となるかを決定するところの、人類歴史の中で空前絶後の大事件である。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "最終戦争は近く必ず行なわれ、人類歴史の最大関節であるが、しかしそれを体験する人々は案外それほどの激変と思わず、この空前絶後の大変動期を過ごすことは、過去の革命時代と大差ないのではなかろうか。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "断崖に衝きあたつた私だつた、そして手を撒して絶後に蘇つた私だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――絶後蘇へる――といふ禅語がある、私の卒倒は私を復活させたのである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌精神乖離症└精神分裂症┌今日一日の命│大死一番絶後蘇生└死而後已┌剣道四病│　　驚、恐、疑、惑└剣道四綱　　　一眼二足三膽四力　十二月五日　初雪、晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は生れて初めて、そして恐らくは絶後であろうと思うが、本当に後悔した。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人であっても赤裸々たる自己の本体に立ち返り、一たび懸崖に手を撒して絶後に蘇った者でなければこれを知ることはできぬ、即ち深く愚禿の愚禿たる所以を味い得たもののみこれを知ることができるのである。",
              "citation": {
                "source": "愚禿親鸞",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北海道に於ける絶後ではないかも知れぬが、空前の大雜誌だらう」といふ、仲間での評判は讃め過ぎでないと思はれた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔も愛人や妻の死におあいになった経験はおありになっても、まだこんなことまでも手ずから世話あそばされたことはなかったから、自身としては空前絶後の悲しみであると見ておいでになるのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "御法",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折に、その中で、耳目を聳だたして開演する事が出来ようとは、いかに熱望していたとはいえ、昨日までの田舎廻り、乞食芝居の座員には、万に一の希望も絶望であろうとされていたものが――加うるに日本劇川上一座の人気は、空前絶後とされ、夢想にも思いも浮べぬ、彼地の劇界を震撼させたものであった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く詩壇と画壇の一部の者らはツァラアを空前絶後の大詩人と云うどころではない。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりあえず空前とは申しましたものの、或は絶後になるかも知れぬと考えられておりますほどの異常な事件で御座います」「……そ……それは……ドンナ事件……」　と、私は息を吐く間もなく、寝台の端に乗り出した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――以上――　　空前絶後の遺言書　　　　　　――大正十五年十月十九日夜――キチガイ博士手記　ヤアヤア。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを前の新聞記事や、胎児の夢の論文と一緒に読めば、前述の美少年と美少女を材料とする怪実験が、大正十五年の十月十九日……すなわち今日の正午を期して、空前の成功を告げると同時に、絶後の失敗に終ったという、奇々怪々な精神科学の学理原則の活躍が、明々、歴々と判明して来る。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に、国宝とも世界宝とも何とも言いようのない……極度に科学的で、徹底的にローマンチックな、エロ、グロ、ノンセンス共に百二十パーセント以上の含有量をもった……空前絶後の超々特作的スケールの雄大さと、ストーリーの深刻さをあらわした……実にソノ何とも彼とも……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
