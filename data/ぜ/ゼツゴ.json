[
  {
    "uuid": "22d3e420-a554-5967-bba1-e26931935c1c",
    "entry": "絶後",
    "reading": {
      "primary": "ぜつご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
