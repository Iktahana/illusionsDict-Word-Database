[
  {
    "uuid": "70346955-6d6b-539c-9922-31b4164e23fd",
    "entry": "贅",
    "reading": {
      "primary": "ぜい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
