        "examples": {
          "standard": [
            {
              "text": "長音階と短音階は、西洋音楽の基本となる代表的な全音階である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鍵盤の白鍵だけで構成されるハ長調の音階は、全音階の一種だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "全音階的なメロディは耳に馴染みやすく、多くのポピュラーソングで使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の「憂鬱の全音階を支配した」と言われた絶望の音楽の底には、言うに言われぬ温かさがあり、その悲嘆と慟哭とのうちには、大きな光明への予感が芽ぐむのである。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフリカの音楽は、ヨーロッパの全音階にあてはまらない。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルースを、ヨーロッパの全音階音楽にあてはめて考えると、ブルースは基本的にはこうなっているといえるだけで、なぜこうなのかは、わからない。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
