        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "国内戦時代のたたかいの結果、失明し全身不随となった若いオストロフスキーが、同志と家族にたすけられつつ、その生涯の終りに「鋼鉄はいかに鍛えられたか」という長篇小説をのこした。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その列車の機関士たる私はもう全身不随で、腕が自由を失っているので、何として見ようもないのです。",
              "citation": {
                "source": "十時五十分の急行",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本銀行と三越の全身不随症の建物がその蔭で尻餅をついてゐる。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろ豪胆をもって鳴っていたが、メリー号の全身不随となったのを知って、今は、すっかり絶望のふちに沈んでしまったかれだった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年このかた寝たまま、殆んど全身不随で口をきくこともできなかったから、父のためには、寧ろ死は救いだったであろう。",
              "citation": {
                "source": "竹柏記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ表立って披露はしていない、孝也と桂の二人に承諾させ、披露の準備をしているうちに三度めの発作が起こり、全身不随になったまま寝ついた。",
              "citation": {
                "source": "月の松山",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
