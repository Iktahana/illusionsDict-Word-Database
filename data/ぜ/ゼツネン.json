    },
    "definitions": [
      {
        "index": 1,
        "gloss": "giving up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死ぬ人もある死なるゝ人もある世と思うて、絶念め得るであらうか。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし絶念め得たりとも絶念めての後には徒らに躯の小室がうごめく許りとおもへ。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "固より絶念めんと思はねば、絶念めん樣もない。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶念めんとて絶念め得る戀ならば、始めより太刀佩く大丈夫の言には出でず。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と絶念をつけて、せつせと禁酒の伝道を怠らなかつた。",
              "citation": {
                "source": "飲酒家",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして絶念がつけばそんな廉価な事は無い筈だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをそんな……」「それをそんな……」とは言つたが絶念のいゝ人だつたからその儘持つて帰つて、押入に突込んでしまつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　書肆はかういつて絶念めた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜女に生れると絶念めなければならぬ、「哲学」が無くてはならぬ訳である。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何うしても絶念められなかつたと見えて、羽織の紋所には、捨てられた女五人の名前を書き込んで平気でそれを著てゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、その男は幾らか気味も悪かつたので、一冊だけですつかり絶念めて、また以前のやうに墓へ土をかけて置いたさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体茨城の人には、人間では水戸烈公より外に偉い人はなく、山では筑波山の外に山らしい山は無いと思つてゐるのが多いが、伝右衛門もその一人で、仕合せと文字を知らなかつたから、烈公の方は絶念めて、閑さへあると筑波山へばかり登つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、よくよく仲間の頭が悪いのに懲りたやうな事を言つて、「そやから僕もこの頃ぢや代議士なぞすつかり絶念めてしまうて、画家として立たうと思つてるのや。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、まあ折角だがお絶念下すつて……」　かう言つて星島氏は孝行者らしく狐のやうな軽い咳を二つ三つした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな折には早く絶念をつけて、物の半町と後を蹤けないうちに横町へ逸れるなり、理髪床へ飛び込むなりするが可い。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折象はお役人の手抜りを直訴しようとまで思つたらしいが、役人といふものは chacanas よりも長い爪をもつてる事を思ひ出したので、すつかり絶念めてしまつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「飛んでもないお考へ違ひで……」と独逸の註文取りはなかなか絶念めようとはしなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来も馬は度々そんな目に出会つて懲りてはゐたが、それが世間だと絶念をつけてゐるらしく、黙つてまた駆け出した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど男が七十五歳の折の事で、齢も齢だから老人自身は迚も助からないものと絶念めて、「乃公も今度こそ愈々お暇乞だ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんば失望したところで、その人達は直ぐ絶念められるに相違ない。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これではとても遣切れないといふので資本の手薄な書肆はつい出版を絶念めて了ふ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかその作物の出来栄が悪かつたら、自分は才能のないものだと絶念めて、これからは一切創作に筆を取らない約束で、書いて貰ひたい。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、恩給のことなぞは絶念めて、折角御静養なさるが可でせう。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "御言葉に従つて、絶念めるより外は無いと思ひます。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私はへえ、面目なくて、斯うして貴方等に合せる顔も無いのでやす――まあ畜生の為たことだからせえて（せえては、しての訛、農夫の間に用ゐられる）、御災難と思つて絶念めて下さるやうに。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
