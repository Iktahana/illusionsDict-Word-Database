    "definitions": [
      {
        "index": 1,
        "gloss": "all-wave (receiver)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
