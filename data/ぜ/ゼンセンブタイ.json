          "literary": [
            {
              "text": "露村にて前線部隊に編入さる。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞で私達は玉砕と言われた前線部隊の人々が生還していることを度々読んだ。",
              "citation": {
                "source": "青年の生きる道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最前線部隊が突っ込んで、五原を占領して、直ちに反転した。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう中川、高山などの先鋒が進出してから、夜に入って、すでに勝龍寺の西方あたりで、足軽隊同士の鉄砲戦があり、その附近で、探り合いの放火が行われたという報らせは――まず前線部隊からこれへ伝令されていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる最前線部隊である。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
