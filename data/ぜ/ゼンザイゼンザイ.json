        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文殊師利嘆じて曰く善哉善哉。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔うた、酔うて悠然として雲を眺めてゐた、善哉善哉、そして唄つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、酔つぱらひが近づいて呼びかけた、私はぢつとして動かなかつた、善哉善哉、其調子其調子！",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日七夜、縁の下でお通夜して、今日満願といふ其夜に、小い阿弥陀様が犬の枕上に立たれて、一念発起の功徳に汝が願ひ叶へ得さすべし、信心怠りなく勤めよ、如是畜生発菩提心、善哉善哉と仰せられると見て夢はさめた。",
              "citation": {
                "source": "犬",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「善哉善哉、われ汝を待つ事ここに久しだ。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、前祝いに一｜献……」「善哉善哉！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に善哉善哉である。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だがお生憎さまだ、色よりは慾の一本道、すこし餌をならしておいて、中仙道の流行ッ子にしてやるのよ」「流行ッ子たあ、なんのことさ」「――善哉善哉。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "善哉善哉、これぞ天の助けというものだろう」　と喜んで、即座に、誓いを立てて荷担した。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
