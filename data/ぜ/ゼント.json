[
  {
    "uuid": "bbc3a34f-c64d-5e8a-b9cc-428a8d1f8046",
    "entry": "前途",
    "reading": {
      "primary": "ぜんと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
