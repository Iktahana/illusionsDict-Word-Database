    "definitions": [
      {
        "index": 1,
        "gloss": "letter breaking off with someone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
