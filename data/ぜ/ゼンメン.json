[
  {
    "uuid": "a22a8eda-90e9-5d2a-aec4-24ad5ce1b735",
    "entry": "前面",
    "reading": {
      "primary": "ぜんめん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
