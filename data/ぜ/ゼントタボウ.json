        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "容貌技芸共にすぐれ、前途多望と称せられたる女形なり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "水谷準氏と城昌幸氏とは前途多望という事を、最も私に約束して居ります。",
              "citation": {
                "source": "探偵文壇鳥瞰",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから日本の文壇は前途多望、大いに楽観すべき現象に充ちていると思います。",
              "citation": {
                "source": "文壇の趨勢",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（hopeful）前途多望の（大事な）息子［滑稽］。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに雑誌なんかの上で大人が一二度小才のきいた文章が出してあるとすぐ「前途多望の天才」とかなんとか云う尊称がたてまつられる。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前途多望とは君等のことだ。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "５．彼自身も軍人として前途有望な人間であつたが彼の敵もまた同樣に外交家として前途多望であつた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
