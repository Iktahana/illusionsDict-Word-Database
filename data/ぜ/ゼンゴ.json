[
  {
    "uuid": "937a2b6b-24aa-5147-8c8f-6374c857cc62",
    "entry": "前後",
    "reading": {
      "primary": "ぜんご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
