    "definitions": [
      {
        "index": 1,
        "gloss": "move with haste (when you have no doubts)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
