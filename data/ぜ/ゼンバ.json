        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、それから中一日置いてあくる日の前場の引け頃になると、取引所の中に一騒動が起った。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにやら、前場の姿のままの野中教師、音も無く花道より登場。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "前場と同日、十月十七日の夕刻。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前場の人々全部と、理髪師張首明、白基竜、安重根。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "７時間的に遡って、この場の前半は前場と同時刻を繰り返す。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側に前場の集会所に通ずる扉あり。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに安重根、柳麗玉、禹徳淳、朴鳳錫、白基竜、黄成鎬、同志一、二および前場の青年多勢と露国憲兵数名。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前場の初めと同じ時刻。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前場には質屋の番頭が来て持つて帰らうとする。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『双葉フアンは、彼の目方が前場所に比べて三貫目減つてゐたところに敗因があるといふ。",
              "citation": {
                "source": "双葉山",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前場より二年後の冬、昼近く。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "三前場の人物は、押川と持山とを除き、既にみな帰つたあとである。",
              "citation": {
                "source": "雅俗貧困譜",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、前場の若々しさは去つて、もとの目立たない女になつてゐる。",
              "citation": {
                "source": "温室の前",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "文六、前場の服装にて、右手より現はれる。",
              "citation": {
                "source": "遂に「知らん」文六（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "二底野が、また前場と同じやうに寝転んで雑誌を読んでゐる。",
              "citation": {
                "source": "運を主義にまかす男",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（やがて、両手にて顔をおほひ、入り来り、急いでピヤノを開け、静かにセレナタを弾く）第三場前場と同じ場面。",
              "citation": {
                "source": "古い玩具（一幕六場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（更に顔を近づけ、留雄の眼を見上げる）第五場前場と同じ場面。",
              "citation": {
                "source": "古い玩具（一幕六場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――幕――第二場前場の吹奏楽がまだ続いてゐる。",
              "citation": {
                "source": "感化院の太鼓（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――幕――第二場友吉の部屋、――前場の翌日。",
              "citation": {
                "source": "動員挿話［第一稿］",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中仕切りに、前場の望楼にありたると同じ、ただし、もっとずっと大きな札荅蘭族の旗、黄色地に白と赤の星月の旗が、壁掛けのごとく懸けてある。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこんな事には馴れてゐるのと、気が張つてゐるので、前場の浜に於ける彼よりも自分で自分を支配してゐる平静さを保つてゐる。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前場に出た今井である）今井　待て。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――舞台空虚のまま暫く間……）（幕）７　花道だけで　前場の幕が降りるとすぐ起る夏祭の囃子鳴物、それに混って遠くで多人数のワッショイ、ワッショイの掛声。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、前に老婆のひざまずいていた場所にモデル女シィヌが裸体で低い台に腰かけているし、ヴィンセントが腰かけていた場所には、同じヴィンセントがイーゼルに立てかけた全紙の木炭紙に向ってシィヌを写生しているので、瞬間、前場の光景とダブる。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前場に出た今井である。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "―幕―７　花道だけで前場の幕が降りるとすぐ起る夏祭の囃し鳴物、それに混って遠くで多人数のワッショ、ワッショの掛け声。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（前場の課長と義一の関係を逆にしたものである）作業のリズムとテンポには無関係な低いトギレトギレの言葉。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前場でクライソリン株は一〇セントから三ドルを超えました」　クレードルストンがうめいた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い銀行の金網の外は、証券取引所の前場の引け時とて、金を出す人預け入れる人々でごった返していた。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで、古靴のしうぜんばかりで、まだ一度も、新しい靴をつくつたことがありません。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
