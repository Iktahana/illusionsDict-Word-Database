    "definitions": [
      {
        "index": 1,
        "gloss": "one's last (piece of) writing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
