[
  {
    "uuid": "8f72a24f-cef7-51bd-b56a-aba75c748334",
    "entry": "前著",
    "reading": {
      "primary": "ぜんちょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
