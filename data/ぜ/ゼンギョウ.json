        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あんたがこの前行つた時でも毛布団だつたとかつて言つてたあね」　母は随分気懸りらしかつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この奇人は数年前行衛不明になっていた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな様子だかお前行って見ておくれ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って雇人に呉れてやり、お前行けと言うと、われわれの行くところでないと辞退したので、折角七円も出したものを近所の子供の玩具にするのはもったいない、赤玉のクリスマスいうてもまさか逆立ちで歩けと言わんやろ、なに構うもんかと、当日髭をあたり大島の仕立下ろしを着るなど、少しはめかしこんで、自身出向いた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "提燈さしむくるより早く、岡本氏微笑しながら、『何だ、前行者が歩きながら小便したるなり』といふに、一同覺えず、どつと笑ふ。",
              "citation": {
                "source": "千葉夜行記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『若しもお前行かなかつたら、俺一人｜奈何すべと思つてだつけす。",
              "citation": {
                "source": "天鵞絨",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "實はね、伊貝の旦那から、お前行つて、杉野の兄さんにお逢ひして來いといふお話でしねて。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前行くところがなくなったら、今夜からＫさんのところへ行ってるといい。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "爰許今朝出馬、黒石通り、中野村迄帰程、様子相尋候処、五七日内には出艦手筈難及由に付、午刻より又々弘前行相催す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「光、お前行かんか。",
              "citation": {
                "source": "父",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等は少時待った後、護国寺前行の電車に乗った。",
              "citation": {
                "source": "年末の一日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前行って大ビラであの死骸を片付けて来い。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる黒死館殺人事件と呼ばれて、酷烈｜酸鼻をきわめた流血の歴史よりかも、すでにそれ以前行われていて、しかも眼のあたり、遺骸の形状にもそれと頷かれる恐怖悲劇の方が、胸を塞いでくる強い何物かを持っていたのは事実だった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前行われた時と同じ室に入って、鉄筐の中から、熊城が｜栄光の手を取り出したとき、その指の顫えに、無量の恐怖を感じさせるものがあった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、使節の随員は宮廷よりの馬車に分乗し、使節の馬車に前行すべし――とありますが、随員のはおろか、わたくしのも参りませぬ。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四年を終了して居ります」「それじゃＭ学院がここから近くていいから、明日でもお前行ってくるがいい」そして彼は「田中に手紙を書こう」と言った。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御前行ってね、そう云って御呉れ、池は何にもかまって御呉れでない、するようには私自分で行ってするからとね……あんなに美くしくてやさしかった人をどうして……」　殿は泣きじゃくって居る童に云いつけて向うにやらせた。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴方行つて入らつしやい」「折角だから御前行くが好い。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "で私はいよ／＼腹を立てて翌日更に井出君を引返してやつたが、心元なく思はれたので、夕方勤め先から歸つて來た弟に、「井出君ではやはり駄目らしいから、お前行つてつれて來て呉れないか。",
              "citation": {
                "source": "不良兒",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いざ子ども」は、部下や年少の者等に対して親しんでいう言葉で、既に古事記応神巻に、「いざ児ども野蒜つみに蒜つみに」とあるし、万葉の、「いざ子ども大和へ早く白菅の真野の榛原手折りて行かむ」（巻三・二八〇）は、高市黒人の歌だから憶良の歌に前行している。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌は、従来万葉集中の秀歌として評価せられたが、それは、分かり易い、無理のない、感情の自然を保つ、挽歌らしいというような点があるためで、実は此歌よりも優れた挽歌が幾つも前行しているのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「梅の花散らまく惜しみ吾が苑の竹の林に鶯鳴くも」（巻五・八二四）は天平二年大伴旅人の家の祝宴で阿氏｜奥島の作ったものであるから此歌に前行して居り、「御苑生の竹の林に鶯はしば鳴きにしを雪は降りつつ」（巻十九・四二八六）は此歌の少し前即ち一月十一日家持の作ったものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち一人の導者が僕の手を捉へて雲霧の濛々たるなかを行く、それが奈何にも慌てふためいた様子であり、僕に前行した数人の紅毛人を追ひ越して行く。",
              "citation": {
                "source": "ヴエスヴイオ山",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は、この前行ったとき馴染になった無線係の菅井という理学士だった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折角楽しみにして来て留守番をして貰うのもお気の毒だから、私居てお前行ったらいいだろう？",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日になったら、お前行って、よく謝った上で、羽織を貰ってきてくれないか。",
              "citation": {
                "source": "白日夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "東廂の北端に人影ゆらぐと見る間に、黒袍の前行に續く御劍御璽の捧持者の間を、黄櫨染の御袍、立纓の冠を召された聖上陛下が、御裾を待從に捧げさせ給ひ、げにも威風堂々として出御せさせらる。",
              "citation": {
                "source": "賢所御神樂の儀",
                "author": "羽田亨",
                "note": "青空文庫"
              }
            },
            {
              "text": "御拜十餘分で御簾の外に立ち出でさせられ更に正面して拜一拜、再び前行後從の供奉に、南廂を東廂にと玉歩を運ばせられ、北の御殿にと入御あらせられた。",
              "citation": {
                "source": "賢所御神樂の儀",
                "author": "羽田亨",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の夫婦らしく、飯もおほかた一緒に食ふし、芝居の招待券をもらふと、お前行つて来いと、髪を結はせて出してやつたこともある。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
