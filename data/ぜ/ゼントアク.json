        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ザラツストラは、一切の人生を善と悪との間に起る不断の闘争であると考えた。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂があって見れば善と悪とは……何んとか云った、善と悪とは……何んとかだとよ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "散文（詩でないもの）と詩（韻文）とが、一つの言語で結びつくのは、北と南、善と悪との反対を、同時に考えるような矛盾である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "善と悪との向う岸です。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "天は人間と獣との間に区別を設けないと同じく、善と悪との間にも差別を立てないのか。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一気が存在すれば気の象があり、気の象があれば、善と悪と正と偏と吉と凶と純と駁と生と死と陰と陽と、種々般々の差別がある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏と表、善と悪、さうしたものを超越した境が最も好いのではないか。",
              "citation": {
                "source": "娟々細々",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして単に利害とか損得ということだけでなく、正と不正、善と悪、といったような立場から、動きたいものです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ善と悪の混血児はというとほとんど出て来ないんだから、至極単簡で重宝であります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の人民は、東條時代を通じて、もっとも非合理野蛮な侵略主義者の善と悪との規準で支配されてきた。",
              "citation": {
                "source": "地球はまわる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会の発展の過程にあらわれる善と悪とは馬琴の勧善懲悪小説の善玉、悪玉であらわされるよりはるかに動的で互の関係のうちに質の変化を経験してゆくものである。",
              "citation": {
                "source": "地球はまわる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで道徳というのは、前にも一寸触れたように、善と悪とを区別することを唯一の仕事とする、あの倫理学や何かと必ずしも関係があるのではない。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかプログラムに眼をとおすとマズルカというクラシック、韃靼踊り、善と悪との争い、東、猶太風、気まぐれ、グロテスク、さすらい――郷土的なものと象徴的なものとを、程よく集めてある。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは、理想社会に一歩近づいた実顕地内で、善と悪の代理戦争が行われているのではないか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "現世の善と悪は要にもたゝず、たゞたゞ大日向の念仏のみとなへれば、神仏にもまさるべき善はない。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれら三つの種類のものにおいて問題にされるのは、右の順序に従ってそれぞれ、一、利と害、二、正と不正、三、善と悪である。",
              "citation": {
                "source": "解釈学と修辞学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は同じ人間に善と悪とが対立してゐることを忘れて、只その悪ばかりを見るからいけないのだ。",
              "citation": {
                "source": "愛人と厭人",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの善と悪とに感じる力を人間の心に宿る最も尊きものと認め、そしてこの素質をさながら美しき宝石の如くに愛で慈しむ。",
              "citation": {
                "source": "善くならうとする祈り",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "善と悪との感じは、美醜の感じよりも遥かに非感覚的な価値の意識であるから、その存在は茫として見えるがもつと直接に人間の魂に固存してゐる。",
              "citation": {
                "source": "善くならうとする祈り",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "善と悪とは人の心の内で分ち難く縺れ合つて働く。",
              "citation": {
                "source": "善くならうとする祈り",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この認識の絶対境においては、物とわれとの差別なく、善と悪との対立なく、ただ天地唯一の光景あるのみである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九一五・一一）　善くなろうとする祈り　　　　　我建超世願、必至無上道、斯願不満足、誓不取正覚　――無量寿経――　私は私の心の内に善と悪とを感別する力の存在することを信ずる。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの善と悪とに感じる力を人間の心に宿る最も尊きものと認め、そしてこの素質をさながら美しき宝石のごとくにめで慈しむ。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "善と悪との感じは、美醜の感じよりもはるかに非感覚的な価値の意識であるから、その存在は茫として見ゆれど、もっと直接に人間の魂に固存している。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "善と悪とは人の心の内で分かちがたく縺れ合って働く。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし善と悪とはあくまでも峻しく対立せしめられなくてはならない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教にはいる門　宗教にはいる正門は善と悪との対立である。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから片方で善と悪という心が強いのでありまして、弱い者が強い者にいじめられることが見るにたえられない。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに一つの絶対、すなわち善と悪、得と失、二つのものが成立することのできない、二つのものの相対、二つのものがあい対するということが、成立することができない環境であったのであります。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
