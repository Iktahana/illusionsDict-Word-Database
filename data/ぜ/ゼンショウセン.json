    "definitions": [
      {
        "index": 1,
        "gloss": "(preliminary) skirmish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
