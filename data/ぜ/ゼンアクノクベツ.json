    "definitions": [
      {
        "index": 1,
        "gloss": "distinction between right and wrong",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
