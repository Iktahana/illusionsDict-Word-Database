  {
    "uuid": "6829dd83-eea4-5b12-811e-eb4b04025dc0",
    "entry": "全店",
    "reading": {
      "primary": "ぜんてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
