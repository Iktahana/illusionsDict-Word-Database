    "definitions": [
      {
        "index": 1,
        "gloss": "hors d'oeuvre",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「オールドゥーヴル」は「前菜」に殆ど駆逐されたかたちである。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事時間前の前菜にはなおさらである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老翁は今｜前菜の一種を拵えている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは料理家の間にアンショア・ア・ラ・ブレトンヌと名づけられる前菜なのだ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老翁がラルュウの忙しい料理場の一隅で先程から加減していたのは「食卓の歓び」の著書の中に編み入れる前菜の一種であった。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰻も捨てられた、独活も捨てられた――そして「巴里人のアンショア」の名で一つの前菜が新しく生れた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西扉の傍には、何のつもりか舶来の酒の壜や前菜料理の材料なぞと一緒に大きくふくらましたゴム風船の沢山浮んでいる見世飾があって、それらの透き間から垣間見ている者もいた。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "畦の玉蜀黍の一列で小さく仕切られている畑地畑地からは甘い糖性の匂いがして、前菜の卓のように蔬菜を盛り蒐めている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはウォツカの罎と前菜の載つた卓子があつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の臙脂色の満唇と黒いヴェネツィア笹絹の夜礼服とが、いつかラトヴィヤのホテルで前菜に食べた、私の大好きな二種の露西亜塩筋子の附け合せと同じ効果を出していたからだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "衝立の陰から、前菜の皿を持って給仕が現れた。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――ああ、ねぶたいです……」　眠たいのはもう馴れているとでもいうように、給仕は心得た顔つきで前菜をすすめなおした。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの盛沢山な前菜皿のようだ。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前菜を捧げた給仕に、苦笑し乍ら呟くのが聞えた。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前菜に蝶鮫の乾物を撮んでから、三人は五時ちかくになって食卓についた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで前菜の出ているテーブルへ近よって客と主人とが慣例どおりウォツカを一杯ずつ飲んでから、都鄙の別なくロシアの津々浦々でやるようにいろんな塩物や或る種の刺戟性の珍味で口直しをすると、一同はぞろぞろと食堂へ向ったが、先頭に立った主婦は、まるでするすると泳いでゆく鵞鳥のようだった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、さっそく仕事に取りかかり、先ず手箱の前で、ちょうど何か審理のために出向いた地方裁判所の予審判事が、前菜のテーブルへ近よりながらやる、あの同じ手つきで、さも満足そうに揉手をすると同時に、その中から書類を取り出した。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋へ入ると、そこにはもうちゃんと前菜が出ていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "県の役人連には必らずこの前菜がつきもので、役人が県下で二人おちあえば、次ぎに顔を出すのは前菜と相場がきまっているのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そう言いながら、市の恩人であり、商人社会の庇護者であるところの警察部長は、甘口のウォツカと辛口のウォツカで混合酒をこしらえて、まず前菜をつまんでから、それをぐっと一息に呑みほした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンリエットはさきからにこにこしながら、美しい前歯で前菜の赤い小蕪を噛んでいたが、饂飩のようなスパゲッティが湯気を立てて出て来ると巧にフォークへ巻きつけた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋色に塗った低めの長い食卓には、鉢から移された前菜の、生海胆、琵琶湖産の源五郎鮒の卵巣、日向産の生椎茸の油煮、熊の掌の煮付に添えたひじき、鴨のロース、仙台産の味噌で包んだ京の人蔘、など、これらが織部の小皿に並んでいる。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めに幾種類かの前菜が出て、それからいよいよ羊の肉となる。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス料理の、オードブル（突出し、前菜）は冷たいのが百六十種、温かいのが二百種ある（宮内省司厨長秋山氏談）日本料理の突出しを、何んという料理人が百種こしらえたか？",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京星ヶ岡茶寮の北大路氏は、この前菜を十六種位出して、一名物を為し、日比谷の花の茶屋も、十種位は作っている。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "百種も、前菜を作ったら、日本料理で、無くなりもするか？",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点、北大路も、花ノ茶屋の井上も同じことで、前菜二十種だけ作っておいて、儲かったら、のん気に、陶器を焼いたり、別荘を建てたりしている。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも五十種の前菜と三十種の漬物とだけでも立派に一名物はできる。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな批評は恐らく批評にはならぬであらうが、さういふ印象を与へる作品の味は、またなかなか捨て難いもので、いはば、前菜のフォア・グラだ。",
              "citation": {
                "source": "『おふくろ』",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
