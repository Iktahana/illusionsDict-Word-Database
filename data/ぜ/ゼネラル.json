    "definitions": [
      {
        "index": 1,
        "gloss": "general (manager, strike, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
