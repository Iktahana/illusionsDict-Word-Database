[
  {
    "uuid": "cd7d14ca-617d-5b3b-9851-7fc97d3d8956",
    "entry": "絶体絶命",
    "reading": {
      "primary": "ぜったいぜつめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
