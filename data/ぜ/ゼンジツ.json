[
  {
    "uuid": "e813c9b3-36b5-50be-966a-b78faafa9a56",
    "entry": "前日",
    "reading": {
      "primary": "ぜんじつ",
      "alternatives": [
        "まえび"
      ],
      "is_heteronym": false
    },
    "grammar": {
