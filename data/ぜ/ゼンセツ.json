    "definitions": [
      {
        "index": 1,
        "gloss": "preceding paragraph, section, or verse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
