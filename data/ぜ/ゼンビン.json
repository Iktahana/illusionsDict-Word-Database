    "definitions": [
      {
        "index": 1,
        "gloss": "one's previous letter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "前便に、もう蚊帳を奪はれたと云つたでしよう、それがまたきのふから僕等の室に障子まではまつたのです。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "前便にくらべると、苦しみが沈潜して、何か充実している感じである。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、きょう、ちょっと珍妙な事件があったので、前便の不備の補足かたがた早速御一報に及ぶ次第なのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地氏に迷惑をおかけした金銭上の事については前便に書いておきましたから見てくださったと思います。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『日本』明治三十一年二月二十四日〕七たび歌よみに与ふる書　前便に言い残し候こと今少し申上候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、宣言的な前便については一言もふれず、じかに人情に訴える効果を見越したような運びかたは、はる子に落付けないのであった。",
              "citation": {
                "source": "沈丁花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前便と同じ手蹟で、「チャアリイが俺たちの手にあるあいだ、おれたちは、アメリカじゅうの探偵が大騒ぎをしたってすこしも驚きはしない。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治三十一年二月二十四日）　　　　七たび歌よみに与ふる書　前便に言ひ残し候事今少し申上候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔日本　明治31・2・24〕七たび歌よみに與ふる書　前便に言ひ殘し候事今少し申上候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "●昭和二十一年六月二十一日　大森区馬込末田方より　広島市古田町字高須二三六　前田恭子宛　前略　前便で無理な御願い申込んだが、その後こちらで何とか打開の途がつきさうになつたからあの件は放念してくれ給へ。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前便に申上候井上の嬢さんに引き合せくれんと、谷田の奥さんが申され候ゆゑ、今日上野へまゐり、只今帰りてこの手紙をしたため候。",
              "citation": {
                "source": "独身",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤前便に申上候｜通、不幸なる境遇に居られし人なれば、同じ年頃の娘とは違ふ所もあるべき道理かと存じ候。",
              "citation": {
                "source": "独身",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "前便で着物のことを書いておいたが二三日何だか寒いので見合わせているのだ。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其関係上前便封書にて、該家に係る戸籍謄本申請至急御下附を願う。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――前便でだいぶいろいろなことを申し上げましたが、ほんとうに僕の抱いている不安というものがおわかりになったでしょうか、この恐怖は未だかつて地球人が誰一人として想像もしなかったであろう恐怖です、超大巨人によって我が宇宙が爆撃されるというのっぴきならぬ不安は……。",
              "citation": {
                "source": "宇宙爆撃",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や則ち如何前便申上げ候通り、椽端の日向ぼつこに候。",
              "citation": {
                "source": "もゝはがき",
                "author": "斎藤緑雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、前便の趣、其許の考、一応尤に候も、決して常軌を逸したる次第には無之、たとへ一度失敗するも再び起つ勇気と自信とを失はず、一家のものには多少苦労ありたらんも、そは成功の暁十分に償ひ得るものなり。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも初めての長旅なので夫も大変気づかつてくれまして、途中、前便のとほり松島を見物いたし、青森で船のでるのをまつあひだ三時間ほど停車場前の「かぎや」ともうす宿で休み、連絡船で六時間、割合にくたびれもせず、はじめて海を越えた土地につきました。",
              "citation": {
                "source": "早春箋",
                "author": "辻村もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居道の事例に依て昨日の話と今日の話にては全然計畫を異にいたし目下の處にては前便申上候脚本の件はもはや忘れたるが如く何とも申參らず候を、當方も却て仕合せに存居候。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも前便と同じように書留になっていないので、眼前の用を弁ずる中味に乏しいのは、お秀からまだ何にも聞かせられないお延にもほぼ見当だけはついていた。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この猫は前便に書いた猫、ひどい好人物的猫で、猫を好かないものの家にいついてしまいました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことも私は、前便で書いた、芸術は在らしめること、客観的に在らしめなければ、どんなよい意図もないに等しい、というあのことを感じ直させました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲ちゃんは前便で書いたとおり保田。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "前便で大抵書いたと思いますが、家はなかなか簡単にかわれません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "手塚さんは島田へわざわざ達ちゃんの送別の手紙をくれました（前便で書いたと思いますが）　伝記が豊富な題目に溢れているのは全くです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔十三枚目欄外に〕　前便のタテの封筒がいかにもいや。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうの朝までは前便に書いたと思いますがひる十一時四十分　六・四　夕午後五時半　六・三　夜九時　六・六食事　十二時半　　　　　　　食六時半　　　　　　　就眠九時四十分　今朝起きたの七時半。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前便にも書いた通り、いかにも面白いし、生々と吸収されるし、ねうちは益※明瞭となって来るし、総合的なものの中核となるし、順につづけて行きます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで、私が、いいとか、わるいとか、そういう感情的なものにこだわっていたこと（前便、きのう一寸ふれた）が、この頃よく自覚されて来ているから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうは、前便で話していたように会だらけの日でした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
