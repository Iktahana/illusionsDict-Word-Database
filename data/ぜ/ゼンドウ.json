[
  {
    "uuid": "810a70d8-41bf-589a-81f0-7d29a5d14be4",
    "entry": "善導",
    "reading": {
      "primary": "ぜんどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "proper guidance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "支那、日本等の東洋諸國に於て、古來あまり科學が發達しなかつたのは、勿論他にいろいろの原因もあるだらうが、一つには此等の國々の教育法が、子供の本然する童話精神を善導せず、むしろこれを枯燥させるやうにさへしたからである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる思想善導の問題でも、あらゆる方法の中で最も有効有力なものは、適当な映画の制作であろうと思われるが、これについては余白がないからここれは触れない。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、また一方、この同じ心理がたとえば戦時における祖国愛と敵愾心とによって善導されればそれによって国難を救い戦勝の栄冠を獲得せしめることにもなるであろう。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者の場合には世道人心を善導し、後者の場合には惨禍と擾乱を巻き起こした例がはなはだ多いようである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画は文部省あたりの思想善導映画として使われうる可能性をもっている。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの点に気がつくならば、現時の詩壇にある如き似而非自由詩が、根本的に承諾されないものであること、いかにもしてより高いイデヤの方へ善導して行かねばならないことを知るだろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この教授は、五六年まえ、私たち学生のころ、自ら学生の左傾思想の善導者を以て任じていた筈である。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、そのころの教授の、善導の言論も、やはり今日の起訴の理由の一つとして挙げられている。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の友は、我に於ける旅の道ずれ、事業の伴侶のようなものだけではなく、正に近くより遠くに及び、一心の小さなものが周囲に広がり、天地の善導を助け、神の徳を讃えようとするもので、道友を得る悦び楽しさは例えようも無い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が我を知る・知らない、世の我を認める・認めないことに無関心に月日を送っても、学問が次第に成り徳が次第に向上すれば自然に人にも知られ、世にも認められ、世の為人の為にもなり、天地善導の助けにもなって、我が道は広まり、我が志も報われる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青年の任務」「思想善導」「農民の誇」……何時もチットモ変らないその講話は、もう誰も聞いているものがなかった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな玩具があるよ、神聖なる勞働、母なる大地……君が、農民生活には何はともあれ、空疎ではない充實したものがある、實質的なものがある、健康なものがある、などと云ひ出す口ぶりは、ラヂオの青年の夕べの農村青年代表や、農村を地盤にしてゐる政治屋や、ある種の思想善導家や、さういふものを思はせる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず最も幼稚な段階は「思想善導」と呼ばれるものであった。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が思想善導なるものは、こうした近代的な自由主義的（？",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした模範的モデルへ強制しようという広義の教育観は、実際、この思想善導と一緒に、この頃社会教育を支配し始めたように見える。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し真面目に考えて見れば、こんな教育方針が矮小で卑小なものであることは明らかなのだが、「思想善導」という常識社会で甚だ尤もらしく用いられた言葉は、恰もこの種の偽教育観と全く同じ本質のものだった。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそこへ善導さるべきであったその善思想という積極内容は、一体何であったか。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想善導の場合のような、ただの寝言ではなかった。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて以上、「思想善導」、「国民精神作興」、「国体明徴運動」は、思想統制（文化・言論・統制も之に準じる）の三つの推進段階であった。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実思想善導と云っても国民精神作興と云っても、又国体明徴運動と云っても、夫が為政者や類似為政者の仕事を指すものではあっても、一般の民衆と何か関わりのあるものだというような印象は受け取ることが出来なかっただろう。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時代の日本型ファシズムの高潮にも拘らず、そして多年の思想善導、国民精神作興、国体明徴、思想動員、精神動員、其の他等々の方寸にも拘らず、日本当局に依然として、民衆的な宣伝力に富んだ文化政策がないという不可思議は、ここに秘密を持っている。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本だって、あの作品や「トルクシブ」は「思想善導」されてカットされているんだろう？",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鸞はこの伝統をインドの竜樹、天親、支那の曇鸞、道綽、善導、日本の源信、源空の七人の祖師において見た。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏説まことにおはしまさば、善導の御釈虚言したまふべからず。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "善導の御釈まことならば、法然のおほせそらごとならんや。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄土真宗では、竜樹、天親、曇鸞、道綽、善導、源信、源空の七祖を正依の祖師とし、さらに菩提流支、懐感禅師、法照禅師、少康禅師の四師を傍依の祖師としている。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩提流支は『高僧和讃』曇鸞章に、懐感は同じく源信章に、法照、少康の二人は同じく善導章に出ている。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「九十五種みな世を汚す、ただ仏の一道のみひとり清閑なり」と善導はいっている。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉の濃いきりっとした顔立の少年で、どことなく不良にして置くのは惜しいような気がしたので、石子刑事はそれとなく善導につとめたのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "難渋な人々や気の毒な人々を善導して明るくしてやらなければならない。",
              "citation": {
                "source": "ヒロシマの声",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
