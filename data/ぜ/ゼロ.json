        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これらは騎士気質から出たものとして、武士道から出た「意気地」と差別しがたい類似をもっている｛１０｝。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前０時を過ぎると、死体のように冷やかな銀行街から、大江村を渡って、鬢にほつれるある女が夜間薬品店にあらわれると、灯籠道でもあるくように蒼ざめて、淀川の水面に赤いレッテルの商標を投じた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "１０＝茶店　仕出しが二人三人口々に「喧嘩だ」と叫んで走って行く。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "２０＝店　伝六も思い出して大笑いです。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）３０＝（Ｆ・Ｉ）右門宅　右門の前で伝六が、Ｔ「人に喋ると罰が当るそうで御座んすがね」　とすっかり喋って了った。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "４０＝二階の密室　十人分程の膳部が並べてある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "５０＝おふみの室　覆面の侍（太郎左衛門）が襖を開いて入って来る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「不義者ッ」６０＝下の室　お類と伊吉、その声にキョロキョロと辺りを見廻す。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）７０＝（Ｆ・Ｉ）番所　漸く釈放されたお兼と敬四郎は迎えに来た松公と共に帰る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）８０＝（Ｆ・Ｉ）峠の頂上　五人組が腰打ち掛けて待って居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生活＋戦争＋スポーツ÷０＝能」の意味がわかったかナ？",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……÷０＝能の「０」はそもそも何じゃと言うのだね。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "両君はその「０」を掴むべく夢中になって御座るようだから……。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "答、０、と書いたが、若し間違っていたら、またこないだみたいに侮辱されると思ったから、答、０デショウ、と書いた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "１０　二日のち、四ツ橋電気科学館の星の劇場でプラネタリュウムの「南の空」の実演が済み、場内がぱっと明るくなって、ひとびとが退場してしまったあと、未だ隅の席にぐんなりした姿勢で残っている薄汚れた白い上衣の老人があった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その神秘をドン底まで探偵して、電子の作用に過ぎない事を計数の上で嘲笑し、その信仰心理を徹底的に分析して、｜＋−０式な利己人の表現に過ぎないと喝破し、一切の美を醜悪な、又は単純無趣味な、直線、もしくは曲線にまで分解し、罵倒しつくした。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "１＝Ｘ／Ｘ＝１×１＝０／０＝８÷８なんていうのを使うのは大抵素人に限るようである。",
              "citation": {
                "source": "探偵小説漫想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "√（−１）を使う時、本格探偵小説の価値は０となるか、又は性質を変じてノンセンス、ユーマー、怪奇小説の類に堕するようである。",
              "citation": {
                "source": "探偵小説漫想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし３−５＝０という約束から出発した数学も可能かもしれない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ヴェクトルの数学では、１に１を加える場合に、その和として、０から２までの間の任意な値を得ることができる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前世の業のようなんだから致し方はありません、柱一本立直らないで、それだけの身上がまるで０。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "主役に据えたＮＥＣはその後、16ビットに移ってからもＰＣ―９８００シリーズを大成功させました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その市場独占の経過をたっぷり見てきた後で再刊するのなら、せめて長めの後書きを用意して、ＰＣ―９８０１が市場を制覇する、その後の流れにも触れておきたい。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＰＣ―９８０１の成功の軌跡をさらりと跡づける」くらいの気持ちではじめてみると、話を聞かせてくれたある人が、驚くような手がかりを与えてくれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけでも、既に世間的價値がゼロに近いのに、さらにこのお爺さんには子供が無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯の危険率も、危険地帯の安全率もゼロではない。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛をかじる虫も、人間が見ると能率ゼロのように見えても実はそうでなくて、虫の方で人間を笑っているかもしれない。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん一種の指数曲線か何かに従って、漸近的にゼロに向かって行くだろう。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいうまでもなく全然落第でありゼロである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬとゼロだよ」「馬鹿！",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
