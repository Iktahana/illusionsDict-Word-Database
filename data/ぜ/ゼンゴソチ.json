        "examples": {
          "standard": [
            {
              "text": "銀行のシステム障害が発生し、利用者への補填を含む善後措置が発表された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "延期された公演の払い戻しなどの善後措置は、公式サイトで案内されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大火災の後、被災した家族への生活支援などの善後措置が検討された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ただ、或る重大な事件が昨日来、ワーナー調査団に発生して目下極力善後措置に努力中だとは知っていたが……。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮中には光緒帝も西太后も西巡していて恵妃（同治帝の妃）のみが国璽を守っていたが、柴大人に使を派して謝意を述べ、大人の指示によって宮中の善後措置を講じた』という意味の談がある。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
