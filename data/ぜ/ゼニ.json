    "definitions": [
      {
        "index": 1,
        "gloss": "round coin with a (square) hole in the center",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし今晩は、出掛けるために電車賃が一銭もないのであつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んでしまつた本が二冊ばかり出て来た時に、「五十銭にはなるだらう」と呟いた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "本を売つて一円五十銭ばかり出来ると、明治座の見料が出来た。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の肥つた女達は、私のや私の前の男のネクタイを見ながら、「まあ勉強しますわねえ、八十銭であんな物まで附けるのですものねえ……ええェ」と云つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三銭あるいは四銭位です。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銭のせいであろうか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友情と金銭とのあいだには、このうえなく微妙な相互作用がたえずはたらいているものらしく、彼の豊潤の状態が私にとっていくぶん魅力になっていたことも争われない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　登竜門ここを過ぎて、一つ二銭の栄螺かな。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはやがて、そろって銭湯に出かけた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭湯から帰って、早めの夕食をたべた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家のひとつきの家賃は、六円五十銭であった。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（但し私の云ふその条件とは、金銭や環境、又は個性なぞと呼ばれてゐるものの裡にあるのではない。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩では食へぬといふ言葉は、東西古今にある言葉であるが、日本の今日のやうに、煙草銭も出ぬといふ有様は東西古今にはないのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日｜銭を貰うて先ず学校へ行ったが、教場でも時々絵の事に心を奪われ、先生に何か聞かれても何を聞かれたか分らぬような事もあった。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰に贈るあてもないが一枚を五十銭で買った。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園裏にて下り小路を入れば人の往来織るがごとく、壮士芝居あれば娘｜手踊あり、軽業カッポレ浪花踊、評判の江川の玉乗りにタッタ三銭を惜しみたまわぬ方々に満たされて囃子の音ただ八ヶまし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右へ廻れば藤棚の下に「御子供衆への御土産一銭から御座ります」と声々に叫ぶ玩具売りの女の子。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔除鼠除けの呪文、さては唐竹割の術より小よりで箸を切る伝まで十銭のところ三銭までに勉強して教える男の武者修行めきたるなど。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾籠な話であるが室戸の宿の宿泊料が十一銭であったことを覚えている。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道中の昼食は一人前五、六銭であったらしい。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの昼食で甥が一、二杯自分より多く飯をくったら、その分だけ一銭多く取られた。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りもう十一銭の宿泊料では覚束ないであろう。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草へ行く積りであったがせっかく根岸で味おうた清閑の情を軽業の太鼓｜御賽銭の音に汚すが厭になったから山下まで来ると急いで鉄道馬車に飛乗って京橋まで窮屈な目にあって、向うに坐った金縁眼鏡隣に坐った禿頭の行商と欠伸の掛け合いで帰って来たら大通りの時計台が六時を打った。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど二学期の試験のすぐ前であったが、忙しい中から同郷の友達等が入り代り見舞に来てくれ、みんな足しない身銭を切って菓子だの果物だのと持って来ては、医員に叱られるような大きな声で愉快な話をして慰めてくれた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀明水に達したるは午後七時に垂んとす、浅間社前の大石室に泊す、客は余を併せて四組七人、乾魚一枚、麩の味噌汁一杯、天保銭大の沢庵二切、晩餐の総べては是の如きのみ、葉マキ虫の葉を綴りて寝ぬる如く、一同皆｜蒲団に包まりて一睡す。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと隣って、一段高く梯子段を上ったところに、浅間神社を勧請した離屋が、一屋建ててあり、紀伊殿御祈願所の木札や、文化年間にあげたという、太々神楽の額や、天保四年と記した中山道深谷宿、近江屋某の青銭をちりばめた奉納額などがあった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一円九十銭の日当の中から、日に、五十銭の米を二升食われて、九十銭で着たり、住んだり、箆棒奴！",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一口まぜに、民子は私が殺した様なものだ、とばかりいって居て、市川へ置いたではどうなるか知れぬという訣から、昨日車で家へ送られてきたのだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜに自分はかやうに肉体的に病み苦しまなければならないかとさへ叫んだ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の話しぶりはきわめて卒直であるものの今宵初めてこの宿舎で出合って、何かの口緒から、二口三口｜襖越しの話があって、あまりのさびしさに六番の客から押しかけて来て、名刺の交換が済むや、酒を命じ、談話に実が入って来るや、いつしか丁寧な言葉とぞんざいな言葉とを半混ぜに使うようになったものに違いない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
