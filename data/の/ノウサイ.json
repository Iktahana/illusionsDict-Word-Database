[
  {
    "uuid": "cd993ee9-9a18-5453-982c-1e97ad6eeced",
    "entry": "納采",
    "reading": {
      "primary": "のうさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "betrothal gift",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "支那古代の婚姻には、納采・問名・納吉・納徴・請期・親迎といふ所謂六禮があるが、この六禮は、皆祖先の廟で行ふ（『禮記』昏義）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "是以昏禮、納采、問名、納吉、納徴、請期。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "納采、問名、納吉、納徴、請期の五儀がそれです。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "納采の時でも問名の時でも、納吉の時でも同樣に廟の前で主人が客から命を受けます。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚手續は『禮記』にある通り最初に納采を行ひます。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを納采と云ふのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏丸中納言が引婿の納采をあてにして、姫たちを風に吹かせるような真似をしても、とても憎めるわけのものではない。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
