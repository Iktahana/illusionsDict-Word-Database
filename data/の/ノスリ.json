    "definitions": [
      {
        "index": 1,
        "gloss": "common buzzard (Buteo buteo)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
