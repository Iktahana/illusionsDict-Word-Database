[
  {
    "uuid": "48875196-b172-5855-ac6c-21aef148fba5",
    "entry": "のこのこ",
    "reading": {
      "primary": "のこのこ",
      "alternatives": [
        "ノコノコ"
      ],
      "is_heteronym": false
    },
    "grammar": {
