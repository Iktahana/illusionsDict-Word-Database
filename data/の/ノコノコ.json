        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "unconcernedly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "のこのこと書斎を出て行つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、根が骨太の岩乘なからだであつたから、十日も經たぬうちに全快し、食慾は舊の如く旺盛で、色慾などもちよつと出て來て、よせばよいのに、またもや兎の庵にのこのこ出かける。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "フト彼方を見れば、てっきり鉄五郎がのこのこやって来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝通り――　てっきり鉄がのこのこ歩いて来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊がのこのこやって来た三次を見て走り寄った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも、その表に立ち止った一人の武者修業の侍（早水団九郎）　のこのこ門内へ入る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それゃ、まあ、すまんこって……」「おどれが、こんな所で、のこのこ這いよりくさる！",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬四郎ものこのこ戻って来た。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んでから幾日も経ち、内臓なども乾きついてしまった蠅がよく埃にまみれて転がっていることがあるが、そんなやつがまたのこのこと生き返って来て遊んでいる。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな人たちのところへ、のこのこ出かけて行くのは、なんだか自分のろくでもない名前を売りつけるようで、面白くない。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にのこのこついてきて、何かそれが飼われているものの義務とでも思っているのか、途で逢う犬、逢う犬、かならず凄惨に吠えあって、主人としての私は、そのときどんなに恐怖にわななき震えていることか。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "要らざる時に東京から、のこのこやって来て、この吉田の老若男女ひとしく指折り数えて待っていた楽しい夜を、滅茶滅茶にした雨男は、ここにいます、ということを、この女中さんにちょっとでも告白したならば、私は、たちまち吉田の町民に袋たたきにされるであろう。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらとうとう、象がのこのこ上って来た。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど小金井は桜の名所、それで夏の盛りにその堤をのこのこ歩くもよそ目には愚かにみえるだろう、しかしそれはいまだ今の武蔵野の夏の日の光を知らぬ人の話である。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代は稗田のあとについてのこのこ家の中へはいった。",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はちやうど籠球部へ籍を入れて四日目だつたが、指導選手のあとにのこのこ随いて行つて、夕陽丘の校門をくぐつたのである。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "燗は焚火でふたりの夜　節分には樹明君に誘われて、八幡様へのこのこおまいりいたしました。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて猪野は渡弁護士を食堂に案内し、お神の竹子も席を立ち、「お前もおいで」といわれて、銀子ものこのこついて行った。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途、買い物にでもまわったのであろうと思って、僕はその不用心にもあけ放されてあった玄関からのこのこ家へはいりこんでしまった。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店で、葡萄酒飲んでいるうちは、よかったのですが、そのうちに割烹店へ、のこのこはいっていって芸者と一緒に、ごはんを食べることなど覚えたのです。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、根が骨太の岩乗なからだであつたから、十日も経たぬうちに全快し、食慾は旧の如く旺盛で、色慾などもちよつと出て来て、よせばよいのに、またもや兎の庵にのこのこ出かける。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というような文章があったけれども、そのしなかった悔いを噛みたくないばかりに、のこのこ佐渡まで出かけて来たというわけのものかも知れぬ。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」誰に断って、のこのこ、ひとの庭先なんかへ、やって来たんだ、と言おうと思ったが、あんまりそれは、あさましい理窟で、言うのを止めた。",
              "citation": {
                "source": "市井喧争",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、二度も罹災して、行くところが無くなり、ヨロシクタノムと電報を発し、のこのこ生家に乗り込んだ。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは但馬さんの、昔の御恩をさえ忘れた様子で、但馬のばかが、また来やがった、等とお友達におっしゃって、但馬さんも、それを、いつのまにか、ご存じになったようで、ご自分から、但馬のばかが、また来ましたよ、なんて言って笑いながら、のこのこ勝手口から、おあがりになります。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴球部の先輩、大沢殿と松村殿がのこのこやって来た。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
