        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いったいどうしたんでしょう」「まず乗せ逃げとでもいうんでしょう」「へえ、なんでございます」「客の逃げたのが乗り逃げ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手はそれまでは乗り逃げをせられたのかと思いながら、やるともなしに土間へ眼をやった。",
              "citation": {
                "source": "白い小犬を抱いた女",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減にしろ、伝馬まで乗り逃げやりやがって。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると、ばっさりやって乗り逃げしたかもしれねえんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "この泥棒野郎が車を盗みよって、乗り逃げしてるのや。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が手を取り合って、最後の覚悟を語りあっているところへ、横合から漂然と流れて来た一個の巨船――それこそ意外中の意外、というべき猿田飛行士が乗り逃げをした筈の新宇宙号だった。",
              "citation": {
                "source": "月世界探険記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――最初犬吠が乗り逃げした宇宙艇は、誤ってこの無引力空間に陥って、ここを漂っていたのだ。",
              "citation": {
                "source": "月世界探険記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "木挽町の河岸へ止った時、混雑にまぎれて乗り逃げしかけたものがあるとかいうので、車掌が向うの露地口まで、中折帽に提革包の男を追いかけて行った。",
              "citation": {
                "source": "深川の唄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ一番の勇気をふるいおこして、鷲ぬすみのはなれわざ、小屋の前からさッと一陣の風をくらって、宙天へ乗り逃げしてしまった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
