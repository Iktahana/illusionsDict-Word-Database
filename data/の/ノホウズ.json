[
  {
    "uuid": "f083ced0-e087-540c-8fcc-9bd2231b2d32",
    "entry": "野放図",
    "reading": {
      "primary": "のほうず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
