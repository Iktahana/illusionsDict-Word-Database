        "examples": {
          "standard": [
            {
              "text": "そのヴィンテージショップは、素晴らしくノスタルジック（郷愁を誘う）な雰囲気だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、学校時代のノスタルジック（郷愁を誘う）な思い出をいくつか共有した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その映画のサウンドトラックは、意図的にノスタルジック（郷愁を誘う）で、過去の時代を呼び起こしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私にとってはその終日日に倦いた眺めが悲しいまでノスタルジックだった。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが何かわれわれ人間の奥ぶかくにあるもので、その一心な目ざしに自分を集中させていると、自分のうちにおのずから故しれぬ郷愁のようなものが生れてくる、――何かそういったノスタルジックなものさえ身におぼえ出しながら、僕はだんだん切ない気もちになって、やっとのことで、その彫像をうしろにした。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "基本的にはハッピーでノスタルジックでエキゾチックな、つまり単なる気ばらしとして単純な大人が聞いてよろこぶ音楽が、ティファナ・ブラスだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
