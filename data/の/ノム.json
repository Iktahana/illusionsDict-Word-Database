  {
    "uuid": "fa7be2f0-47d1-53a7-a2ce-c8c3e9cf5006",
    "entry": "服む",
    "reading": {
      "primary": "のむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
