[
  {
    "uuid": "c9da96b1-6f19-51a3-9f7a-9a68cb26cfa2",
    "entry": "飲む",
    "reading": {
      "primary": "のむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to drink",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勝負事でも始めるか酒でも飲むしか仕方はない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が日本酒を飲むので、妻が酌をしてくれる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はただ、ビイルをしっかり飲むばかりである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「またそれを飲むと明日朝目覚が悪くて困るから。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "町へ行くときも、酒を飲むときも、女と遊ぶときも、僕は常にただ一人である。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕の散歩のかへり道に、このホテルの静かな食堂へ入つて、大層冥想的な紅茶を飲むのは、温泉場の物侘しい生活にふさはしいことである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際それは彼にとつては火を飲むやうに苦しかつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行けばまた酒を飲むであらう。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同は狂気のように躍り上って、悦んだ、そうして小さい谷川へ下りたときには、敷石の水成岩の上に、腹這いになって、飲む、嗽ぐ、洗う、もう浸かるばかりにして、やっと満腹した。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の登山者は、ここで一息いれる、水を飲む、床几にごろりと横になるのもある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "川俣川にかけた橋を渡って、大門川の峡流を見下しながら、弘法水に立ち寄り甘美な泉をむすんで飲む。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふ貴重な水なれば、子等が飲むのには柄杓に二杯も飲ませはする。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、あれを二本飲むと眠るものが出来て困るからだそうです。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚木の大きい咽喉仏がゆっくり生唾を飲むのが感じられた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は青年ながら家で父と晩酌を飲む口なので、私の顔をちょっと見た。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅へ出てあんまり心持ちのわるいときはちょっと飲むといいっておっかさんがいったぜ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今眼前にこの岩手山の実に立派な姿を眺め、その麓に展開する山川の実に美しい多様な変化を味わっていると、どうしても日本はやはり八百万の神々の棲処であり、英雄の国であり、哲人の国であり、食うことと飲むことの外にまだ色々様々大事なことのある国だとしか思われないのである。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう歌を大抵の人は、平凡である、稀薄である、素湯を飲むようであると云うのであるが、その淡然たる声調の上に何処ともなく、情緒のにじみが潤い出て居る。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒飲む人のだらしのなさを描いた第百七十五段も面白い。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題に的確に答えるためには、勿論まず毒薬の種類を仮定した上で、その極量を推定し、また一人が一日に飲む水の量や、井戸水の平均全量や、市中の井戸の総数や、そういうものの概略な数値を知らなければならない。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉の味のことで、ふと思いついたが、酒を飲む者の言葉には注意していると面白いものが多い。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山中の道楽は酒を飲むことと、映画を見ることだ。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "めいめい、好み好みの場所に席を取って、鮨種子で融通して呉れるさしみや、酢のもので酒を飲むものもあるし、すぐ鮨に取りかかるものもある。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生一本の酒を飲むことの自由自在、孫悟空が雲に乗り霧を起こすがごとき、通力を持っていたもう「富豪」「成功の人」「カーネーギー」「なんとかフェラー」、「実業雑誌の食い物」の諸君にありてはなんでもないでしょう、が、われわれごときにありては、でない、さようでない。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに酒を飲むにしても、どこか川っぷちのレストランみたいなところで、橋の上からだとか向こう岸からだとか見ている人があって飲んでいるのならどんなに楽しいでしょう。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後Ｓ―はひどく酔ったときなどは、気持にはどんな我慢をさせてもという気になってついその女を呼ぶ、心が荒くなってその女でないと満足できないようなものが、酒を飲むと起こるのだと言った。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、へいぜい自分の使っている茶碗でしきりに茶を飲む折田を見ると、そのたび彼は心が話からそれる。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　思切って坂道を取って懸った、侠気があったのではござらぬ、血気に逸ったではもとよりない、今申したようではずっともう悟ったようじゃが、いやなかなかの臆病者、川の水を飲むのさえ気が怯けたほど生命が大事で、なぜまたと謂わっしゃるか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いややがて、この鯉を料理して、大胡坐で飲む時の魔神の姿が見せたいな。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯を食べに行っても可、ちょいと珈琲に菓子でも可、何処か茶店で茶を飲むでも可、別にそれにも及ばぬ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
