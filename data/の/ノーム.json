    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gnome",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれが器械仕掛けでメトロノームのようにきちょうめんに鳴るのではちっとも涼しくはないであろう。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時や例の錦城館のお富の身請をソーレターノーム。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は單に時間的順序によつてのみ區別されるメトロノームの相繼いで鳴る一つ一つの音を個性と考へることを躊躇する。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は単に時間的順序によってのみ区別されるメトロノームの相継いで鳴る一つ一つの音を個性と考えることを躊躇する。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少くともアラスカのノームに至るまでの航空は追風ならん。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして海峡のノーム町を目指して飛んでゐるうちに、気嚢にまた氷の層が出来はじめて、船体はたえず下方へと押しつけられた。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "はげしい吹雪もおそつてきたので、ノーム行きを断念し、その手前のテラー村に着陸しなければならなかつた。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに時間そのものが、ものの動きより生じ、グリニッジ天文台の時計はその一つの便宜的説明にしかすぎなくなった時、リズムの根底をなしている音楽的メトロノームは何を意味することとなるか。",
              "citation": {
                "source": "リズムの構造",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "又彼のタクトはメトロノームと寸分の変りなく、拍子だけでその中に感情は全くはいっていなかった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "意志によって訓練され、まるでメトロノームに合せて行動しているような男だった。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにも、土の妖精であるノームや、小さな女の子の妖精であるニンフなどが近くの森に住んでいます。",
              "citation": {
                "source": "サンタクロースがさらわれちゃった！",
                "author": "A KIDNAPPED SANTA CLAUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうしろにはたくさんのピクシーやノーム、ニンフたちがいて、さいごには、かわいらしいフェアリーたちが千人、きれいないしょうをきて、行進にくわわっていました。",
              "citation": {
                "source": "サンタクロースがさらわれちゃった！",
                "author": "A KIDNAPPED SANTA CLAUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の指揮する管絃楽の、確固たる正確さ、メトロノーム的な均斉さ、常に美妙な色合いを失わない演奏法を、激称した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
