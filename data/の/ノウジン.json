        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あちらにも、こちらにも、うれはしげな農人の顔がみえる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その淋しさと農人の豊かさとが寛大と細心の象徴のように私の眼の前に展けて見えた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京町から平野橋、それから今迄の道に直角に歩いて思案橋、博物館、農人町、住吉町の通りから道頓堀に出て、それから中の島まで引返した。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、はや落穂ひろひの農人が寒き瞳よ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが母の生れた家であつて、数代この近郷の尊敬と素朴な農人の信望とをあつめた石井家の邸宅であつた。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は若草の萌えた野道から来るともいい、また都大路の女の着物の色から来るともいうが、津軽海峡をへだてた北海道の平野に、久しく農人の生活を送って来た人の話によると、あちらの春は、野からも山からも来ない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが母の生れた家であって、數代この近郷の尊敬と素朴な農人の信望とをあつめた石井家の邸宅であった。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "路に逢ふほどの農人はみな丁寧にその青い頬かむりを解いて會釋した、私はまた何事もわが意の儘に左右し得るものと信じた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜柔かなる月の出に生じろき百合の根は匂ひいで、鴉の鳴かで歩みゆく畑、その畑に霜はふる、銀の薄き疼痛…………過ぎし日は苦き芽を蒔きちらし、沈默はうしろより啄みゆく、虎列拉病める農人の厨に黄なる灯の聲もなくちらつけるほど。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが母の生れた家であつて、數代この近郷の尊敬と素朴な農人の信望とをあつめた石井家の邸宅であつた。",
              "citation": {
                "source": "思ひ出",
                "author": "抒情小曲集",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢　　　　　　　シュリ・プリュドン夢のうちに、農人曰く、なが糧をみづから作れ、けふよりは、なを養はじ、土を墾り種を蒔けよと。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュリ・プリュドン夢夢のうちに、農人曰く、なが糧をみづから作れ、けふよりは、なを養はじ、土を墾り種を蒔けよと。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "道芝の上吹く風よ、農人の寢覺に通ふ微かなる土のおとづれ、なつかしき母の聲音か。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "天草は農人、五島には鯨とる子もガリレヤ海の海人の習と悲節を守りつぐ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪袴、草鞋穿きの農人の姿なぞは殆ど見られぬ。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "丙子秋与石田士道、成田成章、太田農人、皆川叔茂同詣寺。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「余与金輪寺混外上人相知五六年於茲、而以病脚在家、未嘗面謁、丙子秋、与石田士道、成田成章、太田農人、皆川叔茂同詣寺、得初謁、乃賦一律。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒は前年初見の時の同行者として、梧堂を除く外、成田成章、大田農人、皆川叔茂を挙げてゐて、岡本、田内、土屋は与らなかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また私の生れた市街の場末には農人の町があって、私は幼年の時から其処に耕作と紡織とに勤勉な沢山の男女を見ました。",
              "citation": {
                "source": "婦人改造の基礎的考察",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "峨峨温泉展望青灰色の岩壁の外輪をあんなにもうねうねと帆走する白雲の塊り峽中は西風をめぐらした城のやうに今にも霧をはなち、雨を吹き入れよう下には阿羅漢の如く浴する赤肌の農人が物見臺の上にゆつたりと歩みいで衣をかかへて、遠く陰りゆく日を惜しげにその青青とした髯を風にすりつけては仰ぐ。",
              "citation": {
                "source": "季節の馬車",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の東の仕切になつて居るのは農人町川です。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると隣にゐた農人は、すぐ、「入り込んだらしいかね」と声をかけた。",
              "citation": {
                "source": "猟人",
                "author": "津村信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く見れば水戸様の饌にのりそうな農人形が、膝まで泥に踏み込んで、柄の長い馬鍬を泥に打込んでは曳やっと捏ね、また打込んでは曳やっとひく。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "簑笠は、後世農人の常用品と專ら考へられて居るが、古代人にとつては、一つの變相服裝でもある。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "此所のやうに自給自足すら覚束ないやうな痩地の所へは買出しの人さへやつて来ず、従つて農人はおのづから勤勉であると同時に悪びれもせず、人間本来の性情を素直に保つてゐる。",
              "citation": {
                "source": "開墾",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "くすしきは神のみちから、たくましきは農人のつとめ。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
