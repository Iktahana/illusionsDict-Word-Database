    "definitions": [
      {
        "index": 1,
        "gloss": "to go bar-hopping",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
