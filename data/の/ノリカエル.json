    "definitions": [
      {
        "index": 1,
        "gloss": "to transfer (trains)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その上、小田原で乗り換えると行く手にはもっと難物が控えている。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の先生の話　冷い雨の降る日――四谷から牛込へ帰る途中――飯田橋から新宿行の急行電車に乗り換えると――あの中学生――一週間余り前に、上野公園の杉の木蔭で、友達にアルファベットの秘密を教えた生徒が、偶然に記者の前に立っているのを発見した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スキーの跡は市内の方へ向いてその空地を斜めに横切り、どうやら向うの本通りへ乗り換えるつもりらしい。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶の水から甲武線に乗り換えると、おりからの博覧会で電車はほとんど満員、それを無理に車掌のいる所に割り込んで、とにかく右の扉の外に立って、しっかりと真鍮の丸棒を攫んだ。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて電車は、彼の乗り換えるべき停留所のところに来た。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "須田町で九段両国の電車に乗り換えると、不格好な外套を被て、この頃見馴れない山高帽を被った、酒飲みらしい老人の、腰を掛けている前へ行って、瀬戸がお辞儀をして、「これからお出掛ですか、わたくしも参るところで」と云っている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―８００１の開発にあたって自社で開発したベーシックを捨て、マイクロソフトのものに乗り換える決断を行ったのも、これが業界の標準的な地位を占めつつあるとの認識からだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶は国際列車のレールは各国共通に一本のものであるべき筈だから、列車は乗り換える必要がないと教える学者たちには賛成出来なかった。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちでも、「では、さきの方から乗り換えるのか？",
              "citation": {
                "source": "黄昏",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき登山電車に乗り換える時に、駅長に、上の方の天気はどうでしょうと聞いたら、霽れるとは思えない、という返事で、内心少からず不安を感じていたが、不安は失望に変って来だした。",
              "citation": {
                "source": "吹雪のユンクフラウ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスメーアのトンネルの中でまた乗り換える。",
              "citation": {
                "source": "吹雪のユンクフラウ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国鉄本線へ乗り換える前、三島神社で遊んだ。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "到頭十時二十分の大船で乗り換えるのにした。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "木津で、名古屋行きに汽車を乗り換えると、車内は何となく年末らしい気分のする旅行者が多勢乗っている。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と心で呼びかけておいて、電車に乗り換えるために、彼女と反対の方へ歩きだした。",
              "citation": {
                "source": "小説中の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、自分の家へ帰るにはその方が便利な郊外電車に乗り換えるために、或る途中の駅で汽車から下りた。",
              "citation": {
                "source": "燃ゆる頬",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その機会と思ひがあれば、やがて真実の生活へ乗り換えることは、いつでもできる。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬を牛に乗り換えるもいいが、日頃お二人さんの張合っているのを、百も二百も承知の上で、林蔵親分を袖にして、猪之松親分へ血道をあげ、狎れつくとは性悪の骨張だよ」　林蔵は内緒の前を離れ、用を達すと裏梯子から、自分の部屋へ返って来た。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからインパイア・ステート・ビルは八十八階でエレヴェーターを乗り換える……まあざっとこれくらいのところです。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子で和歌山行きの小さい汽車に乗り換えるころには、空が一面に薄曇りになって、何となく気持ちも晴れ晴れしなかった。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街電車へ乗り換える所へ来て、改札口で乗越賃を払おうとすると、釣銭がないと言って駅夫が向こうへ取りに行く。",
              "citation": {
                "source": "停車場で感じたこと",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の船に乗り換えるために、高雄で一泊することになった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタジオからの帰り、ちょうど夕暮れのラッシュにあたる時刻で、私と真理子のあいだにもぎっしりと人がつまり、私は打ち明けたのを後悔して乗り換える駅のくるのを心待ちにしていたはずだったが、だんだんとムキになった。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでバスに乗り換えるのである。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "悦子は今日の大垣行きが、蛍狩だけではないらしいことを早くも感じていた様子であったが、大阪で汽車に乗り換えると、「お母ちゃんは何で洋服着て来なんだの」と云った。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "若松から、博多、熊本方面に行く者は、ここで、乗り換えるのである。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はガイヨンの方へ乗り換えるためにヴェルノンで降ります。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで乗り換えると次の停留所が連隊前である。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあんな所でまたガレーヂの車にのりかえるとは。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、しっかりやって来たまえ」　そういう声に送られて、警部は暁の洋上に船をのりかえることになった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
