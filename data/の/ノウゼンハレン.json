        "examples": {
          "standard": [
            {
              "text": "サラダに彩りを添えるため、凌霄葉蓮の花を散らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この凌霄葉蓮、 edible flowers としても使えるんだよ」と、ガーデナーは教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちは、鮮やかな黄色の凌霄葉蓮の花を指さして喜んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "丈なす薔薇、色鮮やかな衝羽根朝顔、小さな淡紅色の花をつけた見上げるような莨の叢立ち、薄荷、孔雀草、凌霄葉蓮、それから罌粟。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
