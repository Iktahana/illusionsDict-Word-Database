[
  {
    "uuid": "780a65ef-14bd-528e-97c7-125cb2fd1a5f",
    "entry": "熨斗目",
    "reading": {
      "primary": "のしめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
