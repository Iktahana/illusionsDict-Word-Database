      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "variety of ceremonial dress made of intertwined cloth and silk threads",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「熨斗目」の腰に織り出してある横縞や、「取染」の横筋はいずれも宝暦前の趣味である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――これはこのあたりのものでござる――」　藍の長上下、黄の熨斗目、小刀をたしなみ、持扇で、舞台で名のった――脊の低い、肩の四角な、堅くなったか、癇のせいか、首のやや傾いだアドである。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾模様の五ツ紋、熨斗目の派手な、この頃聞きゃ加賀染とかいう、菊だの、萩だの、桜だの、花束が紋になっている、時節に構わず、種々の花を染交ぜてあります。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは熨斗目の紋着振袖という、田舎に珍しい異形な扮装だったから、不思議な若殿、迂濶に物も言えないと考えたか、真昼間、狐が化けた？",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが熨斗目ともありそうな、柔和な人品穏かに、「私は楽書はせぬけれどの、まずいと云うのを決して怒るな、これ、まずければ、私と親類じゃでのう。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女にしても見まほしい腮から横鬢へかけて、心持ち青々と苦味走ったところなぞ、熨斗目、麻裃を着せたなら天晴れ何万石の若殿様にも見えるであろう。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、忍のご城内では、何か高貴のおかたでもこよい城中に迎えるらしく、熨斗目麻裃の家臣たちが右往左往しながら、しきりとその準備に多忙をきわめているさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまた、きょうはどうしたことか、黒羽二重五つ紋の重ね着を着用に及んで、熨斗目の上下こそつけね、すべての服装が第一公式のお武家ふうでしたものでしたから、うるさいことにまた伝六が、血のめぐりのよろしくないところを遺憾なく発揮いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえは大役仰せつかったといったせりふを聞いて、出世したろうの、松平のお殿さまへ食いつこうのと途方もねえことをいって騒いでいるが、お年始へいった帰りだけだったのなら、熨斗目裃のご定服を着ているのがあたりめえなんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵能楽の間の狂言を模し、衣裳は素襖、上下、熨斗目を用い、科白には歌舞伎狂言、俄、踊等の状をも交え取った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "平島羽二重の熨斗目に、精巧織の袴をつけている人もあったし、木綿の絣を着流しに、跣足の尻端折で、ぴたぴた歩いて来た人もあった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから熨斗目麻上下、大小たばさんだ山岡｜主計、お証拠お預かりの宰領である。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に馬上で行くものは、即ち山内伊賀之助、熨斗目麻上下を着用し、総髪にして蒼白い顔、鷲のように鋭く澄み切った眼、広い額に善謀を現し、角ばった※に果断を示し、高い頬骨に叛気を漂わせ、キッと結んだ唇に、揶揄、嘲笑をチラツカせている。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉例によつて熨斗目長上下の若年寄が、能舞台の階段を昇り、橋懸へ来て幕に向ひ「お能始めませい」と声をかけた。",
              "citation": {
                "source": "よくぞ能の家に",
                "author": "二十四世　観世左近",
                "note": "青空文庫"
              }
            },
            {
              "text": "和綴のかなり厚い一冊物で、表紙は茶色の熨斗目模様、じゃばらの糸で綴じてあり、綴目の上下に紫色の切れが張ってあって『心の種』と書いてあります。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎の扮した高時の頭は円く、薄玉子色の衣裳には、黒と白との三つ鱗の模様が、熨斗目のように附いていました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃化粧の顔、高島田、金糸銀糸で刺繍をした肩衣、そうして熨斗目の紫の振袖――そういう姿の女太夫の、曲独楽使いの浪速あやめが、いまその舞台に佇みながら、口上を述べているのであった。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台には華やかな牡丹燈籠が、二基がところ立ててあり、その背後には季節に適わせた、八橋の景が飾ってあり、その前に若い娘太夫が、薄紫｜熨斗目の振袖で、金糸銀糸の刺繍をした裃、福草履を穿いたおきまりの姿で、巧みに縄をさばいていた。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無地｜熨斗目の、拜領物らしい振袖、袴は脱いで疊んであり、横顏の端麗さは非凡でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美少年國",
                "note": "青空文庫"
              }
            },
            {
              "text": "派手な熨斗目の着物を着たり、特に春団治は、初代二代ともに気違いじみた着物を着ていた。",
              "citation": {
                "source": "噺家の着物",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭は茶筅髷に熨斗目の着物、腰みの、唐人姿の乙姫さまが、やいのやいのというもてなしに腎虚寸前、ホームシックになり、帰りてみれば「色即是空」。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "登は熨斗目麻裃、まさをは白｜無垢に同じ打掛、髪は文金の高島田で、濃化粧をした顔は、人が違ったかと思われるほどおとなびてみえた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂に入り、月代を剃り、髪をあげ、丸に九耀星の家紋の付いた熨斗目麻裃を着せられた、彼はなにも云わず、人形のようにされるままになっていた。",
              "citation": {
                "source": "野分",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒羽二重の熨斗目の紋附に羽織袴を着けて立った姿は、縁側一杯に照らす麗かな日をまともに浴びて黒い七子の羽織地が銀沙のようにきら／＼光って居る。",
              "citation": {
                "source": "少年",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国老就任の挨拶なので、酒井家では老臣の関｜主税が接待に出、兵部と甲斐とは熨斗目麻裃に着替えた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、安芸は熨斗目麻裃を着け、出陣の熨斗を取って祝ったあと、玄関の式台前でまた酒肴を出し、留守の者から供をする小姓、徒の者たちにまで盃を与えた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙入の代りに足袋を懐中したり、扇子を忘れて文鎮を持っていったり、熨斗目の上へ継ぎ裃を着るなどという例がいくらもあった。",
              "citation": {
                "source": "日本婦道記",
                "author": "小指",
                "note": "青空文庫"
              }
            },
            {
              "text": "松の内の登城ですから、無論式服、熨斗目の裃に長袴、袴の括りは大玄関の板敷へ上がるとすぐに下ろして裾を曳くのが通例でした。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季その折々の風物の移り変りと、村の年中行事を、その時々にたのしめるようになったのは、私には、まだ、この二三年以来のことである。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして空気のしめりの丁度いい日またむずかしい諳誦でひどくつかれた次の日などはよくアラムハラドはみんなをつれて山へ行きました。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
