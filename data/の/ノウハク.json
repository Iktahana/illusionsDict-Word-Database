          "standard": [
            {
              "text": "彼は大学で農学を専攻し、最終的に農博の学位を取得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "農業技術の発展に貢献したとして、彼に農博の称号が贈られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この研究室には、数名の農博が在籍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "内閣にはいった渡辺千冬、世界的の学者となった農博、鈴木梅太郎、京城大学の総長だの、李王職長官だのになった法博、篠田治策だのが、それである。",
              "citation": {
                "source": "私の歩んだ道",
                "author": "蜷川新",
                "note": "青空文庫"
              }
            },
            {
              "text": "おととい仕事をすまして、きのうはくたびれていたが三越へ行って野原へあげるものを見て来て、きょうはのびのびとして貴方とさし向い。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうはくつろいで愉快でした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
