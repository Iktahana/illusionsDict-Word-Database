        "examples": {
          "standard": [
            {
              "text": "瞑想中は、特定の脳活動が活発になることがfMRIの研究で示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の脳活動をモニターすることで、嘘をついているかどうかを判別する実験が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "睡眠不足は、集中力や判断力に影響を与え、脳活動を低下させる原因となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この統計によって見ても明かなように高級な智脳活動にはすらりとした背も高いタイプが適し、工場の労働、農業などにはずんぐりで手脚も太短い娘が適しているのである。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、頭脳活動の重点主義が常に行き過ぎるといふ意味である。",
              "citation": {
                "source": "一国民としての希望",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、感覚的に趣味の洗煉といふ形で現れ、頭脳活動に於て速度と飛躍性とが加る。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、頭脳活動の局部への偏しかたが甚だしいといふ現象である。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経性の不調というのは頭脳活動をする人が折々やるものだそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
