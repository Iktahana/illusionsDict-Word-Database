      {
        "index": 1,
        "gloss": "taste (of a liquid, esp. alcoholic beverages)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
