        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "時局あて込みの幕末ものの字幕のイデオロギーなどは実に冷や汗をかかせるものである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは……九代の後胤平の、……と平家の豪傑が名乗れる如く、のの字二ツ附けたるは、売物に花の他ならず。",
              "citation": {
                "source": "草あやめ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでしょう、駄賃を稼ぐための職業婦人が聾の坊さんの杖つきのの字に附合っていられる筈はない。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "津の国屋――津国屋と書くのがほんとうだそうですが、暖簾にはやはり津の国屋と、のの字を入れてありました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "○くだものの字義　くだもの、というのはくだすものという義で、くだすというのは腐ることである。",
              "citation": {
                "source": "くだもの",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "つゆは汚れた白いまへだれをしてゐる男に、雜煮を二杯註文して、やがて運ばれて來た雜煮の中の、紅いのの字の模樣のついたかまぼこをおかづにして握り飯をひろげた。",
              "citation": {
                "source": "玄關の手帖",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "のの字になったり、Ｓの字になったりしてさかんに運動します。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女按摩は球江の躯ぢゆうに椰子油をぬるぬると塗りたくりながら、固い掌でゆるくのの字を書くやうなしぐさで、油で濡れてゐる背中を揉んでゐる。",
              "citation": {
                "source": "ボルネオ　ダイヤ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしくこれは、調伏呪語に使う梵語のの字なんだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖は漢音でよみ、村の名はのの字を入れて訓讀するのださうである。",
              "citation": {
                "source": "湖水めぐり",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のの字を描き、しの字を描いて、風に捩れ束になった焔が、蟒のように※って来る。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にひとり十一二の少年が、項には銀の頸飾をかけて、手に一本の刺又をかまえて一｜疋のの字は作者の造字）を目がけて精一杯で刺そうとしているのだが、※は身を翻して彼の胯の下からくぐり抜けて逃げてしまったのであった。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ得意になって書かれてある字にも誤って慢心したる者の字と、いわゆる分を知り、足るを知るものの字は大なる相違があって、第一慢心者の字は慎みがない。",
              "citation": {
                "source": "墨蹟より見たる明治大正の文士",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "またなお俗字として榿だの※だのの字が使われている。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のの字の誤り、これは萱と同字で、その漢音はケン、呉音はクヮン、共に忘れる意である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「格子の外から刺しておいて戸へ足をかけて刃物を抜いたことは格子の瑕でも見当はつくが、その足跡から見ると、お銀さんてえのは、四尺七、八寸の優形で女の身の持ち方知らずに刃を下へ向けたところから、左手利きをそのまま出して刀痕がのの字――。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "のの字の刀痕",
                "note": "青空文庫"
              }
            },
            {
              "text": "その筆初め「のの字の刀痕のこと」の項に、親分藤吉の人物と名声をこう説明してあるのだ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにやって来たか、この寂寞と荒涼たる焼跡の中の、僅かな安全地帯に立入って、柳の木の蔭に立休らい、いささか芝居がかった気取り方で、身体をゆすぶって、鼠幕のあたりを、頭でのの字を書いて見上げたところ、誰か見ている人があれば、そのキッかけに、「音羽屋！",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳にのの字を書きながら、ついうなずいてしまったのでございます。",
              "citation": {
                "source": "人でなしの恋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時「感激」がどんなにはげしくても、そして、その「感激」をわけあう男の人たちが数人集ったにしろ、仕事そのもののじみな本質は必ず経済問題にぶつからずにはすまない。",
              "citation": {
                "source": "その人の四年間",
                "author": "――婦人民主クラブの生い立ちと櫛田ふきさん――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば、ここは、病人だけがいるところであり、健康なもののじっとして、いられるところではありませんでした。",
              "citation": {
                "source": "だまされた娘とちょうの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　酒屋のおやじさんが、こっそりさぐらせると、なにかひどくくさいにおいのするもののじっけんにつかっているというのです。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかえってみると、いけがきの外から、いなかもののじいさんが、にこにこ笑いながらのぞいていました。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
