[
  {
    "uuid": "5f4b8a08-50f3-5054-81d4-61d29686fabb",
    "entry": "呪い",
    "reading": {
      "primary": "のろい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
