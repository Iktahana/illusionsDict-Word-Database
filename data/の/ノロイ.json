    "definitions": [
      {
        "index": 1,
        "gloss": "curse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "訣れは憤りと呪いを置土産にいで立ったものの、渡海の夜船の雨泊中に娘の家の庭から拾って来た福慈岳の火山弾を取出してみて、それが涙痕の形をしており、魚の形をしており、また血の色をしているところから福慈岳神としての娘の苦労を察し、決意のほどもほぼ覗えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り付きようもない娘の心にせめて親子の肉情を繋ぎ置き度い非情手段から、翁は呪いという逆手で娘の感情に自分を烙印したのだったが、必要以上に娘を傷けねばよいが。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "驢馬が頭を下げてると荷物があんまり重過ぎないかと驢馬追いにたずねましたし家の中で赤ん坊があんまり泣いていると疱瘡の呪いを早くしないといけないとお母さんに教えました。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おや、呪いをかけたね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あああ、さっきのホンブレンのやつの呪いが利いたんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その呪いの的になる人は時々変りはしたけれども、どういうものかおせいは貧乏籤をひいた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではまず第一に自分を救う、すなわち自分の不平、不安、失望、落胆、恨み、呪い、……などを征服するには、どうしたら良いでしょうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく立並んで呪いの眼で睨む。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの呪いは死人と慾を離れた人には効かないと云って居るじゃないか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――わたしは、生れてから一度も自分の為めにお母さんの呪いをせがんだことはありませんでした。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老女　――禁ぜられた呪いを犯すときには、お祖父さまの代から燃え続いて居るこの炉の火が消えて仕舞うのです。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか呪いの鬼となることは止めにして下さい。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿難を許せば、お前は一人で呪いを受けねばならないのだぞ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞわたくしを呪いの犠牲にして下さいまし。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿難　――いやわたしが呪いの犠牲になります。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）老女　――呪いは意志なのだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呪いは遂げることより外何物も知らぬ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呪いはただ貫く為に在る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなた達の大事な武器の呪いは今｜壊り損われようとして居るのだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の中央にて護法の諸天善神達と、呪いの方の眷属等と戦う。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呪いの方の眷属は多く妖艶なる美女の姿を装うて居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち呪いの眷属達は諸天善神達に打ち敗かされ、一人々々雲の上より突き落され、遂に掃蕩され尽す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのト書きに於て、諸天善神と呪いの魔の眷属の働きを、それは闘争にも見え舞踊にも受け取れると書いた。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧を呪いし罪によって地獄の責苦を受くる事よ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの呪いももとはといえば、娘の望みを遂げさせ度さの親心と、仏はみそなわされた。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は笑って何かかすかに呪いのような歌をやりながらみんなを指図しています。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏の運も久しからじ」などと、恐ろしい呪いの声を放つところであろう。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は早く夕飯を食って、九段の長い坂をもう一度あがって、裏四番町の横へはいると、どこの屋敷の甍もゆうぐれの寒い色に染められて、呪いの伝説をもっている朝顔屋敷の大きな門は空屋のように閉まっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の市電よりのろいくらいの速度で蛇のようにうねった線路を汽笛の代りにチャン／＼／＼と絶えずベルを鳴らして進むのである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばまた「のろい週期」などという言葉も平気で使うが「長い週期」というよりも日常会話にはこの方が実感があるから自然にそんな用例が出来るのであろうと思われる。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
