[
  {
    "uuid": "342dab18-3b8f-5064-9aed-60c84892394e",
    "entry": "逃す",
    "reading": {
      "primary": "のがす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to miss (e.g. a chance)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういう「事実の方則」がこの書の到る処に強調されているのを見逃すことは出来ないのである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれにしてもこのボーイの外貌について、一つ著しい変化の起っているのを見逃す事は出来なかった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃次第に露骨になりつつある都会のある階級の女のコケトリーについて、人から色々の話を聞かされていた私は、この無心の子供のこの非凡な註説を無意味には聞き逃す事が出来なかった。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さあ、斯うなつたら逃す事でないぞ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度こそ見逃すものか！",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその所作よりも、大きな帯や大きな袖に覆われてはいるものの、流石に年頃まえの小娘の肩から胴、脇、腰へかけて、若やいだ円味と潤いと生々しさが陽炎のように立騰り、立騰っては逸作へ向けてときめき縺れるのをわたくしは見逃すわけにはゆかなかった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはこう言ったあと、葛岡の肩に片手を置いたまゝ、睫毛の雫を邪魔にして頻りに眼瞼をしばたゝきながら、店の灯の照し出す葛岡の顔の色のひと揺ぎをも見逃すまいと見詰めております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "立った序にとて、弟は茶を淹れかえ、今度は自分で新しく桶から出した山独活を鉢で勧めまして、なおも話の続きから私たちを逃すまじき粘りを見せています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気はあせり、瞳は男の影像を見逃すまいと空を見つめて居るので、中々錠のありかが判らない。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "主の傷つき倒れたのを介抱しようとすると、利家「敵を逃すな」と下知した。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治六年の征韓論に就いての廟議の紛糾は、当時の重臣間に於ける文治派と武断派との意見の対立ではあるが、武断派の思想的背景としては、西洋文明の輸入に快からざる保守主義的傾向、攘夷思想の変形である国権論、武士階級の撤廃に対する不満、薩長専制に対する不平などが横はつてゐることを見逃すことが出来ない。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ逃すな」　道家も二人の近侍と斬り結んでいた刀を不意に引いて庭に逃げおり、崖の端に往くやいなや、「えい」　と、云う懸声と共に暗い川の中へ身を躍らした。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえどさくさまぎれで握るとしても少くとも二つの眼だけはそれを見逃すまい。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた、東北地方の農家の炉端を歌ってよくその地方色を出している詩として、佐伯郁郎君の『故里の爐辺を想ふ』をも見逃すことは出来ない。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が真実を見逃すことはあるまいよ。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「心の友よ、どんな事件も逃すものか。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその中からおずおずした物おびえのある顔を見逃すまいとした。",
              "citation": {
                "source": "女の首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東芝はパーソナルコンピューターでもスタート・ダッシュを決める絶好の機会を逃すことになる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パーソナル・インテリジェント・コミュニケータは複数のメーカーから販売されるだろう」とのビル・アトキンソンの指摘を思いだせば、後発からきっちりと文脈を付けてコンピューターに乗りだしてきたＳ社（繰り返しになるがソニーである）あたり、当然このアイデアを逃すはずはない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上先生の説かるゝ芸術論が、人生論が、難解であるといふことから学生たちは片言たりとも逃すまいとして耳をそばだて、速記に余念がなかつた。",
              "citation": {
                "source": "文学とは何ぞや",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うっかりと口をすべらせた以上、どうであなたの地獄耳が聞き逃す筈はありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れで彼等は少しでも異つた出來事を見逃すことを敢てしないのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作家の筆は、一見すると他奇なきものと見られますが、どうして容易ならぬ飛躍性が充ち充ちてゐて、うつかりと、われわれが技巧的なことなどを口にしたら、こつちこそ飛んだ自業自得に陥入るであらう、長成を見逃すことになるでせう。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "近時の欧州においてサー・オリヴァー・ロッジやロムブロゾーの如き大科学者が競って心霊現象を以てする来世問題の研究に没頭する如きは、見逃すべからざる事柄である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ見逃すべからざる点である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これキリスト以前に生まれし摯実なる心霊の来世探究史として、見逃すべからざる箇所である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼は、娘の一瞬の動作をも見逃すまいと眼をそばだてゝゐるところだつたので、極めて迷惑さうに、軽く点頭いたゞけであつた。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋と云つてもたゞの百姓家同然で、若しも軒先に煙草の看板ほどの酷く煤けた「おとまり宿」といふ板が掛つてゐなかつたら見逃すのが当然沁みた草葺屋根の不恰好な二階屋だつた。",
              "citation": {
                "source": "るい",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "当局も文化と民衆との接触がその作用の大きさに於て、見逃すことの出来ないことを認めてゐる今日、当局が今後文化人に対する奉仕の求め方も強くなつてくるものとみていい。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "その線路の右端の下方、すなわち紙の右下隅に鶯横町の彎曲した道があって、その片側にいびつな長方形のかいてあるのがすなわち子規庵の所在を示すらしい。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
