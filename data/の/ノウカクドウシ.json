        "examples": {
          "standard": [
            {
              "text": "「開く」は能格動詞の代表例で、物が「開く」とも、誰かが「ドアを開く」とも言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "英語の\"break\"も能格動詞として使われ、「The glass broke」と「He broke the glass」のように主語が変化する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "能格動詞の習得は、非母語話者にとってしばしば難しい点の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
