[
  {
    "uuid": "c63f15cb-a7ba-533c-909f-e87fa3751a00",
    "entry": "伸び",
    "reading": {
      "primary": "のび",
      "alternatives": [
        "ノビ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "growth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "村落の光る厩のうへに、かがやく愛の手は伸びゆきて、われの身は銀の一脈、ひそかに息づき生命はや絶えなんとする。",
              "citation": {
                "source": "厩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "番茶を一口すすって、「僕のこの不精髭を見て、幾日くらいたてばそんなに伸びるの？",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚がそよそよと伸びるのが肉眼でも判るほどだから、と真顔で教えたら、だまってしゃがんで僕の顎を皿のようなおおきい眼でじっと見つめるじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころに生え伸びたまだらな無精鬚。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と浦島は寢呆けてゐるやうな間伸びた口調で言つた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甍は伸びをし空は割れる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島山に住む人は、山のわたくし同様、驚異でいのちに傷目をつけられ、美しさにいのちの芽を牽出され、苦悩に扱かれて、希望へと伸び上がらせられなければならない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二人は顔を見合せましたら、燈台守は、にやにや笑って、少し伸びあがるやうにしながら、二人の横の窓の外をのぞきました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻き縮んだ黒焦の紙が一枚一枚するすると伸びて焼けない前のページに変る。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸びるのは縮まるためであり、縮むのは伸びるためである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸びるのが目的でもなく縮むのが本性でもなく、伸びたり縮んだりするのが生きている心臓や肺の役目である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが伸び切り、縮み切りになるときがわれわれの最後の日である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢のそばに寝ていた猫が起きあがって一度垂直に伸び上がってぶるぶると身振いをする。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、空の光の照明度がある限界値に達すると、多分細胞組織内の水圧の高くなるためであろう、螺旋状の縮みが伸びて、するすると一度にほごれ拡がるものと見える。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、病勢は変りなく、熱はなくなりましたが下痢は酷くおもゆとミルクでアゴ伸びるばかり（お粥をちょいと食うともういけません、情けない腹になりやがったものです）けれど懸命に頑張って居りますから此の手紙がそちらへ着く頃には（それが一ヶ月もかかるのでしたら）退院して本隊を追ッ掛けている筈です。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空はぐん／＼伸びてゆく、何者がそれを阻むことが出來よう。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顏は、自然に使ひ耗らされ、汚れ、皺だらけになり、旅行中嵌めきつてゐた手袋のやうに、伸び切つてしまつてゐる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い麦がずん／＼伸び上って来るのを見て楽んでいたことを思い出しているのだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いゝえ、まだ伸びません。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが今では、三尺ばかりに伸びて穂をはらんでいる。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇一の家には、麦が穂をはらんで伸びている自分の田畑があった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、銃が重くって、手が伸びているようだった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しおくれて、それまでは藤棚から干からびた何かの小動物の尻尾のように垂れていた花房が急に伸び開き簇生した莟が破れてあでやかな紫の雲を棚引かせる。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はその物音のする方を伸びあがるようにして覗きながら、また云い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "植込みの間をくぐってゆくと、そこには物凄いような大きい池が青い水草を一面にうかべて、みぎわには青い芒や葦が伸びていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、朝顔ももういけねえ、この通り蔓が伸びてしまった」「そうですねえ」と、庄太は首をのばして覗いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍にひかえている藤江も伸びあがって一と目みて、身をふるわせるように驚いたらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "若芽が伸びたアカシヤの葉末は、焚火に紅く染っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝の肖像、われらおよばぬ至上にあり、金屬の中にそが性の祕密はかくさる、よしわれ祈らば、よしやきみを殺さんとても、つねにねがはくば、われが樂欲の墓場をうかがふなかれ、手はましろき死體にのび、光る風景のそがひにかくる。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧のかげ夕方かけて読書かな夕立やかみなり走る隣ぐに沓かけや秋日にのびる馬の顔鯛の骨たたみにひらふ夜寒かな秋ふかき時計きざめり草の庵石垣に冬すみれ匂ひ別れけり　彼の俳句の風貌は、彼の人物と同じく粗剛で、田舎の手織木綿のやうに、極めて手触りがあらくゴツゴツしてゐる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
