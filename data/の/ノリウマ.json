        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「近ごろは正勝の野郎、浪岡にきり乗りませんよ」「浪岡を自分の乗り馬にするつもりなのかな？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪岡なら、乗り馬としちゃ最上の馬だからなあ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、この牧場の中でももっとも値段の出ている馬だし、調教を少しつければ、それだけでもう浪岡は貴族階級の乗り馬だよ」「それを正勝の野郎に勝手にさせておくなんて、そんな馬鹿なことはねえ！",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪岡をきみの乗り馬にしちゃ困るじゃないか？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三世紀に蒙古に遊んだ天主僧プラノ・カルピニの記に、その貴人死ねば天幕の真中に屍骸を坐らせ、鞍置き※附けた牡馬牝馬と駒各一疋を添え葬り、別に一牡馬を殺してその肉を食い、皮に藁を詰め棒｜尖に刺して立て、死者が冥界にあってもこの世と斉しく天幕に住み母乳を飲み、牡馬に乗り馬を飼い殖やし得と信じた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の方はニュシンゲン氏の二人乗り馬車で彼の夫人の横に座っている自分がまるで夢の中にいるように思われた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
