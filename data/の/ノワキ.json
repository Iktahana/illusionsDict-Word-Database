      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "typhoon in the early autumn",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "危機一髪、団子鼻に墮そうとするのを鼻のわきの深い皺がそれを助けた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたくしの言う事はどうしても聴いて頂けないの」　姫の切なげな懇願に昭青年は前後のわきまえも無くなって「では」と言って姫を川の中へ連れて入りました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は人から人へと語り繼がれて不朽なものとなり、一方は何んのわきまへもなしに言ひ傳へられるのである。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰府訪でし人帰りきての話に、かの女乞食に肖たるが襤褸着し、力士に伴いて鳥居のわきに袖乞いするを見しという。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に帰るや、炉に火を盛に燃きてそのわきに紀州を坐らせ、戸棚より膳取り出だして自身は食らわず紀州にのみたべさす。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕上の小卓の上に大型の扁平なピストルが斜めに横たわり、そのわきの水飲みコップの、底にも器壁にも、白い粉薬らしいものがべとべとに着いているのが目についた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁断を犯す仕事であるから、二人は忍び忍びに家を出て、どんど橋のわきで落ち合うことになっていたように聴いていると彼女は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はまるで前後のわきまえをなくしていた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山土のいろもあかく見えたる、あまりうつくしさに恐しくなりて、家路に帰らむと思う時、わが居たる一株の躑躅のなかより、羽音たかく、虫のつと立ちて頬を掠めしが、かなたに飛びて、およそ五六尺隔てたる処に礫のありたるそのわきにとどまりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてやはり琺瑯引きでとっ手のついた大きい筒形のコップをそのわきに並べて置き、そうしてコップの円筒面を鉢の縁辺に軽く接触させる。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂のわきのマドンナやクリストのお像にはお蝋燭がともって二三人ずつその前にひざまずいて祈っている。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の廊下の扉のわきに「宝蔵見物のかたはここで番人をお待ちくだされたし」という張り札がしてある。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意に自分のベットの足もとのほうでチョロ／＼／＼と水のわき出すような音がしばらくつづいて、またぱったりやむ。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居間のすみの箪笥のわきにある鏡台の前へすわって左から来る光に半面を照らさせ、そして鏡に映っているものは画架でも背後の箪笥でもその上にある本や新聞でも、見えるだけのものはみんなそのままにかいてみようと思ってやり始めた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた低気圧が来て風が激しくなりそうだと夜中でもかまわず父は合羽を着て下男と二人で、この石燈籠のわきにあった数本の大きな梧桐を細引きで縛り合わせた。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "複製原稿で最もおもしろいと思うのは、詩稿のわきに描き添えられたいろいろの化け物のスケッチであろう。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、これが、私の最も関心を有し、かつ久しく待ち望んでいたところのものでございまして、もうこれからは私も誰はばかるところなく、男性の権利を女性に対して主張する事が出来るのかと思えば、まことに夜の明けたる如き心地が致しまして、おのずから微笑のわき出るのを禁じ得ないのでございます。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベツドから降りて外套を脱ぎ、ドアのわきの釘へそれを掛けた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアのわきの壁に、兩腕をうしろへまはしてよりかかり、めくれあがつた上唇をことさらにきゆつと尖らせて言ふのであつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのわきに鏡がかかって、その下には長い柄のついたブラシが置いてあったのです。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「又三郎ほんとにあそごのわき水まで来て待ぢでるべが。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまもなくみんなは約束のわき水の近くに来ました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに沿うて二条のトロのレールが敷いてあって、二三町隔てた電車通りの神社のわきに通じている。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんがポチのわきにしゃがんでいた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうなすったのです……明りのせいかしらん、……お顔の色がお悪いようですが……」　火鉢のわきに小母さんが、園からずっと離れて茶箪笥の前におぬいさんが座をしめた時には、園の前にはチャブ台は片づけられていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その芸者も腹を立てたやうにつうつと立つてまた私のわきに来てしまつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "権兵衛茶屋のわきから蕎麦ばたけや松林を通って、煙山の野原に出ましたら、向うには毒ヶ森や南晶山が、たいへん暗くそびえ、その上を雲がぎらぎら光って、処々には竜の形の黒雲もあって、どんどん北の方へ飛び、野原はひっそりとして人も馬も居ず、草には穂が一杯に出ていました。",
              "citation": {
                "source": "鳥をとるやなぎ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのわきに鏡がかゝつて、その下には長い柄のついたブラシが置いてあつたのです。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "末座で挨拶をして、近常さんは、すぐに毛氈の上をずッと、鶏のわきへ出なさると、運八の次に居た、その富さんが座を立って出て、双方でお辞儀をして、目を見合って、しばらくして、近常さんが二度ばかり黙って頷くと、懐中の鏨を出したんです。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "塚の森の榎の根に、線香の煙淡く立ち、苔の石の祠には燈心が暗く灯れ、鉦は更に谺して、老たるは踞り、幼きたちは立ち集ふ、山の峽なる境の地藏のわきには、女を前に抱いて、あからさまに襟を搜る若い男。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
