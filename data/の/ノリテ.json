        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それがなか／＼面白いもので、どこを來てゐるか知らんと思つて、時々乗り手がふり返つて見る。",
              "citation": {
                "source": "日高十勝の記憶",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "またでこぼこしているため、熟練の乗り手でなければ越えられないほどだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然歯をむき出して気たゝましい叫びと共に前脚を挙げて、件の乗り手に踊り掛つた。",
              "citation": {
                "source": "写真に添えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あだかも意地の悪い馬がなれぬ乗り手にするように、船体は猛烈にその背を振った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り手は先ず第一に肥前家の臣で、大坪流の古高新兵衛。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り手の主こそ見えないが、いずれもそれらはひと目にそれと、使用の客の容易ならぬあだ者であることをじゅうぶんに物語っている品々ばかりなのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠はからっぽであっても、人足がついておったら、ぽつりぽつりとどこにいくつ置いてあってもいっこうに不思議はねえが、乗り手もかつぎ手もまるで人っけのねえ気味のわるいから駕籠ばかりがひょくりひょくりと、それもよく考えてみりゃお城のまわりなんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠の向きをしちっくどく聞いてみたのは、ひとりだか七人だか知らねえが、七つの捨て駕籠の乗り手がどこから先に捨てはじめて、どこで捨て終わっているか、それを探ってみたんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとも不審、いかにも奇怪、から駕籠と思いきや、中にはじつに不思議な乗り手が黙然として乗っていたからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "――唸って飛んで栗毛の足にハッシとからみついたかと見えるや、馬は竿立ち、笑止にも乗り手は地に叩きつけられました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "艫と舳の二カ所に赤々と篝を焚いて、豪奢極りない金屏風を風よけに立てめぐらし、乗り手釣り手は船頭三人に目ざむるような小姓がひとり。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならば、乗り手に罪がある筈。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密の急使に立つ乗り手の八人は、伊豆小姓と江戸に評判の美童ぞろい――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人が乗るんだから、ヒンヒンはねちゃいけねえぜ」　馬ぐらい乗り手を見分けるものはない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや、乗り手が伝六とあっては、くろも南町ご番所名代のこのひょうきん者をよく知っているとみえて、長い顔をさらにぬうと長くのばして笑ったまま、動こうとしないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やじうまじゃ乗り手もありゃしねえや、べらぼうめ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車を追い越し追い越し行くので、割り合い乗り手がある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "面紗をへだてゝゐるので観衆には私の表情が在りのまゝには映らなかつたのか、「ゼーロンの乗り手の顔は、男らしいぞ」とか「眼つきが強さうだぞ！",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄馬ではあったが乗り手がたっしゃ、パッ、パッ、パッと走りだした。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り手の顔かたちは、とうに見定めがつかなかつたが八丁櫓と六丁櫓の夫々の漕ぎ手が此処を先途と腕をそろへ、息を合せて漕げや漕げ、曳哉、曳！",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り手の一同が気勢を合せて、舟舷に逼ひ寄らうとする彼に伴れて、徐徐と舟の中心をとらなければならなかつた。",
              "citation": {
                "source": "西瓜喰ふ人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り手は、手綱を引いたり、拍車を当てたり、大騒ぎだ。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、父ほどの乗り手を見たことがない。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その馬上の姿は実に美しく、無造作に楽々と乗りこなしているところは、鞍の下の馬までが感じ入って、乗り手を誇りとしているように見えた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬といふものは、多くの場合、乗り手よりも剛健な精神と剛健な肉体とを持つてゐるから、滅多に下らない乗り手の蔭口なぞ利かうとしないが、もしか馬が亜米利加の大統領か新聞記者のやうなお喋舌だつたら、世間は今とはもつと違つたものになるに相違ない。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ舟にのりて行かば、くるほしきなみの亂れもここちよく、ちのみごの夜びえする、あやしきこゑもきかであるべきに、ふるとせひとにかくれて、わがはぐくみしいろぐさのはや涸れぬとぞ、けふきけば薄葉に涙しをるる、よしゑやし、悲しきものはあだがたき、君ならなくに、はやも我が世をのがれいでばや。",
              "citation": {
                "source": "浮名",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祈りをあげ、祈りをあげ、さくらはな咲けども終日いのりて出でず。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついにのりて盛岡につきぬ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "越ヶ谷の停車場より馬車にのりて、野田に赴かむとするに、馬車今來しばかりにて、まだ時間がありさう也。",
              "citation": {
                "source": "春の郊外",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜は宵より庭をめぐり、三たびか鞭もて追ひしものを、夜ふけて林檎の下葉がくれ、守る身も忘れて夢に入れば、こはまた、下枝の風にのりて、語るよ、小狐聲も低く母見ぬ闇路を庭にかくれ、人の子戀ひ行く汝が身なるに、雛鳩與へよ、否といはば、翌くる夜鳴かまし、君が影に。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
