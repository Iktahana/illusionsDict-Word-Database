    "definitions": [
      {
        "index": 1,
        "gloss": "one's feeling while riding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
