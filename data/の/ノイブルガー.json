        "examples": {
          "standard": [
            {
              "text": "オーストリアの特定の地域で栽培されるノイブルガーは、独特の個性を持つ白ワイン品種だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このレストランのワインリストには、珍しいノイブルガー種のワインが載っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ノイブルガーから造られるワインは、軽やかでありながらも複雑なアロマが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ノイブルガーは簡単に次のように要約している。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノイブルガー(16)が引用しているマクリツィの記載によるとまるで20世紀の病院である。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "人体解剖についてのフリードリッヒ１世の指示はノイブルガーによると単に形式的なものであった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
