    "definitions": [
      {
        "index": 1,
        "gloss": "to make someone fall forward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "背のあたりに白斑二つ三つある赤毛のめす子である。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "投げられた遊び人泡食って、Ｔ「ナッナッ何かの間違いですよ」　と言いわけするのも聞かず、さんざん叩きのめす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦とも言わせず、踏のめす気か足を挙げた赤熊は、四辺に人は、邪魔は、と見る目に、御堂の灯に送らるるように、参詣を済まして出た……清葉が、朧の町に、明いばかりの立姿。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚は釣れず、濡鼠になって、大洗（大笑い）になるまでさ」と洒落のめす。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスケット銃を持った兵士をたたきのめすことと、人を惨殺するのを傍観するのは別のことだ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次はぽつさりと立つて居るおつぎを突きのめす樣に戸口に送つてがらりと戸を閉ぢて掛金を掛けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "馭者は舌を上へ捲いてキツ／＼キと口の中で妙な聲をさせて革の手綱を緩めると馬は首を前へのめす樣にして蹄を立てゝ二足三足と重相に歩き出した。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度生血の味をしめた虎の子のような渇欲が葉子の心を打ちのめすようになったのはそれからの事である。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前のつり鐘を打ちのめす意気合いで、みごとに恨みを晴らしてしんぜられよ」　なんじょう黙山の今はちゅうちょすべき、かわいい声をふりあげると、姉上兄上ふたりのかたき思い知ったかとばかりに、大きく袈裟掛けに二太刀切りさげました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蚊のめすは、とくに長いくちばしをもつてゐます。",
              "citation": {
                "source": "パナマ運河を開いた話",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "のめすならのめす、斬るなら斬ってみろい！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「監督をたたきのめす！",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この野郎、要らねえ事をしやべると、たゝきのめすぞ。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "モレエヌはラブレエのやうに笑ひのめす花。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ちぇっ、折角日本軍を叩きのめすに足る新兵器が出現したのになあ……」　この後は、録音なし。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らのあの眼なざしほどに今の杉村をぶちのめすものはない。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅多に手荒なことをしたことのなかった父親をして、終にお島の頭髪を掴んで、彼女をそこに捻伏せて打のめすような憤怒を激発せしめた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまだ懲りずに、彼奴はそのやくざを自慢の種にして、この人生を金テコでぶちのめすような滅茶な調子で、押しまくって生きようとするのだ！",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォツカの雫で濡れ放題のカウンターを、その団扇みたいな手で歪むほど打ちのめすと、尻尾を踏んづけられた狼のような唸り声をたてて、蹴倒した木椅子を両脚で突き飛ばしながら、亭主が巨大な図体を癇癪の筋だらけにして飛び出して来た。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には息もつまるような大暴風雨で、小さい人間共の魂を、いやと云う程打ちのめす事もあるのでございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんしゃくを起こして酷く私を殴ちのめすんです。",
              "citation": {
                "source": "六月",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この元気でもって、帝都市民の生活を脅かすあらゆる悪漢どもを一掃してやろう」　課長はその悪漢どもを叩きのめすような手附きで、オ一チ二イと体操を続けていった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると真夏の太陽がカアンというあの変テコな沈黙でいやというほど俺の頭を叩きのめすものだから、俺は危く目をまわそうとするのじゃよ。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "聖なる酔っ払いは神々の魔手に誘惑された話",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると真夏の太陽がカアンといふあの変テコな沈黙でいやといふほど俺の頭を叩きのめすものだから、俺は危く目をまはさうとするのぢやよ。",
              "citation": {
                "source": "木枯の酒倉から",
                "author": "――聖なる酔つ払ひは神々の魔手に誘惑された話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "板で叩きのめすような衝動が清家博士の身体を襲った。",
              "citation": {
                "source": "空気男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
