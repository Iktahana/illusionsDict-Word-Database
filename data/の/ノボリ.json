  {
    "uuid": "a98a9a87-d411-5977-9479-320a705141f4",
    "entry": "幟",
    "reading": {
      "primary": "のぼり",
      "alternatives": [
        "ノボリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "nobori",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "商店の赤地に白く染め抜いた幟は影を落としてる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏見人形に思い出す事多く、祭り日の幟立並ぶ景色に松蕈添えて画きし不折の筆など胸に浮びぬ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "油地獄にも、ならずものの与兵衛とかいう若い男が、ふとしたはずみで女を、むごたらしく殺してしまって、その場に茫然立ちつくしていると、季節は、ちょうど五月、まちは端午の節句で、その家の軒端の幟が、ばたばたばたばたと、烈風にはためいている音が聞えて淋しいとも侘びしいとも与兵衛が可愛そうでならなかった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶屋のボンボリの仄白い光の中から、芝居小屋にかかげられた幟の列を俯瞰する。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の秋のお祭りに、太鼓を舁いだり、幟をさしたり、一張羅の着物を着てマチへ出る村の人々は、何等か興味をそゝって話の種になったものだが、東京の街で見るものは彼等にとって全く縁遠いものだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由のない不安と憂鬱の雰囲気のようなものが菖蒲や牡丹の花弁から醸され、鯉幟の翻る青葉の空に流れたなびくような気がしたものである。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔一〕谷権現の祭りとて、　　　　　麓に白き幟たち、むらがり続く丘丘に、　　　　鼓の音の数のしどろなる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうした町も今は屋根瓦の間へ挾まれてしまって、そのあたりに幟をたくさん立てて芝居小屋がそれと察しられるばかりである。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の影ならず、血だらけの抜刀を提げた、半裸体の大漢が、途惑した幟の絵に似て、店頭へすっくと立つと、会釈も無く、持った白刃を取直して、切尖で、ずぶりとそこにあった林檎を突刺し、敵将の首を挙げたるごとく、ずい、と掲げて、風車でも廻す気か、肌につけた小児の上で、くるりくるりとかざして見せたが、「あはは。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "横町には斜に突出して、芝居か、何ぞ、興行ものの淺葱の幟が重なつて、ひら／＼と煽つて居た。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "入って見ると、裏道の角に、稲荷神の祠があって、幟が立っている。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉幟を見て　青空に高く、五月の幟が吹き流れてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉幟を見て　　日本の鯉幟りは、多くの外國人の言ふ通り、世界に於ける最も珍しい、そして最も美しい景物の一つである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――人間の意志の力ではなく、自然の氣まぐれな氣流ばかりが、鯉幟りの魚を泳がすやうに、我我の子供等もまた、運命を占筮されてゐるのである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一に自由、夫から統一」といふ叫び声を無意味なものとして聞き流した彼は、「第一に国家の権利、夫から国家」といふ旗幟を無遠慮に押し立てた。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は競争で大文字の千字文から、しまひには手に余るやうな太い筆を持つて旗や幟の字まで書いたりした。",
              "citation": {
                "source": "私の書に就ての追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "油地獄にも、ならずものの与兵衛とかいふ若い男が、ふとしたはづみで女を、むごたらしく殺してしまつて、その場に茫然立ちつくしてゐると、季節は、ちやうど五月、まちは端午の節句で、その家の軒端の幟が、ばたばたばたばたばたと、烈風にはためいてゐる音が聞えて淋しいとも侘びしいとも与兵衛が可愛さうでならなかつた。",
              "citation": {
                "source": "音について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後又、北は塞を出でゝ元の遺族を破り、南は雲南を征して蛮を平らげ、或は陝西に、或は蜀に、旗幟の向う所、毎に功を成す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "江｜乃ち兵を率いて※沱を渡り、旗幟を張り、火炬を挙げ、大に軍容を壮にして安と戦う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉が憎んだ佐々成政の三蓋笠の馬幟を氏郷が請うて、熊の棒という棒鞘に熊の皮を巻付けたものに替えたのは、熊の棒が見だてが無かったからと、且は驍勇の名を轟かした成政の用いたものを誰も憚って用いなかったからとで有ったろうが、秀吉に取って面白い感じを与えたか何様か、有らずもがなの事だった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑乱は旗幟紛※として彼我酣闘する也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると正月の事であるからして、船は何れも陸に揚げてあつて、胴の間には竹、松、橙を飾り、艫には幟を立ててある。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またやや大きな船になると、幟の意匠も亦複雜になる。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔卑屈の友らをいきどほろしく〕宮沢賢治卑屈の友らをいきどほろしく粘土地二片をはしりてよぎり崖にて青草黄金なるを知りのぼりてかれ草黄なるをふめば白雪きららに落ち来るものか一列赤赤ならべるひのきふたゝび卑屈の友らをおもひたかぶるおもひは雲にもまじへかの粘土地なるかの官庁に灰鋳鉄のいかりを投げよ",
              "citation": {
                "source": "〔卑屈の友らをいきどほろしく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔霜枯れのトマトの気根〕宮沢賢治霜枯れのトマトの気根その熟れぬ青き実をとり手に裂かばさびしきにほひほのぼのとそらにのぼりて翔け行くは二価アルコホール落ちくるは黒雲のひら",
              "citation": {
                "source": "〔霜枯れのトマトの気根〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルヒ　アサカラ　ヨイテンキヤマヘ　ユキマス　シバカリニ　このお爺さんの樂しみは、お天氣のよい日、腰に一瓢をさげて、劍山にのぼり、たきぎを拾ひ集める事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来わが血の大方は頭にのぼり、煮え返り、滾り泡だつ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚がこんどはそこら中の黄金の光をまるつきりくちやくちやにしておまけに自分は鉄いろに変に底びかりして、又｜上流の方へのぼりました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よだかはむねがつかえたように思いながら、又そらへのぼりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧がはれて、お日さまが丁度東からのぼりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
