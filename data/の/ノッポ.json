        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ニューヨークで安ホテルを捜しあてたときに帳場に居たのっぽの番頭がやはりチューインガムを噛んでいた。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりのせいたかのっぽの子どものまたの下をくぐって、神さまは森へにげかえりました。",
              "citation": {
                "source": "子どものすきな神さま",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲の高い西洋の町であれ程背低だった加奈子が今｜茲ではひどく背高のっぽになった気持だ。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、大柄ののっぽうの、それでいていつも棗のような顔をして眼の細い、何か脱俗している好々爺が著て来たのがこれであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも白っぽいなと見ていると、またその後からのはのっぽで白で、大跨だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと無邪気なのっぽ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーターヘッドのサイディ・ムドナルドもそれを見たと言い、シェットランドの背高のっぽうのピーター・ウィリアムソンもそれを見たと言い、ミルン氏もまたブリッジで確かに見たという。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいて戸を叩きますと、すぐ入口は開いて、のっぽでがりがり、いかつくて怖い面の女が出てきました。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "背は六フィートを越える程度だが、ひどく細身のためそれ以上ののっぽに見える。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただすこしのっぽにそだちすぎたかもしれない。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やめてくれ、のっぽうめ！",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "「のっぽ」とよし子が一言答えた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっぽな露西亜種の向日葵が、野球用の革手袋を思わせるような大きな盤の上に、高々と大粒な実を盛り上げて、秋風に吹かれているのは哀れが深い。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　目じるしが火の見やぐらというのっぽの背高でしたから、に組の火消し番所は労せずしてすぐと見つかりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこんところに毛ずねをまる出しにして伸び上がっているのっぽは、どこの野郎だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おう、早く入れ」「はっはっはっはっ」　のっぽの川上機関大尉は笑いながら、ぬっと室内に入る。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも兵科は違っていて、背高のっぽの川上大尉は機関科に属しており、長谷部大尉は第三分隊長で、砲を預かっていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月に葉が生れかわると云う事やつつましげな輝きや、やたらに大きくのっぽに育たない事なんかが私の心を引いたのだ。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがて四十を少し出たくらいの、のっぽうの女が現われた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "若殿はのっぽでお出になるからなあ」　りよは顔を赤くした。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の皮膚は赤銅色をして大きい目鼻は怪鳥のような凄みを持った、馬鹿にのっぽな、カインの末裔を思わせるような人間だった。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "節子さんは娘時代には、一｜反半なくては、長い袖がとれなかったという脊高のっぽ、浜子は十貫にはどうしてもならなかったか細い小さな体だった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿入れの丹前をひっかけた、のっぽの仙太が、ひょろひょろした足どりで町中を歩いていると、人びとは避けるようにして、足早にすぎてしまう。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バアナア街の場合など、運送屋の下｜請けのようなことをしている男が小馬車を自宅の裏庭へ乗り入れて、そこに、血の池の中に仆れているエリザベス・ストライド――綽名を「のっぽのリック」といって背が高かった。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "のっぽのリッツ――エリザベス・ストライド――で、この付近で名うての不良少女だった。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　半ポンドの葡萄を紙袋に入れて、パッカアが差し出すと、のっぽのリッツ――エリザベス・ストライド――が、受け取った。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "けしからん奴だ、あの野郎――月尾寒三というんですよ、そののっぽ野郎は……」「ほう、月尾寒三ですか」　袋探偵はうっかりしていて、烏啼のラブ・ネームを調べることを忘れていた。",
              "citation": {
                "source": "心臓盗難",
                "author": "烏啼天駆シリーズ・２",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやだなあ」　と、のっぽの山木がさわぎだした。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小面倒な家族関係で揉まれていたら、今ごろはもう少し人間が悧巧になっていたかと思うけれど、何しろのっぽう一方で暮してきたんだから自分ながら始末にいけない。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
