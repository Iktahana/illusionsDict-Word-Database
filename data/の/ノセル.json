    "definitions": [
      {
        "index": 1,
        "gloss": "to place on (something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "踏んで蹴って又投げつけて、　格闘暫時――　結局フラフラの半次を軽々と肩に乗せる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が担架に乗せるとて血でぬる／＼している両脇に手をやると、折れた骨がギク／＼鳴った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士「よろしい、私お二人とも乗せます」青年（笑いながら）「悪漢みたいだな、知らん人を自動車へ乗せるなんて、あんたは」紳士「冗談じゃない、そりゃ、アメリカのことですよ。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも馬車へ乗せるとか乗せぬとかいう話らしい。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この軽気球はそもそも商店の広告なぞではなく、一時間一円で博覧会のお客を乗せる目的から備えつけられたものである。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども乗せる前に、オーレ・ルゲイエは、いつもこうたずねました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた方のような珍らしい夫婦を乗せるのは一生の話の種だ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、近くの村の青年の寄り合いに雇われたが、案内に来た青年は馬方で、馬力の荷物のうしろの方に空所を作って、そこに座布団を敷いて、三味線と、下駄を抱えた女を乗せると、最新流行のスットントン節を唄いながら、白昼の国道を引いて行った。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "河の流れへ顔を向けて貝の片殻のやうに展げた掌に頬を乗せる。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "判事に浮世ばなしを促されたのを機にお幾はふと針の手を留めたが、返事より前に逸疾くその眼鏡を外した、進んで何か言いたいことでもあったと見える、別の吸子に沸った湯をさして、盆に乗せるとそれを持って、前垂の糸屑を払いさま、静に壇を上って、客の前に跪いて、「お茶を入替えて参りました、召上りまし。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　人を煽てに乗せることをよくない趣味と心得て居乍ら、而も職業としては悪びれず、何処迄もそれを最上の商法信条とする。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうと知ったら、君枝を自転車に乗せるんやなかったんや。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車に乗せるたんびに終点まで行ってしまうような健康な精神病者や痴呆患者が出来上る。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうと知ったら、君枝を自転車に乗せるんやなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車は二人を乗せると市立精神病院を出て、直ぐ繁華な街へ出て行った。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に乗せるだわさ。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大変なものに乗せるんだな。",
              "citation": {
                "source": "光籃",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおかまを乗せると、約二十五分で米が炊き上がったという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先ず、スペース・トラベルというゲームを乗せるために、この『玉抜き』環境を整備した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ裾野のコンピューター市場ではマッキントッシュがますます栄え、はびこったＤＯＳの上にＷｉｎｄｏｗｓを乗せるマックの物真似が受けに受けている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンは誰が何といおうとＳＰＡＲＣを推進するし、アップルは自分でマッキントッシュのＯＳをＲＩＳＣに乗せる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つのハードの双方に二つのＯＳを乗せることができて、そのどちらでも同じアプリケーションが走る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局避難者を乗せる為に列車が来るから、帰ってからでなくてはいけないということであった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れ切っている二人は木枕に頭を乗せるとすぐに高いびきで寝付いてしまったが、およそ一※も経つかと思うころに紋作はふと眼をさました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫たちは、ボーイ長を彼の背中に、そうっと乗せるようにした。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十余年前まで但馬因幡地方で馬極めて稀なり、五歳ばかりの児に馬を知るやと問うと、顔を長く四疋と尾あり人を乗せると答う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、読みかけの新聞を、帽子をかむったままの顔の上へ乗せるようにしたまま、どうやら居睡りでもはじめたらしく、軽い鼾が聞えて来る。",
              "citation": {
                "source": "香水紳士",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はいたずら者らしくひとり笑いをしながら立て膝をしてみたが、それには自分ながら気がひけたので、右足を左の腿の上に積み乗せるようにしてその足先をとんびにしてすわってみた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前をまで相談に乗せるような事はいらんのだよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父上はこれに一々｜水引をかけ綺麗にはしを揃えて、さて一々青い紙と白い紙とをしいた三宝へのせる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
