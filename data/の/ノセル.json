        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駅まで車に乗せてくれてありがとう。助かったよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雨が降っていたので、隣の家の子供を学校まで乗せていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "もしよかったら、次の会議まで私を乗せていってくれませんか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to load (luggage)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
