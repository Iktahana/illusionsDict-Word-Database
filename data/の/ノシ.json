    "definitions": [
      {
        "index": 1,
        "gloss": "bye-bye",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○オクツタ」ユイノウタノム」ケツコンシキノシタクセヨ」アスペキンタツ」オオスミチユウタロウ　同時に電報｜為替で百円送られて来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に茨木君は「コノシロ」池の写生に出かけられた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "○わたくし達は、外でお友達と一緒の時は「ノシちゃえ」なぞと随分、男のような言葉も使ってわあわあ騒ぐ。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、舞台の方から例の強い男、事件出態とばかりノシノシ出て来た。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『センダガヤノシヨウジヨゴロシノハンニンケンキヨサレマシタ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクタチ兄ダイハ、ナカヨク、タッシャニ、コノシマニ、クラシテイマス。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "エノシマヘフタリッキリデデカケルノイヤ？",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『エノシマヲフタリッキリサンポスルノイヤ？",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマキチ　ハ、ソコラニ　タノシソウニ　オヨイデ　イル　サカナ　ニ　イイマシタ。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オットセイの黒ずんだ肉を売る店があったり、猿の頭蓋骨や、竜のおとし児の黒焼を売る黒焼屋があったり、ゲンノショウコやドクダミを売る薬屋があったり、薬屋の多いところだと思っていると、物尺やハカリを売る店が何軒もあったり、岩おこし屋の軒先に井戸が二つあったり。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の先に巨漢がノシノシと近付いて来た。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平「蜂谷君じゃないか」十吉「じゃ、やっぱし中瀬古君か」庄平「うん、イノシシだよ」十吉「あわて者の」鶴三「お知り合いでしたか」庄平「中学時代一緒だったんですよ、もう十年も会わぬが、面影はあるね」十吉「実は、先刻君を見たんだよ、学校で」庄平「マラソンをやってる処を」十吉「うん」庄平「どうして声を……？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、来るときには連中は問答無用でノシノシと上がり込んでくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年は亥の歳だから、例に依ってイノシシの話の原稿を早く纏めて送れという訳と解いたので、初めて気が付いてこの篇に取り掛かった。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今村鞆君の『朝鮮風俗集』二〇八頁に「亥は日本ではイノシシであるが、支那でも朝鮮でも猪の字は豕の事で、イノシシは山猪と書かねば通用しない。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに和漢とも後には老いたる豕も本は子であったから猪、イノコと唱えたので、家に畜う家猪に対して、野生の猪を野猪また山猪、和名クサイイキ、俗称イノシシという。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど家猪を飼う事早く絶え果てたから正にイと名づくるものがなくなり、専らイノシシすなわち野猪をイと呼び、野猪の子をイノコと心得るに至った。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "本篇を読む方々に断わり置くは、猪の事を話すに一々家猪、野猪を別つはくだくだしいが、特に野猪と書いた場合はイノシシに限り、単に猪と書いたのは家猪野猪を並称し、もしくはいずれとも分らぬを原文のまま採ったのである。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃支那人が家猪を持ち来ったのを、日本人が野猪イノシシの略語でシシと呼び、山羊をヤギと呼んだのだ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿はカノシシ、野猪はイノシシ、紀州の鹿瀬、井鹿、いずれもシシガセ、イジシ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪を邦訳の絵本にイノシシと訓ませ居るが、それでは烏斯蔵国の高太公の女婿となって三十人前の食物を平らげたり、三年間妻を密室に閉じ籠めて行ない続けたり、渡天の途中しばしば女事で失敗したり、殊にはこの書の末段に、仏勅して汝懶惰にして色情いまだ泯びざれども浄壇使者と為すべし、汝｜原食腸寛大にして大食を求む。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいか、おまえがやられたら、おれがノシにいく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいいが、ふつうの寮生がスニーカーやテニスシューズを愛用するのとは異なり、片桐は、三センチぐらいのヒールのついた黒いチャッカーブーツで、点呼だろうが、食堂だろうが、学校だろうが、どこへでもノシていくので、そのたびに問題になる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい苦痛に対処するために、藤井が鼻を押さえていた手をさげたので、ブーツの靴底が、藤井の顔を平らにノシた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねばれる蛇の卵見ゆ、かつは臭のくさければガメノシユブタケ顰めつつ毛根を水に顫はす。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
