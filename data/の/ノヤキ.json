    "definitions": [
      {
        "index": 1,
        "gloss": "burning off a field (in early spring)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "草刈り・野焼きの歌なども、すべて経験から出てゐるとは言へない。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると「おもしろき」も野焼きの火に過ちなき様になど言ふ原義を没した用途を持つてゐたのかも知れぬ。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "野焼きを否定する心が、一転して、其焼く心を咎める心地から転じて、不都合にもわが心をかく燃えしめる、と言ふ譬喩に用ゐたのである。",
              "citation": {
                "source": "副詞表情の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅原や　むねの板間の　あはぬ限りは」は、古代にある野焼き歌の類型が、象徴的に感じられる所から、神祇の御作と言ふことになつた訣であらう。",
              "citation": {
                "source": "副詞表情の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらあたりは一面の草原なれば、春のころは野焼きのあとの黒める土より、さまざまの草｜萱萩桔梗女郎花の若芽など、生え出でて毛氈を敷けるがごとく、美しき草花その間に咲き乱れ、綿帽子着た銭巻、ひょろりとした蕨、ここもそこもたちて、ひとたびここにおり立たば春の日の永きも忘るべき所なり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前の春の初め、野焼きの火が燃えのぼつて来て、唯一宇あつた堂が、忽痕もなくなつた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前の春の初め、野焼きの火が燃えのぼつて来て、唯一宇あつた萱堂が、忽痕もなくなつた。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前の春の初め、野焼きの火が燃えのぼって来て、唯一宇あった萱堂が、忽痕もなくなった。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "河内平のあちこちの野で、野焼きをしている火がひろい闇の中に美しく見えたからである。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、さういふきれいなたべものやきものをすきです。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは、そういうきれいなたべものやきものをすきです。",
              "citation": {
                "source": "『注文の多い料理店』序",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "禰宜　箒で、そのやきもちの頬を敲くぞ、立ちませい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お皿に愚かしく積まれてある五切れのやきざかな（それはもう鯛では無い、単なる、やきざかなだ）を眺めて、私は、泣きたく思つた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」人格円満のＮ君は、平気でそのやきざかなに箸をつけて、さう言つた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇気、失望、狡猾、落胆、負け惜しみ、慰め――その間には叩かれた女の掌のやきもち筋も見えるよ。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この国のやき物は東洋のを粉本にしつといへど、染いだしたる草花などの色は、我｜邦などのものに似もやらず。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この国のやき物は東洋のを粉本にしつといえど、染めいだしたる草花などの色は、わが邦などのものに似もやらず。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「綺麗な方だわ、だけど、どうも人間にあんな綺麗な方はないと思ったら、やっぱり狐ですよ、私は蓮香さんが帰るとき、後からつけて往くと、南の山の穴へ入ったのですもの」　桑はそれは李のやきもちだろうと思ったので、いいかげんにあしらっていた。",
              "citation": {
                "source": "蓮香",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、大変ですよ、やっぱり人間じゃありません、疑わずに早く関係を絶つ方がよござんす、あなたは冥途が近いのです」　桑は蓮香のやきもちだと思ったので、黙って何も言わなかった。",
              "citation": {
                "source": "蓮香",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その酒場のやきもちの怒声が、へんに思想めいた顔つきをして民衆のあいだを練り歩き、民主々義ともマルキシズムとも全然、無関係の言葉の筈なのに、いつのまにやら、その政治思想や経済思想にからみつき、奇妙に下劣なあんばいにしてしまったのです。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず上等なところでお多根｜菩薩のやきもちというところかね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "母さんにしろ此処の姉さんだつて、いざとなれば気狂沙汰のやきもちやきなんだから可笑しくつて仕様がないや。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中で一番のやきもちやきはあの爺だらうと妾は思つてゐるんですが……」　私はテルヨから左う聴いた時、驚きのあまり思はず胸一杯に空気を吸ひ込み、長い※があるかのやうに顎を掴み百貫の鉄棒のやうに徐ろに左腕を宙にあげてゐた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして角太郎は旦那の隠し子ですもの、腹の底には女のやきもちもきっとまじっていましょう。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう商売の女のやきもちは人一倍で、そりゃあ実におそろしいもんですからね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがお定まりのやきもちで、いろいろのごたごたが起る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親のやきもきしている様子も、見えすいていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやきつくような欲望に対して、これらの若い評論家たちは必ずしも完備した思想的設備をもっているとはいえない。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらも、當分は、或は二年なり五年なり、歸りたくないと云つてよこしたのだが、かの女も例のやき／＼した口調で、歸らないなら歸らないでもいい、あなたのやうな人は子供までがさう云つてますと云ふ、最後の手紙をこちらへほうり附けた切りであつたのだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで此の葢の裏を返してみるがいゝ、こゝは高臺を削るのと同じやうに削つてあるが、其の削り方の親切さ、飽くまで深く、ロクロの働きも充分であつて、恰かも宋代のやきものゝ高臺をみるやうな氣がする。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
