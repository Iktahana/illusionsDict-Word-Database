[
  {
    "uuid": "6b4cce9e-35cd-5c2e-819a-13f3f6394cc9",
    "entry": "ノベル",
    "reading": {
      "primary": "ノベル",
      "alternatives": [
        "ノヴェル"
      ],
      "is_heteronym": false
    },
    "grammar": {
