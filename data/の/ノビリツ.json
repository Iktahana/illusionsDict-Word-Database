        "examples": {
          "standard": [
            {
              "text": "書道では、線の「伸び」が作品の生命感を左右する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "マイクロコンピューターの市場は、前年比七〇パーセントを超える伸び率で成長を続けていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした構造的変化に加え、アメリカの半導体業界の不況もあずかって、一九八一（昭和五十六）年三月期の経常利益は伸び率ゼロにとどまった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が學校で屹度一番のびりつこであることに疑ひの餘地はない。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は三ノ組のびりつこから三番目で、従つて私の名が呼ばれるまでには夥しい時間を要した。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "名札のびりつこにかかつてることも、点呼のときしまひに呼ばれることも、自分が事実できないことさへもすこしの疑ひすら起させなかつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
