      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "excellent calligraphy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、賣藥の效能書を、實に信用する愚かな性質を持つて居ります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、「二箇のズルフオンアミド基」を有する高級化學療法劑に就いては、かねて新聞廣告に依つても承知してゐたのでありますし、いま自ら購ひ求めて、藥品に添附されて在る一枚の效能書をつくづく眺め、熟讀して、腰の腫物を忘却してしまふほど安心したのであります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "效能書に依れば、これは、たいした藥なのであります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二錠づつ、一日三囘服用すると、たいていの腫物は、なほるといふ效能書の言葉だつたのですが、二日服用しても、三日服用しても、ちつとも輕快になりません。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日服用したら、あと服用を禁止せよ、三日乃至五日間休止して、それからさらに二錠づつの服用を開始せよ、と效能書に書かれて在りましたので、私は、少しも、ききめの無いままに、その藥の服用を、やめなければならなくなりました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、あまり有頂天で效能書の文句を信じ過ぎたのでありませう。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ク教授は新醸のワインを取出して能書きを並べた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マツシーマーア、カデンーノーオー、センキーンーンタン」というふうに全く同じ四拍子アンダンテの旋律を繰り返しながら、だんだんに薬の効能書きを歌って行くのである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこう説明すれば、それはもう世捨人の働きに効能書が付いてうるさくなります。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千日が間、能書の僧数百人を招請し、供養し、これを書写せしめしとなり。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "効能書のない薬品なんて、絃の無いヴァイオリンみたいに、はかなく落ちつかない気が致します。",
              "citation": {
                "source": "正直ノオト",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "効能書は、無ければ、いけないものなのでしょうね。",
              "citation": {
                "source": "正直ノオト",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "効能書のついたソーダ水を考えてみましょう。",
              "citation": {
                "source": "正直ノオト",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術に、意義や利益の効能書を、ほしがる人は、かえって、自分の生きていることに自信を持てない病弱者なのだ。",
              "citation": {
                "source": "正直ノオト",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人たちには、効能書の必要は、あまり無いようですね。",
              "citation": {
                "source": "正直ノオト",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "効能書を、必要とするのは、あなたがた（おゆるし下さい）病弱者だけなのです。",
              "citation": {
                "source": "正直ノオト",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女房は片膝立ちに腰を浮かしながら能書をいう。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がね、小さい時、万はもう大きな身をして、良い処の息子の癖に、万金丹売のね、能書を絵びらに刷ったのが貰いたいって、革鞄を持って、お供をして、嬉しがって、威張って歩行いた児だものを。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかつて薬の効能書に「食間服用」とあるのを、食事の最中に服用するものだと早合点して、食事中に薬を飲んで笑われたことがあるが、しかしこの煙草に関しては私はつねに「食間喫煙」であった。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事その物よりも、意味付けや能書きに過度に傾いてしまい勝ちな性格が災いして、「プログラミングを体験した」という程度以上には、私の技術は進歩しませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにをしていいかは、個々のテキストについた能書きを読んでほしい。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "能書きは作家に言わせておくとして、出版社に必要なのは市場が今、何を求めているかを素早く察知する力だろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "誕生当時、パーソナルコンピューターは「情報処理の能力を個人に解放する」、「より良く生きるために、より自由に、より深く考える道具を提供する」という能書きを引っ提げ、大見得を切って登場した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら元祖幼形成熟のこの私が、変わって家電戦略に秘めたアップルの志を深読みしてあげましょう」と妄想をたくましくしても、かつて哀愁の高田馬場で思い込みの鬼と呼ばれたこのオレにも、算盤勘定以外、アップルの家電戦略の能書きはさっぱり見えてこないのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの新しい空間をテーマとして、電脳社会論という能書きをドドーンと垂れてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "能書きはおおむね、てなことになる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "面胞だらけの小汚ない醜男で、口は重く気は利かず、文学志望だけに能書というほどではないが筆札だけは上手であったが、その外には才も働きもない朴念人であった。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぱんぱんとたちまちかぎつけてめえりますから、お待ちなさいよ……」　いったかと思うと、伝六自慢の一つ芸、能書きにうそはない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが証拠に、太夫が唐人語を使って踊りを踊りますから、だまされたと思って、二文すててごらんなさいよ」　得意になって口上言いが能書きを並べだしたものでしたから、それにつられて、あたりの者がどやどやと六、七人木戸をくぐりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、まことや口上言いの能書きどおりなのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
