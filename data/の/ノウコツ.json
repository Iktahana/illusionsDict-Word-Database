    "definitions": [
      {
        "index": 1,
        "gloss": "placing (a person's) ashes inside a funerary urn (or a tomb or ossuary)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "遺骸は町屋の火葬場で火葬に付して、その翌朝Ｔ老教授とＮ教授と自分と三人で納骨に行った。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分細君には惚れていたのだが、その納骨を二年も放って置いて、いまだにそれを済ませないというズボラさである。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓地の円屋根、納骨堂、また、反青き塔のつま。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四日には一同京都に着し、紫野大徳寺中｜高桐院に御納骨いたし候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルレスのバジリカ式の寺院を象つた、聖トロフイヌスの納骨箱でさへ黄金の響を、微かな哭声にして発したのである。",
              "citation": {
                "source": "クサンチス",
                "author": "XANTHIS",
                "note": "青空文庫"
              }
            },
            {
              "text": "長範の腕は盗みをするだけに寸も長かつたし、納骨には打つて附の代物であつたが、山でもまだ一稼ぎしなければならぬので、一寸｜出し惜みをした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日お絹さんの母が亡くなりまして、今朝納骨式に地三をつれて里へ帰りました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "注（１）大阪の天王寺という大きなお寺では、この骨はみんな納骨所に投げ込まれる。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "学術雑誌で名前を知っている偉い博士たちの研究室が、納骨堂の中でもあるかのように同じ形をしてうちならび、白い大理石の小さい名札の上にその研究室名が金文字で記されてあった。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "納骨のために墓の石も取除かれたが、彼の持っている骨壺は大きすぎて、その墓の奥に納まらなかった。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "長年教会へ通いつめているので、納骨堂や祭具室の冷たい匂いがその衣類にまで浸みこんでしまったのであろう。",
              "citation": {
                "source": "老嬢と猫",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は姉の子供の娘一人と定雄の子供の長男次男と、それに定雄夫妻に姉、総勢六人で父母の骨を納めてある大谷の納骨堂へ参った。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同｜揃って上に登り、納骨堂へ参拝して、それからいよいよ本堂で経を上げて貰わねばならぬのであるが、誦経の支度のできるまで六人は庭向の部屋に入れられた。",
              "citation": {
                "source": "比叡",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また京都の街を見降す位置にある本願寺の納骨堂に父の骨を納めることは、この街に電力を送っている宇治川の水電を成就させた父の心も安ませることだと思ったが、幸子には、その灯も涙の種になるのかもしれないと思ったりした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は彼は、母には父の納骨をすませた旅さきから手紙で結婚のことを云い出す考えでいたので、妹を一緒に京都へつれて行くこともひかえ、母の傍に残したくもあったのだが、この夜はそんなに旅さきまで策を用うるのが佗しく仰ぐ花明りも眩ゆかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来れば彼は午前中に納骨を済ませたいと思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "由吉は案内役の知人が正午前に来ると云うので、昼食時の落ち合う場所を定め、矢代はそれまでに西大谷の納骨をすませる予定を話すと、千鶴子も一緒にそちらへ廻りたい旨申し出てくれた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮池に懸った石橋を渡って納骨堂の石段を登って行くときも、矢代は稀に見る槙三の端麗な精神について千鶴子に賞讃した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とにかく、出来るだけ早く納骨をすませてから、また来るよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の納骨に親戚たちを呼びよせることはさして苦労ではなかったのを、それもせず急に出て来たのは、仕事を措いて出て来るもの達への遠慮のみならず、彼の見知らぬ親戚の多数と顔を合せる気苦労もあり、また他に口にはしがたい理由も少しはあった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、母が先だって彼を動かし、父の納骨を好機に家の所有を瞭らかにすることを命じても、あるいは彼から母に反対したかもしれなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "納骨の場を掘ってくれている間に、矢代は墓石の間を廻り碑面を読んでみた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "川に向いた縁先の籐椅子に矢代はかけると、父の納骨を尽くすませた気安さに、初めてネクタイを解きほどいたくつろぎを覚え、思うさま山、川、雲を見あげた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大連より四十分にして旅順に入り、旧市街にある戦利記念館を一覧して後、車を西港の北岸に駐め、納骨祠と表忠塔のある白玉山に登り始めたが、直射する日光の下に遽かに炎威を感じながら、長き沙巌の坂を攀づるのは、心臓の痼疾ある妻を聊か苦めた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーモンの塁砦を東北に見はるかす高地の上に素晴らしく大きな蒲鉾型の納骨堂が横たわり、その中央に高い燈台塔が立っている。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "納骨堂の中には、身内の人たちでもあろうか、花などを持った参詣者も少からず見受けられた。",
              "citation": {
                "source": "ヴェルダン",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くに納骨堂の白い丸屋根が見える。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして苦悩に満ちた生涯は終り、湯呑のやうな恰好をした病院製――患者が造つてゐる――の骨壺に骨の切れ端が二三個納まつて、ハルちやんが抱へて行つたやうに、納骨堂の棚の上に並べられる。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
