        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奥さん、ノイローゼですよ」　妻はほっとした表情になる。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やはりノイローゼでしたのね。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "前述の通り、あれほど気違いじみた叫びを上げたのはどんな最後の恐怖のせいなのか、ダンフォースは話してくれない――その恐怖が彼が現在罹患しているノイローゼの原因になっているのは悲しいかな間違いないと思うのだが。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "……べつに、だれのせいでもない、一種のノイローゼなのかもしれない。",
              "citation": {
                "source": "お守り",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノイローゼだのテンカンなどが、自覚しないまま営業してるという話ですからねえ」　矢木は真顔になって話の方向を変えた。",
              "citation": {
                "source": "記憶",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりノイローゼにもなれませんねえ。",
              "citation": {
                "source": "凡人凡語",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのはきっとノイローゼだ。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなのだ、他人はきっとこんなおれをノイローゼだというだろうなと思うと、胸の中で、さらに笑いの小爆発は連続してやまなかった。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰に見せるためでもなく、自分の一種の生理的欲求のつもりで、だから私は自分ではこれも「ノイローゼ」の一つのあらわれだと思っていた。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカにも停年があつて、退職した者がよく退職ノイローゼ（精神病）にかゝるという話だが、無理もない。",
              "citation": {
                "source": "老人退場説",
                "author": "山浦貫一",
                "note": "青空文庫"
              }
            },
            {
              "text": "………コンナデモナイノイローゼニ過ギナイヨウニモ思エルカラダ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スミ子ちゃんは、このごろ、なんだかノイローゼ（しんけいすいじゃく）みたいね。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとうさんや、おかあさんに知らせたって、またノイローゼだといって、とりあってくださらないにきまっている。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのときは僕も妹も、ノイローゼのようだった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊＊　われわれはノイローゼになると、自己嫌悪におちいると共に快楽をはかないものだなどという。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "係のＭ氏はノイローゼになりそうだと言った。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
