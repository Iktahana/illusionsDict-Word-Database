        "examples": {
          "standard": [
            {
              "text": "聖書に記されているノアの箱舟の物語は、世界中で広く知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大洪水から生き物を守るため、ノアの箱舟が造られたと伝えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境問題が悪化する現代において、地球全体がノアの箱舟のようだという表現を耳にするようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "〔無題〕煙突男が消えたあと、銀座の柳が溺れたあと、流行の洪水にノアの箱舟が一艘陸軍旗を立てて来る。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここは、まるでノアの箱舟ね」　ひろ子が、笑って云った。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、土の中に埋めるものはノアの箱舟のようになります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにたいしてアウグスティヌスは論理的に考えて大地がノアの大洪水後にも動物を自然発生によって生み出す力を持っているとしたらノアの箱舟は必要ではなかったと悩み、神の恩寵と神がマウスのように不愉快なものを造ることとを調和させることが出来なかった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
