  {
    "uuid": "1b86e0d3-ecb4-53df-9ce4-41c8d6deab41",
    "entry": "のん",
    "reading": {
      "primary": "のん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "助詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indicates a confident conclusion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "甲府の知り合ひの人にたのんで、下宿屋を見つけてもらつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは、どうも、のんき過ぎますから。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は青空を見上げて、「しかし、東京は、のんきだな。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、旅行者にとってはのんきそうに見えながらも、帝都の人たちはすべて懸命の努力で生きているのだという事を、この北京の客に説明してやろうかしらと、ふと思った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日をたのんで、その場をごまかして置くような事も今は、なくなりました。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無邪気に信じている者だけが、のんきであります。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりかうした作家たちが、詩や俳句を作るのは、飽食の後で一杯の紅茶をのんだり、或は労作の汗を流し、一日の仕事を終つた後で、浴衣がけに着換へて麻雀でもする気持なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村はいつも、寒夜の寝床の中に亡き母のことを考え、遠い昔のなつかしい幼時をしのんで、ひとり悲しく夢に啜り泣いていたような詩人であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化の伝統が古くなるほど、人の心に余裕が生れ、生活がのんびりとして暮しよくなる。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気象輪講会は何となく上品にのんびりしていたし、地球物理輪講会は生真面目でしかも家族的な気分であったが、地理の輪講会には何となく物々しい人間臭い気分があった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会食室の戸が開いているからちらと見たら、三十くらいの意気な女と酒をのんでいる男があったが、顔はよく見えなかった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶をのんで粗末なビスケットを二つ三つかじる。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人女にも、於七が吉三のところへ夜決心してしのんで行って、突如、からからと鈴の音、たちまち小僧に、あれ、おじょうさんは、よいことを、と叫ばれ、ひたと両手合せて小僧にたのみいる、ところがあったと覚えているが、あの思わざる鈴の音には読むものすべて、はっと魂消したにちがいない。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神代櫻へは、わざわざ團體で行かなくても、私たちだけで、のんびり見物に行きませう、賞金もらつたら、そのお金で行きませう、さうしませう、と三人で話をきめた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "など、のんきな事を考へながら山を降りて來たら、途中で、野良へ出かける息子の聖人とばつたり出逢ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな、のんびり暮してゐるよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に、のんびりしたものです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとこの狸は、何の罪とがも無く、山でのんびり遊んでゐたのを、爺さんに捕へられ、さうして狸汁にされるといふ絶望的な運命に到達し、それでも何とかして一條の血路を切りひらきたく、もがき苦しみ、窮餘の策として婆さんを欺き、九死に一生を得たのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も無事でよかつたが、おれも何といふ事もなく火傷がなほつて、かうしてまた二人でのんびり話が出來るんだものなあ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこれから、鎭守の森の神さまにたのんで來るから。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しも、のんびりしない。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は返事に窮して、お勘定をたのんだ。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日をたのんで、その場をごまかして置くやうな事も今は、なくなりました。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無邪氣に信じてゐる者だけが、のんきであります。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんにわかれたあのをんな、いまに帰つてくるのやら　　徐かに私は酒のんで　　悔と悔とに身もそぞろ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかにしづかに酒のんでいとしおもひにそそらるる……　　ホテルの屋根に降る雪は　　過ぎしその手か、囁きかふかふか煙突煙吐いて赤い火の粉も刎ね上る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで茶をのんで餅をつまんでゐたら、同宿の若い夫婦連れがあとからはいつて来た。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の運轉手は、しきりにベルを踏み鳴らしながら、併しわり合にのんきさうな顏をしてバスに押し込む遊山客の群を眺めて居たのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の山懷の一隅には非常時の嵐が未だ屆いて居ないのか、妙にのんびりした閑寂の別天地である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の勇氣がなくてはとても今の世間をのんびりした氣持では渡つて行かれないらしい。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
