    "definitions": [
      {
        "index": 1,
        "gloss": "to stretch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山を石膏細工の人形とすれば、雲は衣裳で、あのようにまで、モデルの肢節にぴったり合って、屈伸するものとは思っていなかった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が伸々と拘束なしに内側の生命を伸す間に、女は有史以来｜圧えためられてそれを萎縮されてしまった。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ大きな欠伸する。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父は當前に坐る、愚息はゴロリ臥ころんで足を蹈伸す、この臥轉び方が第一上出來であつた。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と一人が前を遮るように、独楽の手繰をずるりと伸す。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の裏は、すぐ四谷見附の火の見櫓を見透すのだが、其の遠く廣いあたりは、日が眩いのと、樹木に薄霧が掛つたのに紛れて、凡そ、どのくらゐまで飛ぶか、伸すか、そのほどは計られない。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて足駄を引摺つて、つい、四角へ出て見ると、南寄の方の空に濃い集團が控へて、近づくほど幅を擴げて、一面に群りつゝ、北の方へ伸すのである。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が手を伸すとの、また水に持って行かれて、手毬はやっぱり、川の中で、その人が取らしっけがな。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は暫らく、じっとしていたが、やがて手を伸すと、枕元のスタンドの灯をつけた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究と仕事以外には、何一つ道楽も趣味もない男で、欠伸する暇もないくらい、医学の仕事に全身を打ち込んでいたのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　無理がとほれば道理引込む西　むまの耳に風　東は理もまた時ありて屈伸することを云ひて、世情の頼む可からざるを憤り、西は馬耳東風何の饗応無きを云へり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草｜田畝に巣を持って、観音様へ羽を伸すから、隼の力と綽名アされた、掏摸だよ、巾着切だよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――雨が降るのではない、月が欠伸する息がかゝるのであらう……そんな晩には獺が化けると言ふが、山国に其は相応はぬ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で心持｜好く手足を伸すよ、姐さんお前ももう休んでおくれ。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、欠伸するのはせらぴむか。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に武田の脅威を受けていては、謙信上洛の志も関東経営の雄志も、伸すに由ないのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後永禄五年五月、水野信元のとりなしで信長と清須城に会して連合を約し、幼少から隠忍した甲斐あって次第に勢を伸す基礎を得た。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ頃からかはよく分らんが、床に入って、可心持に、すっと足を伸す、背が浮いて、他愛なくこう、その華胥の国とか云う、そこへだ――引入れられそうになると、何の樹か知らないが、萌黄色の葉の茂ったのが、上へかかって、その樺色の根を静に洗う。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト境の方に立ったのが、心持｜身体を開いて、頬の皺を引伸すような声を出した。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一脚の卓子を囲んで、柳沢と差向いに同じ椅子に掛けていたが、体を捻って、背後へ手を伸すと雑書を納れた本箱の上から、一瓶の角砂糖を取って、これを二人の間に居る一｜人の美少年の前に置いた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　梓は笑いながら犬の前足を取って伸すと、飼犬は口を開けて、目を光らして、わッ！",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論三が下るものやら二が上るものやら、節は伸すもんだか縮めるもんだか、少しも知らない。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」……とも言はず、女太夫が、間近から手を伸すと、逆らふ状もなく、頬を横に、鬢を柔順に、膝の皿に手を置いて、「ほゝゝゝゝ。",
              "citation": {
                "source": "光籃",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "足をずらしてつかつかと出ても、馴れて畳の破にも突かからず、台所は横づけで、長火鉢の前から手を伸すとそのまま取れる柄杓だから、並々と一杯、突然天窓から打かぶせる気、お勝がそんな家業でも、さすがに婦人、びったりしめて行った水口の戸を、がらりと開けて、「畜生！",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い身空にふりみふらずみ、分けてその日は朝から降りつづく遣瀬なさに、築地の家を出て、下谷｜三の輪辺の知辺の許へ――どうも前に云った雪中庵の連中といい、とかく赤蜻蛉に似て北へ伸すのは当今でいえば銀座浅草。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸すと八畳間の天井を隅から隅へ斜めに掛けても尾端は鴨居の下迄垂れさがつた。",
              "citation": {
                "source": "山峡の凧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼が火をともして腕を伸すと、うつとりと眼をつむつて煙を吹いた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかくは子供が通つてしまつた後の筵を丸めて、更に行手に敷き伸す仕事を繰り返しながら子供の運動に伴れて何か口のうちで呟いて居ります。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いひながら側にあつた小形の風琴をとり、両手をかけて引き伸すと雑作もなく「てふちよ、てふちよ」と何ともいはれぬ面白い調子に鳴り出し升た。",
              "citation": {
                "source": "黄金機会",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "からたちの垣根萩原朔太郎からたちの垣根の中に女のはしやぐ聲のする夕餉の葱のにほひする灯ともしごろからたちの垣根を過ぐる侘しさよ。",
              "citation": {
                "source": "からたちの垣根",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
