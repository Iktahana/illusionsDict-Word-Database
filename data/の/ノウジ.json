[
  {
    "uuid": "98d22d11-73d8-5f5c-8162-a353f82e40a7",
    "entry": "能事",
    "reading": {
      "primary": "のうじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
