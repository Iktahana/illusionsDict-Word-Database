[
  {
    "uuid": "16532a51-4376-5ee8-838a-4c12bd6b6003",
    "entry": "飲むべ",
    "reading": {
      "primary": "のむべ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
