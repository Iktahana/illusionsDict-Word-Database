    },
    "definitions": [
      {
        "index": 1,
        "gloss": "person who likes to drink",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人は如何にや知らず、我は打対ひて酒飲むべき花とは思はず。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌い終ったら、にこにこ笑って、また酒を飲むべし。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、飲むべき家も蔵も無い。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ、糠雨でも飲むべい、とってな、理右衛門どんが入交わって漕がしつけえ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつなりけむ、母上の給いたる梨の、核ばかりになりしを地に棄てしを見て、彼処の継母眉を顰め、その重宝なるもの投ぐることかは、磨りおろして汁をこそ飲むべけれと、老実だちてわれに言えりしことあり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "身も心も欲しがる酒、さういふ酒だけ飲むべし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "自戒　　　　　　酒について酒は味ふべきものだ、うまい酒を飲むべきだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルコールを止揚せよ、先づ焼酎を止めろ、酒は日本酒に限る、燗してちびり／＼飲むべし、時としてぐい／＼ビールを呷るもよからう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "また街に出かけて飲む、Ｗ店、学校、そしてまたＷ店、たうとうそこで倒れた、まことに久しぶりのよい泥酔であつたよ、しかし、ほんにしかし、酒は飲むべし、飲まれてはならない！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "○生活箴二章　　△金銭を大切にすべし　　△酒食を慎むべし○飲酒戒三則　　△火酒を飲むべからず　　△微酔にて止めること　　△現金で飲むべし十二月十八日　曇――晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒として味ふべし、アルコールとして飲むべからず。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本女は、室の隅におかれた大きな旅行籠の前へひざまずき、ともかく茶を飲むべく、四角な茶カン、二本のアルミニュームの匙、砂糖を出して、古風な更紗張テーブルへおいた。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　△　△　△　△自戒三条　一、自分に媚びるな　一、足らざるに足りてあれ　一、現実を活かせいつもうまい酒を飲むべし、うまい酒は多くとも三合を超ゆるものにあらず、自他共に喜ぶなり。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角水は十分に飲むべし。",
              "citation": {
                "source": "四日間",
                "author": "ガールシン",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、保一くんはあの朝、健吉くんの出たあとへ忍んできて、令嬢から十時ごろに飲むべき薬が届いていると聞き、もしや兄がその中へ薬を混ぜはしなかったかと疑って、その薬を母親に飲ませなかったのです。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が眠り得ぬ夜のために飲むべく云ひ置き給へりしベルモツトはさすがに舌なれぬ心地、未だ知らぬ酔の案ぜられも致され、赤の葡萄酒を紅色のカツプに一つつがせてのち床に横はり候。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よしッ、じゃきみにきくがきみは水を飲むか」「飲みます」「一日｜何升の水を飲むか」「そんなに飲みません」「いかん、人間は毎日二升の水を飲むべしだ、顔回は一｜瓢の飲といったが、あれは三升入りのふくべだ、聖人は」「さようなら」　光一はたまらなくなって逃げだした。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "○験なき物を思はずは一坏の濁れる酒を飲むべくあるらし　〔巻三・三三八〕　大伴旅人　太宰帥大伴旅人の、「酒を讃むる歌」というのが十三首あり、此がその最初のものである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一首の意は、甲斐ない事をくよくよ思うことをせずに、一坏の濁酒を飲むべきだ、というのである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに塩を加え、牛乳を交えて飲むべし。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○牛乳を多量に飲むべき必要あらば弐合の乳を一合に煎じ詰めて用ゆべし。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の住む盛り場の近所へ所用があって出向いたが、そこは私の始めての土地で、おまけにその日は一人であり、知っている土地へ戻って一杯やるのもオックウであり、さりとて飲むべき店も見当がつかない。",
              "citation": {
                "source": "日月様",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この勢いでは、この牝牛の乳をみんな絞って、みんな飲んでしまうかも知れない、牛の子の飲むべき乳を――人間が横取りして飲んでしまうなんて、なるほど、毛唐というものは随分ひでえことをするなあ――という表情が、子供たちの面に現われる頓着もなく、再度の丼はことごとく飲みつくされてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はゆるりと一杯鯛の刺身で飲むべえ。",
              "citation": {
                "source": "蝋人形",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "食うべき米も飲むべき水もなかった。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "食うべきものも飲むべき水もなかった。",
              "citation": {
                "source": "海難記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲むべき酒杯を最後の一滴まで余さず飲み干した、というのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "人的労働用具乃至労働力は最も経済的でなくてはならぬ、「下部あまた召使とも万の事自ら辛労を忍て勤ること女の作法也」、「朝早く起き夜は遅く寝ね昼は寝ずして家の内のことに心を用い織縫績緝怠べからず又茶酒杯多く飲むべからず歌舞伎小唄浄瑠璃等の淫たることを見聴べからず」云々。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその水を飲むべく気力がありません、手も利きません、身体も動かすことさえできませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻燈は第一が『お酒をのむべからず。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
