[
  {
    "uuid": "11e432d5-04ad-51d3-851e-c85505e29f29",
    "entry": "能吏",
    "reading": {
      "primary": "のうり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "able official",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幕末の能吏、水野忠徳は、「井伊大老が橋本左内を殺したるの一事、以て徳川氏を亡ぼすに足れり」と喝破してゐる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二八　矛盾の申立　幕府の能吏渡辺大隅守綱貞が町奉行であった時に、或医者が訴訟を起した。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、つとめてポイントに触れぬところが能吏か。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て藤田東湖が幕府の能吏矢部駿河守との対話を記したるを見るに、曰く、矢部余に謂て曰く、「足下は川路三左衛門に親しきよし、川路または岡本忠次郎などいえるものは元来勘定所より出身せり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "一はその下僚の温良にして民に近き能吏多く、他は精刻｜苛佻、動もすれば訐以て直となし、察以て明となす酷吏多し。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府の当途者及び要衝に立つ能吏は、彼が一方においては尊攘党の望を負い、他方においては英才賢明なるの為人を聞き、彼に思を属したり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる場合、その幾十パーセントかは、その職にありながらプラトン型に何かほかに凝るものを見つけるか、ディオゲネス型にカストリを飲むかしながら、やはり、その知識の奉仕をアリストテレス型に能吏として行なうという事となるのである。",
              "citation": {
                "source": "知識と政治との遊離",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに實際大岡越前守は事務に練達湛能の能吏であつたから、これを理想的に祭り上げ何んでも箇でも持つて行つて、名判官一手專賣としたのも、自然の勢である。",
              "citation": {
                "source": "大岡政談",
                "author": "尾佐竹猛校訂",
                "note": "青空文庫"
              }
            },
            {
              "text": "能吏があっても、それが中間に自分のポケットに多く収むる様ではまたいかぬ。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "宦官的な側用人、腐敗しきった無能吏、つべこべ出入する阿諛的儒者、大奥と表との見えざる穴道を往来する城鼠奸人の輩など、仮借なく、罷免させた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山毛欅だの、欅だの、これは此処で初めて名をも聞いた木のうりの木だの、そのの木だのというのの幹の大きさ枝の繁さ、そしてその全体の美しさ不思議さに至っては私は初めから筆にすることを断念せねばならぬのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでね、そういう劇場だって、運転資金となる利益は矢張り切符のうりあげだろう？",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時ちょうど奈良から初もののうりを献上して来ました。",
              "citation": {
                "source": "八幡太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとまず安倍晴明がそのうりを手にのせて、「ほう、これは珍しいうりだ。",
              "citation": {
                "source": "八幡太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "下ぶくれのうりざね顔で目は大きすぎるほどぱっちりとして髪を二つに割って両耳のところで結び玉をこさえている。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "○アホートヌイ〔アホートヌイ・リャード、現在のカール・マルクス大通り〕に又百姓がそろそろものうりに出かけて来た。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さん、兄さんは、きのうりんごの皮をむかないで食べたからでしょう。",
              "citation": {
                "source": "政ちゃんと赤いりんご",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものうりのところで、できあがったものだけをかうんだ。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ものうりがいった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものうりはクスリをうっていた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ものうりはいった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、ものうりの話をききながら、ほんのすこしだけのこっていた水を、ぐいとのみほした。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん　ものうりの　にぐるまは　まわってきます　――　おにくやさんに、　うおやさん、　それから　ぱんやきティモシー。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つ角の、これもまた暗いところをえらんで出るアイスクリーム屋のうり声である。",
              "citation": {
                "source": "夜店ばなし",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なか高のうりざね顔で、眉と眼のあいだが広く、きめの密かな白い膚に、ふっくりとした唇が、なまなましいほど赤かった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼と眉のあいだのひらいた、なか高のうりざね顔は、忘れることのできないものだ。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
