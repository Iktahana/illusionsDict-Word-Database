    "definitions": [
      {
        "index": 1,
        "gloss": "open-air tea ceremony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「朝から奥歯がやめやがってな、甘いものはたべられんのだてや。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も東京は諸國から秀才が集るのだて。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが東京へ出て監督してやれば可いのだが、さう云ふわけにも行かないのだて……まあ何分にも君方等に頼みます。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その代り以後はちと場所柄をわきまえるようにしてもらいたいものだて。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘伝と聞けば、なお更それを聞きたいものだて。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹揚に構へてゐてこそ、人間の価値は自づと知れるものだて……」「あたしだつて、朝倉の親戚に……あそこの奴等だつて、実にもう何とも彼とも云ひやうもない我利々々亡者ばかりで、金々ツて、厭になつてしまふ。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりしづか　さうかといつて、私のやうに一本の茎に二つの自分といふものがあつて、それが絶えず別々な事を考へてゐるのも、いい加減なものだて。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまくもぐったものだてば。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "石に溺れて役向きを疎にするやうでは、お上への聞えもおもしろくなからうといふものだて。",
              "citation": {
                "source": "石を愛するもの",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも才三方へ嫁に行かねば死んでしまうと騒いだのだて――いや女と云うものは始末に行かぬもので――是非行かして下されと泣くじゃ」「ふん、それで思う通りに行きましたか」成蹟は良好だ。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どこをどう運動したものか殿様の御意でその方の娘をあれに遣わせと云う御意が帯刀に下りたのだて」「気の毒ですな」と云ったが自分の見込が着々｜中るので実に愉快でたまらん。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでも」と、這入つて來た女の方が眞面目な笑顏を見せて、「あなたはえらい人なのだて、ねえ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋というもの、するならばするで、せめてそれらしい恋をしては下さるまいか、つまらぬことで江戸趣味をなくしたくないものだて！",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えらい時刻にやって来たものだて！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "主にどんなことを考へていらつしやるのか、あの頭の中でどんなことが目論まれてゐるのか、それがひとつ知りたいものだて。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時団七とお辰との人形を使うた吉田文三郎が、格子縞の帷子のだて姿や、女の夏の旅姿に浅葱の綿帽子を考へ出した――近年東京でのお辰は、此定型に従はぬ事になつてしまつた――上に、九郎兵衛の人形に本水を浴せる工夫をしたりした。",
              "citation": {
                "source": "涼み芝居と怪談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあなた、処女が身寄りのようなものだてえノブちゃんの心細さは分りますとも。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり芝居ばっかり見たがって居るからあんな苦しい暮しをするのだて。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこっちのものだて」　この時次の間よりかの老女のいくが、菓子｜鉢と茶盆を両手にささげ来つ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "武男さんが帰りゃなかなか断行もむずかしいからね、そこで帰らんうちにすっかり処置をつけてしまおうと御隠居も思っとるのだて。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸は江戸で浪人者があばれ廻ったり、貧窮組が起ったり、江州の長浜へ来れば長浜でまた――厄介なものだて、どこへ行っても世話がやける世の中だ――だがおいらはもう知らねえよ、そういちいち人の世話ばかり焼いていた日にゃ、第一こっちの魂が焼け切れちまあな。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "癩病の血も、万引の血も、忘れてしまえば、誰の中にも流れてはいないものだて。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "得てして、こういう怪物は神様の御神体と同じように、カラでなければ、とんだ下手物しか出ないものだて」　今迄の例がそうだった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の神だのサエノカミてえものは石を拝むものだてえ話さ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "外から見れば棺桶を何倍も大きくしたような薄汚いものだが、美人になりたい一心のために、あの棺桶に寝るという御婦人方の気持ばかりはおどろき入ったものだてなア」「大伴夫人がその上で美人術をうけているのを見たかね」「二階の寝室の中のことは、外からは分りやしねえ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも落ちついたものだて。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふふふ、すると甚吾のやつめ、なんのことはない俺に正案を教しているようなものだて、うふっ。",
              "citation": {
                "source": "寛永相合傘",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
