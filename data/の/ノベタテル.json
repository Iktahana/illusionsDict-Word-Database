[
  {
    "uuid": "a275cec6-2101-5692-8f42-12f080821211",
    "entry": "述べ立てる",
    "reading": {
      "primary": "のべたてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
