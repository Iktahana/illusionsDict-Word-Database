    "definitions": [
      {
        "index": 1,
        "gloss": "just as one wishes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからまたたいていの人間なら疲れ果てて、へたばってしまうであろうと思われるような超人的活動を、望み次第にいくらでも続けて見せてくれるのである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お動きなすって御成敗がなさり悪くば、縛りましょう、釣上げましょう、さあさあ、どうとも御望み次第。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗るわ、降りるわ、混合う人数の崩るるごとき火水の戦場往来の兵には、余り透いて、相撲最中の回向院が野原にでもなったような電車の体に、いささか拍子抜けの形で、お望み次第のどれにしようと、大分｜歩行き廻った草臥も交って、松崎はトボンと立つ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからの出世は望み次第だ。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "船賃は望み次第出すが……と尋ねてみると、淡白らしい船頭は、城ヶ島なら屈託する事はない。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "度胸のいい返事に、侍どもは再び顔を見あわせていたが、やがて、その一人が重そうにかかえている白木綿の風呂敷包みを取り出して、長左衛門の眼先に置いて、これを形代として金三百両を貸してくれ、利分は望み次第であると云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "香材の出処実に思いのほかなるもありて、一九〇三年版マヤースの『｜人品および身死後その残存論』巻二第九章附録に、精神変態な人が、頭頂より二種の香液を他の望み次第出した記事と弁論あり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほうびは望み次第、つかみ次第！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "望み次第というのにけしかけられたのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの工女とか、女店員とか専門のもあれば、お望み次第のデパート式もポツポツある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は片っ端から少女を誘惑して団員とし、一方から望み次第に若い男性を引っぱって来てその少女に宛がって享楽させる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に望み次第の金子を融通仕様といふのである。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "定食が三円、それ以上はお望み次第ということにしています。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "田楽刺し、八目刺し、ないしは菱鉾の刳り刺し、お望み次第突き刺して見せる？",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "褒美は望み次第ぢや。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "責め苦の数々お望み次第じゃ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜劇でも悲劇でもお望み次第に実演させて見せる……」「でもねえ先生……」　女将の横に居る肥っちょの一番肉感的な女が、細長い眉を昂げて、薄い唇を飜した。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて金銀が欲しいとあれば、予はその方どもに何なりと望み次第の褒美を取らすであろう。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "領内へふれて十五六から隠居の者に至るまで、浪人もとより、町人百姓職人この一戦に手柄を立て名を立て家を興さん者は集れ、手柄に応じ恩賞望み次第とあり、如水自ら庭前へでゝ集る者に金銀を与へ、一人一人にニコポンをやる、一同二回三回行列して金銀の二重三重とり、如水はわざと知らないふりをしてゐる。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからば仰せに従いて、これより直ちに」「厩へ案内致させ申そう、そのうちにてよき馬を遠慮なく択み取り給え、弓矢も望み次第のものを」　兵馬は喜んで、能登守のあとに従いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前、その気があるなら一番やってみたらどうじゃ、甲府から三里離れた有野村の藤原といえば直ぐわかる、そこへ行って主人の伊太夫に会い、これこれのわけでお嬢様をお連れ申したといえば、それこそ謝礼は望み次第じゃ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年、明治六年の十一月には、筑摩県｜権令永山盛輝の名で、神葬仏葬共に人民の信仰に任せて聞き届ける旨はかねて触れ置いたとおりであるが、今後はその願い出にも及ばない、各自の望み次第、葬儀改典勝手たるべしの布告が出るほどの時節が到来した。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうだねえ……何でも御望み次第。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「賢子の中宮の御腹に皇子誕生を祈祷してくれまいか、願いのかなった暁は、恩賞は望み次第じゃ」「お安いご用でござります」　頼豪は三井寺に帰ると、百日の間、心をこめて祈り続けた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国は気も顛倒して、「坊やを探しました者には、望み次第の褒美をやる」　と言いますが、これだけに手際よく誘拐されては、手の付けようがありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "何日と日限は切らぬが、出來るだけ早く、この丸藥と同じものを作り、その處方を書いて貰ひ度いのぢや、褒美は望み次第取らせる、――が萬一｜失策ると其儘歸さぬぞ」　道庵はヒヤリとしました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵粮丸祕聞",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、宜いとも、お粂さんに口説かれりや本望さ、夜逃げでも心中でもお望み次第何んでも付き合つてやるぜ」「まア、嬉しいねえ、――だけど、私のお願ひといふのは、そんなことぢやない」「？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼女",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの関子も驚いて、マネキンを止し度いと言い出しましたが、此人気に有頂天になった竹屋デパートの支配人は、契約の期限を楯にどうしても聴いてくれません、その代り給料は望み次第と大きく出ます。",
              "citation": {
                "source": "悪魔の顔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんな形の靴でもおのぞみしだいにつくります。",
              "citation": {
                "source": "あひるさん　の　くつ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "褒美はのぞみしだいにやろう」「じゃ、おれの親方の家でもいいかい」「頼む、あれ、あれ、もう軍馬の蹄がまぢかにせまる」「たいへんだ！",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
