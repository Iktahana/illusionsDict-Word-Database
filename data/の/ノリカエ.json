    "definitions": [
      {
        "index": 1,
        "gloss": "transfer (trains, buses, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三昼夜かかって、やっと秋田県の東能代までたどりつき、そこから五能線に乗り換えて、少しほっとした。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、乗り換え切符を出さなくなったために乗客の選ぶコースが平常と変わり、その結果としていつもは混雑するある時刻のある線路が異常に閑散になったというような現象もあるらしく思われた。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三田行きの電車を大手町で乗り換えたり、あるいはそこから歩いたりして日本橋の四つ角まで行く。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの練馬駅から東上線で池袋へ行き、そこで省線に乗り換え、新宿駅へ着いたら、東京行の省線に乗り換え、水道橋というところで降りて、とたいへん遠い路のりを、不自由な日本語で一生懸命に説明して下さいましたが、どうやらそれは、本郷の春日町に行く順路なのでありました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八王子あたりまでは、よく晴れていたのだが、大月で、富士吉田行の電車に乗り換えてからは、もはや大豪雨であった。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "池袋から乗り換えて東上線の成増駅まで行った。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "川部という駅で五能線に乗り換えて十時頃、五所川原駅に着いた時には、なんの事はない、わからない津軽言葉なんて一語も無かった。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里から西南へ三時間程汽車に乗って行くとロアール河の都ツール市へ着きます、其処から汽車を乗り換えて二十分｜許りで此のモントリシヤへ到着します。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "境川で乗り換えて、市岡四丁目で降りた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃木の馬が疲れたので、吉松の馬に乗り換えたが、忽ち弾丸が馬に中って、馬は狂奔して敵中に入ろうとした。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は馬を馳けづめに馳けらせるので、途中で度々、乗り倒したが、前もって宿々に馬を置いてあるから、忽ち乗り換え乗り換え諸鐙を合せて馳せた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりバーゼル止まりの客車へ乗り込んでいたが、車掌に注意されてあわててベルリン直行のに乗り換えた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車もあるにはあるが、小牛田で東北本線に乗り換え、瀬峯まで行ってから軽便鉄道で築館まで行き、そから高清水まで歩くとなると、乗り換え時間の都合や何かで、三時間ぐらいで行けるかどうかわからなかった。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも汽船の乗り換えは毎回少なくとも十五分の遅れが出る。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新聞材料にぶつかった最初から受け続けている、何とも云えないイヤナ感じを、ここでもっと突込んでみようか……それともこの辺で思い切ってしまって、もっと明るいキビキビした、ほかの材料に乗り換えようかと、一瞬間思い迷った。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一太郎に乗り換えれば原稿料が倍稼げるぞ」とからかうと、「効率の対極にこそ文化は育つ」とＴ田は力なくほざくのが常だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は西国まで往くことは出来ぬが、諸国の船頭を知っているから、船に載せて出て、西国へ往く舟に乗り換えさせることが出来る。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女も、それを取って乗り換えのために戸口へ立って行った。",
              "citation": {
                "source": "指",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、小田原で乗り換えると行く手にはもっと難物が控えている。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、乗り換えて見ましょうか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田の高等商業学校へ行くつもりで、本郷四丁目から乗ったところが、乗り越して九段まで来て、ついでに飯田橋まで持ってゆかれて、そこでようやく外濠線へ乗り換えて、御茶の水から、神田橋へ出て、まだ悟らずに鎌倉河岸を数寄屋橋の方へ向いて急いで行ったことがある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の先生の話　冷い雨の降る日――四谷から牛込へ帰る途中――飯田橋から新宿行の急行電車に乗り換えると――あの中学生――一週間余り前に、上野公園の杉の木蔭で、友達にアルファベットの秘密を教えた生徒が、偶然に記者の前に立っているのを発見した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな停留場には一切止まらず一気に走って、重立った停留所や乗り換え場所だけ拾って行く。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の帰りに市ヶ谷にいる軍人に用事が出来たので、帰りに市ヶ谷へ廻り、またそこで酒を飲んで、十時｜比帰って来て、飯田橋で一度電車を乗り換え、二度目に水道橋で大塚行の電車へ乗って、後の上り口の処へ立っていると、春日町の方から来た電車と壱岐坂下の手前で擦れ違った。",
              "citation": {
                "source": "妖影",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（掲載誌不詳、『十番随筆』所収）春の修善寺　十年ぶりで三島駅から大仁行きの汽車に乗り換えたのは、午後四時をすこし過ぎた頃であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二日は猿田｜川岸から舟に乗って栗橋に着き、さらに堺川岸から舟を乗り換えて、その夜は舟泊まりとなる。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "スキーの跡は市内の方へ向いてその空地を斜めに横切り、どうやら向うの本通りへ乗り換えるつもりらしい。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金杉橋でのりかえ、一の橋までまいりましたの。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自働車にのりかえ、やっと車室に乗込んだら直ぐ発車という程度で間に合った。",
              "citation": {
                "source": "湯ヶ島の数日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奉天」　のりかえ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            }
          ]
        }
