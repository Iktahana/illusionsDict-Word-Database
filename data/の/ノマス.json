[
  {
    "uuid": "eac651a6-3788-5f1d-b731-dd3e0174eecf",
    "entry": "飲ます",
    "reading": {
      "primary": "のます",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
