    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wild rose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔温く妊みて黒雲の〕温く妊みて黒雲の、　　　　　　野ばらの藪をわたるあり、あるいはさらにまじらひを、　　求むと土を這へるあり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに野ばらの根を浄み、　　蟻はその巣をめぐるころ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは小さな円い緑の草原で、まっ黒なかやの木や唐檜に囲まれ、その木の脚もとには野ばらが一杯に茂って、丁度草原にへりを取ったやうになってゐます。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の者が野菜洗うためにとてこの流れの幅をことさらに広く掘り、小さき入り江をなせる、いつもかれが好みて訪い来るところにいで落ち葉を敷きつ、茅、野ばら、小笹の類入り乱れし藪叢を背にしてうずくまり、前には流れの音もなく走るをながめたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれらの中でいちばん立派なのは小さな野ばらの木でした。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野ばらの枝は茶色の琥珀や紫がかった霰石でみがきあげられ、その実はまっかなルビーでした。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青ぞらはふるい　ひかりはくだけ　風のきしり　陽は織れど　かなし」　野ばらの木が赤い実から水晶の雫をポトポトこぼしながらしずかに歌いました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十力の金剛石はきょうも来ず　めぐみの宝石はきょうも降らず　十力の宝石の落ちざれば、　光の丘も　まっくろのよる　二人は腕を組んで棒のように立っていましたが王子はやっと気がついたように少しからだをかがめて、「ね、お前たちは何がそんなにかなしいの」と野ばらの木にたずねました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野ばらは赤い光の点々を王子の顔に反射させながら、「今｜言った通りです。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野ばらがよろこんでからだをゆすりました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野ばらがあまり気が立ち過ぎてカチカチしながら叫びました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十力の金剛石は野ばらの赤い実の中のいみじい細胞の一つ一つにみちわたりました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は向うに、七尺ばかりの高さのきれいな野ばらの垣根を見ました。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野には、あざやかな緑の上に、白い野ばらの花がさいていた。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　野ばら　夏の山路を旅した時の事である。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し離れた崖の下に一株の大きな野ばらがあって純白な花が咲き乱れている。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今折って来た野ばらをかぎながら二三町行くと、向こうから柴を負うた若者が一人上って来た。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はなんというわけなしに手に持っていた野ばらを道ばたに捨てて行く手の清水へと急いで歩いた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、芝生を静かに横切って野ばらの蔭まで行くと、立ちどまって首を上げ、細い焔のような舌をふるわせた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野ばらめ、消えてなくなれ！",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと道に出たときには、大辻の手も足も、野ばらのとげでひきさき、血だらけになっていた。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　両手は朝露にぬれ、足も枯草と泥に汚れて、もはや血眼の彼女は、人に見られてもかまわず、野ばらの蔓の中まで掻き分けた。",
              "citation": {
                "source": "錦紗",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど若し我が恋人われより遠く、北の国なる霧の中にあらば、何かせん、四月の新しき歌、四月の白きリラの花、野ばらの花も、梢を縫ひて黄金と開く四月の日光も。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらの垣根には、白い野ばらの花が、こんもりと固まって、雪のように咲いています。",
              "citation": {
                "source": "月夜と眼鏡",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なぜそんな事をします、うつくしいカアル」　アルダナは愛の眼を以って彼を見ながら訊いた、彼女はちょうど夏の日の朝のようだった、髪のなかの日のひかりと、野ばらのような顔の色と、山の湖のように青い眼と。",
              "citation": {
                "source": "精",
                "author": "CATHAL OF THE WOOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、国境のところには、だれが植えたということもなく、一株の野ばらがしげっていました。",
              "citation": {
                "source": "野ばら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "野ばらの花が咲いて、みつばちは、日が上がると、暮れるころまで群がっています。",
              "citation": {
                "source": "野ばら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一月ばかりしますと、野ばらが枯れてしまいました。",
              "citation": {
                "source": "野ばら",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾宮沢賢治落ちしのばらの芽はひかり樹液はしづにかはたれぬあゝこの夕つゝましくきみと祈らばよからんをきみきたらずばわが成さんこの園つひにむなしけん西天黄ばみにごれるに雲の黒闇の見もあへず",
              "citation": {
                "source": "開墾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく去年などは幾株かのばらとつつじを綺麗に坊主にしてしまわれた。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
