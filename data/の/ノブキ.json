        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "永井さん来訪、野蕗君徃訪。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――野蕗さんがひよつこり乗り込んで、送つて下さつた、涙ぐましい温情を感じた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎藤さんからなつかしいたよりがあつた、野蕗君からも近々訪問するといふうれしいたより。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時帰庵、野蕗君を待つ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "僊君乗車の汽車を待ち合せて共に野蕗居へ。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蕗君は駅まで出迎へて下さつた、奥さんは娘さんのお産で満洲行の不在。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蕗老に導かれて、みどりさんを訪ねた、病臥中で気の毒だつたけれど、私たちの訪問が彼女を喜ばし慰めたことは疑へない。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……野蕗老のまめ／＼しさよ、おべんたうを詰めて貰ひ、残りの酒を酌んで別れる、なが／＼お世話になりました、さよなら、ごきげんよう。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの方は、めずらしく浅野蕗子から来ている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみに耐えてふるえている浅野蕗子の、清らかな小さい赤い唇があり、彼女の弟も、日本の苦しみの中で命を絶った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあのぶきりょうな子家鴨もみんなと一緒に水に入り、一緒に泳いでいました。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたつの品に何かのぶきみな怨念でもが残っていると思うより思いようがない……。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二には、疑問の中心点であるごく内密にしてほしいといったそのことの理由について、なんらかの糸口とひっかかりを発見しないことには、それこそ伝六のいいぐさではないが、このぶきみきわまる怪談のあばきようがないと思いついたからでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "しんちんと鬼気胸に迫って、ぞおっとえり首までがあわだつばかり、そのぶきみな境内をものともしないで、名人はほこらの裏にぬけると、ぴたり身を社殿の陰に寄せながら、じっと息をひそめて、何者かを待ちだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゃべるなとしかられたのがきいたためではないらしく、どうやらあたりのぶきみさ、ものすごさにおしゃべり虫がちぢみ上がったとみえて、ごくりごくりとなまつばをのんだままでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門のぶきみなくらいにゆうぜんとしたおちつきぶりを見て、とうてい三人の悪友だけではわが身の安全がおぼつかないと思ったものか、いきなり家の内めがけて逃げ出しましたものですから、もう事ここにいたらば、右門に待たれるものはおなじみのあの草香流のみです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかというと、このために、物をいう木や、ひとりで動く道具や、あのぶきみな機械人間や、そういったものは皆姿を消してしまって、三角岳はまたもとの自然のままの姿にかえったのだから。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのぶきつちような處に、泡鳴らしい味ひがあつたものである。",
              "citation": {
                "source": "詩と散文との間を行く發想法",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、くねくねと曲って、ゆらゆらうごいているが、そのぶきみさといったらない。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の口から下はナプキンにかくれて見えないが、青いめがねをかけたその顔は、頭から顔じゅうをほうたいでぐるぐる巻き、ほうたいの白い中から鼻だけが赤くのぞいていて、そのぶきみさは、全身の毛がそうけ立つほどだった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあのぶきつちよな丑紅の牛も大切であつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらの姿を初めて見た者は、おそらく一種のぶきみさにおそわれるだろう。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには食いつき犬も仰天したらしい、ううと唸り、背筋の毛を逆立てながら、そのぶきみさにおそれをなして、じりじりと後へしさりだした。",
              "citation": {
                "source": "似而非物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやは傷を見たときちょっと蒼くなったが、すぐに気をとり直したようすで、敏捷に立ちまわり、庄兵衛のぶきような手当ぶりをよく助けた。",
              "citation": {
                "source": "十八条乙",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――眼に見えない周囲のぶきみな情勢、重症の父、早くもまたぐれだしたという半三郎、そして哀れな由利江、「なにもかも暗い、前も後ろも」金之助は溜息をつきながらこう呟いた。",
              "citation": {
                "source": "落ち梅記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのぶきみな手ごたえに、胆が消えた。",
              "citation": {
                "source": "夕靄の中",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐のぶきような抱きかたを見て、綱宗が、原田は子を抱いたことがないようだな、と笑った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのぶきみな深いしじまを縫って、「はやく医者を」という言葉がつぶてのように人びとの耳をうった。",
              "citation": {
                "source": "日本婦道記",
                "author": "藪の蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなさわぎのあいだに、Ｒすい星のぶきみな姿は、グングン地球に近づいていました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭からすっぽりとかぶるようになっていて、目のところだけ三角の穴があいている、あのぶきみな覆面です。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
