          "literary": [
            {
              "text": "現世の愛の苦労を厭う狡猾な男女は、二人が恋の神秘に辿り着いた時、其処まで運んで呉れた此世の舟を乗り捨てるので御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車を乗り換え、乗り捨てると、彼は示された町を訊ねた。",
              "citation": {
                "source": "自殺を買う話",
                "author": "橋本五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりから外出中の叔父も自宅を案じて自転車で駆けつけたが、火の廻りが案外に早く、大波のごとくに寄せ来る避難者の群れに捲き込まれ、その車も自転車も人浪の間に引き棄て乗り捨てる。",
              "citation": {
                "source": "震災日誌",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
