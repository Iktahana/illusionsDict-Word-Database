    "definitions": [
      {
        "index": 1,
        "gloss": "concussion (of the brain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
