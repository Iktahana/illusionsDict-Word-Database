[
  {
    "uuid": "aa8f31b5-3072-551c-acfe-f4e3c43c044e",
    "entry": "納棺",
    "reading": {
      "primary": "のうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
