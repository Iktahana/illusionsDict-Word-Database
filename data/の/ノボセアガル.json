        "index": 1,
        "gloss": "to be beside oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「粋」という字に羽織を着せたような米朝の噺に、田舎娘が町の若い衆にのぼせ上がるように胸ときめかせてしまうオレは、正統派として育った枝雀の芸も正直見てみたい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の寒気に凍え切った肉体はすぐ熱を吹き出して、顔などはのぼせ上がるほどぽかぽかして来る。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むちゃくちゃにのぼせ上がるがいい、有頂天になるがいい。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "女だから、女の友達をと考えるのだけれども、自分が足りないのか、向うが私を厭な奴だと思うのか、のぼせあがるようなひともない。",
              "citation": {
                "source": "生活",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大竜は小心ヨクヨクたるところもあるが、オッチョコチョイの勇み肌もあって、小さいのや女の子におだてられても気をよくしてのぼせあがる性分だった。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "のぼせあがるのもほどがあるよ。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって彼にのぼせあがる女は幾らもいたが、彼はどんな女をも近よせず、いまだに独身をとおしている。",
              "citation": {
                "source": "滝口",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌打ちをしてそう云われたとき、おれはのぼせあがるほど癪に障った。",
              "citation": {
                "source": "落葉の隣り",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふん、そうのぼせあがるな、まあおちつけよ永井主計うじ。",
              "citation": {
                "source": "古今集巻之五",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は反射的に眼をそらしたが、なめらかに脂肪を包んだ肌の色と、たっぷりと豊かに、重たげな乳房のまるみと、そうして二つの小さな鴇色の蕾とが、そらした眼の裡にはっきりと残って、彼を狼狽させ、のぼせあがるような気持にさせた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐は幼なかったが、それが鯉だということはすぐにわかったし、そんなに大きな鯉を見たのは初めてで、のぼせあがるほど昂奮した。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
