    "definitions": [
      {
        "index": 1,
        "gloss": "paper bag for putting a present in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
