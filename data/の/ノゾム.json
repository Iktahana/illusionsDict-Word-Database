[
  {
    "uuid": "4157f652-6494-500e-9b8c-424ffe3a9301",
    "entry": "望む",
    "reading": {
      "primary": "のぞむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
