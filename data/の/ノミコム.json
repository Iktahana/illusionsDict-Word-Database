[
  {
    "uuid": "7abbd0b2-35b2-5f5b-810e-65b832a6aa92",
    "entry": "飲み込む",
    "reading": {
      "primary": "のみこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
