  {
    "uuid": "6a083066-94ce-5c0d-9451-69510242cc2a",
    "entry": "ノロ",
    "reading": {
      "primary": "ノロ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "norovirus",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私がノロクサと三階に登つた時には、もう五人分しか席がなかつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札口でなしに、小荷物口の方に向って、三四十人の人の群が、口々に喚き、罵り、殴り、髪の毛を引っ掴みながら、揺ぎ出した岩のようにノロノロと動いて行った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私はノロくさく歩いた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和六年の秋米国各大学における講演を頼まれて出張し、加州大学、スタンフォード大学、加州及びマサチュセッツのインスチチュート・オブ・テクノロジーその他で、講義、あるいは非公式談話をした。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また髭にうんと絞られるぜ‥‥」「可哀想になあ‥‥」　中根熊吉の「馬さん」は二｜年兵の二｜等卒で、中隊でもノロマとお人好しとで有名だつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに連れて煤けたお面を冠った、奇妙な着物を着た人間が、ノロマが蜘蛛の巣を取るような恰好でソロリソロリとホツキ歩くのだから、トテモ退屈で見ていられない。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのノロノロした張り合いのないように見えた舞いの手ぶりが非常な変化のスピードを持ち、深長な表現作用をあらわすものであると同時に、心の奥底にある表現欲をたまらなくそそる作用を持っている事が理解されて来る。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい眼前にも湯屋の煤突がノロ／＼と黄色い煙を噴出してゐた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までよりも更に数等深い鋭い恐怖に襲われつつ、白昼の夢遊病者のようにノロノロと自分の周囲を見まわした。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレノロジストの主張の如くに、腦の某部分が某才能某情感の根基若くは寓居であるや否やは猶未確定に屬すると雖も、要するに器分と非器分との間には脱し難き連鎖があり、器分が一を減ずれば非器分が一を減じ、器分が一を増せば非器分が一を増すことは爭ふ可からざる事である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイノロジイらしいなと誰かが噂した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「踊る一寸法師」では、その材料のステキサと、ノロノロと推移するリズムの詩的？",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに連れて煤けたお面を冠った、奇妙な着物を着た人間が、ノロマが蜘蛛の巣を取るような恰好でソロリソロリとホツキ歩くのだからトテモ退屈で見ていられない。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのノロノロした張り合いのないように見えた舞の手ぶりが、非常な変化のスピードを持ち、深長な表現作用をあらわすものであると同時に、心の奥底にある表現慾をたまらなくそそる作用を持っている事が理解されて来る。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "孰れにすべきか一時間ばかり考へる為にノロノロと歩み走つた。",
              "citation": {
                "source": "吾家の随筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "テクノロジーを頼る理由がここにあります」　幅広くツールキットの採用を働きかける中で、ボイジャーはしだいに、エキスパンドブックの可能性を認めようとする人たちを獲得していきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パーソナルコンピューターの革命に関して学ぶべき最大のポイントは、テクノロジーなり科学なりに対し、それが何に対して奉仕するものなのかを検証し、地球に生きる一人一人の人間にとってプラスとなる方向に、鞭をくれてやるという態度ではないでしょうか」と、ちゃんと二百十九頁に書いてあるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネットワークはまさにバイオテクノロジーのように有用であり、大きな市場規模を持ち、同時に退屈だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "末席をけがすとエム・ピー・テクノロジー社長の吉本万寿夫さんに、「こんな話はマッキントッシュが出た時点で、五、六年前にやっておくべきですよね」とかまされた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＭＤのＸ８６互換への挑戦は、その後チップス＆テクノロジーズ、サイリックス、テキサス・インスツルメンツといった追随者を生み、競争相手の出現によってインテルは製品の大幅な値下げを迫られた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにインテルの３８６独占の打破には、チップス・アンド・テクノロジーも名乗りを上げた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等の香気は明らかに動物の生殖慾の亢昂時に成り立つところのジャ香（ジャコウジカより得られる香料）やショウ香（ノロジカより得られる香料）や、植物の交精時に発する薇薔花香・百合花香・菫花香・ヘリオトロープ花香・茉莉花香等とは異なったものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレノロジストの主張のように、脳の或る部分が或る才能或る情感の寓居であるか否かは未確定といえども、要するに器分と非器分との間には脱し難い連鎖があり、器分が一を減ずれば非器分が一を減じ、器分が一を増せば非器分が一を増すことは争えない事実である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様みたいな薄ノロが洋服を着たら、さぞかし……フッフッフ。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
