              }
            },
            {
              "text": "「馬鹿、うすのろ、妾を侮辱したね、妾のプライドをきずつけたんだ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ空｜想家で何かの趣味道楽なしには生きられない青木さんにとつては、ただ金に追はれてばかりゐるやうな、あくせくした日々の生活がむしろのろはしいくらゐだつた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしのろ／＼這っている訳には行かない。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹が重く、動作がのろいんだが、健二はやはりこんなことを気遣った。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柵を開けてやると、彼女は大きな腹を地上に引きずりながら低く呻いてのろのろ外へ出た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛や馬の群が、背に夕日をあびて、草原をのろのろ歩いていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞は今朝出る前に讀み盡して了つたし、本を讀む元氣もなし、眠くもなし、喋舌る對手もなし、あくびも出ないし、さて斯うなると空々然、漠々然何時か義母の氣が自分に乘り移つて血の流動が次第々々にのろくなつて行くやうな氣がした。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん貝がらだけでなく生きた貝で、箱の中へ草といっしょに入れてやるとその草の葉末を蓑虫かなんぞのようにのろのろはい歩いた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
