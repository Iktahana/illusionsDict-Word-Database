[
  {
    "uuid": "1333cc87-1513-58dd-8ca6-60c297c46f4c",
    "entry": "祝女",
    "reading": {
      "primary": "のろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
