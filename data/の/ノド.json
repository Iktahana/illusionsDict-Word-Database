[
  {
    "uuid": "a87efd7b-23b1-5d4a-985d-5d1dc69e1133",
    "entry": "喉",
    "reading": {
      "primary": "のど",
      "alternatives": [
        "のんど",
        "のみと",
        "のみど",
        "ノド"
      ],
      "is_heteronym": false
    },
    "grammar": {
