      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "throat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おれの凄惨な一声で、この団欒が滅茶々々になるのだ、と思ったら喉まで出かかった「助けて！",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのう、赤ちやんが咽喉にお餠を引つ掛けて、呼吸が止りかけてゐます。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくよく咽喉の栓となつた生焼けの餠は、却々取り除けられさうもなかつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が仰向いて長火鉢の上の柱時計をみながら飛び出した喉豆に掛けた声で「七時かあ」と云つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか海洋博物館での通俗講演会でペンクが青島の話をしたとき、かの地がいかに地の利に富むかということを力説し、ここを占有しているドイツは東洋の咽喉を扼しているようなものだという意味を婉曲に匂わせながら聴衆の中に交じっている日本留学生の自分の顔を見てにこにこした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか船首をめぐらせる端艇小さくなりて人の顔も分き難くなれば甲板に長居は船暈の元と窮屈なる船室に這い込み用意の葡萄酒一杯に喉を沾して革鞄枕に横になれば甲板にまたもや汽笛の音。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲んでみると名状の出来ぬ芳烈な香気が鼻と咽喉を通じて全身に漲るのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑喉場の前に日本式の小さい帆前が一艘ついて、汀には四、五人ほど貝でも拾っている様子。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お婆さんの儼然たる態度に壓倒されて、言葉が喉のあたりにひつからまつて何も言へない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕快に喉をくすぐりながら通過して、體内にぽつと灯りがともつたやうな嬉しい氣持になる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼女はうめくべく唄の一句毎の前には必らず鼻と咽喉の間へ「フン」といった自嘲風な力声を突上げる。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼吸を吸い込むと胸の中に枯枝か屑のようなものがつかえ、咽喉はいらいらと虫けらが這うように痒い。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸から咽喉へかけて意地悪い痩せこけて骨張った手が捏ねくり廻しているようだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつ等が、咽喉にうにょうにょして停滞しているときは、全く無作法な獣たちですね。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚木の大きい咽喉仏がゆっくり生唾を飲むのが感じられた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体的とも精神的とも分野をつき止めにくいあこがれが、低気圧の渦のように、自分の喉頭のうしろの辺に鬱して来て、しっきりなしに自分に渇きを覚えさせた。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな羽虫が幾匹も幾匹もその咽喉にはいりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜疋の甲虫が、夜だかの咽喉にはいって、ひどくもがきました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまるでよだかの咽喉をひっかいてばたばたしました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一疋の甲虫が、夜だかの咽喉にはいって、ひどくもがきました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして誰にも聞えないやうに窓の外へからだを乗り出して力いっぱいはげしく胸をうって叫びそれからもう咽喉いっぱい泣きだしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "達二は咽喉一杯叫びました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉例だとあって朝鮮の鶴と称するものの吸物を出す家があったが、それが妙に天井の煤のような臭気のある襤褸切れのような、どうにも咽喉に這入りかねるものであった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ追付いた敵が彼の咽喉を切開したというのである。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかベルリンで見た歌劇で幕があくとタンホイゼルが女神の膝を枕にして寝ている、そして Zu viel! zu viel! と歌いながら起き上がる時に咽喉がつかえて妙な声になりそうなので咳払いを一つして始末をつけたのを記憶している。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自棄のない詩は神の詩か凡人の詩かそのどつちかと僕が決めたげます",
              "citation": {
                "source": "（テンピにかけて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ茲で附加へたいことは、感動が、点睛の実現にまで到達する、つまりのどいりのする感動であるためには、私はどうしても宗教が必要だと思ふ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "上陸当初の日に一瞥して嘔吐を催し、現代日本の醜悪面を代表する都会と罵り、世界のどんな汚い俗悪の都市より、もっと殺風景で非芸術的な都市と評した東京は、彼が死んでも住みたくない所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は、私のどたばた働く姿を寝ながら横目で見て、「君は、めっきり尻の軽い男になったな。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな「純真」のどこが尊いのか。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
