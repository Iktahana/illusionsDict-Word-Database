          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "手を伸ばすと、棚の上の本にようやく届いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供は母親に向かって両手を伸ばし、抱っこをねだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困っている人には、ためらわずに助けの手を伸ばすべきだ。",
              "citation": {
