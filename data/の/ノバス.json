        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "コーヒーが濃すぎたので、少しお湯で伸ばすことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
