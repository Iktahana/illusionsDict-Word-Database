[
  {
    "uuid": "ed677a3d-0a0d-5ca0-9693-9bdf1323002f",
    "entry": "伸ばす",
    "reading": {
      "primary": "のばす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
