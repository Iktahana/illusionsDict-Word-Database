        "examples": {
          "standard": [
            {
              "text": "ふと故郷の風景が脳裏に浮かび、少し感傷的な気分になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重要な会議中に、昨日の失敗が脳裏に浮かんで集中できなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ああ、あの時の君の言葉が、今になって脳裏に浮かんでくるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いざ、眼のために書くことを諦めなければならないとなると、私の脳裏に浮かぶのはやはり失明のために苦しんだ先人たちのことである。",
              "citation": {
                "source": "平次と生きた二十七年",
                "author": "――筆を折るの弁――",
                "note": "青空文庫"
              }
            }
          ]
        }
