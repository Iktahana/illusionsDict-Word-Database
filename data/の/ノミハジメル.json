        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、斯うしてチビチビと飲み始めるのだ。",
              "citation": {
                "source": "極夜の記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこんなに飲み始めると耳鳴りがし足が動けなくなるまでぐでんぐでんに酔わねば収まらない性分である。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして酒を飲み始める。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時、私は茶の間へ行き酒を飲み始める。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "木内氏宅へ寄り、表の酒屋で一升買ってもらって飲み始める。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなときは躯まで小さくなったかと思うほどおとなしく、ろくろく話もできないというふうになるが、飲み始めるとまた同じような結果になるのであった。",
              "citation": {
                "source": "落葉の隣り",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "休んで又歌ふことになったが、もうハイボールを飲み始める。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中の喫茶店にチョコレートを飲みに入ったが、そこで彼女にせがみ、アドルムを三錠、十錠のみはじめると、私は丁度、麻薬中毒患者が薬にありついたような、ただ本能の奴隷となる。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
