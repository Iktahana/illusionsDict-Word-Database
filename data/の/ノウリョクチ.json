        "examples": {
          "standard": [
            {
              "text": "このキャラクターは、攻撃力と防御力の能力値が高いのが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゲームの序盤で、まずは主人公の能力値をバランス良く上げることを目指した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「おお、このボスキャラ、能力値が半端ないな！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "このようなものだ――　　シャーロック・ホームズ――その能力値　一、文芸の知識――ゼロ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の記憶が確かなら、仲良くなり始めの頃、僕の能力値をはっきり定めて書き立てたことがあったね。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
