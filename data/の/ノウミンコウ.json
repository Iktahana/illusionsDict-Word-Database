        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "都市部の建設現場では、多くの農民工が汗を流して働いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "農民工の存在は、中国の経済発展を支える大きな力となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は故郷の家族のために、農民工として大都市で懸命に働いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――広東の共産分子で無産者の中央執行委員会を構成せんとしたプロレタリア的要素からなる多数の同志が、反動派の主脳部を共産軍の砲兵隊をもって攻撃を始め、第一公園に於て農民工人を一団にした暴動が勃発して、市中は大混乱に陥り、珠江の紫洞船の房室は忽ちにして死体室に変ったのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "模様がうぶで、純で、どこか西欧の農民工藝と通じるところがある。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の農民工藝の代表者にいつだとてなれるでありましょう。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例を農民工藝のようなものに取るならなおさらです。",
              "citation": {
                "source": "民藝の性質",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
