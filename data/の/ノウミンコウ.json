    "definitions": [
      {
        "index": 1,
        "gloss": "migrant worker from the countryside (in China)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
