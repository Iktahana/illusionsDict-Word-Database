    "definitions": [
      {
        "index": 1,
        "gloss": "busy farming season",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "部落の人達も、植付期とか収穫期とかの、農繁期になると、子供の馬方で間に合うようなときには、伝平をわざわざ頼みに来た。",
              "citation": {
                "source": "馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "農繁期には必らず何日間か、差配松本の持田に勞力を提供しに行かなければならなかつたが、昔からのしきたりでそれはほとんど無償勞働だつた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月の半ば頃から、駿介は、健康恢復後の最初の仕事として、農繁期託兒所を創設するために奔走しはじめた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駿介は、農繁期託兒所が、村の女子青年團とか僧侶とか、或ひはその他の有志などによつて計畫なり實行なりされたことが、一度でもあつたかどうかを、いろいろ人に訊いてみたが、今迄てんでさういふこともないらしかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "農繁期託兒所のやうな仕事は、ある特志家個人の仕事とするよりも、村の何等かの團體が經營の主體となることが望ましい。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「農繁期託兒所は近頃、他村でもぼつぼつ始めてゐる所がありましてな。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "農繁期託兒所に對する新たな興味と熱意とが涌いた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "農繁期に於ける親達の足手※ひを、何とかその期間だけ親達から隔離しておけばいいといふだけのものではない、託兒所は子供達のために獨立した使命を持つてゐる、といふことを、今更のことではないが深く感じた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の労力は昼夜のわかちなく求められて、農繁期に机に向うことなどは思いもよらない。",
              "citation": {
                "source": "文学と地方性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれこれ話しつゞけてゐたが、いよ／＼農繁期に入つたのでまた暫らく逢へまいといふので、一杯やることに相談一決（いつでも異議のあつたことがない！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶よく見よ、餌を運ぶ蟻は今正に収穫の農繁期なり。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農繁期でみなさんおいそがしくいらっしゃいませう。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "土の囁き一　予め通知を出しておいたのに、集りが非常にわるく、農繁期で無理もないとは思ふものの、田丸浩平は、いささか失望の気味で、会場の薄暗い電燈の下へ、それでも顔を見せた八九人の有志と車座を作つた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "楯家では、細君が下の男の子二人を連れて先月から地方の実家へ納まり、留守は主人と長男、長女夫婦、次女の五人となり、女中は農繁期だけといふ約束で田舎へ手伝ひに帰つてゐる。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はほんの少しばかりの田畑を小作しているとのことだが、むろんそれだけで足りようはずはなく、養蚕時はその手伝いに、農繁期には日傭取りに……というふうにしてささやかな生計を立てていたのである。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "田屋とはその名のごとく田地の所在に設けられた小屋で、平素は居村の住宅に住んでいる農民も、農繁期には朝夕その耕地に通うの不便を避けて、便宜ここに寝泊りしたものであった。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、農繁期になりますと、学校よりゃ野良仕事が大事だと言って、めったに学校へは出て来ない子供が多いです」「それじゃ、村の百姓達の人情、人気はどうでしょう？",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "川に沿うて下ると間もなく駒ヶ岳神社の里宮に着いたが、失望したことには社殿は改築中で、それも農繁期の為か工事は中止されて、留守居の老人がいるに過ぎない。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に今は農繁期ですよ。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも、農繁期の時だけ連れ帰って仕事をさせて、後は邪魔になるのでまた山へやって置くのだそうである。",
              "citation": {
                "source": "由布院行",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "農繁期なので、東北本線の急行はすいていた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさは姉が結婚して、農繁期になるのに田舎では雇う人手もないというので一・二ヵ月かえります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "農繁期なのでバスは行きかえり殆ど一人。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから十一月迄農繁期ですからどうせなかなかないでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今度は冬になって、農繁期が終って、誰かみつかる迄は、こういう状態でやって行かなければならないでしょうから、早くなれてうまくやって行きたいと思って居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いずれも農繁期ですから、秋に入ってということになるでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎は、農繁期休暇二週間のうち、半分だけはお父さんの顔を見て来なさいと云われた由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大袈裟に云えば一村ことごとく義太夫語りか、三味線｜弾きか、人形使いか、太夫元かでない者はなく、それらの人々は農繁期には畑へ出て働き、百姓の仕事が暇になる季節にそれぞれ一座を組織して島の此処彼処を打って廻る。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は小さい頃から、母といっしょに藤左衛門の家へ、農繁期の手伝いにゆく習慣がついているので、ひとり息子の藤作とは兄妹同様に扱われている。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
