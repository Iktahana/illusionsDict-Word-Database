[
  {
    "uuid": "863d5c1a-57f6-5641-98d1-a63d586a04ef",
    "entry": "納金",
    "reading": {
      "primary": "のうきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
