  {
    "uuid": "5667dac4-cee3-5df5-b931-252f42d945ec",
    "entry": "ノミ屋",
    "reading": {
      "primary": "ノミや",
      "alternatives": [
        "のみや"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
