    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bookmaker",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "執筆者へ渡す謝礼の金まで注ぎ込み、印刷屋への払いも馬券に変り、ノミ屋へ取られて行った。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、大体、新興喫茶で、女の子にサービスさせておきながら、ノミ屋なみの勘定ですまそうとする客はヤボですよ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "政党におちょっかいを出すなんと、そんな柳子さん、若宮猛なんて株屋、株屋と言ったって、あんた、買うたか買わんかの、ノミ屋に毛の生えたような小者だのに、政党に手を出すなんて、あんた、先さまが笑わあ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地域に蝟集するバラツク建てのノミ屋とパチンコ屋に、今を盛りと客がはいつている時刻で、それに東京では、新宿に次ぐ多数の乗客を呑吐するといわれる池袋駅で、その眼の先きから出火したのだから、駅前は身動きの出来ぬ雑沓で、悪くすると私など、押し倒されかねまじき形勢である。",
              "citation": {
                "source": "擬似新年",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノミ屋のアンちやんらしいのが、駅の軒下へ運び出しておいた荷物を、両腕にかかえて立上つて、「もう大丈夫だ。",
              "citation": {
                "source": "擬似新年",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻雀友だちで、ノミ屋だつたり質屋だつたり撞球屋だつたりしている、通称かんちやんの家は、どうやら焔の海の真ん中らしく、見舞つてやりたいが、そつちへは消防官がやつてくれない。",
              "citation": {
                "source": "擬似新年",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方のお考えじゃア、オレの手はノミやカンナをとるタクミの手じゃアなくて、斧で木を叩ッきるキコリの腕だとお見立てですかい。",
              "citation": {
                "source": "夜長姫と耳男",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
