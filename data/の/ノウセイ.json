          "literary": [
            {
              "text": "黒崎は友人たちとともに、脳性麻痺の障碍を持った子供が使う、意思表示の道具を作ろうと準備を進めているという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本は黒崎の友人でこの試みに共感していた玉城重信と玉置晴朗とともに、群馬県桐生市の桐生第一養護学校を訪ね、脳性麻痺の子供たちにとってどんな道具がふさわしいのかを探りはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
