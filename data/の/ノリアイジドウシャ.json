    "definitions": [
      {
        "index": 1,
        "gloss": "bus (on a regular route)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "乗合自動車の轍の地揺れのたびに落ちるマロニエやプラタアヌの落葉。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃の工合があまりよくなかったが気分がいいので乗合自動車で銀座へ行った、そして例のように風月へはいってコーヒーを呑んだ。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がた／＼の古馬車と、なたまめ煙管をくわえた老馭者は、乗合自動車と、ハイカラな運転手に取ってかわられた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道もそこまでは乗合自動車がやって来た。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその乗合自動車のやって来る起点は、ちょうどまたこの溪の下流のＫ川が半町ほどの幅になって流れているこの半島の入口の温泉地なのだった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ一台の乗合自動車が通りかかった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車ばかりか、意地悪く乗合自動車も来ない、円タクも来ない。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしきりに考えながらも足取だけは小急ぎに国道へ出たが、ちょうど通りかかった乗合自動車を見ると、急に手を挙げて飛乗って町へ出た。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合自動車に乗って日の暮れぬ中に谷郷村に帰った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、六年前から、馬車の代りに走るようになった乗合自動車が朝早く通ったのである。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か身体ごとヴァイオリンに挑み掛っているように感じられるその行儀の悪い弾き方は、庄之助が寿子のような小柄な体格でどうすれば強い音を出すことが出来るだろうかと、考えた末の弾き方であったが、しかし審査員達はそんな意味には気づかず、乗合自動車の女車掌のような寿子の姿勢に、思わず苦笑した。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺が大椿寺ぞとはひり来て寂しと出でぬ日暮を二人この寺も古うなりぬと陽の隈に尿しつつ云ふ我も寒むかりさびさびと暮れしづもれば磯寺の障子はかげる寒しとなしに長井二月三日薄暮、三崎より乗合自動車での帰途半で下車、長井で一泊することになつた。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は下田からの乗合自動車に乗った。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は乗合自動車が通うようになったが、その時代にはがたくりの乗合馬車があるばかりだ。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "草色の市営乗合自動車。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水色の市営乗合自動車。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "省線電車の中に並んだ女達が慎ましく膝の上に揃えた指、乗合自動車の吊り革を掴む女達の指。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そこの足掻きをするような爆音を立てながら停まっている乗合自動車の横に、婦人が、何かを思い惑うようにして立っているのだ。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し婦人は、驚異の眼を※っている彼の顔を見ると、すぐに乗合自動車のステップに足をかけた。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、動き出したその乗合自動車に飛び縋った。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合自動車は停留所ごとに人溜まりを呑んで、身じろぎも出来ないほど詰め込んだ胃袋を揺す振りながら、ごとごと走った。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "政雄は郊外の町と市の間を往復することになった新設の乗合自動車会社へ紹介せられて往ってみるとすぐ相談が出来た。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は急に脚を速めて引き返して、乗合自動車に乗つて日本橋まで行つた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも幸ひなことには、その停車場前には、Ｍ温泉までの乗合自動車が汽車の時刻と連絡して、きちんとそこに客を待受けてゐた。",
              "citation": {
                "source": "浴室",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｗ町からの乗合自動車の中でＫはほつと呼吸をついた。",
              "citation": {
                "source": "海をわたる",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の天城越幾年か見ざりし草の石菖の青み茂れり此処の渓間に　乗合自動車の故障の直されるあいだ、私はツイ道ばたを流れている渓の川原に降り立って待っていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ枯葉をつけている櫟林や、小松山や色美しい枯萱の原などを、かなり烈しい動揺を続けながらこの古びた乗合自動車は二時間あまりも走って、やがて下田街道へ出た。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ私のいる勉強乗合自動車会社に、新高って言う新しい運転手さんが来ましたの。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "半狂人を作る都会　市営の乗合自動車で、俗に「円太郎」というのがある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合自動車も、円タクも、人力車もＴ町迄だと、市外と同じ「割増し」をとった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
