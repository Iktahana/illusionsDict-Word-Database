        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蕭条とした山野の中を、孤独に寂しく漂泊していた旅人芭蕉が、あわれ深く優美に咲いた野花を見て、「笠に挿すべき枝のなり」と愛しんだ心こそ、リリシズムの最も純粋な表現である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音はやや斜め後ろから間近になると突然私の眼の前に、野花をうざうざするほど摘み集めた見覚えのある経木の手籃が放り出された。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の野花のいろは総じて紫か黄、白で、精々華やかなものでは淡紅色がある。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灼々たる野花を見ず。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "滞留洵に十一週日時に或は野花を探りて僅に無聊を銷するに過ぎず、その間一日淺間の山嶺に雲の峰の上騰するを見て始めて天地の壯大なるを感じたりき。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国の山は立てり、東北の山は横はれり、紫苑の花萩の花女郎花もしくは秋草野花をもてかざりとなせる宮城野の一望千里雲烟の間に限り無きが如きは、独り東北の地勢にして中国に見るべからざるの広野なり。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした死骸に往き当ると穴を掘り、野花を供えて懇に埋めてやった。",
              "citation": {
                "source": "仙術修業",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の野花の数々はその美しさを競ひ、星空を地上に引きをろしたやうな極度の美しさが展開されてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにして月はイルミネーションとして君を飾る君の沿岸に咲く野花のなんとことごとく君の為めの花輪であらう、すべてを冷静に眺めてきたヴォルガよ、沈着な河、ヴォルガよ、君はいま歴史を貫く国を貫ぬいてゐる、正義の河と言へるだらう。",
              "citation": {
                "source": "小熊秀雄全集-5",
                "author": "詩集（４）小熊秀雄詩集２",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに沈める眞珠あり、ここに香れる野花あり、ゆくな油鰭よ、宵暗をなに恥かしき契かは。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいやしき手にて作られし物と變りて、百種の野花思ひ／＼に咲けるぞめでたき。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒野荒野花と云ふ花は咲けども妻と云ふ花は咲かないおお　淋し荒野の果てに咲く花は妻と云はりヨかおお　淋し風に吹かれて飛ぶ雲は荒野の　果ての　野の　果てのわたしに　何んで恋しかろ。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "灌木、微風、野花、小鳥、陽は明るく空気はにおい、大変心地よい草原である。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野生の野花でございますが、造った花よりずっとずっと、綺麗で清らかでございます。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汀の野花をひきちぎつては、切りに舟を目がけて投げてゐたが、そこまでもとゞかず花片は吹雪となつて水の上に散つてゐた。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "野花があり、芝に覆はれた明るい斜面の見晴しがあつた。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからＮは、自分等の食卓を山の神様のために野花で飾らうと云つたのでした。",
              "citation": {
                "source": "舞踏会余話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちだって、旅行者のもつ俗な善意と口笛の気軽さで、野花とみどりの斜面と羊のむれのケント州の心臓を走って、「ある日大きな倫敦へ愛蘭人がやってきた」ように、黒いヴィクトリア停車場へ着いたものだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古昔寧楽朝山上憶良詠秋野花草七種。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余因賦秋野花草七種詩。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲き乱れている野花の香が、野一杯に充ちている。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにはじめて勢いを得たゼーロンは、野花のさかんな河堤をまっしぐらに駆け出したのである。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いなだらかな三日月眉は澄みきつた栗色の眼の上にもたげられ、薔薇いろの唇には屈託のない微笑が浮かび、頭べにまとはれた赤や青のリボンは、長い編髪や野花の小束と共に、彼女の蠱惑的な頭べの上に、華やかな王冠のやうに落ちついてゐた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは野花と共に水面ちかく群がつて、身をこごめながら水中を覗きこみ、飽かずおのが朗らかな眸にながめ入り、ほほ笑みかけ、枝を頷かせては会釈する。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "紹巴という茶人は、海辺の野花と漁家の形をした青銅の香炉に配するに、海岸のさびしい美しさを歌った和歌をもってした。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "野花を摘み摘み、プロヴァンスの唄でもうたいましょう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野花を摘み摘みプロヴァンスの唄を唄った。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時、夕映の空や河原の野花などを眺めながら、父母は私の今後の生活について話したかったろうし、私も自分の志望や目的などについて話したかったが、然しただ一二言のうちに互に首肯し合って、つまらないことばかりを話題にした。",
              "citation": {
                "source": "父母に対する私情",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、河内の国、富田林の、石の上露子さんとどっちが――」　かつて、雑誌『明星』の五人の女詩人、鳳晶子、山川登美子、玉野花子、茅野雅子と並んで秀麗しい女であって、玉琴の名手と聞いていた人の名をいって見た。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "野花を蹴散らし砂塵を上げ、走る走る驀地！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
