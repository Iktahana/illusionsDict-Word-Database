  {
    "uuid": "60b65bca-7daf-55dc-955c-cdc8cdfb3ce2",
    "entry": "暖簾",
    "reading": {
      "primary": "のれん",
      "alternatives": [
        "のうれん",
        "のんれん"
      ],
      "is_heteronym": false
