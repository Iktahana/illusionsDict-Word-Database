    },
    "definitions": [
      {
        "index": 1,
        "gloss": "advertising the excellence of one's wares",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ク教授は新醸のワインを取出して能書きを並べた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マツシーマーア、カデンーノーオー、センキーンーンタン」というふうに全く同じ四拍子アンダンテの旋律を繰り返しながら、だんだんに薬の効能書きを歌って行くのである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事その物よりも、意味付けや能書きに過度に傾いてしまい勝ちな性格が災いして、「プログラミングを体験した」という程度以上には、私の技術は進歩しませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにをしていいかは、個々のテキストについた能書きを読んでほしい。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "能書きは作家に言わせておくとして、出版社に必要なのは市場が今、何を求めているかを素早く察知する力だろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "誕生当時、パーソナルコンピューターは「情報処理の能力を個人に解放する」、「より良く生きるために、より自由に、より深く考える道具を提供する」という能書きを引っ提げ、大見得を切って登場した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら元祖幼形成熟のこの私が、変わって家電戦略に秘めたアップルの志を深読みしてあげましょう」と妄想をたくましくしても、かつて哀愁の高田馬場で思い込みの鬼と呼ばれたこのオレにも、算盤勘定以外、アップルの家電戦略の能書きはさっぱり見えてこないのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの新しい空間をテーマとして、電脳社会論という能書きをドドーンと垂れてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "能書きはおおむね、てなことになる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぱんぱんとたちまちかぎつけてめえりますから、お待ちなさいよ……」　いったかと思うと、伝六自慢の一つ芸、能書きにうそはない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが証拠に、太夫が唐人語を使って踊りを踊りますから、だまされたと思って、二文すててごらんなさいよ」　得意になって口上言いが能書きを並べだしたものでしたから、それにつられて、あたりの者がどやどやと六、七人木戸をくぐりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、まことや口上言いの能書きどおりなのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問がなきゃなかなか書けるもんじゃねえんですよ」「能書きいわなくともわかっているよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴公もこれが御入用かな」「能書き言うなッ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、買うとき味なせりふをぬかしやがってね、こういうものは人まかせにすると、気に入ったのが手にへえらねえからと、さんざんひねくりまわして買ってけえったといやがったからね、能書きをぬかしたところをみるてえと、いくらか名人気質の野郎かなと思って探ってみたら――」「桃華堂の無月だといやしねえか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかでも桃華堂はことのほか偽作がじょうずとかいう評判だから、もしかすると野郎じゃねえかと思っていたやさきへ、おめえがいま京金襴を買い出しにいって能書きうんぬんといったんで、名人気質のやつならてっきり野郎とホシがついただけのことさ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "能書きはあとにして、急所だけてっとり早く話したらどうだ」「ところが、そいつがくやしいことにはおあいにくさま。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなの一枚看板がむっつり屋であるように、あっしの能書きたくさんもみなさまご承知の金看板ですからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "用があるならひとっ走りいってめえりますが、にんにく灸の百両ほども買ってくるんですかい」「能書きを聞いてくるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "能書きはあとにしろ」　にらみつけて奥へ通ろうとしたのを、「お待ちなされよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ「日本はソフトウエア産業に弱点を持っており、こうした面でも競争力を養っていかなければならない」といった能書きにくっ付いてきそうな官製産業政策のピントのずれ具合には、こうしたエピソードやのちに触れるタイニーベーシックの手作り運動の経緯を振り返るたびに愕然とさせられる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ベーシックを学べば、必要なプログラムは自分で書くことができる」という能書きに、決定的な嘘があったわけではない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と向いあった往来の向い側には、古着屋が店を開いており、その隣には袴を穿いて口鬚をはやした、大分もう年をとった一人の男が、オットセイの黒焼きだとか、蘇鉄の果だとか称している、えたいの知れないものを台の上にのせて、演説口調で何か能書きを並べたてていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もんは効能書きを讀んで、小指で糊をすくひ、ほんの少しなめてみた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これは僕の友だちに聞いた能書きだがね、そいつがやり始めた缶詰だよ。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、光ったりっぱな容器の中にはいって、ちゃんと効能書きがついている。",
              "citation": {
                "source": "手風琴",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩永健著『ロツチエの研究』とか云ふのは、長々しい効能書きを書きそへて定価一円七十銭で販売致しますと出て居る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "能書きを聞いたのはこれが初めてじゃない。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは朝の太陽というわけでこの束の間の夜から朝へのうつりかわり、きのうがきょうになるなりかたには不思議な感動を与えられる。",
              "citation": {
                "source": "モスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
