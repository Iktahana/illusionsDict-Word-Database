    "definitions": [
      {
        "index": 1,
        "gloss": "thrust at the opponent's throat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
