      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to get on (train, plane, bus, ship, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "随分愛想のいいその男が、汽車に乗るや間もなく眠つてしまつたことは、なんとなくその夜学二年間の総計のやうな気がされて淋しいやうでないこともない。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場はそれから近くだつたのだが、とても直ぐ電車になぞ乗る気にはなれなかつたので、ともかく私は次の駅まで、開墾されたばかりの、野の中の道を歩くことにした。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　電車に乗る時だつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る馬車も／＼皆満員となりて乗る折もなし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし六時の急行に乗る積りなれば落付いて眠る間もなかるべしと漱石師などへ用もなき端書したゝむ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜松にては下りる人乗る人共に多く窮屈さ更に甚だしくなりぬ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山越しに木曾路へ出て、汽車に乗るとすれば、トンネル又トンネルがあつて、この温気に、土竜のやうに、暗の窖を這ひ、石炭の粉の雨を浴びなければならない。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に小さな汽船の艫の方などへ乗ると、縦横に揺り上げ揺り下ろされる。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだ、この不景気に乗るような唄をこしらえて見ては。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹屋の渡しを渡船に乗るときには年下の方が柚木に「おにいさん、ちょっと手を取って下さいな」と云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝七時八分青森行に乗る。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま停まる停車場に下りる人もなければ乗る人もない。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五稜郭行というバスを見かけて乗る。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の声はやはり唄三味線の絃の音色に乗るように練習して来たものである。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗客の人種が自分のいつも乗る市電の乗客と全くちがうのに気がついて少し驚いた。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車に乗ると大抵満員――それが日本特有の満員で、意地悪く押されもまれて、その上に足を踏みつけられ、おまけに踏んだ人から「間抜けめ、気を付けろい」などと罵られて黙っていなければならなかった。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々子が菓子ほしい時に、父は必ずだっこしろ、だっこすれば菓子やるというために、菓子のほしい時彼はあっこあっこと叫んで父の膝に乗るのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私の実の楽しみは、軽便鉄道に乗ることの途中にあった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「俺ァ駿河の国は有度郡清水港の長五郎だ」　次郎長の背後の二人が名乗る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分達者で……」　サッと駕籠に乗る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝附近――元の場所　逃げて来た仲蔵は、其処に待って居た駕籠に乗る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はマルセーユから催眠酒をのまされたような意識を失って近東行の急行列車に乗ると昏々とマホガニイの寝台でフロレンス辺まで吊されていたらしいのだ。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミサコは通りがかりのタクシーに乗るとカブト町に向って車を疾走さしていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　自動車に乗ると清三は両親にそう云った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山村水廓の民、河より海より小舟｜泛かべて城下に用を便ずるが佐伯近在の習慣なれば番匠川の河岸にはいつも渡船集いて乗るもの下りるもの、浦人は歌い山人はののしり、いと賑々しけれど今日は淋びしく、河面には漣たち灰色の雲の影落ちたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "航空者特に自由気球にでも乗る人はこの事実を忘れてはならない。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んで立っていた若い会社員風の二人連れが話しているのを、聞くともなく聞いていると、毎朝同じ時刻に乗る人がみんなそれぞれ乗り込む車の位置に自ずからきまりがあると見えて、同じ顔が同じところにいつでも寄り合うようだと云っていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばわれわれが毎日電車に乗る度に、私が日比谷で見たような場面を見せられるとしたらどうだろう。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隊長は、兵卒を橇にして乗る訳には行かなかった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、門司から御用船に乗る際、同様にビラを拾っていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
