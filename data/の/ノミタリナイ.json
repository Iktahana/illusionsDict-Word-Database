      {
        "index": 1,
        "gloss": "not having had enough to drink (esp. alcohol)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
