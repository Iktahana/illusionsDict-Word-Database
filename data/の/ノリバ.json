    "definitions": [
      {
        "index": 1,
        "gloss": "place for boarding vehicles",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
