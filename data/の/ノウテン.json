[
  {
    "uuid": "2e735daa-afe7-5122-ac8a-0f317567ff47",
    "entry": "脳天",
    "reading": {
      "primary": "のうてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
