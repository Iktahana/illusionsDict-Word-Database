    "definitions": [
      {
        "index": 1,
        "gloss": "to change (buses, boats, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分の魂の一部分あるいは全部がそれに乗り移ることなのだ」　喬はそんなことを思った。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音源はお園からは十メートル近くも離れた上手の太夫の咽喉と口腔にあるのであるが、人形の簡単なしかし必然的な姿態の吸引作用で、この音源が空中を飛躍して人形の口へ乗り移るのである。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌が街頭へ飛び出して自動車のおやじから乗客の作曲家に伝染し、この男が汽車へ乗ったおかげで同乗の兵隊に乗り移る。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これが元来空想的な傾向を有つシャクに、自己の想像をもって自分以外のものに乗り移ることの面白さを教えた。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで皆が大型の方へ乗り移ると、ぼうと汽笛が喚く。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "数人の人が舟へ乗り移るような物の気配がして舟が重くなったが、別に人の姿は見えなかった。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、二度目には、ひらりと軽く乗り移ると同時に、車輪は静かにすべるように動きだした。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船から車に乗り移るころにようやく朝日が上って、ほのかに見ることのできた源氏の美貌に入道は老いを忘れることもでき、命も延びる気がした。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは鹿を描いて、その表情に人間的なものを打ちこむといふこと、古い形容でいふ『対象に乗り移る――』といふことは、飼育してゐる化物位ではやれる仕事ではない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそれに乗り移る時汚物によごれた婦人客の有様など、見て居られなかった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "末次郎　あんなかたりの女子に神さんが乗り移るもんですか。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、彼らは本船へ乗り移るときに、彼らにとって生命よりも大切な大小を捨てている。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり絵の中の気分が、こっちへ乗り移るのだね。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動女優の表情はいつしらず彼女達に乗り移る。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は髢を取って元の舟へ乗り移ると、人も舟もやがて波間に隠れてしまいました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、科学の重力はおのれをかくまで発達せしめたその民族の虚に乗じ、これを押し潰して滅ぼすや否や、直ちにこれを奪った他の民族に乗り移る忘恩を決行する。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓練ある沈黙と速度のうちに一同がそれに乗り移ると、そのままボウテは漕ぎ出して、碇泊中の船影のあいだを縫って間もなく沖へ消える。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓練ある静寂と速度のうちに、一同がそれに乗り移ると、そのままぼうては漕ぎ出して、碇泊中の船影のあいだを縫って間もなく海へ消えた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等運転士のハウオウスがイサドル・ストラウス夫人にボウトに乗り移るように奨めると、夫人は断乎として拒絶して、「ストラウスの傍を離れるのは嫌です。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリップスとブライドに直ちに無電室を出て最後の救命艇に乗り移るように命じたが、船長が立ち去ると同時に、フィリップスは再び聴取器を掛けて又ＳＯＳを打ち始めた。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一礼してそれに乗り移る。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十人のものは本堂の縁から駕籠に乗り移る。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロッコは三人が乗り移ると同時に、蜜柑畑の※を煽りながら、ひた辷りに線路を走り出した。",
              "citation": {
                "source": "トロッコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と船に乗り移る間ぎわにも、銭占屋はそのことを誓った。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは面白いな、遠慮なく乗り移るがいい。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂が『乗り移る』とか『取り憑く』とか『生れ変る』とかいう事実は、その本人の『心理遺伝』の作用以外の何ものでもないというのが、吾輩の学説の中でも、最重要な一箇条になっているんだからね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロツコは三人が乗り移ると同時に、蜜柑畑の匂を煽りながら、ひた辷りに線路を走り出した。",
              "citation": {
                "source": "トロツコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "保吉は女と目を合せた刹那に突然悪魔の乗り移るのを感じた。",
              "citation": {
                "source": "あばばばば",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "艀に乗り移ると、霧は降るように濃くなった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵団長に急がされて、みんなそれぞれの持物を持ってボートの中へ乗り移る。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
