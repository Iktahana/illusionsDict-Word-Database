          "literary": [
            {
              "text": "メフィスト「先づ飲助連に紹介しませう、さうすると貴方は必ず此世は至極簡単に渡られるものだと合点するに相違ない。",
              "citation": {
                "source": "喜劇考",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "メフイストフエレス「先づ第一に飲助達に御紹介申しませう。",
              "citation": {
                "source": "ひとりごと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、パツと鞭をあてゝ駆け出したら、あの飲助連中が何んなに吃驚りするでせう。",
              "citation": {
                "source": "馬車の歌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの六平の禿罐も飲助やさかいのう。",
              "citation": {
                "source": "恭三の父",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみすけのおれのことだからべつにやけ酒じゃないのだが、端からみたらそうとれるかもしれぬ。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            }
          ]
        }
