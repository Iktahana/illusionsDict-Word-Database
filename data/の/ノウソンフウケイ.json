        "examples": {
          "standard": [
            {
              "text": "絵画には、夕暮れ時の美しい農村風景が描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「窓から見える農村風景は、都会の喧騒を忘れさせてくれる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、田園を流れる小川や、緑豊かな田畑が広がる農村風景をスケッチした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "南国の豊かな農村風景に比べてみると凡そ話が違ふのである。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に変テツもない山近い農村風景。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
