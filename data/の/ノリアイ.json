        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "乗合わせた農夫農婦などは銘々の大きな荷物に腰かけているからいいが、手ぶらの教授方以下いずれも立ったままでゆられながら、しきりに大気の物理を論じ合っていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃はもちろん自動車はおろか乗合馬車もなく、また沿岸汽船の交通もなかった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合自動車の轍の地揺れのたびに落ちるマロニエやプラタアヌの落葉。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海へ下る九十九折のピンヘッド曲路では車体の傾く度に乗合の村嬢の一団からけたたましい嬌声が爆発した。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉地からそれらの町へは、いずれも直通の道路があって、毎日定期の乗合馬車が往復していた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝大川　乗合舟。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きしなに、誰れでも外米は食いたくないんだから今度買ってきたら分けあって食べましょうと云って乗合バスに乗った。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪から例の瀬戸内通いの汽船に乗って春海波平らかな内海を航するのであるが、ほとんど一昔も前の事であるから、僕もその時の乗合の客がどんな人であったやら、船長がどんな男であったやら、茶菓を運ぶボーイの顔がどんなであったやら、そんなことは少しも憶えていない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃の工合があまりよくなかったが気分がいいので乗合自動車で銀座へ行った、そして例のように風月へはいってコーヒーを呑んだ。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩釜から小さな汽船に乗って美しい女学生の一行と乗合せたが、土用波にひどく揺られてへとへとに酔ってしまって、仙台で買って来たチョコレートをすっかり吐いてしまった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そよりとも風のない日で、秋の暑さは大川の水にも残っているらしく、向う河岸から漕ぎもどして来る渡し船にも、白い扇や手拭が乗合のひたいにかざされて、女の児の絵日傘が紅い影を船端の波にゆらゆらと浮かべていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて漕ぎ出したときに、御符売りは艫の方に乗り込んだ一人の男を急に見付け出したらしく、ほかの乗合をかきわけて彼の胸倉を引っ掴んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はほかの乗合の手前、おとなしく黙っていられなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの乗合の客も口々になだめたので、御符売りはよんどころなしに手をゆるめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、この二ツの間を、乗合いみたいに往復した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がた／＼の古馬車と、なたまめ煙管をくわえた老馭者は、乗合自動車と、ハイカラな運転手に取ってかわられた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道もそこまでは乗合自動車がやって来た。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその乗合自動車のやって来る起点は、ちょうどまたこの溪の下流のＫ川が半町ほどの幅になって流れているこの半島の入口の温泉地なのだった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ一台の乗合自動車が通りかかった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……下が黒羽二重の紋着と云ふ勤柄であるから、余計人目について、乗合は一｜時に哄と囃す。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに沓掛の駅でおりて星野行きの乗合バスの発車を待っている間に乗り組んだ商人が運転手を相手に先刻トラックで老婆がひかれたのを目撃したと言って足の肉と骨とがきれいに離れていたといったようなことをおもしろそうに話していた。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めてノートルダームに行った日はここから乗合馬車に乗ってまずバスチールの辻まで行きました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば自分の祖母にやさしい言葉をかけるとか、乗合馬車で座席を譲るとかいうくらいな事でもいいが、とにかく何かしないではおかないようにするがいい」という一節がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三輛の乗合馬車が待つて居る。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃高知から種崎まで行くのには乗合の屋形船で潮時でも悪いと三、四時間もかかったような気がする。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その小笠をかなぐって脱いだ時は、早や乗合の中に紛れたのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡場に着くと、ちょうど乗合が揃ッていたので、すぐに乗込んだ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭は未だ到なかッたが、所の壮者だの、娘だの、女房達が大勢で働いて、乗合に一箇ずつ折をくれたと思い給え。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合もそれは目出度と言うので、いくらか包んで与る者もあり、即吟で無理に一句浮べる者もありさ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合に話好の爺様が居て、それが言ッたよ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
