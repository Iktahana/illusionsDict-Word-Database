[
  {
    "uuid": "b67dafd3-9442-5e29-b4a9-370513add2e7",
    "entry": "乗り越す",
    "reading": {
      "primary": "のりこす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
