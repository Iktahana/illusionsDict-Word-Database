[
  {
    "uuid": "a56c7463-ad6d-5600-ae0c-4bf6e07ce042",
    "entry": "惚気",
    "reading": {
      "primary": "のろけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
