        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「のの様、どうか家族の健康をお守りください。」と祈りを捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、悪いことをしたら「のの様が見ているよ」と母に言われたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お祭りの日には、村人がみんなでのの様に豊作を願った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "生きもののさまざまな物音が彼の道を取りまく。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "（伊勢）　　　※ののさまどつち。",
              "citation": {
                "source": "お月さまいくつ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧だの靄だの雲だの虹だののさまざまな変化は容易に見飽きるものではありません。",
              "citation": {
                "source": "身辺打明けの記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、たずねていることがよくわかりましたので、女中は、「坊ちゃんのお母さんは、ののさまになってしまわれましたのですよ。",
              "citation": {
                "source": "遠方の母",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ののさまということも、また、ののさまになれば、空へ上ってしまわなければならぬということも、まだ正ちゃんには、わかりませんでした。",
              "citation": {
                "source": "遠方の母",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり突然の逮捕に驚かされるというようなことがなく、ほかの形勢がきわめて不利のような場合であっても、外見上の無罪宣告を受ける場合につきもののさまざまな努力や焦慮を引受けねばならないと心配する必要はありません。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにでも通用する夜の正装が、外面上、人間的なもののさまざまな変種を、礼儀正しいひといろに総括している。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
