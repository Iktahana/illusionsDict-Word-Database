[
  {
    "uuid": "510fb563-6db3-5d0f-acb2-b20a49a94356",
    "entry": "のめる",
    "reading": {
      "primary": "のめる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to fall forward (of a person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "朝｜一遍田を見廻って、帰ると宅の温かい牛乳がのめるし、読書に飽きたら花に水でもやってピアノでも鳴らす。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を下りて見ると不忍弁天の社務所が池の方へのめるように倒れかかっているのを見て、なるほどこれは大地震だなということがようやくはっきり呑込めて来た。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人ごとに、我が身にうとき事をのみぞこのめる」云々の条は、まことに自分のような浮気ものへのよい誡めであって、これは相当に耳が痛い。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁って、生でのめるようなしろものじゃなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰から上をのめるように前に出して、両手をまたその前に突出して泳ぐような恰好をしながら歩こうとしたのですが、何しろひきがひどいので、足を上げることも前にやることも思うようには出来ません。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒小袖の肩を円く、但し引緊めるばかり両袖で胸を抱いた、真白な襟を長く、のめるように俯向いて、今時は珍らしい、朱鷺色の角隠に花笄、櫛ばかりでも頭は重そう。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだやうになつてゐた数秒、しかし再び意識をとり戻した彼が、勇敢にも駈け出した途端に両手に煉瓦を持つて待ちぶせてゐた一人が、立てつづけに二個の煉瓦を投げつけ、ひるむところをまたもや背後から樫棒で頭部を強打したため、かの警官はつひにのめるやうにぶつ倒れたのだ。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　傍へ来た駅員に、突のめるように、お辞儀をして、「真平御免ねえ、はははは。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の根に躓いて顛倒しそうになっても、にこりともせず、そのまま、つんのめるような姿勢のままで、走りつづけた。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「待て、」　と云ったが、遣手の剣幕に七分の恐怖で、煙草入を取って、やッと立つと……まだ酔っている片膝がぐたりとのめる。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のときから今に至るまで、憐れなもの、その殊に体裁や負け惜しみで隠された人々の自我慾の憐れさ、これに引っかゝるとわたしの気の弱さは一堪りもなく前に突きのめるのであった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだひどい水で」と前のがのめる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　師匠と弟子は走りかかって、左右からかの怪物を取押えると、怪物はのめるようにぐたりと前に倒れた。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日もまた酒のめるかな！",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、彼は起上り、頭を低く下げ、前へつんのめるような恰好で、扉に向って走った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋にいたのはひとりの研究者で、奥の机にのめる恰好で、研究にいそしんでいた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と突のめるように巻煙草を火入に入れたが、トッチていて吸いつきますまい。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら拳固だ、どッこい足蹴だ、おっとその手を食うものか、その内に一人つんのめるね、ざまあ見やがれと、一々｜合点が出来ますだろう。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はひと堪まりもなくそこに突んのめると、男はすぐにその手から小さい風呂敷包みを引ったくろうとした。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "噛み合うように固く胸高に腕ぐみをして、上体をのめるほど前にかしげながら、泣かんばかりの気分になって、彼はあのみじめな子供からどんどん行く手も定めず遠ざかって行った。",
              "citation": {
                "source": "卑怯者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれがために前にのめる。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、日中でもよく何かにつまずいて、のめる程暗い隅に転がったまま、その漁夫がうなっているのを、何日も何日も聞かされた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそこでのめる程酔払ってしまった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ものも云えず、一寸つまずいただけで、そのまま他愛なくつんのめる程疲れ切っていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰ひとりそつちを振向いてゐる者さへなかつたが、私の好奇心は一層深まつたので、兎も角正体を見定めて来ようと決心して何気なさ気に其場を脱けてから、麦畑へ飛び降りるやいなや狐のやうに前へのめると、矢庭に径も選ばず一直線に畑を突き抜いて、彼等の行手を目指した。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰ひとりそっちを振向いている者さえなかったが、私の好奇心は一層深まったので、ともかく正体を見定めて来ようと決心して何気なさげにその場を脱けてから、麦畑へ飛び降りるやいなや狐のように前へのめると、やにわに径も選ばず一直線に畑を突き抜いて、彼らの行手を目指した。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、二十五銭」「ぼく五銭だ」「お茶が一杯ずつのめるね」　二人は笑いませんでした。",
              "citation": {
                "source": "誰が・何時・何処で・何をした",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思った彼は、新世界をぐるぐるまわりながら、酒ののめるところを物色した。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げる奴は何分にも素人の悲しさ、気ばかり焦って体が前へ泳いでいるので、ちょいと蹉くとすぐに突んのめる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも有難うございました」、とのめるように私の床の側に坐りながら、「好かったわねえ」、と私と顔を看合わせて微笑した。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
