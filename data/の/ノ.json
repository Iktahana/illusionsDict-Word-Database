[
  {
    "uuid": "8fa6db9d-05cf-53c4-b9a9-c85375aac132",
    "entry": "乃",
    "reading": {
      "primary": "の",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "助詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "indicates possessive",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "乃ち、東洋芸術の大部が一色であり、雑多あつて多様なき所以である。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち類推はそれが十分に行はれない場合の補助手段である。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ちそれは人為的に増減出来るものではない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乃木大将一代記」なる映画は今以てハツキリと覚えてゐる。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みち、一寸倉に行つて乃木さんの訓言の掛軸があるからあれを持つて来い。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全て本能乃至本能的なるものは、否定すべきものではない。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し序に言ふが、給料はといつたら、それはそれはお話にならないもので、女優の三分の一は十円乃至十五円といふ、彼等の必需品化粧料を買ふさへ出兼る程のそれだつたのである。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃木坂倶樂部十二月また來れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃木坂倶樂部　　乃木坂倶樂部は麻布一聯隊の附近、坂を登る崖上にあり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁舟江心に向かいてこぎ出せば欸乃風に漂うて白砂の上に黒き鳥の群れ居るなどは『十六夜日記』そのままなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、いままた、乃木將軍が、よみがへつて來て居る。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一望千里の滿洲の赤土の原、あかあかと夕燒にてらされ、ひとり馬で歩いて居る猫背の乃木將軍のすがたが、この眼に見えるのだ。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいふ、東郷大將とふたり外遊の折、乃木、かならずその國一のホテルに宿り、手袋、煙草、すべて一流のものをのみ用ゐた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その點では、天下の大野暮乃木將軍も亦、ものの見事に通人の資格あらむ乎。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日服用したら、あと服用を禁止せよ、三日乃至五日間休止して、それからさらに二錠づつの服用を開始せよ、と效能書に書かれて在りましたので、私は、少しも、ききめの無いままに、その藥の服用を、やめなければならなくなりました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "性なきまでに白げられたる、木の骨――というより外に、与える名がない――と、砂に埋まれた楕円石や、稜角の鋭いヒイラギ石やは、丁度、人間の屍骸が、木乃伊となって、木偶か陶製の人物か、区別が見えないと同じように、原性を失って、唯一自然の平等相に復帰している。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尤も、船会社と、船会社から頼まれた海軍だけだったが――　やがて、彼女が、駆逐艦に発見された時、船の中には、「これじゃ船が動く道理がない」と、船会社の社長が言った半馬鹿、半狂人の船長と、木乃伊のような労働者と、多くの腐った屍とがあった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬初め頃迄に小さなスケッチ板へ二三十枚、六號乃至八號の畫布へ數枚を描いた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜物乃至自畫像などは寒い時の爲に保留するといふやうな氣もあつて、暖い内はなるべく題材を戸外に求める事に自然となつてしまつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日乃至十日に雨とか風があることは東洋の諺では自然が順調だといふことになつてゐる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "和名鈔には「顱　和名加之良乃加波長　脳蓋也」とあるそうで「カハラ」は頭の事である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「己」は「意能」、「於能」、「意乃」。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年五月二十五日『東京朝日新聞』）　　　　　　　　　八十三　　　　　　六千年前の肉塊　近頃エジプトの医学校で木乃伊の解剖分析に従事している学者がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木乃伊を作るには始め塩水に死体を漬け種々の樹脂の類を塗って固めたものらしい。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大詰はこちらに案あり）　時節柄大河内で西郷さんか、乃木さんの一代記八千ぐらいにまとめてやればどうやろか。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は官憲の眼をくらますために木乃伊の教訓的な役割をいつまでも演じていたくはないのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、その性質｜如何に拘らず、一｜體人の犯罪｜乃至は祕密を探し尋ねて、それを白日にさらし出すと云ふ事はあんまり好い氣持のするものぢやありません。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の野原を夏の風が行くに煙が去つた情熱の火が突進するブツカルものもなく――だから不可ない昔からあつたものだのに今新たに起つたものだそれを如何して呉れるい横から眺めてゐるな誰の罪でもない必要ぢやない欲しいだけだ",
              "citation": {
                "source": "情慾",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "名詞の換言で日が暮れようアスファルトの上は凡人がゆく顔　顔　顔石版刷のポスターに木履の音は這ひ込まう",
              "citation": {
                "source": "春の日の怒",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に女には今日の表現が明日の存在になるんだ。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
