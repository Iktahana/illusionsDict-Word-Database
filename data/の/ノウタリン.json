        "examples": {
          "standard": [
            {
              "text": "「ちょっと待って、今の説明、全然わからなかったんだけど、私って脳たりんなのかな？」と、彼は頭を掻いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「彼はいつもぼんやりしているから、周りからは脳たりんだと思われがちだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そんなに簡単なことも理解できないなんて、君は本当に脳たりんだね！」と、友人は冗談めかして言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
