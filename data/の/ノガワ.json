    "definitions": [
      {
        "index": 1,
        "gloss": "brook running across meadowland",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夕方に駒込の通りへ出て見ると、避難者の群が陸続と滝野川の方へ流れて行く。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市野川やぐんぐんのぼって行く。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市野川が崖の上のみちを見ている。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市野川やみんながぞろぞろ崖をみちの方へ上って行くらしい。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじさま、奥様、お開けになって、野川さんと御相談下さいまして、暫くのあいだおあずかり下さいまし。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "野川で鰌を突くのであらう。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私も加わり、暫く、黙って酒を飲んで居ると、表はぞろぞろ人の行列の足音、花火が上り、物売りの声、たまりかねたか江島さんは立ち上り、行こう、狩野川へ行こうよ、と言い出し、私達の返事も待たずに店から出てしまいました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だいあれあ、と口々にお祭を意味なく軽蔑しながら、三島の町から逃れ出て沼津をさしてどんどん歩き、日の暮れる頃、狩野川のほとり、江島さんの別荘に到着することが出来ました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕靄につつまれた、眼前の狩野川は満々と水を湛え、岸の青葉を嘗めてゆるゆると流れて居ました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家は、滝野川の中里町にあります。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年六月、東京朝日新聞）　この記事が東京朝日新聞に出たのを見た滝野川の伊達氏が、わざわざ手紙をよこして、チャップリンの文楽見物の事実を知らせてくれた。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――仮装した小按摩の妄念は、その枝下、十三地蔵とは、間に水車の野川が横に流れて石橋の下へ落ちて、香都良川へ流込む水筋を、一つ跨いだ処に、黄昏から、もう提灯を釣して、裾も濡れそうに、ぐしゃりと踞んでいる。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳田さんは、旅籠のあんまに、加賀の金澤では天狗の話を聞くし、奧州飯野川の町で呼んだのは、期せずして、同氏が研究さるゝ、おかみん、いたこの亭主であつた。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡瓜ならば日野川の河童が噛ろう、もっての外な、汚穢うて汚穢うて、お腰元たちが掃除をするに手が懸って迷惑だ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉七　当国には、板取、帰、九頭竜の流を合せて、日野川の大河。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ツ目小僧の豆腐買は、流灌頂の野川の縁を、大笠を俯向けて、跣足でちょこちょこと巧みに歩行くなど、仕掛ものになっている。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　うの花にはまだ早い、山田｜小田の紫雲英、残の菜の花、並木の随処に相触れては、狩野川が綟子を張って青く流れた。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂を挙げて南条に引返し、狩野川を横切った。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　金沢なる浅野川の磧は、宵々ごとに納涼の人出のために熱了せられぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "椹野川にそうて散歩した、月見草の花ざかりである、途上数句拾うた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ立つて山口へゆく、椹野川風景もわるくない、桜冬木、白梅紅梅、枯葦、枯草、ことに川ぞひの旧道は自動車が通らないのがうれしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつては蒲公英の莖を噛みながら、ひとり物思ひに耽つて徘徊した野川の畔に、今も尚白い菫が咲くだらうか。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四国三郎の吉野川が村の中を流れて、村落のあるのはそれに沿った僅かばかりの平地で、高峰駿岳が一面に聳えていた。",
              "citation": {
                "source": "山の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは吉野川の河原であった。",
              "citation": {
                "source": "山の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "螢、淺野川の上流を、小立野に上る、鶴間谷と言ふ所、今は知らず、凄いほど多く、暗夜には螢の中に人の姿を見るばかりなりき。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "建てて数十年を経たる古家なれば、掃除は手綺麗に行届きおれども、そこら煤ぼりて余りあかるからず、すべて少しく陰気にして、加賀金沢の市中にてもこのわたりは浅野川の河畔一帯の湿地なり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜ふかき野川の堰今朝もまた氷張りけり。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらいっぱいこんなにひどく明るくて、ラジウムよりももっとはげしく、そしてやさしい光の波が一生けん命一生けん命ふるえているのに、いったいどんなものがきたなくてどんなものがわるいのでしょうか。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまのがわの　にしのきしを、　すこしはなれたそらの井戸。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、これだけの、小さな小さな「火事教育」でも、これだけの程度にでもちゃんとしたものがわが国の本屋の店頭にあるかどうか、もし見つかったかたがあったらどうかごめんどうでもちょっとお知らせを願いたい。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
