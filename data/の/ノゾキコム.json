    "definitions": [
      {
        "index": 1,
        "gloss": "to look into",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女覗き込むやうにしてみてゐる。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍から三次も覗き込む。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ、何だ」　好奇の顔が四方から覗き込む。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、この子は、こんな処で、どうしたのよ」　肩を揺って顔を覗き込む。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行夫は敏夫を覗き込むやうに頭を曲げ、敏夫は兄の脇腹に手を置き添へすや／＼と眠つてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして船頭に渡賃を云われて小銭を船頭の掌に渡すあの子は、もう一度船頭の掌の中の小銭を覗き込むだろう。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "臺所から縁側に出て仰山に覗き込む細君を「これ平民の子はそれだから困る……食べものではないよ。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泣いちゃ判らんよ」　鶴雄は乾いた声を不安そうに出しながら、「――二階のお客さんに泣かされたのか」　鈴子の顔を覗き込むと、「ううん」　と、可愛いい首を振って。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を閉じさえすれば、霧に曇った硝子窓から覗き込む水夫の顔を見た。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にまわって入れ代り立ち代り昂作の顔を覗き込む子供もあった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が覗き込む要所要所には必ず大小の食もの屋の店先があった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日に二十度、わが家の郵便受箱を覗き込む売れない作家を、嘲っている人の為せる仕業にちがいない。",
              "citation": {
                "source": "悶悶日記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｋは少女のように無心に笑って、私の顔を覗き込む。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども女は、私にむかって叮嚀にお辞儀をして、私の顔を斜に覗き込むようにしながら、ごめん下さいましい、とまた言った。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と云うのを、聞かない振でさっさと引込もうとしたので、「あれ、お待ちなさい」と、下〆をしたばかりで、衝と寄って、ブラッシを引奪ると、窓掛をさらさらと引いて、端近で、綺麗に分けてやって、前へ廻って覗き込むように瞳をためて顔を見た。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこれから橋を渡ろうという時、向うの袂へ、十二、三を頭に、十歳ぐらいのと、七八歳ばかりのと、男の児を三人連れて、その中の小さいのの肩を片手で敲きながら、上から覗き込むようにして、莞爾して橋の上へかかって来ます。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と人が変ったようなおどおどした口調で言って、私の顔を覗き込む。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は起上がって、隣に寐ておられる師父の顔を覗き込む。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都は常に多くの漫遊者を扱ひ慣れて居るから、旅人として向ふに氣が付かせずに、その横顏を覗き込むといふことは出來ない。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑ったかと思うと、今度は態とのように暗い障子の方を向き、最も不利な光線を、鏡の背後に廻して、苦々しく眼のなかを覗き込む。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて助教授宮坂は日本人的のぎこちない真面目な顔付きでガルスワーシーを覗き込むようにしながら氏の近作「銀の匙」と「白鳥の歌」に就いて発言しようと口を切った時、玄関へ一団の訪問客の押しかけて来たけはいを感じて言葉を切った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりおり岩菊の蕊を覗き込む、　蟻の黒い大きな触角が動く。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女がわたしの机の前に立って、わたしの書いている紙の上を覗き込むようにじっと眺めていると、不思議にわたしの筆の運びがにぶくなって、頭もなんだか茫として、何を書いているのか自分にも判らなくなって来る……。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが此の家の先祖代々の墓なのだが、其の横を通つて、薄暗い家の中を覗き込むと、誰もゐない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがこの家の先祖代々の墓なのだが、その横を通って、薄暗い家の中を覗き込むと、誰もいない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが中野学士の背後から覗き込むようにして、何かヒソヒソ囁やいている様子であったが、やがて返事を催促するかのように中野学士の肩に両手をかけてゆすぶった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞き咎めた翁はアシライの手をピタリと止めて、皆の顔を覗き込むように見まわした。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉はやゝ安心したので歩きながら延びあがるやうにして、土手越しに別荘の内を覗き込むやうにした。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生があるかね、」「ございます、」「では、生を一杯貰はふか、」「はい、」　洋服の女はそのまゝ引ツ返して左の壁の方に寄つた窓の口へ行つて、覗き込むやうにして、「生を一杯、」　と云ふと、中から洞穴の中からでも響いて来るやうなしめつぽい声で返辞をした。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は背のびをして、紙幣の数をのぞきこむと、「まあ――」と云って笑った。",
              "citation": {
                "source": "シルクハット",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
