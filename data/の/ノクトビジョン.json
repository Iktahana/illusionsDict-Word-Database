        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ノクトビジョンを働かしているか」　望月大尉から山岸中尉への注意だ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノクトビジョンとは、暗黒の中で、物の形を見る装置だ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉眼では見えないが、赤外線をよく感ずるノクトビジョン装置で見れば、まるで映画をみるようにはっきり物の形がわかるのである。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の目は、テレビジョンの上にある、楕円型のノクトビジョンの受影幕に注意力をむけている。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノクトビジョンを左右へ振って、前方を注意しているが、なにも見えない。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まではノクトビジョンでなければ、姿が見えなかった一号艇が、まぶしいほどはっきり姿を見せているのですよ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "念のためにノクトビジョンでのぞいてみたが、まったくそのとおりだ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
