[
  {
    "uuid": "31aa08d8-1252-5b68-af38-3f7f22c20ab4",
    "entry": "納涼",
    "reading": {
      "primary": "のうりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
