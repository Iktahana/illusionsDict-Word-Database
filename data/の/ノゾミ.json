    "definitions": [
      {
        "index": 1,
        "gloss": "Nozomi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかすがにのぞみのみにて、拱きて、そがのぞみに圧倒さるる。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなしきものまにや、のぞみうしなひ、いつさいより靈智うしなひ。",
              "citation": {
                "source": "偏狂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われらひとしく丘に立ち〕宮沢賢治われらひとしく丘に立ち青ぐろくしてぶちうてるあやしきもののひろがりを東はてなくのぞみけりそは巨いなる塩の水海とはおのもさとれども伝へてきゝしそのものとあまりにたがふこゝちしてたゞうつゝなるうすれ日にそのわだつみの潮騒のうろこの国の波がしらきほひ寄するをのぞみゐたりき",
              "citation": {
                "source": "〔われらひとしく丘に立ち〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の娘だって容貌のぞみで大名の御部屋様にもなれねえとも限らねえが、それなら又そのように打ち明けて召し抱えの相談もありそうなもんだが、少し理窟が呑み込めねえな」と、半七はしばらく考えていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあれひんがし一つらの、　　　　　うこんざくらをせなにして、所長中佐は胸たかく、　　　　　　　野面はるかにのぞみゐる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稔らぬなげきいまさらに、　　春をのぞみて深めるを。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石沙無人の境の、家となり、水となり、田となり、村となつた、いま不思議な境にのぞみながら、古間木よりして僅に五｜里、あとなほ十｜里をひかへた――前途の天候のみ憂慮はれて、同伴に、孫引のもの知り顔の出来なかつたのを遺憾とする。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのぞみなら、まだまだ言えるんですけどね、それよりは、このヴァレリイの本をあなたにあげたほうが、僕もめんどうでなくていい。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはみな霜を織ったような羅をつけすきとおる沓をはき私の前の水際に立ってしきりに東の空をのぞみ太陽の昇るのを待っているようでした。",
              "citation": {
                "source": "インドラの網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱鳴り瓦飛び壁落つる危急の場にのぞみて二人一室に安座せんとは。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果として起こってきた文化なるものは、あるべき季節に咲き出ない花のようなものであるから、まことの美しさを持たず、結実ののぞみのないものになってしまった。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの　路次を　抜けさへ　したらば、　　抜けさへ　したらと　ほのかな　のぞみだ……いやはや　のぞみにや　相違も　あるまい？",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、それをわたくしはのぞみます。",
              "citation": {
                "source": "マリヴロンと少女",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "引かれて、やがて蔭ある処、小川流れて一本の桐の青葉茂り、紫陽花の花、流にのぞみて、破垣の内外に今を盛りなる空地の此方に来りし時、少年は立停りぬ。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには、小田のところへ行けば、もしかしたら、鶴雄の消息がきけるだろうという、淡いのぞみもないわけではなかった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "のぞみどおり材料をもらうと、はた織りには使わず、またからのままで織るふりをしつづけました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、ともかく、きみののぞみもなかば達せられるわけだ。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんが重い病気で、もう、たすかるのぞみがなかったのですからね。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "のぞみ通りにしてやるからまっておれ」　と云ううちに消え失せました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小さい太郎は、のぞみを失ひませんでした。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもまだ松吉はのぞみを棄てませんでした。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのぞみどおり　博士は莞爾と笑いました。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも博士は、意に介しなさることなく、酔客ひとりひとりに、はは、おのぞみどおり、へへへへ、すみません、ほほほ、なぞと、それは複雑な笑い声を、若々しく笑いわけ、撒きちらして皆に挨拶いたし、いまは全く自信を恢復なされて、悠々とそのビヤホールをお出ましになりました。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえがいなくなってから、すべてが、よろしく、すべてが、つまり、おのぞみどおりだ。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、いま、万事が、おのぞみどおりなのだからね。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
