          "literary": [
            {
              "text": "ポルチコ型の玄関先へ乗り付けると、私はその屋敷を正面から見やった。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二の二　三四郎は、しばらく先生の後影を見送つてゐたが、あとから、車で乗り付ける人が、下足の札を受け取る手間も惜しさうに、急いで這入つて行くのを見て、自分も足早に入場した。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人が白昼自動車でのりつけるなんて。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さんはトラックをのりつける。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
