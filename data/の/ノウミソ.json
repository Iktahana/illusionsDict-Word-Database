        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「脳みそだけじゃない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしでも脳みそがあるなら、考えてみろ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだって君は、脳みそを半分｜抜き取られた兎みたいな顔をしているのですね？",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "有閑なブルジョア・インテリゲンチアらしく脳みそは一秒間にどれだけ沢山のものを連想し得るかを暇にまかせて追求し主観の転廻のうちに実現と美を構成しようとしたのが「水晶幻想」であった。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――獸のように四つ足を突いて首を前に出していては、到底重い脳みそを頭の中に入れておられるはずのものでない。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは脳みその焼いたのだよ。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは腐った脳みそが入っている。",
              "citation": {
                "source": "山と雪の日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みみずの脳には少ししか脳みそがはいっていない」「それはデマ（うそっぱち）だ※」と言いたいのだが残念ながら本当だ。",
              "citation": {
                "source": "みみず先生の歌",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もっと沢山脳みそさえありゃ、学校へ行けるんだ※",
              "citation": {
                "source": "みみず先生の歌",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人とも、あたまを、どこかかたいかべか、器械にぶっつけ、脳みそを出して、死んでしまったのであろうか。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "脳みそに、さわっちゃった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣きながら、彼は、脳みそで、べとべとになったじぶんの手を、鼻さきにもっていった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの脳みそは、林檎の匂いがするぞォ！",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、このように脳みそが、はみだしてしまっては、おどろいたって、もうおそい。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じぶんの脳みそを、なめちまえ」　ひどい奴があったものである。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの脳みそは、まるで、おしつぶされた林檎みたいだ」　といったが、林檎の味がするのも道理である。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、じぶんの脳みそとばかりおもって、じつは、じぶんのあたまの下におしつぶした林檎を、指さきにとって、一生けんめい、うまいうまいと、なめていたのである。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやッ、こんなところに、おれの脳みその塊が、落っこってらあ」　脳みその塊ではない。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは林檎であって、脳みそではない。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "』あとにあわれな　町の人、どうにか子どもを　とりかえす、工夫に脳みそ　しぼったが、影もかたちも　行方がしれず、泣けどくやめど　かいはない。",
              "citation": {
                "source": "魔法の笛",
                "author": "ロバアト・ブラウニング",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも、脳みそをしぼって考えてるんだが、するといろんな手が浮ぶね。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白さに、ぼくの目はすいつけられ、ぼくの脳みそは催眠術にかかったようになる。",
              "citation": {
                "source": "かき",
                "author": "УСТРИЦЫ",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどり色の光の輪と影が、また動きだして、ワーリカの半びらきの、じっとすわった眼へ這いこむと、はんぶん寝入った脳みそのなかで、もやもやした幻に組みあがる。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどり色の光の輪と、ズボンやお襁褓の影が、ゆらゆら揺れて、彼女に目くばせするうちに、またもや彼女の脳みそを占領してしまう。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどり色の光の輪も物影も、だんだん消えていって、もはや彼女の頭へ這いこんだり、脳みそを曇らせたりするものはない。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべは十時に床へはいって、けさ九時に目がさめたが、あんまり寝すぎたもんで、脳みそが頭蓋骨に、べったりくっついたような気がした――とまあいった次第でな（笑う）。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は脳みそに、釘をぶちこまれたような気持だ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたいことに、脳みそだけは、まだちゃんとしている。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのワーニャだの、脳みその腐ったお袋さんだのが喋りだすと、みんな一も二もなく、黙って拝聴するが、わたしが一言でも口を利こうものなら、すぐみんな白けた顔をするんだ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
