          "literary": [
            {
              "text": "私の健康さの全部のものを作品に捧げつくして、その残りカスが私というグウタラな現身なのだよ、と誇示し得ないこともないのである。",
              "citation": {
                "source": "わが精神の周囲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "残りカスみたいになっちまって――ヘヘ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もちろん或る意味で既成の新劇の中から育って来たために、自分では気づかないでそれの残りカスをまだ身につけているであろう私のようなドラマティストをも叩きつぶす必要があるのならば、諸君から叩きつぶされても、私は、うらみには思わないであろう。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
