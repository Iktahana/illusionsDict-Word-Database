        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "王国の賛沢な偕調が部屋を満たして、アングロサクソンの英諾威人、ケント族の仏伊人、スラブの露墺人、アイオニアンの血族｜希臘人、オットマン帝国の土耳古人等に交って、東洋の黄色な悲劇的な顔が七分の運と三分の運命に対する己惚れをもって、千金を夢みているのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はマダム・レムブルグの家でアングロ・サクソンの英諾威人、ケント族の仏伊人、スラブの露墺人、アイオニアンの血族｜希臘人の商人、オットマン帝国の土耳古人等と夜食を共にするのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "諾威道路に彼の姿が見えなくなると、リー・シー・ツワンは鏡の前でシルクハットをかぶった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はマダム・レムブルグの家でアングロ・サクソンの英諾威人、ケント族の仏伊人、スラブの露墺人、アイオニアンの血族希臘人の商人、オットマン帝国の土耳古人等と夜食を共にするのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれが諾威の家ではと丁寧にことわつてある。",
              "citation": {
                "source": "翻譯に就いて",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はあの諾威人シガーソンの、有名な探険記を読んだかもしれないが、しかしおそらく君はその中で、君の友人の消息については、何物も知るところは無かったろう。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたとわたくしとは只今｜諾威の国境にゐるのでございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくし共｜諾威人は、あのモスコエ島の名を取つてモスコエストロオムと申します。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し潮流最も劇しく、暴風の力これを助長するときは、諾威国の哩数にて、渦巻の縁を距ること、一哩の点に船舶を進むるだに、甚だ危険なるべし。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程諾威では一般にさういふ説が行なはれてゐるが、自分はそんなことは信じないと云つたのである。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも諾威に今生きてゐるだけの漁師の内の、一番の年寄を連れて来て聞いて見ても、あの時のやうな暴風に逢つたものはないだらうと存じます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツを中心にして、ロシア、フランス、スペイン、ベルジユーム、オーストリア・ハンガリイ、諾威、丁抹、さういふ各国の文学がそこに移植せられた。",
              "citation": {
                "source": "ペチヨリンとゲザ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『諾威も瑞典も旅券の査証は要らないんだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "諾威へ帰る兄弟の実業家――これはエクボという不思議な名を持っている。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて諾威クリスチャニアのフィヨルドが私たちを迎えるだろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと諾威のホルテン港へ寄る。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも確かに十五世紀の人物とみえて、びっくりするような大男で、何かしきりに話しかけるんだが、十五世紀にしろ現代にしろ、諾威語は私には少しも通じない。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも馬鹿なやつで、世界じゅう諾威語をしゃべってると信じてるらしい。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "イブセンと言えば、諾威国立博物館本館の階上で、イブセンの書斎を見た。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "諾威から来てどことなく明るい感じのするのは、ことによるとこの人形のせいかも知れない。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "土耳古人にもせるびや人にも諾威人にも波蘭人にも、ぶらじりあんにもタヒチ人にも、そして日本人にも第二の故郷である異国者の自由港。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "君ばかりじゃない、土耳古人もせるびや人も諾威人も波蘭人もブラジリアンもタヒチ人も亜米利加人も――。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "土耳古人もセルビヤ人も諾威人も波蘭人も、ぶらじりあんもタヒチ人も「紳士である」いぎりす人も、「あんまり紳士でない」亜米利加人も――。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イブセンは初め諾威の小さいイブセンであって、それが社会劇に手を着けてから、大きな欧羅巴のイブセンになったというが、それが日本に伝わって来て、又ずっと小さいイブセンになりました。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "経済財務、軍備縮少、社会問題、保健、交通、情報会計等の各部に部長があり、英、仏、伊、日、蘭、波蘭、和蘭、加奈陀、諾威、等の国人より成り、毎週一回二時間位の部長会議を開き、各種の問題を打合せまたは討議する。",
              "citation": {
                "source": "国際聯盟とは如何なものか",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそれが、「ハイムスクリングラ（オーディン神より創まっている古代諾威王歴代記）」にある、僧正テオリディアルの執事そっくりじゃ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、中央にいる諾威人の前砲手、ヨハン・アルムフェルト・ヴィデだけがずば抜けて高く、それから左右に、以前は一等運転士だった石割苗太郎と朝枝、そして両端が、現在はウルリーケの夫――さきには室戸丸の船長だった八住衡吉に、以前は事務長の犬射復六となっているからだった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも一方では、王クローディアスやレイアティズとも関係するばかりでなく、末には諾威の王子フォーティンプラスとも通謀して、ハムレット亡き後の丁抹を、彼の手中に与えてしまうのである。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めの半分はオラーフ・トリーグヴェスソンというノルウェーの王様の一代記で、後半はやはり同じ国の王であったが、後にセント・オラーフと呼ばれた英雄の物語である。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オラーフが「すさまじい音をして折れ落ちたのは何か」と聞くと、エーナールが「王様、あなたの手からノルウェーが」と答えた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
