        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "主役をつとめるノバリーク兄弟とその敵役ショーンブルクの相貌もこの一種特別な感じを強めるもののように思われた。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウステラゴメナ、ノバスカイヤ、フサ河流域であります。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウステラゴメナ、ノバ………何と云つたかな。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さう、ノバスカイヤ、それから何！",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「フーン」小サイ　デンデン蟲ハ、オカアサマデモ　ワカラナイ　フシギナ　トホイ　ソラヲ、ホソイ　メヲ　一パイ　ノバシテ　イツマデモ　ミテ　ヰマシタ。",
              "citation": {
                "source": "デンデンムシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "−−−−−−−−−−−−−−−−−−−−−−−−−−洋画壇時評　三つの展覧会　　　　新進ＮＯＶＡ展　ノバ展の一般的な世評を私は度々耳にしたが、大体この展覧会に就いては「余りパッとしない展覧会だ」といふ評判が多かつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッとしないとか、問題でないとかいふ、批評はノバ展の場合、他の展覧会の評と同一に考へられないもの、造型展あたりに比べても、成程この展覧会は子供つぽいところが多いし技術の叩きあげにも年季がかゝつてゐないし、作品も不揃であることは、認めないわけにはいかない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンデパンダンを何処かで企てゝゐるといふ話もきいたが、今の処ノバあたりでアンデパンダン的意義を極度に発揮して欲しいと思ふ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの際ノバ展辺りでもむやみに油絵具を画布の上に消費することをやめて、絵具を節約して良い絵を描いて出品して欲しい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈スターティング・オーヴァー〉にしても、〈ウォチング・ザ・ウィールズ〉にしても、〈ノバディ・トールド・ミー〉にしても、たまらん」「それに、〈グロウ・オールド・ウィズ・ミー〉だ」「それをいおうと思ったんだ」　ワンテンポおいて、慶一は、呆れたように高志を見た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレカラ、君チャンハヨナカニ目ヲサマスト、ブルブルフルエナガラ、何ンダカオッカナクテ、オ母ッチャトコエモ出セズニ、ソート手ダケヲノバシテヤッテ、ユスルノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "イソイデ、オ母ッチャノ方ニ手ヲノバシテヤッテ、ヨナカニコエヲ出スノガオッカナイノデ、ハジメダマッテユスッテイタガ、オ母ッチャハナカナカ目ヲサマサナイノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガ、オツウヤノバンニ、キテイタ人ガオソクナッテカラ目ヲサマシテミルト、ホトケサマノ前ニソナエテイタモノガ、ドレモコレモ一ツノコラズナクナッテイタコトガ分リ、大サワギニナッタノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　ホフマンの作やノバリスの作に、猟奇小説、探偵小説の味のあることは云う迄も無い程である。",
              "citation": {
                "source": "他界の味其他",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオン着任当時、マッセナはゼノバに於ける（ゼノバは当時中立で海岸道不良のため同地は仏軍の補給に重要な位置を占めていた）外交を後援するため、一部をボルトリに出していたのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在カタカナガ一般ニ使ワレテイルノハ数学書、法律書、官報、軍関係ノ書類ナドデアルト思ウガ、イズレモ最モ正確ヲ期セナケレバナラヌ種類ノモノバカリデアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ワズ右手ヲノバスト手ニ何カ堅イ物ガサワッタノデ夢中デ要之助ノ顔ヲナグリツケマスト彼ハ『アッ』ト云ッテ倒レマシタ。",
              "citation": {
                "source": "夢の殺人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一方でコンピューターの設計に関する勉強を独学で続けていたウォズニアックにとって、データジェネラル社のミニコンピューター、ノバ★は当時、あこがれのマシンだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テネットが倒産して当面の仕事を失ったウォズニアックは、ノバを手本にしてコンピューターの自作を試みた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★ＤＥＣでＰＤＰ―８を設計したエドソン・デ・カストロは、同社を離れてデータジェネラルを設立し、一二ビット構成のＰＤＰ―８を一六ビット化してノバを開発した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パネルに安っぽいトグルスイッチとランプを並べたデザインは、アルテアのルーツを思わせるそっけない作りだったが、ノバは当時としてはきわめて速かった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルトのハードウエアの開発にあたって、パロアルト研究所のエンジニアはノバのＣＰＵの命令セットにもとづき、これを大幅に強化する道を選んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『トランジスタ技術』はマイクロコンピューターの大々的な特集を組み、ミニコンピューターのノバを使ってきた電気通信工学科でも、いち早く仕入れてきた８００８を使って、安田助教授が手作りコンピューター試作一号機に取りかかっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつぎにあるは英国少年ゴルドンで、そのつぎは米国少年ドノバンで、最後に帆綱をにぎっているのは、黒人モコウである。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士男は十五歳、ゴルドンは十六歳、ドノバンは十五歳、モコウは十四歳である。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だいじょうぶか、ドノバン」　富士男は暗のなかをすかして見ながらいった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だいじょうぶだ」　ドノバンの声である。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう夜が明けないかなあ」　ドノバンがいった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たおれたッ」とドノバンがさけんだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
