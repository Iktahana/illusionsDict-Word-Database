    "definitions": [
      {
        "index": 1,
        "gloss": "Siberian rubythroat (Luscinia calliope)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浅野駒吉君『旭農場』草と樹木のもつ魅惑がでゝゐて好きだが余り硬化せずに色調などもつと自由な境地にゐて欲しい、『ダリア』の方はこなれてゐない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "（笑ひながら反対側の入口から去る）入れ代りに、浜野駒江（五十ぐらゐ）が、玄関の方から顔を出す。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としどろもどろのごまかし方をして、「ところで、おれにその藥を少しゆづつてくれないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆の先を紙になすりつけ、それが数尾のごまめを表わし得て生動の妙を示したところで、これはあまりに職工的なあるいはむしろアクロバチックの芸当であって本当の芸術家としてむしろ恥ずべき事ではあるまいか。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でもごまかして、他人のごまかしまで略奪して生きてゐるで無えか。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としどろもどろのごまかし方をして、「ところで、おれにその薬を少しゆづつてくれないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさに、うまい嘘も思い浮ばず、「あちこち、あちこち」　と言い、「皆、めしはすんだのか」　などと、必死のごまかしの質問を発し、二重まわしを脱いで、部屋に一歩踏み込むと、箪笥の上からラジオの声。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もうイーチャン打って、ずるずる時間を延ばすことが、この際のごまかしだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごまかしの元祖はフランス人だよ。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "タコ坊主のようなおっさんがちっぽけな座布団一枚を大広間ほどにも使い、目をむき、体を捩り、時には背筋をぴんと伸ばして落語を繰るのに初めて（情けないことに）テレビで触れたときは、へそのごまが飛び出すほど笑った後で、オレは枝雀を知らぬ田舎者として過ごしてきた我が半生を呪った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィクションというよりは、ただ、仮名を用いる程度のごまかしなのですから。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどまた戦争に負けたからと言って、大いそぎで一時のがれのごまかしを捏造して、ちょっとうまい事をしようとたくらんでいる政治家など無ければ幸いだが、そんな浅墓な言いつくろいが日本をだめにして来たのだから、これからは本当に、気をつけてもらいたい。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "功利性のごまかしで、うまく行く筈はないんだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこれは結局一種のごまかしで一種の観念論だ。",
              "citation": {
                "source": "運命と人",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもあれらの何処までが私の夢であつたか、或ひは夢と云ふのは私のごまかしであるか――それを判別すべく、焦れた酒の香に酔ひ痴れたまゝの私の頭では、少くとも明日を待たねばならなかつた。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "意味の解らぬやうなことを云ふのも、悶々たる時のごまかしにはなりませうがね。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの女中は何か自分にしくじりがあって、急に暇を出されるような事になったので、そのごまかしにいい加減なでたらめを言うのだ。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山のごまがきいたと見えて、氣分がさつぱりした……』などと言つてゐるに拘はらず、次第にその體のやつれて行くのを目にした。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしイタリーの映画監督が諸事情を無視して本当に現実のリビヤの生活、そこで有形無形にもみ合っている白い皮膚と黒い皮膚との利害の対立とを描いたならば、沢山のごまかしとロマンティシズムから脱出した脱出映画が作られたであろう。",
              "citation": {
                "source": "イタリー芸術に在る一つの問題",
                "author": "――所謂「脱出」への疑問――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スターリングラードが六台の土鋤機を欲しているときに、世界は一個のごまかしの賞牌をその胸に飾ったのである」と。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "網野菊の正直なよろこびは、その後うつりかわってこんにちに及んでいる日本の民主化のごまかしとすりかえの甚だしさに対して、どんな内心の憤りを表現しようとしているだろうか。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼は当時の自分の力では打ち破ることの出来なかった周囲のごまかし、小市民の毒によって、少なからず制約されている。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことにこそ、人民の要求のごまかすことのできない力が示された。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人民生活のごまかしようのない逼迫は、あらゆる女性の問題を、むき出しに社会問題として、半封建の特権者によって行われているファシズムへの傾きをもつきょうの政治の破綻としてわたしたちの毎日にほこさきを出しているのである。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのごまかしにだが、「学術上では、猿が人間に進化したと申すそうですが、ここのお話は虎が猿になりました」「いや、君の動物まね声にもなってありがたいよ」と、主人は答えた。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "林田は、実に剛情な女だと云つて怒つた顔をしていたが、それは実は咄嗟のごまかしで、彼はやすを訊問すると称してあの部屋でさし向いになり、厳重にくり返しくり返し十七日の午後の警告を説いたにちがいない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで議長のごま塩ねずみが仲間からえらばれて、ここのお寺の和尚さんの所へ行って、もう一｜度猫に綱をつけてもらうように頼みに行く役を引き受けることになりました。",
              "citation": {
                "source": "猫の草紙",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧さんの持っている木箱にはさつまあげ、鮭のごまふり、鯛の飴干し二人は同じような笑いを感受しあって日本橋に立ちました。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――明日は明日の風が吹くから、ありったけのぜにで買って送りましょう……小僧さんの持った木箱にはさつまあげ、鮭のごまふり、鯛の飴干し二人は同じような笑いを感受しあって日本橋に立ちました。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "―明日は明日の風が吹くから、ありつたけのぜにで買つて送りませう……小僧さんの持つた木箱にはさつまあげ、鮭のごまふり、鯛の飴干し二人は同じやうな笑ひを感受しあつて日本橋に立ちました。",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
