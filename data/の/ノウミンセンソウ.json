          "literary": [
            {
              "text": "一九〇八年に発表した版画の連作「農民戦争」で、ケーテ・コルヴィッツは「ヴィラ・ロマナ賞」を獲得した。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしイデオロギーがそういうものならば、なる程彼の云う通り、農民戦争や宗教改革に於ては、イデオロギーなどは無かったに相違ない＊。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "部分的にドイツの農民戦争などを研究はされているけれど。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民戦争（1524-26）が始まらなければそうだったかも知れない。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
