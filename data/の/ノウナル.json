    "definitions": [
      {
        "index": 1,
        "gloss": "to be lost (e.g. luggage)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "貧乏したら石油まで早よ無うなる。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで洗濯石鹸を揉むようで……その水を汲み換え汲み換え泡の影が無うなるまで揉みました奴の三杯酢を肴にして一杯飲もうモノナラその美味さというものは天上界だすなあ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれぢや今に作るものが無うなるやらうと、人事ながら氣になるんぢや。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪所の裏が百姓｜家で、牛のうなる声が往来まで聞こえる、酒屋の隣家が納豆売の老爺の住家で、毎朝早く納豆納豆と嗄声で呼んで都のほうへ向かって出かける。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすればお客人の遠慮がのうなる。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんともなけりゃ、これから往て、湯に入って来た」「あい」「おそうなったら、湯がきたのうなる、はやいがいい」「あい」　お種は土間へおりて手拭竿から手拭を執り、糠袋を持って表へ出た。",
              "citation": {
                "source": "蟹の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "児は星の下で仔犬のうなるような声をして泣いていた。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お犬のうなる声ほど物凄く恐しきものなし。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の老朽教師の低い蜂のうなるような活気のない声にくらべては、たいへんな違いである。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時ごろから日没前までの間、蜂のうなるような声はつねにこの家の垣からもれた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、気がついて見ると、私の耳のそばで虻のうなるような音が聞えました。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜風が街道を吹きはらっていて、電柱のうなる音がしていた。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "・考へる人に遠く機械のうなる空・筍を掘るひそかな筍　四月二十日雨、曇、そして晴、私の気分もその通り。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "六｜人の武士が縁側に上がって待っていますと、やがて雷や稲光がしきりに起こって、大風のうなるような音がしはじめました。",
              "citation": {
                "source": "大江山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しんとした死の国のような静寂の中で、屋根のスレートを叩いている雨と、煙突に風のうなる音が聞えるだけであった。",
              "citation": {
                "source": "自責",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋をわたれば葭町の花柳場があり、いんしんな人形町通りがあり、金のうなる問屋町にとりまかれて、うしろには柳橋がひかえている。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽霊屋敷だとか、お化けのうなる声がしただのというばかげた話は、まじめになって出来ないですからね。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うーむ」、　房枝は、黒川のうなるこえをきいたが、次の瞬間、彼女も頭がぼーっとしてしまった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "近い南瓜畑では熊蜂のうなる音がぶんぶん聞えていた。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その響が虻のうなるように際立って耳につくばかり、あたりは寂として枯蘆のそよぐ音も聞えないのは、日も漸く傾いて、ひとしきり風の鎮る時刻になったせいであろう。",
              "citation": {
                "source": "元八まん",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか、遠いところで、凧のうなる音が聞こえていました。",
              "citation": {
                "source": "ある日の先生と子供",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立のざわめきや、煙突のなかで風のうなる音がする。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、又極めてかすかながら人のうなるような声がきこえた。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この場からそなたがのうなるか首がのうなるか、いずれがよい？",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のうなるほかになんの物音も聞こえなかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "大津波のうなる音、木のめりめりさける音、圧搾された空気の爆発する音、すさまじいうなり声がわたしたちをおびえさせた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うそれだけのうちで、何を訊ねようにも種が無いので、先生が後を向ききりになると一緒に、今までひっそり閑としていた教室中には、急に小蜂のうなるような囁や、せわしい身じろぎの音が、一しきりサワサワ、サワサワと鳴り渡った。",
              "citation": {
                "source": "面積の厚み",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもよく耳をすませば羽虫のうなるような蛍光灯の音が聞こえるはずだ。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルクイストが試験管を壊すと、機械のうなる音が聞こえてくる。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳は悪魔のうなるように、ウンウンと力をこめて綱を引きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
