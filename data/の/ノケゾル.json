    "definitions": [
      {
        "index": 1,
        "gloss": "to bend backwards",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あツ」　仰け反る辨次郎。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あッ」　仰け反る弁次郎。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お秀の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んかの彈みで仰け反るところを、前から一杯に突いたものに間違ひあるまい。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "色若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "のけぞるほどに、ぎょっと致しました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、のけぞるやうにして、背後の壁の呼鈴を押した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "５５＝密室　敬四郎今度は右門の去った後を覗くと、５６＝おふみの室　おふみに挑みかかる覆面の太郎左衛門、小柄で額を切られてアッとのけぞる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "55＝密室　敬四郎今度は右門の去った後を覗くと、56＝おふみの室　おふみに挑みかかる覆面の太郎左衛門、小柄で額を切られてアッとのけぞる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えまなく窓のそとの闇に眼をくばつて、道ばたのすすきのむれが白くぽつかり鼻先に浮ぶと、のけぞるくらゐびつくりした。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはどうも、つい置き忘れておりまして」　直助は洗濯物を執って入ろうとして対手に気が注くなり、のけぞるようにして驚いた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "総領女はのけぞる程に驚いたが、知られては大変だと思ったので、そっと寝床へ戻って来て、弟をそろそろと起して其の耳に口をつけて囁いた。",
              "citation": {
                "source": "白い花赤い茎",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、雨戸を開けて中を覗くなり、のけぞるように驚いて白翁堂勇斎の家へ往き、勇斎を伴れて新三郎の家へ取って返した。",
              "citation": {
                "source": "円朝の牡丹燈籠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の高い痩ぎすな男は、それを見るとわっと叫んでのけぞるように身を反して逃げだした。",
              "citation": {
                "source": "女の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この騒ぎが一団の仏掌藷のような悪玉になって、下腹から鳩尾へ突上げるので、うむと云って歯を喰切って、のけぞるという奇病にかかった。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっくりとうちの親分がこの縁側まで出ていったと思ったら、ぱたりとのけぞる音がきこえたんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "このご前は、この嘘つきのご前さまは――」「まだ言うかっ」　お雪の叫びよりも、いつのまにか黒集りに駈け集った人の耳が恐ろしかったものか、パッと有朋が大きくひとゆり馬上の身体をゆり動かしたかと思うと、お雪の白い顔が、なにか赤いものを噴きあげて、のけぞるように馬の下へころがった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川は一眼見てのけぞるほど驚いた。",
              "citation": {
                "source": "唖娘",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間一面の血の海で、その血溜りの真ン中へのけぞるように倒れた人は、昨夜のままのパジャマを着た明らかに赤沢院長の無惨な姿だった。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その慌てたような顔をじっと睨みつけて、実雅はのけぞるばかり胸を突き出してあざ笑った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかと思ふと俄かにはしやぎ出し、胸をはだけ、股をあらはし、手を打つて、後ろにのけぞるやうにして、奇聲を放つて唄つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と一声、のけぞるような、驚ろきの声を上げると、『芳っちゃん芳っちゃん、来てよ、へんだわ、へんだわお姉さまが――』　と、テントに残っていたお友達に叫んだ。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、いきり立っていた吉原兵太郎はのけぞるほどひき戻された。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウウウンと、のけぞる侍――一五　当身を食って、大刀こそ放しはせぬが、「む、ううむ」　と、うめいて、のけぞって、体が崩れて、そのまま、苅田の畦の中に、溜り水を刎ねかして倒れてゆく侍――「雪、さすがだな――」　平馬は、それと見て、奥歯を噛むようにして、うめいて、「生意気な！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いうように、悲鳴に似たものを揚げて、三斎、のけぞるばかり――「や、や！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは、大グランド大尉の、赤鬼号じゃないか」「や、やッ」モンストン少佐も、探照灯に照し出された、見覚えのある、真紅な胴体をもった飛行機を見付けて、のけぞる位に駭いた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "擦れちがいざまに顔をのけぞるようにして僕たちをまじまじと眺める。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うーむ」　と唸って、「火の玉」少尉の上半身が後にのけぞる。",
              "citation": {
                "source": "空中漂流一週間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてのけぞるくらいにおどろいた。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっとも、あなたが手記を書いてくれれば、お見せしますがね」「なんの手記です」「つまり、それ、アンタのアレをやったときの手記さね」　毛里はのけぞるようにしてカラカラと笑った。",
              "citation": {
                "source": "犯人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一平がのけぞると、馬吉は落ちついて、ヨイショ、と言った。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダダダッと二列に坐った一行の前まで走ると、グッと立ちどまって、のけぞるように胸をそらした。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
