    "definitions": [
      {
        "index": 1,
        "gloss": "payment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "金銭だに納付せば位階は容易に得べき当時の風習をきたなきものに思い、位階は金銭を以て購うべきものにあらずとて、死ぬるまで一勾当の身上にて足れりとした。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて、五〇年を超える保護を希望する場合には「少額の手数料を納付するよう求める」などの方法を検討すべき、とする要望が一件あった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "私有財産限度超過額ハ凡テ無償ヲ以テ國家ニ納付セシム。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ納付ヲ拒ム目的ヲ以テ現行法律ニ保護ヲ求ムルヲ得ズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "國家改造後ノ將來、私有財産限度ヲ超過シタル富ヲ有スル者ハ其ノ超過額ヲ國家ニ納付スベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "國家ハ此ノ合理的勤勞ニ對シテ其ノ納付金ヲ國家ニ對スル獻金トシテ受ケ明カニ其ノ功勞ヲ表彰スルノ道ヲ取ルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ納付ヲ避クル目的ヲ以テ血族其他ニ分有セシメ又ハ贈與スルヲ得ズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "國家ガ國際間ニ生活スル限リ國家ノ至上權ニ於テ國家ノ所有ニ納付セシムル所以。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私有地限度以上ヲ超過セル土地ハ之ヲ國家ニ納付セシム。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "將來其ノ所有地ガ私有地限度ヲ超過シタル者ハ其ノ超過セル土地ヲ國家ニ納付シテ賠償ノ交付ヲ求ムベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ納付ヲ拒ム目的ヲ以テ血族其他ニ贈與シ又ハ其他ノ手段ニヨリテ所有セシムルコトヲ得ズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "國家ハ皇室下附ノ土地及私有地限度超過者ヨリ納付シタル土地ヲ分割シテ土地ヲ有セザル農業者ニ給付シ、年賦金ヲ以テ其所有タラシム。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "年々多大ノ收益アリテ近ク私産限度ヲ超過スベク而シテ超過額ヲ國家ニ納付スルヲ欲セザル目的ヲ以テ、限度以下ノ時ニ於テ、自己自身ノ欲望ニ從ヒテ消費セントスルハ亦國民ノ權利ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は、余が納得したのを見ると、ぜひこれを至急出願してくれといって、余の前に、出願手数料及び特許局へ納付すべき出願印紙料として、封筒に入った金を置いた。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（本器の売価は一個金十五円也とし、その半分は国家へ税金として納付させる。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして各包毎に、村名、氏名、納付月日、受付番號、納付包數等をそれぞれに書き込んだ荷札をつけた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち因みをもってその組織設備の一斑を述べんに、通学児童は何人にても自由に食事の給与を受け得らるれども、ただ無料にてこれを受けんとする者に対しては、委員においてその児童の家庭の状態を調査し、その事情に応じて無料の給与を許し、あるいは実費の一部ないし全部を納付せしむることとす。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "納付スベシのスベシが無うなつてけつかる。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃従来松山藩へ幕府から与えている領地家督相続の証として黒印ある書面（即ち将軍の御判物）悉皆を朝廷へ納付せよとの御沙汰があったので、それを入れたる長持を私がこの京都行のついでを以て保護して行けとの命を受けた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し二十日以内に納付すべし」「えッ五万円を二十日間に……。",
              "citation": {
                "source": "一九五〇年の殺人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "未三月久保村五人組　　　　　喜多武三郎　　　　　高野宇平民政掛御役所様　ここに「見懸人」とは、その村に居付きの人民ではなく、しかも現に住しているものに対して、見懸銀と称して課税した、その見懸銀納付者の称である。",
              "citation": {
                "source": "来り人の地位と職業",
                "author": "平民申付候事",
                "note": "青空文庫"
              }
            },
            {
              "text": "』（訳者註）かかる租税は重さを異にして農業者または地主の異る階級の負担する所とはならないが、けだし彼らは共に粗生生産物の騰貴によって補償され、そして単に彼らが粗生生産物の消費者たるに比例してこの租税を納付するに過ぎないからである、ということを、私は説明せんと努力し来った。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に労賃が、そして労賃を通じて利潤率が、影響を蒙る故に、地主はかかる租税に対し彼らの十分な分前を納付せず特に免除された階級なのである。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に奨励金を支払うために国民が納付せざるを得ぬ租税であり、そして第二に内国市場におけるこの貨物の価格騰貴によって生じ、かつ国民全体が穀物の購買者である故に、この特定貨物において国民の全体が支払わなければならぬ所の租税である。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『従って第一の租税の支払のために彼らが納付する五シリングごとに、彼らは第二の租税の支払のために六｜磅四シリングを納付しなければならぬ。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして同年内になお二駄の年貢米がまた今林庄から納付になっているからして、三石六斗の合計になり、かなりの収入となったのである。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田庄の所領もまた全部ではなくして三分の一であったろうと思われることは文亀三年正月二日の条に見えているが、とにかくこの庄からして三条西家に入るべき公用は年千疋であって、しかも他の諸庄に比べ、比較的正確に納付されたらしい。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永正二年に納付のあった節も同断である。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
