    "definitions": [
      {
        "index": 1,
        "gloss": "to proclaim (e.g. gospel)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "道や教えを宣べ伝えるという事は、取りようではたいへん穏やかな仕事のように思われる。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち汝らの聞いたとおり、イエスは神より油を注がれたキリストとして世に遣わされ、貧者、囚人、盲人、被抑圧者、並びに債務のために苦しめられる者に解放と自由を宣べ伝える。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イエスに遣わされて、世に福音を宣べ伝える使命を託された者、との意味である。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはイエスの生前においてすでにこの役割を与えられ、イエスの死後においてはその志をついで、広く世界に福音を宣べ伝える戦士となった。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イエスの使命は村々に福音を宣べ伝えることであったが、それをこの重い皮膚病を患っている人の軽薄がじゃまをしたのである。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の国の福音を宣べ伝えるについて、最も根本的な原理がその中に含められていたのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち悔い改めを宣べ伝えることと、悪鬼を逐い出し病者を医療する方法とを授けられたのです（六の七、一二、一三）。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悔い改め」を宣べ伝えることは、神の国の福音を聴かせることの必要な準備でありまして、その意味において弟子たちの地方伝道はイエス御自身の伝道の適切な「前座」でありました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分は聖書の言によってようやく彼の誘惑を退け、心の悔い改めと霊の新生による神の国の福音を宣べ伝える道に進み入ったのであった（マタイ四の一―一一）。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はただ言葉ばかりではなく、物を通してじかにこの真理を宣べ伝えるために「民藝館」を興しました。",
              "citation": {
                "source": "美の国と民藝",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
