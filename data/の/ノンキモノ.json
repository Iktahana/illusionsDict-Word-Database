    "definitions": [
      {
        "index": 1,
        "gloss": "happy-go-lucky person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
