    "definitions": [
      {
        "index": 1,
        "gloss": "to be about to get on (a train, bus, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "発車ベルが鳴り、慌てて電車に乗りかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「危ない！今からバスに乗っかるんだから、走らないで。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "改札口でICカードをかざし、まさにホームへ電車に乗っかろうとしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自分はもう町が尽きるんだなとは思いながら、つい芋に心を奪われて、橋の上へ乗っかかるまでは川があるとも気がつかなかった。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とただ間拍子もなく、女房の言いぐさに返事をする、俊吉の膝へ、衝と膝をのっかかるようにして盆ごと茶碗を出したのである。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
