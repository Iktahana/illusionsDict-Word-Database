        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "本名もお察しの通り小野原ノブ子に間違い御座いません。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、十五世紀にコンスタンチノブルの最初サルタン珍事を好む、基督教の大僧正に詛はれた者は地も其尸を壞らず。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見りゃ、わかるだろうが」　浅井は開いた窓から手を入れ、ヴェランダと室内をつなぐドアのノブをむこう側からつかみ、ドアをあけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "北端の教室のまえまでくると、高志は気をつけをして扉をノックし、返事を待たずにノブをまわして入っていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お岩さんは、生徒から、たんに「ノブ子」といわれている、数学の女教師だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーラスまでくると、非常扉が開いて、頭が雀の巣のようになった、一八〇を超える大男が、ノブをもったまま、踊り場の慶一と柾生を見る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は釈然としないまま、じゃあ、といってノブに手をかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノブをつかんだとき、思ったとおり、広岡がそのリフを弾きはじめたので、慶一はクスクス笑った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "安心するように、高志にいってくれ」　ノブのまわる音がして、慶一は手で義晴を追いはらい、外の空気を吸っていた、という思い入れで、ゆっくりと寮長をふりかえった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノックをせずに、静かにノブをまわす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は扉のノブに手をかけながら振り返って付け足した。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく観察すれば、日本にも随分アントニイ、コルソフや、ニチルトッフ、ハーノブのやうな人間はあるのだ」と言つて話し出した。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "採集植物シモツケソウ　クカイソウ　ルリトラノオ　キンバイソウ　ヤナギラン　ウスユキソウ　ヨブスマソウ　ノブキ　バイケイソウ　シュロソウ　ヒメユリ　シラヤマギク　オタカラコウ　タムラソウ　キオン　谷を上れば、右が霧ヶ峰主峰たる車沢山（？",
              "citation": {
                "source": "女子霧ヶ峰登山記",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「馬鹿やなあ、シゲノブと読むんや。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は Whittier五月　　九日　鶴見氏と午後から Greenwich へ人をたずね、お茶をホテルでのみ、東洋軒で食べ、ミス　リザノブィッチのところへ行き、アスターに一寸より、其から Whittier にかえり、Ａに電話をかける。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○イースター後、春、殆ど初夏の五月　鶴見氏との交際　河合、ハザノブウィッチ。",
              "citation": {
                "source": "「伸子」創作メモ（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍵が開いてゐたので、ノブをまわすと、燈火がかうかうとついたベッドの上に、女学生のはく、黒いパンツがぬぎすててある。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノブに手をかけると、扉はニスの匂ひをさせてすつと開いた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアには鍵もおりてなかつたので、そつとノブをまはすと、安南人の番人が庭に立つてゐたンで、吃驚しちやつた……。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノブ子さんの若い時にそっくりだ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、小生の死後、妻ノブ子と、愛児嬢次の保護をお頼み申上ぐる程のお方も亦、御迷惑ながら天下に唯、貴下お一人しかおいでにならない事を、深く深く確信致している者であります。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の妻ノブ子の行為は疾くに察知していたところであるが、余等は逆に彼女の手を利用し、虚偽の暗号電報を彼女に盗読せしめて、Ｊ・Ｉ・Ｃを通じて彼女の手を利用している米国政府を欺瞞していたものである。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴンクールのコンドルが、妻のノブ子に懸想しましたのは確かにこの時に相違ありませんので、この時以来、今日に至るまで引き続いて参りました小生一家の不幸は、大部分コンドルの仕業と申しても差支えないのであります。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る夜ローサンゼルスの郊外に在りました小生の留守宅は、大勢の覆面強盗に襲われまして、金庫を奪われました上に、ノブ子の貞操までも蹂躙されようとしたのでありますが、折柄小生を訪問して来ましたコンドルは一身を以て賊を逐い散らし、ノブ子の危急を救いました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもノブ子はこのために一時病気となり、加うるに資金欠乏のために当座の仕事を中止せねばならぬ破目に陥りましたが、コンドルはこの時も前と同様に親切に妻の世話を致しまして、巨額の金を貸し与え、仕事が続くようにしてくれました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような金をコンドルがどこから持って来たものか、私は今以て怪訝に堪えませぬが、そのような事は気付かぬながらに、妻ノブ子は友人として衷心からの感謝をコンドルに捧げておりましただけで、小生の妻たる一事は決して忘れておりませんでした。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンドルは小生の妻ノブ子を責め落す半永久的手段の第一着手として、或る日隙を見て愛児嬢次を誘拐して見世物師に売り飛ばしてしまいました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして死なんばかりに狂い嘆くノブ子に嬢次の行方を探してやるのだからと云い聞かせて、東部、紐育に連れ出しました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちコンドルは友人の悪弁護士や偽探偵を使って、愛児嬢次の行方を捜索してやると言葉巧みに偽らせ、時々は見すぼらしい姿をした嬢次の写真を見せたりなぞしまして、四五年の間にノブ子の全財産を捲き上げてしまいました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
