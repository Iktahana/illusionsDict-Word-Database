        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白いノーネクタイのシャツを着て、パナマ帽を冠ったその男も気がついたらしく、そのがっしりした顔にやや苦み走った微笑を泛べながら、寛るやかに足を運んで来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に着けてをつたノーネクタイのワイシャツが暑くてたまらない、到頭之を脱いで網目の半袖のシャツに換へる。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の服装はネズミ色のオーバー、ギャバジンの白いズボン、ノーネクタイだった。",
              "citation": {
                "source": "フシギな女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノーネクタイの背広もあれば、浴衣の裾をからげたのもある。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズラリ並んだ、喪服の人々の前を通って、仏前に礼拝するのは、誰しもテレるものだが、今日は何しろ暑さは暑し、ノーネクタイの不礼姿でズン／″＼と入って、ペコンと礼をして、サッサと出て来ちまったが、あとで自分をいやになって困った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
