        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "長さ二町ばかりの、その暗い湿つぽい通りに、今挙げたホンの三四軒の店屋が所々にあるのは、まるで蛍でもゐるやうな感じだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は独りで一軒の家に住んでゐて、毎夜、夜明近くまで読書する。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気味わるく物凄い顔をした、雲助のような男たちに脅やかされたり、黒塚の一軒家のような家に泊って、白髪の恐ろしい老婆に睨まれたりした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし東京へ移ってから、子供が大ぜい生れたりして、家内が狭くなった上に、貯財も少し出来て来たので、夫人のすすめで売家を一軒買うことにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると一軒｜頃合の家が見つかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、馬場とシゲティとは共鳴をはじめて、銀座一丁目から八丁目までのめぼしいカフエを一軒一軒、たんねんに呑んでまわった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の酒の店を五六軒。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路に落ちる家々の軒の日影が、くつきり黒い。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の軒は一樣に低く、城下まちの落ちつきはある。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は帰途、新宿の酒の店、二、三軒に立寄り、夜おそく帰宅した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此の近所に一軒だつて上品な家はない。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手に抱へられて、店屋の軒にやられた時、彼は「Ｓ子が来てやあしないか……？",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、今日古ぼけた軒廂が退く。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "精養軒は美味いのであり、おふくろのオムレツは不美味いのである？",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の軒先に、魚の干物でも乾してあるのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏祭の日には、家々の軒に、あやめや、菖蒲や、百合などの草花を挿して置くので、それが雨に濡れて茂り、町中が忽ち青々たる草原のようになってしまう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨や御豆の小家の寝覚がち「五月雨や大河を前に家二軒」という句は、蕪村の名句として一般に定評されているけれども、この句はそれと類想して、もっとちがった情趣が深い。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の燈やゆかしき奈良の道具市　秋の日の暮れかかる灯ともし頃、奈良の古都の街はずれに、骨董など売る道具市が立ち、店々の暗い軒には、はや宵の燈火が淡く灯っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の軒には干魚がかけて乾してあり、薄ら日和の日を、秋風が寂しく吹いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯や何に世渡る家五軒　木枯しの吹く冬の山麓に、孤独に寄り合ってる五軒の家。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の軒先には、台所のガラクタ道具が並べてある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にまた蕪村は、冬の蕭条たる木枯の中で、孤独に寄り合う村落を見て木枯や何に世渡る家五軒　と、霜枯れた風致の中に、同じ人生の暖かさ懐かしさを、沁々いとしんで咏むのであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われこの新道の交路に立てどさびしき四方の地平をきはめず暗鬱なる日かな天日家竝の軒に低くして林の雜木まばらに伐られたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その石段の両側には、土産物の寄木細工を売る店や、かういふ町に適当な小綺麗の小間物屋や、舶来煙草を飾つた店や、中庭に廻廊のある二層三層の温泉旅館が、軒と軒とを重ね合せて、ごてごてと不規則に並んで居る。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに山の霧が多いので、いつも水蒸気で町の軒灯が紅色にかすんで、一層山間都市の華やかな感じを深める。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏町の溝を流れる湯の匂ひや、朧ろにかすむ紅色の軒灯や、枕に近い湯滝の音やが、何とも言へぬ春らしい感じを起させる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外には程近い山王台の森から軒の板庇を静かにそそぐ雨の音も佗しい。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔卑屈の友らをいきどほろしく〕宮沢賢治卑屈の友らをいきどほろしく粘土地二片をはしりてよぎり崖にて青草黄金なるを知りのぼりてかれ草黄なるをふめば白雪きららに落ち来るものか一列赤赤ならべるひのきふたゝび卑屈の友らをおもひたかぶるおもひは雲にもまじへかの粘土地なるかの官庁に灰鋳鉄のいかりを投げよ",
              "citation": {
                "source": "〔卑屈の友らをいきどほろしく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雲を濾し〕宮沢賢治雲を濾しまことあかるくなりし空かな子ら歓呼してことごとく走り出でしも宜なれや風のひのきはみだるるみだるゝ",
              "citation": {
                "source": "〔雲を濾し〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雪とひのきの坂上に〕宮沢賢治雪とひのきの坂上に粗き板もてゴシックを辛く畳みて写真師の聖のねぐらを営みぬぼたと名づくる雪ふりていましめさけぶ橇のこらよきデュイエットうちふるひひかりて暮るゝガラス屋根",
              "citation": {
                "source": "〔雪とひのきの坂上に〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
