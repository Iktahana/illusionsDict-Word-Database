[
  {
    "uuid": "7832d312-4cea-5289-bbf8-8f018c3fc032",
    "entry": "乗り出す",
    "reading": {
      "primary": "のりだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
