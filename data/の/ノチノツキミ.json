    "definitions": [
      {
        "index": 1,
        "gloss": "moon-viewing on the 13th day of the 9th lunar month",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
