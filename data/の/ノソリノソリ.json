        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "獅子はだまって受けとって脇にはさんでのそりのそりとこんどは自分が見まはりに出ました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その乞食の人はどんなことがあっても駆けるということをしないで、ぼろを引きずったまま、のそりのそりと歩いていたから、それにとらえられる気づかいはなかったけれども、遠くの方からぼくたちのにげるのを見ながら、牛のような声でおどかすことがあった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のそりのそりと歩行き出すと、はじめ、出会ったのは緋縅の武者で、続いて出たのは雁がね、飛んで来たのは弁慶で、争って騎ろうとする。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "又某時、庭の方でがらがらと云うような大きな音がしたので、見ると庭の片隅に立てかけてあった竹竿が二本、人の歩くように並んでのそりのそりと歩いていた。",
              "citation": {
                "source": "唖の妖女",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿め、と噴出して飛上る後から、ややあって、道学先生、のそりのそり。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と大声で言って衆口を閉じさせ、ひとまず落ちつく事にいたしましたが、さてその後、シーボルトという人が日本にまいりまして、或る偶然の機会にれいの一件がのそりのそり歩いているのを見つけて腰を抜かした。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、店のまえのたたきのところへ、一ぴきのやせた犬がびしょぬれになって、のそりのそりとやって来ました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはのそりのそりと歩く重だるいやうな足音であつた。",
              "citation": {
                "source": "雨夜詞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身のたけに余る柴を負うてのそりのそりあるいて来た。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはのそりのそりと歩く重だるいような跫音であった。",
              "citation": {
                "source": "萌黄色の茎",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫が知らせたんだわね、愛吉、お前のお庇で、」　と入ったまま長火鉢に軽く膝を支いて、向うへ廻った女房に話しかけたが、この時門口を見返ると、火の玉はまだ入らず、一件の繻子張を引提げながら、横町の土六尺、同一処をのそりのそり。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "動ともするとおびえて胸の中ですくみそうになる心を励まし励まし彼れは巨人のように威丈高にのそりのそりと道を歩いた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちにはまだ大事な用があるわ」　鋭く主水之介が呼び止めながら、のそりのそりと庭先へ降りて行くと、ぎょッとなったようにして立ち止まっている件の男の側に歩み寄ったかと見えましたが、ここら辺もまた退屈男の常人でない一面でした。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お約束のようにヒュードロドロと下座がはいると、上手のささやぶがはげしくゆれて、のそりのそりと出てきたものは、岡っ引き長助の扮している朝鮮虎です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と笑いながら、そのままのそりのそりと町の方へ歩いていきました。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆然自失したように手槍を杖についたまま、じいッと主水之介のすばらしい男前にやや暫し見惚れていたが、のそりのそり近づいて来ると、上から下へじろじろと探るように見眺めながら、ぽつりと言いました。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから、直人がのそりのそりと宿の土間へ這入っていった。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山で鳴く山鳩や、日暮れ方にのそりのそりと出てくる蟇がよい御友達でした。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそんな時患者の方は、急に口をつぐんでいつも教えられたように院長の言葉を聞分けようとでもするのか、妙な上眼を使いながらのそりのそりと尻込みするのだった。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「楊閣下、これからすぐ、第七十七回目の練魚がやれます」「よおし、ではそっちへゆこう」　楊博士は、のそりのそりと練魚司令部へ足をはこんだ。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうするうちに山賊は腰の太刀おつとりてのそりのそりとやつてきた。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこらに遊んでゐる子供達が、人ずくなで、おまけにびくびくものなのを見ると、えてして強気になるものと見えて、のそりのそりと高脚を踏みながら、ひたひた水を渉り、土塊を跨いで、物好きにも子供達の群に近づいて来ることがよくあつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "見あぐれば千仞の谷間より木を負うて下り来る樵夫二人三人のそりのそりとものも得言わで汗を滴らすさまいと哀れなり。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は口笛を吹きながら、のそりのそりと砂浜を歩いていたが、ふと振り返ると、マッチをつけかねていた庸三に寄り添って、袖で風を遮ぎった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬小舎に投げ込んで、馬に踏ませてから畑の敷肥に使うのだろう、馬は今までの重荷を急に卸されて身軽になって、身体じゅうに波を打たせながら、何人も引かないのに、のそりのそり先きに立って歩いて行くと後から脊負子を脊に、雪袴に草鞋穿きの若い男女がついて、家の角を廻って見えなくなった。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "土城にはもう誰もいない、何だか怯くなって爺は上の方へのそりのそり這い上ってみた。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
