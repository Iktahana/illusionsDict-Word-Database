        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "よしやこの縁を厭ひたりとも、野末の草花は書院の花瓶にさゝれん物か。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は夏の最中自分はたゞ畫板を提げたといふばかり、何を書いて見る氣にもならん、獨りぶら／＼と野末に出た。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾て志村と共に能く寫生に出た野末に。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は夏の最中自分はただ画板を提げたというばかり、何を書いて見る気にもならん、独りぶらぶらと野末に出た。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて志村と共に能く写生に出た野末に。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の出前学校は、　　稗と粟との野末にて、　　朝の黄雲に濯はれてあり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ宵ながら月は高く澄んで冴えた光を野にも山にも漲ぎらし、野末には靄かゝりて夢の如く、林は煙をこめて浮ぶが如く、背の低い川楊の葉末に置く露は珠のやうに輝いて居る。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山家の時雨は我国でも和歌の題にまでなっているが、広い、広い、野末から野末へと林を越え、杜を越え、田を横ぎり、また林を越えて、しのびやかに通り過く時雨の音のいかにも幽かで、また鷹揚な趣きがあって、優しく懐しいのは、じつに武蔵野の時雨の特色であろう。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ宵ながら月は高く澄んで、さえた光を野にも山にもみなぎらし、野末には靄かかりて夢のごとく、林は煙をこめて浮かぶがごとく、背の低い川やなぎの葉末に置く露は玉のように輝いている。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "野末はるかに百舌鳥のあわただしく鳴くが聞こゆ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らの芸術に先生がたの裏書きをしてもらうくらいなら、僕は野末でのたれ死にをしてみせる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　橋から橋へ、河岸の庫の片暗がりを遠慮らしく片側へ寄って、売残りの草花の中に、蝶の夢には、野末の一軒家の明窓で、かんてらの火を置いた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴えた通る声で野末を押ひろげるように、鳴く、トントントントンと谺にあたるような響きが遠くから来るように聞える鳥の声は、梟であった。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘆の穂が幽に、おなじように細い残月に野末に靡く。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "電柱とラヂオの竹が、矢來の如く、きらりと野末を仕切るのみ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そこだてね、まあ聞かっせえ、客人が、その最愛らしい容子じゃ……化、」　とまた言い掛けたが、青芒が川のへりに、雑木｜一叢、畑の前を背｜屈み通る真中あたり、野末の靄を一｜呼吸に吸込んだかと、宰八｜唐突に、「はッくしょ！",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車に連るる、野も、畑も、畑の薄も、薄に交る紅の木の葉も、紫｜籠めた野末の霧も、霧を刷いた山々も、皆｜嫁く人の背景であった。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃はあてもなく異性を戀して春の野末を馳せめぐり、ひとり樹木の幹に抱きついて「戀を戀する人」の愁をうたつた。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかなしい田舍の鷄家根をこえ垣根をこえ墓場をこえてはるかの野末にふるへさけぶああ私はこはれた日時計　田舍の白つぽい牡鷄です。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかなしい田舍の鷄家根をこえ垣根をこえ墓場をこえてはるかの野末にふるへさけぶああ私はこはれた日時計　田舍の白つぽい雄鷄です。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しい野末の墓石が風にふかれてゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はけふも野末の墓場をおとづれた。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人よ、旅人よ路を急げと海べをくれば波の音野末をゆけば蝉の声……妹　　わたしはあんとき泥棒をうまくつくつたわね。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は底深く澄み、太陽は冷めて黄ばみ、木の葉は薄く色づく、野末を渉る風さへも足音を秘めて忍び寄る。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い月は、野末に一つ、あるけれど、もと末も分らない、雲を落ちた水のような畝った道を、とぼついて、堪らなくなって――辻堂へ、路傍の芒を分けても、手に露もかかりません。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙が立つて、づん／＼とあがる坂一筋、やがて、其の煙の裙が下伏せに、ぱつと拡がつたやうな野末の処へ掛つて居ました。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……東雲の雲は其の野末を離れて、細く長く縦に蒼空の糸を引いて、上つて行く、……人も馬も、其処を通つたら、ほつほつと描かれやう、鳥も飛ばゞ見えやう、――けれども天守の屋根は森が包んで、霞がくれに尚暗い。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴えた通る声で野末を押ひろげるやうに、啼く、トントントントンと谺にあたるやうな響きが遠くから来るやうに聞こえる鳥の声は、梟であつた。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる日のかかる野末を。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああかい、ゆうひに、てらされて、とうもは、のずえの、いしの、した、――まっさき、かあけて、とっしんし――」「ひろぼうか」　男の子をからかっているのか壮い男の声が軍歌に交りあった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
