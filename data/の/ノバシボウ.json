        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "狭い場所での作業には、リーチを伸ばせる伸ばし棒が役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工具箱の中に、ボルトを回すための伸ばし棒が見当たらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "機械の奥にある部品に届くように、彼は伸ばし棒を慎重に操作した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
