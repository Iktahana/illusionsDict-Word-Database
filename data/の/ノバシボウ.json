        "examples": {
          "standard": [
            {
              "text": "クッキー生地を均一に伸ばすために、伸ばし棒を使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パン作りでは、伸ばし棒で生地を薄く広げる作業が重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "麺棒とも呼ばれる伸ばし棒は、日本の家庭料理でもよく使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "父親は腕を伸ばし棒を廻しながら舞い、息子は地に蹲まり、其の儘何ともいえない恰好で飛び跳ね、此の踊の画く円は次第に大きくなって行った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
