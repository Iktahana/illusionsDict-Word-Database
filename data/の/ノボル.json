    "definitions": [
      {
        "index": 1,
        "gloss": "to ascend",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「お宅へ上るところでした。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから座敷へ上ると、妻が洋服をぬがせて和服に着かえさせてくれる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "男子が年と共に前額部の禿げ上るのは当り前の事で、少しも異とするに及ばぬけれど、大隅君のは、他の学友に較べて目立って進捗が早かった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階に上ると、荷物が来てゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「分らないものだ……」　近頃彼は口癖のやうに、長いこと坐つてゐて立ち上る時など、何時もさう口ずさむのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は芭蕉の俳句中でひらひらと上る扇や雲の峯　を第一等の名作として推賞してゐたが、上例の如き自作の句を観照すると、芥川氏の芭蕉観がどのやうなものであつたかが、およそ想像がつくであらう。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡頭に下り立ちて船に上る。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀の遊ぶのを見たりとて面白くもなし湊川へ行て見んとて堤を上る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要太郎の指をさす通りにグサ／＼と下駄の踏み込む畔を伝って土手へ上ると、精の足元からまた一羽飛び出して高く舞い上がった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言つて、父はペンを置いて立ち上る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、かへつてそのはうが、活き活きして面白いお話が出來上るかも知れぬ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやうに、所謂「傑作意識」にこりかたまつた人の行ふ藝事は、とかくまづく出來上るものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴がボウボウ燃え上るんだから、ひどい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお爺さんは苦笑して、もう立ち上る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の宵　　　　　　青いソフトに降る雪は　　　　　　過ぎしその手か囁きか　　白秋ホテルの屋根に降る雪は過ぎしその手か、囁きか　　　　ふかふか煙突｜煙吐いて、　　赤い火の粉も刎ね上る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかにしづかに酒のんでいとしおもひにそそらるる……　　ホテルの屋根に降る雪は　　過ぎしその手か、囁きかふかふか煙突煙吐いて赤い火の粉も刎ね上る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷が狭くなって、崖側を行くと、緩いながらも雪の傾斜で辷るから、ミヤマナナカマドの枝を捉えながら上る、前にも増した雪の断裂で、草鞋に踏み蹂った雪片は、山桜の葩弁のように、白く光ってあたりに飛び散る。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは自分に憶い出の多い小舎である、六年のむかし、槍ヶ岳へ上る前夜、この小舎へ山林局の役人と合宿したとき、こういう話を聞いたからで。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌くる日は穂高岳に上るつもりで、朝｜夙く起きた、宿の女が「飯が出来やしたから、囲炉裏の傍でやって下せえ、いけましねえか」と、畏る畏る閾越しに伺いに来る、いいとも、と返辞して大囲炉裏の前に、蝋燭を立て、猟士や宿の人たちと、車座になって飯を済ます、準備も整って出かけると、雨になった。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "痕を残さない、濃さと淡さの碧が、谷から舞い上る霧のほむらに、ぬらりと光る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "潭が深くて、渉れないから、崖に攣じ上る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻に敷いた褥は、可愛らしい高山植物で、チングルマの小さい白花、アカノツカサクラの赤い花などが、絨氈の斑紋になって、浮き上る、焚火の影に、鮮やかな織目を見せる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ思いが、仲間の顔色に読まれる、飯を炊くのに、未だ時間がある、思い切って天幕から一、二間歩き出した、岩を二ツ三ツ飛び越えて、次第に爪先が上る、無辺無限の単調の線が、どこへ繋がって、どこへ懸っているのか、解らない……やはりあの空線の一つを辿っている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "フツ、フツと、柔くて、しかも鋭敏な音を立てて霧――雨が来た、偃松も、岩も、山も、片ッ端から白い紙になって、虚空に舞い上る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "西に向いて、また一峰を超え、やや下ってまた北に向って上る、霧の中で目標にする山もないから、手に磁石を放さない、何でも北へ向けばいいのだ、北へ、北へと歩む。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は躍り上るように喜んだ、ほんとうに、久しく尋ねあぐんでいたのだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその花は、一つのこずえの尖端に、十数個から二十ぐらい、鈴生りに群って、波頭のせり上るように、噴水のたぎるように、おどっているところは、一個｜大湊合の自然の花束とも見られよう、その花盛りの中に、どうかすると、北向きに固く結んだつぼみが見える。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい急坂を上る機関車のような、重苦しい骨の折れる時間が経った。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "期限までに仕上ると、会社から組には十万円、組から親方には三万円の賞与が出るのだ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、上に上ると、それは吹雪と一緒になって飛んで行った。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
