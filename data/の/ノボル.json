        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "原油価格の高騰により、ガソリン代がまた上った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "株価が予想以上に上り、投資家たちは喜びに沸いた。",
