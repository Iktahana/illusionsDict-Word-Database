        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "徃復七里、帰途の暑さはこたえた、しかし、のんべんだらりと坐つてゐるよりも歩いた方がたしかに身心をやしなふ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ともつかずやれば成績は上がらず、かえって邪魔をされ、邪魔されて師匠の没後の家のためにならぬにかかわらず、のんべんだらりで附いているはさらに嫌なり。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "身を引いた時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその仲間は、逆に自分がやられているのにのんべんだらりと逃げもしない「だらしのない奴」だと思い、相手にそう云おうと思っていたというのである。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その同志にとってはしゃべるという事は始めから考え得られないことだったし従って他のものもしゃべるなどとは考えもしなかったので、「のんべんだらり」とアジトにいたのだ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "が今あの頼りない太田を前にしては、私はこの良き意味での「のんべんだらり」をアジトで極め込んでいるわけには行かぬ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの恐ろしい目に会わなかったことを実に仕合わせに有難くは思うが、万事が落付くまで、生れた東京の苦しみを余処にのんべんだらりとしてはいたくない。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ただ家にのんべんだらりとしているのは苦痛で、少しでも自分の社会生活が欲しくて、職業についた人というのも少くはなくなって来ていた。",
              "citation": {
                "source": "働く婦人の新しい年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんが兵隊に行っているうち、私はのんべんだらりとしていたかい？",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんがいつまでものんべんだらりとしていて話をはこぼうとはしないので、お初は階下で気をもんでいるおっ母さんの姿に急かれるような気がしていらいらしてくる。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は歴乎とした一家の父で、その名をキーファ・モーキエヴィッチといって、ごく柔和な性質で、一生をのんべんだらりと暮らしてしまった男である。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "本をひろげて見たり、好い加減な文章を書いて見たり、それにも飽きると出たらめな俳句を作つて見たり――要するにまあ太平の逸民らしく、のんべんだらりと日を暮してゐたのである。",
              "citation": {
                "source": "東京小品",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、北きょくにひとつだけ、南きょくにもひとつだけ、あかりがあるんだけど、そこのふたりのあかりつけは、のんべんだらりとしたまいにちをおくっていた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうやって、いつまでも、のんべんだらりと、酔払いのあいてをさせられてはたまらない。",
              "citation": {
                "source": "ニュー・ヨーク　『青春の自画像』より",
                "author": "前田河広一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のんべんだらりと滞在して、山の宿屋めしにもあきてきたが。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつまた、いつまでも妻の千浪を、のんべんだらりと文珠屋へ預けて置くのは、佐吉の好意に甘えすぎるようで、それも面白くないので、ああは言ったものの、一応千浪を引き取り、佐吉と相談の上で、大次がこの腕に覚えの居合い手品を始めたのだった。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつ、櫛まきお藤の隠れ家でのんべんだらりとお預けをくっているはずなのが、それがある朝、ヒョイと思い出したのが丹下の殿様から言いつかっている大事の御用――こりゃアいけねえ、おらあこんなところにいい気に引っかかっていられるわけのもんじゃアねえんだ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶をもう一ぱい、金鍔をもう一つというので、定公め、なかなか腰を上げないのだが、べつに急ぐこともないので、幸吉もついそのまま、のんべんだらりと茶店に根を生やしていると……めずらしい晴天だから、人出が多く、茶店はかなり混んでいる。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯五は、それをいいことにして、のんべんだらりと滞在していた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさまはね、私が、一生懸命に仕事をする気にもならないで、のんべんだらりと真木にこびり付いているとお思いになるから、そんな風にお思いになるのよ。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間がすぎてゆくその感覚なしに、のんべんだらりとしていられると、ＳＵでもジリジリしてきます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事の配分と時間のこととを考えると、ユリもそうのんべんだらりとしていられないね、とお思いになるでしょう？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃の主義主張としても、一日｜作さざれば一日食せずという気概の下に働いて来たこの先生が、このごろでは一日中、何も作さずに、のんべんだらりと、食ったり飲んだりしている日が多い。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで道庵先生は、こう毎日、のんべんだらりとして宿屋の飯を食っていることに生活の空虚を感じ、これでは天道様に対して相済まないと自省してから、こういう無意識空虚な生活から一日も早く脱却向上しなければならぬと義憤を発したのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、彼が十一時ころになって、自分の都合でやっと足を運んで来るまで、のんべんだらりと待っているはずがなかろうじゃないか？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて三十七年、のんべんだらりとどこにも区切りが見当らぬとは、ひどく悲しい。",
              "citation": {
                "source": "青春論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、ばかな」彼は、自分の迂愚を罵って、「――あんな男をあてにして、のんべんだらりと待っている奴が間抜けというものだ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
