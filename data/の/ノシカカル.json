    "definitions": [
      {
        "index": 1,
        "gloss": "to lean over (and cover with one's body)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眼前を過ぎる幻像を悲痛のために強直した顔の表情で見詰めながら、さながら鍵盤にのしかかるようにして弾いているショパンの姿が、何か塹壕から這い出して来る決死隊の一人ででもあるような気がするのである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひととほりの訊問をすませてから、鬚は、ベツドへのしかかるやうにして言つた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と今度は別の太い声がのしかかるように響いた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ荒野の真ん中にあったとしても、この地の人々は自らに重くのしかかる不安な気持ちをつぶやくことができない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「主の御手がお前に重くのしかかる！",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "※瑁の揃いに相違なかったよ」と、お弓はのしかかるようにいった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は明りを求めて勾欄の上にのしかかるようにして茶碗を眺めた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "進むにつれて右舷の海中へ、身を曲ねらして躍り出た巨大な怪獣のような鳥喰崎の全貌が、大きくのしかかるように迫り寄る。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟慮お許しくださるまいか」「ならぬ」左源太のしかかるのを、眼で抑えた三郎兵衛、「時期は？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お庭番の中間が、のしかかるように、煽てた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　子は立上って母の肩の上へ負われるようにのしかかると、暫く静にしていたが、その中に両足で畳を蹴り飛び上った。",
              "citation": {
                "source": "火",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙間さ持つて來て、井戸側ぜんたいの重みが上からずんとのしかかる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "放って置けばのしかかるし、何か云うと直さまあわてて、はい、はいの連発だ。",
              "citation": {
                "source": "或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は姑との軋轢に苦しむアサ夫婦の心持を、旧套の力がのしかかる大さの感覚でうけて観ており、後半では作者自身の理想に立ってアサの成長を描いているようにも思える。",
              "citation": {
                "source": "徳永直の「はたらく人々」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっちへ行っておいで」お島はのしかかるような疳癪声を出して逐退けた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "自身にのしかかるそういう重荷の歴史性を、はっきり解剖し、根底から社会通念を人間が生きるに合理的な方面に導こうとする建設の道へ身を投じる者は、少数の、本当に強い心持の若者であろう。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争の無惨と無意義な破壊の犠牲はいつも人民に、女と子供と老人に無限にのしかかるものであることを血の涙をとおして自覚した。",
              "citation": {
                "source": "正義の花の環",
                "author": "――一九四八年のメーデー――",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、列というものがその力でどこかをみっしみっしと軋らせはじめると、一番弱々しい箇所に向ってのしかかるのは列の力学とでもいうものだろうか。",
              "citation": {
                "source": "列のこころ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイには、この母親がどんなに気を張り智慧をしぼってその日その日三人の健康な若者の胃をなだめているかということがわかり「一片のパンさえも石となって」彼の心にのしかかるのを感じる。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓊助君は、漫画修行による人生観察の過程で、旧套の重荷に反撥して自らを破ることが、新世代にのしかかる圧力を克服することではないことを、既に学んでいるであろう。",
              "citation": {
                "source": "鴎外・漱石・藤村など",
                "author": "――「父上様」をめぐって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日重いのしかかる様な日がつづきましたので、昨日と今日の雨がどんなに私の心をすがすがしくさせてくれる事でございましょう。",
              "citation": {
                "source": "たより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の上にだけ重くのしかかる目に見えない日常の絆、女心は先ずそれを吐露したいのだという疼くような苦衷、それは「行人」の千代子の心のなかにとらえなかったばかりでなく、漱石のあらゆる他の作品のなかに欠けている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また後ろをふり返ると御堂の上にのしかかるようにそびえている東山のはるかのてっぺんに、真っ黒に繁った杉の木立ちがぬっと顔を出しているのを見たに違いありません。",
              "citation": {
                "source": "田村将軍",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "てっきりそれに違いないと思いました」　かの男は膝の上で拳骨を堅め、少し前へのしかかるようにして、詰るような口吻で後をつづけた。",
              "citation": {
                "source": "誤診",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "神父はほとんどのしかかるように鬚だらけの顔を突き出しながら、一生懸命にこう戒め続けた。",
              "citation": {
                "source": "おしの",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上へ拡げた紙へ胸ごとのしかかる姿勢で好子はおだやかに云った「山田は時々戦死するかもしれないよと云うのよ。",
              "citation": {
                "source": "二人いるとき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老紳士はほとんど厳粛に近い調子で、のしかかるように云い切った。",
              "citation": {
                "source": "西郷隆盛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が堡塁へのしかかるように、身体を寄せて敵の前進を眺めていた。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
