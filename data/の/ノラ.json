        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "牛の脊中へ赤い紙片を貼付け、尻尾に摺粉木を一本縛り付けて野良へ出しておく。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "など、のんきな事を考へながら山を降りて來たら、途中で、野良へ出かける息子の聖人とばつたり出逢ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "晝間は出入の織るやうに忙がしかつた各旅館の玄關にも今は殆ど人氣が見えず、野良犬がそこらをうろ／＼して居るのが見えた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の火事ならば大勢の人が集まっているであろうに、あたりには人影もなくただ野良犬が一匹そこいらにうろうろしていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大船近くの土堤の桜はもうすっかり青葉になっており、将来の日本ハリウード映画都市も今ではまだ野良犬の遊び場所のように見受けられた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞の漫画を見ていると、野良のむすこが親爺の金を誤魔化しておいて、これがレラチヴィティだなどと済ましているのがある。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野良帰りの七五郎、入って来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "文六、大声に、Ｔ「珍しや、父の敵　頓間野良兵衛ッ！",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、学年が進んで、次第に都会人らしく、垢ぬけがして、親の眼にも何だか品が出来たように思われだすと、おしかは、野良仕事をさすのが勿体ないような気がしだした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野良仕事にも、夜なべにも昔日のように精が出なくなった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘から谷間にかけて、四五匹の豚が、急に広々とした野良へ出たのを喜んで、土や、雑草を蹴って跳ねまわっているばかりだ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻を殴られた豚は悲鳴を上げ、野良を気狂いのように跳ねまわった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚は呻き騒ぎながら、彼等が追いかえそうと努めているのとは反対に、小屋から遠い野良の方へ猛獣の行軍のようになだれよった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「内地に居りゃ、今頃、野良から鍬をかついで帰りよる時分だぜ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし長屋は右側ばかりで、左側の空地は紺屋の干場にでもなっているらしく、所まだらに生えている低い秋草が雨にぬれて、一匹の野良犬が寒そうな顔をして餌をあさっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそこらにさまよっている野良犬のなかで、性質の獰猛らしいのを二匹も拾いあげた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜犬談」も、いくらか皮膚病嫌惡の小説みたいなところもあるが、甲府では私は本當に野良犬どもに惱まされた。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばあさんも、野良仕事が忙しくって洗ってやりもしなかった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝五時から、十二時まで、四人の親子は、無神経な動物のように野良で働きつゞけた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飯を食って、野良へ出てから母は云った。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、まだ、兄の妻とならないさきの、野良で自由にはねまわり、自由に恋をした、その時の顔だ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い時分、野良で過激に酷使しすぎた肉体は、年がよるに従って云うことをきかなくなった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源作が野良仕事に出ている留守に、おきのの叔父が来た。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年あまり清吉が病んで仕事が出来なかったが、彼女は家の事から、野良仕事、山の仕事、村の人夫まで、一人でやってのけた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お昼から、お里が野良仕事の為初に、お酒と松の枝を持って畠へ行ったひまに、清吉は、寝床から這い出して、そっと、風呂敷を開けて見た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪のあるのは旧大きいお邸の医者様の跡でな、ここいらはこれでも一ツの村でがした、十三年前の大水の時、から一面に野良になりましたよ、人死もいけえこと。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の一角、直線に断たれてその間から広い野が見える、野良一面、糸遊上騰して永くは見つめていられない。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿取、麦蒔、大根取などに、多くの男共や女共と一しよに野良に働いた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "此奴は褌にするため、野良猫の三毛を退治て、二月越内証で、もの置で皮を乾したそうである。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "平民の野良犬も多いのに、何も選好をして華族様の御手飼を殺らずともの事だ、奥様に知れようものなら、金次一生の越度とならあ、忌々しい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
