    "definitions": [
      {
        "index": 1,
        "gloss": "nori",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "衰へや歯に食ひあてし海苔の砂この秋は何で年よる雲に鳥蝙蝠も出でよ浮世の花に鳥秋近き心の寄や四畳半　こうした句の詩情しているものは、実に純粋のリリシズムであり、心の沁々とした咏嘆である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衰へや歯に喰ひあてし海苔の砂　独居する芭蕉の心に、次第に老が近づくのを感じて来た。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理人篠村宇三郎、かご入りの青海苔を持って来て、「これは今年始めて取れましたので差上げます。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "セコンドメイトは、私が頭を抱えて濡れた海苔見たいに、橋板にへばりついているのを見て、「いくらか心配になって」覗き込みに来るだろう。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、デッキへ洩れると、直ぐにカラカラに、出来の悪い浅草海苔のようにコビリついてしまった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は香りを消さぬように薬味の青｜海苔を撒らずに椀を重ねた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして玉子と海苔巻に終る。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の小さい膳の上には、いつものように炒り玉子と浅草｜海苔が、載っていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう心配の揚句、玉子と浅草海苔が、この子の一ばん性に合う喰べものだということが見出されたのだった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅僧も私と同じくその鮨を求めたのであるが、蓋を開けると、ばらばらと海苔が懸った、五目飯の下等なので。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者知るや、さんが、オムレツを啣んで、あゝ、うまい、と嘆じ、冴返る身に沁々とほつき貝と、芥川さんが詠じて以来、――東京府の心ある女連は、東北へ旅行する亭主の為に鰹のでんぶと、焼海苔と、梅干と、氷砂糖を調へることを、陰膳とゝもに忘れない事に成つた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのでんぶ、焼海苔など称ふるものをしたゝか入れた大バスケツトがあるゆゑんである。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海苔を収むるがために「ひゞ」と称して麁朶を海中に柵立するところも、またこの砂洲の上もしくはその附近の地なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとろえや歯に食いあてし海苔の砂」などという句でも若いころにはさっぱり興味がなくてむしろいやみを感じたくらいであったのが、自分でだんだん年を取ってみるとやはりそのむしろ科学的な真実性に引きつけられ深く心を動かされるようである。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥色をした浅草紙を型にたたきつけ布海苔で堅めた表面へ胡粉を塗り絵の具をつけた至って粗末な仮面である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お女中が来て今日はお美味い海苔巻だから早やく来て食べろと言ったが当頭俺は往かないで仕事を仕続けてやったのだ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はちっとも気がつかなかったが、あとで聞いたところによると、先生が海苔巻にはしをつけると自分も海苔巻を食う。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごまのふってあるのや、中から梅干しの出てくるのや、海苔でそとを包んであるのや……こんなおいしい御飯を食べたことはないと思うほどだった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人のこの姿は、浅草｜海苔と、洗髪と、お侠と、婀娜と、（飛んだり刎ねたり。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "がさり……「叱……」　と言ふ追ふ聲も、玄米の粥に、罐詰の海苔だから、しつこしも、粘りも、力もない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰返すやうだが、それが二日で、三日の午すぎ、大雨に弱り果てて、まだ不安ながら、破家へ引返してから、薄い味噌汁に蘇生るやうな味を覺えたばかりで、罐づめの海苔と梅干のほか何にもない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おつやは海苔巻を一つ取って遣る。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おつやは海苔巻の鮓を取ってやれば、太吉は平気で食う。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそくなつて帰庵、見ると机上に酒壱本と海苔一袋とが置いてある、Ｔ子さんに間違はない、だいぶ待つたらしい形跡がある、私も樹明君もゐなくて、かへつてよかつた、よかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しおかづは手輕だ、葡萄豆と紫蘇卷と燒海苔と鹿菜と蜊貝のお汁………品は多いが、一ツとして胃の腑の充たすに足りるやうな物はない。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ実の入らない果実、塩｜煎餅、浅草｜海苔、牛乳の含まぬキヤンデイ、――食品目は偏つて行つた。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川｜海苔を細かく忍ばしてある。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、海苔茶漬にしよう。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」最も簡略のおかずのつもりで海苔を所望したのだが、しくじった。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにふるへ、かくれつつうかがひのぞく榎あり、いのりつつ、一心に幹をけづりしに、樹樹はつめたく去り行けり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
