    },
    "definitions": [
      {
        "index": 1,
        "gloss": "payment (of taxes, fees, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その頃、安二郎は廃球以外に新品の電球も扱っていて、電球工場から仕入れたのを地方の会社や劇場に納入する一種の仲買いの様なことをしていたが、時々｜刺青のたあやんと称する男が、五百個千個と電球を売りつけに来るのを安い値で買いとっていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニラのキャッポ区に雑貨商を出している太田恭三郎が、アメリカ当局と交渉して、ベンゲット移民への食料品納入を請負い、味噌、醤油、沢庵、梅干などを送って来てくれたのは、そんな時だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金属ソジウムは中々高価な薬品なので、多量は手に入らないのが普通であるが、幸にも研究所へは先頃三十キログラムほど納入され唯今彼の許で試験をすることになっているから、これを持ち出して使えばよい。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に収入のあつた場合にその五分の一を納入するのみで、吾家の食堂に酒樽を備へつゞけるであらうと主張した酒造家が居た。",
              "citation": {
                "source": "ゾイラス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "炊事場の手までが足りなくなつてＮのコツクは、もう大分前から凡ての炊事長になつて、食料品の納入係に忙しかつた。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕作の全過程から、乾燥し、納入して金に代へるまでの一切が、煙草組合といふ團體の責任で行はれ、一人一人の組合員が、これはおれの葉、これはお前の葉、といふ考へにとらはれることなく、ひたすらに全體の葉をよく仕上げる、といふ熱意だけで動くやうにならねばだめだらう。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "年貢米の納入時期、およそ一ヶ月間は、地主はずつと家にゐて、ふだんはどこか餘所にゐるものも歸つて來て、親しく小作人に面接するのが常である。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "直接小作料の問題で立ち上る氣力のない貧農、又は立ち上つても會費を納入し、恒久的な組織に保持しえない貧農についてである。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "財産税の処理方法は多額納入者により便宜な支払方法を決められた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで三百余人とられ、野菜作物は四割だめ、麦納入不能。",
              "citation": {
                "source": "大衆闘争についてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計検査上の都合から、ＳＥＮＡＣは一九五八（昭和三十三）年三月に取りあえず東北大学に納入されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "未完成のまま納入され、仙台で手直しを繰り返しただけに、図面上には論理の誤りもかなり残されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井の指導を受けながら悪戦苦闘の末に仕上げたマシンは、ＮＥＡＣ―１１０３と名付けられてようやく納入にこぎ着けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "基本ソフトウエアのトラブルは許されないとはいえ、納入先がはっきりしているオフィスコンピューターならまだしも責任の取りようがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてこのプログラムを収めた紙テープがＤＥＣのミニコンピューターを納入した大学や企業に流れては、各所にゲーム中毒患者を発生させた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらためてテレルをバイトショップに訪ねたジョブズは、組み立てとテストをすませた状態で納入するという条件で、一挙五〇台のアップル※の注文を取りつけた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレルとのあいだで合意した納入価格は、一台およそ五〇〇ドル。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦二人だけで始めた会社はこれまで、オフィスコンピューターの販売とメインテナンス、加えてマシンの納入先からの開発依頼をこなし、第二次オイルショック後の苦しい時期をどうにかこうにか乗り切ってきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又一方に組合費の納入成績はグングン下落して、何とも云いもしないのに、タッタ一人の事務員が尻に帆をかけるという奇現象を呈する事になったが、それでも吾輩喜んだね。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして専務と談合の末、製品は或る価格で中本に譲り、中本は或る価格で銅線を納入するという、甚だばかげた妥協に結着したようでした。",
              "citation": {
                "source": "水甕",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月末日までに品物の納入完了という契約であるが、早いほど良いからというペルメルのサイソクであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "久五郎は泣きほろめいて多門を詰問しカケ合ったがダメの物は仕方がないから、ギリギリの八月末日に自分の買い集めた五万五千斤だけ横浜へ届けて、契約の期限は今日だが、あと十日だけ待ってくれ、残りの四万五千斤はそれまでに必ず納入するから、と懇願した。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束の期限までに納入しなかったことと、五万五千斤のクズ糸をつかませようとしたカドによって、五十万ドルの罰金を要求した。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判の結果、罰金二十万ドルでケリがついたが、納入の二十五万斤とクズ糸五万五千斤はただ取られで、一文の支払いも受けられない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして績ぎ蓄めた藕絲は、皆一纏めにして寺々に納入しようと言ふのである。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また現に、日本の出版物は全部この館に納入することを法律は定めており、それの目録は印刷して、全国の図書館に流すことになり、昨年末から実行しているのである。",
              "citation": {
                "source": "巨像を彫るもの",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日既に原子炉は、葉書一枚出して註文すれば、ちゃんと造って納入してくれるところまで、世の中は進んでいる。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあいい、税を払わんのだから」　ところが、翌年の課税として金九フラン五十サンチーム納入すべしという新しい白箋を受け取った。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もし貧弱な土地の農業者が、極めて長期の借地契約を利用して、大なる費用をもって、施肥、灌漑、囲墻等によって、彼れの土地の生産力を増進せしめる気になるならば、彼は、地主に支払われる実際の地代に比例してではなく、土地の実際の年々の価値に比例して、救貧税を納入するであろう。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかることが遂行されるために本年二月公布の法律によって、各出版物は、必ず一部ずつ国立国会図書館に納入さるべきであると規定しているのである。",
              "citation": {
                "source": "国立国会図書館について",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
