[
  {
    "uuid": "54934124-c854-5f7f-a33b-b7e25dba9784",
    "entry": "延び延び",
    "reading": {
      "primary": "のびのび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
