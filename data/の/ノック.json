        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "額の油汗拭わんと、ぴくとわが硬直の指うごかした折、とん、とん、部屋の外から誰やら、ドアをノックする。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノックは、無心に、つづけられる。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良はレムブルグの寝室の扉をノックした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "露台でハヤミは僕を賞讃して、愛を誓った　のだが、翌日、ホテルの僕の部屋、ノックするとＹが飛込んできた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "形のいい鼻の粗い魅力がうす黒い建物に吸いこまれると灰色のホテルの壁にそって彼女の影がコンクリートの階段を中年女の靴音をのこして一歩、一歩、女の強い忍従が右に折れると、或る部屋の扉を繊奢な澱みもなく暴々しくノックした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、夙川のアパートメントの独身部屋をノックする音で私は眼ざめました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "皺だらけの私の寝室をノックする音がして、暗闇から出た女の手が、楕円形の天井をみつめていた私の目前で葡萄蔓のようにからんで、青いリノリウムのうえにMELINSの扱帯が夜光虫のように円をつくると、私は断截された濡れた頭髪を腕の中に感じて、いつのまにか恋愛のマッフのなかに、ひとときの安息を求めた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてその部屋の戸をジムがノックしました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノックするとは這入ってもいいかと戸をたたくことなのです。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の足音を聞きつけてか、先生はジムがノックしない前に、戸を開けて下さいました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣のドアがけたたましく開いたと思うと清逸のドアがノックされた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の部屋をノックして急な帰京を知らせると、そこにい合わせた三人は等しく立ち上って、少し頓狂なほど興奮して園を玄関まで送ってきた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫除けの網戸を開けて戸をノックした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはみんなにも挨拶して廻り、所長が出て来るや否や、その扉をノックしてはいって行きました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、ドアをノックする音が聴えた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、ドアをノックする音が聞えた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、電話を掛けようとした途端に伊都子がノックしたのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜伊都子が信吉の部屋をノックしたのも、信吉が電話を掛けようとしていた時だった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時軽く戸をノックしたと思うと、本家の養女の寿々千代の愛子が顔を出し、続いて見知らぬ男が一人戸口に現われた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "やまは娘が、私の仕事時間を済ましてから来て欲しいと言伝てたが、いっそ、今、直ぐ独断に娘を二階の部屋へ訪ねてみよう――　二階の娘の部屋の扉をノックすると、私の想像していたとはまるで違って見える娘の顔が覗いて、私を素早く部屋の中へ入れた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう言いさして夫人は門の中へ消えたが、やがて階段を上って来て部屋の戸をノックする。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと様子をさぐってみようと思って、ドアをノックしてみたが返答は無い。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアをノックしているようでもありませんし、まどを外からたたいているようにも、思えませんでした。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、ノックしていたのはきみか。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしはさっきから、ノックしていました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれど、わたしは、強くノックすることができません。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人のきょうだいたちと、いっしょにするときは、もっと強く、ノックできるのですけれど。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、その間に属官が三度ばかりきまってコツコツとノックするのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
