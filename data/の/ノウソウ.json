[
  {
    "uuid": "a74b1c27-7cdb-55f3-94a3-cfa933e766de",
    "entry": "能相",
    "reading": {
      "primary": "のうそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
