              }
            },
            {
              "text": "きのうきょうとは思えども、数うれば早やふた月を過ぎて、きょうはあたかも御命日じゃぞ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう少しざっくばらんにいってくださいよきのうきょうのお交際じゃなし。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウ先のことだけれど、きのうきょうのように思われますよ。",
              "citation": {
                "source": "忘れ形見",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰あきのうきょうの新参者だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうきょうの伝六様の十手あしらいは気合いが違うんだ、気合いがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしく、この野郎は、きのうきょうの騒動につけ込んだただの切り取り強盗ですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、きのうきょうののど笛騒動が長引いているんで、それにつけ込んでの荒仕事やったんだろう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおかた、この連中がよからぬお家横領のたくらみを起こして、お殿さまをそそのかし、まずじゃまになるやつから先に遠ざけようと、忠義無類のあんたのお父御さまを閉門のうきめに会わせたんでしょうね」「はっ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
