    "definitions": [
      {
        "index": 1,
        "gloss": "through (e.g. an intermediary, a medium)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "郭光はこれを介して謝源に渡した。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "淺見君に會つたそもそものはじめも彼を介してである。",
              "citation": {
                "source": "淺見淵君に就いて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は絵の具を介して筆尖でこの怪物の面を押し擦るタッチのうちに病友がいかにこの腫物を憎んだか。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "料亭など借りるのは出来過ぎているし、寮は人を介して頼み込むのが大仰だし、その他に頃合いの家を探すのであるが、とかく女の身は不自由である。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆ど同時に仲人を介して結婚を申し込んでいる智子の家と同じ地主仲間の北田家の当主三木雄は盲目青年の上、教育もなし、まるで周囲の問題にされていなかった。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて景一光広卿を介して御当家御父子とも御心安く相成りおり候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が英語が出来るというので、僕の家の人を介して、井筒屋の主人がその子供に英語を教えてくれろと頼んで来た。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂に七月五日に、氏直は愈々窮して弟氏房を伴って城を出て、家康を介して降服を申し出でた。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、博士との直接的な感情ではなく、博士の令嬢を介して初めて感じられる間接的な感情であった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みやすさという問題は残しながらも、ネットワークを介して本を読みに行くことは、かなり前から現実のものになっていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて新しい器には、ネットワークを介してきわめて素早く移動させうるという、古い器になかった際だった特長があります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなふうに穏やかなものだから、久しく訪ねて行かなかった時分に、ひどいことを私の妻の家のほうから、ちょうどまたそのほうへも出入りする女の知人を介して言わせたのです。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし予も今に余暇ごとに研究を続けおり、これより外に一言も洩らさぬ故、例の三銭の切手一枚封じ越したり、カステラ一箱持って遥々錦城館のお富（この艶婦の事は、昨年四月一日の『日本及日本人』に出でおり艦長などがわざわざ面を見に来るとて当人鼻高し）を介して尋ね来りしたってだめだと述べ切って置く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど瑞村と余とは香峰を介して人物性行を傳聞せしのみにて、未だ相識らざりしなり。",
              "citation": {
                "source": "月の隅田川",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――此度小生に於て、買占め置き候貴下に対する債権に就て、御懇談いたしたきこと有之、且つ先日杉野｜子爵を介して、申上げたる件に付きても、重々の行違有之、右釈明｜旁々近日参邸いたし度く――あゝ何と云う図々しさだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、折々母を介して簡単な二言三言を交える丈だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、今度は谷中派の方からかえって和解を申し込んで来たりして、両派に関係のあった人たちを介して会員になりたいなど続々申し納れがあったりしました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "発会当時およびその後のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで柏木家から改めて師匠を介して三枝家へお綾さんを貰いたいと申し込んだのです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は僕の胸のうちにあるアルキメデスの測進器に寄り、風を介して、無言の現実と親しむのである。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋経験の立場は「自覚における直観と反省」に至って、フィヒテの事行の立場を介して絶対意志の立場に進み、更に「働くものから見るものへ」の後半において、ギリシャ哲学を介し、一転して「場所」の考に至った。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三度人を介して談判したが、埒があかない。",
              "citation": {
                "source": "『十八時の音楽浴』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――此度小生に於て、買占め置き候貴下に対する債権に就て、御懇談いたしたきこと有之、且つ先日杉野子爵を介して、申上げたる件に付きても、重々の行違有之、右釈明｜旁々近日参邸いたし度く――あゝ何と云ふ図々しさだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、折々母を介して簡単な二言三言を交へる丈だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田と源次を介して、彼等に近づく機會を得たいといふ望みを、駿介はかねてから持つてゐたが、まだその時を得なかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし直接にか、誰か人を介してか、……兎も角、話してみませう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "○演技指導とは演出者が「俳優たちの」肉体を介して、作中人物の創造に参与し、これを具体化し完成せしむることによって自己を表現せんとする手続きをいう。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者なり監督なりが直接見物に話しかけるということはないので、すべて俳優の演技を介してものをいうのであるから、俳優の演技というものはずいぶん重要な役割を受け持つているわけである。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘事ながら、第一部を通讀したしるしにと言つて、織田正信君を介してその愛藏する『慊堂遺文』二卷を贈られ、自分を勵まして呉れたＹ博士のやうな人もあつた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四　正月になってから、別れた後をいくらか潔くしておきたい気持で、かなり纏まった金を舞踊の師匠を介して、今度は全く自発的に葉子に贈ることにした。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
