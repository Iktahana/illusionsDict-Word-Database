          "literary": [
            {
              "text": "君チャンハホットシテ、ネガエリヲウッテ、足ヲチヂメテ、ネルノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガカタカナノ場合ハソノ成立ノ歴史カライツテモ楷書ノ漢字ノ一部分ヲチヨツト失敬シタマデデアルカラ、コレガ楷書ノ字ト一緒ニ並ンデイルトコロハアタカモ親ト子ガ並ンデイルクライヨク調和スル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏ノ夜ノ河原ノミズガ血ニ染メラレテ　ミチアフレ声ノカギリヲチカラノアリッタケヲオ母サン　オカアサン断末魔ノカミツク声ソノ声ガコチラノ堤ヲノボロウトシテムコウノ岸ニ　ニゲウセテユキ　それらの声はどこへ逃げうせて行っただろうか。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏ノ夜ノ河原ノミヅガ血ニ染メラレテ　ミチアフレ声ノカギリヲチカラノアリツタケヲオ母サン　オカアサン断末魔ノカミツク声ソノ声ガコチラノ堤ヲノボラウトシテムコウノ岸ニ　ニゲウセテユキ　それらの声はどこへ逃げうせて行つただらうか。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "pixiv は絵を投稿する所だと思っていてあまりヲチせず気づかなかったのですが、山樹さんの訳（http://www.pixiv.net/novel/show.php?id=299703）があったのですね。",
              "citation": {
                "source": "羊飼いハイタ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "山羊サン　ハオヒゲ　ヲチヨキン　ト切ツタノ。",
              "citation": {
                "source": "カハイイ　山羊サン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "タカヲチヤンノウチハ　クルリト　カラタチノカキヲマハツタ　アソコダ。",
              "citation": {
                "source": "ゴムフウセン",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラタチノ　カキノナカカラ　タカヲチヤンガ　ヨンデル。",
              "citation": {
                "source": "ゴムフウセン",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクウレシクテ　ウレシクテ　タカヲチヤンノウチノ　ゴモンノハウヘ　カケテツタ　カケテツタ。",
              "citation": {
                "source": "ゴムフウセン",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "バス・カーテンノ裂ケ目カラ、彼女ハトキ／″＼肩ダノ膝ダノ足ノ先ダノヲチラツカセタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤モ、予ト二人キリノ時ニ限ッテワザト昔ノ俤ヲチラツカセルコトハアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次ニ布団綿ヲチギッテ大キイノハ六七センチ、小サイノハ二センチグライノ丸ニ圓メ、紅絹ノ裂デ包ンデタンポヲ作ル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この天皇、トヲチの縣主の祖先のオホメの女のクハシ姫の命と結婚してお生みになつた御子は、オホヤマトネコ彦クニクルの命お一方です。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コンヤジュウニジヲチュウイセヨ」　文面は簡単だけれど、その意味は明瞭であった。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――内ヨリモ鉄砲｜矢数射尽シテ、切ツテ出テ働クヲ、兄弟、火花ヲチラシ、つばヲ割リ、ココヲ先途相戦フ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
