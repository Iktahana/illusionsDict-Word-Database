[
  {
    "uuid": "c3046cc3-a65e-5566-92db-00ace9036ae6",
    "entry": "を以て",
    "reading": {
      "primary": "をもって",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
