    "definitions": [
      {
        "index": 1,
        "gloss": "along (a wall, river, railroad tracks, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "王の血がフンドの指の間を伝い上って彼の傷へ届いたと思うと、傷は見るまに癒合して包帯しなくてもよいくらいになった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻と下女とをかわるがわる手伝いにやっていたが、立入って世話しているとまた癪にさわる事が出来て、罪もない妹に当りちらす。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神代ながらの俤ある大天井、常念坊、蝶ヶ岳の峰伝いに下りて来た自分は、今神河内の隅に佇んだ。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "深いところは、稀に膝以上まで水が来るが、頭の平ったい、太鼓の胴のような大岩や、頭だけ、微に水面に露している石が、入り乱れて立ったり、座ったりしているから、大概は、石伝いで飛ばされる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石・苔・偃松（白河内岳に登る記）　野営を撤して、濡れそうなものは油紙で包み、岩伝いに北を向いて、大籠山と後で名をつけた一峰に達した、三等三角測量標が立っている、霧が吹雨を浴びせかけて、顔向けも出来なかったが、白峰山脈で、初めての三角標に触れたのだから、ちょっと去りにくい気がした。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄花石楠花が、岩角の間に小さくしがみついて咲いている、その間を踏んで、登れば、千枚沢岳と悪沢岳の間に、赤石山が吊鐘を伏せたように円く立っている、支脈伝いに背面を見た時には、壮大だと思った白河内岳も、ここから見ると、可愛そうなほど、低くなって、下に踞くまってしまった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "間の岳は大断崖を隔てて北に聳えている、北岳はここからは見えない、峻急な山頂の岩壁を峰伝いに北に向けて直下する。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "羚羊・長之助草（北岳の絶巓に登る記）　それから尾根伝いに、間の岳の絶頂まで這い上り、三等三角測量標の下に立った、北西に駒ヶ岳（甲斐）の白い頭が、眼前の鋭い三稜形をしている北岳に、挟みつけられて見える、霧が来て散った。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中からは、ざんざ降りで、尾根伝いの笠ヶ岳登りを見合せて、蒲田谷へ下りるより、外にしようはなかった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つの小さな姿が、川岸伝いに、川上の捲上小屋に駆けて行くのが、吹雪の灰色の夕闇の中に、影絵のように見えた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして爪先下りのなだらかな道を下へ下へとおりて行く、ある人はどこまでも同じ高さの峰伝いに安易な心を抱いて同じ麓の景色を眺めながら、思いがけない懸崖や深淵が路を遮る事の可能性などに心を騒がすようなことなしに夜の宿駅へ急いで行く。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が牛舎の流しを出て台所へあがり奥へ通ったうちに梅子とお手伝いは夕食のしたくにせわしく、雪子もお児もうろうろ遊んでいた、民子も秋子もぶらんこに遊んでいた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上がってからおよそ十五、六分も過ぎたと思う時分に、あわただしき迎えのものは、長女とお手伝いであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は僕を手伝いとして山畑の棉を採ってくることになった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年生のときにＮ先生の研究の手伝いの傍らそれに縁のあるミラージに関する色々の実験をしたことも生涯忘れられぬ喜びであった。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年生のときはＴ先生の磁力測量の結果の整理に関する仕事の御手伝いをしながら生意気にも色々勝手な議論を持ちだしたりした。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の顔をして貝原は毎日水泳場へ手伝いに来た。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺れんちの薪を積む手伝いでもして呉れろよ。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八歳か九歳の時から鰯網の手伝いに行った。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯取りの池におみよの帯が浮かんでいた其の前の日の朝、この母子は練馬の方の親類に不幸があって、泊りがけでその手伝いに行かなければならないと云って、近所の人達に留守を頼んで出て行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて縁伝いに軽い足音が静かにきこえて、三、四人の人がここへ忍んで来るらしかったが、顔をあげてはならないと、この間の女がまた注意した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄太の女房も手伝いに行っていたが、半七の来たのを知ってあわただしく帰って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間の後、津浦線伝いに、賀耀祖の部隊が到着した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄条網を丸めて、片方にのけた狭い出口から兵士たちの列伍は、電柱伝いに行進した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、空気が淀んで床下の穴倉から、湿気と、貯えられた葱や馬鈴薯の匂いが板蓋の隙間からすうっと伝い上って来た。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　パルチザンは、山伝いに、カーキ色の軍服を追跡していた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて歩けるようになると私は杖をついて海岸伝いの道をあるいてみる。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておみちはそのわずかの畑に玉蜀黍や枝豆やささげも植えたけれども大抵は嘉吉を出してやってから実家へ手伝いに行った。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明な水のなかで鼠は左右に金網を伝い、それは空気のなかでのように見えた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前、俺は、ここの溪へ下りて、石の上を伝い歩きしていた。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
