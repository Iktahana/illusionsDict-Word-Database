        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」オニハ　コナヒダ　アヅカツタコブヲ　ツケマス　ミギノ　ホホオヤオヤ　トウトウ　コブ　フタツブランブラント　オモタイナハヅカシサウニ　オヂイサンムラヘ　カヘツテ　ユキマシタ　實に、氣の毒な結果になつたものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉花道から、大刀片手に大跨にヅカヅカと舞台へ来り、平土間に向って、Ｔ「文句が有ったら　上って来い」　観衆睨み乍ら舞台の端を行ったり来たり「文句ある奴何奴だァ」と怒鳴って歩く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵ヅカヅカと駕籠に寄り、垂れを上げんとした時、アッと叫んで蹴飛ばされる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「シカシキヅカイスルナ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」オニハ　コナヒダ　アヅカツタコブヲ　ツケマス　ミギノ　ホホオヤオヤ　トウトウ　コブ　フタツブランブラント　オモタイナハヅカシサウニ　オヂイサンムラヘ　カヘツテ　ユキマシタ　実に、気の毒な結果になつたものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナルホド、イママデ　キヅカズニ　ヰタガ、カナヅチハ　クワヲ　ツクル　コトガ　デキルノダナ。",
              "citation": {
                "source": "カナヅチ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイヘン　シヅカナ　ムラデ　イヌノ　ナキゴヱモ　キコエズ、イエイエノ　マドハ　ミナ　カタク　トザサレ、ガイトウニハ　ヒガ　トモツテ　ヰマセンデシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケフハ　ガチヨウサンノ　タンジヨウビデスカラ　オデカケ　クダサイ」「ア、サウデスカ」「トコロデ、イタチサン、ヒトツ　オネガヒガ　アルノデスガ」「ナンデスカ」「アノ、スミマセンガ、ケフダケハ　オナラヲ　シナイデ　クダサイ」　イタチハ　ハヅカシクテ、カホヲ　マツカニ　シマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "アペンニノの森林、豪貴の人々の別莊の其間に碁布せるピアツツア、デル、グランヅカ、其外美しき古代の建築物など、その言ふところ人をして目のあたりに見る心地せしめき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍服着たる一老人、若しその奇術奇ならざるときは、われは我が「ヅカアチイ」二個（約三圓三十八錢）を取り返すことを得んかといひしに、ポツジヨは我に代りて、若し疑はしとおもひ給はゞ、夥伴に入り給はでもあるべきにと答へぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ミヅカマキリ有吻類だつたかしら？",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "門から直ぐ左に折れた、ヅカ／＼と小使室の入口に進んだ。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と挨拶するさうで、初めて警察へ行つた時は、案内もなしにヅカ／＼事務室へ入つたので、深野と云ふ主任警部が、テッキリ無頼漢か何か面倒な事を云ひに來たと見たから、『貴樣は誰の許可を得て入つたか？",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、極りが惡さうにした顏に一寸眼を光らして、ヅカヅカ入つて來た。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と挨拶するさうで、初めて警察へ行つた時は、案内もなしにヅカ／＼事務室に入つたので、深野と云ふ主任警部が、テツキリ無頼漢か何か面倒な事を云ひに来たと見たから、『貴様は誰の許可を得て入つたか？",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "門から直ぐ左に折れて、ヅカ／＼と小使室の入口に進んだ。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、極りが悪さうにした顔に一寸眼を光らして、ヅカヅカ入つて来た。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "少ナクトモカナヅカイノ問題ヨリハハルカニ単純デアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌ミヅカラ△自│　　└オノヅカラ二月一日　晴曇。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "エエ最う一本燐燧が有ればと思う折しも、背後の方に荒い足音が聞こえて誰かヅカヅカと這入って来た。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、なにを考えたものか突然彼は、ふたたびとってかえすと、障子をガラリと開け、靴のままヅカヅカと、松山の寝床に近づいたが、ポケットから点火器をとりだして、カチッと火をつけると、左手で静かに枕元の方へさしだし、一方の右手を伸ばして夜具の襟をグッと掴むと、ソッと持ちあげてみた。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
