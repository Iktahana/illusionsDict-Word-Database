    "definitions": [
      {
        "index": 1,
        "gloss": "wig",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "非常に根は虔しやかであるくせに、ヒヨツトした場合に突発的なイタヅラの出来る女だつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジブンガ　リツパナ　タイシヨウニ　ナツテ、ムネニ　ヅラリト　クンシヨウヲ　ナラベ、ピカピカ　ヒカル　ケンヲ　モツテ、ウマノ　上ニ　ソリカヘツテ　ヰル　ユメヲ　ミテ　ヰルト、ヤガテ　ヨガ　アケテ　アサニ　ナリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはじめの命名はヅランテなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "△久連石雨董――『仔馬』デッサンの不確かな割に、画面をよく生かしてゐる、殊に馬の鼻ヅラの鈍角な線は、よく仔馬を語つてゐる色彩も良い意味の甘さが流れてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "稍暫くたつて――（その間一郎は、用事があるからと呼んで置きながら、来て見れば黙つてゐるとは……とばかげた気持がしてゐた時）――漸く先生は、屹と此方を睨めて、「お前だらう、黒板にイタヅラ書きをしたのは――」と云つた。",
              "citation": {
                "source": "悦べる木の葉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪我をしてはならぬ、イタヅラをしてはならぬと、一々心配してゐたら手足を縛つて真綿にでもくるんで置かなければなるまい。",
              "citation": {
                "source": "家庭の読書室",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大魔神ヅラして、なんだよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちには野郎だつて、どこかへ引越してしまふヅラな。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が、達磨の頭を見あげて、「アノ、素てッぺんから、転ばり落ッこッタラ、如何ヅラァなァ！",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに惹かれて相手の者も、無造作に眼を挙げ、「粉になッちまふヅラァ！",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩を組み合せながら、トンネルの中を歩きながら、「アッハッハッ……粉になつてしまふヅラァ――は好かつたね。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京の中央公園で飼育されてるさまざまの奇怪豪華な金魚も、この一匹のウマヅラハギの姿態には及ばない。",
              "citation": {
                "source": "北支点描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この木の下にウマヅラハギを泳がしてみたら、面白かろう。",
              "citation": {
                "source": "北支点描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は嘗つてエヅラ・パウンドの書いた「ユリシイズ論」を讀み、そのうちでジョイスがフロオベルに大へん似てゐることを指摘してゐるのを、ちよいと面白いと思つたが、この頃はますますその感が強い。",
              "citation": {
                "source": "日付のない日記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○面ヅラ切らした馬。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "面ヅラ「面綱」の訛りで、馬の額から頤下にまはして結んだ綱である。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と叱つてもぬかに釘の道楽息子を爺さんが叱る場合に、「面ヅラ切らした馬エンタ奴だ」といふ。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "因みに人間の場合、両耳から頤にかけて生やした髯（所謂天神髯か）を当地方では、「面ヅラ髯」といふといふ。",
              "citation": {
                "source": "津軽地方特有の俚諺",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "華族崇拝だの封建性だのと目クジラだてて民主ヅラをひけらかすのは当らない。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自らのみ道義あつく、心正しきものとする為政家ヅラほど浅はか、醜悪なものはない。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は一生、浮ぶ瀬がなくなるわけなんです」　数学、物理化学が丁、英語も丁、漢文と国語が丙、よくぞ申したり、アッパレな奴で、どんなに仏頂ヅラで怒っていても、たいがい腰がくだけてしまう。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだって仏頂ヅラをするんだい。",
              "citation": {
                "source": "無毛談",
                "author": "――横山泰三にさゝぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分のヒゲヅラがきらいである。",
              "citation": {
                "source": "三十歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私のヒゲヅラが気にかゝっていたのを忘れない。",
              "citation": {
                "source": "三十歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "全然笑顔を忘れた仏頂ヅラであるが、これも亦、初々しいという感じで、人に不愉快は与えない。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソプラノ嬢も三人の旦那方の愛想のよいトリナシに機嫌を直して、仏頂ヅラの合間に、今までにない含み笑いなどを浮かべる。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "結句ツネメヅラシキと訓んで居り、いずれでも好い。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑はれる織田は一向に軽薄ではなく、笑ふ人の方が軽薄なので、深刻ヅラをしなければ、自分を支へる自信のもてない贋芸術の重みによた／＼してゐるだけだ。",
              "citation": {
                "source": "大阪の反逆",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎の伝統の中で女の躾を身につけたソメちやんだから二の腕を見せてもすくみ羞らふサムライの娘カタギ、それが一そう酔客のイタヅラ心をそゝつて、はては掴へてハダカにする。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと違つて、何の技巧も施さず自然にお客がよつてくるのだから、たゞもう時代の寵児、単なる時代のイタヅラの私生児のやうなものでもあつた。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
