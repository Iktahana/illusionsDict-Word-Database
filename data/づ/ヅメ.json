        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕の直ぐ隣にはばかに肥つた男がゐて、僕は追ひ詰められたやうになつて腰掛けてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつも和服――特に浴衣を好んだ――を着、畳の上に正坐し、日本の煙管で刻煙草を詰めて吸ってた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈の暗い入口であつたけれども、かう言つて私に詰め寄つた時の芥川君の劍幕は、可成りすさまじいものであつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然は相当に美しいが、何分近在の百姓が大勢詰めかけるので、伊香保そのものの空気が、まるで田舎の温泉場に変つてしまふ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子を取って恭しく子規の家を尋ねたが知らぬとの答｜故少々意外に思うて顔を見詰めた。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "危篤な病人の枕もとへはおおぜいの見舞い人が詰めかける。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ光の弱い太陽を見詰めたが金の鴉も黒点も見えない。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は枕元の火鉢の傍で縫いかけの子供の春着を膝へのせたまま、向うの唐紙の更紗模様をボンヤリ見詰めて何か考えていたが、思い出したように、針を動かし始める。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲隠れする最後の一角まで、追い詰めるように視線を投げた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて雪に触れたのは、七、八合目の間であった、殊に八合目の室だけは、どういうものか、半ば戸が開いて、中の水桶には厚氷が張り詰めている、誰かが捨てて行った手拭は、板のように硬くシャチ張っている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝込みを踏み込みやがったな）　彼は、本能的に息を詰めた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、第三金時丸は、三千三十噸の胴中へ石炭を一杯詰め込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "発破と度胸競べなんざ、真っ平だよ」　こんな訳であって、――どんな訳があろうとも、発破を抑えつけるなんて訳に行くものではない――岩鼻火薬製造所製の桜印ダイナマイト、大ダイ六本も詰め込んだ発破は、素晴らしい威力を発揮した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三本の発破が、岩盤の底に詰められて、蕨のように導火線が、雪の中から曲った肩を突き出していた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには私の過去の道筋で拾い集めて来たあらゆる宝石や土塊や草花や昆虫や、たとえそれが蚯蚓や蛆虫であろうとも一切のものを「現在の鍋」に打ち込んで煮詰めてみようと思っている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また片方の尖っている方が親鳥の腹の下へ沢山詰め込むのに都合がよいからだという説もある。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思ってかさにかかって翁の娘の神に詰め寄りなじりかかろうとする刹那に神楽の音が起り祭が始ってしまった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆が入り代り立ち代り問い詰めても、昭青年はただ「鯉魚」と答えるだけでした。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、体はとてもいい状態で、ただこうやっているだけで、とろとろしたいい気持ちで、よっぽど気を張り詰めていないと、気にかけなくちゃならないことも直ぐ忘れているんだ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はやや茶の間の方へ退りながら「誰が出すもんか」と小さく呟いていたが、柚木が彼女の眼を火の出るように見詰めながら、徐々に懐中から一つずつ手を出して彼女の肩にかけると、恐怖のあまり「あっ」と二度ほど小さく叫び、彼女の何の修装もない生地の顔が感情を露出して、眼鼻や口がばらばらに配置された。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは蝸牛の肉を茹でて軟かくしたものを上等のバタと細かく刻んだ薄荷とをこね合せたものと一緒にして殻に詰めるだけのことである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯草を詰めた木沓のダンスを懐かしく思ふのだ。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婀娜っぽい、かろらかな微笑の裏に、真摯な熱い涙のほのかな痕跡を見詰めたときに、はじめて「いき」の真相を把握し得たのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後ろを引詰め、たぼは上の方へあげて水髪にふつくりと少し出し」た姿は、「他所へ出してもあたま許りで辰巳仕入と見えたり」と『船頭深話』はいっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯に立っていた中年の下町女が何気なしにバスの間を覗いていたがふと自分の前の少女を見付けてびっくりしたような顔をして穴の明くほど見詰めていたようである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三十尺の高さに噴き上げている水と蒸気を止めるために大勢の人夫が骨を折って長三｜間、直径二インチほどの鉄管に砂利をつめたのをやっと押し込んだが噴泉の力ですぐに下から噴き戻してしまうので、今度は鉄管の中に鉄棒を詰めて押し入れたらやっと噴出が止まった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長自身は、さしづめ一國の宰相とでもいふやうなところであつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしづめ、彼は教養ある「姉さん」なのだが、しかしそれにしては、ほんの少しながら物質観味の混つた、自我がのぞくのが邪魔になる。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "波宜亭少年の日は物に感ぜしやわれは波宜亭の二階によりてかなしき情感の思ひにしづめり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天の川の水あかりに、十日もつるして置くかね、さうでなけぁ、砂に三四日うづめなけぁいけないんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
