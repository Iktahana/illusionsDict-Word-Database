[
  {
    "uuid": "465ac1a6-204f-5f57-989a-5855a6d69961",
    "entry": "採用",
    "reading": {
      "primary": "さいよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
