    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drizzle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水色絹の簾の縁がしつとりと濡れて居り、簾の生地の竹の手觸りの冷え／″＼しさに、目をとめて見れば、いつの程よりか外には時雨のやうに冷い細雨がしとしとと降つて居たのである。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　小田原は街まで長い其入口まで來ると細雨が降りだしたが、それも降りみ降らずみたいした事もなく人車鐵道の發車點へ着いたのが午後の何時。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "細雨に暮れなんとする山間村落の生活の最も靜かなる部分である。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "事實、此世に亡い人かも知れないが、僕の眼にはあり／＼と見える、菅笠を冠つた老爺のボズさんが細雨の中に立て居る。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は薄曇つたまゝで、三日の間はつきりした日の目を見せなかつたから、今日あたりは秋雨のやうなうすら寒い細雨が降るのだらうと彼れは川上から川下にかけてずつと見渡して見た。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその時は二百十日前後の天候不穏、風まじりの細雨の飛ぶ暗い夜であるから、午後七、八時を過ぎると殆ど人通りがない。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "路は屡々記す通りの難所である、加之も細雨ふる暗夜である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧に似たる細雨は隙間もなく瀟々と降頻って、濡れたる手足は麻痺れるように感じた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織は細雨に遭つたやうにしつとりと濡れてゐて、白い水蒸気が渦巻くやうに立つた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "横へ切れて田畝道を、向ふへ、一方が山の裙、片傍を一叢の森で仕切つた真中が、茫と展けて、草の生が朧月に、雲の簇がるやうな奥に、祠の狐格子を洩れる灯が、細雨に浸むだのを見ると――猶予はず其方へ向いて、一度斜に成つて折曲つて列り行く。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その日も朝から細雨が降っていたが、暮れ六つごろからやんだ。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "細雨に烟る長汀や、模糊として隱見する翠の山々などは、確かに東洋の繪だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "細雨に烟る長汀や、模糊として隠見する翠の山々などは、確かに東洋の絵だ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に川中島は前夜細雨があったためか、一寸先もわからぬ濃霧である。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その挨拶ながら私が赤坂の家をたずねたのは、あくる日のゆう方で、六月なかばの梅雨らしい細雨がしとしとと降っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんやまたこの時金風｜淅々として天に亮々たる琴声を聞き、細雨｜霏々として袂に滴々たる翠露のかかるをや。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま伊東深水氏の「細雨」の表現をみれば勿論さうした表現の、用意に欠けてゐることはないが、もう一つの用意をそこに発見する、それは線や点で雨を描いただけで果されない効果といふものを他に求めてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "打惑ひて入りかねたる彼の目前に、可疑き女客も未だ背けたる面を回さず、細雨静に庭樹を撲ちて滴る翠は内を照せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばし休憩する程に、細雨至りぬ。",
              "citation": {
                "source": "鹿島詣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "（細雨ふりいず、玉虫は空を仰ぐ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "看れども見えざる細雨を衝いて、香取祠に詣づ。",
              "citation": {
                "source": "北總の十六島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮れむとして、細雨ふりかゝる。",
              "citation": {
                "source": "吾嬬の森",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも其の時は二百十日前後の天候不穏、風まじりの細雨の飛ぶ暗い夜であるから、午後七、八時を過ぎるとほとんど人通りがない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが九月二十四日の午後この山に登った時には、麓の霧は山腹の細雨となって、頂上へ来ると西の空に大きな虹が横たわっていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "入梅に近いこの頃の空は曇り勝ちで、きょうも宵から細雨が降っていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は朝から陰っていて、霧だか細雨だか判らないものが時どきに山の上から降って来て、山ふところの宿は急に冬の寒さに囲まれたように感じられた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発の朝はどんより陰って、なんだか霧のような細雨が時々に降って来るらしいので、どうしようかと一旦は※躇したのですが、汽車の時間まで先方へ報らせてあることでもあり、却ってこんな日の方が涼しくていいかも知れないとも思ったので、わたくしは思い切って家を出ました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "出るときに空を仰ぐと暗い雲はだんだんに倫敦の上を掩って、霧のような冷い細雨がほろほろと帽子の庇に落ちて来た。",
              "citation": {
                "source": "倫敦の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから四日ほど過ぎると朝から細雨が降った。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋平に宿った晩には細雨が寂しく降っていた。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
