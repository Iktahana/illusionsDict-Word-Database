[
  {
    "uuid": "fe9fa800-15c7-56c4-91e2-cd2f578f3613",
    "entry": "才人",
    "reading": {
      "primary": "さいじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
