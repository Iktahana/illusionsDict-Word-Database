[
  {
    "uuid": "03d01810-5ccf-5f15-9304-9db1adb4a951",
    "entry": "最前",
    "reading": {
      "primary": "さいぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
