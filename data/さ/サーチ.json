        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大学を卒業して大学院に入り、そうして自分の研究題目についていわゆるオリジナル・リサーチを始めてほんとうの科学生活に入りはじめたころに、偶然な機会でまた同時に文学的創作の初歩のようなものを体験するような回り合わせになった。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光の群れがサーチライトのように一団の大光明となって二人の真正面の窓から流れ込んで来て、金ピカずくめの応接間の内部を白昼のようにアリアリと照し出しているではないか。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の出ない前、碇泊中の独艦のサーチライトが蒼白い幅広の光芒を闇空に旋回させて、美しかった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝雲を破る太陽の如く、深夜を掃照するサーチライトの如く、全篇の生気を一挙に躍動させ初めるのだから大したものである。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いお盆がそれこそサーチライトのようにギラリギラリと輝きまわり屈折しまわる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピューターが８ビットの時代、ＯＳの標準の座を握ったのはデジタルリサーチのＣＰ／Ｍだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて吉本万寿夫氏は、デジタル・リサーチ（ＤＲＩ）の人だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが先頭を切ってＡＭＤチップの採用に踏み切ったＡＳＴリサーチに続いて、一九九一年の十月二十一日から開催されるコムデックスでは、新たな３８６互換チップ採用の声が上がるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころサーチライトで照らし出したほど部分的にわかるところがあるんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "７ぼくはひざまずいて祈ったそれが消えてくれるようにと〈ニードルズ・アンド・ピンズ〉サーチャーズ　翌七月二日は、寝不足と恐怖から、慶一は、なにがなんだかわからないままに午前中を終わった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと、今度は右手の沖合へ、仄明くサーチライトの光芒をひらめかして、大きく円を描きながら消え去って行った。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーチライトにしろ。",
              "citation": {
                "source": "父を売る子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が、面白可笑しく小走りに駈けて行くと、一直線の田圃道の遥か彼方に青白い光りが一点現れたかと思ふと、見る間にそれはサーチライトになり、僕の眼を射つた。",
              "citation": {
                "source": "センチメンタル・ドライヴ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋雨　雨は夜の野原をびしよ濡れにし、空を動いて行く青白いサーチライトの光も濡れてゐる。",
              "citation": {
                "source": "かげろふ断章",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇のなかにサーチライトはゆるく揺れ、少しづつこちらにむけられて来る。",
              "citation": {
                "source": "かげろふ断章",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は、星空をサーチライトの光が青白く、幅ひろく動いていました。",
              "citation": {
                "source": "二人の弟たちへのたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーチライトの交錯した灯が遠くに小さく見えた。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "節穴や隙間から日の光が白く射し込んで、サーチライトのやうにお駒と定吉との枕元を照らした。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く灯の海をなしている城内の方では、サーチライトが青い光を放って幾つも空中を駆け廻っていた。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタルリサーチ社を起こし、マニュアル込みのセット価格七〇ドルで売ることを決めると、一九七六年四月号の『ＤＤＪ』にウォーレンがまとまった紹介記事★を書いてくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "七万ドルの資本は、ベンチャー投資会社の先駆けとなったアメリカン・リサーチ＆ディベロップメント社から引き出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "異なったメーカーのマシンに採用されているＯＳとしては、デジタルリサーチのＣＰ／Ｍが唯一の存在だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発チームのスタッフはアメリカ大陸を東から西へと飛んで、カリフォルニア州モントレーのデジタルリサーチと、ワシントン州ベルビューのマイクロソフトを訪れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月の終わり、スタッフがデジタルリサーチを訪ねると、アポイントメントを取り付けていたにもかかわらずキルドールは席をはずしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "入り口で引っかかったまま、デジタルリサーチとの最初の会見は実りなく終わった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタルリサーチは、ヒューレット・パッカード（ＨＰ）社へのＣＰ／Ｍの供給交渉を進めている最中だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタルリサーチのＯＳとマイクロソフトの言語は、互いに依存しながらお互いの存在価値を高め合う、強力なコンビを組んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭにベーシック以外の言語も求められたマイクロソフトには、デジタルリサーチをこのプロジェクトに引きずり込んでともに全力疾走するか、言語とＯＳで棲み分けるという従来の協調関係を清算して、別の新しいＯＳに言語を対応させるかの二つの選択があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタルリサーチからの発売をこれ以上待っていられないと考えたパターソンは、一九八〇年四月、自分で８０８６用のＯＳを書きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＯＳはオプションにまわされていたが、マイクロソフトの開発したＰＣ―ＤＯＳに加えて、デジタルリサーチのＣＰ／Ｍ―86とソフテックマイクロシステムズのｐ―Ｓｙｓｔｅｍの供給も予定されていることが明らかにされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
