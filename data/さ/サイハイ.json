[
  {
    "uuid": "69b644f6-a425-5e9d-9b84-860167132f28",
    "entry": "再拝",
    "reading": {
      "primary": "さいはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bowing twice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "生命がけで、描いて文部省の展覧会で、平つくばって、可いか、洋服の膝を膨らまして膝行ってな、いい図じゃないぜ、審査所のお玄関で頓首再拝と仕った奴を、紙鉄砲で、ポンと撥ねられて、ぎゃふんとまいった。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯人　作す可からず、再拝して　還一｜哭す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此詩劉文貞に傾倒すること甚だ明らかに、其の高風大業を挙げ、而して再拝｜一哭すというに至る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "子路再拝して謝し、欣然として任に赴いた。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命がけで、描いて文部省の展覧会で、平つくばつて、可いか、洋服の膝を膨らまして膝行つてな、いゝ図ぢやないぜ、審査所のお玄関で頓首再拝と仕つた奴を、紙鉄砲で、ポンと撥ねられて、ぎやふんとまゐつた。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は再拝して泣いて訴えた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丁堀同心近藤右門の口は金鉄にござそうろうあいだ、おん秘密にすべきお喜久の方様のご条々は生々断じて口外いたすまじく、さればこれなる下人一匹、些少ながらご進物としてさし上げそうろうまま、一服盛りにでもご手料理くだされたくそうろう頓首再拝」　したため終わると、伝六、辰に命令一下。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "館機再拝具草、笑政。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何レ近日、再拝／＼。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年八月十三日　森玄道、伊藤助太夫あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "再拝河田佐熊先生　龍拝御直破",
              "citation": {
                "source": "手紙",
                "author": "慶応三年二月十四日　河田左久馬あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月廿五日龍馬　再拝。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年八月二十五日　佐々木高行あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十九年七月二十六日尾崎秀実頓首再拝　竹内老先生　玉案下追白、一番暑熱の必要なこの頃、この涼しさはお米のことが心配になります。",
              "citation": {
                "source": "遺書",
                "author": "尾崎秀実",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかおれはあの男が、海へ卒塔婆を流す時に、帰命頂礼熊野三所の権現、分けては日吉山王、王子の眷属、総じては上は梵天帝釈、下は堅牢地神、殊には内海外海竜神八部、応護の眦を垂れさせ給えと唱えたから、その跡へ並びに西風大明神、黒潮権現も守らせ給え、謹上再拝とつけてやった。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ever yours, ―― Yours truly, ―― Yours faithfully. … 頓首再拝（と書状を結ぶに相当）。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「頓首再拝つつしんで歎願奉り候」と書いたのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は東に向い一拝して香を焚き、再拝して退った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻がつゞいて再拝して香を焚き、三拝して退いた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして神国不滅だの、神風だのと信じていたのですからねえ、虚像を相手に、ひとり拍手再拝していたわけだな」「僕らの誠が足りなかったのです」「いいえ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑児｜矩方、泣血再拝して、家厳君、玉叔父、家大兄の膝下に白す。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "在巣鴨　　天道公平　再拝　針作君は九拝であったが、この男は単に再拝だけである。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにして一人その道に来たり会するありて、はるかに一老体の地に座して頓首再拝するを見て大いに怪しみ、近づきてこれを検するに、頭巾前に垂れて両眼を隠している。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の上のことを訊く者は、香を鼎に焚いて再拝した。",
              "citation": {
                "source": "促織",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんは頓首再拝して乃公にお礼を言って然る可き筈だ。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時も、急に席を下って、わしを再拝したのじゃ。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一（二四六）　他邦におる知人に使者をやって訪問させる時には、再拝してその使者をおくられる。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思った彼は、馬上に浜松城のかたを再拝して云った、「危急の場合とはいえ、われらごとき者の槍の石突をお当て申し、おん名を冒しまいらせた罪は万死に価すべし。",
              "citation": {
                "source": "死處",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中等教育の必要を説いた上に、事情を訴えて、「何卒右の儀、高等二学年修了以上の方々及び其父兄へ御懇話の上、一人にても二人にてもお遣し被下ば、邦家中等教育の為め、光栄これに如くもの無之候、頓首再拝」　と結んであった。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓首再拝新太郎寛一兄　新太郎君は斯ういう具合で、天候恢復以来｜頓に気が荒くなっていた。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下野の国府へ、軍勢が着くと、一戦を交じえる者もなく、勅司藤原｜公雅、大中臣定行などが、門を出て、地上に伏し、将門を再拝したといわれている。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとみんなのほんたうのさいはいをさがしに行く。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
