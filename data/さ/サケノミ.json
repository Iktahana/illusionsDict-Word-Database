    "definitions": [
      {
        "index": 1,
        "gloss": "(heavy) drinker",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
