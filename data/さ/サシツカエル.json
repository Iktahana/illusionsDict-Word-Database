    "definitions": [
      {
        "index": 1,
        "gloss": "to interfere (with)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今、少しでも眠って置かないと、明日の戦いに差し支えるだろう。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を歓迎した後なら大抵のものは歓迎しそうであるが、自分が朝夕に差し支える間は、歓迎は華族様に任せておく了見らしい。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをなすったら、あなたあしたの仕事に差し支えるでしょう。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "山中原野の特色などというものは、ともすれば千篇一律に堕して、二つあっては弁別に差し支える場合が多かった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日に差し支えるからである。",
              "citation": {
                "source": "パーティ物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "商店の方では事務にさしつかえるのでまた別の事務員を入れたが、その事務員も数日すると来なくなった。",
              "citation": {
                "source": "机の抽斗",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その孤児院の組織を見まするに、われわれの今日日本にあるところの孤児院のように、寄附金の足らないために事業がさしつかえるような孤児院ではなくして、ジラードが生涯かかって溜めた金をことごとく投じて建てたものです。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後から坪内先生のところへあがろうとしたが　夕飯の仕たくにさしつかえるのでやめ、小杉と云う書生が目見えに来た。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知っていないと、これから恐竜とのつきあいにさしつかえるからね」「そのことだが、恐竜は猛獣のように荒々しいともいえるし、そうでもないともいえるし」「なんだ、それじゃ、どっちだかはっきりしないじゃないか」「いや、はっきりしていることはしているのだ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的立場から自分も犯罪の種類も超越して云々」「公判が近づいているから」「イヤそういうこともですね、明日公判があってきょう腫物を切ってはさしつかえるというような場合でない限り考慮しません。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このポーニン氏は、身体の小柄ににあわず、ひどく心臓のつよい人物で、相当の金をもっているようにいっていたが、ときには宿屋の払いにもさしつかえることなどもあって、まことに複雑怪奇な人物というべき人物だった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事にさしつかえると、一日五百万円ぐらいずつ、穴をあけますから」　サシで話し合えば、もう、しめたもの。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "角力とりが座布団の上へ坐っていたって、民主々義にさしつかえるワケはないのだ。",
              "citation": {
                "source": "戦争論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そなた、さしつかえる事なくば、この屋敷に来てたもらぬか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、黒船の渡って来た嘉永年代からは、諸大名公役らが通行もしげく、そのたびに徴集されて嶮岨な木曾路を往復することであるから、自然と人馬も疲れ、病人や死亡者を生じ、継立てにもさしつかえるような村々が出て来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだまだ、圓遊には、愉快な逸話がいろいろあるけれど、それらは、あまり、書いてしまうと小説の方の材料にさしつかえるので、勝手ながら芸惜しみをさせてもらう。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百石のお旗本が五十両にさしつかえるとは……考えられないようだが不義理だらけで首もまわらず、五十はおろかただの五両にも事欠く源十郎であった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これでは食事にもさしつかえるから、妻君に病中の用事を達してもらいたい、君から頼んでくれるわけにはゆかぬかと、臆し、赤面しながら、極めて遠廻しにその意味をいった。",
              "citation": {
                "source": "黒い手帳",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "市民としての修養にさしつかえるからとでも云うのであろうが、労働課や調停課に行かずに特高部へ行ったのは、多分修養団が特高と仲が好かったからに過ぎないだろう。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は大楽しみをするからあまり前もって云って、何かさしつかえると実に相すまないから前晩までふせておいて、日曜日は栄さん、本間さんの細君、ひさ、私もちょいちょい手伝って、お釜二つに五目ずしをつくりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月一日は日曜日だし、二日はさしつかえるし、三日は疲れていてあやしいし、というわけできのう汗をふきふき出かけましたら、お目にかかれず残念でした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく食物にもさしつかえるようになりました。",
              "citation": {
                "source": "イワンの馬鹿",
                "author": "SKAZKA O IVANE-DURAKE",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなを助け出してやらんことには仕事にさしつかえるしね。",
              "citation": {
                "source": "探偵小説このごろ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そこで、書記代理が友人との会食か何かでさしつかえることがなければ、処刑命令の正本が作成され、書きあげられ、浄書され、送達される。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまになっておまえをとり戻そうというのは勝手かもしれない、けれど父上やこの母の気持も察してお呉れ、おまえの生れたじぶんは父上のご身分も軽く、子供を多くかかえて、恥ずかしいはなしだけれどその日のものにもさしつかえるようなことさえある、貧しく苦しい暮しでした。",
              "citation": {
                "source": "日本婦道記",
                "author": "糸車",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と思ったが、預け物のうち、竹刀はとにかく、皆伝の目録だけは、どうしても、持ち帰らなければ、屋敷へ戻って、父に怪しまれるし、明日の親類どもの披露の宴には第一にさしつかえる。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台にさしつかえるから、まあ鼻紙銭でも包んで行け』　と、芝居者が、駈けつけて来てみると、益太郎は、腰の海老鞘を閂に反り打たせて、『貴様は、そもそも、男か女か』　と、半四郎に、奇問を発している。",
              "citation": {
                "source": "田崎草雲とその子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
