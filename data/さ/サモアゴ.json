        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "というよりも、サモア語との交換教授だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「｜壜の魔物」をサモア語に訳して、オ・レ・サル・オ・サモア誌に載せ度き由。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月×日　昨夜八時半頃ロイドと自室にいると、ミタイエレ（十一・二歳の少年召使）がやって来て、一緒に寐ているパータリセ（最近、戸外労働から室内給仕に昇格した十五・六歳の少年、ワリス島の者で英語は皆目判らず、サモア語も五つしか知らない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この老人のサモア語の発音――殊に、その重母音の発音は美しい。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も今ではサモア語が読める。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）承知の旨をたどたどしいサモア語でしたためる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………」　古い、美しいサモア語の発音で、ゆっくりゆっくり語られる此の話は、大変面白かった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の貧弱なるサモア語の許す範囲で語合った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日スティヴンスンはサモア語で感謝の演説をした。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Papalangi とは、サモア語の白人という意味。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
