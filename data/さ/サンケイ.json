        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山景風光ともにすぐれて明るかつたが、階上のバルコンや寝室から仰ぐ夜空の美しさも格別であつた。",
              "citation": {
                "source": "書斎と星",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "山景野色も雪ありしとはおもはれず、雪の浅き他国に同じ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "山々の中腹に白く靄がたなびいて雨中山景です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……小鳥は枝から枝へとさえずりかわし、藪のなかには小さなけもののはしりまわる姿もみえる、まったく平和な山景色であった。",
              "citation": {
                "source": "梟谷物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで奈良のだいぶつさまにさんけいするみんなの絵のようだと一郎はおもいました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで奈良のだいぶつさまにさんけいするみんなの絵のやうだと一郎はおもひました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずしいので　さんけいの　人に　ものを　もらって　たべているのです。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも途中ちくぶしまへさんけいなさりたいと云う仰せでござりましたから、お女中がたやわたくしどもゝおつきそい申しあげまして、長浜よりお船にめされました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
