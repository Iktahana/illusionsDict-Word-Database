        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大学を出て一年ばかり郷里の日向で何をするともなく暮してゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは利根川、その氾濫のながめいちじるく、青空に桑の葉光り、さんらんとして遠き山里に愁をひたす、あはれ、あはれ、われの故郷にあなれば、この眺望のいたましさ。",
              "citation": {
                "source": "厩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬儀は郷里兵庫県で行ふとあり、息を引取つたのは、東京に於てだとあつた。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルスリーヌ・デボルド―※ルモオルは千七百八十六年七月の二十日にドゥエ（Douai）に生れ、千八百五十九年七月二十三日巴里で死んだ。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達は今卒業して、二人ともそれぞれの郷里に帰つてゆく。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "四里の道を歩いたこととて、足は脹れぼツたい。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里の方には大学に行つてゐることになつてゐたのが五年目にバレて、だから「親を欺いた者」でさへもあるのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年郷里に住むやうになつてから、その模型は庭の躑躅の蔭の平たい石の上に置かれてゐた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳述、私は明治四十年四月の末に生れ、その年十一月三日に郷里を母と母方の祖母と三人で立ち、四日乗船、六日大連着、そこで父に出迎へられ、（その父も今は亡き数、――安らかなれかし！",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日所感萩原朔太郎朝鮮人あまた殺されその血百里の間に連なれりわれ怒りて視る、何の慘虐ぞ",
              "citation": {
                "source": "近日所感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千九百十七年十一月九日郷里にて萩原朔太郎",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も、なかなかの、田舎者ですが、私のさとは、彼の生れ在所より、更に十里も山奥でありますから、何をかくそう、私は、もっとひどい田舎者なのであります。",
              "citation": {
                "source": "田舎者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは妻の里の甲府市へ移った。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどなく暑中休暇にはいり、東京から二百里はなれた本州の北端の山の中にある私の生家にかえって、一日一日、庭の栗の木のしたで籐椅子にねそべり、煙草を七十本ずつ吸ってぼんやりくらしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして馬場のひとりごととは千里万里もかけはなれた、つまらぬ感傷にとりつかれていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田さんが郷里へお帰りになりましたので、私共も心細く存じておりましたところ、昨年の暮に、大隅さんから直接、私どものほうへお便りがございまして、いろいろ都合もあるから、式は来年の四月まで待ってもらいたいという事で、私共もそれを信じて今まで待っておりましたようなわけでございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例として桜狩美人の腹や減却す人間に鶯鳴くや山桜　人里離れた深山の奥、春昼の光を浴びて、山桜が咲いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら蕪村の場合は、侘びが生活の中から泌み出し、葱の煮える臭いのように、人里恋しい情緒の中に浸み出している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが即ち文化の余裕といふものであり、昔の日本の江戸や、今の仏蘭西の巴里などで、この種の閑人倶楽部が市中の至る所に設備されてるのは、文化が長い伝統によつて、余裕性を多分にもつてる証左である。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の喫茶店で、街路にマロニエの葉の散るのを眺めながら、一杯の葡萄酒で半日も暮してゐるなんてことは、話に聞くだけでも贅沢至極のことである。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の江戸時代には帰らないでも、せめて巴里かロンドン位の程度にまで、余裕のある閑散の生活環境を作りたい。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふどち二人三人かいつらねて、堀切の里にいきけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の屋蔭の苔むしたる井筒に、新調の洋服涼しげなる若人二人、巴里形の麥藁帽子見よげにかぶりて、細き櫻のステツキを手すさびに振り上げ、花もまだきなる紫陽花の葉を叩きつ、あやめを隔ててこなた、うちまもり給へるなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなとよ、妾は柳は柳なれど、加賀の千代の句近し、おんみは河内の國玉越の里の柳、楊枝にけづりてもなよよかなり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず裏の畑の茄子｜冬瓜小豆人参里芋を始め、井戸脇の葡萄塀の上の棗、隣から貰うた梨。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "店へは郷里の新聞が来ているので話はよく郷里の噂になる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君は郷里に年老いた貧しい母を残してある事を想い出したのである。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鯨絵巻の写しや、硯石で昔から知られた行当岬のスケッチや、祖先の出身だという一世一海和尚の墓の絵などが郷里の家に保存してあったはずであるが、いつの前にかもう無くなってしまったか、それともまだ倉の中のどこかに隠れているか不明である。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああふるさとの永日に少女子どものなつかしさたとしへもなきなつかしさやさしく指を眼にあててももいろの秋の夕日をすかしみるわが身の春は土にうもれて空しく草木の根をひたせる涙。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われらひとしく丘に立ち〕宮沢賢治われらひとしく丘に立ち青ぐろくしてぶちうてるあやしきもののひろがりを東はてなくのぞみけりそは巨いなる塩の水海とはおのもさとれども伝へてきゝしそのものとあまりにたがふこゝちしてたゞうつゝなるうすれ日にそのわだつみの潮騒のうろこの国の波がしらきほひ寄するをのぞみゐたりき",
              "citation": {
                "source": "〔われらひとしく丘に立ち〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
