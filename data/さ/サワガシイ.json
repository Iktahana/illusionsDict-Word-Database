[
  {
    "uuid": "edee6a3a-0b8a-5dc0-b077-debe9b228f7d",
    "entry": "騒がしい",
    "reading": {
      "primary": "さわがしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
