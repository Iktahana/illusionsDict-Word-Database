    },
    "definitions": [
      {
        "index": 1,
        "gloss": "undermentioned (statement)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかるに、昨年の秋、山田君から手紙が来て、小生は呼吸器をわるくしたので、これから一箇年、故郷に於いて静養して来るつもりだ、ついては大隅氏の縁談は貴君にたのむより他は無い、先方の御住所は左記のとおりであるから、よろしく聯絡せよ、という事であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりながら鏡を示されし時乞食僧は逃げ去りつつ人知れず左記の数言を呟きたり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集者を誰れや彼れやと云うと暇取りますから甚だ失礼ですが最初一二度私が編集しましょう（五句集の体裁で）、早速ですが左記に依り御投書を願います。",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "左記の友人の許へ、将来の方針に就いて相談に行って来るのですから、御心配無く。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年、彼が借衣までして恋人に逢いに行ったという、そのときの彼の自嘲の川柳を二つ三つ左記して、この恐るべきお洒落童子の、ほんのあらましの短い紹介文を結ぶことに致しましょう。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「健康診断を致しますから、八日正午、左記の病院に此の状持参にておいで下さい。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて今回本紙に左の題材にて貴下の御寄稿をお願い致したく御多忙中恐縮ながら左記条項お含みの上｜何卒御承引のほどお願い申上げます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左記の三十種の事物について語れば、即時除名のこと。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "定價一部金十八錢郵税二錢△半年分前金税共一圓十錢△一年分同二圓十錢廣告料　菊判一頁金十五圓　半頁金八圓（明44・２・１「創作」第二卷第二號）　　　〜〜〜〜〜〜〜〜〜〜〜〜〜〜〜〜前金購讀及び廣告申込は必ず左記發行所宛の事又爲替劵に豫め受取人を指定する時は發行所同番地石川一とせられたし。",
              "citation": {
                "source": "無題",
                "author": "月刊文藝雜誌　樹木と果實　初號三月一日發行",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生また／＼転居と申すべきか、当分の間左記へ滞在いたします。",
              "citation": {
                "source": "はがき通信",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十章八節―十二節に似たる箇処を旧約聖書中に求むれば、左記の如き代表的のものがある。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「紀州、ご本山よりご下向のご番僧説教日割りは、左記のとおり相定め候につき、お心得しかるべく候。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本願ハ左記理由ニ仍リ拒絶スベキモノト認ム。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "意見アラバ来ル×月×日迄ニ意見書ヲ提出スベシ』　と、あっさり殺し文句があって『左記』のところには、『本願ノ要旨ハ、義手ヲ人体ニ添架スルニ在ルモノト認ム。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今日の買物のうちで、左記の三つはよかつた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六十四条、ソヴェトの選挙権及び被選挙権は宗教・民族・住所上の要件等の如何に拘らず、ロシア社会主義連邦ソヴェト共和国の左記男女公民にして、選挙当日満十八歳に達するもの之を享有す。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十一年二月の日附で「曾禰達蔵氏ト共ニ左記ノ処ニ事務所ヲ開始シ公私ノ依頼ニ応ジ専心建築工事ノ設計監督ニ従事仕候間此段御披露申上候。",
              "citation": {
                "source": "父の手帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご感想、ご指摘を、大家さん提供の左記のアドレスでお待ちしています。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "御退屈様――　◆葉書は左記へお出し下さい。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して、前記諸項に関する一切の根本的の疑問に対する解決と説明は、この直方事件の発生後、約二箇年目に現われたる左記、第二回の発作に現われたる諸般の事情に依って、徹底的に明らかにするを得べし。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "左記は同氏が、筆者に書いてくれないかと云って話した怪談の体験である。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省婦人教育委員会の経過一、前回五月下旬欠席しましたが、打合わせた通り左記のように局長あて意見出しました。",
              "citation": {
                "source": "往復帖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――左記の通りにござソロ、柳川源達どの、同じく春勝どの、岩橋貞助どの、岩崎栄太郎どの、同じく久治どの、――よろしいか？",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――おいおいご同意なされソロかたがたは左記の通りにござソロ――柳川源達どの、同じく春勝どの」　それをまた人々は、何度目かの耳を傾けて聴き入っていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――信ちゃん、わたしは都合の悪いことがあって、しばらくは身を隠さねばならなくなったから、明日にでもわたしの荷物をひとまとめにして、左記へ送ってくださいね。",
              "citation": {
                "source": "宝石の序曲",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察に引致されたＡ夫人と、Ａ嬢の監禁されていた宿の内儀さんの自白によって左記の事実が明白となった。",
              "citation": {
                "source": "緑衣の女",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一見ばかばかしき騒ぎは、新聞読者の余りにも周章てん坊たるを証明するわけでもあるが、しかし左記の十二項を読んでいくと、まあそのくらい騒ぐのも無理ならぬことのようにも考えられる。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから……」　と、彼は、警告文の左記列項を順々に読んでいって、遂に最後の項に来た。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その材料について、予は左記の如き分子式を想像するが、この中には、地球にない元素が四つも交っているので、もしルナ・アミーバーが渡来したときには、面白い研究材料が出来ることであろう、云々」　ルナ・アミーバーという、透明で、流動性の生物があることは、博士の論文を見て始めて知ったのです。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶も、去るにあらずや……湧き起る歓喜のためには　人の情けも、小さきものとみゆるにあらずやああ、神様、これがすべてでございます、　尽すなく尽さるるなく、心のままにうたへる心こそ　これがすべてでございます！",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
