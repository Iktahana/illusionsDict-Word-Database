[
  {
    "uuid": "722480ad-4539-5eb9-a362-e40df3269846",
    "entry": "左記",
    "reading": {
      "primary": "さき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
