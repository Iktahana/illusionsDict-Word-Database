    "definitions": [
      {
        "index": 1,
        "gloss": "the thirty guardian deities (one for each day of the lunar month)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神将　我々は天が下の陰陽師、安倍の晴明の加持により、小町を守護する三十番神じゃ。",
              "citation": {
                "source": "二人小町",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（小野の小町に）三十番神を御覧なさい。",
              "citation": {
                "source": "二人小町",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の太政大臣、女の検非違使、女の閻魔王、女の三十番神、――そういうものが出来るとすれば、男は少し助かるでしょう。",
              "citation": {
                "source": "二人小町",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮家の唱名の後につづき、「摩訶般若波羅蜜多、十六善神哀愍覆護、滅悪生善経々部、明王部天童部、七曜九曜十二宮、二十八宿三十番神、修行者猶如薄伽梵」　と、八人の山伏も珠数おし揉み、一斉に唱えて責めかけた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十番神の御神燈に、磨き抜いた千本格子。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の蕎麦屋から芸者連れの男が三十番神の提灯をくゞつて外へ出た。",
              "citation": {
                "source": "夏の月",
                "author": "川端茅舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は三十番神といって京の周囲の神々が、毎月日をきめて禁中の守護をしておられた。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
