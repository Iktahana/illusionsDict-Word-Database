[
  {
    "uuid": "78e6aaea-fbb4-5b6e-840e-39b1f498a206",
    "entry": "為れる",
    "reading": {
      "primary": "される",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be done (to someone or something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "深く愛してゐるだけにかう云ふ事を為れると実に憎い。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ云ふ風だから益す脚下を見られて好い事を為れるのだ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふむ、それで富山はどうしました」「来る度に何のかのと申しますのを、体好く辞るんで御座いますけれど、もう※く来ちや、一頻なんぞは毎日｜揚詰に為れるんで、私はふつふつ不好なんで御座います。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ斯う楽に活計てゐたつて決して為れる訳のものぢやない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこう楽に活計ていたって決して為れる訳のものじゃない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ譬へば急湍変じて激流と為り、更に変じて静流と為り、而して後一碧洋々たる湖沼と為れるが如し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟子曰く、否、然らざるなり、事を好む者これを為れるなり。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "周の夢に胡蝶と為れるか、胡蝶の夢に周と為れるかを知らず」。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その志明かなれば冬の夜を、われは嘆かず、人々の憔燥のみの悲しみや憧れに引廻される女等の鼻唄を、我が瑣細なる罰と感じそが、わが皮膚を刺すにまかす。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに牧野さんが酔ふと発しはじめるのなぞは、当人に自制力がないよりも、周囲が彼にとつてはあまりに不真面目に見える所から起るのであつたと考ふべき点もあるのであるから、さういふ定説が呑気に繰返されることは辛かつたのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "是等の作品が、一般に愛されるべくそれ程難解なものとは思へぬ。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに猶、諸君も嫌ひではない冗舌は、此処に十分に按配されてをり、直き直きに抽象語を以てしなければ、かの「意味がない」と云つて嘯く、平盤な心情の人達のためには、十分哲学的学術的な言葉も此処には見出されるのである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は想起される印象を、刻々新しい概念に、翻訳しつつあつたのです。",
              "citation": {
                "source": "宮沢賢治の詩",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまれ渚よりも、沖の方が想ひ出される。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことが果される時に詩は初めて「作品」として通用するのだと思ふ。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば日々報道される様々な事件が、昔人間の数の少なかつた時よりも、人の感動を鈍らせ易いものだといふことが云へるとしても、而も芸術とはさういふ事情の問題ではなくして、さういふ事情の中にあつても猶感動する人がゐたら、その人が感動した感動に基因して表現するに到る所のものである。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　　　　　　　×　斯の如き時代にあつて、芸術が容易に圧倒されることは、さもありさうなことであらう。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさうである限り、新短歌も短歌と共に今後の発展を約束されるものではないとみねばなるまい。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに私の言ひたいことは、詩歌は理念を持つといふだけでは十分でない、その理念を蕩揺させてみるべきだといふこと、謂はば理念の余剰価値に迄到達すべきだといふこと、そこに於てはじめて詩歌は享楽されるものたるのみならず、意欲されるものとなるといふことである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "統一への途上に於て小主観的作品の物されることが多ければこそ、問題は錯雑を極め、作品よりも批評の方に真実の見られ易いが如き事態ともなつてゐるのではあるまいか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤解されたことを忍んで別れるより仕方もなくなると、忍んだ故にもう一段誤解されるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰度、音楽に鈍感な女の人が、オーケストラを聴いてゐて、フリュートなぞが単独に吹奏される部分でだけ、音そのものの物理的な快味にだけ感じ入るのに似てゐて、私は明治以降の殆んど全ての文学者が、外国文学の作品を読む時も、そんなやうなものであつたと云つても、強ち過言とは思はないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してそれらの新しい主義主張は、何か新しく云ひたいことが鬱勃とした所から発生してゐるといふよりも、事態の貧窮を救済しようとて案出されるもののやうである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば小松清氏によつて、行動主義文学といふのが提唱される。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ斯かる場合には、直観が稀薄になるについては一定の時間内に吾人が熟視し得ざる程多量の物をみせられたからでもあらうことに思ひを到して、個人が個人外との関係から意識上では解放される、即ち肚据えて十分に出来ることだけをするやうに心懸けるに如くまい。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自体芸術といふものは、それが研究の対象とされる限りに於ては如何にも科学的に闡明され得るものではあれ、制作される限りでは、生れるものであつて生むものではないのである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術堪能そのものが登用される場合は極めて稀であります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の中で、私はそれを読み出しながら、さてどんな相談したい事等あることかと、その方のことが思ひ出されるのであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の知人を訪問しても、洋風の応接間などに通されると、帰ってからも甚だ不機嫌であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に眼を見合すだけで、一切の意味が了解される恋人同士の間には、普通の意味での言葉や会話は、全く必要がないのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
