[
  {
    "uuid": "1d17dbeb-d8ff-5d5a-b372-d45224cca594",
    "entry": "彩画",
    "reading": {
      "primary": "さいが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
