        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西鶴は頬の色の「薄花桜」であることを重要視しているが、「いき」な頬は吉井勇が「うつくしき女なれども小夜子はも凄艶なれば秋にたとへむ」といっているような秋の色を帯びる傾向をもっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "入れ違いに今度は二ツ目左膳と、おさらばお小夜御免と内へ入る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜一寸おくれて表で待って居たがそっと中を覗く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言ってお小夜に実はこれこれでと頼む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仕方が無いわね」とお小夜紙入れを出す。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝外で　待っていたお小夜が何事ならんと入って来た。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜づかづかと徳兵衛の前へ進んだ。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜が、Ｔ「確かに此の人の買った品」　と言って、Ｔ「おさらばお小夜が証人だよ」　「サァ刀貰って帰りましょう」と二人が帰ろうとする。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左膳が、Ｔ「三百両なら売ってもいいなァお小夜」　左様、左様とお小夜。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）なりひらの宅　なりひらに、さんぴん山左、ましらの半次が待って居る処へ左膳とお小夜が帰って来た。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜もむかついたらしい。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "後でお小夜がなりひらに、Ｔ「雲霧主膳ッて何んな野郎か」　と言って、Ｔ「明日妾が小当りに当ってみらァね」　と言う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対の方向からブラリブラリとお小夜。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方ですれ違った時、主膳お小夜の手をグッと掴む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまったッ、お小夜の手は主膳の紙入れを掴んで居る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）ある料亭の二階　主膳等とお小夜。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳がお小夜に一杯呑めと盃をさし、Ｔ「其方を番所へ引ッ立てるとは申さん」　と言って、Ｔ「其処は魚心あれば何とやら」　と言って、Ｔ「身共の一味に加わらぬか？",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お小夜がせせら笑って、Ｔ「御冗談でしょう」　なにッと主膳、Ｔ「如何にもあたしァおさらばお小夜ッてしがねえ巾着切サ」　と言って、Ｔ「連判状とか何とか言う」　と言われて主膳ナニッと顔色変えた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜シャアシャアとして続ける。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜尚も、Ｔ「けちな野郎達たァ交際い度かあ御座んせん」　ウヌッと抜き討ちに斬って来る主膳の刃をヒラリとかわしてお小夜、窓から屋根へ――　屋根から木を伝って板塀を跳び下りて大地へつッ立った。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "下からお小夜が、Ｔ「おさらばで御座んす」　と言って立ち去った。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜がやって来た。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）なりひらの宅　お小夜がなりひらに、Ｔ「さんざんサ」　とベソを掻く。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひらが主膳に、Ｔ「先日はお小夜さんが御世話になりまして」　と頭を下げる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろお世話になりました　　いろいろお世話になりましたねえ　　いろいろお世話になりましたさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに良いお天気の日に　　お別れしてゆくのかと思ふとほんとに辛い　　こんなに良いお天気の日にさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、午睡の夢から覚めてみると　　みなさん家を空けておいでだつた　　あの時を妙に思ひ出しますさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして明日の今頃は　　長の年月見馴れてる　　故郷の土をば見てゐるのですさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはそんなにパラソルを振る　　僕にはあんまり眩しいのです　　あなたはそんなにパラソルを振るさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
