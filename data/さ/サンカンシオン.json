    "definitions": [
      {
        "index": 1,
        "gloss": "alternation of three cold and four warm days (usu. in late winter and early spring)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "朝鮮で三寒四温という言葉があるそうで、これはまさに七日の週期を暗示する。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は曾て男女の別れるについての苦悩の脱却順序を、気象の三寒四温の理にあてはめて説いたことがあつた。",
              "citation": {
                "source": "生滅の心理",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "三寒四温といふ、その一温といふお天気である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪空、痒いところを掻く　雪空、いつまでも女の話で（隣室の青年達に）・雪の日の葱一把・一把一銭の根深汁です　一月十五日　晴、三寒四温といふがじつさいだ。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この気温の不順不同は、所謂三寒四温どころのものでなく、ヒステリックである。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三寒四温といって、思いがけなく暖かい日もあった。",
              "citation": {
                "source": "私の若い頃",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三寒四温といふ在來の言ひ傳へはよく要を得てゐる。",
              "citation": {
                "source": "吉日",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
