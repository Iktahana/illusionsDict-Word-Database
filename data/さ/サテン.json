    "definitions": [
      {
        "index": 1,
        "gloss": "satin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "逃げたらあかんし」と蓮葉に言って、赤い斑点の出来た私の手の甲をぎゅっと抓ると、チャラチャラと二階の段梯子を上って行ったが、やがて、「――ちょんの間の衣替え……」と歌うように言って降りて来たのを見ると、真赤な色のサテン地の寝巻ともピジャマともドイスともつかぬ怪しげな服を暑くるしく着ていた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近移ったばかりの信濃町の雪枝の家の少し手前で、タキシイを乗り棄て、白いレイスの衿飾りのある黒いサテンの洋服を着た葉子は、和装の時ほど顔も姿も栄えないので、何か寒々した感じだったが、気分も沈みがちであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "サテン、　ポンパドゥール、　ラストリン、　生地にも　それぞれ　かわった　名前が　あって、　どれも　このお話の　おこったころには、　とても　ねうちの　あるものでした。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "きぬと　サテンが　みんな　切りとられたまま、　さぎょう台の上に　おかれました。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふくやさんは　だんろのそばに　すわりなおして、　かわいそうに　ひえた手を　あたためながら、　ぶつぶつと　ひとりごと　――「チョッキは　もも色の　サテンから　たってある　――　バラの　つぼみの　ししゅうは、　きれいな　きぬ糸で。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "西門通りの　ふくやさんの　お店では、　ししゅうされた　シルクと　サテンの　ぬのが　さぎょう台に　おかれたまま　――　２１ある　ボタンあなも　手つかず　――　まども　しまっていて、　ドアも　かたく　戸じまりされていると　あっては、　これでは　だれも　ぬのの　ぬいあわせを　することが　できません！",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもわず　声を　あげる　ふくやさん　――　そこには、　ぬのを　きりそろえて　おいてあっただけなのに　――　かわりに、　どこまでも　うつくしい　コートと、　きれいに　ししゅうされた　サテンの　チョッキが　ならんでいたのです。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢夫人と千々子さまは、サテンのワンピースにあらたまり、石田氏までがキチンとネクタイをつけている。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は玄関と亡霊のような身廊の埃が妙な具合に払われ、会衆席のサテンの裏打ちと破れたクッションが散らかっているのを見た。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "会衆席のサテンの裏打ちとクッションの馬巣織を斜めになった窓の鎧板に押し込んであったのだ。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に多くのサテンと馬巣織の端切れが拭ったばかりの床の上に散らばっていた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから両目、喉、両耳に何か詰まったように感じ、得も言われるほどキラキラ輝く暖かい雪の感触だが、サテン布のように柔らかい。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "サテン服を着て、長い指に高価な家宝をはめているので、大邸宅の女主人としても通用しかねない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖地の大広間に立ち尽くし、花嫁衣装をまとい、真っ白なサテンの衣装、バックル靴を履き、これらは遙か昔に豪華船から分捕った物だそうだが、コルセットも絹製の古風な形で、メアリすら息を呑む代物であり、全体を覆うベールは薄くて半透明、まるで絹蜘蛛が花嫁の黒髪に金糸を撚ったかのよう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体にフリルやレースの首飾りや刺繍はなく、サテンの光沢も真珠の輝きもないけれども、パリ製であり、同様にミリアムとモード嬢もパリ製のドレスを着ており、モード嬢は花嫁の付き添い係の予定だ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、伯爵夫人が出てきました」　サーンス伯爵夫人が笑顔でホールにお出まし、黄色のサテンをお召しで、驚くほど堂々とした容姿だ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "レディは背が高く、黒づくめで、黒い外套の下に黄色いサテンをお召しでした」　レックミア侍従が陽気に、気前よく言った。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホールでサテンを着ていたレディです」　侍女は絶対の自信を持って話した。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "通常であれば、夜遅く出歩くのは気にならないし、そんなとき上流社会の服装は着ないし、靴だって、凝った留め金のついたサテン靴じゃない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっと向きを変え、細いサテン靴の踵を返したとき、驚きの声を上げた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "サテンの長椅子に居座ったごろつきは寝ていた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色のサテン椅子でいびきをかいている男を見て、にたっと笑った。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑い声が夜のしじまを破ると、サテン椅子の男がもぞもぞ動いて大いびきをかいた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は右手にレース・サテン・毛皮の高級お召し物を抱え、もう馬車の中で着るばかり。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと着いたのが、ちょっと離れたところにあるぼろ小屋、ラッフルが毛布をはぐと大型栗毛が現れ、馬肌がサテンのように陽光に輝いた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や陽気な団員がシルク、サテン、アーミン毛皮で着飾っている。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやり眺めていたのは、テーブル銀器や高級備品、金色サテン壁の絵画だった。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "明かりがちらちら照らすのはダイヤモンド、真珠、サテンや勲章。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
