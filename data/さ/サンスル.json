  {
    "uuid": "4b29ac50-ec2c-54ae-ada4-ac85c387d999",
    "entry": "参する",
    "reading": {
      "primary": "さんする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-自動詞"
      ],
