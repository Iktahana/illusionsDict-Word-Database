[
  {
    "uuid": "77d12225-cc4d-5ca1-b9c2-cf67acd1afe7",
    "entry": "授かる",
    "reading": {
      "primary": "さずかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
