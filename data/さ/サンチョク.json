    "definitions": [
      {
        "index": 1,
        "gloss": "out on a third-base liner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "照彦様が再三直されて国語の読み方をおわった時、「有本さん、ご苦労でございます。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西銀座の三直へ寄り、天ぷらを食ふ、油がいゝのでよろし、値段もよろしく、四円九十何銭。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」昼の終り、又天ぷら食ひたくなり、三直へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三直へ寄り、野菜本位で食べ、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三直で天ぷら食ひ、ビーコンでコーヒー飲み、三昧堂で新刊を求めて座へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時半鏑木を連れて出、三直へ行き、天ぷら。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人で出て、三直で天ぷらを食ひ、フランコでコーヒーと菓子を食べて座へ帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三直へ寄り、天ぷら夕食。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野と出て中泉眼科へ寄り、三直で天ぷらを食って座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "終ると、三直で天ぷらを食ひ、すぐ又引返す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中泉眼科から、三直へ、天ぷら食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "京極もゐて、二人を三直へよび、天ぷらしこたま食べる（二十五円也）、銀座へ出て別れ、八時十分東京駅へ、女房・清を迎へに行き、帰宅。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野と三直で天ぷら、汗かき乍らうんと食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "終って、天ぷら食ひに南部僑一郎を連れて三直へ行く、飯なし時間だから、天ぷらオンリー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月の大阪を決定の筈で文芸部が集まった、葦原邦子が母親の反対で出演出来なくなり、古賀政男のみ出演、さて、その出しもの今日は決定出来ず、平野・菊田・斎藤を連れて三直で天ぷら、飯が出ないから栄ずしへ寄って、すしをつまんで座へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の終りに、小佐川観之丞来り、幡随院のコーチ礼として三直の天ぷらを食はせることゝし、平野同道行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三直へ寄り天ぷら食って座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三直――こゝが一ばん、他はづっと落ちる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
