  {
    "uuid": "939dfd55-35fb-52c2-b405-bd948e15d9b0",
    "entry": "皿鉢",
    "reading": {
      "primary": "さわち",
      "alternatives": [
        "さはち",
        "すなばち"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "platter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あるいは葬式や嫁入りの門先に皿鉢を砕く、あの習俗がこんな妙な形に歪曲されて出現したのかもしれない。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がたぴしという物音は皿鉢飛んだ騒動なり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所では皿鉢のふれ合う音、庖丁の音、料理人や下女らの無作法な話し声などで一通り騒がしい上に、ねこ、犬、それから雨に降り込められて土間へ集まっている鶏までがいっそうのにぎやかさを添える。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯時が近くなるので、勝手のほうでは皿鉢の音がしたり、物を焼くにおいがしたりする。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まれに台所で皿鉢のかち合う音が聞こえても三毛は何も知らずに寝ていた。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾山の陶器は人も知る如く、楽焼角皿鉢のようなものが、最も多く遺されている。",
              "citation": {
                "source": "乾山の陶器",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物｜皿鉢料理の卓を圍んで土佐料理に舌鼓をうつて居る折、其時の母校々長、校友會長の甲藤義治氏の好意であつたらう、高知の名物男の政吉といふ老藝人を呼んでくれた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは聖書のなかで陶工の粘土とロクロについて読んだことがあるが、われわれがつかっている皿鉢が当時からそのままこわれずにつたわったものではなくヒョウタンのように木に生ったものでもないことには思いいたらなかった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いったい、なにを始めようというんだ」「なに、万一のときの用心さ」　女中たちが酒や皿鉢をはこび終って、しばらくすると、主馬が立って、隣り座敷へゆき、なにかしているようすだったが、すぐに、襖の間から顔を出して、手招きをした。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さわちゃん」と女の声で叫ぶのが聞えた、「どこにいるの、さわちゃん、かあさんはここよ、おとうさまもかあさんもここにいてよ、さわちゃん、――あたしたちここにいてよ」　さわの喉から劈くような声が出た。",
              "citation": {
                "source": "榎物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さわ、どこにいる、さわちゃん、こっちへおいで。",
              "citation": {
                "source": "榎物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さわちゃん、どこにいるの。",
              "citation": {
                "source": "榎物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「六年、六年もよ」さわはくすっと喉で笑った、「なんのために六年も待ってたの、さわちゃん、あんたはいったいどこの誰を待ってたのよ」　さわは忍び笑いをしたり、肩をすくめたりし、絶えず独り言を呟きながら、泊りをいそぐ客たちや、馬や駕籠の往来する道を、あてどもなくふらふらあるいていった。",
              "citation": {
                "source": "榎物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
