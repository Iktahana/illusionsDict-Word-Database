    "definitions": [
      {
        "index": 1,
        "gloss": "bleached cotton cloth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
