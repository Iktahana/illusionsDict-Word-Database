    "definitions": [
      {
        "index": 1,
        "gloss": "sea bilberry (Vaccinium bracteatum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つぎねふや　山城川を　川溯り　我がのぼれば、川の辺に生ひ立てる烏草樹を。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏草樹の樹　其が下に生ひ立てる葉広五｜百つ真椿。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に歌よみしたまひしく、つぎねふや七　山代河を川のぼり　吾がのぼれば、河の邊に　生ひ立てる　烏草樹八を。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏草樹の樹、其が下に　生ひ立てる葉廣　ゆつ眞椿九、其が花の　照りいまし其が葉の　廣りいますは、大君ろかも。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分がよくなったら一つひさしぶりで相撲をとりませうか。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はし（橋）にて、であい、ひさしぶりにて、はなしをする。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさしぶりに、また、同かの、それ、みぎの、れいの、あいかわらず、歯をいたむなりけり。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ君よかうした情歡もひさしぶりだ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさしぶりで懇意にしてゐる家へ訪ねていつたのに、生憎留守だつたので、もういく先のあてもなく、ぶらりぶらりと歩いてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、「晩には何か取りまして、ひさしぶりで一本あげましょうか。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい卒業生は、ひさしぶりの故郷の風景に、ものうい瞳をそつと投げたきりで、さもさもわざとらしい小さなあくびをした。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ひと息で言ってしまって、それから急に固くなり、「ほんとうに、おひさしぶりでございました。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと吉野山参りの先達をなんべんもやった亀菊さんは、ひさしぶりに鳴らしてやろうというので、宝蔵倉からほら貝をとり出してきました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさしぶりですたい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬のむことを忘れて、　ひさしぶりに、母に叱られしをうれしと思へる。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさしぶりに、　ふと声を出して笑ひてみぬ――蝿の両手を揉むが可笑しさに。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁先にまくら出させて、　ひさしぶりに、　ゆふべの空にしたしめるかな。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははははは」　よく訊いてみると、きのうは旧暦の三月三日で大潮にあたるというので、老人は近所の人たちに誘われて、ひさしぶりで品川へ潮干狩に出かけると、花どきの癖で午頃から俄か雨がふり出して来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩、ひさしぶりに法師がやって来た。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはひさしぶりに、こっちへ用があって、野々宮さんを引っ張って来たところだ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたの午後には父親が迎えにきて、ひさしぶりに家で夕食をたべられるという四月二十七日、慶一は、昼下がりの明るい、しかし、やさしい陽射しを浴びて、ゆるやかに搖れる教室の外の柳を見ながら、頭のなかで、あすレコード屋にいったら買うもののリストをつくっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このところ、慶一はひさしぶりにギターを弾いている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさしぶりに見る先生は、ちょっとまぶしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな、ひさしぶりに会うと、全然わからないっていうんですよ」「なにいってんのよ、兄さん。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなさんのほとんどが、卒業以来、ここには足を運んでいないと思われましたので、きていただいたわけで、ひさしぶりに、生徒の気分を味わっていただこう、という趣向です」　そんなもん、味わいたくなんかねえぞ、とヤジが飛ぶ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひさしぶりじゃん」　ほんとうは半年ぶりだったが、高等部の三年間を疎遠なままに終わってしまったので、もっとずっと長いあいだ、会っていなかったような気がした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに気持ちのいい夜はひさしぶりだ」　ほんとうに風邪をひきそうなくらいの、「爽やか」をとおりこした涼しさだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、きょうだいは、ひさしぶりに、たがいに手と手をとりあったのです。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさしぶりの話がつきない夜の雨になり　三月廿八日　曇。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君来庵、周二君も来庵、めづらしい三人でひさしぶりの快飲。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
