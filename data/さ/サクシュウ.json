    "definitions": [
      {
        "index": 1,
        "gloss": "autumn of last year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが、小作料のことから、田畑は昨秋、収穫をしたきりで耕されず、雑草が蔓るまゝに放任されていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋、友人の遭難を聞いて、私の畜犬に対する日ごろの憎悪は、その極点に達した。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に同銅像は昨秋十月旧門弟一同発起となり一月着工、胸像は福岡県糸島郡出身彫塑家津上昌平氏の献身的努力により作製されたものである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらぬ邪魔立て致して、御僧は何者じゃ」「当行学院御院主、昨秋｜来関東｜御巡錫中の故を以て、その留守を預かる院代玄長と申す者じゃ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨今、淫蕩場面の映画が歓迎されるのも、昨秋の大震災の民心に影響した結果であろうと思われる」云々。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は松山散策、――立花から郊外へ（朱鱗洞君の墓を展した、昨秋の深更まゐつたときは酔中で礼を失したことが多く済まないと心が咎めてゐたが、これでほつと安心した）。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は、また、久しぶりに、めでたく卒業した、愛する妹が帰って来まして、七条駅まで迎えに行き、昨秋以来の、なつかしい逢瀬の、互いに労う挨拶を交わす時にも、兄妹ともしあわせな心地につつまれました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は昨秋外相に就任した際は連合軍の政策に対しある程度の疑念を抱いていたが、現在ではわれわれは民主主義を当時より安易な気持で受入れることが出来る」（『日本経済新聞』九月七日号）　労働法における勤労階級の権利を、資本家とその権力の利害と妥協させる一機関として中央労働委員会が組織された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がこの青年を明瞭り記憶したのは昨秋の道普請のときであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋この稿を起し、前半を雑誌『槐（えんじゅ）』に掲載した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "迂生事、昨年七月より近郊にて（現今のところ）約六｜反歩の土地つき家屋を借受け、昨秋切花用として芍薬二千株程植付け候。",
              "citation": {
                "source": "新らしき祖先",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋からは追うても捨てゝも戻って来る、いまだ名無しの風来の牝犬も居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は年来ピンの押入婿であったが、昨秋新に村人の家に飼われた勇猛の白犬の為に一度噛み伏せられてピンをとられて以来、俄に弱って著しく老衰して見えた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋の麦蒔に馬糞を基肥に使った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋以来鼬の難にかゝることこゝに五たびだ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈台下暗かった粕谷にも、昨秋から兎に角電燈がつきました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の姉は昨秋、義兄は今春他界した。",
              "citation": {
                "source": "盗難",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋はじめて富士見へ行くとき、家の近所のカストリ屋のオヤジ（と云っても三十ぐらいの威勢のよいアンチャンであるが）が、ちょうどその土地の生れの人であるから、一緒に行ってもらった。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時代の権太楼夫人が、戦後、離婚して家庭裁判まで起こし世間を騒がせた女性で、弱り目に祟り目で相前後して権太楼君は記憶喪失症になって病床にあること多年だったが、昨秋からようやく再起、今度再婚もしたと聞く。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三年前に利根の対岸宮郷村の豪農から嫁たみを貰い、昨秋長男の裕八郎が出生してから、まだ半歳とたっていない。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋の台風の記憶がまだ脳裏に新たな市人は、中央気象台のやや鎮撫的な報告があるのにも拘らず、緊張した顔面に不安の色を湛えていた。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨秋合同葬の際に私どもは神父様をはじめ多くの霊魂に誓い、天国よりのお助けをこい願いました。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが惜しいとまこと思う頃にはこれまた東京の人でない」　かつて私にこの小品があり、昨秋、上梓した『随筆、寄席風俗』の中へ収めた。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにＣ君が昨秋、新日本の大正聖代號（？",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ乾坤二刀、夜泣きの刀のいきさつはなくとも、昨秋あけぼのの里の試合に勝って、当然じぶんのものと信じている弥生のこころが、当の剣敵諏訪栄三郎に傾きつくしていると知っては、丹下左膳の心中はなはだ穏かならぬものがあったことは言うまでもない。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一三節　余、これを試みんと欲し、昨秋自宅において、前後数回試験を施したることあり。",
              "citation": {
                "source": "妖怪玄談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして、そのようやく進みて東京に入りしは昨秋のことなり。",
              "citation": {
                "source": "妖怪玄談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛は昨秋より不消化の為めに悩む事あり。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに昨秋帰朝した時以来、友人の語る処によると、数多の奇行が目立つので、友人は無論のこと、庭球協会の幹部中にも派遣反対の意見は強かったという。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
