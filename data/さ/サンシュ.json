[
  {
    "uuid": "691f30be-d256-58c5-87c0-ea33cf97de89",
    "entry": "蚕種",
    "reading": {
      "primary": "さんしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
