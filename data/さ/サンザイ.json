    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be scattered",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "生垣で囲われた藁屋根の家が、閑雅に散在している郊外村落の昼景である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、山榛の木、沢胡桃などが、悄然と、荒れ沢の中に散在している。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同じ人の名が色々な住所と結合してぱらぱらに散在しているので、どれが現住所であるか、当人でさえ時々間違えることがありそうである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした例も実際捜せばところどころには散在するのである。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上述べたような項目の外に著しく多数に散在しているのは有職故実その他あらゆる知識に関するノートと云ったものである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘のそこかしこ、それから、丘のふもとの草原が延びて行こうとしているあたり、そこらへんに、露西亜人の家が点々として散在していた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事はどうでもよいが、私の眼についたのは、この灰色の四十平方寸ばかりの面積の上に不規則に散在しているさまざまの斑点であった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千ヶ滝から峰の茶屋への九十九折の坂道の両脇の崖を見ると、上から下まで全部が浅間から噴出した小粒な軽石の堆積であるが、上端から約一メートルくらい下に、薄い黒土の層があって、その中に樹の根や草の根の枯れ朽ちたのが散在している。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思イ見ヨ、諸君ハ、現ニ、商埠遙ニ散在シテイル貧窮セル居留民達ノ生命ヲモ財産ヲモ保護シテハイナイノデアル。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　自動車は、太馬路から、拒馬や、鉄条網が、頑張っていない、緯四｜路へ出て、七｜馬路で永※門の方面に曲り、日本軍の警備区域でもなく、南軍が散在している区域でもない、その中間の線を選んで迂廻した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の方々に散在していたきれぎれの雲は、どこかへ消え失せてしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　山の麓のさびれた高い鐘楼と教会堂の下に麓から谷間へかけて、五六十戸ばかりの家が所々群がり、また時には、二三戸だけとびはなれて散在していた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに類する多くの問題は至るところに散在している。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚さ一センチ程度で長さ二十センチもある扁平な板切れのような、たとえば松樹の皮の鱗片の大きいのといったような相貌をした岩片も散在している。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る間に付近に散在していた土方が集まって来て、車夫はなぐられるだけなぐられ、その上交番に引きずって行かれた。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば林とても数里にわたるものなく否、おそらく一里にわたるものもあるまい、畑とても一眸数里に続くものはなく一座の林の周囲は畑、一頃の畑の三方は林、というような具合で、農家がその間に散在してさらにこれを分割している。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この趣味を描くために武蔵野に散在せる駅、駅といかぬまでも家並、すなわち製図家の熟語でいう聯檐家屋を描写するの必要がある。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこのコハシあるいはコフジに相当するものと思われる類似の楽器の類似の名前がヨーロッパ、アジア、アフリカ、南洋のところどころに散在しているのが目につく。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この豊量に水に恵まれた都には、聖ピエトロ大｜伽藍前のピアッツアの噴水を中心にして、僧院にも市場にも全都に散在している。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、きまって自分の家の周りに、一番手近かに飲食料の貯蔵所、家畜、野菜畑、果樹園を置き、次に穀物畑、葡萄畑、次に牧場、最後に小さな灌木の密林（野鳥獣を棲息させて、時折りこれを捕ったり、家具を作る木材を得る）という順に置いて、一幅の風景画のように、各家庭が散在しております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる、各宗各派を開宗した名僧知識および、その他散在する諸美徳たちです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すわや海上の危機は逼ると覚しく、あなたこなたに散在したりし数十の漁船は、北るがごとく漕戻しつ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人の哲学はこの二語を以て既に千六百万人の世界各地に散在する信徒を得た。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藏原伸二郎卷尾に　この書の中にある詩篇は、初版「青猫」を始め、新潮社版の「蝶を夢む」第一書房版の「萩原朔太郎詩集」その他既刊の詩集中にも散在し、夫夫少し宛詩句や組方を異にしてゐるが、この「定本」のものが本當であり、流布本に於ける誤植一切を訂正し、併せてその未熟個所を定則に改定した。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがってこの書の思想の一部分は、前の書物『新しき欲情』の中にも散在している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見廻す周囲は松林や市街のあふれらしい人家に取囲まれていて、畑地の中のところどころに、下宿屋をアパート風に改造した家が散在し、二階から人の頭が覗いていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "満天に散在する星の一群を綴り合せて、いろいろな形を想像して出来たのが星座である。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふりかえって、まちを見ると、ただ、ぱらぱらと灯が散在していて、「こどものじぶん、」Ｋは立ちどまって、話かける。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、清国留学生は日本全国に散在して、その数すでに一万ちかくに及んでいる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとのことで崖の上までたどりつき、脚下の様を眺めたら、まばらに散在している鎌倉の街の家々の灯が、手に取るように見えたのだ。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
