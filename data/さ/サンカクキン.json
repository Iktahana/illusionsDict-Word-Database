        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実際左の肩の三角筋がぼうと熱をもって疼く。",
              "citation": {
                "source": "針",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "鑑定書の口調をまねて詳しく云うと、右三角筋部、左前上膊部、左右｜臀部、右前｜大腿部、左｜後膝部の六ヶ所に、長さ三センチから一センチ位までの、剃刀様の兇器によるものと覚しき軽微な斬り傷があって、そこから六本の血の河が全身に異様な縞を描いていたのだ。",
              "citation": {
                "source": "悪霊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
