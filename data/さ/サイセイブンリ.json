        "examples": {
          "standard": [
            {
              "text": "近代国家では、祭政分離の原則が確立されていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "憲法では、政教分離の原則として祭政分離が明記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祭政分離は、個人の信仰の自由を保障するための重要な考え方だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "家々の宮廷に事へた由緒を陳べ其と共に、今の天子の長命を呪して忠勤を示す事、祭政分離の政策が、この風を変改するに到るまで、継続して居たものであらう。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭主は当然に家長の役であったが、家にも一国と同じく祭政分離の必要があって、優良なる若者の中から年男が選定せられることになった。",
              "citation": {
                "source": "歳棚に祭る神",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
