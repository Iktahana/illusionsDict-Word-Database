[
  {
    "uuid": "13278f78-eb91-5677-a767-5192e1b5547c",
    "entry": "差し招く",
    "reading": {
      "primary": "さしまねく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
