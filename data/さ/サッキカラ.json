    "definitions": [
      {
        "index": 1,
        "gloss": "since some time ago",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "嬢やはと聞くと、さっきから昼寝と答えたきり、元の無言に帰る。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がついてみると、さっきから、ごとごとごとごと、ジョバンニの乗ってゐる小さな列車が走りつづけてゐたのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「居ますとも、さっきから鳴いてまさあ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラは、さっきから、訊かうと思ってゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたらさっきから仕度ができてめずらしそうにこの新らしい農夫の近くに立ってそのようすを見ていた子供の百姓が俄かにくすりと笑いました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとしゅっこは、さっきからよっぽど怒っていたとみえて、「ようし、見てろ」と云いながら、本気になって、ざぶんと水に飛び込んで、一生けん命、そっちの方へ泳いでいった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからもう二十分も待ったんだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから見つからなくって。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前、さっきから隣の地主が奥の部屋で待ってるよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、さっきから、腹這いになって、二重硝子の窓から、向うの丘の方を見ていたのであった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だからさっきから、わしは「待ちませんよ、」「待ちませんよ」と二三度も警告を発しておいたじゃないか。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからの話を聴いて、お徳も内々は思いあたることが無いでもなかったのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからの口ぶりで大抵判っているが、おめえは行く行くその古着屋の店へ坐り込んで、一緒に物尺をいじくる積りでいるんだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからどうも唯の人でないらしいと思っていましたが、おまえさんは三河町の親分さんでございましたね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七も承知したが、ここではどうにもならないから、ともかくも番屋まで来いと云って、お俊を引っ立てて出ようとするところへ、さっきから入口に立っていた女がはいって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからおとなしくしていれば、図に乗って何を云やあがるんだ」と、かれは呶鳴った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　山崎は、さっきから学生服に着かえていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はさっきからその扉は外へ出る為のだと思ってゐたのだ。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから見えていた白い燈台はすぐそこだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども電光があんまりせわしくガドルフのまぶたをかすめて過ぎ、飢えとつかれとが一しょにがたがた湧きあがり、さっきからの熱った頭はまるで舞踏のようでした。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから台所でことことやっていた二十ばかりの眼の大きな女がきまり悪そうに夕食を運んで来た。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がついてみると、さっきから、ごとごとごとごと、ジョバンニの乗っている小さな列車が走りつづけていたのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラは、さっきから、訊こうと思っていたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様はさっきから阿呆鳥だの何だのと俺の悪口を云ったな。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから六時間もたっています。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王様はどう云う訳かさっきからひどくお悦びでございます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに居て、さっきから休んでござったのが、右の売薬じゃ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　私はそのさっきから何んとなくこの婦人に畏敬の念が生じて善か悪か、どの道命令されるように心得たから、いわるるままに草履を穿いた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから、あちこち飲み歩いても、まだ半分以上も残っているんです。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
