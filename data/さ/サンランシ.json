        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここに風穴を穿ち、蚕卵紙を貯蔵す。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "養蚕の目的は蚕卵紙を作るにあらずして糸を作るにあり、教育の目的は教師を作るにあらずして実業者を作るにあり、と。",
              "citation": {
                "source": "慶応義塾学生諸氏に告ぐ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた蚕卵紙を蚕に仕立てます故、丹精はなか／＼容易なものでは有りませんが、此の程は大分養蚕が盛で、田舎は賑やかでございます。",
              "citation": {
                "source": "霧陰伊香保湯煙",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来農桑を御奨励になり、正月の初子の日に天皇御｜躬ずから玉箒を以て蚕卵紙を掃い、鋤鍬を以て耕す御態をなしたもうた。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年試みに此の穴中に蚕卵紙を蓄蔵したりと云ふ。",
              "citation": {
                "source": "周防石城山神籠石探検記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "西原君報告の蚕卵紙を貯えたとあるのはこの穴だ。",
              "citation": {
                "source": "周防石城山神籠石探検記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
