        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ある日二人は、例によって睦じく連れそいながら、牛込辺の売邸を探しに歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、飯場の人たちが、親も子も帰らない事を気遣って、探しに来なかったならば、その親たちと同じ運命になるのであったほど、執拗に首を擡げる事を続けたであろう。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝源兵衛宅表　番頭の長吉や手代が提灯持って娘を探しに八方へ走る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "借家を探しに行った父親の敬蔵が帰って来て雨上りの水泳場で父娘二人きりの夕飯が始まった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所はまだ下町の中央に未練があって、毎日、その方面へ探しに行くらしかった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、おやじが、あたふたと、郭を探しにはいってきた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは越前屋の女房にたのまれて、為さんの死骸を探しにでも行ったのかとも思ったが、何分にもいろいろの奇怪な事件がそれからそれへと続出するのにおびやかされている彼女は、どうも落ち着いてはいられないような気がするので、更けてますます降りしきる雨の中を越前屋へたずねて行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "七之助はもう三吉のところに行かずに、まっすぐに死に場所を探しに行ったのであろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっかえして探しに行くのは、命がけだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば僕は一千九百十九年の七月に、アメリカのヂャイアントアーム会社の依嘱を受けて、紅宝玉を探しにビルマへ行ったがね、やっぱりいつか足は紅宝玉の山へ向く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝石を探しに出掛けたのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば僕は一千九百十九年の七月に、アメリカのジャイアントアーム会社の依嘱を受けて、紅宝玉を探しにビルマへ行ったがね、やっぱりいつか足は紅宝玉の山へ向く。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い本をお探しになるのが何よりのお楽しみだそうですね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻姉さん所にもお前を探しに来たんだよ」　と云ふのを冒頭に、裏に怒りを潜めながら、表は優しい口調で、お末に因果を含めだした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い娘の行衛を心配して探しに来た母親や伴の者とめぐり合ったので、慧鶴は無事に娘をそれ等の手に引渡した。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはねえ、顔も洗わないで探しに来たんだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森に子供らが農具をかくすたびにみんなは「探しに行くぞお」と叫び森は「来お」と答へました。",
              "citation": {
                "source": "『注文の多い料理店』広告文",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森が子供らや農具をかくすたびに、みんなは「探しに行くぞお」と叫び、森は「来お」と答えました。",
              "citation": {
                "source": "『注文の多い料理店』新刊案内",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すでに、二日の日の午後、火と煙を三方に見ながら、秋の暑さは炎天より意地が惡く、加ふるに砂煙の濛々とした大地に茣蓙一枚の立退所から、軍のやうな人ごみを、拔けつ、潛りつ、四谷の通りへ食料を探しに出て、煮染屋を見つけて、崩れた瓦、壁泥の堆いのを踏んで飛込んだが、心あての昆布の佃煮は影もない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高岡に彷徨いていたって始まらんので、金沢には士官がいるから、馬丁の口でもあるだろうと思って、探しに出て来た。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてそれを探しにゆくかと思案していると、囚人は更に教えた。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのはつまり、亀吉が豹吉にいいつけられて小沢十吉を当てなく探しに、千日前のハナヤを出た頃――。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして由三が家を探しに來たことをいふと、綾さんと兩人で、那處は何うの此處は何うと、恰で親族の者が引越して來るとでもいふやうな騒をする。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、俺は此処へ村井を探しに来たんだな……」　という事実をやっと意識した彼は、いつも村井に会いに行く時の習慣を無意識の中に繰返しながら、トラックの出口から中庭へ這入って、編輯局の裏梯子を登った。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはきっと最前の井戸のところに落して来たに違いないと思って、又探しに行って見ましたが、そこにもありません。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは料理屋でもお探しになってはいかがですか」　と申しました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……貴方は……金貨を探しに来られたのでしょう」　私の胸の動悸が又、突然に高まった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方がお探しになっているオーラス丸の船長夫婦と……一人の女の児と……一人の運転手と……三人の水夫の死骸なのです。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの百姓男は、村長からいひつかつて、坊さんを探しに今朝はやくから、この街道に出て来てゐたのでした。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のキャッチボールのそれ球をわんわんのように這って椽の下にさがしに行ったりどろだらけな靴下をつくろってやることもあります。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
