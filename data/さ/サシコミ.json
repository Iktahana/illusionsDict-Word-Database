[
  {
    "uuid": "25ec47a6-acef-5d25-a9d8-97fb488b4a83",
    "entry": "差し込み",
    "reading": {
      "primary": "さしこみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
