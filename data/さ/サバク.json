[
  {
    "uuid": "79c55580-d497-5bd9-8ec9-72b586154c7b",
    "entry": "佐幕",
    "reading": {
      "primary": "さばく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "adherence to the shogunate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "佐幕、勤王、因循三派のどれにでも共鳴しながら同じ宿に泊る。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……然るにこの助太刀の二人というのが相当名のある佐幕派の浪人で、身共の顔を見識りおって友川の手引をしたらしいと思われたが、事実、三人とも中々の者でのう。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐幕派が盛んになると勤王派の全部に腹を切らせる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに勤王派が盛り返すと今度は佐幕派の全部を誅戮する。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩奸会賊と云ふのは、当時の志士の標語であつて、薩摩は会津と同じく、佐幕の張本人と目され、その評判のわるいこと甚だしい。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩藩はしかし、果して佐幕であらうか。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し慶喜が本当に肚を据ゑて、佐幕派の藩士を集めて、反薩長の旗幟を掲げて起つたならばどうであつたであらうか。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし自から家康に代りて天下を取らむと思ひしなるべしと疑ふ人あらば、そは、維新の際、薩長が取つて徳川に代らむと誤解せし佐幕の諸藩の人々の見と同じかるべき也。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊王攘夷と開港佐幕と、昨是今非の紛々たる声に交って、黒船来の恐怖心が加わった、地に鬱積している不安動揺の声なのである。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤王佐幕の喧しい争闘の時には昼夜兼行で浜町の上屋敷に上訴に出かけて行つたこともあつた。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "時はあたかも藩閥政府の全盛時代で、いわゆる賊軍の名を負って滅亡した佐幕派の子弟は、たとい官途をこころざしても容易に立身の見込みがなさそうである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彰義隊と白虎隊では佐幕党ばかりで取合わせが悪いので、前に長州の奇兵隊をかき、後に会津の白虎隊を書いて「維新前後」という題にしてはどうだと言ってやると、川上はまたすぐに飛んで来て、なにぶん頼むと言った。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、維新の時、一藩｜挙って宗家大事という佐幕派であった。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐幕派が七分、勤王派が三分という形勢であった。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐幕派の首領は、家老の成田頼母で、今年五十五になる頑固一徹の老人である。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、佐幕主戦派にとっては、大打撃であった。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、王政維新の世になってみると、佐幕派の頼母の死は、殺され損ということになって、下手人たちを賞賛こそすれ、非難するものはなかった。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤王に之かんか、佐幕に之かんか。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏見、鳥羽の戦を以て始まり、東北地方に押し詰められた佐幕の余力が、春より秋に至る間に漸く衰滅に帰した年である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川幕府の末造に当つて、天下の言論は尊王と佐幕とに分かれた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時尊王には攘夷が附帯し、佐幕には開国が附帯して唱道せられてゐた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "智者は尊王家の中にも、佐幕家の中にもあつた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "正義とは尊王攘夷の事で、因循とは佐幕開国の事である。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れから江戸の方では又幕府と云うものが勿論時の政府でリキンで居ると云う訳けで、日本の政治が東西二派に相分れて、勤王佐幕と云う二派の名が出来た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三、東西二派の理非曲直は姑く扨置き、男子が所謂宿昔青雲の志を達するは乱世に在り、勤王でも佐幕でも試みに当て砕けると云うが書生の事であるが、私にはその性質習慣がない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤王攘夷と佐幕攘夷と名こそ変れ、その実は双方共に純粋無雑な攘夷家でその攘夷に深浅厚薄の別はあるも、詰る所は双方共に尊攘の仕振りが善いとか悪いとか云うのが争論の点で、その争論喧嘩が遂に上方の攘夷家と関東の攘夷家と鉄砲を打合うような事になるであろう。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に申す通りに古川節蔵は私の家から脱走したようなもので、後で聞て見れば榎本よりか先きに脱走したそうで、房州鋸山とか何処とかに居た佐幕党の人を長崎丸に乗せて、ソレを箱根山に上げて、ソレで箱根の騒動が起たので、あれは古川節蔵が遣たのだと申します。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その遺臣論は姑く擱き、私の身の進退は、前に申す通り、維新の際に幕府の門閥制度、鎖国主義が腹の底から嫌だから佐幕の気がない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐幕家の進退は一切万事、君臣の名分から割出して、徳川三百年の天下｜云々と争いながら、その天下が無くなったら争の点も無くなって平気の平左衛門とは可笑しい。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "独立の手本を示さんとす第四には、勤王佐幕など云う喧しい議論は差置き、維新政府の基礎が定まると、日本国中の士族は無論、百姓の子も町人の弟も、少しばかり文字でも分る奴は皆役人になりたいと云う。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
