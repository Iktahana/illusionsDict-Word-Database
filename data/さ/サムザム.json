        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "銘仙の袷に金紗の羽織を着、兎の毛で縁をとつたオールドローズの繻子の肩掛に寒々とくるまり、海老茶の袴を胸高く穿いてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし作者の意味では、そうした故事や固有名詞と関係なく、単にこの易水という文字の白く寒々とした感じを取って、冬の川の表象に利用したまでであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱買つて枯木の中を帰りけり　と歌う蕪村は、常に寒々とした人生の孤独を眺めていた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校時代のことを考えると、今でも寒々とした悪感が走るほどである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "置時計、銅像、懸物、活花、ことごとくが寒々として見えるから妙である。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫紺色に寒々とさえた空には星がいっぱいに銀砂子のように散らばっている。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を隔てて眼の前にふさがるように切り立った高い崕の上に、やや黄味を帯びた青空が寒々と冴えて、ガラス板を張りつめたように平らに広がっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本は寒々とした想いで、喫茶店のなかへ戻った。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その重い心の底を、五月の風がさっと冬の風のように吹き渡り、小沢は何か寒々とした想いで、Ｓ署の玄関に佇んでいたが、やがてひょいと顔をあげた途端、小沢ははっとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "口繩坂は寒々と木が枯れて、白い風が走つてゐた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん途中見て来たところでは、稲の植えつけもまだ済まず、避暑客の来るには大分間があったが、それにしても、この町全体が何か寒々していた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "河口に近く流れを二つに分けている洲の方に、人家の灯がちらちらしており、水のうえに仄かな空明りが差して、幾軒かの汽船会社の倉庫が寒々と黒い影を岸に並べていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い空のほうは、寒々としていました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりを見まわしても、目にうつるものは、寒々とした、ものさびしい景色ばかりです。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、雪の女王の広間は、がらんとして、だだっぴろい、寒々としたところでした。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ゲルダは、寒々とした、なに一つない大広間にはいりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは、雪の女王のお城の、なに一つない、寒々とした美しさを、おもくるしい夢のように、忘れてしまいました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校時代のことを考へると、今でも寒々とした悪感が走るほどである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "池のはたの杉の木が、すっかり伐り払われて、何かこれから工事でもはじめられる土地みたいに、へんにむき出しの寒々した感じで、昔とすっかり変っていました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒々した東北の漁村の趣は、それは当然の事で、決してとがむべきではないが、それでゐて、井の中の蛙が大海を知らないみたいな小さい妙な高慢を感じて閉口したのは私だけであらうか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやはや、全くもう身の毛のよだつやうな有樣でございますて‥‥」　二人はすぐに階下の應接間へはいつて行つたが、寒々とした部屋ながらそこは家具一つ亂れてはゐなかつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんなかに富士があつて、その下に河口湖が白く寒々とひろがり、近景の山々がその両袖にひつそり蹲つて湖を抱きかかへるやうにしてゐる。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "熙々として照つてゐた春の陽は何時か烈しい夏の光に變り、澄んだ秋空を高く雁が渡つて行つたかと思ふと、はや、寒々とした灰色の空から霙が落ちかかる。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煕々として照っていた春の陽はいつか烈しい夏の光に変り、澄んだ秋空を高く雁が渡って行ったかと思うと、はや、寒々とした灰色の空から霙が落ちかかる。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――人々はもはや耳かきですくうほどの理性すら無くしてしまい、場内を黒く走る風にふと寒々と吹かれて右往左往する表情は、何か狂気じみていた。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の底が次第に白く更け、白い風が白く走る寒々とした焼跡に、赤井はちょぼんと佇んでいたが、やがてとぼとぼと歩きだした。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "××県地図と笹の絵が、白い宿直室の壁に、何かさむざむとへばりついているのが、自分を暗示しているような気がしてならない。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さむざむし池の面や、行けば行き、とめぐればただめぐりて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さむざむと、雀など。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮ぐもりの燻しがさむざむと満ちる、これから、蜆いろの沖にも。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
