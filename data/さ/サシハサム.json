[
  {
    "uuid": "6da2db4a-7602-5601-9687-c1102b415122",
    "entry": "差し挟む",
    "reading": {
      "primary": "さしはさむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
