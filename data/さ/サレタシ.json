    "definitions": [
      {
        "index": 1,
        "gloss": "I would like you to ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
