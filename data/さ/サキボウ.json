        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　高信さんが、銀貨を若干、先棒の掌へポンと握らせると、にこりと額をうつむけた処を、「いくら貰うたかい。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレデリックもイングンもスウエーデン貴族社會の甘やかされた子供達で、共にウプサラの大學に學んでゐたが、不良な道樂者のお先棒だつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると上機嫌で先棒を担いでいた湊屋の若い奴が向う鉢巻で長持唄を歌い始めた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様のお先棒にだけはなつて呉れるなよ。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おい、若いの、今度部屋に来るときは、俺のやうな立派な髯を生して来いよ――』　と源はモッコの引繩を、ヒョイとしやくりあげて、先棒担ぎの若い無髯の土工の力の負担を少くしてやるのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷門の前まで来ると、次郎左衛門を乗せた駕籠屋の先棒が草鞋の緒を踏み切った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思う途端に、駕籠の先棒がだしぬけに頓狂な声で、「おい、この駕籠は滅法界に重くなったぜ」と、呶鳴った。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてはうぬが、この淫乱妾のお先棒になって、京弥どのを掠ってまいったのじゃな」「よよッ、又しても悪い奴がかぎつけてまいったな！",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御三家ですらもが薩長の鼻息｜窺うて、江戸追討軍の御先棒となるきのう今日じゃ。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかん　相棒と云つても、内の人は先棒だよ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "助十　先棒でも後棒でも、斯ういふときに遠慮が出來るものか。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "助八　先棒を嵩にきて、乙う大哥風を吹かすなら、おめえの亭主なんぞは頼まねえ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "助八　まあ、仕方がねえ、おれが先棒になつて遣るから、あとからそろ／＼附いて來い。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フェーッ」というと先棒が、ガタンと駕籠を抛り出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……オイ先棒もう一度あやまれ」　すると先棒がまた出た。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○演技指導における俳優と演出者の関係は、ちょうど一つの駕籠をかつぐ先棒と後棒の関係に似ている。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先棒の姿は後棒に見えるが、先棒自身には見えない。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう深刻な戦争の先棒をかつぐ決心をしている日本の帝国主義にとって、日本プロレタリア文化連盟は邪魔でしょう。",
              "citation": {
                "source": "ますます確りやりましょう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が他人のお先棒になるもんか！",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美味しいわ、これは案外」　嫌いな私が先棒で、二三本あったカルピスが皆空になった。",
              "citation": {
                "source": "この夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代は投票の純潔さを益々必要とするのに、実際は、公機であるべき新聞が先棒でその逆が勝利を占めることを実地教訓する。",
              "citation": {
                "source": "夏遠き山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ、こういう伯父たちが先棒になって、半分盲目になった染物職人の指貫きをやいておいて火傷をさせて悦ぶような残酷で卑劣なわるさを企らむ。",
              "citation": {
                "source": "逝けるマクシム・ゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまにおとなしく台所にかたまっていると思うと、この大人達は自分が先棒になって、半分盲目になっている染物職人のグレゴリーの指貫をやいて置いて哀れな職人が火傷するのを見て悦ぶ有様である。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると吾輩の周囲には、梅をお先棒にした座員の一同が犇々と立ちかかっている様子だ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃公等は自分でその先棒になろうとは思わぬ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            }
          ]
        }
