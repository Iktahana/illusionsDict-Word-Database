    "definitions": [
      {
        "index": 1,
        "gloss": "suspicion (of others)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頼朝だって、ただ猜疑心の強い、攻略一ぽうの人ではなかった。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心は恐ろしい疑念や猜疑心で一ぱいでした。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心はみるみる猜疑心で一ぱいになってしまいました。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "心が裂けそうで、中にはもう毒々しい不信感、猜疑心が何千何百といっぱいで。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の心はみるみる猜疑心でいっぱいになり、二階に駆け上がって、彼女がうちにいないか確かめに行きました。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前に見えた男の大きな顔は、品がなく脂ぎっていて、猜疑心に満ちていた。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱暴で意地悪でまことに猜疑心が深かつた。",
              "citation": {
                "source": "肉桂樹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、私が妻に対して不満足を抱いてゐたとすれば、其不満足は、今一｜種の猜疑心となつたのであらう。",
              "citation": {
                "source": "背負揚",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "と叫んだのも、恐く此の猜疑心であらう。",
              "citation": {
                "source": "背負揚",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は自分の愛子ぐらいの年ごろの時の自分の経験の一々が生き返ってその猜疑心をあおり立てるのに自分から苦しまねばならなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇分たち、二〇分たち、それでも高志はあらわれず、猜疑心と不安とを抑えこむのにも疲れ、なにがどうなったのかわからないまま、あきらめて、慶一は寮にもどることにした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何にも言わないということは、ますます彼の猜疑心を尖らした。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不成功の原因の一つは、わが国に対する妥当でない猜疑心によるものである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "道ならぬ恋の罪悪、乾くことなき我慾の罪悪、他を陥れなければ止まない猜疑心、泥土に蹂躙せられた慈悲、深く染着しつつもその染着をわるいと思はない心、さういふ光景は一々かれの眼に映つて見えた。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ彼には、時として、善く言へば新聞記者的とでもいふべき鋭い猜疑心を、意外な邊に働かしてゐるやうな癖があつた。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、われわれ日本の読者の悲劇は、ヨーロッパ現代文学の中でも、歴史様相に対して最も猜疑心の深い動機にたつ作品が、このんで紹介され、高い翻訳料を支払うために熱心に広告されるということである。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い限りの無い悪夢にでも襲われたようにして起って来た恐怖――親戚や友人に対してさえ制えることの出来なかった猜疑心――眼に見えない迫害の力の前に恐れ戦いた彼のたましい――夢のように急いで来た遠い波の上――知らない人の中へ行こうとのみした名のつけようの無い悲哀――何という恐ろしい眼に遭遇ったろう。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車がプラットフォームへ止るや否や、Ｙ、日本紳士をヘキエキさして「キム」に関係があるかもしれぬという名誉の猜疑心を誘発させたところの鞣外套をひっかけてとび出してしまった。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫉妬から、猜疑心から、競爭心から、好奇心から、等々。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に彼はつねに猜疑心に苦しめられる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸にして幸雄兄の知辺があるので、紹介して貰って奔走したけれど、田舎の人は消極的で猜疑心が強くて、出来そうで出来ない。",
              "citation": {
                "source": "『鉢の子』から『其中庵』まで",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉見の父が少年二人を密訴に出したので、門番も猜疑心を起さずに応対して、却つて運びが好かつた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝つて何處まで猜疑心の強い人間だつたのでせうね。",
              "citation": {
                "source": "滑川畔にて",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人としても国民としても自ら悪意や猜疑心を以て暗雲を立て、東西の方角までも朦朧たらしむるに代え、善意と友情によりて碧空一点の雲翳を止めざる所まで昇るを要する。",
              "citation": {
                "source": "東西相触れて",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時クリミヤ戦争の当分ではあるし、元来英吉利と露西亜との間柄は犬と猿のようで、相互に色々な猜疑心がある。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、その争いは武器を取って雌雄を決する闘争ではなく、暗黙のうちに郷里の評判や、学科の点数や、席次や、社会的地位を争うのだから、そこに不純な名誉心や嫉妬心や猜疑心が介在して来るから、本人達に取っては、非常に苦しいものだったに違いないと思う。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　支那人の猜疑心（一）　支那人は一般に猜疑心が深い。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる場合を警戒する諺で、之に由つても、支那人の猜疑心の強い一端を察知することが出來ると思ふ。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
