    "definitions": [
      {
        "index": 1,
        "gloss": "Satsuma and Chōshū (clan alliance)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
