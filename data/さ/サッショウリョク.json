          "standard": [
            {
              "text": "その爆弾は非常に殺傷力が高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "銃器の殺傷力は、使用される弾丸の種類によって大きく変わる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害時に暴徒化した群衆の殺傷力を警戒する声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "殺傷力はないが、砲煙が高く天に沖するという。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "投爆者として俺が参加する予定だった三月事件の場合は、襲撃目標の首相官邸や政党本部に爆弾を投ずるといったところで、実際にはあまり殺傷力のない爆弾を威嚇的に用いるだけのことだったし、議事堂の襲撃も大臣の総辞職をそこで強要するというのにすぎない。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
