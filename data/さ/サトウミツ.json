          "literary": [
            {
              "text": "パスチーラ　果実や漿果を砂糖蜜で煮とかし、型に入れて半ば固めたもの。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物についていへば砂糖蜜などを多く入れてむやみに甘くしたるは月並なり。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ジンジャービスケットは玉子三個、砂糖四杯、バター大匙三杯、を能く掻混ぜ生姜粉大匙一杯半、メリケン粉大匙十杯、ベーキングパウダー茶匙二杯、モラッセス即ち砂糖蜜大匙四杯を加えて能く混ぜ牛乳を入れて好い加減にこね展し棒にて延ばし前法の如くに焼くなり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
