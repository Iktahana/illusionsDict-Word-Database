    "definitions": [
      {
        "index": 1,
        "gloss": "sporadic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "各人の文学上の活動が既成ジャーナリズムのうちに散発します。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四五年の第二次精神崩壊では、もはや、集団主義の前に示す個人主義の抗争のムーヴメントは一九三〇年の残余であり、ゲリラ的な散発の抵抗で漸次その線をおさめつつある。",
              "citation": {
                "source": "現代美学の危機と映画理論",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果、殆ど同じ数の散発的な患者に曝される機会はあっても、家庭内および個人的な交際でコレラの広がることが少ないのであろう。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠隔地にある大いなる種族の小都市や大いなる種族が居住していない荒廃した太古の都市――地下の深淵への経路が適切に封鎖ないし警備されていない場所だった――において、なんとも悍ましい侵入が散発するようになった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気を散発性、流行性、風土性、と分類するのは彼のお蔭であり、彼は急性病を慢性病から区別した。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "散発的な襲撃を止めて、大挙行動する整備の状態にあるのではないか。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世の町にはネズミが多く衛生状態は決して良くはなかったにも拘わらず散発の例や地方的な流行はあったが決して拡がらなかった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "この病気が続いて常に存在し新しい世代が生まれるとその大部分を襲うとペストは次第に局地感染で散発的になり死亡率も比較的に低下するであろう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "1899年にトリエステ、ハンブルク、グラスゴー、マルセイユ、ナポリに散発したが大部分はペスト流行地から到着した船の乗客や水夫たちが上陸した結果であることが示された。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ年の４月にメルボルンで似た状態の散発が起きた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンフランシスコのシナ人のあいだでペストの存在が1900年に見つかりカリフォルニアの種々の場所で広範に散発しこの頃から20世紀の最初の10年の終わりまで起きた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし軽症で散発的な地方病的な例で特に子供の場合に発疹は僅かで一時的でありこの病気に不慣れな医師は気が付かないことがあり得る。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの病気がそれ以前に地方病的あるいは散発的、時々に起きる熱病、としてくすぶり続けて後の流行病の火だねにならないことを意味しているのではない。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが散発的すなわち地方病的な病例である。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に述べた状況から散発的、地方病的でラットまたはマウスからヒトへの発疹チフス感染はこの病気が流行病になり認識され鑑別されるより数世紀前に起きたのではないかと思われる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "メキシコと合衆国南部では少数ではあるが長いあいだ認識されていない散発的な患者がイエネズミから絶えず感染していてメキシコではシラミが関係すると流行が起きる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレー半島では都市型および農村型の熱帯発疹チフスがあってやはり散発的であり集団感染を起こすことは稀である。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初にヒトのこの病気はたぶん軽症の散発的な形を取って今日に合衆国南東部で起きているように時間的および地域的に分散していたのであろう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれらの不規則に散発し一般的に小さい疫病発生について我々は詳細の情報を持たない。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルコ人やハンガリー人が比較的に免疫性をもつことは従って彼らのあいだに「集団」抵抗性が存在する傾向のあることを示しこの抵抗性は長いあいだ絶えることのないこの病気への暴露、すなわち散発的な患者や小グループの発生が続くことによって作られる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "東部辺境、たぶんイタリア、スペイン、およびドイツのある部分でも発疹チフスの感染は現在の腸チフスのように散発的に存在していた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにシナとかメキシコでは周期的に起きる地域的な流行病であり北アフリカや近東では散発的に起きていた。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "連中をやっつけてこっぴどい教訓にして、首謀者を撃ち殺せば、将来絶対もめません」　再び散発的に撃ってきた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間隔を置いて、次の半時間は散発的に銃撃戦になった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "――母子砲とは一名を鼠弾ともいって、一弾が幾ツにも割れ、その中からまた無数の小弾や油ボロが散発するという始末のわるいものだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髮屋の夜櫻間中庸さんぱつやの　窓の月はくさい髮の　にほひがするみゝずが　細々と泪の音をたてゝゐるそんなに月がかなしいのかい痩せきつた　俺のからだに夏が　夏がしんみりと重たい",
              "citation": {
                "source": "散髮屋の夜",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほら、モダンガールいうの、あれかもしれんな」「でも、モダンガールいうのは、男のように髪をここのとこで、さんぱつしとることじゃろ」　そういって耳のうしろで二本の指を鋏にしてみせてから、「あの先生は、ちゃんと髪ゆうとったもん」「それでも、洋服きとるもん」「ひょっとしたら、自転車屋の子かもしれんな。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
