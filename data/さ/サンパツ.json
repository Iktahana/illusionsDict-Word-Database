[
  {
    "uuid": "4e2fb2e0-1afc-58eb-8ff9-164fb90d8e9e",
    "entry": "散発",
    "reading": {
      "primary": "さんぱつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
