        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "足場が不安定な場所で作業するために、才取りを使って資材を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、長い才取りを巧みに操り、屋根の上の職人に瓦を渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の職人たちは、独自の才取りを工夫して作業効率を上げていたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
