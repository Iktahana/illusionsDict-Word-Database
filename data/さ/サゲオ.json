    "definitions": [
      {
        "index": 1,
        "gloss": "cord for attaching a sword scabbard tightly to the obi",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わなゝく指にて裾を紮げ、手拭もて鉢巻し、脇差の下緒にて襷十字に綾取る間もあらせず。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "信幸、家康の許へ行くと、家康喜んで、安房守が片手を折りつる心地するよ、軍に勝ちたくば信州をやる証ぞと云って刀の下緒のはしを切って呉れた。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸屋でこそあれ辻屋は土地の旧家で身代もなかなか確かりしたもの、普通の糸屋と異って、鎧の縅の糸、下緒など専門にして老舗であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも刀の下緒を襷にして、切腹の座の背後に控えた。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しあの中から強ひて、更に古い新島の姿を求めようならば、はちまきの裾を垂らした下緒と称する、伊豆七島のものいみ生活に通じたはちまきの固定した形である。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に飛び退いた小一郎は、引き抜いた下緒をピューッと振り、一つ扱くと早襷！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「うむ邪教徒の一味にか」「はい左様でございます」「よし」と云ったが鉄之進は、刀の下緒を引抜いた。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　キリキリと下緒で綾を取る。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて下緒は延ばせば一丈、たたんで下げれば五寸となる。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「フ、フ、計ってやったーッ」　見れば刀を打ち落とされ、下緒で両手をキリキリと縛され、身動きならず服部織江は、一本の柱にくくりつけられていた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当でございます、わたしは、どうして死んだらよいか、それを昨夜も一晩中考えておりました」「そして考えついたかな」「やっぱり人に弄り殺しにされてしまいとうございます」「なるほど」　寝返りを打つと竜之助は、枕許の刀の下緒をずっと引き寄せました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一つこのたびだけは、手前どもにもむりをおゆるし願いたいんで」「これだけ事をわけて申し入れてもか」「相すみません」　起き上がりざま、ピンと下緒にしごきをくれた源十郎、「ようし！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と二人ともおっかなびっくりでしりごみしているところへ、ただちにとってかえした源十郎を見ると、刀をとりに行ったものであろう左手に長い刀を下緒といっしょに引っつかんで、その面相｜羅刹のごとく、どうも事態がおだやかでない。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "五尺そこそこの矮躯に紺の脚絆、一枚引っかけた盲目縞長ばんてん、刀の下緒のような真田紐を帯代りにちょっきり結んで、なるほど両脚が釘抜のように内側へ曲がっている。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と自分は草鞋を締直し、刀の下緒をはずし、たすきにしかける）長五　それで、兄きは、また……？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……加多、今井と眼と眼を見合わせながらジーッと立っていた後、黙って地図を懐中に入れ、刀の下緒を取り口に咬え、たすきをしはじめる）今井　……（加多を見詰めてこれも身仕度をしながら）では？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまた思いきりよく素裸、全身に刺青をしたやつに腹帯下帯だけで散らし髪、ドスは下緒で斜めに背中にくくりつけている。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀の下緒ぢやなし、前掛の紐ぢやなし、ひどく新しいが――」　平次は萠黄染料の匂ひを嗅ぎ乍らそんな事を言ふのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二人濱路",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀の下緒じゃなし、前掛けの紐じゃなし、ひどく新しいが――」　平次は萌黄染料の匂いを嗅ぎながらそんな事を言うのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、相手の天魔太郎は、南のやぐらの上に、印もむすばず、呪文もとなえず、小唄でもうたいだしそうなすずしい顔をして立っていましたが、やがて時分をはかって「ゆくぞ、ご坊」　刀の下緒をといて、北のやぐらめがけてサッとほうりました。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天魔太郎が空中にほうったモエギ色の下緒は、二ツ三ツもんどり打つとみるや、一転ごとに大きくなって、最後には三間（六メートル）あまり、青色の大蛇となり、覚心坊のやぐらにからみつき、鏡のごとき二つの目をみひらき、紅蓮のほのおをはいて、ユラユラとやぐらの頂上にはいあがるのです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその首には、細いモエギの下緒が、人をバカにしたようにふた巻ばかりまいているにすぎなかったのです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは身の毛もよだつおそろしさですが、天魔太郎それを見ると、ニッコと笑って、もういちどモエギの刀の下緒をとり、やぐらの下にかみつく大トラめがけてサッとほうりました。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……加多、今井と眼と眼を見合せながらジーッと立っていた後、黙って地図を懐中に入れ、刀の下緒を取り口に咬え、たすきをしはじめる。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土方をはじめ一団がこれはと驚くときは遅く、北の方にめぐらされた寺の垣根を後ろにとって、下緒は早くも襷に結ばれ、太刀の構えは平青眼。",
              "citation": {
                "source": "大菩薩峠",
                "author": "甲源一刀流の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この途中、島田虎之助はフト怪しい気配に打たれたので、もとより新徴組がかく精鋭を尽して来ようとは思わなかったが、心得ある乗り方で乗物の背後にヒタと背をつけて前を貫く刀に備え、待てと土方の声がかかった時分には、既に刀の下緒は襷に綾どられ、愛刀志津三郎の目釘は湿されていた。",
              "citation": {
                "source": "大菩薩峠",
                "author": "甲源一刀流の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いざ、お仕度召されい」「心得て候」　壮士は、刀の下緒を襷にする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この若い寡婦はまた、その男とは結婚しないと云う約束のもとに二、三年も濃やかな愛情をささげおうていると云うことだが、こんな恋愛は新らしいとは云えないだろうか。",
              "citation": {
                "source": "恋愛の微醺",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの顔さげおめおめ都へお帰りになれようか」「…………」「おそらくは、慕蓉をたよって、朝廷への帰参をとりなしてもらおうというお腹なのでしょう。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
