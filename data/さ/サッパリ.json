    "definitions": [
      {
        "index": 1,
        "gloss": "feeling refreshed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――私も若い時には、大酒を飲んだものですが、いまはもう、さっぱり駄目になりました。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が何だかさっぱり訳が分らねえ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでしばらく飼うと脂気が抜けてしまうそうで、そのさっぱりした味がこの土地に相応しいような気もした。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしに、さっぱりそんな慾はなくってよ」　捨てるともなく誇りと励みに背中を向けかけると、ふた親が説く、山の祖神の偉さというものより部落の間の噂に遺っている山の祖神の偉からざる方面のことが女には懐しまれて来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえがときどき「あんまり断片的の感想で、さっぱり判りませんね。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄助は、しばらく腕を組んで、みんなのとるのを見ていたが、「さっぱり居なぃな。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっぱり魚、浮ばなぃよ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「魚さっぱり浮ばなぃよ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にその泥岩｜層は、川の水の増すたんび、奇麗に洗われるものですから、何とも云えず青白くさっぱりしていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "異性に対する淳朴な信頼を失ってさっぱりと諦むる心は決して無代価で生れたものではない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年東京ではさっぱり鳶というものを見たことがなかったので異常に珍しくなつかしくも思われた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は今日を別れと思ってか、髪はさっぱりとした銀杏返しに薄く化粧をしている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘルムホルツは対話ではさっぱり要領を得なかったが、しかし彼は very fine head をもっている」と評した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカでもプロフェッサー達はみんな品のいい、そうしてヨーロッパの国々の多くのプロフェッサーよりもさっぱりした感じの人が多かったが、これらの先生達は誰もチューインガムを噛んではいなかった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レビュー式でも本当に面白いレビューならまだしも、さっぱり面白くない百景を並べたのでは全く生徒が可愛相である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことには、このドイツ語で紹介された老子はもはや薄汚い唐人服を着たにがにがとこわい顔をした貧血老人ではなくて、さっぱりとした明るい色の背広に暖かそうなオーバーを着た童顔でブロンドのドイツ人である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの商店も小綺麗にさっぱりして、磨いた硝子の飾窓には、様々の珍しい商品が並んでいた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「そうだ、綺麗さっぱり諦めるんだ！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（さっぱりと）そのお嬢さんがわたしの髪とおんなじならようございますが。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女はさっぱりと云った。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生は、近頃、さっぱり姿を見せないね」　常連の間に不審がるものもあったが、やがてすっかり忘られてしまった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」為吉は美しいさっぱりした東京の生活を想像していた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句をはじめるまではさっぱり気づかずにいた自然界の美しさがいったん俳句に入門するとまるで暗やみから一度に飛び出してでも来たかのように眼前に展開される。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "納豆屋の「ナットナットー、ナット、七色唐辛子」という声もこの界隈では近ごろさっぱり聞かれなくなった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところはやった玄米パン売りの、メガフォーンを通して妙にぼやけた、聞くだけで咽喉の詰まるような、食欲を吹き飛ばすようなあのバナールな呼び声も、これは幸いにさっぱり聞かなくなってしまった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って一概に秋を悲しいものときめてしまった昔の歌人などの気持が自分にはさっぱり呑みこめなかったのであった。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵でも描くような心持がさっぱりなくなってしまったので、総持寺見物のつもりで奥へはいって行った。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近来杏仁水の匂のする水薬を飲まされた記憶はさっぱりない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
