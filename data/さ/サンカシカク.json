        "examples": {
          "standard": [
            {
              "text": "マラソン大会の参加資格は、年齢と健康状態が問われます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この国際的なコンペティションに参加するには、厳格な参加資格を満たす必要があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私の参加資格はありますか？」と彼は恐る恐る尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "参加資格はアマチュワー・オーナー・フライヤーに限る。",
              "citation": {
                "source": "空飛ぶ悪魔",
                "author": "――機上から投下された手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "実を言えば、ドロシーに参加資格はない。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
