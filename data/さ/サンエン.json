[
  {
    "uuid": "ff865e19-5d04-5986-8cf8-2e0cb62d7eec",
    "entry": "三猿",
    "reading": {
      "primary": "さんえん",
      "alternatives": [
        "さんざる"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
