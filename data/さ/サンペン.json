    "definitions": [
      {
        "index": 1,
        "gloss": "three sides (length, width and height)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
