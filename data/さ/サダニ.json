          "literary": [
            {
              "text": "誰か先に立つて云ひ出すものがありや、理の當然だによつて、案外安々とその通りになるんぢやが……みんな腹ぢや思つてゐながら、お互ひに人におつつけおつつけしとるんぢやけに、どもならんわ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "多年の経験から来たその鋭い眼を家の台所にまで向けることは、あまりおさだに悦ばれなかった。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日のおげんは台所のしちりんの前に立ちながら、自分の料理の経験などをおさだに語り聞かせるほど好い機嫌でもあった。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は掴ませるつもりもなく、熱い火箸をおさだに掴ませようとした。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の手が少し狂ったかも知れんが、おさださんに火傷をさせるつもりでしたことでは無いで」　とおげんは言って、直次の養母にもおさだにも詫びようとしたが、心の昂奮は隠せなかった。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "おげんはおさだに、「なあし、おさださん――喧嘩でも何でもないで。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘のまきと、さだに守りをされながら、六の小さい裸足の足音は湿りけのある地面に吸いつくような調子で、今来て肩につかまったかと思うと、もうあっちへヨチヨチとかけて行く。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
