    "definitions": [
      {
        "index": 1,
        "gloss": "left-most",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最右翼と最左翼は紙一重の差がある許りだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンは最左翼の大集団を直接掌握し、同時に全軍の指揮官であった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文戦」の最後的分裂を報告したのち、ブルジョア新聞は「この分裂の結果、左翼文学の指導権は完全に最左翼たるナップに移ってしまった訳だ」と書いている。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『事実は私は女秘書聯盟の書記になって午飯の休憩時間を一時間増すための全国的運動を起してそのかげに隠れて加奈陀総同盟の最左翼と結託しようか、それともハリウッドへ行って映画女優になろうかとずいぶん考えたのです。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "又此列の最右翼に居る「範叟道規庵主、元文三年｜戊午八月八日」は、別本に泰了縁家の祖と註してあるから、此系の最も古い人に當り、又此列の最左翼に居る壽阿彌の父「頓譽淨岸居士、寛政四年｜壬子八月九日」は、泰了と利右衞門の稱を同じうしてゐるから、泰了の子かと推せられる。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "清司は村に居る中から指導的立場にゐた青年だったが、旅へ出て行ってからは最左翼的色彩を一層濃厚にしてゐた。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つてあらゆる自然主義者は理論上最左翼に立たなければならぬ。",
              "citation": {
                "source": "続文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は最左翼の向うにある暗黒の中に立たなければならぬ。",
              "citation": {
                "source": "続文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　或左傾主義者　彼は最左翼の更に左翼に位していた。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って最左翼をも軽蔑していた。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンクスは東雲仙火山と西雲仙火山の接触地点にあって、すぐ背後に矢岳を負い、矢岳と野岳との間の最低地｜空池を控え、野岳と連接する妙見岳の裾野が、見事なスロープを作り最左方石割山との間に、寄生火山を持つ第一｜吹越の障壁で、北を限った一大盆地がそれである。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中を、風のために呼吸を奪はれながら、昼夜の別なく最左翼へわたし達の旅団は強行軍を行つたのです。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際裸体婦人同盟は、アントワアプに本部のある最左翼解放運動の前線で、言わばその独立活動隊です。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代の進展に意識的に関与して、他のことはどうでもいい、つまり、私たち最左翼の知識群です。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "半円の最左翼に構え込んでいた、佐藤｜志津馬という門弟が、向卍で打ち込まれたのであった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、最近文壇の指導勢力は最も社会主義的社会建設の為に、ハッキリした理解と協力し得る最左翼の芸術団体であるプロレタリア作家連盟が握って来た。",
              "citation": {
                "source": "ソヴェト・ロシアの現状勢と芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が最左端、次が権左、次が木村、次が我等の主人役という順序である。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "その農夫は、イギリスのある騎兵旅団が、たぶんヴィヴァイアンの旅団であろうが、最左翼としてオーアンの村に陣地を占めに行くのの案内者となったのである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アロハ葬儀社を最右端だとすると、そこから最左端の名称に向けて、それこそ電話帳に掲載されているとおり、たくさんのアロハなんとかがあるわけだ」「最左端は、なにかしら。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉の第二軍中川勢の突出は、明智方の最左翼にある斎藤隊が克ち取った凸形を、忽ち危ういものにした。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一群の奇兵は、かれの策をうけて、長久手を迂回し、徳川勢の最左翼――つまり赤備えが挙げて前に押し出したあとを狙って、敵の中核を急襲し、全山の陣容がみだるるを見て――家康を捕捉しようと考えたのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道のところどころにちらばって黒い小さいさびしい家だ。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "壱唱　ふくろうの啼く夜かたわの子うまれけり　さいさきよいぞ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿まはしがともからぴよいと小さいさんばしの上にとびあがるのを、船の中の人々はだまつて見てゐました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、ふとお店におはひりになつたのが始まりで……さあお嬢さまは何がお気にいりで店へさうさいさいお出でになるやうになつたのでせう。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすれば、いつも皆にかつさいされるのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいさきが悪いと思った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　テエブルのむこうにひっそり坐った小さいさちよの姿を、やさしく眺めて、「僕は、ばかなことばかり言ってるね。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そう言いながら起きあがり、小さいさちよを、ひしと抱いた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　テエブルのむかふにひつそり坐つた小さいさちよの姿を、やさしく眺めて、「僕は、ばかなことばかり言つてるね。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
