        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "仝年十一月、諸井三郎を訪ぬ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仝年五月、「朝の歌」及「臨終」諸井三郎の作曲にて日本青年館にて発表さる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花、梅吉、喜三郎ことし十五の小性とて娘お蝶がませぶりをさげすみしたる樣もなく家代代の重寶をそつと小縁に運ぶ哉。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理人篠村宇三郎、かご入りの青海苔を持って来て、「これは今年始めて取れましたので差上げます。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、小指ぐらいの茶いろなかじかが、横向きになって流れて来たので、取ろうとしたら、うしろのほうで三郎が、まるで瓜をすするときのような声を出した。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」三郎が、河原の砂っぱの上で、ぴょんぴょんはねながら、高く叫んだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」三郎は立って、口を大きくあいて、手をひろげて、しゅっこをばかにした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎だけが、いちばん上で落ち着いて、さあ、みんな、とか何とか相談らしいことをはじめた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎ひとり、上をまわって泳いで遁げたら、しゅっこはすぐに追い付いて、押えたほかに、腕をつかんで、四、五へんぐるぐる引っぱりまわした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎は、水を呑んだとみえて、霧をふいて、ごほごほむせて、泣くようにしながら、「おいらもうやめた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中豊三郎氏の人物二枚も随分変っている。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "も少し早くこの器械が出来ていてそして男三郎の審問などに使ったら面白かったろうに。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝代官屋敷の夜――　竹垣三郎兵衛の屋敷に乱入した次郎長を始め清水一家の猛者八人。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　彼女の二人の子供、十歳になった三郎と、まだ七歳の四郎は、その日昼飯が済んでから、戸外へ遊びに出たまま帰って来ないのであった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病後の四郎がこの風に当って、折角ここまで癒って来た病気をぶりかえさなければいいが、もし道に迷ったのなら、年上の三郎がうまくここの番地が云えればいいが、とか彼女は様々な思いにかき暮れていた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、カバーをかけたタクシーが夜間薬品店のまえでとまると、なかから、林田三郎が仕掛花火のように商館にかけこんだ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "改まつて紹介すれば、新美｜術院會｜員、國｜畫會｜總帥の梅原｜龍三郎｜畫伯その人だが、なアにお互に負けず嫌ひで相當｜意地つ張りでもある二人。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時頃和木清三郎から電話。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時から二時過ぎまで井汲清治、和木清三郎、勝本清一郎達と肩を並べてお辭儀役。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオニングを和服にくつろいでガス暖爐の前に坐ると間もなく、これも同町内の梅原龍三郎さんから電話。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時過、和木清三郎、倉島竹二郎來訪。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀の父は東京府に勤めて三十五円ばかり取って居て夫婦の間にお秀を長女としてお梅源三郎の三人の児を持て、左まで不自由なく暮らしていた。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "又た室の片隅に風呂敷包が有って其傍に源三郎の学校道具が置いてある。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其外源三郎の臥て居る布団というのは見て居るのも気の毒なほどの物で、これに姉と弟とが寝るのである。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "松雲閣の玄関からそのまゝ事務所へ廻りみちして支配人の福地第三郎君に会った。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　第三郎氏はじぶんで椅子をすゝめた。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に云ったような人間の多い時代ですから、旗本の隠居や大町人の贅沢な奴らが川春の宇三郎にたのんで、御留川のむらさき鯉を食うのがある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇三郎はそこを附け込んで、うまい儲けをする。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お徳の白状もあるのですから、すぐに宇三郎を召し捕ってもいいんですが、宇三郎という奴はなかなか食えない老爺らしいので、下手に当人を引き挙げて強情にシラを切っていられると面倒ですから、まず料理番の富蔵をおさえて、こいつの口から動かない証拠を挙げてしまおうと思ったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
