        "examples": {
          "standard": [
            {
              "text": "特定の感染症は、再帰熱を引き起こすことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "医師は、患者の症状が再帰熱のパターンに一致すると診断した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「熱が上がったり下がったりを繰り返すんだけど、もしかして再帰熱かな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "当時陸軍では、ことに田舎の軍隊では、再帰熱のように時々起る語学熱が流行っていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるにしても、このほど帰国の船中｜蘭貢において、テレーズが再帰熱にて死去したるは哀れとも云うべく、また、皮肉家大鳥文学博士がこの館を指し、中世堡楼の屋根までも剥いで黒死病死者を詰め込みしと伝えらるる、プロヴィンシア繞壁模倣を種に、黒死館と嘲りしこそ可笑しと云うべし――。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "再帰熱は時々見られる。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "再帰熱、コレラ、赤痢、およびマラリアがコーカサスから北極地帯に拡がった。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
