        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫人はその追想記の中で、箪笥の抽出を開けるにさえも、そッと音を立てぬように気をつけたと書いている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした夫婦の会話は女中や下僕にはもちろんのこと、子供たちにさえもよく解らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ家の中に住んでる家族の者にさえも、ほとんど全く解らない不思議な言葉で、何時間も倦きずに睦じく語り合ってた二人の男女こそ、この世における最も理想的に幸福な夫婦であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年多少日本に幻滅を感じた時でさえも、他の外人が日本を悪意的に批評する時、いつも憤然として大に怒り、さながら自分の愛人を侮辱された時の騎士のごとく、鋭い反撃の槍をふるって突き当って行った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊さんになるさえもよきです』『あなた、坊さんになる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどにも情深く、心根のやさしい人があるかと思い、ヘルンに対して、何かいじらしく涙ぐましいものさえも感じたというのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人でさえも書斎に入ることは許されなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村は芭蕉を崇拝し、自分の墓地さえも芭蕉の墓と並べさせたほどであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛でさえも、蕪村の場合には夢の追懐の中に融け合っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのヒイキにした蕪村でさえも、単なる写生主義の名人としか解さなかった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "来訪客と話すことも、昔のように苦しくなく、時に却って歓迎するほどでさえもある。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今特別の同情を以て見ている余にさえも、この何処の何人とも知れぬ人の記憶が長く止まっていようとも思われぬ。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、一人でさえも登り難い道を、一人を負って駈ける事は、出来ない相談だった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千年来伝わった日本人の魂でさえも、打砕いて夷狄の犬に喰わせようという人も少なくない世の中である。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうやって自分を真昼の寂しさに憩わしている、そのことさえも意識していない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い煙さえも液体に見えて立騰っていた。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にして生、そこに芳烈な匂いさえも感ぜられる。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼女が鑑札を受けて大びらで稼ぎに出るとなるとこの探偵は尊敬さえもしてくれた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう大丈夫役人どもは私たちを殺しに来たのでもなく、私どもの居ることさえも知らないことがわかったのです。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず客観的表現を研究の対象として、その範囲内における一般的特徴を索めるから、客観的表現に関する限りでさえも「いき」の民族的特殊性の把握に失敗する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "扇紋は畳扇として直線のみで成立している間は「いき」をもち得ないことはないが、開扇として弧を描くと同時に「いき」は薫をさえも留めない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ新米にさえもならない自分の顔がその日どんなであったかは自分には分らない。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのんびりした世界でさえも、自分の手でしっかり握っていない限り私有物の所有権は確定しないものと見える。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地味な科学者の中でさえも「新しいもの好き」がある。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にして多くの文明の利器は時々南向いた豚さえも北へ向かせるように出来ているのが多い。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように、最も問題になる憂いの少ない論文でさえも、見る人の眼のつけ処でその価値にかなりの懸隔を生じるのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
