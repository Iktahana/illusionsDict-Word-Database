        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "茶番をやる水兵もある、軍樂を奏する仲間もある、武村兵曹は得意に、薩摩琵琶『河中島』の一段を語つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十九回　薩摩琵琶春枝夫人の物語――不屆な悴――風清き甲板――國船の曲――腕押し脛押と參りませう――道塲破りめ――奇怪の少尉　春枝夫人は清しき眉を揚げ『あゝ其事！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "武村兵曹も其仲間に入つて、頻りに愉快だ／＼と騷いで居つたが、何時何處から聞知たものか、例の轟大尉の虎髯はぬつと進み出て『これ、武村兵曹、足下はなか／＼薩摩琵琶が巧い相な、一曲やらんか、やる！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "究竟するに紅葉は実を写す特有の天才より移つて、佐太夫なる、或意味に於ての理想的伝記を画き出たるを以て、平常の細微巧麗なる紅葉の作を読み慣れたる眼には、何となく琴曲を欲ふ時に薩摩琵琶を聞くが如きの感あるなれ。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これや不可と思つて、聲を立てて讀むと何時しか御經の眞似をしたくなつたり、薩摩琵琶の聲色になつたりする。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "余興に入り、薩摩琵琶、落語、小樽新聞から派遣された年のとった記者の修養講話――「一日講」――があり、――そして、「酒」が出ることになった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かと云うと田中君は、詩も作る、ヴァイオリンも弾く、油絵の具も使う、役者も勤める、歌骨牌も巧い、薩摩琵琶も出来ると云う才人だから、どれが本職でどれが道楽だか、鑑定の出来るものは一人もいない。",
              "citation": {
                "source": "葱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってまた人物も、顔は役者のごとくのっぺりしていて、髪は油絵の具のごとくてらてらしていて、声はヴァイオリンのごとく優しくって、言葉は詩のごとく気が利いていて、女を口説く事は歌骨牌をとるごとく敏捷で、金を借り倒す事は薩摩琵琶をうたうごとく勇壮活溌を極めている。",
              "citation": {
                "source": "葱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩も作る、ヴァイオリンも弾く、油絵の具も使う、役者も勤める、歌骨牌も巧い、薩摩琵琶も出来るサア・ランスロットである。",
              "citation": {
                "source": "葱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩吟、薩摩琵琶、落語、講談、声色、手品、何でも出来た。",
              "citation": {
                "source": "父",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯をすましたばかりで、階下では煙草専売局へ勤めている亭主がラジオの薩摩琵琶を聞いている。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "永田錦心の薩摩琵琶はよかった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "天幕の諸君は尚も馳走に薩摩琵琶を持出した。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十勝の山奥に来て薩摩琵琶とは、思いかけぬ豪興である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "演壇では、筒袖の少年が薩摩琵琶を弾いて居た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その琵琶の音は、正銘の薩摩琵琶の音でありますけれども、聞く人は、何だかわからないと言っている人が多いようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他には薩摩琵琶歌だの漢詩｜朗吟なぞも存在しているが、此れも同じく色彩の極めて単純な日本特有の背景と一致した場合、初歩期の単調が、ある粗朴な悲哀の美感を催させるばかりである。",
              "citation": {
                "source": "黄昏の地中海",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等にはもつと了解し易い詩吟もあり薩摩琵琶歌もありながら、彼等は單純に西洋音樂は日本音樂よりも高尚である深遠であると云ふ盲目的判斷、寧ろ迷信に支配されて馳せ集るのだ。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "錦心の弟子で交換局へ行き夜刃郎錦心の孫弟子二階まで出張り古蝶薩摩琵琶一軒家ではあるまいし同　私は少年の日、永田錦心が「石童丸」の仰せをうけて清正は……」のあの一齣、沈痛な節廻しのレコードを聴く毎に、ヂーンと瞼を熱くした。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ此は作者名を忘れたが「薩摩琵琶すてつぺんから目をつむり」独唱に人を喰つたる高島田古蝶女優もうアートペーパーかなと思ひ同　アートペーパーと云ふものの、あの紙質のあの光沢の、さらにそこへ印刷された女優姿の、いかに近代の魅惑たりしかよ、こはこれ、そのころのわかい女優が宿願の声と聴け。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "『紳士にして「お茶碗」と「お碗」との区別を知らず、富豪にして「清元」と「長唄」とを混同し「歌沢」「新内」の生粋を解せずして、薩摩琵琶、浪花節の露骨を喜び、旧劇の渋味をあざけりて壮俳の浅薄を賞す。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩摩琵琶浪花節よりもっと「露骨」な安来節、鴨緑江節が勢力をえている。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、音痴の私が、うたうことのうまい道理はないが、三十をすぎてから、偶然の動機で、正派薩摩琵琶の師匠と知り合い、正派の豪壮な階調が、ことごとく文章、特に語呂の呼吸と物語の筋の一致しているところにあると思った。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "解説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとき師の米作氏いわく「永田は画よりも琵琶が上手で全く天才ですよ、確かに物になります、その内一つやらせてお聞かせ申そう」と、これが後に薩摩琵琶で一流をだした永田錦心とは当時夢にも思わなかった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが今日の薩摩琵琶の起原である。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
