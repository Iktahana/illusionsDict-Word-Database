        "examples": {
          "standard": [
            {
              "text": "彼は裁きの庭で自身の潔白を主張し、真実を訴え続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの被害者が、裁きの庭で正義が実現されることを願っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "裁きの庭の厳粛な雰囲気に、誰もが言葉を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一人ぼっちの老年、病気、それから怖ろしい裁きの庭でなさる返事。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは裁きの庭だぞ。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼自身は、甘んじて、その直後に襲せて来た捕手の群れに身をまかせ、われから司直の裁きの庭へすすんで坐ったものだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
