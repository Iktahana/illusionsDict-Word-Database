  {
    "uuid": "fc6e3372-e637-573b-a300-37f27fed9453",
    "entry": "散見",
    "reading": {
      "primary": "さんけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being seen here and there",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "立派なる洋館も散見す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧みて「高根の雪」なる美しい語が、我が日本の古くからの歌に散見するのも、我が山岳国には欠かれない存在であると云わねばならない。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の趣味としては、もつと空氣の明るく近代的で、工場や、煙突やが林立し、一方に生産的市場が活動しつつ、一方に赤瓦の洋風家屋などの散見する情趣、即ち大都會の郊外にみる近代的生活の空氣がすきなのだ。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝に雪をいただいて、それが丁度、枝に雪がなっているように見える枯木が、五六本ずつ所々に散見する外、あたりには何物も見えなかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鸚鵡石」という不思議な現象の記事を、※軒小録、提醒紀談、笈埃随筆等で散見する。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し好色すぎたと思われる描写が処々に散見されたからである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し十四｜位から彼の父に送る手紙の中には、もう政治上の意見などがちらほら散見し始めたさうである。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽蝦夷の称は、元慶二年出羽の夷反乱の際にも、屡々散見す。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に其の言散見するありて、其書の完成せる無きならん。",
              "citation": {
                "source": "水",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝ふるところの談、雑書に散見するもの亦多し。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又各種の戰記野乘にも軍氣に關する記事の散見するのを認める。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま読みかえし、私自身にさえ、意味不明の箇所が、それらの作品には散見されるのである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "意味不明の文章が散見されるということだけでも、私は大いに恥じなければいけない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞や雑誌などで、夫婦という字を散見しても、ひとのことどうでも宜いようなものの、好もしいとはかの女は思わない。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾百種の新聞雑誌に散見する議論にはすこぶる高尚なるも多きを、余は通信員となりし日より、かつて大学にしげく通いし折、養い得たる一隻の眼孔もて、読みてはまた読み、写してはまた写すほどに、今まで一筋の道をのみ走りし知識は、おのずから綜括的になりて、同郷の留学生などの大かたは、夢にも知らぬ境地に到りぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……というような考察は、英国の極めて高等な芸術家たちの論議に散見しているところだそうである。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧を伴い、亦屡々豪雨の降ったことは当時の戦記の到る所に散見して見える。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾百種の新聞雜誌に散見する議論には頗る高尚なるも多きを、余は通信員となりし日より、曾て大學に繁く通ひし折、養ひ得たる一隻の眼孔もて、讀みては又讀み、寫しては又寫す程に、今まで一筋の道をのみ走りし知識は、自ら綜括的になりて、同郷の留學生などの大かたは、夢にも知らぬ境地に到りぬ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨家の書といふものは、漢書に六部の書名が見えるが、胡非子隨巣子等の文は意林や太平御覽や北堂書鈔等に散見するのみで全豹は覗へぬのであり、何樣しても現存墨子を研究の標的とするほかに道は無い。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた各種の戦記や野史（在野の人が編纂した歴史書）にも軍気に関する記事が散見するのを認める。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来焚書の厄は屡々歴史に散見する。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの雷と雀の鳴き声の如き取扱いをしている句は、江戸川柳の中に至るところに散見する。",
              "citation": {
                "source": "江戸推理川柳抄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは享保年間に尾州領内をあらし廻った大賊で、その事蹟は諸種の記録にも散見している。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――この千鶴といふ女をめぐつて、カトリック村落の父親と息子との一挿話はまことに印象的で、しかも、愛慾の影はあちらこちらに散見します。",
              "citation": {
                "source": "檀一雄「リツ子・その死」",
                "author": "――創芸社刊――",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠方からそこを望遠鏡で覗いた者の話によると、人間の白骨ばかりでなく、時々｜紛れ込んで来る熊や鹿や其の他の動物の屍や骨が夥しく死の谷の中に散見するそうである。",
              "citation": {
                "source": "科学時潮",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "また写実派の中に散見し得る浪漫的分子を切り放して、浪漫派の中に入れる事も困難になってしまう。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　以下、連日散見のままに。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "けどワシの財布からでた金は、サードパーティには渡してもアップルにはびた一文渡さんけんね」暴走族並の改造マシンを叩きながら、Ｔ田は広島弁丸出しでそうわめきたてた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
