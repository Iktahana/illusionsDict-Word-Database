    "definitions": [
      {
        "index": 1,
        "gloss": "man in attendance (on a person of high standing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫人や家族の者たちは、彼の左右に侍って酌をしながら、その日の日本新聞を読んできかせた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女郎屋の印象は、私の故郷上州で唄ふ盆踊りの歌「鈴木主水といふ侍は、女房子供のあるその中で、今日も明日もと女郎買ひばかり。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大井川の水｜涸れ／＼にして蛇籠に草離々たる、越すに越されざりし「朝貌日記」何とかの段は更なり、雲助とかの肩によって渡る御侍、磧に錫杖立てて歌よむ行脚など廻り燈籠のように眼前に浮ぶ心地せらる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お祝言の時などの島臺の、れいの蓬莱山、尉姥の身邊に鶴と一緒に侍つて、鶴は千年、龜は萬年とか言はれて目出度がられてゐるのは、どうやらこの石龜のやうで、すつぽん、たいまいなどのゐる島臺はあまり見かけられない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして侍き崇むる外に山に就ての知識を授けて貰った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岳神の妻は、笑って冗談のようにして、「この中に、もし、お気に入りの娘でも見当りましたら、お身のまわりのお世話に侍かせましょう」　といって呉れた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはわたしの母に侍し、母が首尾よく天に生れたならば、すぐ海に入って大經を探らうと思ふ。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しるべの燈火かげゆれて、廊下の闇に恐ろしきを馴れし我家の何とも思はず、侍女下婢が夢の最中に奧さま書生の部屋へとおはしぬ。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『武家義理物語』の三の一に「すこしの鞘とがめなどいひつのり、無用の喧嘩を取むすび、或は相手を切りふせ、首尾よく立のくを、侍の本意のやうに沙汰せしが、是ひとつと道ならず。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見るより美登利の顏は赤う成りて、何のやうの大事にでも逢ひしやうに、胸の動悸の早くうつを、人の見るかと背後の見られて、恐る／＼門の侍へ寄れば、信如もふつと振返りて、此れも無言に脇を流るゝ冷汗、跣足になりて逃げ出したき思ひなり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥州にいる牛若丸に逢いたくなった母｜常盤が侍女を一人つれて東へ下る。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の頂点では常盤と侍女と二人が丸裸にされて泣き騒ぎ、その上に無残に刺殺され、侍女の死骸は縁側から下へころがされるといういきさつが数コマに亘って描かれてあるらしい。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お侍の果し合か」　「ううん」　「じゃ渡世人か、其奴ァ面白え」　石松、起き上って表へ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝表　侍が床几に憩み、掛けている。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と三次の背後から通り過ぎた又別の深編笠の侍。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いているその侍の移動。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次急に足を早めて侍を追い越すとその儘走り出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前にハタと足を止めたのが今の侍である。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷の衝立の向うで侍が五、六名酒を呑んでいる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が淋しくたたずむ時、　彼等の背後を韋駄天の如く走り過ぎた侍がある。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤が、他の若侍に、Ｔ「聞かれたか　仲蔵の定九郎？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と問えば、　若侍の一人が「ウン兼々承知致す」Ｔ「変っとるそうな」　進藤会心の笑い「貴公等未だ御存知ない。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　他の若侍「ハアハア、あの大吉、どうか致したか」。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤が、Ｔ「何でも、仲蔵の定九郎　あの大吉に　そっくりとの事」　他の若侍「左様か、此奴は初耳」　進藤がヘヘンと笑って、Ｔ「河原者風情に　真似られるとは　大吉奴、落ちぶれたわい」　と、一同冷笑する。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の若侍が大きな欠伸した。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、他の若侍と共に気色ばむ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤始め、若侍達も、いまいましそうな顔。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤始め若侍「畜生！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急速なるＦ・Ｏ）　＝（Ｆ・Ｉ）ある街角　進藤甚助やって来ると、昨日の若侍と剣士日下部典六の面々とバッタリ出会った。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武者は（むさ）侍は（さぶらい）牛車は（ぎっしゃ）不孝は（ふきょう）禿は（かぶろ）敬白は（けいびゃく）――といった類がそれである。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
