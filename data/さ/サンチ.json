    },
    "definitions": [
      {
        "index": 1,
        "gloss": "centimeter (esp. of cannon caliber, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
