  {
    "uuid": "b965522a-3c05-5215-a376-bde68cb56c9f",
    "entry": "糎",
    "reading": {
      "primary": "サンチ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
