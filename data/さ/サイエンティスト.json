          "standard": [],
          "literary": [
            {
              "text": "「東洋の」秘密教団と、デコボコ二人組のマッドサイエンティストに狙われ、バッキンガム宮殿や、アルプスや、バハマを逃げまわるビートルズの物語のなかに――。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "但、少女の内的圧迫から生じた病気をクリスチャン・サイエンティストの力で直すみたいなところはいや也。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスチャン・サイエンティストは多分このような発疹や発熱を否定し、痒さを認めるのを拒み、「無限」と調和するだろう。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
