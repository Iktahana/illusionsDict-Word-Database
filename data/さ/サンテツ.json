    "definitions": [
      {
        "index": 1,
        "gloss": "staying up all night three nights in a row",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "肥前の唐津では、酔っ払いのことを『さんてつまごろう』と称えるが、これはどういう意味であろうか。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんてつ先生とかいうほかには姓名もよくは知らなかった。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事の手を抜いて来るらしい、医者のさんてつに叱られて帰るが、またすぐ覗きに来るというふうであった。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜさんてつなどと呼ばれるのか誰も知らなかったが、そう呼ばれても滝本は訂正することもなく、改めて本名を名のることもなかった。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんてつ先生は、石で圧迫されたために、内臓にひずみができているのだろう、まもなくおさまるだろうと云った。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "与平は二人の小頭とともに、義一とりゅうの傷をしらべながら、誰かさんてつ先生を呼んでくれ、と云った。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
