    "definitions": [
      {
        "index": 1,
        "gloss": "dark night in the rainy season",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この花も五月闇のなかにふさわなくはないものだと思いました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……軒の柳に靄の有る、瓦斯ほの暗き五月闇。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月闇に、猫が屋根をつたはらないとは誰が言ひ得よう。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冥途の首途を導くようじゃありませんか、五月闇に、その白提灯を、ぼっと松林の中に、という。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　風が、どっと吹いて、蓮根市の土間は廂下りに五月闇のように暗くなった。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は低く灰汁を漲らして、蒼穹の奥、黒く流るる処、げに直顕せる飛行機の、一万里の荒海、八千里の曠野の五月闇を、一閃し、掠め去って、飛ぶに似て、似ぬものよ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中陰の翌日からじめじめとした雨になって、五月闇の空が晴れずにいるのである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月闇　闇の妖女の唇は、あんまり紅くて、まつ黒だ。",
              "citation": {
                "source": "かげろふ断章",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月闇おぼつかなきに郭公　　山の奥より鳴きていづなり　この歌調には、何か切なものがある。",
              "citation": {
                "source": "新緑",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月闇おぼつかなき山の奥から鳴いて出づる郭公と共に止み難い何ものかの力を同感しているように思われる。",
              "citation": {
                "source": "新緑",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は傍観せず、鎌倉の山の木立深い五月闇をおかして鳴き出づる郭公の心になっていると感じるのは私の誤りだろうか、実朝は、切な歌を多く遺した。",
              "citation": {
                "source": "新緑",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "訪ふ人も、なき憂き宿は、五月闇、雨の音にぞ、なぐさまれける。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "真暗い五月闇に草舎の紅い火を見るも好い。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、待ちなよ、淺草まで此夜更けに行くんだ、せめて、これでも」　平次は紙入を持つて追つかけましたが、八五郎の姿はもう、五月闇の中に消えてしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "苫三七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ真っ暗な五月闇の雲の断れ目に、ぴかぴかと大きく光る星だけが、何かの凶兆のように眼に映った。",
              "citation": {
                "source": "茶漬三略",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山梔子の花はほの暗い五月闇の中に、白い顔をもたげて、強い匂の手で通る人を呼びとめた、あの素晴らしい実の形や色はそんな心根の暖い情愛の言葉でなかつたならば何であつたらう。",
              "citation": {
                "source": "雑草雑語",
                "author": "河井寛次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "網打やとればものいふ五月闇　　　　雪芝　舟か陸かわからぬが、とにかく投網を打っている男がある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "つねならばもう梅雨雲の五月闇といわれる頃を。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくの五月闇であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "高橋の手勢は、橋上を押してゆき、隅田藤内左衛門の一勢は、水馬隊を編成して、橋下を泳ぎわたる――となって、前夜の北岸は五月闇のうちに殺気立った。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきやみ烟たなびく暮れ方を、夢のやうにて人に添ふみち。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
