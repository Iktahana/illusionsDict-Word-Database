          "standard": [
            {
              "text": "探偵は、遺留品に触れることで過去を読み取るサイコメトリー能力を持つ女性に協力を求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サイコメトリーは、超能力の一種としてフィクション作品によく登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のサイコメトリーは、持ち主の記憶や感情を鮮明に感じ取ることができるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あれ程の真黒焦の焼餅やきな位だから、吾が夫のことでヒステリーのやうになると、忽ちサイコメトリー的、千里眼になつて、「吾が行へを寝ぬ夢に見る」で、あり／＼と分つて後追駈けたものであらうかも知れぬ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
