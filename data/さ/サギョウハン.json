          "literary": [
            {
              "text": "「作業班、出発用意」　作業班の人々は、急いで空気服をつける。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の номер〔借室〕へはコオペラチーブのウダルニク〔突撃作業班員〕が来てツェールイ・リャード〔一連の〕の不愉快があったと云う。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "作業班、ライフ・ロープ張り方、急いでやれ」　山内が命令を伝達した。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "海兵の作業班がありたけのロープを筏の上に縦横に張りまわした。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
