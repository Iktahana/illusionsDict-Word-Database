        "examples": {
          "standard": [
            {
              "text": "サムスンは世界的な電気メーカーとして知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新のサムスンのスマートフォンは、カメラ機能が格段に向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サムスンの工場では、最先端の半導体が生産されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あるいはブラッドフォードのメイソン、名うてのマラー、モンペリエのルフェーヴル、ニューオーリンズのサムスン。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の縁のある眼を慘忍な所業の爲めに取り去られた捕はれの鷲は、あの盲目のサムスンのやうな樣子をしてゐたであらう。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
