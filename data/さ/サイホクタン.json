        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここは、本州の西海岸の最北端の港である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七学級の教室はその最北端にあった。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清澄山より天津を經て保田に至るの路、凡そ十里、安房の最北端に一貫して、一方は、東海岸に達し、一方は西海岸に達す。",
              "citation": {
                "source": "房州の一夏",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "岬の端に、圓い屋根の燈臺の建物が立つのは、やがて織布のやうに長い島根半島の最北端であると知れた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＵＯＭＩ　フィンランド共和国は欧羅巴の最北端に位し、北緯六十度と七十度のあいだにある。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ちに最北端の巓に漕ぎつけて、一同之に上る。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、独領ニューギニアの最北端に、“Nord-Malekula”という、荒れさびた岬がある。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてアラスカの最北端のバロー岬を指して進んだ。",
              "citation": {
                "source": "北極のアムンセン",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "堺の街｜端れは即ち和泉の国端れになつて居る程に、和泉の最北端にあるのです。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "堺の街端れは即ち和泉の国端れになつて居る程に、和泉の最北端にあるのです。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茨城県の久慈川ではどの位上流へ鱸が遡るかと調べて見ると、久慈郡の最北端大子町斎藤桃太郎さんの簗へ年に二、三度は落ちるそうである。",
              "citation": {
                "source": "河鱸遡上一考",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此脈の最北端に位する菅峰（大洞山とも称す、高さ千四百七十三米四）は、笹塒山の右に尖頂を現しているのがそれであろうと思うが、或は此山は見えないかも知れない。",
              "citation": {
                "source": "望岳都東京",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（船を木曜島の南の湾につなぎとめ、海路は豪州最北端に入った。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "（欧州最北端の村に行きつく。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはもとのキトー王国の最北端であるから、町には相当の金銀宝玉が見出された。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
