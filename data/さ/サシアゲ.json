[
  {
    "uuid": "1d9eb8e1-3460-564d-8343-94891ec16751",
    "entry": "差し上げ",
    "reading": {
      "primary": "さしあげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
