[
  {
    "uuid": "3e884fd4-830f-5963-aa6f-35dab45a8cd7",
    "entry": "再現",
    "reading": {
      "primary": "さいげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
