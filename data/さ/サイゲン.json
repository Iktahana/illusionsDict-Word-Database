    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reappearance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人語を肉類のやうに罐詰にして永く保存したり、隨意に再現したりしたいといふ希望。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の生きた知覚は、既に十数年を経た今日でさえも、なおその恐ろしい印象を再現して、まざまざとすぐ眼の前に、はっきり見ることができるのである。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ換へると、文章は人格の再現なりといふ事になるが、これをもつと狹い意味に文章は氣質の再現なりとも言へると思ふ。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客観的にあったことを、あったことゝして作品の上に再現しようとした。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、前者では練習さえ積めばかなりの程度までは思いのままにあらゆる有様を再現することが出来るが、後者の方では二度と同じ結果を出すまでに何度試みを繰返さなければならないかを、確実に予言することが出来ない。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の再現して見せたその調子は自分を泣かすだけの力を持っていた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まではなるべくなら避けたく思った統計的不定の渾沌の闇の中に、統計的にのみ再現的な事実と方則とを求めるように余儀なくされたのである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の価値と同じく文学の価値もまたこの記録の再現性にかかっていることはいうまでもない。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりにそのカメラの視野内に起こった限りの現象は必然的なものも偶然的なものも委細かまわず細大もらさず記録され再現されるのである。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある母音や子音は明瞭に出ても、たとえばＳの音などはどうしても再現ができなかったそうである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは妙に押しつぶされたような鼻声ではあったが、ともかくも文学士の特徴ある「ラアヽ」などの抑揚をかなり忠実に再現したので、講堂の中からは自然な感嘆の声とおさえつけた笑声とが一時に沸きあがった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "改良を加えた蝋管蓄音機を聞きそこなった私は、音色の再現がどのくらいまで完全に行ったかを経験する事ができなかった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この器械はいわゆる無ラッパの小形のもので、音が弱くて騒がしい事はなかったが、音色の再現という点からはあまり完全とは思われず、それに何かものを摩擦するような雑音がかなり混じていて耳ざわりであった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音波によって起こされた電流の変化を、電磁石によって鋼鉄の針金の付磁の変化に翻訳して記録し、随時にそれを音として再現する装置もすでに発見されて、現にわが国にも一台ぐらいは来ているはずである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三色写真が絵画の複製術として物足りないごとく、蓄音機は名曲のすぐれた演奏の再現器として物足りないものである。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考えでは、三色版が色彩に対しても不忠実であるのみならず、画面の微妙な光沢や組織に対し全然再現能力のないのに反して、良い蓄音機では音色や強弱の機微な差別が相応に現われ、そして最も重要な要素と考えられる時間関係がかなり厳密に再現される。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ音楽家にとって不満足であろうと思うのは、たとえ音色がよく再現できていると言ったところで、これをほんとうの楽器に比べればどうしてもいくぶんの差違のある事は免れ難い事である。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "めいめいの画家の好む顔の線がそのままに袖のふくらみの線に再現されているのを見いだしてひとりでうなずかれる場合がかなりにある。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同じ「夕飯」がまだまだ根を引いて「木曾の酢茎」に再現しているかの疑いがある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝗の羽音がどれだけ忠実に再現されているかは明らかでないがともかくも不思議な音である。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてカメラの対物鏡は観客の目の代理者となって自由自在に空間中を移動し、任意な距離から任意な視角で、なおその上に任意な視野の広さの制限を加えて対象を観察しこれを再現する。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にして現在の録音機と発声マイクロフォンとはその機巧のいまだ不完全なために、あらゆる雑音の忠実な再現に成功していない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、盲者が、話し声の反響で室の広さを判断しうるような微妙な音色の差別を再現することはまだできないのであるが、それにもかかわらず適当な雑音の適当な插入が画面の空間の特性を強調する事は驚くべきものである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、たとえば色彩再現の科学的技術がいかに発達したとしても、それがために発声映画がもたらしたほどの根本的な革命が起ころうとは思われない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "億百万のばけものどもは、通り過ぎ通りかかり、行きあい行き過ぎ、発生し消滅し、聨合し融合し、再現し進行し、それはそれは、実にどうも見事なもんです。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大詩人の夢を再現し、その芸術の影に形と実質とを与えてくれたからだ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのことは、夢が何億萬年の古い人類の歴史を、我々の記憶の中に再現することを實證する。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく夢の起源は、人間にも動物にも共通して、祖先の古い生活經驗を遺傳してゐるところの、先驗的記憶の再現である。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、こまかいことをいえば、さいげんがないが、すべて、きみという曲芸師が、豹の皮をかぶっていて、とっさに、早がわりしたということがわかれば、黄金豹の怪事件は、みんな解決がつく。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな猛者に、ふたりもおどりこまれた日には、よしや、城内に二千の野武士はあるとも、どれほど死人｜手負いの山をきずかれるか、さいげんの知れたものではないと思った。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
