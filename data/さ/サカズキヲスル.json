    "definitions": [
      {
        "index": 1,
        "gloss": "to share a cup of sake (in commemoration of something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "辻堂の中で三々九度の杯をするように一杯飲もう、と言った。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婦が来てから杯をするまでには時が立った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後の乾杯をする時、阮東は恐ろしい声で叫びました。",
              "citation": {
                "source": "三つの悲憤",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い木片で乾杯をする　　狡獪な農夫は此処より立去れ。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尉の紹介でその女性の隣の席につきましたが、一雄は何が何んだかわからず、夢のような気がしてぼんやりしていると、背広服をはじめ一同は夫のために乾杯をするやら、いかにも丁寧なにこやかな態度で、ここでもまた松岡の父が話題にのぼり、父の交遊関係など根掘り葉掘り訊ねるのでした。",
              "citation": {
                "source": "恐怖の幻兵団員",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネると、藤山一郎来り、北浜のサンボアへ行き、結婚一年の乾杯をする。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "婚礼の杯をするまでは、そんな心地は覚えない人であったのに、ゆうべからは藤吉郎の顔へ眸も向けられなかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
