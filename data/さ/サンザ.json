[
  {
    "uuid": "e712ad3e-f433-54aa-9404-f9d528e77d48",
    "entry": "蚕座",
    "reading": {
      "primary": "さんざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
