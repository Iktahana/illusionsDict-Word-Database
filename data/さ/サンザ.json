  {
    "uuid": "29c52d83-7946-5337-92ba-4345509b7439",
    "entry": "サンザ",
    "reading": {
      "primary": "サンザ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sansa",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は尺に近い赤魚を、サンザン苦労して引つ張り上げ、魚籠に入れる直前に落した。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、浪人者サンザンの態にて逃げ去る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉と典六の立廻り若干――　結局、サンザンな目に遭った典六、其の場におさえつけられた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角、白倉サンザンにやられた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はサンザしたい放題のことをして来た虚無主義のブルジョア……惜しい浮世じゃ御座んせんからね。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりにはサンザシやヘビノボラズが生えています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の光は形円きトベラノキに遮られて空気｜冷やかに風うすく匐ひくねれるサンザシに淡紅緑の芽は蕾み、そのもとに水仙の芽ぞ寸ばかり地を抽きてうち戦ぐ。",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで良心のない人間みたようにニコニコしているもんですから、あたしは、なおの事腹が立って腹が立って……」とサンザンに泣いて訴えられますと、未亡人はつつましやかに溜め息を洩らしながらコンナ忠告をされました。",
              "citation": {
                "source": "奥様探偵術",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處には一本の黒い山櫨（サンザシ）が生へて居て、其れに黒い旗が掛かつておる。",
              "citation": {
                "source": "アーサー王物語",
                "author": "KING ARTHUR'S ROUND TABLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな事なら、わしゃ言うとかにゃならぬことや、仕ておかにゃならんことが沢山沢山あったに――おじいさん、どこまで他人を困らせる人か、わしゃもう、若いころからこの人のためには、ほん、サンザンな目に逢うとるわ。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "髭の男は、梅の実のカクテルをアンコールして寒子には甘いサンザノを註文してくれた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度ソンナ奴に狙われたら生きて日本に帰れねえからそう思えってサンザ威嚇かされておりましたからね。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾と貴美子さんを自動車へ乗せてミカド・ホテルへ連れて行ってサンザ御馳走をして下すった上にね。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『象は眞言宗と見えて、鼻の先に香を摘んで、香爐に不恰好に振り撒き、「象撒くサンザンだ（ノーマクサンマンダのもじり）ベーロシヤナア」と唱へて退く……虎は禪宗と見えて「南無迦羅タンノウ虎ヤー虎ヤー」（これでお仕舞）』と結んでゐる。",
              "citation": {
                "source": "新詩發生時代の思ひ出",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い博多の事ばよう知ッとるし、なかなか好い、博多のモンとありゃ、一体誰じゃろうかい」等と、次兵衛達や、田舎芸術家達の間に、サンザン首をひねらしたものである。",
              "citation": {
                "source": "夢の如く出現した彼",
                "author": "夢野久作氏を悼む",
                "note": "青空文庫"
              }
            },
            {
              "text": "その馬面に突きつけられた雑誌が、此れまでサンザ首をひねらせた新青年の夢野久作ものするところの、あの古博多の川端――筆者の産れた――あたりと櫛田神社の絵馬堂を織り込ンだ『押絵の奇蹟』だったのである。",
              "citation": {
                "source": "夢の如く出現した彼",
                "author": "夢野久作氏を悼む",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此頃もネ、お俊姉さんのは催促髷だなんて、皆なでサンザン冷かしました。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ピシリと韮山の頬をなぐる）二三日前から、私は、手前の家をはじめとして、妾の家までサンザンお百度を踏んで、追いかけて歩いているんだ。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本田　いやね、先程から、もうサンザン話をして、口がすっぱくなる程言っても、この人にゃわからんのですよ。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の方も、去年以来、場の方でサンザンなんだ。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことで春子さんは、あちこちとサンザン苦労をなさって、そりゃひでえ目に会ったそうでやす。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それを、世間で、侵略戦争だの、ドロボウ戦争だ、戦争犯罪だ……サンザンいわれて……いや、そりゃいいさ、実際そうだったんだから。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをさ、目え釣り上げて役場さ行っちゃ、日が一日サンザからかわれてよ、ガッカリして戻って来て、ここの橋の所まで来ると泣いてござら。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあに、段々聞くと、悪い地酒をサンザ飲んで、そこへサバずしの少し腐つたやつを食つて、油に酔つちやつて頭が少しどうかしていたのよ。",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれを追いつめて来ているニヒルは、人とケンカをしてサンザンにたたきなぐられた人間が痛さとつらさに泣き、泣きながら次第にその痛さとつらさを忘れて行くような種類のものであったり、チョットした手術をされた患者が手術室から出されてヤレヤレ痛かったと思うような程度のものでは無いし、あり得ない。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――というような事をサンザンに考えた末にも尚、私には決定的な不満が残るのである。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前もサンザンいったように、もう、こいだけ、つまり半年以上もこうして来たんだから、いまさら、めんどうな事をいい合ってみても、はじまらん。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
