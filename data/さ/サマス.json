[
  {
    "uuid": "a1f974d1-a865-51ce-813e-e0c3e3ac2ee7",
    "entry": "覚ます",
    "reading": {
      "primary": "さます",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
