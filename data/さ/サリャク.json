[
  {
    "uuid": "4a1b2e90-5d0d-5581-9817-4051262be773",
    "entry": "作略",
    "reading": {
      "primary": "さりゃく",
      "alternatives": [
        "さくりゃく"
      ],
      "is_heteronym": true
    },
    "grammar": {
