    "definitions": [
      {
        "index": 1,
        "gloss": "Three Kingdoms period (of Chinese history, 220 CE-280 CE)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
