    "definitions": [
      {
        "index": 1,
        "gloss": "going against the grain (woodworking)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "門を離れた左手にあるは、青竹で作った菱垣で、檜逆目のございません板へ、徳川天一坊殿御旅館と、墨色鮮かに書いてある。",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張小刀で削るのであるが、普通なら小刀を逆に使わなければ出来ぬところを、非常にむずかしいが特殊の方法で逆目もなしに出来るのである。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷中の家の庭にその材木を置き小屋掛けをしてやり始めたのだけれど、栃の木は固く、非常に逆目の多い木なので、普通の鑿ではやれないので、正次さんという正宗系統の非常にうまい刀｜鍛冶に頼んで、いろいろな特別な鑿を拵えて仕事をしたことを覚えている。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で木目が変って逆目になるが、無理と知ってやって行くと逆目の所から割れて了う。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主殺しの大逆目付けられ、血迷ってわしを切るつもりか！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆目を避けた檜の一まい板に、筆ぶとの一行――「柳生源三郎様御宿」とある。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "追廻しが三、四人飛び出して行って、竹梯子に鳶口、逆目鋸、龕燈提灯などを借りて戻ってくる。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝兵衛、梯子でのぼって行って象の左の脇腹からすこし上った辺を逆目鋸で挽きはじめたが、骨組さえ挽切れば、後は胡粉と膠で固めた日本紙。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆目を削る大工があろうか。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "著莪すでに、また花あやめすでにしをれき、六月の百合こそさかめ、そしらぬけはひ、――君はただひとり行く。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ラキーチンのほうがいささかめんくらった形だ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とおっしゃると」ハリスはいささかめんくらって言った。",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
