        "examples": {
          "standard": [
            {
              "text": "サル痘は、主にアフリカの一部地域で発生するウイルス性の感染症である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発熱と全身の発疹が特徴のサル痘は、過去に欧米でも症例が報告されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世界保健機関は、サル痘の感染拡大に警戒を呼びかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "皆さんでひとつやってくださるとうれしいと思います。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで私は東京をはなれたくない自分の心持の面だけ肯定していて、何とかやりくろうやりくろうとして居りましたが、こうして、あなたも力をつけて下さるとうれしいと思います。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
