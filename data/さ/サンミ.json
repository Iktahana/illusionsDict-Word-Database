[
  {
    "uuid": "c91c4170-d630-5694-843c-73bfaf31740c",
    "entry": "酸味",
    "reading": {
      "primary": "さんみ",
      "alternatives": [
        "すみ"
      ],
      "is_heteronym": true
    },
    "grammar": {
