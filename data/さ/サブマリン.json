        "examples": {
          "standard": [
            {
              "text": "ドキュメンタリー番組で、深海を探査する最新鋭のサブマリンが紹介されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冷戦時代、核兵器を搭載したサブマリンは、国家間の抑止力として重要な役割を担っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、水族館の巨大な水槽で悠々と泳ぐサブマリン型の魚に目を奪われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "プラモデルだって、自動的に潜水／浮上をくりかえす、サブマリン７０７のずんぐりしたモデルが最後だから、もう一年くらいなにも買っていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サブマリンサンド」とか、「チーズバーガー」とか、「ペストリー」とか、「ワッフル」とか、知らない食べ物ばかりだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サブマリンサンドというのは、大魔神のホットドッグのようなものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈イエロー・サブマリン〉の長いフェイドアウトにかぶさって、最近は日になんどもかかる〈チェリシュ〉の印象的なイントロが流れる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
