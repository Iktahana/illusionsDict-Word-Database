        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五月十四日　金　お母様がおばあさまの来訪で青年会館へは行かないとおっしゃるので、二人は午後からサムソンとデリラを見に行く。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムソンとデリラはもう誰でも書いたし、サロメもふるいし、珍らしいものと云ったら、門井も此位ほか思いつくまい。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サムソンとデリラ」のことを思う。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうね」「サムソンとデリラですって――」　曲目をきくと伸子は行って見たくなった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に組曲「アルジェリア」や歌劇「サムソンとデリラ」といったものがあるが、良いレコードはない。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌劇「サムソンとデリラ」はサン＝サーンスの傑作でもあるが、浪漫的な良いものだ。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
