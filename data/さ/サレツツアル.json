    "definitions": [
      {
        "index": 1,
        "gloss": "to be in the process of being ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
