  {
    "uuid": "19014d06-bf7c-5aa2-96a5-43bcf0aa54ea",
    "entry": "主典",
    "reading": {
      "primary": "さかん",
      "alternatives": [
        "しゅてん",
        "そうかん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "secretary (lowest of the four administrative ranks of the ritsuryō system)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浅間神社の主典、富士武雄氏の好意ある接待に預かり、絵ハガキや案内記を頂戴する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大社の主典島君に導かれてあちこちと見て※つた後、私達は千家邸で早い晝食の饗應を受けた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "権少主典田中なにがしが現地立会人として派遣され同行することになった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肥沃の原野と聞いておる」と、堀｜大主典は顎をしゃくった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「聞かせて頂きましょう」と大主典は本論にはいった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふーん」と大主典はうなってそれを見つめた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "親しみ易げな印象を得た堀大主典の応接に、うっかり寛いで、その一瞬の気ゆるみに、ついと足をさらわれたような心のよろめきを感じた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一直線に使庁の門をはいり、案内知った堀大主典の部屋にとびこんだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の椅子に頬杖をついていた堀大主典は、はいって来た阿賀妻を見て気づいたように云うのであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の背の上にいて、原野の展望を指で差し示しながら堀大主典は喋っていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀大主典の馬がだく足で前に出る。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大主典を迎えたイシカリ出張所の下僚に馬の手綱を渡し、阿賀妻は挨拶をして渡船場に向った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして阿賀妻にとっては、その嗤笑は堀大主典であらねばならなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかしげられる水っぽい眼、堀大主典の眼の色がぽかりと浮んだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は先方の一かたまりの人間が堀大主典に率いられているのを認めたのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、隙は堀大主典の方にあった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀大主典は首をのばした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀大主典と、その向い合せには阿賀妻が、舷側に腰をかけ、杖づいた長刀の先に顎をのせていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿賀妻さん」と堀大主典の声がした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰をかがめねば聞きとれないような堀大主典の言葉は、まるで呪文のようにぶつぶつと続いていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿賀妻をとおした伊達邦夷の家臣から堀大主典を通じた開拓使の役人と脱皮するのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗がりのため、そんなことは堀大主典の目にはとまらなかっただろう。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、つい手近な士族たちに堀大主典の目が行ったのも無理はない。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか重要な宿場として権中主典の兵頭なにがしが宰領していた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、帰って来た堀大主典にとって、このことはながい間腹の底に積み重ねていた憤げきに火をつけたことであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それで――」と一人の役人は上座の大主典を見て云った、「さい前のお話、いかがなことで――」「うん」と堀は顔をあげた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀という個人の昂奮は、大主典という職務の立場にかき消された。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀大主典がカラフト問題を喫緊とするならば、阿賀妻は何とか目鼻の見えて来た移住の諸問題を一気に解決したかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、それは――」　阿賀妻は瞳をこらしてはじめて堀大主典の眼を見た。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども「諺に云う――」とかの長官が述べはじめたとき、もっぱらその人の手によって進退｜黜陟の鍵をにぎられている大主典の堀盛は、例の無表情な顔に立ち戻って先を読んで行った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
