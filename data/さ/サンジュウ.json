  {
    "uuid": "1b3a00e8-c53b-5124-af8b-678f2a6b66ab",
    "entry": "３０",
    "reading": {
      "primary": "さんじゅう",
      "alternatives": [
        "みそ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
