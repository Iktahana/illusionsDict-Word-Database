      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thirty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（Ｆ・Ｏ）３０＝（Ｆ・Ｉ）右門宅　右門の前で伝六が、Ｔ「人に喋ると罰が当るそうで御座んすがね」　とすっかり喋って了った。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "つごうがいいことに、モトローラという別の会社はＤＥＣのミニコンピューターの作りを意識した、６８系（６８０００、６８０２０、６８０３０と続くシリーズだ）の製品を出していた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハードウエアは、８０２８６搭載の松下電器のＰａｎａｃｏｍ　Ｍ５３０である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "６８０３０搭載マシン購入のための貯金を崩し、Ｔ田はサードパーティのアクセラレーターと大型モニターを買った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミップスの最高速版であるＲ４０００の８０ＭＩＰＳに対して、ＡＬＰＨＡは３００ＭＩＰＳはでるという触れ込みで、商売人のビル・ゲイツはさっそくＷｉｎｄｏｗｓ　ＮＴをＡＬＰＨＡに載せると言いだした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＯＳ開発にあたっていた松下は系列の松下通信工業から、教育市場向けとして８０２８６搭載のＰａｎａｃｏｍ　Ｍ５３０にＢＴＲＯＮ１を乗せてＰａｎａＣＡＬ　ＥＴとして発売し、かろうじて意地を見せるにとどまった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＲＯＮチップのＧ　ＭＩＣＲＯ１００、２００、３００をそれぞれ搭載した複数の製品ラインが用意されるとのことで、低価格攻勢をかけるサンのマシン並のお値段となるだろうと、オレの責任において勝手に予測しておく。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで画面の中央にでしゃばるのは、マッキントッシュＳＥ／３０だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その巴里が、２・３０ＰＭのブウルジェが、ふたたび「社会」が人性が生活が、いまぐんぐん機の下に盛れあぶってきている。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレックスの開発作業はＡＲＰＡの援助を受けて進められ、ケイは操作用にキーボードは付いているけれど、プログラミングにはパンチカードを使うしかなかったＩＢＭの１１３０というコンピューターで作業を進めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七三（昭和四十八）年十月、端末装置事業部は日本電気の製品としては初めてマイクロコンピューターを使ったＮ６３００シリーズの発表を行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方Ｎ６３００には、「インテリジェントターミナル」と銘打ったこの装置のためにあらたに日本電気の半導体セクションが開発した、八ビットのＤＴ―１が組み込まれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の端末にないたくさんの機能を盛り込んだにもかかわらず、集積回路の採用が効いてＮ６３００はきわめて小型に仕上がった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでどおりのキーボードとプリンターでユーザーに向き合うタイプに加え、Ｎ６３００にはディスプレイを採用した機種も用意されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ６３００と名付けた端末で、かつて日本電気としては初めてマイクロコンピューターを中心にシステムを組んだグループは、これをいっそう高機能化し、同時に低価格化した後継機の開発を進めつつあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "端末グループは、こうした仕様にもとづいてすでに開発に着手していたＮ６３００の後継機を、情報処理のパーソナルコンピューターの候補として押し出してきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "価格はＲＡＭ四八Ｋバイトの標準構成で七九万八〇〇〇円と従来のＮ６３００の半額以下に設定された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "下級生でやはりコンピューターに興味を持っていたアレン・ボームと、週に一度通うことになったこの部屋で出合ったＩＢＭの１１３０が、ウォズニアックの初めてのマシンとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その成果が一九七二年に発表されたミニコンピューターＨＰ３０００と、同じく同年に発表された科学計算用のポケット電卓ＨＰ35だった★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "精密機械工学科には沖電気のミニコンピューター、ＯＫＩＴＡＣ―４３００Ｃがすでに導入されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスキーマイクロソフトに出向した古川の懸命の売り込みにもかかわらず、この時期、当初からＭＳ―ＤＯＳマシンとしてスタートを切ったのは松下通信工業のマイブレーン３０００や日立のＭＢ―１６００１など、ごくわずかの機種に限られていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、まず第一号を読んでみると、一、八角形ノ文字盤ヲ有シ、其ノ下二振子函アル柱時計ニシテ、文字盤の裏ニ赤キ「チョーク」ニテ３０３６ノ数字ヲ記シアルモノ。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その３０ぷんほどあとに　もどってきた　マグレガーおじさんは、　あちらこちらの　ようすが　どうも　みょうなことに　きづきました。",
              "citation": {
                "source": "ばにばにベンジャミンのはなし",
                "author": "THE TALE OF BENJAMIN BUNNY",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ　ますは　あまがっぱの　あまりの　まずさに　３０びょうと　たたず　はきだして、　のみこまれたのは　ジェレミーさんの　あまぐつだけでした。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "３０分も　すると　森の上にも　月が　のぼりました。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "言いわたされたやつはみんな、強者にしょっぴかれていくから、そうなるともちろん玉くぐらせの役ができなくなるわけで、そんなこんなで３０分かそこらもたつと、残ったのはキングとクイーンとアリスだけで、あとはみんな打ち首を言いわたされてしょっぴかれてしまった。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから手をつけるのがキノコ（まだかけらをポケットに残してあったからね）、かじっていって最後は３０センチくらいの背たけに。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "言いわたされたやつはみんな、強者にしょっぴかれていくから、そうなるともちろん玉くぐらせの役ができなくなるわけで、そんなこんなで３０分かそこらもたつと、残ったのはキングとクイーンとアリスだけで、あとはみんな処けいを言いわたされてしょっぴかれてしまった。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
