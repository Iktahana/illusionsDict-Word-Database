[
  {
    "uuid": "29d6fa33-8370-5039-b1a7-e73755fa7c78",
    "entry": "酒の席",
    "reading": {
      "primary": "さけのせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "名詞"
      ],
      "ctype": null,
