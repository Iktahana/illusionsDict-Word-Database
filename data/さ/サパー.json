        "examples": {
          "standard": [
            {
              "text": "今夜は、家族みんなでゆっくりサパーを楽しむ予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "外食ではなく、家で温かいサパーを食べるのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちは、学校から帰ると、すぐにサパーの準備に取り掛かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ブレークファスト、ディナー、サパーで一日分だが、ラロでは一日二回の給与であった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏卵はこまかにかき廻してあり、ハムも小さく刻んである）、ディナーは挽肉、サパーはチーズである。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉の缶詰はどれをいつ食おうと勝手だが、ビスケット入の方は朝飯、ディナー、サパーに分れていて、朝飯にはレディ・ツー・イート・シリアルというのが入っている。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イシがまだサパーを食っていない。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ結構」というと、大きな卵を三個割ってスクランブルド・エッグスをつくり、トーストと缶詰の桃とでサパーの準備をしてくれた。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この式を英国教宗にてはホリー・コミュニオンといい、ローマ宗にてはミサといい、非国教宗にてはローズ・サパーといい、あるいはプリマス・ブレズレン宗にてはブレイキング・ブレッドという。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食の支度が出来ますと、私等兄弟三人は、父の書斎へ通ずる廊下の上り段の所から、声を揃へて「パパ　カムダウン　サパー　イズ　レディ」と呼ぶのが例でした。",
              "citation": {
                "source": "父八雲を語る",
                "author": "稲垣巖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
