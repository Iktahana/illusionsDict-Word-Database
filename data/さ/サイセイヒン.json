        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "工場では、不良品を減らし再生品として市場に戻す努力をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境負荷を減らすため、再生品を積極的に利用すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "再生品は新品に比べて安価だが、品質が劣る場合もあるので注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
