          "standard": [
            {
              "text": "中世のヨーロッパでは、罪人がさらし台に立たされる刑があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "町広場に設置されたさらし台は、見せしめの役割を果たしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画で見たさらし台のシーンは、当時の人々の厳しさを物語っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「いやな声が聞えるじゃないか、耳のせいか知らないが、甲州の猿橋の下へつるされたやえんぼうが、ちょうど、あんな声を出していたよ」と、垂を手あらく掻き上げて、「見られたザマじゃない」　駕籠を出て来たお角は、がんりきの傍へ寄って来て、「何という業さらしだい、そのザマは……」と呆れ返りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            }
          ]
