    "definitions": [
      {
        "index": 1,
        "gloss": "sadist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "遅いぞ、あしたイサドへ連れて行かんぞ。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂敷へ包んでサドルの後ろへ結えつけて戻って来たら、擦れとりましてな、これだけほどになっとった」　兄はその手つきをして見せた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後方に一輪車が取り付けられ、そうして三つの輪の中央のサドルに腰をかけた人がペダルを踏んで推進する仕掛けになっている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しまた宇宙を舞踏と観じて瞳を放つならば、サカロフ、イサドラ・ダンカン、アンナ・パヴロワ等のみが名舞踊家とは呼ばれまい。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自転車のサドルをパンパン叩きながら、こういいました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の手は出前の盆を高くさし上げたまま、左の手をハンドルにかけ、左の足をペダルに掛けて、つっと車を乗り出すと同時にからだを宙に浮かせ、右脚を軽く上げてサドルに腰をかけようとしたが、軽い風が水色模様の浴衣の裾を吹いて、その端が危うくサドルに引っかかりそうになった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ペタルが前輪の中心にあつて、把手とすれ／＼に着いてゐるサドルに懸けると両膝のかたちがバツタのやうに曲つて、膝小僧がぬつと前へ突き出るといふ格構だから、十八九にもなる娘となれば、如何ほど僕にすゝめられても撮影のために勇姿を示すわけには行かぬだらう。",
              "citation": {
                "source": "写真に添えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆは、私の云ふことを信じて、「ぢや、サドルのある馬には乗れないといふ種類なんだね。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よきサマリヤ人と悪しきサドカイ人とは、隣り合せに住んでいるのではないか。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）も、バリー・サドラー軍曹の〈ザ・バラッド・オヴ・グリーン・ベレー〉も、みんな無視することに決めた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、サドルの端に。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それがね――」とＧは、サドルから飛び降りて、赤くなつた顔を僕に示した。",
              "citation": {
                "source": "センチメンタル・ドライヴ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校を卒業すると、かれはサドベリーという町のある医師のところへ書生として住みこみ、医学を勉強して、後には代診をつとめました。",
              "citation": {
                "source": "ジェンナー伝",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "人はみんなオテル・ドュ・パリやＣＩＲＯやアンバサドウルの食堂で皿や給仕人や酒表と戦ってる最中だった。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィリアム・ホルレルバッハ、シイ・ウェステンブロオク少年、エヌ・ウェステンブロオク、バン・フルインク、ジョス・シリングロップ、アール・メルレンブローク、ヘンリイ・コルテ、イー・ケル、ウィリアム・オスターヘイヂ、ヘンリイ・コオト、イサドラ・フリイベルグ孃、ヘンリイ・フリイベルグ少年。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "――サドー※ヤへ行って。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本女は、写実劇場まで行かずサドー※ヤの交叉点を一寸越したところで馬車を止めさせた。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サドー※ヤにはメイエルホリド座がある。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はもう罵るだけ罵ったのだ、と云うのは、サドー※ヤの交叉点からこの通りを真直来たのではない。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プーシュキン記念像の下まで戻って来てしまった（サドー※ヤとストラスナーヤはつまりそんなに近いのだ）。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して歩調をはやめずまたサドー※ヤを横切ると、その街燈柱と菩提樹のところ、きっちりさっき日本女が一度馬車から下りた地点で車を止めた。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――サドーワヤへはどう行ったらよかろかね？",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オニェーギン」「スペードの女王」「サドコ」はこわくないからね。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワへ来て、大ものの「ボリス・ゴドノフ」も「サドコ」も「デモン」も舞台から聞くことが出来、バレーもいろいろ観た。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等運転士のハウオウスがイサドル・ストラウス夫人にボウトに乗り移るように奨めると、夫人は断乎として拒絶して、「ストラウスの傍を離れるのは嫌です。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へていへば、その表情のハイフエツツの優婉に似通ひしもの、エルマンの甘さに似通ひしもの、ヂンバリストの寂びに似通ひしもの又は、イサドラダンカンの舞踊に、あの華やかなりし頃のニヂンスキーの「牧神の午後」の怪奇さに相通ずるものなど、吾々近代人の香水の選び方は様々の聯想を強ひられる。",
              "citation": {
                "source": "「香水の表情」に就いて",
                "author": "――漫談的無駄話――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
