    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Sado (former province located on Sado Island in present-day Niigata Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五年前、千葉県船橋の映画館で「新佐渡情話」という時代劇を見たが、ひどく泣いた。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐　門狭ですなわち佐渡の狭門に同じく狭い海峡をはいって行く国だとの説がある。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例として「荒海や佐渡に横とう天の川」という句をとって考えてみる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佐渡」でも「天の川」でも同様である。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ宵のうちは帳場の蓄音機が人寄せの佐渡おけさを繰り返していると、ぽつぽつ付近の丘の上から別荘の人たちが見物に出かけて来る。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年、佐渡へ御旅行なされて、その土産話に、佐渡の島影を汽船から望見して、満洲だと思ったそうで、実に滅茶苦茶だ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁が崩れ落ちたと思うところに、日章旗を交叉した間に勘亭流で「祝開店、佐渡屋さん」と書いたびらをつるして隠してあるような六畳の部屋だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新潟から直江津ね、佐渡｜辺は持場であッたそうだ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来｜伏木直江津間の航路の三分の一は、遙に能登半島の庇護によりて、辛くも内海を形成れども、泊以東は全く洋々たる外海にて、快晴の日は、佐渡島の糢糊たるを見るのみなれば、四面※茫として、荒波山の崩るるごとく、心易かる航行は一年中半日も有難きなり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬分は往々敦賀から來た船が、其處に金石を見ながら、端舟の便がないために、五日、七日も漾ひつゝ、果は佐渡ヶ｜島へ吹放たれたり、思切つて、もとの敦賀へ逆戻りする事さへあつた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……よく、言う事で――佐渡ヶ島には、ぐるりと周囲に欄干があるか、と聞いて、……その島人に叱られた話がある。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡が、臥牛のようにゆったり水平線に横わって居ります。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒海や佐渡に、と口ずさんだ芭蕉の傷心もわかるような気が致しましたが、あのじいさん案外ずるい人だから、宿で寝ころんで気楽に歌っていたのかも知れない。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたお天気だったら、佐渡ヶ島へ行ってみるつもりです。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡へは前から行ってみたいと思っていました。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんど新潟高校から招待せられ、出かけて来たのも、実は、佐渡へ、ついでに立ち寄ってみたい下心があったからでした。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡夷着、午後四時四十五分の予定。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しに佐渡へなど行く気になったのだろう。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しに佐渡へなど行くのだろう。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡は、淋しいところだと聞いている。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新潟まで行くのならば、佐渡へも立ち寄ろう。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂わば死に神の手招きに吸い寄せられるように、私は何の理由もなく、佐渡にひかれた。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しに佐渡へ行くのだろう。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだって、佐渡なんかへ、行って来なければいけないのだろう。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡へ行ったって、悪い事ばかり起るに違いないと思った。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡は、もうすぐそこに見えている。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、佐渡ヶ島でないのかも知れぬ。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが、佐渡だね。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡は寝たかよ灯が見えぬというのは、起きていたら灯が見えるという反語なのだから、灯が見える筈だね。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "編暦をつかさどる人々は、たとえば東京における三月の平均温度が摂氏何度であるかを知らなくても職務上少しもさしつかえはない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
