[
  {
    "uuid": "b436d0c1-bd38-5589-ac80-e4df20723b2e",
    "entry": "誘い込む",
    "reading": {
      "primary": "さそいこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
