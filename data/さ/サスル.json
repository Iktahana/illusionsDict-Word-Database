    "definitions": [
      {
        "index": 1,
        "gloss": "to rub",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ようようマッチの箱を見出し、マッチを一本取りて摩る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その明りが消えると、また気になるので、またマッチを摩る。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か言い出しそうにしては口のあたりを手の甲で摩るのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかるとき、おぼめき摩る Violon のなやみの絃の手触のにほひの重さ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "※オロンの三の絃摩るこころか、ていほろと梭の音たつるゆめにか、寝ねもあへぬ鶯のうたのそそりのかつ遠み、かつ近み、静こころなし。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、ひらく汀の瞳くろぐろと、冷やにならびうかがへる妖女のつらね肋骨の相摩るごとき笑して灰色の髪音もなくさばくと見れば、そこここに首もたげゆく蛇のむれ、ああまたもとの幽鬱に主消えしづむ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "車のゆきかふこと隙間なく見ゆるに、その餘せる地にはうれしげなる面持したる人肩｜摩るほどに集へり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "床を掻くが如く摩るが如き響を聞きたり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまへどうした、何を鬱いでゐるのかね」　引寄せられし宮はほとほと仆れんとして椅子に支へられたるを、唯継は鼻も摩るばかりにその顔を差覗きて余念も無く見入りつつ、「顔の色が甚だ悪いよ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀川十里の間あし茅の深き処、浅瀬の船底石に摩る処、深淵の蒼みたるところ、堤に柳ありて直曲なる処、野渡のせばき処、遠き山見るところ、近き村ある処、彼此観望する間、未後大坂城を前に望て、遂に過所町の河岸に著く。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちある晩｜風雪になって、雨戸の外では風の音がひゅうひゅうとして、庭に植えてある竹がおりおり箒で掃くように戸を摩る。",
              "citation": {
                "source": "独身",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　戸川はとうとう引き摩るようにして富田を連れ出した。",
              "citation": {
                "source": "独身",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの子もどの子も手を出して摩るのだ。",
              "citation": {
                "source": "犬",
                "author": "レオニイド・アンドレイエフ　Leonid Andrejew",
                "note": "青空文庫"
              }
            },
            {
              "text": "（片々の上沓の上革を、片々の底革にて摩る。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "幅びろの大鋸はうごきぬ、鈍き音、――あやし獸のなきがらを沙に摩るか。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通に考えたらとても出来そうもないことが、多年の経験と研究との恐ろしさで、特殊の摩鉢と摩棒とを使って、そして摩る速度と摩棒の運動とを適当に選ぶことによって、可能になったのだそうである。",
              "citation": {
                "source": "霜柱と白粉の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の底に足がついて、世に疎きまで思い入るとき、何処よりか、微かなる糸を馬の尾で摩る様な響が聞える。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいない大きな浴槽のなかで、洗うとも摩るとも片のつかない手を動かして、彼はしきりに綺麗な温泉をざぶざぶ使った。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は狼狽へて又背中を摩る。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女は黙って学士の手を取って、引き摩るようにして跡へ引き返した。",
              "citation": {
                "source": "みれん",
                "author": "シュニッツレル　Arthur Schnitzler",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日を反映さする金茶色の唐松と、輝やく紅葉――そのくせ、もう枯れ枯れに萎び返って、葉の尖はインキを注したように、黒くなって、縮れている――で、夏ならば緑一色のちょんぼりした林が、今朝は二、三倍も広くなったような気がする。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者は科学を成立さする必要上、自然界に或る秩序方則の存在を予想す。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いただけでもくさくさするよ」　と、夫は調子に乘りながら、「貧乏畫家の妻として三｜年間で三百｜圓溜めたあたしの經驗か？",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遂に僕は心を静めて今夜十分眠る方が可い、全く自分の迷だと決心して丸山を下りかけました、すると更に僕を惑乱さする出来事にぶつかりました。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし高きに登りて一目にこの大観を占めることができるならこの上もないこと、よしそれができがたいにせよ、平原の景の単調なるだけに、人をしてその一部を見て全部の広い、ほとんど限りない光景を想像さするものである。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "春、夏、秋、冬、朝、昼、夕、夜、月にも、雪にも、風にも、霧にも、霜にも、雨にも、時雨にも、ただこの路をぶらぶら歩いて思いつきしだいに右し左すれば随処に吾らを満足さするものがある。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其上仕事をさするにあらず、日夜氣まゝに遊ばせて、食物は望次第、海のもの、山のもの、乞ふにまかせて與へむに、悲む理由は無きはずなり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "情無い、もう不具根性になったのか、僻も出て、我儘か知らぬが、くさくさするので飛んだことをした、悪く思わないでおくれ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上また母親はあらかじめ一封の書を認めておいて、不断滝太郎から聞き取って、その自分の信用を失うてまで、人の忌嫌う我児を愛育した先生に滝太郎の手から託さするように遺言して、（私が亡くなった後で、もしも富山からだといって人が尋ねて来たら、この手紙を渡して下さい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞丈雑記に、湯を召さするに常の衣の上に白き生絹、其白き生絹の衣を、湯巻ともいまきともいふなり。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
