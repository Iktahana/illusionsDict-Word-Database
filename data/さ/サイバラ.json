  {
    "uuid": "0316827e-3585-59c1-baed-6d5650a9fd28",
    "entry": "催馬楽",
    "reading": {
      "primary": "さいばら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
