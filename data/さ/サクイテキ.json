        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なるほどプロレタリア文学にはブルジョア文学が習慣づけて来たような作為的なヤマはいらない。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて併し、こうした半官憲的文化動員・思想動員が、その作為的なポーズに拘らず、自然な文化的信用を民衆の間に博するかどうかは、実際極めて疑問と云う他ない。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これは、作為的にならずにまったく率直に書かれているので、私は素晴らしいと思った。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに殆ど凡ての史料は不純にされてゐる、それはつねに党派的で、つねに作為的で、つねに或は熱中により、或は盲目な憎みもしくは愛によつて、だから私欲によつて無意識的に歪められてゐる。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月下旬に検事が来たとき私の調べの事情をはなし、自分が全く作為的な調書をとられていること、もし公判になれば、自分はそれをひるがえすということを話した。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビオメカニズム〔メイエルホリドが唱えた生物力学的演技法〕によって機械の動き、「ベルト」「車輪」など生しもするが大体はミミック〔顔面の作為的表情〕だ、普通の。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの日の一切の行為のうちで、この瞬間の私が一番作為的であり、卑劣であつたと思つてゐる。",
              "citation": {
                "source": "いづこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの日の一切の行為のうちで、この瞬間の私が一番作為的であり、卑劣であったと思っている。",
              "citation": {
                "source": "いずこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし女の態度はいかにも憎たらしいし、作為的だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを非とするためにわたしがでっちあげうるすべての人道主義は、すべて作為的なもので、わたしの感情よりは理論に関したものであった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹のお徳は仇っぽい作為的な品で、ちょいと見は綺麗にも艶やかにも映りますが、こう並べると、玉に彫んだ女神と、泥焼のお狐様ほどの違いがあります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由主義者は「人間」を個別的に判定する、そうしないで仮に党派的になど判定すると、それは外部的な作為的な判定になるというのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれがために、いつもの乾山のうまい書が、力のある字が、どれほど良心の咎めを受けて、弱く作為的なつまらぬものになっているか、わからぬほどである。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が三人のうちで最初に親しんだのが次郎であったとしても、もともと「次郎のために」ということが、周囲の人々の作為的な希望であって、彼女自身の自然な心の動きから出発したものでなかったとすれば、彼女が、次郎に対して感じた以上の親しみを、恭一か俊三に対して感じないとは限らなかったのである。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、次郎は、詩を解するには、これまで、あまりにも武勇伝的であり、作為的であったといえるだろう。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「光ほのか」が、どんな材料からつくられたかが推察されましたが、つまりは「光ほのか」は作為的であって失敗です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、不幸なわが十九世紀に生まれ合わせて、しかもその上に、地球上で最も抽象的な作為的都市であるペテルブルグに住むなどという、とんでもない不幸を持ちあわせた、教養の高い人間に与えられた意識量の、半分どころか、四分の一もあったらたくさんなのだ（実際、街にも作為的なのと、そうでないのとがある）。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも中には作為的なものもある。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
