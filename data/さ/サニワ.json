      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(one's own) garden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
