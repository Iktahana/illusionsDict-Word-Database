        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の三猿主義的な態度は、周りの人々を苛立たせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "問題が起きても、彼は三猿主義を貫き、何も言おうとしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「おいおい、そんな三猿主義じゃ何も解決しないぞ！」と友人が呆れて言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "其から丁度三年間といふもの私は全く俳句界から手を引いて、所謂見ざる聞かざる言はざる三猿主義を極め込んでゐたのであつたが、其間に私が当初の希望通り小説（写生文）に熱衷することが出来たのは初めの二年間許りであつて、あとの一年になつてからふと健康を損じなか／＼思ふやうには筆が取れぬことになつてしまつた。",
              "citation": {
                "source": "進むべき俳句の道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
