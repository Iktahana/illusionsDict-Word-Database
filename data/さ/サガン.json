[
  {
    "uuid": "7dc3f73e-1b38-5558-ab0b-8594d54a1ade",
    "entry": "左岸",
    "reading": {
      "primary": "さがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
