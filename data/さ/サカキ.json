    "definitions": [
      {
        "index": 1,
        "gloss": "sakaki (species of evergreen sacred to Shinto, Cleyera japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "朝は早く起き、榊をあげて柏子を打ち、木の香の匂ふ縁側に、日向ぼつこでもしてみるとしたらどうであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右にはゆうを掛けた榊台一対。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい風が吹いて来て榊のゆうがサラサラと鳴り、檜扇がまた散った。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "榊の影が大きく壁にうつって茄子や葡萄が美しくかがやいた。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面には御簾を垂れて、鏡や榊や幣束などもみえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "榊の葉やいろいろの花にこぼれている朝陽の色が、見えるように思われた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は、報徳神社といふ、彼の二宮尊徳翁を祭れるもの、石段の南北に畏くも、宮樣御手植の對の榊、四邊に塵も留めず、高きあたり靜に鳥の聲鳴きかはす。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一連の御幣と、幣ゆいたる榊を捧げて従う。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お父さん、お父さん、榊原――俊明先生です。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士が驚いた――客は京の某大学の仏語の教授で、榊三吉と云う学者なのだが、無心の小児に向っては、盗賊もあやすと言う……教授でも学者でも同じ事で、これには莞爾々々として、はい、今日は、と言った。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女の痴話の傍杖より、今は、高き天、広き世を持つ、学士榊三吉も、むかし、一高で骨を鍛えた向陵の健児の意気は衰えず、「何をする、何をするんだ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お光さん、私だ、榊だ、分りますか。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十二日に入牢して、吉五郎は北町奉行榊原｜主計頭の吟味をうけることになったが、他の同類がひとりも挙げられていないので、かれはあくまでもその犯罪を否認した。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "結城秀康を大将に、榊原康政を先鋒にした。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此區に近づくに從つて高く聳やぐ幟、街道を跨ぐ提灯、幣束を付けた榊、夏蜜柑の枝、蝦、しめ蠅の類が見え出して來た。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の青龍、白虎等の四神を頭に付けた鋒、錦の旗、榊の枝、其他｜御酒錫、供餅などを持つた人々が嚴肅に石段の上に並ぶ。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "榊が立ち、提灯が弔るされる。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "榊を外す、それを受取る。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これでは、玉の手を握ろう、紅の袴を引こうと、乗出し、泳上る自信の輩の頭を、幣結うた榊をもって、そのあしきを払うようなものである。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水につくと、魑魅が枝を下り、茂りの中から顕われたように見えたが、早く尾根づたいして、八十路に近い、脊の低い柔和なお媼さんが、片手に幣結える榊を持ち、杖はついたが、健に来合わせて、「苦労さしゃったの。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡いふすぼりが、媼の手が榊を清水にひたして冷すうちに、ブライツッケルの冷罨法にも合えるごとく、やや青く、薄紫にあせるとともに、乳が銀の露に汗ばんで、濡色の睫毛が生きた。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "榊五六本、秋は木犀の薫みてり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方には芝笹の所々に、つつじや榊を這わせた植込みがあり、他方は少し高くなり、庭隅の一本の頑丈な巨松の周りに嵩ばった八ツ手の株が蟠踞している。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "磐が根に注連縄ひきはり、幣帛にしで結ひ垂れ、真榊の、鏡葉の音さやさやにうち清めて。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、室の一方には蒲団を畳んで積み、衣類を入れた葛籠を置き、鎧櫃を置き、三尺ばかりの狭い床には天照大神宮の軸をかけて、其の下に真新しい榊をさした徳利を置いてあった。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには甚六も恐れをなして、村にいる山伏を頼んで祈祷をしてもらおうとすると、須弥壇が動きだしたり、榊立や山伏の錫杖が何人が投げるともなしに家の外へ飛んででたりするので、山伏も恐れて逃げて往った。",
              "citation": {
                "source": "一緒に歩く亡霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、同じ二日市で榊屋の隠宅というのに引越した時に、父が私に羊羹を三キレ新聞紙に包んだのをドンゴロス（ズックの事）の革鞄から出してくれた。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康は、小笠原長忠を先陣とし、右に酒井忠次、榊原康政、左に本多平八郎忠勝、内藤信重、大久保｜忠世、自分自身は旗本を率いて正面に陣した。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "本多忠勝、榊原康政共に年二十三歳であったから、血気の働き盛りなわけであった。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒井忠次、榊原康政等は姉川の上流を渡り、朝倉勢の側面から横槍を入れて無二無三に攻め立てたので、朝倉勢漸く浮き足立った。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
