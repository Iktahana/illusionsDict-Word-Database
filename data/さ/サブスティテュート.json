        "examples": {
          "standard": [
            {
              "text": "主力選手が怪我で欠場するため、急遽若い選手が「サブスティテュート」として起用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "料理では、手元にない材料のサブスティテュートとして別の材料を使うことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このチームは、ベンチに強力なサブスティテュートがいるため、試合展開に合わせて柔軟に対応できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それに合わせ、慶一は〈サブスティテュート〉をスタッカートで歌いながら、三階のヴェランダにむかう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのビニールのシートにすわり、クリーム・サブスティテュートの入った小さな容器を三つ、四つ、おおざっぱにテーブルの上に転がしていくウエイトレスの体の動きに、都会の朝の日常がある。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
