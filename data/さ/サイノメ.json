        "examples": {
          "standard": [
            {
              "text": "彼はさいの目を振って、出た数字で進むマスを決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "さいの目の一つ一つに、物語があるようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "丁か半か、さいの目の行方に運命が委ねられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さいの目の一平次どの「畜生ッ」　八五郎は格子をハネ飛ばすように、ガタピシさせながら飛び出しましたが、もとより悪戯者はその辺にマゴマゴしているはずもなく、路地のやみは漆の如く濃い中を、八五郎は暫らくウロウロするだけのことでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうすんだよ」　そして、発音に大いに気を使い、一つ一つの言葉のあいだに長い間をはさむことによっていっさいの目立つ点を取り除こうと努めた。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
