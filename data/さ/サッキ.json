    },
    "definitions": [
      {
        "index": 1,
        "gloss": "a short while ago",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先天的観念もないぞよ！",
              "citation": {
                "source": "（仮定はないぞよ！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧なさい天才は彼の自叙伝を急ぎさうなものに恋愛伝の方を先に書きました",
              "citation": {
                "source": "（天才が一度恋をすると）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――額をみ給へ――一度は神も客観してやりました――不合理にも存在価値はありませうよだが不合理は僕につらい――こんなに先端に速度のある自棄　々々　々々下駄の歯は僕の重力を何といつて土に訴へます「空は興味だが役に立たないことが淋しい――精神の除外例にも物理現象に変化ない」ガラスを舐めて蠅を気にかけぬ",
              "citation": {
                "source": "（古る摺れた）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば夏休みも近づかうといふ暑い日に、唱歌教室で先生が、オルガン弾いてアーエーイーすると俺としたことが、笑ひ出さずにやゐられなかつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別、先生の口唇が、鼻腔が可笑しいといふのぢやない、起立して、先生の後から歌ふ生徒等が可笑しいといふのでもない、それどころか、俺は大体、此の世に笑ふべきものがあらうとは思つちやゐなかつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると先生は、俺を廊下に立たせるのだつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に邪魔になる程に、大声で笑つたわけでもなかつたし、それにしてもだ、先生がカン／＼になつてたことは事実だし、先生自身何をそんなに怒るのか知つてゐぬらしいことも事実だし、俺としたつて意地やふざけで笑つたわけではなかつたのだ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の暑い日に、俺は庭先の樹の葉を見、蝉を聞く。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ神よ、私が先づ、自分自身であれるやう日光と仕事とをお与へ下さい！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなが何を話したか別段記憶しないが、ともあれみんな文学青年が先輩を詣でた式のことで、主人は間もなく退屈した。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "山賊仲間に聖者のゐたためしは先づないが、修道院の中には天使から悪魔までがずらりとゐる。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ第一に、是等の詩を書いた人は豊富である。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、自体インテリがインテリであるためには、衣食住の先のこと、換言れば観念を必要とし、それに就て仕事をする場合にインテリなのである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一行を読んで、先づ見えて来るのは水平線である。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しまあ、よく視よう、鏡なんだもの、と緊張を増すと同時に、急いで先が読みたくなくなる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "高森は今宮崎県の中学で英語の先生をしてゐる。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校庭宮沢賢治さ霧する白き木柵幹彫れる桐のいくもと剥げそめし白きペンキの木柵に人人は倚りそのペンキあるいは剥げあるものは庭をのぞめり一鐘のラッパが鳴りて急ぎ行く港先生白堊城秋のガラスはひらごとにうつろなりけり",
              "citation": {
                "source": "校庭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨、気持は、そこで一先づ安らかとなつたが、作品が熟してゆくといふことは、時日を要することであるし又、漸次のことであるから今分つたからといつて、すぐに今迄よりも好いものを書いてみせろと期待されても、六ヶ敷い。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその衰微の原因の第一として、先づ論理的性格の欠乏といふことを指摘したい。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしあたつて先づ、新短歌の成績を考へてみよう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと芸術は先づは感覚的でなければならぬ。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論かういふことは、一々の短歌作品、一々の俳句作品に就いてそつくりそのまま当箝まることではないけれども、夫々の様式を規範的に観た場合そのやうに言ふことは先づ間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の遠い祖先のスペインの血は、その顔にも現れて、はげしい苦闘的なものを印してゐた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天才が閃くのは思ひがけない発見の中にであり、その点では同時代人の中にも先人の中にも彼女に如くものはないのである。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所でもし感情喪失が原因なれば、人は先づ退いて心身を休めるの必要があるのであらう点で、前二者とは趣を異にするのである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に、真実と、虚飾との二つがあることは先刻知れ渡つてゐる。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし　世の成り行なるものは対に純粋理性に逆行するものゆゑ、叫び――即ち抒情が先に生れるべきであつたに、歴史は吾々に叙事芸術の先にあつたことを示す。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、気を取り直して、「ついさっき。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬢やはと聞くと、さっきから昼寝と答えたきり、元の無言に帰る。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウトウトこんな事を考えていたが、気がついてみると垣の外ではさっきの子供等がまだ大きな声で歌ったりわめいたりしている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
