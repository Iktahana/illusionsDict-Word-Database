        "examples": {
          "standard": [
            {
              "text": "行列が近づくと、群衆は左右に分かれ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "前方の道は二股に分かれており、ハイカーたちは両方のルートを探索するために左右に分かれることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "二人の友人は、会った後、左右に分かれて別れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "根は高く盛り上がり、木肌には古苔一面に附き、梢の高さは空の雲さえそこで左右に分かれるほどである。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
