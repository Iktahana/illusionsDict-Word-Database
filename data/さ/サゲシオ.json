        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "図は前にも云った通り上げ潮の時の有様ですが、下げ潮の時には反対に図の下側の方へ同じような流れと渦巻が出来ます。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールもまちまちに河下の方へ艇頭を向けると、下げ潮に乗って、逃げ出した。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに今は下げ潮のこととて、附近の漂流物は沖合へ流されているのだ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げ潮には湾内へ激しく流れ込み、下げ潮には疾風の如くに、外洋へ注ぎ出す。",
              "citation": {
                "source": "葵原夫人の鯛釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げ潮と同時に降り出した雨はやまない、雨は下げ潮時にはれる。",
              "citation": {
                "source": "道具と餌と天候",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
