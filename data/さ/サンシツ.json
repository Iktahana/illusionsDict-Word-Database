[
  {
    "uuid": "e088cff0-d737-5b70-810d-e0415a235573",
    "entry": "蚕室",
    "reading": {
      "primary": "さんしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
