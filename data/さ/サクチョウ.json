        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし昨朝八丈島沖に相当な深層地震があったのでそれで帳消しになったのかもしれない。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び黄浦江の惨殺死体（去る××日胡某の惨殺され居りたるウインソア橋に近き黄浦江河岸に復た／＼昨朝午前六時頃年若き男の惨殺死体漂着せるを発見せり。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方に西村の贋母親は、憤慨の余り縊死していることが昨朝に至って発見されたので、早速係官が出張して取調の結果、他殺の疑いは無いことになった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由を得んとして反つて不自由を與へられ寧ろ社會主義を叫ばぬ方が得策なりとは、彼の淺薄なる思想を窺ひ知り得べきも、昨朝判檢事出張し書籍及び手紙を押收したりと云へば守田と同じく何事にか關連し居たるものならん。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官殺しの犯人も遂に悪運尽いて、事件発生後十一日の昨朝逮捕された、此地方では珍しい出来事であつた、誰もほつと安堵と快心の吐息を洩らしたことである。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨朝の七時頃シリングの宿所の親方であり且フリイベルグ工場の雇傭人たるウェステンブロオクが厩の馬の手入にギャムブル横町の格子戸へ出た。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕度を調えて出て見ると、陣中に、昨朝とはまた違う一種の生気が漲っていた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝の御飯はよく炊けた（昨朝の工合の悪さはどうだつた）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜少しく睡眠を得て昨朝来の煩悶やや度を減ず、牛乳二杯を飲む。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "○酒井蓉子殺し犯人は強盗前科四犯の兇漢と判明　――大川氏の行為は正当防衛――昨朝文士大川竜太郎氏方に兇漢侵入し大惨劇を演じたことは既報の通りであるが、兇漢の指紋により果然同人は強盗前科四犯あり目下××刑務所に服役中の痣虎こと大米虎市と称する脱獄者であることが明かとなった。",
              "citation": {
                "source": "黄昏の告白",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方が云われる津多子夫人は、昨朝早々にこの館を去ったのですじゃ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨朝の事変の真相が何故かまだ今日になつても明白でない。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "Yes'ter-【複合詞】（――morn-ing ＝ yesterday morning）［詩］昨朝。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "（morning）昨朝。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "「裏の庭木戸が、昨朝も今朝も開いていたようですが、差支えないのですか」いくらか気掛りだったので次手に訊いて見た。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "――君それから宅に行ってくれたかね」　「昨朝ちょっと寄って来た。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――君それから宅に行ってくれたかね」「昨朝ちょっと寄って来た。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「御通知によって、昨朝飛翔したアブロ練習機を精査してみると、車輪軸に打たれている鋲が一個はずれている事を発見した。",
              "citation": {
                "source": "旅客機事件",
                "author": "大庭武年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨朝八時多年召使ひたる老婆しん病死せし旨その家より知らせあり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨朝は筧（克彦）博士（憲法学者）というのが、ノリトのようなことをやった。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨朝以来不思議なことばかり、どうにも拙者には見当が付かぬ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、昨朝、ついに思い切って抜け落ちた。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨朝、内部へ放ってある信ずべき密偵からの告知。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨朝初めてこの狂気の山脈に接近した際に目撃したような蜃気楼なのではないかとさえ半ば考えたのかもしれない。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "病室の戸を開ける時も昨朝と同じく萬一どうかした事が一夜の間に起きはしなかつたらうかといふ考へが閃いて少し心臟の鼓動が高まるやうに覺えた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸を開けて見ると文太郎は矢張り昨朝の如く一人寢臺の上に寢たまゝで室内は寂寞としてゐたが唯昨日と異る所はぱつちりと眼を覺してゐた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にのしかかって絶命しているのは、昨朝別れたままの鳥井青年だ。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月四日（月曜）　昨朝の飯に、コロを出されてクサったので今日は注文で、かまぼこ屋の天ぷら（実はサツマ揚げ）を出させる、うまい、が何ともはかなき朝飯なり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――折角、信孝君をお迎え申して、子としては、父なき御孝道を尽させ給い、臣としては先君の弔合戦、ここは死生も御一緒に、御旗をひとつに、昨朝来、書簡を以て再三御参会を促しまいらせたが、何のかのと御理由のみ立てられて、いっこうお腰の上がらぬ様子。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "かならずここは保ちささえますゆえ、ただ金剛山の寄手へたいし、勅をくだし賜われと、それを請うてまいったのも、つい昨朝のことではないか。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
