        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "安五郎は、　「さてと……俺の番だったな」　「へッ、御貸元の番で。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい新太、お客人にお茶出しな」　「へえ」　「さてと……吉兵衛、儂の番だったな」　「へえ」　次郎長、児分に、　「茶は要らねえ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてと、今日はどこから……おや、あなた僕の顔を見ていますね。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず作戦はあと廻わしにして、「さてと、今日はどこから……」　といいながらおぬいさんを見ると、書物に見入っているとばかり思っていたその人は、潤いの細やかなその眼をぱっちりと開けて、探るように彼を見ているのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてとまずお台所お松の方の召上る物はぐい極となったが、私は何にしよう。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてと、できたよ」と、魔法使いは言いました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてと、どうしたもんかな？",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてと、どんな味かな」ばあさんは、こう言って、短刀を引きぬきました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてと、こうなったら、くしにでも、結婚を申しこむか。",
              "citation": {
                "source": "カラー",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてと、どうしたら、からだを動かすことができるんだろうなあ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてと、わたしは、ひと休みするとしよう。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてとよ……生肝を取って、壺に入れて、組屋敷の陪臣は、行水、嗽に、身を潔め、麻上下で、主人の邸へ持って行く。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてと、ご苦労を掛けた提灯を、これへ置くか。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんまに心配かけてしもて」　君枝がそう言うと、蝶子はさてといった顔になって、「しかし、あんたも気イつけんとあかんし。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と声づくろいをしてからに、得意気に、やや諛って、ええ、さてと、帽子の鍔を一つ叩くと、　まず、初めは、「近頃流行の安来節」と手前口上で、一歩退ると、えへんとやったものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてとや、このほどよりの御はなし、母よりうけたまわり、うれしく存じ候」　てッきり、例の区役所先生に送るのだと分った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてと、ワトソン、今からベイカー街へ馬車で行こう。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さてと、困ったな、喧嘩が禁制となって酔払いがお気に入らずとあっては、前座種切れだ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてと、どうするかな」　場内が明るくなると、高志がいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてと、じゃ、部室にもどるか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしろ、もうカビが生えて、聴けたもんじゃないだろう」「さてと。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてと、対日戦だが、だんだん長期化するのは困るね。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてところで信長だが、こいつはとても感心な奴で、悪党振りが大きかった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてところでこの俺だが、これからどうしたものだろう？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さてところでお町だが……」お町のことを考えた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてところで原の城だが、そこへ一揆があつまった頃から耳よりな噂が聞こえてきた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ程の覺悟をして歸つたものがさてとなると又遽に搖ぎ出す、さう云ふ自分がいかにも彼には安價な男に思はれた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、さう覺悟はしてゐたものの、さてとなると俺は苦しんだ。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年もの間、読みたい新聞を読めずにいたわたしどもは、これをめずらしいことと思ったが、さてと考えてみると、奇妙な感じがした。",
              "citation": {
                "source": "主婦と新聞",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "声が出せたら、陶工がさてと偽の署名をしかけた時、皿や花瓶は一斉に哭いて拒んだだろう。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
