    "definitions": [
      {
        "index": 1,
        "gloss": "sleeping medicine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
