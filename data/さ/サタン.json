    "definitions": [
      {
        "index": 1,
        "gloss": "friendship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いき」に左袒する者は 〔amour-gou^t〕の淡い空気のうちで蕨を摘んで生きる解脱に達していなければならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "秦火以後に諸子は復活したが墨子は其の學統さへ全く絶えて、終に晉の代の魯勝が出るまでは少くも墨子に左袒する氣味の人が無かつたのであるから、今更判然と考定する事の出來ぬのも自然の數である。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、直覚があるからと言つて、常識を踏み躙つて了ふ人達には私は左袒しない。",
              "citation": {
                "source": "エンジンの響",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この事に關する以上、僕はお父さんに左袒します。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「ラモナ」だけしか見ないが、無条件に天然色映画の左袒者になれると思う。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "志賀直哉に向って、日本の知性を押し潰そうとしている力に左袒しているといったならば、彼はどんなに意外に思うであろう。",
              "citation": {
                "source": "前進的な勢力の結集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし後にはこれに左袒するものも多くなって、順承が聴納しようとした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾に左袒する者は、檄の至るを待ち、叡山に来会せよ。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "正弘は彼に於て概ね開国論に左袒し、伊沢｜美作守政義の洋行の議をさへ容れた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らはまさにデテルミニストに左袒しなければならぬ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "答　それは感覚と云ふ言葉の意味や、意志と云ふ言葉の意味を、はつきり制限して貰はないと、僕にはどちらにも左袒出来ない。",
              "citation": {
                "source": "東西問答",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに異様な汚臭を放つに至つては、公平な眼を以て、決して左袒する事は出来ないよ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れこそ実に国を滅す奴等だ、こんな不文不明な分らぬ乱暴人に国を渡せば亡国は限前に見える、情けない事だと云う考が始終胸に染込んで居たから、何としても上方の者に左袒する気にならぬ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は百姓・町人に左袒して思うさまに勢いを張れという議論なれども、また一方より言えば別に論ずることあり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上論ずるところを概すれば、今の世の学者、この国の独立を助けなさんとするに当たりて、政府の範囲に入り官にありて事をなすと、その範囲を脱して私立するとの利害得失を述べ、本論は私立に左袒したるものなり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一も舅姑の意に戻ればすなわちこれを不孝者と称し、世間の人もこれを見て心に無理とは思いながら、己が身に引き受けざることなればまず親の不理屈に左袒して理不尽にその子を咎むるか、あるいは通人の説に従えば、理非を分かたず親を欺けとて偽計を授くる者あり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "桓帝の時は佛教漸く流通し、殊に桓帝は老佛に歸依して、宮中に二者を併せ祀つた故に、當時老子に左袒する人は、かかる説を唱へて、暗に佛教を抑へたものと見える。",
              "citation": {
                "source": "老子化胡經",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、斯様な問題に触れて居るのは、多く労働者の左袒者である。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも僕の僻見に左袒し、僻見の権威を樹立する為に一｜臂の力を仮すものはないか？",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "其趣は、無辜の子供等が家内に喧嘩する處へ、父母が其一方に左袒するに異ならず。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに爰に恐る可きは、政黨の一方が兵力に依頼して兵士が之に左袒するの一事なり。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "我輩は固より今の所謂自由改進の民權論に心醉する者に非ず、又今の所謂守舊保守の輩に左袒する者に非ず。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに同僚中に直名に左袒する者があって、かえって「闘訟律」に依って許容違法の罪を訴えた。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は鴈治郎のに左袒する。",
              "citation": {
                "source": "封印切漫評",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し今の処、左袒多かるべき此方に、説を向けることが出来ぬ。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人主義攻撃の名によって、安価なセンチメンタリズムに左袒してはいけない。",
              "citation": {
                "source": "霧の中",
                "author": "――「正夫の世界」――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
