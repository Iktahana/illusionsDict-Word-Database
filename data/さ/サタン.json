  {
    "uuid": "3578d596-f235-5ebc-9df7-4a0c59f36237",
    "entry": "嗟嘆",
    "reading": {
      "primary": "さたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lamentation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこには深い深い絶望の嗟嘆と、人間の心のどん底からにじみ出た恐ろしい深酷なセンチメンタリズムとがある。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　　×　　×　　×　　×　　×　　×　　×　　×　　　　　×　　×　　×　　×　　×　　×　　×　　×　　×　Ｓ夫人の白隠伝は、こののんきな嗟嘆の声で終っている。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらにあってはただ嗟嘆するのみ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌黎嗟嘆すること久うして曰く、吾今にして仙葩を視たり。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余輩は彼の光栄ある戦勝を得ながら、一文の償金すら取れざりし事を今更嗟嘆する者にあらず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と嗟嘆して、此うしてゐては、遂に自滅を免かれぬと思ふ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "門族の栄華の雲に蔽われて、自家の存在と、学者の独立とを忘れていた英吉は、日蝕の日の、蝕の晴るると共に、嗟嘆して主税に聞くべく、その頭脳は明に、その眼は輝いたのである。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れ、我ら近代邪宗門の徒が夢寝にも忘れ難きは青白き月光のもとに欷歔く大理石の嗟嘆也。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃霧はそそぐ……そこここに虫の神経鋭く、甘く、圧しつぶさるる嗟嘆して飛びもあへなく耽溺のくるひにぞ入る。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――霧しぶく苑の奥、夕日の光、水盤の黄なるさざめき、なべて、いまものあまき嗟嘆の色。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "外面なる嗟嘆よ、波もなきいんくの河に旗青き独木舟そこはかと巡り漕ぎたみ、見えわかぬ悩より錨曳き鎖巻かれて、伽羅まじり消え失する黒蒸汽笛ぞ呻ける。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、さはあかれ、嗟嘆の樅のふたもと。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、はやにほへ、嗟嘆の樅のふたもと。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、また燃ゆれ、嗟嘆の樅のふたもと。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、見よ、悩む、嗟嘆の樅のふたもと。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、さは顫へ嗟嘆の樅のふたもと。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の宇宙をわたくしは日夜に検鏡しつつ、人知れぬ驚喜と嗟嘆とに我が身内も顫へつつある。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "此雑誌も既に第六号を刊行するに至り候事、嬉しき事に候へど、年齢に伴なふ思想の発達著るしからざるに徴すれば、精神的意義に乏しき武断一偏の校風が今猶勢力を有する結果なるべくと、婆心また多少の嗟嘆なき不能候。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "智謀あり、秀吉、家康に向って嗟嘆して曰く、「今｜茲に二つの不思議あり、君知れりや」と。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌幸死に臨み、わが死後三年にして必ず、東西手切れとならん、我生きてあらば、相当の自信があるがと云って嗟嘆した。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、盛んな自然の大暴れに、嗟嘆の声をあげていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、たとえ幸運が我々の側を見すてずに、スレーターが頸骨を挫折して即死してしまったとはいえ、この一事あるがため、もしさもなければ犯罪上の最大な傑作として、人々を言葉もないほど嗟嘆させたでもあろうほどの玉に、一つの瑕をつけてしまったのである。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど洪水じゃなと嗟嘆せざるを得なかった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程洪水ぢやなと嗟嘆せざるを得なかつた。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧の為に嗟嘆したり怨憤したり、甚しきに至っては自ら殺し、人を殺すに至る者もある。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の人は年末には感慨嗟嘆し年頭には奮起し祝福するのが常である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその事があって以来、暫く貴女のお姿が、見物席に見えなかったので、愈々私の思い違いを信じ、貴女が私の無礼をお怒りになり、あれきりお姿をお見せにならなくなったのではないかと思うと、私は身も世もないような、深い失望と嗟嘆とに暮れてしまいました。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄は、元気であった父も、折々は嗟嘆の声を出すようになった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は苦しがって長い釘を柱へ打ち込み乍ら、困った、困ったと云う嗟嘆を繰り返した。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "定めとてもない漂泊の旅に転々として憂世をかこち勝ちな御面師が、次第に自分の名前にまでも呪詛を覚えたといふのが、漠然ながら私も同感されて見ると、私は彼との悪縁が今更の如く嗟嘆されたりした。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
