[
  {
    "uuid": "eaa42c08-6ee8-521c-bfba-2ba6d4815768",
    "entry": "再三",
    "reading": {
      "primary": "さいさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "again and again",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "再三すゝめるけれど却々剛情で洗礼を受けない。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が芥川君と別れてゐる間、再三この疑問について考へた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "再三問いかえせしも訛の耳なれぬ故か終にわからず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再三医者に懇願してよう／＼自宅で療養することにして貰った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、再三籠を背負って行くのを見た者があるそうだ。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って、あまり這いようがおそいと、再三繰りかえさせられる。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば江上の杜鵑というありふれた取り合わせでも、その句をはたらかせるために芭蕉が再三の推敲洗練を重ねたことが伝えられている。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ来るやうにと再三駄目を押して帰つて待つたけれども、四十分も待つのに来てくれさうにはなかつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二人は再三辞退して、ようやくこれを受納め、「ああ、お若いに御奇特な。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう稀有の例であるから、老中の方でも最初は容易に許可しそうにも見えなかったが、再三評議の末にいよいよそれを許可することになった。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが隣座敷へ夜中に再三出入したことを、どうしてか宿の者に覚られたらしい。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之も高い所から再三転げ落ちて、剣の如き岩石に撃れ劈かれたので、古い鳥籠を毀したように、身体中の骨は滅裂になっていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察の方でも無論｜之に目を注けて、再三取調べたけれども更に要領を得ない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の真青な顔や瞬き一つしない鋭い眼の輝きは見逃されたとしても再三すゝめられても御馳走に箸一つつけない彼の強情振りは、明らかに人眼をひいた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、青大将の顔に似た顔つきの、丸坊主のおやじが、首を振り振り、いかにも上手みたいにごまかしながら鮨を握っている様も、眼前に見るように鮮明に思い出され、後年、電車などで、はて見た顔だ、といろいろ考え、なんだ、あの時の鮨やの親爺に似ているんだ、と気が附き苦笑した事も再三あったほどでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実をいへば詩集「月に吠える」出版の時、序文を是非蒲原有明先生にたのみたく再三書簡を以て懇願したるも返事を下さらないので、遺憾ながら意を果さなかつたやうなわけです。",
              "citation": {
                "source": "蒲原有明に帰れ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはもう、お前の顔を二度とふたたび見たくなかったので知らん振りをしていたが、あさは再三お前に、島田の留守中はこっちにいるようにと手紙を出した様子だった。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日、戊午、和漢の間、武将の名誉有るの分御尋ね有るに就いて、仲章朝臣之を注し出して献覧せしむ、今日、善信、広元等、御前に於て読み申す、又御不審を尋ね仰せられ、再三御問答の後、頗る御感に及ぶと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草田氏は僕に、再三、「どうか、よろしく静子に説いてやって下さい」と手紙でたのんで来ているのだが、僕は、動きたくなかった。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　われとわが作品へ、一言の説明、半句の弁解、作家にとっては致命の恥辱、文いたらず、人いたらぬこと、深く責めて、他意なし、人をうらまず独り、われ、厳酷の精進、これわが作家行動十年来の金科玉条、苦しみの底に在りし一夜も、ひそかにわれを慰め、しずかに微笑ませたこと再三ならずございました。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿かいて、雑誌社へ持って行っても、みんな、芥川賞もらってからのほうが、市価数倍せむことを胸算して、二ヶ月、三ヶ月、日和見、そのうちに芥川賞｜素通して、拙稿返送という憂目、再三ならずございました。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川賞と言えば、必ず、私を思い浮べ、または、逆に、太宰と言えば、必ず、芥川賞を思い浮べる様子にて、悲惨のこと、再三ならずございました。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王辞すること再三、諸王｜羣臣、頓首して固く請う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "是より建文の事に関せず、専ら国威を揚げしめんとして、再三｜和を出す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の點より觀れば、能く福を惜み得るに於ては其の人既に福人なのであるから、再三再四福に遇ふに至るも、怪むべきでは無いのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に張る氣の事を説くも、再三に亙つて居るから、人少しく自ら省察すれば、おのづから其の消息を悟り得よう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は鼻をつまんで、三度まわって、それから片手でコップの水を二拝して一息で飲む、というまじないを、再三再四、執拗に試みたが、だめであった。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と再三、忠告した筈でありました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見したのを直ぐ其の儘受け取らないで、再三再四繰返えし考え、横からも縦からも噛みしめて本当の事実を本然の姿を突き留めて来て下さい。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み返すこともしないらしく、送った原稿が一枚抜けていたりすることも再三あった。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
