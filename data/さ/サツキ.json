    "definitions": [
      {
        "index": 1,
        "gloss": "fifth month of the lunar calendar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私が最初に会つたのは、一昨々年の五月である。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月、四月、五月、そうです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月のなかば、私は、あの日を忘れません。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年は、竹村書房から「愛と美について」砂子屋書房から「女生徒」女生徒は、ことしの五月に再版になりました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十五年五月、「朝の歌」を書く。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仝年五月、「朝の歌」及「臨終」諸井三郎の作曲にて日本青年館にて発表さる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和八年五月、偶然のことより文芸雑誌「紀元」同人となる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉親は五月蠅い、と思はず、何時もながら痛感した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "開けさせたくはないが開けて貰へば少しでも五月蠅さが減るだらう。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺の感傷が俺を五月蠅くするのだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちばなの昧爽時や古館　五月雨頃の、仄暗く陰湿な黄昏などに、水辺に建てられた古館があり、橘の花が侘しげに咲いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙燭して廊下通るや五月雨　降り続く梅雨季節。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨や御豆の小家の寝覚がち「五月雨や大河を前に家二軒」という句は、蕪村の名句として一般に定評されているけれども、この句はそれと類想して、もっとちがった情趣が深い。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に夏の部で評釈した句「五月雨や御豆の小家の寝醒めがち」も、どこか色っぽい人情を帯びてはいるが、詩情の本質においてやはりこれらの句と共通している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠島はいづこ五月の泥濘道　芭蕉の行く旅の空には、いつも長雨が降りつづき、道は泥濘にぬかっていた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨や蚕わづらふ桑畑　暗澹とした空の下で、蚕が病んでいるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の道や葵かたむく五月雨　曇暗の雲にかくれて、太陽の光も見えない夏の昼に、向日葵はやはり日の道を追いながら、雨にしおれて傾いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊香保のいちばんいい季節は、晩春四五月から、初夏の六七月へかけた時期である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も春といつても、山の春は遅いから、伊香保で春といへば五月か六月であらう。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年五月『輻射』）",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "油地獄にも、ならずものの与兵衛とかいう若い男が、ふとしたはずみで女を、むごたらしく殺してしまって、その場に茫然立ちつくしていると、季節は、ちょうど五月、まちは端午の節句で、その家の軒端の幟が、ばたばたばたばたと、烈風にはためいている音が聞えて淋しいとも侘びしいとも与兵衛が可愛そうでならなかった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも五月の朝の如く爽やかで、樹蔭のやうな緑の光線で一ぱいで、浦島は幾日をここで過したか、見當もつかぬ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に、谷は、四月の末か、五月頃の柔々しい呼吸で充ちていて、大きな声を出すのすら、いたいたしいようだ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月では野にこの青味がない、五月では山にこの花がない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年五月『鉄塔』）",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし年の初め、例えば四、五月頃に七、八月の気候を予察して年の豊凶を卜し、そうしてあらかじめこれに備えることには十分な可能性がある。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は「五月蠅」と書いて「うるさい」と読み、昼寝の顔をせせるいたずらもの、ないしは臭いものへの道しるべと考えられていた。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治三十二年五月『ほととぎす』）",
              "citation": {
                "source": "赤",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖母さんが台所に這入ると、小僧は天秤棒を担ぎあげて、「ありがと、存じました」といふや、赤い手を振りながら、さつき良子が隠れた、あの通路の方へ行つた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきのことばと言へ、今の笑ひ声と言ひ明らかに自分を侮辱してると彼は一途に思ひつめた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
