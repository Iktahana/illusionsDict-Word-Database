        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は愛車のバイクにサイドカーを取り付け、犬と一緒に旅に出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、父が運転するサイドカーに乗って、風を切って走るのが大好きだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "観光地でレトロなサイドカーに乗って、街並みを巡るツアーが人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "サイドカーと広告球を衝突させたがる人間の多い世の中である。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを配達するときは、〒やサンがサイドカー付きのオートバイで配ってまわる。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クラブ二つ」「ハート二つ」「クラブ三つ」「ハート三つ」　サイドカードもこんなにいい。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人乗りの古風な馬車と、更生車と称する自転車にくつつけたサイドカー（？",
              "citation": {
                "source": "天草の春",
                "author": "長谷健",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間でサイドカーというもの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼近くになってサイドカーをひっぱり出してきたロードレース・クラブの連中は、乗りたがるミーヨに、ショート・コースを使ってパッセンジャーのやりかたを教えはじめた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
