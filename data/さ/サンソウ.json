    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sergeant (JGSDF)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジョバンニさんそうでしょう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニさんそうでしょう」　ジョバンニはまっ赤になってうなずきました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんそうは思わないの？",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからいつでも、お母さんそう云ったんだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あゝ、こんな夏になつてから、私は一人の娘さんを見つけました、あなたそれは貴女なのですよ、肩揚のある、私の相手にふさはしい娘さんそうでせうね』　娘さんは寂しさうな顔の半面を月の光りに照らしながら、まだ未練さうにどこかの味瓜に白眼をつかつてゐる様子であつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれどＫ――さんそう言ってたわ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「島ちゃん、お前さんそう幾日も幾日もこちらの御厄介になっていても済まないじゃないか。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、あの、お宅の……おかみさんはおいででしょうか」「へえ、おいでやすが……」とその男は答えたが、うさんそうに私を眺めながら、それ以上何とも答えずに、さっさと裏口から家の中に消えてしまった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「にくらしい人ですねえ、何てまあ……、私と同じ女と云うもんの中にそんな人のあるのを思うと私はどうしていいかわからないほどになっちゃいますワ、ほんとうに……」「何にもお前に関係のある事じゃあないじゃないか」「そうには違いないけど阿母さんそうお思いなさらない？",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だってお前さんそうじゃアないか、相手がそういう偉者だから、なまじっか大人などを差し向けると、すぐ気取られて用心され、それこそ失敗しようじゃアないか」「うん、成程、そりゃアそうだ」今度はどうやら猪右衛門にも、胸に落ちたらしい様子であった。",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なアお神さんそうだろう！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋なんかに行くより、その方が、人目にもつかないし、あたしの貫祿……おかしいわね、梅葉姐さんそう言ったわ……貫祿のためにいいんですって。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦さんそういっていた。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それを彼女が自分で、こうだというのですか」「ええ、姉さんそうおいいやした。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お前さんそう思わないの？",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だってお前さんそうじゃないか。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬい　そうすれば先刻の奴が、いくらやって来ても安心だから、兄さんそうしておくれ。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それが真理だと解っているなら、例え自分は極りの悪いほど濁った、嗄がれ声であっても、美くしい声をもっている人を讃め、なおなおたくさんそういう人の出てくれることを願うべきではありますまいか。",
              "citation": {
                "source": "地は饒なり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちゃんと囲いがしてあって、門がしまっとるわい」　彼は門の上や、その両側に描いてある聖徒の像に向かって、ぎょうさんそうな十字を切り始めたものだ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一刀、一刀、じつにみごとに相手を倒していました、あのくらい使える人はそう多くはないでしょう、花田さんそう思いませんか」「えっ、なんですか」　万三郎は考えごとをしていたので、こう訊き返してから、頷いて答えた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウフフフ、……皆さんそうじゃろうが。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さんそういうことです、ご存知でしょう、ただし霊力があればですが。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と駒をとめた咲耶子は、美しいほほえみをなげて見おろしたが、ふと、伊那丸のすがたを目にとめて、三日月なりの眉をちらりとひそめながら、「まあ、そのおさない人を、ぎょうさんそうにからめてどうするつもりです。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
