    "definitions": [
      {
        "index": 1,
        "gloss": "trivial",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実に瑣末な事柄ではあるが、これだけでもままにならぬ人世という古い標語の真実性を証するための一例にはなるのである。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、瑣末な例であるが『武道伝来記』一の四に、女に変装させて送り出す際に「風俗を使やくの女に作り、真紅の網袋に葉付の蜜柑を入」れて持たせる記事がある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それでもいいからと云われるので、ではともかくもなるべくよく読み返してみてからと思っているうちに肝心な職務上の仕事が忙しくて思うように復習も出来ず、結局｜瑣末な空談をもって余白を汚すことになったのは申訳のない次第である。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理のような基礎科学の教科書が根本の物理そのものはろくに教えないで瑣末な枝葉の物理器械や工学機械のカタログを暗記させるようなものでは困ると思う。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んでも、大体はお互に知り合っていて、瑣末な事を追加して話すというような工合さ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことは右の句の鑑賞にはたいした関係はないことであろうが、自分はこういう瑣末な物理学的の考察をすることによってこの句の表現する自然現象の現実性が強められ、その印象が濃厚になり、従ってその詩の美しさが高まるような気がするのである。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この瑣末な経験はいろいろなことを自分に教えてくれた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この集の内容は例によって主として身辺｜瑣事の記録や追憶やそれに関する瑣末の感想である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな瑣末な科学的知識でも、その背後には必ずいろいろな既知の方則が普遍的な背景として控えており、またその上に数限りもない未知の問題の胚芽が必ず含まれているのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画を見ているうちに自分にはいろいろの瑣末な疑問がおこった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばまた自分の専攻のテーマに関する瑣末な発見が学界を震駭させる大業績に思われたりする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸人の書を讀むや、多くは枝葉瑣末の事を記得して、卻つて其の大處を遺るゝのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛邦、近年神道を興すとて瑣末な柏手の打ち様や歩き振りを神職養成と称して教えこみ、実は所得税を多く取らんために神職を増加し、その俸給を増さしめ、売れ行きの悪い公債証書を売りつけんために無理早速に神社基本金を積ましむる算段と思わる。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "重箱の隅をつつくだけが生きがいの瑣末主義者どもに、「そんなことは人間の仕事じゃないぜ」と啖呵を切ってやりたかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして誕生した編集プロダクションという名のタコ部屋で、かつてオレは瑣末な約束事の特殊処理班として奮闘していた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを瑣末なあれやこれやにこだわれば、大局を見失うに決まってるじゃないかと考えて、ＤＯＳ／Ｖ音頭歌い上げとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは旅行に附随して来る種々の瑣末な事件を煩はしく思ふのである。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて人間に関する事は、どのような瑣末の問題でも、深くこれを思う時は、次第にその関連するところが多くなって、終に「人生の行方」というような大問題に連なり結ばれるものである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて『和漢三才図会』の著者が、〈けだし竜宮竜女等の事、仏経および神書往々これを言う、更に論ずるに足らず〉と結んで居るが、一概に論ずるに足らずと斥けては学問にならぬ、仍ってこれから、秀郷の竜宮入りの譚の類話と、系統を調査せんに、まず瑣末な諸点から始めるとしよう。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでまず竜宮入り譚の瑣末な諸点を解いたつもりだ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも、ぼくが下女に命じて、先生の気にいるように始末をつけるんだが――そんな瑣末な事はとにかく、これから大いに活動して、先生を一つ大学教授にしてやろうと思う」　与次郎はまじめである。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし、これは、ある流派の文学の末期に起こるトリヴィアリズム〔瑣末主義〕に対して、常に繰り返される批難であろう。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世でも理想家はある、しかし多くの理想家の理想は死理想で役に立たない、実際家は固より多い、しかし実際家は理想を欠くが故に其為る所は動もすれば委下瑣末に流れて生存に役せられてゐる、かまけてゐる。",
              "citation": {
                "source": "旅日記",
                "author": "東海道線",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉村の顏に動く表情のどんな瑣末な陰翳をも見逃すまいとの意氣組である。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで話のついでだが、君は瑣末なことが好きで、僕のつまらぬ体験をひとつふたつ記録に起こしたろう。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる有様で、プロレタリア文学運動の退潮後、文学論議は混迷しつづけて益々思弁の瑣末末技の穿鑿に走った。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは、現代生活と文学とから研究の分野を切りはなしてしまったのみならず、専門家間に実証主義という名で呼ばれているそうであるところの一部の研究家を、その準備的研究の上に固着せしめ、枕草子の専門家或は大鏡の専門家という、瑣末な活動に封鎖する結果をひき起した。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庶民性そのものへの過剰な肯定があることから、散文精神なるものが従来の作家的実践のままでは、とかく無批判的な日暮し描写、或る意味での追随的瑣末描写の中に技術を練磨される傾きであった。",
              "citation": {
                "source": "文学の大衆化論について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの純文学の作家の日常生活が余り特殊な文壇的或は技術的範囲に限られていた結果、そういう作家の社会的生活の経験の貧困は作品の質の著しい低下、瑣末主義を惹起した。",
              "citation": {
                "source": "今日の文学に求められているヒューマニズム",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたの神さまつてどんな神さまですか。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
