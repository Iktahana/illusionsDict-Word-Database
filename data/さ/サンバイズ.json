[
  {
    "uuid": "3f53cd2c-9a2f-51c6-8e3a-2f6915ac987c",
    "entry": "三杯酢",
    "reading": {
      "primary": "さんばいず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
