        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが日本人の抒情的な言葉で、あきらめと呼ばれるものであることさえ、おそらくヘルンは知ったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日二三合の米の飯と、少しばかりの副食物と、二三合の日本酒とさえあれば、それで私の生活は充分であると、その訪問客に語っているヘルンは、実際に学者風の簡易生活をしていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はその追想記の中で、箪笥の抽出を開けるにさえも、そッと音を立てぬように気をつけたと書いている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした夫婦の会話は女中や下僕にはもちろんのこと、子供たちにさえもよく解らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ家の中に住んでる家族の者にさえも、ほとんど全く解らない不思議な言葉で、何時間も倦きずに睦じく語り合ってた二人の男女こそ、この世における最も理想的に幸福な夫婦であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年多少日本に幻滅を感じた時でさえも、他の外人が日本を悪意的に批評する時、いつも憤然として大に怒り、さながら自分の愛人を侮辱された時の騎士のごとく、鋭い反撃の槍をふるって突き当って行った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊さんになるさえもよきです』『あなた、坊さんになる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が蛇を追ったといって叱られ、植木屋が筍を抜いたといって怒られ、はては『おババさま』の姑でさえが、枯れた朝顔をぬいたというので『おババさま好き人です。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "松江に居た時も焼津に居た時も、道に捨猫さえ見れば拾って帰り、幾疋でも飼って育てた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどにも情深く、心根のやさしい人があるかと思い、ヘルンに対して、何かいじらしく涙ぐましいものさえも感じたというのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人でさえも書斎に入ることは許されなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "創作集に序文を附ける事さえ、いやである。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の映画は、そんな敗者の心を目標にして作られているのではないかとさえ思われる。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "象徴と譬喩と、どうちがうか、それにさえきょとんとしている人がたまにはあるのだから、言うのに、ほんとに骨が折れる。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛情とさえ結びつく。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、妹さえ丈夫でございましたならば、私も、少し気楽だったのですけれども、妹は、私に似ないで、たいへん美しく、髪も長く、とてもよくできる、可愛い子でございましたが、からだが弱く、その城下まちへ赴任して、二年目の春、私二十、妹十八で、妹は、死にました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたを、一日も、いや夢にさえ、忘れたことはないのです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、そのころすべてにだらしなくなっていて、ほとんど私の身にくっついてしまったかのようにも思われていたその賢明な、怪我の少い身構えの法をさえ持ち堪えることができず、謂わば手放しで、節度のない恋をした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑いだすと果しがないけれども、いったい、彼にはどのような音楽理論があるのか、ヴァイオリニストとしてどれくらいの腕前があるのか、作曲家としてはどんなものか、そんなことさえ私には一切わかって居らぬのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の言葉に依れば、彼のケエスそれ自体が現代のサンボルだ、中はうそ寒くからっぽであるというんだが、そんなときには私は、この男はいったいヴァイオリンを一度でも手にしたことがあるのだろうかという変な疑いをさえ抱くのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな案配であるから、彼の天才を信じるも信じないも、彼の技倆を計るよすがさえない有様で、私が彼にひきつけられたわけは、他にあるのにちがいない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日一日をいっぱいに生きている」　それ以後、私は馬場へ肉親のように馴れて甘えて、生れてはじめて友だちを得たような気さえしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金さえあれば、できる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたまじゃくしさえ読めるかどうか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい音楽学校にはいっているのかどうか、それさえはっきりしていないのです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たのみます、といって頭をさげる、それが芸術家の作品のような気さえしているのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、――いや、そむいてみることさえできない」「君を好きだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのうちに君、眼がさめて見ると、――」「おっとそれあ言うな」馬場は右手を鼻の先で力なく振って、太宰の言葉をさえぎった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれが、やがて大隅君のあの鬱然たる風格の要因にさえなった様子であったが、思いやりの深い山田勇吉君は、或る時、見かねて、松葉を束にしてそれでもって禿げた部分をつついて刺戟すると毛髪が再生して来るそうです、と真顔で進言して、かえって大隅君にぎょろりと睨まれた事があった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いつのまにやら豪放な風格をさえ習得していた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
