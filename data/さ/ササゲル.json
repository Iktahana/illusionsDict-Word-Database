    "definitions": [
      {
        "index": 1,
        "gloss": "to lift up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで私は立って窓枠にのせてあった草花の鉢をもって片隅に始めから黙って坐っていた半白の老寡婦の前に進み、うやうやしくそれを捧げる真似をしたら皆が喜んでブラボーを叫んだり手と拍いたりした。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯が炊けると、嘉代吉はお初穂を取って押しいただいた、山の神さまへ捧げるのだという、私も人夫も、それを四、五粒ずつ分けてもらって、同じように押し頂いて喰べた、奥穂高はと見ると、もういつの間にか、霧がかかった、きょうもまた雨の糸で縫いこめられる象徴のように。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その珠は埋もれた諸經をたづねに海にはいるとき捧げるのである。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は君の愛のすべてを自分のために捧げる覺悟が出來てゐるか？",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "車掌は踏台から乗り出すようにして、ちょっと首をかしげて右の手でものを捧げるような手つきをしながら「もう一枚頂きましょう」と云ってニヤニヤした。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き終へて讀みかへしてみたら、まるでもう滑稽物語になつてしまつてゐたので、これは當時のユウモア小説の俊才、伊馬鵜平君に捧げる事にしたのである。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の肉体の貞操を売っても、夫へ心の貞操を捧げるのを良しと認めた封建時代の女性の良心は、もう今日の女性の良心ではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際巴里人には妻も子も持たないで生涯の愛を舌に捧げる食道楽がたくさんある。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやな許嫁に処女を捧げるよりは……」　と、昨日伊都子は信吉に身を任せた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのものを擲って、肉体と魂と一切のものを――生命までも捧げるようでなかったら、とても僕の高い愛に値しないというような意味なのよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "輪※と樹木輪※の暦をかぞへてみればわたしの過去は魚でもない　猫でもない　花でもないさうして草木の祭祀に捧げる　器物や瓦の類でもない金でもなく　蟲でもなく　隕石でもなく　鹿でもないああ　ただひろびろとしてゐる無限の「時」の哀傷よ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "都會に於ても同じやうに、かうした神神に供物を捧げる人人は、概ね皆社會の下層階級に屬するところの、無智で貧しい人人である。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸瓜に縁があるから「猫」と共に併せて地下に捧げる。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "花にばかり捧げると誓つた桂子の貞操が、こんな言ひ訳を時々自分に向けてしてゐたのだつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "捧げるように両手で取って、「大助りです、ここに雨やみをしているもいいが、この人が、」　と見返って、莞爾して、「どうも、嬰児のように恐がって、取って食われそうに騒ぐんで、」　と今の姿を見られたろう、と極の悪さにいいわけする。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老爺も要らぬ尻押せず、柔順に妻を捧げるやうに、少いものを説得せい。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえが捧げる相手が見付かるまで、わたしはなお禁慾の生活を続けるであろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇「さあ飴を食うぞ」　と翁が云うと老夫人が、大きな茶碗に水を入れたのを翁の前に捧げる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宝石を捧げる私の気もちが、あなたには、おわかりにならないのですか。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "満城の衆みな身命を天主に捧げる覚悟までである」　と書かれてあった。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「味噌湯の方、身体温まっていがんべから……」　お婆さんは床の上に起きかえって、茶碗を、両手で捧げるような手付きで、フウフウと吹きさましながら、続けて二杯も呑んだ。",
              "citation": {
                "source": "蜜柑",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのシャーロック・ホームズ先生はまた、ロンドンの複雑した生活の齎す幾多の興味ある問題の検討に、思うままに生涯を捧げることが出来ることになったと云うわけだ｣",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "残されたものが他にないとすれば、あとはその人生を復讐に捧げるしかない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおさら痛ましいのは――ご婦人がどこから見ても男子一身の愛を捧げるに足る貞淑な人物であることであります。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を詛はんと欲する者、少しの金を捧げると、其女被詛者の名を簿に註し、其名を呼乍ら、留針一本井に落すと詛ひが利いた（Gomme,‘Ethnology in Folklore,’ 1892, p. 87）。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "このけばけばしいランプや香炉がしきりにそれにうち勝とうとしている、かなたの神々しい太陽に捧げるために、酒を注ごうじゃないか！",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけならば、彼らもあるいは忍んで命を光尚に捧げるときの来るのを待つかも知れない。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの一室で人が対話していると、窓越しに見える遠見の屋上でアラビア人のアルラーにささげる祈りの歌が聞こえる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、以上のような経歴をもつ一私人が「文学」と「科学」とを対立させてながめる時に浮かんでくるいろいろな感想をここに有りのままに記録して本講座の読者にささげるということは、全く無意味のわざでもあるまいと考えたので、編集者の勧誘に甘えてここにつたない筆を執ることにした次第である。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青びかりの三角のサンムトリが　たちまち火柱を空にささげる。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
