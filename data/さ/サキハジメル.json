          "standard": [],
          "literary": [
            {
              "text": "が、その咲き始める時はまことにいゝ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "伊豆西海岸の湯",
                "note": "青空文庫"
              }
            },
            {
              "text": "表庭の百日紅に、ぽつぽつ花が咲き始める。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその季節が来ると、勝手に素直に季節向の顔は咲き始める。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、知らないうちに囁きは呟になり、呟は謡となってイレンカトムの唇には、燃え出した霊の華が、絢爛と咲き始めるのである。",
              "citation": {
                "source": "風に乗って来るコロポックル",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
