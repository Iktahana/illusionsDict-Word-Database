[
  {
    "uuid": "c801e226-e0f4-5fa9-94a5-e63e8ffeff6c",
    "entry": "三昧",
    "reading": {
      "primary": "さんまい",
      "alternatives": [
        "ざんまい"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
