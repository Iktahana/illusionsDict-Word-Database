    "definitions": [
      {
        "index": 1,
        "gloss": "row of cherry trees (lining a street)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "桜並木の下で、本科の学生が五、六人、立ったりしゃがんだり、けれども一様に真面目な顔をして、僕を待っていた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "満開をすぎた下の道の桜並木が、車道いっぱいにひろがって寮への道を歩む連中に、盛大に花びらを散らしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜並木は死んでいなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫓の上からホースが二すぢ釣りさがつてゐるのが灰色に見えその少し向は桜並木が黒々と渦巻いてゐた。",
              "citation": {
                "source": "潮干狩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚東川べりの桜並木も美しかつた。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "買って来るわ、ハインツの出来ているのがあるだろうから」「私も行きましょう」　雨があがった桜並木の食糧品屋へ行って見た。",
              "citation": {
                "source": "九月の或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一軒、あっちの桜並木通りの医者へ行った。",
              "citation": {
                "source": "金色の秋の暮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は或る郊外住宅地の住人となっているのだが、そこに見事な桜並木が数丁続いている。",
              "citation": {
                "source": "塵埃、空、花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポチ、ポチ、――ポチふうむ、ポチでもないのか」　夜、暗く長い桜並木の間を家へ帰る途中、よく犬と道づれになる。",
              "citation": {
                "source": "蓮花図",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺からもう町の大通りである桜並木が始っていた。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉焚の煙が見とおしの利く桜並木の通りにも上った。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時、見なれた土手町の桜並木、少年のくらくらするような気持で仰ぎ見た国泰寺の樟の大樹の青葉若葉、……そんなことを考え耽っていると、いま頭のなかは疼くように緑のかがやきで一杯になってゆくようだった。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時、見なれた土手町の桜並木、少年の頃くらくらするやうな気持で仰ぎ見た国秦寺の樟の大樹の青葉若葉、……そんなことを考へ耽けつてゐると、いま頭のなかは疼くやうに緑のかがやきで一杯になつてゆくやうだつた。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ学園前で電車を降りると、その辺は空気も澄んでゐて桜並木の路も私の眼に泌みるやうだつた。",
              "citation": {
                "source": "二つの死",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内を縦に貫く元安川沿いの桜並木は、平和公園に春めいた華やぎを与え、小高い丘といった印象の比治山に人々は酒肴をたずさえて桜を求める。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "海添いの桜並木、海の上からも、薄｜紅い桜がこんもり見えていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……幼稚園　桜並木のある堤の下の、或小さな路地の奥に、その幼稚園はあった。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "久し振りで、本当に震災後初めて十ヶ月振りで鎌倉の駅を見、あの松、あの将軍道の桜並木を見て、実に愉快でもあり、やはり都会の空気とは違つた新しさ、海からの風、六年間｜居馴染んだ空気、風情の懐しさに、酒を飲まなくつたつて酔つたやうな気分にならずにゐられなかつた。",
              "citation": {
                "source": "椎の若葉",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の誕生日じゃないの、そんなに怒らないだっていい」「生れなけりゃよかったんだ」迚も心にこたえ、涙やっと堪え、パン買いに出かけたら、桜並木のところでむこう向いて立って居る人せきさんであった。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十九日（月曜）　昨夜句あり　○白猫の足裏に散る萩の花　○竹の露しとど檐打つ夜半もあり　○はためくや遠稲妻に虫の声　今日　○鎌切の恋のかたみか雄の翹　○桜並木｜病葉の下犬二匹　○赤松の根に露草は咲きやらず九月二十二日（木曜）　アルキペンコの作品が面白かったものの一つです。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小やみに桜並木を上の方へ行って見た。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅を下りてからの長い桜並木は、まだ莟が堅くて、籬の中には盛りの過ぎた白梅が、風もないのにこぼれておりました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山吹の黄色い花も、桜並木の下を埋めていた。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは寂しい木津川縁で、うるんだ春の二十日月が、岸に並んで花咲いている桜並木の梢にかかり、蒼茫と煙った川水に一所影を宿している。",
              "citation": {
                "source": "赤格子九郎右衛門の娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その桜並木の遙か彼方の、斜面をなしている丘の上の、諏訪神社の辺りでは、火祭りの松明の火が、数百も列をなし、蜒り、渦巻き、揉みに揉んでいるのが、火龍が荒れまわっているかのように見えた。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やぁ――」　桜並木になっている坂の小径を、深水が気どったすまし方でのぼってきた。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜並木の小径をくだって、練兵場のやぶかげの近道を、いつも彼女が帰ってゆく土堤上の道にでると、もう夕映えも消えた稲田甫の遠くは紫色にもやっていた。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥居をくぐると染井吉野や枝垂桜の交った一町余りの桜並木が八分の開花を見せて、稍紅の濃い葩からは、宵に降った雨の名残の雫がはらはらと滴っている。",
              "citation": {
                "source": "春の大方山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が土佐から京都に移つて来たのは、昭和十三年の十月のことだつたから、洛中の人となつてからもうすでに十六年、現在私は銀閣寺に近い浄土寺石橋町といふところに住んでゐるが、ここは大文字の送り火で名高い如意嶽の麓で、亡き関雪画伯邸白沙村荘の筋向ふ、前には両岸に桜並木のある、疎水の水が流れてゐる。",
              "citation": {
                "source": "老境なるかな",
                "author": "吉井勇",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉桜になった桜並木のバス道路に、大型の貸切バスが十台ばかりパークしていて、車をまわす空地もないのに、朱と水色で塗りわけた観光バスがジュラルミンの車体を光らせながら、とめどもなくつぎつぎに走りこんでくる。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
