    "definitions": [
      {
        "index": 1,
        "gloss": "jumping straight to the business, ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
