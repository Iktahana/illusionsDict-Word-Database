[
  {
    "uuid": "c2192f0e-dcf9-5e68-965c-35fef1092ffc",
    "entry": "先方",
    "reading": {
      "primary": "さきがた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
