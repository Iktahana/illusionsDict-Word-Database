        "examples": {
          "standard": [
            {
              "text": "その犯人は、被害者に苦痛を与える残忍な方法から、サディスティックな傾向を持っていたことが明らかになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "映画の悪役は、他者に苦痛を与えることにサディスティックな喜びを見出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのようなサディスティックな行動は、いかなる理由があっても許されるものではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「本日は、午後の自由時間を利用して、サロンの特設サテライトスタジオから、特別プログラムをライヴでお送りします。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなさんになにかよいアイディアがあれば、この放送中にサテライトスタジオまできて、発表してください。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザ・ウォーカー・ブラザーズ、〈（ベイビー・）ユー・ドン・ハフ・トゥ・テル・ミー〉」　ワラがマイクのスウィッチを切ると同時に、複数の人間がいっせいに口を開き、サテライトスタジオは大混乱におちいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サテライトスタジオからの放送は、新入生の勧誘のためだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、四日間の特別プログラムと、サテライトスタジオというＰＲが予想以上の効果をあげて、フタをあけてみれば、二十八人もの新入生が入部希望を提出していた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サテライトスタジオをつくればよかったね」　まったく、ラグビーでもやっているみたいだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
