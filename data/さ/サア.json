    "definitions": [
      {
        "index": 1,
        "gloss": "come (on)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さあれ日は過ぎ月は逝き、なれ等血もなく涙なく、よくぞ鬩めげる数千年、さても殺生はての死の、よくぞ好きなる、おゝ永遠の闘争よ、おゝ恩怨の同胞よ！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が這入つて行くなり、「さあお相手しませう」とその男は云つた。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………男　ぢや今度は俺も神剣だよ、さあ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、なんと言っていいか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と問われて、さあ、それは、一口でこうと説明は、どうも、その、と大いに弱っていたようであったが、むりもないことと思った。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やるなら一緒にやってもいい」「あなたは一体、何しにここへ来たのだろう」「さあ、――風に吹かれて」「言って置くけれども、御託宣と、警句と、冗談と、それから、そのにやにや笑いだけはよしにしましょう」「それじゃ、君に聞くが、君はなんだって僕を呼んだのだ」「おめえはいつでも呼べば必ず来るのかね？",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおきいふぐりをぶらさげて、さあ、この一物をどうして呉れる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西日が後れ毛の少し垂れ下つたのを透してるそれをみると――「さあ云へ」――今度は医者の方がセカセカした。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、出しますよ、今度は出る、――揺らずにヂツと――さう／＼／＼……」彼は母親の肩に手を掛けて自分が仕事のしよい位置を取らせた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあこれから、俺はこれを改めなくちや……」　だが今迄のやうに、自分のすることは直ちに郡視学の耳に入り、県視学に聞達するやうなことは、都会ではあるし、それに私立中学のことだからないだらうと思はれた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親が子を可愛がると言ふのが……さあ如何言はうか……意志的意識の世界で三文の値打があるだらうかてなあ――そりやあ親が子を可愛がるやうになつてることも必要でせう、併しそれが人間の口から如何の斯うのつて問題になるべき性質のものぢやないなあ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてレコードに吹き込んで呉れるかも知れない……ニツトー……ツバメか……鷲、さあ……」　私は何時の間にやらロマンチックな浮々しさになつてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあね………」と妻君は俯向いて揃へた指を伸ばして、女優的しなを作つたりしてゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさうなつて来ると、当然少しづゝでも解雇しなければならなくなつて来た。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あゝまだあなたは知らないんでせう、あれやあね、僕等と田舎廻りにゐた時は僕の下役をしてた位なもんでさあ、あゝン………。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "『足を蹈んだのは僕が惡かつた、惡かつたから謝罪る、ねえ君、これは僅かだけれど膏藥代に、な、納めて呉れ玉へ、さあ』對手の心事、酒代にありと見て取つた若紳士は、事の組し易きを喜んで、手早く握つた銀貨、二枚、三枚、光る物手をすべつて男の掌に移るよと見る間に「呵」と叫んで紳士は身を轉換した。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『斯う成つちやあ一番腕ツコキだ、さあ野郎、文句は言はずと、出ろ』男は片脚はづして下駄を脱いだ。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、仲好く分け合ふのだ。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ早く私の甲羅に乘つて下さい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、ここから飛び降りますよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、何をぼんやりしてゐるのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、早く御挨拶をなさい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ちやんと胸を張つて、おれは日本一の好男子で、さうして、最上級の風流人だといふやうな顏をして威張つて歩くのですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、おれのあとについて來い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、もうかうなつたら、脊中にでもどこにでも、からだ一面に塗つてくれ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、下着類を皆、脱いでここへ出して下さい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、早く脱いで寄こして下さいよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、燕麦の用意はいいよ。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝるをりしも剛直の、さあれゆかしきあきらめよ腕｜拱みながら歩み去る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあれ、怒ることこそ汝が最後なる目標の前にであれ、この言ゆめゆめおろそかにする勿れ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
