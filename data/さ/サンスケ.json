    "definitions": [
      {
        "index": 1,
        "gloss": "male bathhouse attendant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
