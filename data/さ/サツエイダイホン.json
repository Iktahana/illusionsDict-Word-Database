        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シナリオに従って精細な撮影台本が作られなければならない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれだけではまだ映画の撮影台本にはなり得ない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後のタイトルにも、監督自身や脚本家、評論家などによるコメントや、場面のイメージを絵にしたストーリーボード、撮影台本など、さまざまな資料が組み込まれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "撮影台本には次のように書いてありました――「午前一時、人通りが殆んど絶えた元町通りを、ダンス・ホールの帰りか、または、酒場で飲んでいたらしい、与多者風の、若者二三が歩いて行く。",
              "citation": {
                "source": "撮影所殺人事件",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "撮影台本はこうなっていましたがね――。",
              "citation": {
                "source": "撮影所殺人事件",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
