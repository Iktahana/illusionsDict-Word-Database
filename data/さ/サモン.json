[
  {
    "uuid": "5e99dded-af0c-5d0c-b77e-ed45f753cee3",
    "entry": "査問",
    "reading": {
      "primary": "さもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
