        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "research visit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "佐藤さんは撫順から特に来られたと云ふ友人達と詩材の採訪に暇がなかつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "北信と尾張平野とをつなぐ路線を採訪して見れば、最違つた意味に於てかぐらの意味が見出せませう。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此雪祭り見物の宿願と、その後、早川さんに唆られた花祭り採訪の欲とが、道順によい日どりも続いてゐる事を知つて、もう圧へることが出来なくなつたのでした。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳田先生から受けた方法を守る為に、採訪記の範囲を出ようとせられなかつた。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此後もつと、採訪と実感と論証とに、互ひの励みをつけて行きたい、といふ気になつてゐます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、此数年間、毎年正月になると、三河・遠江・信濃の国境に近い奥山家へ、初春の行事を採訪に出かけましたが、こゝの門松は、また形が違つてゐるのです。",
              "citation": {
                "source": "門松のはなし",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は二度の務めを、昔、国頭郡大宜味村｜喜如加の小学教員をして居て、私の国頭廻りに、引きまはしの労をとつて下された、島袋教諭の心入れに酬ゆる為、少し前に、ほんの数行手を入れたまゝで、校正も人任せで、郷土研究社の「山原の土俗」と言ふ、同教諭の採訪録の解説として、加へておいた。",
              "citation": {
                "source": "「琉球の宗教」の中の一つの正誤",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "久高島で、川平さんと私との採訪して来た「ゐなぐめがなさば君のめで、ゐきがみがなさばしゆんぢやなしめで」といふ琉歌形の民謡について早く「琉球の宗教」時分に、伊波さんその他から、心切な注意を受けてゐたのであつた。",
              "citation": {
                "source": "「琉球の宗教」の中の一つの正誤",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "信州下伊那の奥、新野の伊豆権現の雪祭りに、早川さんと二人で、採訪旅行をしたことであつた。",
              "citation": {
                "source": "雪まつりの面",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民間伝承を採訪する事の外、地方生活を実感的にとりこまうと努めた。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の記憶は、採訪記録に載せきれないものを残してゐる。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大伴家持等の古詞採訪に努めて居る様子、又家持自身創作に悩んで居る様などを見ても言へよう。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "此島出の最初の文学士で、琉球諸島方言の採訪と研究とに一生を捧げる決心の宮良当壮君の「採訪南島語彙稿」の「孵る」の条を見ると、凡琉球らしい色合ひのある島と言ふ島は、道の島々・沖縄諸島・先島列島を通じて、大抵しぢゆん・しぢるん・すでゆんなどに近い形で、一般に使はれてゐる事が知れる。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此語は其以前ねふすきいさんも、宮古・離島に採訪して来た様である。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其と今一つ、私はなるべく、認識不十分な他人の記録の奇事異聞を利用する前に、当時の実感を印象する自分の採訪帳を資料とする事が、民俗の学問の上に最大切な態度であると思ふ故に、壱岐及びその近島の伝承を中心として、この研究の概要を書く、一つの試みをもくろんだのである。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が、民間伝承の採訪に努力する所以である。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十数年以来採訪せられた材料から見ると、曾ては都方から東へ向けて、神明信仰に附随した伴神の信仰の、宣伝せられた跡が窺はれる。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "叶はぬ時の憑み人として、南方翁に智慧を拝借しようと思ひついた際、窮して通じたと申さうか、佐々木喜善さんの採訪せられた「紫波郡昔話」が出て、其第七十五話に名まで「蛇息子」として出て居た。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "資料の採訪も、書斎の抜き書きも、皆、伝承の含む、ある昔の実感を誘ふ為に過ぎません。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、北遠州天龍沿ひの山間にもある事は、早川孝太郎さんの採訪によつて知れました。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "再、此島こそ、古い生活の俤が、私の採訪に来るのを、待ち迎へてゐてくれたのだ、といふ気がこみ上げて来た。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "東大史料編纂官たる鷲尾順敬博士も、博士の仏教的見地から採訪せられたる資料について、不日高見を寄せらるべく承諾せられた。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『採訪南島語彙稿』　前にのべた「炉辺叢書」には伊波君のものも二、三冊入っていたと思う。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今も感心していることだが、『採訪南島語彙稿』という本を学生時代に一人で作って出版した。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ハワケ　飛騨丹生川谷では、稗と米とを半々にまぜたものに限つてハワケと謂ふ（採訪日誌）。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ハワケ　飛騨｜丹生川谷では、稗と米とを半々にまぜたものに限ってハワケという（採訪日誌）。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡約版は衆知のごとく、早く印行して世に出でたが、しかし私に代って戦時中には、統理の傍ら、他方には、新たに、語詞の採訪と採集とに力を尽くしつつ専ら改訂の業に従った私の次男猛は、苦心努力の結果、辞書編集上、望外にもこよなき良い経験と智識とを得たかと信ずる。",
              "citation": {
                "source": "『広辞苑』自序",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその間ここにいては邪魔になるから、例の小説の資料を採訪すべく、五六日の予定で更に深く吉野川の源流地方を究めて来る。",
              "citation": {
                "source": "吉野葛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮良君の『南島採訪語彙稿』を見ると、沖縄諸島にはクラ以下の前に掲げた三種の外に、なお先島の方面には少なくとも三通りの方言が注意せられている。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お姫さまの手には小さいほうが残り、ヤルマールの手には大きいほうが残りました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
