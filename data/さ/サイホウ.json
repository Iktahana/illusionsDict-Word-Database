  {
    "uuid": "b6de04d9-b151-5199-a376-436e9dfddf4f",
    "entry": "採訪",
    "reading": {
      "primary": "さいほう",
      "alternatives": [
        "さいぼう"
      ],
      "is_heteronym": false
    },
    "grammar": {
