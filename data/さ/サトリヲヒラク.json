    "definitions": [
      {
        "index": 1,
        "gloss": "to achieve enlightenment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
