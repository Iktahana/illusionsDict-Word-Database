        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "マラソンで彼は中盤から一気にスパートをかけ、他の選手に差をつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新商品の開発では、他社との差別化を図り、明確な差をつける必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テストで良い点数を取るには、基礎問題を確実に解いて周りと差をつけることが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これまでひとにあんな――もぐさをつけることなどひどく、原始的野蛮的でいやと思ったが、やって見ると、一緒の快さあり。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to distinguish (between)",
        "register": "standard",
        "nuance": null,
