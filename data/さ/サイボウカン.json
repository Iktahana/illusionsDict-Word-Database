        "examples": {
          "standard": [
            {
              "text": "細胞間コミュニケーションは、多細胞生物の生命活動に不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "細胞間物質が不足すると、組織の結合が弱まる可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの薬、細胞間の情報をスムーズにする効果があるらしいよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "でつまりクリティシズムなるものは、諸文化内部に於ける一切の細胞間の、広義に於ける翻訳のようなものと考えられていいわけである。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この孔は蓮根とその性質が同じことで、やはりこれも細胞間の空隙で気道である（第二図下の左）。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この組織の細胞間物質は液体ではあった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "細胞間物質の生命は細胞の生命とあるていど違うが両者は同じように生きていると我々はみなすようになっている。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
