        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雀のお宿笹藪、小藪、小藪のなかで、ちゆうちゆうぱたぱた、雀の機織。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹽山といふ山は家の後ろで無論見える筈がないが、左りは笹子峠の山脈も薄らいで、宿の裏庭に近い笹藪ばかりが黒い。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "正勝は陽にきらきらと輝きながら散る紅や黄の落ち葉を浴びながら、綱を身体に巻きつけたまま熊笹藪の中を歩いた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼はそこの熊笹藪の中に蔦代の死体を隠し、夜の迫るのをじっと待った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西向観音裏山とか笹やぶとか、ざっとでいいから現場付近の様子を教えておいてくれたまえ」「――現場は、高さ三十メートル、周囲三百メートル余りの雑木山で深い笹藪におおわれていて、二すじの小径が通っている。",
              "citation": {
                "source": "探偵会話　下駄を探せ",
                "author": "――芝公園　女の殺人事件――",
                "note": "青空文庫"
              }
            },
            {
              "text": "死体は頂上に近い小径のすぐ傍、十間ほどの笹藪のなかで発見されたんです。",
              "citation": {
                "source": "探偵会話　下駄を探せ",
                "author": "――芝公園　女の殺人事件――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ある男、犯人が、偶然そのへんで知りあった闇の女と連れだって雑木山をさまよい、れいの笹藪のところで交渉を果す。",
              "citation": {
                "source": "探偵会話　下駄を探せ",
                "author": "――芝公園　女の殺人事件――",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹藪のかたわらに、茅葺の家が一軒、古びた大和障子にお料理そば切うどん小川屋と書いてあるのがふと眼にとまった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "其家の向うに笹藪がある。",
              "citation": {
                "source": "正岡子規",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂地が尽きると笹藪が茂つてゐた。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の入口に地藏樣が並んやゐたり、生の椎茸が河ツぷちに干してあつたり、金色に光つた笹藪なぞが多く、下田の町はづれは、汽車が通じてゐないだけに、温く優さしいところで、旅人らしいくつろぎも、こんなところでこそ休めたいなど考へられます。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯ヶ野から湯ヶ島へかけての谷間の樹のしたみちは、顏も手も染まりさうに薄い緑で、笹藪のこんもりしたのなぞは、全く青春を包んだ喪の小屋のやうで、あの中を覗いたら、火花のやうなかげろふが散りさうです。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　笹藪がはげしく音をたてて、ひとしきり、うねった。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹藪が深く茂つてゐて、近い処を見渡すことが出来ない。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "道に溢れて流れてゐる水に口づけて飲んだり、梅干の種を向うの笹藪に投げたりして、出来るだけ長く休む方が楽であつた。",
              "citation": {
                "source": "遍路",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の笹藪の音までよく聞こえる。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹藪に風のあたる音、笹藪の中を犬が歩く音、みんな聞こえる。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それを不思議とするならば、実は、実の笹藪の音をはっきり聞き取るというのが、第一に不思議だった。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "実の笹藪の中の犬の足音など、果して聞き取れるであろうか。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳の方は、夜中に時計の音がいつも一つしか聞こえなくとも、それは錯覚としてもよく、裏の笹藪のかすかな音まで聞こえるとしても、それも錯覚としてもよかった。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にありったけのその塩を、カヨは笊にあけ、黙って、裏の笹藪の方に出て行く。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "道に溢れて流れている水に口づけて飲んだり、梅干の種を向うの笹藪に投げたりして、出来るだけ長く休む方が楽であった。",
              "citation": {
                "source": "遍路",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小径の両側には、人間の背よりも高い笹藪がつづいていて、ところどころに小さな丘があり、そこには八手や五月躑躅が密生していて、隠れん坊にはこの上ない場所だったけれど、まるで谷間に下りたような気持のするところだった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は突然身を躍らせると、柵を越えて笹藪の中に飛びこんだ。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はめずらしく、少しの酒にやや陶然となっていたので、そこから出るとすぐ居合わす俥に乗って、川を東に渡り建仁寺の笹藪の蔭の土塀について裏門のところを曲って、だんだん上りの道を東山の方に挽かれていった。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "野生の萩や撫子の花も、心して歩けば松の茂った木蔭の笹藪の中にも折々見ることができる。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の丈に近い笹藪と雑草の中を、鼬のようにす早くぬけて行くと、ひと曲り曲った峠路の上へひょいと姿を現した、……それは五郎吉馬子であった。",
              "citation": {
                "source": "峠の手毬唄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことをいつまで考えていても際限がないと、お絹は浴衣の襟をつくろってそこを立とうとした時に、縁の下の笹藪がガサと動いて、幽霊のようなものが谷川の中から、煙のように舞い出した。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は一言も物を言う隙さえなく、欄の上から川の岸の笹藪の中へ、何者とも知れないものに抱き込まれてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お約束のようにヒュードロドロと下座がはいると、上手のささやぶがはげしくゆれて、のそりのそりと出てきたものは、岡っ引き長助の扮している朝鮮虎です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
