    "definitions": [
      {
        "index": 1,
        "gloss": "thicket of bamboo grass",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
