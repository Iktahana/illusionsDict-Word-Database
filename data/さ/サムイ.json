    "definitions": [
      {
        "index": 1,
        "gloss": "cold (e.g. weather)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私がこの本を初めて知つたのは大正十四年の暮であつたかその翌年の初めであつたか、とまれ寒い頃であつた。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく寒い朝だつたよ、三月になつてはゐたが、来る途中、日の当らない所は凍つてゐた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈だし寒いので、火でも起こさうと隣りの部屋を開けると、驚いたことにはそこはもうチヤンと机や本箱が配置されてをり、火鉢には火が起こつてゐて、薬鑵も掛かつてゐる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者不詳　寒い、乾燥した砂混りの風が吹いてゐる。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、心持寒い風が、彼のその帽子を被つてない頭を撫でてゆくのだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "稍々あつて男――もう今では夫、入口より葉巻を銜へ、長きマントの儘、如何にも寒い中を歩いて帰つて来た風である。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒いから、かなはない、と私は、自分の怠惰を、時候のせゐにする。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大正四年の初め頃だつたか終頃であつたか兎も角寒い朝、その年の正月に亡くなつた弟を歌つたのが抑々の最初である。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて始めて両親を離れ、飛び立つ思ひなり、その秋の暮、寒い夜に丸太町橋際の古本屋で「ダダイスト新吉の詩」を読む。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "共に冬の日の薄ら日和を感じさせ、人生への肌寒い侘びを思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち冬の寒い日に、葱などの流れている裏町の小川を表象して、そこに人生の沁々とした侘びを感じているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河豚汁の宿赤々と灯しけり　と、冬の街路に炉辺の燈灯を恋うる蕪村は、裏街を流れる下水を見て易水に根深流るる寒さかな　と、沁々として人生のうら寒いノスタルジアを思うのだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る寒い年の暮に、彼はとうとうその生れた故郷に帰って来た。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの春のまだ寒いころであった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時津から早岐まで、哀れげな小蒸気船に乗っての大村湾縦走はただうすら寒い佗しい物憂さの単調なる連続としてしか記憶に残っていない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い暗い都会霧の中に夢のワルハラのごとく光の宮を浮上がらせる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欅の並木をつつむ真昼の寒い霧。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の日かげはまだ霜柱に閉じられて、隣の栗の木のこずえには灰色の寒い風が揺れているのに南の沖のかなたからはもう桃色の春の雲がこっそり頭を出してのぞいているのであった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは薄曇りの風の弱い冬日であったが、高知市の北から東へかけての一面の稲田は短い刈株を残したままに干上がって、しかもまだ御形も芽を出さず、落寞として霜枯れた冬田の上にはうすら寒い微風が少しの弛張もなく流れていた。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板はどうも風が寒い。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくうすら寒い時候に可愛らしい筍をにょきにょきと簇生させる。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふだけぢやなく、あしたもあさつても寒いにきまつてゐます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と子供を叱るやうな口調で言ひ、「そんな工合ひに家の中で、じつと爐傍に坐つてゐる人と、井戸端へ出て洗濯してゐる人と、どつちが寒いか知つてゐますか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが喫煙おまへのその、白い二本の脛が、　　夕暮、港の町の寒い夕暮、によきによきと、ペエヴの上を歩むのだ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、み空はたかく、吹く風はこまやかに　　――祈るよりほか、わたくしに、すべはなかつた……寒い夜の自我像きらびやかでもないけれどこの一本の手綱をはなさずこの陰暗の地域を過ぎる！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "目が覚めて、宿酔の厭ふべき頭の中で、戸の外の、寒い朝らしい気配を感じながら私はおまへのやさしさを思ひ、また毒づいた人を思ひ出す。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　酔生私の青春も過ぎた、――この寒い明け方の鶏鳴よ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま茲に傷つきはてて、――この寒い明け方の鶏鳴よ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒いので仲間が、入れ代りに眼をさます。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士山中で、大宮口の森林として、もっとも名高いモミ、ツガ、ナラ、モミジ、ブナなどの、夏なお寒い喬木帯を通過する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
