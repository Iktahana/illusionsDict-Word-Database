[
  {
    "uuid": "1db5666a-bb7e-5580-b11b-bc5f326d20f4",
    "entry": "災難",
    "reading": {
      "primary": "さいなん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
