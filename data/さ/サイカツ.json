        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "再活用してほかふ、熟語となつて、こと（言）ほぐと言うたりするほぐの方が、ほむよりは、原義を多く留めて居た。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　奉仕の本縁を説く寿詞ほくはほかふとも再活し、語尾が替つてほむともなつて居る。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "此言寿に伴ふ副演の所作が発達して来た為、ほく事をすると言ふ意の再活用ほかふと言ふ語が出来た。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほぐが語根化して再活用すると、ほがふとなる。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたるの再活用かたらふの用語例が、その暗示を与へて居ると思ふ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "触るは、ふらふ・ふらはふなど再活用を重ねる。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころがる意の動詞コユが再活して、伏しまろぶ意にコヤルと言つている。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この端艇はどこから持って来たか分りませんが、極めて小さいかつすこぶる危しいものです。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
