        "examples": {
          "standard": [
            {
              "text": "資格試験の勉強のために、新しい参考本を数冊購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は授業で配られた参考本を片手に、熱心にノートを取っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この参考本、古くて情報が古いかもしれないな。」と彼はつぶやいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "後記この合戦記を作るに際して、　『余呉床合戦覚書』及び『別本余呉床合戦覚書』上下を主たる参考本とし、諸本によっては人名の多少異るものがあるが今は総てこの覚書に従った。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレディ主筆が素早くリチャード・シスキー博士著の参考本を調べてみた限り、わずか二社のロンドン給水会社だけが、テムズから取水してない。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
