    "definitions": [
      {
        "index": 1,
        "gloss": "(weep) quietly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は芭蕉よりもなお悲しく、夜半に独り起きてさめざめと歔欷するような詩人であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫は言い終ってさめざめと泣きました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそこの川へ身を投げて死にとうございます」　またさめざめと泣き続けます。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〕そして青い橄※の森が見えない天の川の向ふにさめざめと光りながらだんだんうしろの方へ行ってしまひそこから流れて来るあやしい楽器の音ももう汽車のひゞきや風の音にすり耗らされて〔〕ずうっとかすかになりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして青い橄欖の森が見えない天の川の向うにさめざめと光りながらだんだんうしろの方へ行ってしまいそこから流れて来るあやしい楽器の音ももう汽車のひびきや風の音にすり耗らされてずうっとかすかになりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものはいわでさめざめとぞ泣きたまえる、おん情手にこもりて抱かれたるわが胸絞らるるようなりき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして青い橄欖の森が、見えない天の川の向こうにさめざめと光りながらだんだんうしろの方へ行ってしまい、そこから流れて来るあやしい楽器の音も、もう汽車のひびきや風の音にすりへらされてずうっとかすかになりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして青い橄欖の森が、見えない天の川の向うにさめざめと光りながらだんだんうしろの方へ行つてしまひ、そこから流れて來るあやしい樂器の音も、もう汽車のひびきや風の音にすり耗らされてずうつとかすかになりました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さめざめと泣き出す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小春は花のいきするように、ただ教授の背後から、帯に縋って、さめざめと泣いていた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さめざめと泣いて、あつい涙をたくさん流しました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣の両袖で顔を蔽うてさめざめと泣いた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のほつそりした頸すぢお前のながくのばした髮の毛ねえ　やさしい戀びとよ私のみじめな運命をさすつておくれ私はかなしむ私は眺めるそこに苦しげなるひとつの感情病みてひろがる風景の憂鬱をああ　さめざめたる部屋の隅から　つかれて床をさまよふ蠅の幽靈ぶむ　ぶむ　ぶむ　ぶむ　ぶむ　ぶむ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして眼を覚ました僕の枕元に座って、さめざめと泣くのです。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、「うっかりすると、すぐ身体が腑が抜けたようになるんですもの――」　わたくしは逸作に護られているのを知ると始めて安心して、歿くなった父に対する涙をさめざめと流すことが出来た。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものはいはでさめざめとぞ泣きたまへる、おん情手にこもりて抱かれたるわが胸｜絞らるるやうなりき。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――消さないかい――　――堪忍して――　是非と言えば、さめざめと、名の白露が姿を散らして消えるばかりに泣きますが。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言ってお京さんはさめざめと泣いた。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙というものは何とよく出るものかと不思議なほど、お君はさめざめと泣き、夫婦はこれでなくては値打がないと、ひとびとはその泣きぶりに見とれた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十四年三月　　あそびめたはれをのかずのまにまにじだらくにみをもちくづし、おしろいのあをきひたひにねそべりてひるもさけのみ、さめざめとときになみだし、ゆふかけてさやぎいづとも、かなしみはいよよおろかに、ながねがひいよよつめたし。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の出しほの片あかり、薄き足もつびいどろの、肩に光れどさめざめと、歎き恐れて、夜も寝ねず。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、筆を借りてそこの壁に詩を題し、終ると傍にいる二人の小供を抱き締めるようにしてさめざめと泣いていたが、やがて孫恪の方を向いて、「これから永のお別れをします」　と言って、着ていた着物を引裂いて投げ出したのを見ると、赭顔円目の一大老猿であった。",
              "citation": {
                "source": "碧玉の環飾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分長い間経って二人が我に返った時、リメイは（エビルを負かす程の強い女だったにも拘わらず）さめざめと泣きながら、彼が来なくなってからの久しい間に、如何に操を立てるのが苦しかったかを、かき口説いた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙というものは何とよく出るものかと不思議なほど、お君はさめざめと泣き、夫婦はこれでなくては値打がないと、ひとびとはその泣き振りに見とれた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と朝顔の笠を両袖で――外套は宿へ忘れて来た――袖でひしと抱いて、桜を誘う雨ながら、ざっと一しきり降り来る中に、怪しき巨人に襲わるる、森の恐怖にふるえつつも、さめざめと涙を流した、石燈籠が泣くように。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とお杉はこれをいって今もさめざめと泣くのである。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も先刻と同じやうな姿で、同じやうにさめざめと涙をこぼして居るじやありませんか！",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏に眼玉をやつてしまつた魚は、盲目になつてしまつたので、そのなつかしい波の音を聴くばかりで、青い水も白い帆前船もながめ見ることが出来ませんでした、そして海風のかんばしい匂ひにまぢつた海草の香などを嗅ぐと、秋刀魚はたまらなくなつて、この青草の丘の上でさめざめと泣き悲しみました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　かう言つて、その星のやうなものは釣りあげられた船の板子の上で、身を悶えてころがりながら、さめざめと泣きました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
