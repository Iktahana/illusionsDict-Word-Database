    "definitions": [
      {
        "index": 1,
        "gloss": "to insert",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（阿難、娘の眼の中へ自分の瞳を差し込むばかり強く視詰める。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菰を厚く巻いてやるプールの中へ、差し込む薄日に短い鰭と尾を忙しく動かすと薄墨の肌からあたたかい金爛の光が眼を射て、不恰好なほどにも丸く肥えて愛くるしい魚の胴が遅々として進む。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南向きの窓硝子に近い衝立の蔭のテーブルに席をとって、斜めに差し込む日の光に朝の顔を眩しくしていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い光がかっと差し込む。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏至の日に天井の穴から日が差し込むという事だけはよくわかった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の閂をはずそうとしても、ナイフの刃を差し込む隙間がない。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の硝子障子から差し込む雪明りで、微かではあるが、薄暗い廊下に慣れた目には、何もかも輪郭だけはっきり知れる。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは、直ぐ横の小山の向うから、斜めに差し込む航空燈台の閃光です。",
              "citation": {
                "source": "白妖",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意に差し込むやうな痛みが來た。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが出來ましたら、細い方の麥藁を太い麥藁の裂けたところへ差し込むやうになさい。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時ごろからしばらくの間｜斜に差し込む西日の影は、かなり暑かった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌にいらいらする昨夕の酒に、顔の皮膚がまだ厚ぽったく熱っていて、縁側に差し込む朝日が目に沁みるようであった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その深い感動に圧せられたようにうなだれている姿も、遠くから差し込む日光を斜に照り返している背後の灰色の壁もすべてが、異様な緊張の前に息をつめ、見えない眼をみはっているように感じられる。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーラーブは、明りの差し込む窓の下で侍者と一緒に、ぼんやり湯の沸くのを待っていた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折角日曜だっていうのに、これじゃあ外へ出ることも出来やしない」　穢い硝子、穢い建物に、バッと日が明るく差し込むだけ余計塵っぽく、悩ましい。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程、気がつかなかったら家は西向で、午後になると、日が、真正面から座敷一杯に差し込むのである。",
              "citation": {
                "source": "小さき家の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "草木の緑や、男女の衣服の赤や、紫や、黄のかすんだような色が、丁度窓から差し込む夕日を受けて眩ゆくない、心持の好い調子に見えていた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "基板の裏に突き出た集積回路を差し込むソケットの足の一本一本に配線をぐるぐる巻いていく、ラッピングと呼ばれる手間のかかる組み立て方法では、さすがに後藤自身、二台組み立てる以上の根気は続かなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＩＴＳはスロットに差し込むことで、四Ｋ（四〇九六）バイトのメモリーを追加できる増設ボードの発売を予告していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本体内には拡張ボードを差し込むための増設スロットが五つ用意されており、オプションにまわされた容量一六〇Ｋバイトの五インチドライブを二台組み込むスペースが空いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこれも、ＰＣサブグループからの注文を受け入れ、拡張スロットに差し込むオプションのボードとして、インターフェイスを用意しておくことになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが最後の最後まで手直しが続くことを予測して、新一六ビット機は六つ用意した増設スロットの一つにＲＯＭを持たせたボードを差し込むという、きわめて変則的な構成を採用した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本体のカバーをあけて、むき出しの基板を注意して差し込むような構造をとっていることは、家庭への普及の妨げになると松本たちは考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためディスクベーシックで書いたアプリケーションをドライブに差し込むと、拡張部分からディスクベーシックが起動されたあとにアプリケーションが自動的に読み込まれ、ユーザーはいきなり仕事を始めることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★ＭＢＣ―２５０のメインの基板は増設スロットとこれをつなぐバスだけで構成されており、すべての機能をスロットに差し込むボードによって提供することで自由なハードウエアの構成と拡張が可能となるよう配慮されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "増設スロットに差し込むマウス接続用のボードとＭＳ―ＤＯＳに組み込むドライバーソフト、そしてマウス本体を、笹渕は担当者に頼み込んで日本に持ち帰った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★マイクロコンピューターには五Ｍヘルツの８０８８を使い、三・五インチのドライブを採用したジュニアをベースにしたＪＸは、ＲＯＭのカートリッジを差し込むスロットを二つ用意している点でも本家と同様の構成をとっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢代はその喜ぶ父の心情を想像すると、今こうしてここで男爵と自分の並んでいることが、すでに孝行をしていることになっているのだと気がついて、思わぬ明るい気持ちの差し込むのを覚え久しぶり若若しい青年に立ち還って来るのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子は、案外冷たい表情でゐる杉夫を盗み見て、心のなかに噴きあげるやうな侮辱を感じてゐたが、自分が伊庭の家を出る事によつて、伊庭の心のなかに、太い釘を差し込むやうな、気味のいゝものも感じた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "井村は、飴ン棒のようなハッパを横にくわえ、ミチビを雷管にさしこむと、それをくわえているハッパにさしこんだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
