    "definitions": [
      {
        "index": 1,
        "gloss": "moon over a mountain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
