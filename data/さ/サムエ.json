          "literary": [
            {
              "text": "皆は思い思いの作務衣を着て、裏山へ分け入った。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲水たちの顔が変っているように、銘々の作務衣も変っていた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "半町ばかり後からついて行くうちに、彼は老僧の着ている作務衣に気がついた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "老僧の作務衣は、その男が在俗の時に着た黒紋付の羽織らしかった。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
