[
  {
    "uuid": "f600bcf1-bc10-549d-93b2-d17712d3cdf1",
    "entry": "定まる",
    "reading": {
      "primary": "さだまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
