    },
    "definitions": [
      {
        "index": 1,
        "gloss": "three highest ranks (wrestling, unions, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "九蔵の師直、由良之助、勘平の三役が評判となる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人三役くらいで対話の朗読など、いまの僕の力では危かしいし、一人で長い台詞を言う場面は、一つの戯曲にせいぜい二つか三つ、いや何も無い事さえあって、意外にも少いものなのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の時菊五郎はお岩と田宮の若党小平、及び塩谷浪人｜佐藤与茂七の三役を勤めたが、お岩と小平の幽霊は陰惨を極めたもので、当時の人気に投じて七月の中旬から九月まで上演を続けた。",
              "citation": {
                "source": "幽霊の衣裳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸幕府の制度が整備したのは、三代の家光の時代で、その職制は、幕府の重職に大老、老中、若年寄の三役があり、その下に三奉行がある。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "新画番付では三役どころの画工だそうにござります」「すると、相当な値ごろのものじゃな」「へえい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、座頭の俳優が実際においては一役か二役しか勤めていない場合でも、ほかに二役か三役かの役割が附け加えられてあるが、それはでたらめにこしらえた嘘の役割である。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを救うがために、捨役という有名無実のものを作り設けて、一人がいつでも三役か四役かを勤めるように見せかけたのが始まりである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この狂言では、団十郎が清正と太閤と船頭与次兵衛の三役を勤めて、殆んど休みなしに登場していたのである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は一番目に据えられた五幕つづきの大作で、左団次は源三位頼政と長谷部信連と出羽判官光長の三役をつとめたが、そのなかでも信連の大立廻りが最も好評であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "栃木山はその後｜鰻上りに三役に入つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺もお蔭で三役に入つたよ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜村屋菊之丞といふ女形が、木挽町で菅原を演つたとき、覚寿と梅王と千代との三役を勤めた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "横綱や大関は別として、三役や前頭のいいところに坐るには、何も格別｜画が上手でなくともいい、発行人に幾らか出版費の足し前を出すとか、それとも絵の二三｜幅も寄附すればいいので、さうした訳合でかなりの地位に据わつてゐる雛つ児画家も少くはない。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "報告を受けた石井は、府中事業場に集められている情報処理の技術スタッフのうち主任以上の全員に召集をかけ、組合の三役にも出席を求めてこの一件を告げた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターとしての機能に加え、日本語ワードプロセッサーと大型の端末としても利用できる一台三役を謳い文句に、オフィス用の高価格マシンとして５５５０を軌道に乗せた日本ＩＢＭは、次に狙いを定めた家庭市場では一転してＰＣシリーズとの互換路線を選んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、奸妻に悩まされ、病肺に苦しまされ、作者と俳優と劇場監督と三役の繁務に追はれながら、しかも猶この嘲魔の毒手に、陥らなかつたモリエエルは、愈羨望に価すべき比類の少い幸福者である。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく結果だけを見たら、それが、あのまたとない一人三役――ねえ夫人、貴女はたぶん、それを御存知ないのでしょうね」「いいえ、その病だけは、いかにも真実でも、……現在のテオバルトは違いますわ。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、当然裏向きお岩の疑問が起ってきて、幸いだんまりの場面の暗さを機に、あれが誰かの一人三役ではないかとの疑いも起ってくるのだった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三役の中、団七・権太においては、相当彼を第一と認めぬ人々があるに違ひない。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其早替り三役の中で最努力して、人の感動を誘はうとしたのは、愚直な下男の役であつた。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中五段目の三役、七段目の平右衛門・大星、九段目の戸無瀬・大星が、早替りに部類するもので、性格の変化に興味があると言ふほどのものではない。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その聖職者は、人間であると同時にまた神であり、悪魔であるという一人三役を演じることになる。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ中入前で、久須美は何も知らずサジキに坐って三役の好取組を待っているのだが、私は急に心がきまると、久須美のことはほとんど心にかからず、ただタドンのいじらしさ、人間侮蔑に胸がせまって、好取組の見物などという久須美が憎いような気持まで流れた。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ眼でみるせゐか、横光利一の名は、雑誌などの宣伝目次では絶えず、番附の横綱三役然たる趣きで活字になり、人々はまた、彼の作品と放言とを、息をこらしながら、読み、聴き、そして喝采し、ある者は首をひねつた。",
              "citation": {
                "source": "横光君の印象",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "六尺三十貫、頭もあるし、順調に行けば、横綱、大関はとにかくとして、三役まではとれた男だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲連の土俵の上の取組みは、商売だから見ていても壮快を感ずるが、この真剣な暴力沙汰、それが力商売の者――しかも、幕内から三役以上と見えるやからが一団となって、うなりを成して飛ぶ本物の肉弾、今までに見たことのない光景、殺気満々たるすさまじさ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今囘リューバは三役三様に髪をととのえてやらねばならん。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉左衛門の家は代々本陣庄屋問屋の三役を兼ねたから、そのたびに庄屋として、背伐りの厳禁を犯した村民のため言い開きをしなければならなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、青山の家では帰農して、代々本陣、庄屋、問屋の三役を兼ねるようになったのも、当時の戦功によるものであるという。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿平次を見るたびに半蔵の感ずることは、よくその若さで本陣｜庄屋問屋三役の事務を処理して行くことであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
