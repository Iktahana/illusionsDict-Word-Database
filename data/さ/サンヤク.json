[
  {
    "uuid": "f8bd9570-4f52-5e04-8994-2f2f149641a8",
    "entry": "三役",
    "reading": {
      "primary": "さんやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
