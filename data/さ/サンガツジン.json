          "literary": [
            {
              "text": "わたくしは此に「三月尽」の一絶を抄する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十年三月尽日堂島河畔の旅舎にて甲賀三郎",
              "citation": {
                "source": "「黒死館殺人事件」序",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども僕の眼識は欲目のために鈍つてゐて、赤彦君は三月尽を待たずに歿し、短歌の製作も『犬の歌』以後は絶えたのであつた。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……人事に属する季のもの二月、三月尽、夜半の春。",
              "citation": {
                "source": "俳句とはどんなものか",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして三月尽の日記は曰く、「鶯の初音をきく。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
