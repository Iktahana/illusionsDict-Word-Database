          "literary": [
            {
              "text": "ヒポクラテスは産科学についてかなり多く記載し理論の多くは今日では不条理であるが、彼が推奨した処理は有効である。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "産科学についての記述は、産科学が彼の時代には良く理解されていたことを示している。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "産科学は助産婦の手にある。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "産科学手技のうちで死後の帝王切開および胎児切断が行われた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "産科学はほとんどまったく産婆さんの領域であった。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "解剖学および生理学の知識の欠如は産科学ではっきりと見ることができ、産科学で多くの場合に実際の方法や手技を知っているのではなく、主として予想や誤った考えに基いて行われた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "産科学は18世紀に中国と独立に発達した。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "18世紀の中頃に産科学は賀川｜玄悦（1700-1777）によって大きな刺激を受けた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし最も激しい反対者は同僚の産科学教授たちであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後には４年後にブダペスト大学の産科学の正教授となった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
