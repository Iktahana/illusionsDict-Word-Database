    "definitions": [
      {
        "index": 1,
        "gloss": "attendance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四　ある家の告別式に参列して親類の列に伍して棺の片側に居並んでいた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表彰式に彼の母も参列したが、人々は「我 Senior Wrangler の姉君」のために万歳を三唱」した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "キングは名代を遣わして参列させ、その他ケンブリッジ大学や王立協会の主要な人々も会葬し、荘園の労働者は寺の門前に整列した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐屋の葬儀には彼も父の黄村とともに参列した。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、参列をはねつけられて、蝶子はどんなにそれを悲しんだことか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、おやじの十七回忌の法事に参列するために帰ったので、初めから面白ずくの旅行ではなかったのだが、それにしても面白いことはなかったよ。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉沢も一緒に行こうなどと言っていたのであるが、親戚の老人が死んだので、その二七日や三七日の仏事に参列するために、ここで旅行することはむずかしいと言った。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々、大勢の人々がやって来て告別の焼香をして下すったが、その中に古びたカンカン帽、素足に駒下駄、浴衣がけにステッキ一本の書生さんが、アッサリと焼香し、叮嚀に叩頭して行ったのを、参列の人々の中で喜んでいる人が相当あった。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅津只圓翁銅像除幕式　（福岡日日新聞抜萃）　福岡黒田藩喜多流の先覚者梅津只圓翁の銅像除幕式は十四日（昭和九年十月）午前十一時より福岡市中庄只圓翁旧宅庭前に於て、翁の直孫牟田口利彦氏を始め武谷軍医官、梅津正利師範、旧門弟宇佐元緒、古賀得四郎氏以下多数参列の下に盛大に挙行せられた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴田等にも参列を勧めたが、やって来るわけもない。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が秀吉は、「それこそ、こちらから願い度き物であるが、某一人に限らず、丹羽、池田、森、佐々等にも廻状を遣り、来春一同参列の上、取替したがよいであろう。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、山田三造は追悼会に参列したところで、もうとうに歿くなったと云うことを聞いていた旧友にひょっくり逢った。",
              "citation": {
                "source": "雨夜続志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は御親類たちに合わせる顔も無いと云って、久兵衛が葬式の日にも、初七日の墓参の日にも、自分から遠慮して参列しなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸仏開帳の例として、開帳中は数十人の僧侶が、日々参列して読経鉦鼓を勤めなければならない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "万隆寺の僧も今度の開帳に日々参列していたが、教重もその一人で、破戒僧の彼は奉納の兜に眼を着けたのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んだ事をしたと悔んだが、今さら引っ返すわけにも行かないので、彼は素知らぬ顔をして朝飯を食って、ほかの役僧らと共に長谷寺へ参列した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは去年の秋、軍港街に移ると間もなく「鈴谷」進水式拝観の光栄に浴し、続いて駆逐艦「しぐれ」特務艦「剣崎」の進水式に参列の栄を得て、ひたすら胸を躍らせ、行状の謹慎を保つた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "参列の諸員は皆小さい大宮人の美に感激の涙をこぼしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "長奉送使、その他官庁から参列させる高官も勢名のある人たちばかりを選んであった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "参列していた人々も同情の禁ぜられない中宮のお立場と、この寂しい結末の場を拝して泣く者が多かった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "参列者の多く集まって来ることは昔のそうした場合のとおりであった。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑雨の竹馬の友たる上田博士も緑雨の第一の知己なる坪内博士も参列し、緑雨の最も莫逆を許した幸田露伴が最も悲痛なる祭文を読んだ。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣の葬式に参列するのだと言って、おおぜい鉄砲をかついで出た。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "美智子さんの葬式にもぜひ参列したいと思ったのだが、みんなに止められて拠んどころなく見合せたので、きょうは思い切って墓参りに出て来たのだ。",
              "citation": {
                "source": "海亀",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、実力に於て首相格である大熊老人の葬儀のことであるから、上はＡ総理大臣をはじめとし、閣僚全部を筆頭に、朝野の名士という名士、その数無慮五百名、それに加えて、故人の徳を慕う民衆の参列者が一万人に近いという話であった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外に居た参列者だけは、重症を負いながらも、一命はとりとめたようである。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "法会は中途で急に終わって、参列の諸人が一度に退散するために、先払いの雑色どもが門前の群集を追い立てるのであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿闍梨はなにを見て俄に取り乱したのか、おそらく参列の人びとのうちにかの玉藻の妖艶な姿を見いだして、その道心が怪しく乱れ始めたのであろう。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その式はなるべく壮厳を旨として、堂上堂下の者どもすべて参列せよとのことであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
