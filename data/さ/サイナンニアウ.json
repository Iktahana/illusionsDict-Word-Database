        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行中に財布をなくし、災難に遭ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は不運にも交通事故で災難に遭った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誰もが災難に遭う可能性はあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どこへ行ったって災難に遭うのだとすれば、ここを災難の場所として選んでもいいではないか」と考えるのだ。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "出るとかならず災難に遭うというのだ。",
              "citation": {
                "source": "海亀",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々がこれ以上の災難に遭うことなく外部世界に帰ることができたのは皆さんご存知の通りである。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
