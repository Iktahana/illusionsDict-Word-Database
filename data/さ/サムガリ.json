    "definitions": [
      {
        "index": 1,
        "gloss": "being sensitive to the cold",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうなれば自身の寒がりのカメラもしばらく冬眠期に入って来年の春の若芽のもえ立つころを待つことになるであろう。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は毎夜露き出しの夜会服の背中を寒がりながら、シーズンの演劇を見て廻つた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はデンマークへ寒がりに来たみたいだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のはうづに大きな犬なので、前足を突張つて立つたから、脊は小ぽけな、いぢけた、寒がりの、ぼろツ兒より高いので、いゝ氣になつて、垢染みた襟の處を赤い舌の長いので、ぺろりとなめて、分つたやうな、心得てゐるやうな顏で、澄した風で、も一つやつた。",
              "citation": {
                "source": "迷子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ともハヤ心細い、タヨリにならぬ空頼みをアテにして、足に任せて行くうちに、何しろ十二月も三十日か三十一日という押詰まっての事で、ピューピュー風に吹かれた大病人上りの大惣が寒がります。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒がりのヘルンは西田さんに授業中、寒さに困る事を話しますと、それならば外套を着たままで、授業をなさいとの事でした。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "原型の方が寒がりでせう。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして歩いていれば、「あいつは寒がりだな」と思われるぐらいで、とがめられることはなさそうであった。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさんが寒がります。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみつ　皆さんは隨分寒がりなんですね。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三の女　それにねえ、私は人様より倍も倍ももの寒がりなんでございますもの。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なか／＼冷える、奥は雪だらう、寒がりの私は土鼠のやうに火燵にもぐりこんでゐる（抱壺君はベツドで頭だけ出して蓑虫みたいださうな）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆつくり朝寝した、冬らしい寒さだ、これしきの寒さでも寒がり老人にはこたえるのだから情ない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "物価騰貴、木炭の値上りは寒がりの私にはたこへる、白米が一升につき一銭あがつて、三十二銭（私はいまだ米を高いと思つたことはない）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたゝかすぎるほどあたゝかい、炭をなくした寒がりには何よりのうれしさである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒くなつた、あたりまへの寒さだが、寒がりの私は、炭もなくしたから、寝床にちゞこまつてゐる外ない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒がりの叔母は、炬燵のある四畳半に入り込んで、三味線を弄りながら、低い声で端唄を口吟んでいたが、お庄の姿を見るとじきに罷めた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月からこっち、体の工合が良くない続きなので、余計寒がりに、「かんしゃく持」になった。",
              "citation": {
                "source": "秋風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "△北朗の朝寝坊と寒がりとには、放哉あきれながら成る程／＼と思へり、それは、女房を持つてる奴は贅沢だなあ……と云ふこと。",
              "citation": {
                "source": "北朗来庵",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ零度以下四十度なんと云ふこともあるのですから、私のやうな寒がりにはたまりません。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "常子は昨夜寝る前に『あなたはほんとうに寒がりね。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……寒がりのコッペ先生は早や鳶合羽の様な外套を着てござる。",
              "citation": {
                "source": "フランソア・コッペ訪問記",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "顫へながら飛び込んだ客は寒がりである。",
              "citation": {
                "source": "京に着ける夕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒がりの内蔵助は、上の間の行灯の影に、火桶を前にして、一人物案じ顔に坐っていた。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さん便所に立つときに、隣りの布団をみて（ゆかりの奴、寒がりだから頭から布団をかぶって寝てやがる）と思った。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ安火を入れるのだけは、「あの人は寒がり性だから、朝寝起きに安火を入れてあげておくれ。",
              "citation": {
                "source": "別れたる妻に送る手紙",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "」寒がりのＫ君はうちの中でも頸巻をしたままで、小屋から出て来ようともせずに僕たちを促した。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、人のことよりか、君も寒がりのくせに、こんなところでよく我慢しているね。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒がりの吉左衛門ですら、その日は炬燵や火鉢でなしに、煙草盆の火だけで済ませるくらいだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
