[
  {
    "uuid": "5027d329-9e9e-57db-a91a-5feb8c8bef11",
    "entry": "差し詰め",
    "reading": {
      "primary": "さしずめ",
      "alternatives": [
        "さしづめ"
      ],
      "is_heteronym": false
