        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はとつさのうちに了解した。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつさのうちに百姓の片脚をがぶと噛んだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はとっさのうちに了解した。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさのうちに百姓の片脚をがぶと噛んだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そらでも、つちでも、くさのうえでもいちめんいちめん、ももいろの火がもえている。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいの子供をかかえて家内じゅうの世話をやく心せわしいさびしさのうちに年が暮れて正月になった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "働けるだけ働いて、寝たいだけ寝た後の気分は、安らかさのうちに一味の空しさを含んでいる。",
              "citation": {
                "source": "白い路",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "村には静けさのうちに、何となく日暮の物音と、慌しいけはひがこもつてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさのうちに、ぴたりと適切な言葉を選ぶ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京者ではない、と私はとっさのうちに断定した。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とっさのうちに了解した。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、くにゃくにゃと、どやしつけてやりたいほど不潔な、醜女の媚態を以て立ち上り、とっさのうちに考えた。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつまらない単調子さのうちにどことなく騒々しいような、淋しいような――面白いような、自烈度いような気がする。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は絶えず肩から桶のお湯を流し、あまりに露骨にこの明るさのうちに解放されたる肉體を見て戰慄いた。",
              "citation": {
                "source": "三十三の死",
                "author": "素木しづ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居の作用とは、どういう意味か解しかねるが、僕のような若輩から教えられた事をそのまま言うのは、沽券にかかわると思って、とっさのうちに芝居の作用という珍奇な言葉を案出して叫んだのではないかと思われる。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男らしさのうちに女らしさがあり、凜々しさのうちに狡滑らしさがあった。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "与次郎の言いぐさのうちで、自分がまだ考えていなかった部分だけがはっきり頭へ映っている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この静かさのうちに、美禰子がいる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "にもかかわらず第二の美禰子は、この静かさのうちに、次第と第一に近づいてくる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さのうちは老予言者ででもあるように、寂しい姿をして、節くれだった裸の枝で意味ありそうに北極星の彼方を指さしていた公孫樹までが、齢にも不似合な若やぎようで、指さきという指さきをすっかり薄緑に染めておめかしをしている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はたゞひとりで、五體に行き亙つて行く情緒の快さのうちに、その心の手綱を暫し切り放したのであつた。",
              "citation": {
                "source": "醉ひたる商人",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南上總の海は、靜さのうちに徐々として黒みを加へつつあつた。",
              "citation": {
                "source": "夜の浪",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安井と態と眞面目な顏をしながら、『さうさのう、八時から九時までの間頃だ。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝利と侮蔑と嘲笑と憎惡との錯雜にゆがんだ表情は、復讐の快さのうちにふしぎな統一を見出してゐる。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助は暗さと涼しさのうちに始めて蘇生つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の美しさは、昔秀吉が恋着した母の美しさを匂うばかりの若さのうちに髣髴させた。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "淋しさのうちに華やぎが底流れているとでもいおうか。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、故国にとりのこされている無数の妻や母たちに、女のあたしたちも行くところ、と侵略の容易さや、いつわられた雄々しさのうらづけをするためであったろうか。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまことに尤もなのだし、本人として外側から及ぼすどんな力も願ってはいなかったのだけれども、それでも先生の聰明な如才なさのうちに閃くように自身の未来を空白として感じとることは苦しかった。",
              "citation": {
                "source": "時代と人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
