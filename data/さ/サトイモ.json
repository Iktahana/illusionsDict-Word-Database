        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先ず裏の畑の茄子｜冬瓜小豆人参里芋を始め、井戸脇の葡萄塀の上の棗、隣から貰うた梨。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦和の停車場からすぐに町外れへ出て甘藷や里芋やいろいろの畑の中をぶら／＼歩いた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦和の停車場からすぐに町はずれへ出て甘藷や里芋やいろいろの畑の中をぶらぶら歩いた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穀倉の前の日向に莚を敷いて、里芋の皮をむいて居る下女の方へかやを連れながら婆やは行った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間に里芋が畑の黒土ごと投り出されてあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその日、すぐに庭から六畳の縁側のほうへまわってみたのであるが、青扇は猿股ひとつで縁側にあぐらをかいていて、大きい茶碗を股のなかにいれ、それを里芋に似た短い棒でもって懸命にかきまわしていたのだ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といつて、煮えた里芋か蒟蒻の一片を、子供達にくれることがあるのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜煮は中位な四角の餅の燒いたのを大根、里芋、小松菜を浮かべたすまし汁のなかへ浸したものである。",
              "citation": {
                "source": "雜煮",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいに洗った里芋の新芋が八分目ばかり盛ってあった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "里芋が煮え、茶が沸いた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆は里芋を皿へ盛って仏壇の前へ往き、それをさっきの餅と並べて供え、その並びの棚から油壺を執って、瓦盃に注ぎ、それから火打石でこつこつと火を出して灯明をあげ、それがすむと前に坐って念仏をはじめた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆は餅も喫ってみたければ、初物の里芋も喫ってみたかった。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は牛蒡、人参、里芋畑、爽かな野菜がぷんぷん、地から畝から真つ青だ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜻蛉がからんだ、螽※がセ、栗鼠が駈け出す、鳶がセ、お薯もころげ出せ、馬鈴薯、里芋、つくね芋。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "里芋の子のような肌合をしていたが、形はそれよりはもっと細長くとがっている。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなことをいったってちょっとした出来心だか何んだか知れやしない」こう考えてお汁の実に里芋をこしらえてる。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兼が氣を利かせて里芋の煮たのと味附海苔とを棚から探し出して呉れる。",
              "citation": {
                "source": "姉妹",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根、桜島、蕪菜、朝鮮芋（さつま芋）、荒苧（里芋）、豌豆、唐豆（そら豆）、あずき、ささげ、大豆、なた豆、何でもあった。",
              "citation": {
                "source": "私の父",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　里芋は着物を剥がれて、素っ裸のまま、台所の片隅に顫えている時よりも、親芋と一緒に土から掘り出されるおりの方が、ずっとおどけていて、趣きがあるようだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "土だらけの里芋の皮を削り落そうとするとき、どうかすると指先が痒くてたまらなくなるのは、玉葱や辣薤を手にするときに、眼のうちが急に痛くなるのと同じように、土から生れたものの無言の皮肉である。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは二三日前、一里ほど里に下りて行つたところにあつた山畑からそッと取つて來た里芋であつた。",
              "citation": {
                "source": "歸國",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "里芋と筍の煮付け、汁には、たけたウドが入れられてあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑には里芋の葉が大きくなり、玉蜀黍の広葉がガサガサと風になびいた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "のし餅を三枚、ゴマメを一袋、鮭を五切れ、それに明日の煮染にする里芋を五合ほど風呂敷に包んで、重い重いと言ってやがて帰って来た。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの家でも績殻で杉の葉を編んで、仏壇を飾って、代々の位牌を掃除して、萩の餅やら団子やら新里芋やら玉蜀黍やら梨やらを供えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸ある屋後へ※ると、此處は半反歩許りの野菜畑で、霜枯れて地に伏した里芋の廣葉や、紫の色褪せて莖許りの茄子の、痩せた骸骨を並べてゐる畝や、拔き殘された大根の剛ばつた葉の上に、東雲の光が白々と宿つて居た。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸ある屋後へ廻ると、此処は半反歩許りの野菜畑で、霜枯れて地に伏した里芋の広葉や、紫の色｜褪せて茎許りの茄子の、痩せた骸骨を並べてゐる畝や、抜き残された大根の剛ばんた葉の上に、東雲の光が白々と宿つて居た。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゆんの作つた辨當の菜は、ゆうべの殘りの蒟蒻と里芋の煮しめであつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　開成山の物価　柴＝幹　一束一円二十銭、ジャガいも　一俵十六円、さといも（十二貫）十八、玉子　二十銭、うど一貫三円、俵　百、もち　120. 、とり　一羽十円、手間（男）　四円、勤労奉仕女　二円、男　三円五月二十日（土曜）　午前中歯へゆく、上をかりにうめ、下の金冠をとる。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏から秋には蓮根、小さい玉葱、細いんぎん、さといも、冬ならば大根か小かぶの煮物。",
              "citation": {
                "source": "ともしい日の記念",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
