[
  {
    "uuid": "1f229dee-b10a-55e8-a18f-d63c9311dcd8",
    "entry": "流石に",
    "reading": {
      "primary": "さすがに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
