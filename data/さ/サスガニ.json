    "definitions": [
      {
        "index": 1,
        "gloss": "as one would expect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが流石に、當時僕は彼に自殺の決心があることを氣が付かなかつた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝、思い出して、また泣いたというのは、流石に、この映画一つだけである。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつがねえ」白馬驕不行の碾茶の茶碗は流石にてれくさい故をもってか、とうのむかしに廃止されて、いまは普通のお客と同じに店の青磁の茶碗。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今戸の渡と云う名ばかりは流石に床し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大広間の酔ぱらつて居る家来も流石に王のこの様子に気づいたのか急にヒツソリとなつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その状は、流石に形容を遠慮しますけれど、とにかく酸鼻の極でありました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、流石にラテン語の學名は略してある。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮深い小さな聲で云つて居るのであつたが流石に昨日の大宮の車夫とはちがつて、畫の中の物體を指摘したりしないで「色」を云つたりする處がそれだけ新しい時代の子供であるのかも知れない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前の陽は流石に眩しく美しかった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実家は熱田附近だがそう困る家でもないので、心配はしないようなものの、流石にときどきは子供に学費ぐらいは送ってやらなければならぬ。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内一の財産家といふに、家内は祖母と此子二人、萬の鍵に下腹冷えて留守は見渡しの總長屋、流石に錠前くだくもあらざりき、正太は先へあがりて風入りのよき塲處を見たてゝ、此處へ來ぬかと團扇の氣あつかひ、十三の子供にはませ過ぎてをかし。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その十二）直次は其夜の闇にまぎれて、松川屋敷を出ぬ、明けて驚きし佐助夫婦が、常は兎角に小言もいひけれど、いかに定めて斯かる仕義と流石に胸やすからねば評議とり／″＼に、おそよは朝な／＼手を合する神々にも、心得違ひの無きやうにと祈りぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした小説嫌ひの僕であるが、それでも流石に、興味をもつて讀む作品もある。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　流石に室生犀星が辯解した。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が、Ｔ「愈々明日は敵討で御座んすね」　と云われて、流石に嬉しさ包み切れぬ三四郎です。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光、気強くツンと横向いたが流石に涙ぐんで居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その母も、流石に兄も、私も、そして附添ふ若い一人の看護婦も、高い熱でさらさらに乾いた灰のやうなお前の顏色を見、夢中の口から洩れる呻き聲を聞いた時、お前の上に嚴かに死が迫らうとしてあるやうな豫感に打たれて、堅く口を噤んでしまつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で「ウヰンダアミア夫人の扇」は原作とどうかうと云ふことは別問題として、流石にルビツチの監督したものだけあつて、映畫としても可成り面白く見た。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、流石にその頃とは脚色撮影ともに格段の進歩で、如何に文藝映畫でもこの頃はもうそんなものは無くなつた。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗てボズさんと辨當を食べた事のある、平い岩まで來ると、流石に僕も疲れて了つた。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の權幕があまり激しいので、お道も流石に途方に暮れたらしく、そんなら申しますと泣いて謝つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふみも流石に晝は襲つて來なかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　蔭では尾鰭をつけて色々の噂をするものの、武士と武士との交際では流石に面と向つて幽靈の詮議をする者もなかつたが、その中に唯一人、頗る無遠慮な男があつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、あの……（鬼がと云おうとしたが、流石に自分を鬼とは云えなかった）日本軍が強いのは、正服を着た軍隊に対した時だけだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠井さんも、流石に、もう、いやになった。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの悲しい宿命者も、さすがに日本に渡ってからは、多少の平和と幸福を経験した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆あなたのためです』と、さすがにヘルンも夫人に愚痴をこぼしている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした貞淑の妻にかしずかれて、日本での晩年を平和に暮した詩人ヘルンは、さすがに自らその寂しい幸福を自覚していた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、彼もさすがにてれくさそうにして眼を激しくしばたたかせながら、そうして、おしまいにはほとんど不機嫌になってしまって語って聞かせたこんなふうの手柄話を、あんまり信じる気になれないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに大隅君も心細くなった様子で、おい、この家でモオニングか何か貸してくれないものかね、と怒ったような口調で私に言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
