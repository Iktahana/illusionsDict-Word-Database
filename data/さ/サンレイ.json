[
  {
    "uuid": "adb657f1-ab64-539c-b34d-81e483f62d2d",
    "entry": "山霊",
    "reading": {
      "primary": "さんれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
