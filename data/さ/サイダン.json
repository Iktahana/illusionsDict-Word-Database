    "definitions": [
      {
        "index": 1,
        "gloss": "altar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その朝は早々起きて物置の二階から祭壇を下ろし煤を払い雑巾をかけて壇を組みたてようとすると、さて板がそりかえっていてなかなか思うようにならぬのをようやくたたき込む。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の間から祭壇を持って来て床の中央へ三壇にすえ、神棚から御厨子を下ろし塵を清めて一番高い処へ安置し、御扉をあけて前へ神鏡を立てる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一順すむと祭壇の菓子を下げて子供等に頂かせる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物質と生命をただそのままに祭壇の上に並べ飾って賛美するのもいいかもしれない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間幽霊のように扉を排して、一人の日本人の旅人が、この東洋風の祭壇のように怪奇な部屋に這入ると、扉に背をもたせて、彼の眼前に小さくうずくまった花子を凝視した。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は陳子文の死によって北京の秘密結社において自分と彼とシイ・ファン・ユウとの恋愛の共同事業も、陳子文が過去の東洋の虚無主義の祭壇に生還したのを感じて、陳子文の古い伝統の礼譲に敬礼するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のお父さんは七年前の不作のとき祭壇に上って九日｜祷りつづけられた。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは雨夜の仮の宿で、毛布一枚の障壁を隔てて男女の主人公が舌戦を交える場面、もう一つは結婚式の祭壇に近づきながら肝心の花嫁の父親が花嫁に眼前の結婚解消をすすめる場面である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七夕祭りの祭壇に麻や口紅の小皿といっしょにこのおはぐろ筆を添えて織女にささげたという記憶もある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺骸を郊外山腹にある先祖代々の墓地に葬った後、なまなましい土饅頭の前に仮の祭壇をしつらえ神官が簡単なのりとをあげた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うには勿論花で飾られた高い祭壇が設けられていました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーチになった祭壇のすぐ下には、スナイダーを楽長とするオーケストラバンドが、半円陣を採り、その左には唱歌隊の席がありました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが祭壇の下オーケストラバンドの右側に、「異教徒席」「異派席」という二つの陶製の標札が出て、どちらにも二十人ばかりの礼装をした人たちが座って居りました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髯赭顔のデビス長老が、質素な黒のガウンを着て、祭壇に立ったのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭司次長が又祭壇に上って壇の隅の椅子にかけ、それから一寸立って異教徒席の方を軽くさし招きました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "式場は俄に大騒ぎになりシカゴの畜産技師も祭壇の上で困って立っていました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那服で祭壇に立ってはじめて私の顔を見て一寸かすかに会釈しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "異教徒席の中から赭い髪を立てた肥った丈の高い人が東洋風に形容しましたら正に怒髪天を衝くという風で大股に祭壇に上って行きました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちついて祭壇に立ってそれから叮寧にさっきのマットン博士に会釈しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその拍手のまだ鳴りやまないうちにもう異教徒席の中から瘠せぎすの神経質らしい人が祭壇にかけ上りました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人はまるで顔をまっ赤にしてせかせかと祭壇にのぼりました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽屋のうす暗い二階を上つたところに祭壇がある。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "頑冥なる守旧家の手によつて捧げらる新社会の祭壇の前の俺は犠牲だ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "上が兀げて、土がきれいで、よく見ると、誂えた祭壇の……そこへ天狗が集りそうで、うそ寂しい。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以後いまだ百年もたっていないのに、多くの大家が文豪と称せられ、古典の仲間入りをして、文学の祭壇にまつりあげられ、この人たちの片言隻句はまるで文学の神様のような権威を与えられて、大正昭和の文学を指導して来ました。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い階段の前に高い祭壇があって、円柱のあいだに生えているしだれヤナギはいきいきとしていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどの仏の前にも――それはみんな錫でつくってあります――小さい祭壇があって、そこには聖い水と、花と、火のともっているろうそくとがありました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭壇の足もとに、ひとりの生きた人間の姿が、ひとりの若い僧侶が、すわっていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの祭壇でも、りっぱな銀のランプに、よいかおりのする油が燃やされました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの家のえんとつからも、貧乏なお百姓さんの家の、ちっぽけなえんとつからさえも、ちょうど、ドルイド教徒のさいだんからのぼる煙のように、かんしゃをこめた、ささげものの煙が、うす青く立ちのぼりました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
