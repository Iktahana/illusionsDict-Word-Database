[
  {
    "uuid": "f50a71ed-d1aa-594a-8f09-072f8b62582e",
    "entry": "里方",
    "reading": {
      "primary": "さとかた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
