    "definitions": [
      {
        "index": 1,
        "gloss": "wife's family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）学円　何にしろ、お睦じい……ははははは、勝手にお噂をしましたが、何は、お里方、親御、御兄弟は？",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉七　むう、ちと里方へ用がある。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと反対に綾姫の里方の今大路家はあまり仕合せがよくなかった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "子之助はこの年十二月下旬に継母の里方鳥羽屋に預けられた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "里方は深川木場の遠州屋太右衛門である。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に太郎兵衛が娘をよめに出す覚悟で、平野町の女房の里方から、赤子のうちにもらい受けた、長太郎という十二歳の男子がある。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野町の里方は有福なので、おばあ様のおみやげはいつも孫たちに満足を与えていた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄兵衛は五節句だと言っては、里方から物をもらい、子供の七五三の祝いだと言っては、里方から子供に衣類をもらうのでさえ、心苦しく思っているのだから、暮らしの穴をうめてもらったのに気がついては、いい顔はしない。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし心の奥には、こうして暮らしていて、ふいとお役が御免になったらどうしよう、大病にでもなったらどうしようという疑懼が潜んでいて、おりおり妻が里方から金を取り出して来て穴うめをしたことなどがわかると、この疑懼が意識の閾の上に頭をもたげて来るのである。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻がそう云う風で、合意が成り立たないのに、わたくしがどうしようと申したって、里方の親類が承知しません。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのカラタール氏が大急行で巴里まで行こうとしたその目的は一体何であろう――それについては、巴里方面からは何等の報道も来なかった。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「尼ども、両親はとうになくなって、もともと身上の足りぬ処を、洞斎兄の学資といえば、姉の嫁、私には嫂じゃにい、その里方から末を見込んで貢いでおった処を、あの始末で、里をはじめ、親類もあいそを尽かせば、嫂も断念めた。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お千代は北の幸谷なる里方へ帰り、省作とおとよは湖畔の一｜旅亭に投宿したのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其あらましを言ふと、　母は里方の兄なる人から、今日意外なことを聞いた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君の里方では、糟谷をえらい人と思いこみ、なお出世する人と信じて、この結婚を名誉と感じてむすめをとつがし、糟谷のほうでもただ良家の女ということがありがたくて、むぞうさにこの結婚は成立した。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかといっては月のうちに一｜度も二｜度も里方へ相談にいく。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局離縁になって里方へ帰されたようです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はお節や新次郎から幾らかの小遣い銭を貰って、六月以来、山谷の里方へ五、六たび使いに行ったことがある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことになれば、女房の里方の不承知は勿論、親類たちからも故障が出て、伊勢屋の店にお家騒動が起こるのは見え透いている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁の里方でも伊太郎が師匠の御新造と怪しいということを薄々感付いたので、とうとう別れ話になったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口屋は嫁の里方であるので、もしや急病人でも出来たのかと、店の者も思わず戸をあけると、黒い覆面の男ふたりが無提灯でずっと這入って来て、だしぬけに主人に逢わせろと云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし妻の里方では承知しない。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "録異記",
                "note": "青空文庫"
              }
            },
            {
              "text": "其次に、太郎兵衞が娘をよめに出す覺悟で、平野町の女房の里方から、赤子のうちに貰ひ受けた、長太郎と云ふ十二歳の男子がある。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "平野町の里方は有福なので、おばあ樣のお土産はいつも孫達に滿足を與へてゐた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄兵衞は五節句だと云つては、里方から物を貰ひ、子供の七五三の祝だと云つては、里方から子供に衣類を貰ふのでさへ、心苦しく思つてゐるのだから、暮しの穴を填めて貰つたのに氣が附いては、好い顏はしない。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし心の奧には、かうして暮してゐて、ふいとお役が御免になつたらどうしよう、大病にでもなつたらどうしようと云ふ疑懼が潜んでゐて、折々妻が里方から金を取り出して來て穴填をしたことなどがわかると、此疑懼が意識の閾の上に頭を擡げて來るのである。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくがたはしょろうと申しふれられてしばらく江北におとゞまりなされまして、どなたにもたいめんあそばされず引きこもっておられましたが、おなじ月のとおかごろ、いよ／＼尾州清洲のおさとかたへおかえりあそばすことになりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
