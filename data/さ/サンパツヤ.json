        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分はその足で散髪屋へ入った。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髪屋は釜を壊していた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥を飼っている近くの散髪屋の小僧だと思う。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を思い切って短く刈ったら、少しは頭も涼しくなり、はっきりして来るかも知れぬと思い、散髪屋に駈けつけた。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きあたりばったり、どこの散髪屋でも、空いているようなところだったら少しは汚い店でもかまわないと、二、三軒｜覗いて歩いたが、どこも満員の様子である。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は苦笑して、その散髪屋のドアを押して中へはいった。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身では気がつかなかったけれど、よその人から見ると、ずいぶんぼうぼうと髪が伸びて、見苦しく、それだから散髪屋の主人も、私の意向をちゃんと見抜いてしまったのだ、それにちがいない、と私は流石に恥ずかしく思ったのである。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木鉢や、金魚鉢が、要所要所に置かれて、小ざっぱりした散髪屋である。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髪屋に来てまで、こんなに気取らなければいけないのかと、われながら情なく思った。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髪屋の看板写真みたいに、規格型の顔をさらしてると思て、うぬぼれるな。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髪屋も畳屋も同じ手職稼業でたいした違いはないようなものの、おたかにしてみれば口惜しいほど格式が落ちたと思われ、だから断るにもサバサバした気持だった。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と張り出しをし、散髪屋、雑貨屋など人の集るところの家族にはあらかじめ無料で灸をすえてやり、仁の集まるのを待った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ一円残っていますがこれで散髪屋に行き、――後五十銭残りますが、これもいっそ費って、宵越のぜにア持たねエ、クリスマスを迎えようかと愚考しています。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髪屋の娘はもう二十八歳で、嫁に行かなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髪屋も畳屋も同じ手職稼業でたいした違いはないようなものの、おたかにしてみれば、口惜しいほど格式が落ちたと思われ、だから断るにもサバサバした気持だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、お門ちがいや、うちの孫はまだ十やさかいな、おまはん仲人したかったら、散髪屋のおばはんとこイ行きなはれ」「聴こえるがな、聴こえたら、また朝日軒のおばはん頭痛を起しまっせ」　広島生れの玉堂は下手な大阪訛りで言って、ちょっと赧くなった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を浴びてすくっと立っている眼の覚めるような鮮かな肢態に固唾を呑むような嫉妬を感じていた長屋の女が、ある時、お君の頸筋を見て、「まあ、お君さんたら、頸筋に生毛いっぱい……」　生えているのに気がついたのを倖い、おおげさに言うので、銭湯の帰り、散髪屋へ立ち寄ってあたってもらった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして散髪屋、雑貨屋、銭湯、居酒屋など人の集まるところの家族には、あらかじめ無料ですえてやり、仁の集まるのを待ち構えた。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所の客は皆若い男で、散髪屋の職人とでも云つた風であつた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは白い木綿のふはふはした襦袢を着てゐる男で、坂のおり口の右角にある散髪屋の亭主であつた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、散髪屋さんですか、」「今晩は涼しいではございませんか、何所かのお帰りでございますか、」「ああ、中野の方へ行つてまして、ね、……散歩ですか、」「ひと廻りして来やうと思ひまして、ね、」「ぢや、さよなら、」二　義直は坂路をおりた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう坂路をおりてしまつて散髪屋の角を曲らうとしてゐた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは坂のおり口で逢ふた散髪屋の家であつた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髪屋の娘はもう三十二才で、嫁に行かなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで散髪屋の椅子みたいやと君枝が言うと、次郎は天井を仰ぎやすいようにしてあるのだと言った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中風で寝ている父親に代って柳吉が切り廻している商売というのが、理髪店向きの石鹸、クリーム、チック、ポマード、美顔水、ふけとりなどの卸問屋であると聞いて、散髪屋へ顔を剃りに行っても、其店で使っている化粧品のマークに気をつけるようになった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "水を浴びてすくっと立っている、眼の覚めるような鮮かな肢態に固唾をのむような嫉妬を感じていた長屋の女が、あるときお君の頸筋を見て、「まあ、お君さんたら、頸筋に生ぶ毛が一杯……」生えているのに気が付いたのを倖い、大袈裟に言うので、銭湯の帰り、散髪屋へ立ち寄ってあたって貰った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……午後船の散髪屋へ行く。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お邸の若様と云っても、恥かしくないような、好い男の書生さんだった、何か理があるだろうよ）　坂の下の散髪屋の主翁の云った詞も浮んで来る。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幾時｜頃なんだろう」「時計屋の時計はあてにならないね」　時計屋の隣の散髪屋の時計は、十二時を八分過ぎていました。",
              "citation": {
                "source": "誰が・何時・何処で・何をした",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
