    "definitions": [
      {
        "index": 1,
        "gloss": "golden age",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "観瀾山の桜は、いまが最盛期らしい。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして古代における科学の最盛期というべきものはアレキサンドリアのプトレミー朝時代に当って見られる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学の西田幾多郎、哲学史の朝永三十郎、美学の深田康算、西洋史の坂口昴、支那学の内藤湖南、日本史の内田銀蔵、等々、全国から集まった錚々たる学者たちがその活動の最盛期にあった。",
              "citation": {
                "source": "わが青春",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイバネット工業は輸出用のカーステレオ市場に参入して生き残りを図ったが、最盛期には二六〇〇人を数えた従業員は、一九七九（昭和五十四）年には九〇〇人を切るまでに減った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最盛期には一五〇名近い開発要員を指揮して、古山はＩＴＯＳのデバッグに取り組み、着手から四か月後にはどうやら安定して動作する３・３版のリリースにこぎ着けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってその最盛期におけるだけの名人名工はその末世にあっては再び現われるものでない。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の前で仕事する方法は、私の画道の修業時代もまたこの勢力、この方法の最盛期でもあったために、私は最後まで自然の前に立つ技法を学んだ。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "大師の入唐は、唐の文化の最盛期ともいふべき、玄宗の天寶時代を距ること五十餘年で、唐の國運こそ漸く傾いたけれど、その文化と豪華とは、未だ少しも衰へて居らぬ。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの生涯中三十七歳から六十三歳まで、人生の最盛期二十七年間は、本國に意を得ないでドイツ、イタリア等に漂泊の生活を送り、『ブランド』以下『ヘッダ・ガブレル』に至る十餘篇の劇をそのあひだに作つた。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "各人の体形に合せてその理想型を消化し会得しなければならないのだが、一流のプロになるには一日少くとも五百回打撃の練習をし、さらにコースをまわり、一日中ゴルフで暮して少くとも二十年、十四五でクラブを握って四十前後に最盛期に達し技術も完成すると云われている。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前後、「文芸落語」と銘打って（酒井雲が文芸浪曲とて、菊池寛や長谷川伸文学を上演していた最盛期だった！",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "バビロンは最盛期に達していて、東方諸国の交易の中心であり、遠く支那では、周の文化が栄えている。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在ジョンス・ホプキンス大学の物理主任教授をしているディーケ博士や、ミシガン大学のラポルテ博士などが、若い研究員として理化学研究所へやってきていた時代のことで、日本の国力は、最盛期にあったわけである。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "積雪最盛期と、半分解けた時期と、ほとんど解けた頃と、希望どおり三回の撮影をしてくれたのである。",
              "citation": {
                "source": "大雪山二題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時代は、日本の国力が、正に最盛期に達しようとしていた時代であった。",
              "citation": {
                "source": "日本のこころ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日清、日露の戦に勝ち、朝鮮を併合した明治の時代、すなわちいわゆる日本の最盛期においても、小学校四年の義務教育を、六年に延長することは、かなり困難な事業であった。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『舞楽要録』によると、舞楽の最盛期であった藤原時代後半の数多い舞楽演奏は、二三の例外を除いてほとんど皆林邑楽の陵王（左）納蘇利（右）をプログラムの最後に置いている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元後五世紀ごろグプタ朝の最盛期に出たカリダアサの戯曲は、ヘレニズムよりルネッサンスに至るまでの欧州に全然その匹儔を見ないほどの傑作だと言われているが、自然と人間とを超越しようと企てるインド風の生活を題材としているにかかわらず、描写の仕方は決して超自然的超人間的ではない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "グプタ朝の最盛期は北魏の時代に当たっているが、その時代には西域人の来朝が少なくない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど玄弉の時代は西域の最盛期であった。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鳳天平の彫刻と『万葉』の短歌一　推古時代から弘仁時代へかけての仏教美術、特にその最盛期としての天平時代の造形美術が、「外来のもの」であって日本人固有の心生活の表現ではない、ということは、一般に説かれているところである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころは中インドの方でもグプタ朝の最盛期で、カリダーサなどが出ており、シナから法顕を引き寄せたほどであった。",
              "citation": {
                "source": "麦積山塑像の示唆するもの",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この都を造った頃が、平家栄華の最盛期であったかも知れぬ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時には数学ないし諸科学も見るべきものがあることはあるが、未だ最盛期に到来したものでない。",
              "citation": {
                "source": "芸術と数学及び科学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学の最盛期はこれで終わるのであるが、文学においても、また芸術においても、アテナイの国勢伸長期とともに全く地に堕ち、これからは次第に衰退の時期となる。",
              "citation": {
                "source": "芸術と数学及び科学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実サア・ウィリアム・テンプルは、自分の意見として、オランダの貿易はすでに数年間最盛期を過ぎており、明かに衰退し始めている、と述べている２）。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の、最盛期岸田であるから、この美術の人に描かれる画式に、たとへ初めは多少技術的不備はあらうとも「絵にならない作品」などあらう筈はなかつた。",
              "citation": {
                "source": "岸田劉生の日本画",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれら跛行する恐怖たる囚われの精神と同様に、かの呪われた石造都市の原初の最盛期を知っており、嫌ったらしい捕り手の姿で通い馴れたこれらの通廊をのたうち回っていたのだろうか？",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "建設者達はアーチの原理に通暁し多くの場所で巧みな応用を見せ、この都市の最盛期にはドームの群れがあったことだろう。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
