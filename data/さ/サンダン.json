  {
    "uuid": "096da20e-3fe1-5e2e-bdc9-d69284118b49",
    "entry": "讃談",
    "reading": {
      "primary": "さんだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
