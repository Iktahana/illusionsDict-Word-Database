[
  {
    "uuid": "0d773e77-fc52-5538-91a6-13688c4ea77f",
    "entry": "三乗",
    "reading": {
      "primary": "さんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
