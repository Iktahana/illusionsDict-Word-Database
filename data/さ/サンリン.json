[
  {
    "uuid": "c69964b4-9cf9-5cf1-af94-9906768d0ecc",
    "entry": "三輪",
    "reading": {
      "primary": "さんりん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
