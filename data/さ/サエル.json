    "definitions": [
      {
        "index": 1,
        "gloss": "to be clear (of a sight, sound, colour, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とある雨の夜、父は他所の宴会に招かれて更けるまで帰らず、離れの十畳はしんとして鉄瓶のたぎる音のみ冴える。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが夕方になると眼が吸いつくばかりの鮮やかさに冴える。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中になって来ると病気の私の身体は火照り出し、そして眼が冴える。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……気を鎮めて眠ろうとすればするほど、悲しみはあとからあとからと湧き返って、涙のために痛みながらも眠が冴えるばかりだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "井田は何時でもかうなると顏が冴える。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の夜ながら冴えるまで、影は草葉の裏を透く。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の時は濡れたやうな眞黒な暗夜だつたから、其の灯で松の葉もすら／＼と透通るやうに青く見えたが、今は、恰も曇つた一面の銀泥に描いた墨繪のやうだと、熟と見ながら、敷石を蹈んだが、カラリ／＼と日和下駄の音の冴えるのが耳に入つて、フと立留つた。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その透切した衣の背に肩に、一城下をかけて、海に沈む日の余波の朱を注ぐのに、なお意気は徹って、血が冴える。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の夜ながら冴えるまで、影は草を透くのである。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、十夜をあての夜興行の小芝居もどりにまた冴える。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは寒気の冴える朝の楓川に沿い、京橋川に沿って歩いたが、そうそうは寒さに堪えられない。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い火さきが、堅炭を搦んで、真赤に※って、窓に沁み入る山颪はさっと冴える。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は濡れたような真黒な暗夜だったから、その灯で松の葉もすらすらと透通るように青く見えたが、今は、恰も曇った一面の銀泥に描いた墨絵のようだと、熟と見ながら、敷石を蹈んだが、カラリカラリと日和下駄の音の冴えるのが耳に入って、フと立留った。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが薬なら、身体中、一筋ずつ黒髪の尖まで、血と一所に遍く膚を繞った、と思うと、くすぶりもせずになお冴える、その白い二の腕を、緋の袖で包みもせずに、……」　聞く欣八は変な顔色。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生国魂神社境内の夜の空気にカチカチと歯の音が冴えるのであった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅津朔造氏の調子は凜々と冴える、仮名扱いの綺麗な、派手なものであった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子の現在を知ってか知らずにか、自分と新子との関係を、嗅ぎつけているのかいないのか……前川は、酒の酔もすっかり吹き飛ばされて、酔ざめの後の常より一倍冴える頭の中で、彼も夫人の心中を計るべく、作戦を考えねばならなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "生国魂神社境内の夜の空気にカチ／＼と歯の音が冴えるのであった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフェの灯がぽつりぽつりと消されて行って、やがてあわただしい暗さがあたりに漂うと、アスファルトは急に凍てついた白さに冴える。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "良い思案も泛ばず、その夜は大阪駅で明かすことにしたが、背負っていた毛布をおろしてくるまっていても、夏服ではガタガタ顫えて、眼が冴えるばかりだった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは今お話した富豪連が、崑崙山の麓で使い棄てた緑茶の出し殻から精製した白い粉末で、相当高価なものだそうですが、それでも我慢して、普通のお茶に交ぜて服んでみると、芳香や風味は格別無い代りに、純粋のエキスですから神気の冴える事は非常なものです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳が赫と、目ばかり冴える。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに其の頃は紺が七日からも經たねば沸ないやうな藍瓶で染られたので、今の普通の反物のやうな水で落ちないかと思へば日に褪めるといふのではなく、勘次がいつたやうに洗濯しても却て冴えるやうなので、それに地質もしつかりと丈夫なものであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを晩秋の空が悉皆持ち去るので滅切と冴える反對に草木は凡てが乾燥したりくすんだりして畢ふのに相違ないのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄む気を養って止まなければ終に冴える気になる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴える気になれば気は次第に変化して神妙になろうとする。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○を押さえると△があばれだす。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイタイ活動写真をこさえる事は、決してナマ易しい事ではありません。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「拙者、今朝がたより　腹痛を覚え……」　と急に腹をおさえる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "児分の連中、仲蔵の両手両足おさえる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
