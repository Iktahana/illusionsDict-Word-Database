        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高田早苗に似てゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは藤枝の宿で、熊谷蓮生坊が念仏を抵当に入れたというその相手の長者の邸跡が今は水田になっていて、早苗がやさしく風に吹かれているのを見に寄ったり、島田では作楽井の教えて呉れた川越しの蓮台を蔵している家を尋ねて、それを写生したりして、大井川の堤に出た。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早苗とる頃」で想い出すのは子供の頃に見た郷里の氏神の神田の田植の光景である。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三階の部屋から、丘の松、小山田の早苗の風、嶺越しの青※の麦野が眺められます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの町でも魚類売りは行商人の花形役者で……早乙女が採った早苗のように頭の天頂に手拭をチョット捲き付けて、『ウワ――イ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな岡の根に、高田早苗、鈴木梅四郎兩氏の別莊と相竝んで名前は前から知つてゐたこの二升庵は在るのであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次とおつぎは南の早苗振の日に傭はれて行つて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、所々植付けられたばかりの早苗が、軽いほのぼのとした緑を、初夏の風の下に、漂わせているのであった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中早苗氏の翻訳によって最近モーリス・ルヴェルのコント集が『夜鳥』として出版された。",
              "citation": {
                "source": "ルヴエルの『夜鳥』",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "延原謙氏、妹尾韶夫氏、田中早苗氏をはじめとし、この方面に専心した、多くの翻訳家に対しては、感謝を捧げなければなりますまい。",
              "citation": {
                "source": "探偵文壇鳥瞰",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『放送された遺言』は、僕の書いた科学小説の第二作であって、昭和二年「無線電話」という雑誌に自ら主唱し、友人｜槙尾赤霧と早苗千秋とに協力を求めて、三人して「科学大衆文芸」というものを興したが、そのときに書いたものである。",
              "citation": {
                "source": "『地球盗難』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、所々植付けられたばかりの早苗が、軽いほのぼのとした緑を、初夏の風の下に、漂はせてゐるのであつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "高杉早苗の新婚旅行の首途に偶然行きあわせたと云って、翌朝は工場のストーブのかげで互に抱き合い泣かんばかりに感激する娘たちの青春に向って、その境遇さながら、最もおくれた感情内容を最新の経済と科学の技術で結び合わした情熱の消耗品がうりだされている現実である。",
              "citation": {
                "source": "観る人・観せられる人",
                "author": "――観客の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日枝の山、比良の高根より、辛崎の松は霞こめて、城あり、橋あり、釣たるゝ舟あり、笠とりに通ふ木樵の聲、麓の小田に早苗とる歌、螢とびかふ夕闇の空に水鷄のたゝく音、美景ものとして足らずといふことなし。",
              "citation": {
                "source": "芭蕉",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目「恋の信玄」などは、早苗姫が自殺してからの信玄の心理的経路が鮮明に描かれていなかったらしい為に、肝心の幕切れで、信玄と云う人格、早苗姫の死が、一向栄えないものになったように見える。",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "早苗姫が、真個にいとしかったのだが、万事が逆転して子には叛かれ、愛人には怨死されるのか、其とも、只、我ものになるからには飽くまでも服させずには置かない故に口説いたのか。",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、心から愛していたのなら、早苗姫が胸を貫いて死んだ刀の血を拭わせずに鞘に納めることもあり得ようが、忽ち、将軍になろうとしての上洛の途につく決心をするのは何故か？",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者が、私の想像するように、早苗を真心から愛したく思っていたのに、彼の性格的な運命から事は悉く失敗し、最後に彼を捕えたのは、愛でもなく、沈思でもなく、何処までも彼を追い立てて行く武将の野心であったとするならば、最後の一句は、決して、其心をしみじみと味わせるだけの実感を漲らしてはいなかった。",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "稍々誇張して云えば、早苗の自殺ではっと気を緊めた見物の前に、大きく「ええ、口惜しや、騙かられたか！",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "早苗の死、其に連関して全く消極の働きを起した老傅役の自殺、子義信の反乱が、信玄の心にどう影響したか。",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其点がはっきりしてこそ、早苗が、只、敵方に騙り寄せられた城将の妻が古来幾度か繰返したような自裁を決行したのか、又は彼女が云うように、国や命を賭けた戦を、彼女の命で裁かれたのか、歴然と一方に事実として照し出されたのではあるまいかと思うのである。",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉久子の早苗は、序幕の舞台が廻ってからが際立ってよかった。",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯の時ならぬ音に驚かされて、鶯や野を見下せば早苗取　松本にて昼餉したゝむ。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞋を解き足を洗ひ楼上に臥し晴間をも待たで早乙女の早苗取る手わざなど見やる折柄はした女あわただしく来りて汽車はや来れりいそぎ下り給へと云ふ。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕の飛ぶ小雨の日に、「新藁、しんわら」と、はだしの男が臑に細かい泥を跳ねあげて、菅笠か、手ぬぐいかぶりで、駈足で、青い早苗を一束にぎって、売り声を残していった。",
              "citation": {
                "source": "大門通り界隈一束",
                "author": "続旧聞日本橋・その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も、ごう／＼と寒い風の吹くなかをバスにゆられながら、早苗は三條までやつて來て、疏水の近くにある梅園産院と云ふのへ寄つてみた。",
              "citation": {
                "source": "風媒",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "底冷えのする寒い路地の中を小走りに歩きながら、早苗はいろ／＼な胸算用をしてゐるのである。",
              "citation": {
                "source": "風媒",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早苗は、何となくよい子供がさづかりさうな、そんなふくふくした、氣持ちになるのであつた。",
              "citation": {
                "source": "風媒",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのう、昨日、新聞でみまして上りましたのどすけど……」　早苗はシールの肩掛をはづして笑顏でたづねた。",
              "citation": {
                "source": "風媒",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が少しでも口唇を動かすときに、小さなえくぼが輝く薔薇色の頬に現われました。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
