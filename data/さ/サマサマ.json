    "definitions": [
      {
        "index": 1,
        "gloss": "our gracious (e.g. Queen)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
