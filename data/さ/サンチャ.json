    "definitions": [
      {
        "index": 1,
        "gloss": "powdered tea",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日はもう、どのように言いなんしても、かえしはしませぬぞ」　――声の主は笑止なことに身分柄もわきまえず、大身旗本のこの名物男早乙女主水之介に、もう久しい前から及ばぬ恋慕をよせている、そこの淡路楼と言う家の散茶女郎水浪でした。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早乙女主水之介、また罷り越すぞ」　会所の曲輪役人共を尻目にかけながら、ずいとくぐりぬけて、さっさと登っていった家は意外と言えば意外ですが、先程宵のうちに待ち伏せていて、恋慕の口説を掻きくどいたあの散茶女郎水浪のいる淡路楼でした。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあの散茶女郎の水浪で、姿を見るや駈けるようにしてその袖を捕らえにかかりましたので、退屈男は女の言葉がないうちに言いました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "散茶の相場としてこんな物であったかも知れない。",
              "citation": {
                "source": "傾城買虎之巻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "相方は和泉屋の楓と云う、所謂散茶女郎の一人であった。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちばらばらになろうたって、どこかのたまり水の上に落ちようたって、お日さんちゃんと見ていらっしゃるんですよ」　「そうです、そうです。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちばらばらになろうたって、どこかのたまり水の上に落ちようたって、お日さんちゃんと見ていらっしゃるんですよ」「そうです、そうです。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、そこは小母さんちゃんと見通し。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「む、逢いたい、いや、それは小母さんちゃんと見通し。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さんちゃんか、お前じゃあるまいし、儲口なんか捜して歩くものかい」　新吉は笑って見せた。",
              "citation": {
                "source": "女の首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母さん――母さん――母さんちゃん――ちゃん――ちゃん――ちゃん」　この調子が可笑しくもあったので、看護のもの一同が笑うと、お房は自分でも可笑しく成ったと見えて、めずらしく笑った。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母さん、母さん、母さん――母さんちゃん――ちゃん――ちゃん――ちゃん」宛然、気が狂ったような声だ……それは三吉の耳について了って、何処に居ても頭脳へ響けるように聞えた。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう初めて仕事先へ来たおさんちゃんじゃあるめえし。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次郎　おさんちゃん怒っちゃ厭だよ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "（行きかける）三次郎　ちょっちょっ、待ったおさんちゃん、そう急ぐにも当るめえ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさんちゃんだって稀には屈託な顔もするだろうし、溜息だってつくだろうよ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
