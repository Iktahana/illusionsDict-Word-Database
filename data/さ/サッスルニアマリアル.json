[
  {
    "uuid": "fd378527-ec42-5099-baa1-73dbd1f9d341",
    "entry": "察するに余りある",
    "reading": {
      "primary": "さっするにあまりある",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行-不規則"
      ],
