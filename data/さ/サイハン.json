      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reprint",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一昨年は、竹村書房から「愛と美について」砂子屋書房から「女生徒」女生徒は、ことしの五月に再版になりました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし再版のときに色々な増補をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃その著書の再版が出た。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再版の序　この詩集の初版は大正六年に出版された。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにしても再版を出してくれといふ督促の書簡である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は再版の意を決した。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村書房主は沈思のあげく、かうしたらどうでせう、この紙不足の折に兩書とも再版などは、とても出來るものではありませんし、この二つの著書から特に著者の氣にいりの同じ匂ひの作品ばかりを寄せ集めて一本にまとめたら、といふ意見を提出した。",
              "citation": {
                "source": "『老ハイデルベルヒ』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戰時下の、自肅再版形式とでも稱すべきか。",
              "citation": {
                "source": "『老ハイデルベルヒ』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも今日、あへてこの再版を定本にして出す所以は、著者の私にとつて種種の理由があるのである。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも「青猫」を完全な定本詩集とする爲には、是非とも此等の詩を補遺しなければならないので、初版出版後今日まで、長く私はその再版の機會を待つて居た。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた私は、その再版の機會をまつて、初版本の編輯上に於ける不統一を正さうとした。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "再版の機會に於て、これもまた改訂編輯せねばならなかつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この點もまた機會を見て、再版に改訂せねばならなかつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この再版を世に出すのも、既に十餘年も經た今の詩壇で、正しい認識と理解をもつ別の讀者を、新しく求めたいと思ふからである。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌四十二年二月再版。",
              "citation": {
                "source": "小説「墓場」に現れたる著者木下氏の思想と平民社一派の消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處に寫した譯文は即ちその平民新聞第三十九號（八月七日）の殆ど全紙面を埋めたもので、同號はために再版となり、後また文明堂といふ一書肆から四六版の册子として發行されたが、今はもう絶版となつた。",
              "citation": {
                "source": "トルストイ翁論文",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "再版後の分は、表は同じ鼠の無地であるが、背の鞁の金文字は自身のものに換へ大扉と小扉も同じく之に準つた。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴉飛びて朱の満月過ぎにけり鮮かに見えつ太き嘴　（一八五頁）註、但、後の改造文庫「花樫」再版にて、この三句は原作の「過ぎるとき」に還した。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、『花樫』は同五年に改造文庫の一冊として再版された。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "本集は危うく絶版の悲運に際会しようとしたが四十四年の十一月に書肆を換えて再版し、なほ大正五年の六月に更に増補訂正して三版した、その後引続いて版を重ねてゐる。",
              "citation": {
                "source": "「白秋詩集」第二巻解題",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "初回に作っておいた印刷用のフィルムを使い回せるため、再版では一冊あたりの製造コストを抑えられます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一三年再版、エノックの『太平洋の秘密』（ゼ・セクレット・オブ・ゼ・パシフィック）一三一頁に記された、南メキシコのマヤ人の故趾に見る羽被った蛇も、能く飛ぶという表示であろう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六六五年再版ド・ロシュフォーの『西印度諸島博物世態誌』一四二頁に、土人の家に蛇多く棲むも鼠を除くの効著しき故殺さずと見え、『大英百科全書』四に両半球に多種あるボア族の大蛇いずれも温良く、有名なボア・コンストリクトルなど、人と同棲して鼠害を除くとある。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "中堀僖庵の萩の栞（天明四年再版）上の十一張裏に「いけこめの御陵とは大和國藥師（寺か）の後にあり、何れの御時にか釆女御門の御別れを歎き生ながら籠りたる也」是は垂仁帝の世に土偶を以て人に代へ殉葬を止められたに拘らず、後代までも稀れに自ら進んで生埋にされた者が有つたのが史籍に洩れて傳説に存したと見える。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "これの再版か三版かが出た時に金拾五圓也を貰つて私は甲州の下部温泉といふに出向いた事を覺えて居る。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで米国の出版者は思ひきつて英国版と同じ題名にかへて再版を出したら、急に売れ行きが増して来たといふことである。",
              "citation": {
                "source": "商品としての近代小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書の目的は主として郷里の青年に郷土の知識を与えるに在ったが、恩師新村博士が中央の学界に紹介されたお蔭で、端なくも南島研究の手引となり、大正五年に論考数篇を加え、口絵二十余枚を添えて、再版を東京で刊行することが出来、同十一年には、岡村千秋君の尽力によって、第三版を郷土研究社で出して頂いた。",
              "citation": {
                "source": "「古琉球」改版に際して",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十四年一月京都にて西田幾多郎再版の序　この書を出版してから既に十年余の歳月を経たのであるが、この書を書いたのはそれよりもなお幾年の昔であった。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の書物に再版はない　人生は一巻の書物！",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に近く蚕豆、豌豆など一うね二うね植ゑたるが、その花を見れば心そぞろにうき立ちて楽しさいはん方なし。",
              "citation": {
                "source": "わが幼時の美感",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
