[
  {
    "uuid": "976f88f7-95e1-5592-be16-3adf377a651c",
    "entry": "再版",
    "reading": {
      "primary": "さいはん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
