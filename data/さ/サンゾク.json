[
  {
    "uuid": "c05601d3-3590-50db-aad9-37a8ae8c7d9a",
    "entry": "山賊",
    "reading": {
      "primary": "さんぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bandit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山賊仲間に聖者のゐたためしは先づないが、修道院の中には天使から悪魔までがずらりとゐる。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "内のお絹、恐る恐る、見ると、　山賊の好色の笑。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山賊輩はお絹を葛籠から担ぎ出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「こーら」　タハッと驚く山賊が振り返ると、　真黒な辻堂の中に天狗の顔が物凄く光って居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーと山賊、腰を抜かす。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻堂の天狗が（団九郎）、Ｔ「吾こそは　此の仙境に　棲む天狗なり」　そら出たと山賊達、腰を抜かす。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎の天狗は悠々と現れ出て、Ｔ「我名を騙る　憎い人間ども」　山賊達、震え上る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "とそれならぬ、姉様が、山賊の手に松葉燻しの、乱るる、揺めく、黒髪までが目前にちらつく。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「可、と打込んで、ぐら／＼と煮える処を、めい／＼盛に、フツフと吹いて、」「山賊々々。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『まるで山賊のようだ！",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "各粗末なしかも丈夫そうな洋服を着て、草鞋脚絆で、鉄砲を各手に持って、いろんな帽子をかぶって――どうしても山賊か一揆の夜討ちぐらいにしか見えなかった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一通りの山賊でない、図太い山賊で、かの字港まで十人が勝手次第にしゃべって、随分やかましかった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一軒の漁師の家がある、しかし一軒が普通の漁師の五軒ぶりもある家でわれら一組が山賊風でどさどさ入っていくとかねて通知してあったことと見え、六十ばかりのこの家の主人らしい老人が挨拶に出た。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同は寒気を防ぐために盛んに焼火をして猟師を待っているとしばらくしてなの字浦の方からたくましい猟犬が十頭ばかり現われてその後に引き続いて六人の猟師が異様な衣裳で登って来る、これこそほんとの山賊らしかった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……行暮れた旅人が灯をたよるように、山賊の棲でも、いかさま碁会所でも、気障な奴でも、路地が曲りくねっていても、何となく便る気が出て。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは盗賊に殺されたのか道連に殺されたのか、それらの事情も判然しなかつたが、彼女のふところには路銀らしいものを貯へていゐなかつたので、恐くはこゝらを徘徊する山賊の仕業であらうといふことになつてしまつた。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜、この小夜の中山にて山賊｜出でて恋慕し、したがはざるによりて斬殺し、衣裳をはぎ取り行方無し。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居や草双紙にもよくありますが、とかく古寺なんていうものは、山賊なんぞの棲家になるもので、この寺も暫く無住のあき寺になっているうちに、悪い奴らが巣を作ってしまったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「山賊みたいな奴ですな。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「併し一概に山賊などと云っても中には却々い儀深い奴もいるものですよ。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何故と云って、それからその馬車が少しばかり駈り初めた時に、山賊の一人が息せききって駈戻って来たのです。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "五番めのお話小さな山賊の娘　馬車は、うす暗い森の中を通っていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、たいまつの明りのように、キラキラ光っていましたので、それが山賊たちの目にとまりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ると、山賊たちは、がまんができなくなりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、山賊たちは、口々にさけびながら、馬車をめがけて、どっと、おそいかかりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "クルミの実で、ふとったんだろ」と、山賊のばあさんが、言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この子は、あたしとあそぶんだもの」と、小さな山賊の娘が言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの山賊たちは、そのようすに大笑いをして、「見ろよ、ばあさんが、てめえのがきと踊ってるじゃねえか」と、言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、小さな山賊の娘は言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
