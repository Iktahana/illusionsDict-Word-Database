        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それぞ死よ――はたは死人よ……やさしくるほし！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "風なく波なく、さしくる潮の、しみじみと砂を浸す音を翁は眼閉じて聴きぬ。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔を覗き込む女房の真実心配そうなを見て、何か知らず無性に悲しくなってじっと湿みのさしくる眼、自分で自分を叱るように、ええと図らず声を出し、煙草を捻って何気なくもてなすことはもてなすものの言葉もなし。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉が、名月や門へさしくる潮がしらと吟じ、深川に住つてゐたのは元祿のころだつた。",
              "citation": {
                "source": "花火と大川端",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さしくる汐を汲み分けて見れば月こそ桶にあれ』と地謡は歌ふ。",
              "citation": {
                "source": "能楽論",
                "author": "野口米次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "年をとって後光のさしくるような人がいるが、このお婆さんがそうである。",
              "citation": {
                "source": "犬の生活",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
