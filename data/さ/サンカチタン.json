          "standard": [
            {
              "text": "酸化チタンは、白色顔料として塗料や化粧品に広く使用されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この日焼け止めは、紫外線散乱剤として酸化チタンを配合しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "光触媒作用を持つ酸化チタンは、環境浄化技術にも応用されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ことに空気を局部的に熱したときに起る対流渦動の実験にはいつもこれを使っていたが、後には線香の煙や、塩酸とアンモニアの蒸気を化合させて作る塩化アンモニアの煙や、また近頃は塩化チタンの蒸気に水蒸気を作用させて出来る水酸化チタンの煙を使ったりしている。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
