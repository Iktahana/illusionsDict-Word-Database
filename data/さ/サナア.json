        "examples": {
          "standard": [
            {
              "text": "サナアの旧市街は、その歴史的景観がユネスコ世界遺産に登録されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イエメンの首都サナアは、世界で最も古い都市の一つと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "サナアの市場では、スパイスや伝統工芸品がたくさん売られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「……イヤラッサナア……マアホンニ……タマガッタガ……トッケムナカア……ゾウタンノゴト……イヒヒヒヒヒ……」　……そのあとから追いかけるように、私の腹の中でグーグーと胃袋が、よろこびまわる音……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならこのコップで行こうで」「まア……イヤラッサナア……冷たい盃や受けんチウタラ」「ヨウヨウ。",
              "citation": {
