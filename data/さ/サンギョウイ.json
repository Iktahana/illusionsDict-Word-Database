          "standard": [
            {
              "text": "大企業では、従業員の健康管理のため、専属の産業医を置いているところが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は長年、製薬会社の産業医として、社員の心身の健康をサポートしてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「最近、職場のストレスがすごいから、産業医の先生に相談してみようかな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "産業医学のは品切れ、半月程のうちに出来ます由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "産業医学の方は十五日ごろの由です。",
              "citation": {
