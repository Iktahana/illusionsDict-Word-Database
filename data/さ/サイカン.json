      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reissue (of a discontinued magazine, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一日も早く復活再刊の日が来ることを祈ります。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "旺文社文庫の廃刊によって、「若いパソコン・ユーザーたちがこの労作を読む機会を失うことを非常に残念に思う」と書いてくれたその人は、続編をまとめることを条件に旧版を再刊しようと申し出てくれたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その市場独占の経過をたっぷり見てきた後で再刊するのなら、せめて長めの後書きを用意して、ＰＣ―９８０１が市場を制覇する、その後の流れにも触れておきたい。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどこのままの体調では、後書きを片づけられないのではないかとの思いもあり、再刊を優先する気持ちに傾きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩野さん自身が「売れない」と太鼓判を押している電子本の取材に、文庫本の再刊という当初の目算から大きく外れて突っ込んで行ったのは、どんな気持ちからだったのか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前、続編の執筆を条件に文庫版の再刊を申し入れてくれた編集者、魚岸勝治さんも、その一人です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年侯井上が薨去した時、当年の弾劾者たる学堂法相の著書『経世偉勲』が再刊されたのは皮肉であった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『経世偉勲』は実は再び世間に顔を出すほどの著述ではないが、ジスレリーの夢が漸く実現された時、その実余人の抄略したものを尾崎行雄自著と頗る御念の入った銘を打って、さも新らしい著述であるかのように再刊されたのは、腕白時代の書初めが麗々しく表装されて床の間に掛けられるようなもんだ。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四六年の中頃から学生新聞の再刊に着手された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾向　一九四五年八月以後戦時中緘口令をしかれていた綜合雑誌が急速に創刊、再刊された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "満一年の後に雑誌が再刊され、私はふたゝび編輯に携はつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回エキスパンドブックとして再刊するにあたり、あらたに取材しなおして、日本電気にパーソナルコンピューターの種をまいた人々のその後の歩みと、ＰＣ―９８０１の成長の過程を別章を立てて補った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは二年の後「ロテイの結婚」と改題再刊されたものである。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを全体何もないやうに…………………」×「氾濫の再刊の言葉」はすこぶるふるつてゐる。",
              "citation": {
                "source": "身辺雑記",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「氾濫」は再刊する最初のモノがなくなつてゐるのだから私はどうでもいゝとは思つてゐたが、私の「鶴」を評する一文を「何故月船君が同誌に掲載させたのだらう」と室生犀星が思つたらうといふ月船君の話に、私は何のことだ機会があつたら同人をやめることだと思つた。",
              "citation": {
                "source": "身辺雑記",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今依て全十二篇を一册に再刊し、同好の士に頒つと云。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が丁度いま、近いうちに詩の雜誌として再刊することになつてゐる「四季」のために飜譯しかけてゐる「Ｍ・Ｌ・ブリッゲの手記」は、その「田園交響樂」と妙な縁があるのだ。",
              "citation": {
                "source": "「スタヴロギンの告白」の譯者に",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主として随筆と文芸時評（これは早稲田文学の再刊と同時にはじめて書きはじめたもので、自分でも文芸時評の書けることが分つたといつて大変よろこんでゐたものだ。",
              "citation": {
                "source": "牧野さんの死",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度偶然に、森本君の亡くなつた京都から『劇作』が再刊されることになりましたが、そのことは、何かしら『劇作』の新しい出発点に森本薫が今もなほゐるといふ気がしました。",
              "citation": {
                "source": "森本薫君について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "与謝野寛氏雑誌明星の再刊を企つ。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今茲乙巳余｜鄙作『詠物詩』ヲ再刊スルノ挙アリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "メルキュウル・ド・フランス誌の再刊に当たり、同人に加わる。",
              "citation": {
                "source": "「ぶどう畑のぶどう作り」後記",
                "author": "岸田国士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもこの詩集が、今日の最も年若い時代の詩歌と、全く無関係の、無縁のものと化し了つてゐないならば、幸ひにこの書の再刊もいささか自己弁護の辞を得た訳になるだらう。",
              "citation": {
                "source": "測量船拾遺",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腋下にひややかな汗をおぼえながらも、私が書園の需めに応じて、この書の再刊を自分に許したのは、凡そ上の一語に理由は尽きてゐる。",
              "citation": {
                "source": "測量船拾遺",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二十一年歳晩著者記ふたたび　あとがき　冬至書房の中島さんが私の『測量船』を再刊して下さるといふ。",
              "citation": {
                "source": "測量船拾遺",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、それの発見は、ちっとも探索者の明敏さいかんによるのではなくて、ぜんぜん単なる注意と、忍耐と、決意とによるのだ。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛の自覚、思慕の自覚の程度により、あるいは、愛の対象、思慕の対象の深さいかんにより、ある時は「物のあはれ」という言葉が、率直で情熱的な思慕の情の直接さを覆うおそれがあり、またある時は、強烈に身をもって追い求めようとする思慕のこころの実行的な能動性を看過せしめるおそれがある。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
