[
  {
    "uuid": "6c6f92e8-5a65-5f3a-a7cc-3a7f3d3d5a2f",
    "entry": "再刊",
    "reading": {
      "primary": "さいかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
