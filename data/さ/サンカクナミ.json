        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "那珂川の洲口といえば、今でも海水、河水の交会する、三角波の重畳した難コースで、岸の上から見てもゾッとするのに、負ぶさってる私は怖くも何とも感じなかった。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦横に吹きまく風が、思いのままに海をひっぱたくので、つるし上げられるように高まった三角波が互いに競って取っ組み合うと、取っ組み合っただけの波はたちまちまっ白な泡の山に変じて、その巓が風にちぎられながら、すさまじい勢いで目あてもなく倒れかかる。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おも舵っ」「右にかわすだってえば」「右だ‥‥右だぞっ」「帆綱をしめろやっ」「友船は見えねえかよう、いたらくっつけやーい」　どう吹こうとためらっていたような疾風がやがてしっかり方向を定めると、これまでただあてもなく立ち騒いでいたらしく見える三角波は、だんだんと丘陵のような紆濤に変わって行った。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう海一面、三角波の頂きが白いしぶきを飛ばして、無数の兎があたかも大平原を飛び上っているようだった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これア大｜暴風になるな」　三角波が立ってきていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に吹き始めた強い南風に先の尖った小さな無数の三角波を乗せて、深谷邸のある岬の方へむくむくと押しかけて行く。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがテイジョ河口の三角波に擽られて忍び笑いしていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち日本の婦人作家は、嶮しい歴史の三角波を、一人一人の楫につけつつ、しかもやっぱり、ひたむきに文学の仕事をつづけてゆくであろう。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖いのは南支那海の三角波だけだよ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "南支那海の三角波というのは、チョウド風呂敷を下から突き上げるような恰好に動くものだそうで、船首に落ちかかる波の頭だけでも大きいのは十｜噸ぐらいの力がある。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵐、熱風、荒くれた土用波、無風帶の脂を浮かした水平面、無人の白い塔を押し流す寒流、その極地の沿岸をあらふ三角波、おれ達の女主人はこの光景のなかをも出沒する。",
              "citation": {
                "source": "展望",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北洋の三角波を、痛快に破って快走をつづけた。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の形相がすっかり変って、三角波が白い波の穂を飛ばし、ミストラル気味の寒い尖った風が、四十日目の惰気をいっぺんに吹きはらってしまった。",
              "citation": {
                "source": "予言",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがはねかえってきて、あとからあとから、間隔をおいておしよせる波と、ぶつかり、ごったがえして、三角波となり、たけりくるっている。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平洋の波もピンチながら、三角波を立てているというところでしょうね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れ込む淡水と海水が混り合って、三角波を立てている。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
