        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第二ページはおかあさんの留守に幼少な娘のリエナが禁を犯してペチカのふたを明け、はね出した火がそれからそれと燃え移って火事になる光景、第三ページは近所が騒ぎだし、家財を持ち出す場面、さすがにサモワールを持ち出すのを忘れていない。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "サモワールを俺さまが立てるてえのか？",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜がふけて見たら、サモワールの湯気で、凍った窓にそれよりもっと綺麗な氷華がついていた。",
              "citation": {
                "source": "モスクワの姿",
                "author": "――あちらのクリスマス――",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆の服にブラッシをかけ、サモワールを沸かし、家じゅうの煖炉に薪を運んでおいて、食卓用の薬味入れを磨く。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その数日前の或る夕方靴屋の主人のところに働いていた病身の料理女が、サモワールを持ち上げようとして跼んだ拍子にのめったまま、全く突然死んでしまった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイがサモワールの仕度を云いつけられて台処で働いているところへ主人が玄関へ飛び込んで来て「太い声で云った。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場の倉庫からサモワールだの箱だの鋏までくすねて来るのを見るのは厭しかった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その並びの一番はずれの、店というよりは一つの窓に、赤銅のサモワールと並んで、そのサモワールそっくりの赤銅いろの顔をした蜜湯屋が控えておるが、その顔に漆黒の顎鬚さえ生えていなければ、遠目にはてっきりサモワールが二つ窓に並んでいるとしか見えない。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は八時すぎに眼をさまし、サモワールの沸くのを待ってお茶を飲むのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "』ミニャイ小父は漆のように真黒な顎鬚を生やした、肩幅の広い百姓で、寒さに凍えた市場じゅうの連中に飲ませるに足るほどの蜜湯でも沸かせるような、あの途轍もなく大きなサモワールそっくりのどてっ腹をしていたが、彼が喜んで轅馬の背に跨がると、その重みで馬の方が危く地面へへたばりそうになった位だ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サモワールを支度するのじゃ、分ったか？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうサモワールは言いつけましただよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうサモワールはいらないぞ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまじって、部屋の中央にはサモワールがしゅうしゅういいながらさかんに湯気を吹き出していた。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、又しても街道の両側を、里程標だの、宿場役人だの、井戸だの、荷馬車の行列だのが、後へ後へと飛びすぎて行き、灰色の村落にさしかかる度毎に、サモワールだの、女房連だの、旅籠屋から燕麦をかかえて飛び出して来る素敏っこい亭主だのが眼についた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには、チチコフ一家にとっては親戚にあたる、皺くちゃの梅干婆さんで、いまだに毎朝、市場へ出かけては、帰って来ると靴下をサモワールで乾かす婆さんが住んでいた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ナースチャは台所へ戻り、火のしに木炭を足し、サモワール用の小煙筒をしかけた。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのもと町で染物工場をもっていたニキフォーロフの家が、集団農場組織についての調べから家宅捜索をくって、銀のサモワール三つ、絹地総体で三百五十ヤール。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニキフォーロフは銀のサモワールを三つ納屋の乾草の中へかくしてもっていたばかりではない。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アグーシャはサモワールをわかし、がんじょうな身体をした、グレゴリーの前へパンを出した。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イクラ、キウリ、ソーセージ、パン、買い込んで、黒田さん樹をかざってくれ、蝋燭に火をつけ、サモワールをとりよせ、愉快に二時頃まで喋った。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ブドー酒、オトカ、キューリ、カプースタ〔キャベツ〕、鶏、腸詰、クルミ、干アンズ、サモワール　○ニキーチナ夫人のスボートでは二十一日に話すことになった。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○車掌の室にサモワールがあり、変電機があり、車内備付品目録がはってある。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "フクロウも啼きたてたし、サモワールもひっきりなしに唸りましたっけ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪と窓ガラスの霜の花をとおしてさしこんだ冬の太陽が、サモワールの上でちらちらし、そのすがすがしい光が、フィンガー・ボールの中で水あびしていた。",
              "citation": {
                "source": "少年たち",
                "author": "МАЛЬЧИКИ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、サモワールを指さしながら、「カリフォルニヤじゃ、お茶のかわりにジンを飲むのさ」と言ったのである。",
              "citation": {
                "source": "少年たち",
                "author": "МАЛЬЧИКИ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワーリカ、サモワールをお立て！",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それに火をつけて、サモワールの下へ押してみかけたかと思うと、つぎの言いつけが聞こえてくる。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
