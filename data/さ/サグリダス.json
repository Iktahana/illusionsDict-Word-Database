[
  {
    "uuid": "f9d3b2bf-a7be-5fa7-99ae-1c3a46680b2a",
    "entry": "探り出す",
    "reading": {
      "primary": "さぐりだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
