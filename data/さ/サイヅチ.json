    "definitions": [
      {
        "index": 1,
        "gloss": "small wooden mallet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
