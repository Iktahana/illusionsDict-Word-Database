[
  {
    "uuid": "eada20ac-ecb9-5d9f-b8c2-d48a2c09bca5",
    "entry": "産品",
    "reading": {
      "primary": "さんぴん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
