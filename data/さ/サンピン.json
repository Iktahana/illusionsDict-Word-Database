      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "products",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は、マニラの生産品を積んで、三池へ向って、帰航の途についた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして燐寸は、中国の国産品と寸分も異わないものが出来上った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "レッテルの四隅には「提倡国貨」（国産品を用いましょう）とれい／＼しく書いてあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、支那の国産品にゃ違いなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛烈な日貨排斥運動に、皆目売れ口がない神戸マッチを輸入して、関税や、賦金や、附加税を取られるよりは、労働賃銀が安い支那人を使って、全く支那の製品と違わない「国産品」を、支那でこしらえ支那で売る方がどれだけ合理的なやり方か知れない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今時の映画と来たら、単なる機械製産品以外の何者でもあり得ない。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし茂吉は国産品のキュービストで、一種の和臭ニヒリストである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の国産品の大量生産……それが現在の大衆読物の氾濫ではあるまいか。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその国産品の氾濫も最早、行き詰まりかけているのではあるまいか。",
              "citation": {
                "source": "路傍の木乃伊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふむ、ではふたりが外からやってきた、尊師は国産品。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日六階に上つて行つた、××県産品陳列会が特別に催されて、反物、陶器、貴金属類がならべられてゐた、掏らうといふ気持もなく、ぼんやりと売場の間を歩るいてゐると、其処に彼をたいへん怒らしたものがある。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分の労働の生産品をよくしよう、発展させようとすればする程、その方法として専門化してゆかなければならない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "公私生産品一律ニ課税サルルハ論ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹たちに買い残しておくべき衣服地や、外国人向きの土産品や、新しいどっしりしたトランクなどを買い入れると、引き出した金はいくらも残ってはいなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽工業の生産品を、今年の冬は一つの工場、その他の勤め先に半年以上勤めた者に、特別の（オールデル）を渡して配給することにしている。",
              "citation": {
                "source": "露西亜の実生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ソヴェトは重工業に力を入れているから軽工業の生産品はまわり切れない。",
              "citation": {
                "source": "露西亜の実生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り忠実に生産に従事して働いているものは食糧及び軽工業の生産品にも左程ひどく欠乏を感じずに暮している。",
              "citation": {
                "source": "露西亜の実生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "国産品も節約をするように。",
              "citation": {
                "source": "祭日ならざる日々",
                "author": "――日本女性の覚悟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村は都会の工場へ安い原料、労働力を提供して都会の工場主たちがこしらえた高い生産品を買わされている。",
              "citation": {
                "source": "今日の文化の諸問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十四年を一〇〇と見て、農産品価格、農村需要品の価格を見ると、　　　　農産品　農村需要品昭和十年　58.4　　64.1同十一年　65.5　　67.5同十二年　70.9　　73.3　昭和十二年五月には、農産品六九・二に対して、農村需要品は七五・三までになっている。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして見ると、直接農村に一般ラジオ加入者が多くなったとは云えず、寧ろ、中農、地主から没落した自作農等の相場への関心或は農産品仲買関係者が、米や繭の売買で幾分かは儲けてラジオでも引こうかという工合になっていることが推察されるのである。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紡績業は明治の初め日本の資本主義発展の基礎になって、少女の安い労働でもって作った紡績生産量を、世界市場へ最も安く売り出し、イギリスのように紡績業が発達していると同時に一般の社会生活が進んでいて労働賃金の高いところの生産品と競争した。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣伝掲示「｜英産品を買え」。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、お土産品を売るというんで自他ともに許しているはずのミカエル街ピルチの店に、売子と埃と好意と空気の他何ひとつ商品のないのに最後に感心。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは有名な葡萄牙の国産品で、やはり迷信的な厄払いのひとつだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は十時間働かなければ賃金をもらって食えませんから、自分のために働いているように思いますけれども、それは実は五時間でできるのであって、あとはすべての生産品は、生産手段をもっている投資家、株主、会社の社長などの利益のために商品として売られて、それは私共の働く賃金のなかにはくり込まれておりません。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が素敵な組織者であること、工場の生産率を高め、生産品の原価を低めたこと。",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このため一九二一年までの単一経済組織における農産品の現物税徴収では、ソヴェト政府と都会のプロレタリアートとが大難儀を経験した。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「すると其処へ……」　さんぴん山左衛門が実に情けなさそうな恰好で現れて刀屋の店へ入る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「さんぴん山左衛門が祖先伝来の此の名刀」　とほろりとした。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
