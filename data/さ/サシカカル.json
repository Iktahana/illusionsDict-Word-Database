    "definitions": [
      {
        "index": 1,
        "gloss": "to come near (to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やがて午前十時になったので、切符を購めて出札口に差し掛かると、「ドッコイ、お待ちなさい。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れて足を引摺り引摺り、だんだん山道に差し掛かる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが夜に差し掛かる頃、一本の試験管が割れ、実験が頓挫してしまった。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀を前にした立花の屋敷の所へ差し掛かると、この辺一帯は溝渠が開いて水が深く、私と松どんとは、じゃぶじゃぶと川の中でも歩くように、探り足をしては進んで行くと、何んだか、頭の頂天の方で、シュッシュッという音がする。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "上野戦争当時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "円タクで白山坂上にさしかかると、六十恰好の巌丈な仕事師上がりらしい爺さんが、浴衣がけで車の前を蹣跚として歩いて行く。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達の列車が巴里盆地にさしかかると、佐野は何の理由もなしに、巴里を極度に嫌がって、バルセロナを懐しがったりして、女のように神経質になっていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帰り途に下谷の御成道へさしかかると、刀屋の横町に七、八人の男が仔細らしく立っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その家の前を過ぎると、道は溪に沿った杉林にさしかかる。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの独活の畑から杉林にさしかかるところ、それこそ真の闇で物凄かった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は橋詰から歩いて行ってちょうど橋の真中にさしかかる。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白木屋横手から、まず永代橋詰まで行くつもりで、その道筋の二つ目の橋を渡る手前にさしかかると、左の河並に横町がある。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レヤチーズたちの乗って行った船が、カテガット海峡に、さしかかると、いずこからともなく、ノーウエーの軍艦が忽然と姿をあらわし、矢庭に発砲したという。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道が西の峠にさしかかるあたりに、半田池という大きな池がある。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房はじめは我慢して神妙らしく担いでいても、町はずれに出て、杉林にさしかかる頃からは、あたりに人ひとりいないし、そろそろ愚痴が出て来る。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が村を出て峠道にさしかかると、うしろから、がらがらと音がして町へ通ってゆく馬車がやって来た。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　村を出はずれて峠道にさしかかるといつものように背後からがらがらと音がして町へ通ってゆく馬車が駈て来た。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と口々に唄いつれて舞台を横ぎり、花道にさしかかる。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、舟は直に遊仙ヶ岡の碧潭にさしかかる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四谷見附を過ぎて、麹町の大通りへさしかかると、橋ひとつを境にして、急に世間が静かになったように感じられました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出先によんどころない用が出来て、時刻がすこし遅くなったので、急いで家を出て、鬼ばば横町にさしかかると、横町の中ほどの大溝のきわに、ひとりの真っ白な婆が坐っているのです。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一町あまりも町を離れて、小さい土橋にさしかかると、むこうから男と女の二人連れが来て、私たちと摺れ違って通った。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "由兵衛は漁師たちに半金の手付を渡し、鯨はあとから引取りに来ることに約束を決めて、若い者ひとりと共に帰って来る途中、高輪の海辺の茶屋の前へさしかかると、そこに友蔵兄弟が待っていて、由兵衛に因縁をつけた。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空の満月が花の上にさしかかる頃であった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "別軍も伊倉を経て吉次越にさしかかると、待ち構えた薩軍は、峠の麓の立岩に在って砲火を開いた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご想像通り、チャーリントンの丘にさしかかるあたりで目を見張ると、またしても男がいたのです、二週間前と同じように。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸口にさしかかる前に僕は飛び降り、何気なくそぞろに通りをうろつきながら近づいていった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお葉が狹い路次にさしかかる時に、折々｜跛の年老いた俥夫に會ふのであつた。",
              "citation": {
                "source": "三十三の死",
                "author": "素木しづ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏も終わりにさしかかると、しきりに日取りのことを口に出しました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "花鳥の引き廻しが銀座の大通りにさしかかると、大勢の見物が立っている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は時々うしろを見かえりながら善光寺門前へさしかかると、源次は怱々に仕事を片付けたと見えて、やがて後から追って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            }
          ]
        }
