          "literary": [
            {
              "text": "生徒は鶏の骨つき腿肉と野菜だけなのに、厚いサーロインが、先生のまえの網におかれた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　先生は、音をたてはじめたサーロインの厚さに、ちょっとおびえているようだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "待つ間、サーロインステーキとポタアジュ、シュガーコーン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーロイン・ステーキに、グレヴィを容器入りで持って来るのは、何ういふものか。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、サーロインステーキ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
