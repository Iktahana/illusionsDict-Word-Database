    "definitions": [
      {
        "index": 1,
        "gloss": "character (in a novel, film, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "須永というあまり香ばしからぬ役割の作中人物の所業としてそれが後世に伝わることになってしまった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小郷を殺すのは、勿論作中人物だが、しかし、小田は鶴雄だとは考えたくなかった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし、古事記の時代に在っては、作者はすべて、また、作中人物であった。",
              "citation": {
                "source": "一日の労苦",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むべなるかな、君を、作中人物的作家よと称して、扇のかげ、ひそかに苦笑をかわす宗匠作家このごろ更に数をましている有様。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく、楽に、速く進行してはいるが、今度は明かに自分が凡ての作中人物の手綱をしっかり抑えているのだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "横堀の身なりを見た途端、もしかしたら浮浪者の仲間にはいって大阪駅あたりで野宿していたのではないかとピンと来て、もはや横堀は放浪小説を書きつづけて来た私の作中人物であった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "作中人物である腰元弥生の心理状態を、開放するために明るい感じを出したといふ計画性は、それはもの言はぬ作中人物に対する伊東氏の愛情であると同時に、その絵を観る観者そのものを、画面効果上の圧迫感から開放するといふ観る者に対する愛情でもある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち作をするといふことは、自己（作者）の『自然』を持つて、他（実際人物乃至作中人物）の『自然』を探し出し、掘り出し、そしてそれを描くといふことである。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "作中人物の心理を説明するにしても、言葉が非常に豊富である。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "見方も作中人物に好悪をつけたやうなところがある。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、作中人物の内部の心理で、事件を運んで行つた形は、巧みなやうであつて実は巧みでない。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄読んだ部分だけでも、作中人物の対話の嶄新さ、夢や狂気にまで滲透してゆく心理の翳など大変なものですが、現在のような環境であのような仕事を続けて行くということは、殆ど言語に絶する忍耐を要する業かもしれません。",
              "citation": {
                "source": "ある手紙",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは伊達に飾ってあるのではない、僕は朝夕これを執って、わが家の同人の誰でもを相手に剣術の練習をする、堪らなく気が滅入って始末のつかぬ時には、これで戦争ごっこをして気分を晴す、武者修業物語を読んで亢奮すると、これを振り廻して作中人物に想いを擬する。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇野浩二氏は親心のびくつく大切な心理を圧えることに用心をされたのではなく、不恰好にそれをださないことに用心をされたのであって、作者と作中人物とがここまで素早く身を躱して、眼にもとまらぬ早さである。",
              "citation": {
                "source": "作家の生活",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "○演技とは俳優が「自己の」肉体を通じて、作中人物の創造に参与し、これを具体化し完成せしむることによって自己を表現せんとする手続きをいう。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "○演技指導とは演出者が「俳優たちの」肉体を介して、作中人物の創造に参与し、これを具体化し完成せしむることによって自己を表現せんとする手続きをいう。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "石坂洋次郎氏の「麦死なず」という小説が、左翼運動への無理解や自己解剖を巧に作中人物の一人（妻）への誇張された描写にすりかえている等の欠点をもつ作品であるにかかわらず、一応興味をもたれたのも、当時のこのような空気とこの作者の示した不健全性こそが結びつき得たからによったのである。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家も読者も作中人物さえもそれぞれ時代の歴史を照りかえし、またその歴史を交互に営んで生きつづけてきているのであるから。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ｇ）登場する学生の姓については、『小泉八雲全集第四巻』（第一書房、一九二七）には訳者田辺隆次の解説があり、作中人物名の比定は安河内麻吉氏（五高第三回卒業生）の示唆によるとあって信憑性が高いように思われるも、曖昧な点もある。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "作中人物の心持が惻々として迫って来るというところに筆が到るには、花圃の人生は、未だ浅くあった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金毘羅利生記」の主人公はあるいは僕の記憶に残った第一の作中人物かもしれない。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを読んだ作中人物の一人は「ああ、ほんたうにあの時には××ちやんのおなかに砂がついてゐた」と言つた！",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学に関する文章の中で、作品の名を挙げずに作中人物の名前がいきなり書かれたならば、多くの人はまごつくだろう。",
              "citation": {
                "source": "長篇小説私見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は作中人物について、一の批判とその批判から来る責任とを持つべきである。",
              "citation": {
                "source": "長篇小説私見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "古証文、手紙の断片、種々の受取書、いろんな日付や品物の覚え書、そうしたつまらない反故るいの中から、作中人物の実生活を探り出そうとしていた。",
              "citation": {
                "source": "十一谷義三郎を語る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、作品の批評に当って、作中人物と作者とを混同するが如き誤謬が、往々にして見られる。",
              "citation": {
                "source": "小説の内容論",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "作中人物が、その境涯に於て作者と非常に異る場合には、かかる誤謬は殆んどない。",
              "citation": {
                "source": "小説の内容論",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
