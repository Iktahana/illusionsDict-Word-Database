        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "馬場はときたま、てかてか黒く光るヴァイオリンケエスを左腕にかかえて持って歩いていることがあるけれども、ケエスの中にはつねに一物もはいっていないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老人の左腕を引っぱっている上等兵が、うしろへ向いて云った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はときたま、てかてか黒く光るヴアイオリンケエスを左腕にかかへて持つて歩いてゐることがあるけれども、ケエスの中にはつねに一物もはひつてゐないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の左腕の傷はまだ糸が抜けず、左腕を白布で首に吊っている。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁塗り左官のかけ梯子より落ちしものの左腕の肉、煮て食いし話、一看守の語るところ、信ずべきふし在り。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は立ち上って食堂から飛び出し、二、三歩追って、すぐに佐伯の左腕をとらえた。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は真中の女に左腕を組まれて居た。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女を自分｜許りのものだと引っ張り寄せるように右腕で女の左腕を抱き寄せて居るが、女はそれがまんざらでもないらしくあしらい乍ら強いて彼に引き寄せられまいとしてジョーンの左腕にすがって居るようにも見える。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイリスはジョーンの説明を打ち切らした程とんきょうな叫び声を挙げ、ジョーンの左腕をぐっと下へ引いた。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもワルトンは、小癪に触って不満そうに停って居るジョーンより前方へ進み出て、右腕を伸し人差指を剣のように前へ突き出し、左腕を上へ直角に曲げ、決闘の型でアイリスに迫った。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手を握り人差指だけを延ばしてピストルの形を造り、左腕を水平に曲げた上へ載せた。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてか、最近左腕を切断された彼は、なほ、からだ中、いたるところに火傷をしてゐました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "手動のミシンでも同じ跡が付くが、左腕だけ、しかも親指の反対側に付く。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "左腕を負傷していて、ぎこちなく不自然な動きをしている。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "革紐は手足や胴体にぐるぐると巻きつけてあって、頭と左腕とだけが自由になっていたが、その左腕も非常な骨折りをしてやっと、かたわらの床の上に置いてある土器の皿から食物を取ることができるだけの程度にすぎなかった。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は苦しい努力をして左腕を紐の許すかぎり伸ばし、鼠が食い残しておいてくれた食物のわずかな残りを手に入れた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は左腕を自由にしようとしてはげしく――猛りくるって――もがいた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧、私のこの左腕に残つてゐる傷痕は――或る肚黒い酒造業者の酒倉をおそつて、番犬と格闘した思ひ出の痛手だ。",
              "citation": {
                "source": "三田に来て",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少年の頃、果物をとる目的で高い枝から枝を伝ふてゐると、突然枝が折れて地上に転落し左腕を折つた経験がある。",
              "citation": {
                "source": "寄生木と縄梯子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少年の頃、果物をとる目的で高い枝を伝ふてゐた時、突然枝が折れて地上に転落し左腕を折つた経験を持つて以来、木登りと聞くと迷信的な怖れを抱いて、忽ち脚がすくんでしまふのです。",
              "citation": {
                "source": "祝福された星の歌",
                "author": "An episode from the forest",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこの前の時、武さんの馬から墜落して、左腕を首から吊つてゐた。",
              "citation": {
                "source": "肉桂樹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スパリ、冴えた一刀があの憎らしくも悩ましい片袖もろ共左腕をそのつけ根から斬って放った。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "左腕を斬って放たれ乍らも右手一つで咄嗟に抜き払ったその一刀が、ぐさりと千之介の腰車に喰い入った。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、五雲様にはまだ満足な左腕が一本ござりましたゆえ、人の一心というものはあのように恐ろしい力を見せるものかと驚いてでござりまするが、半年とたたぬうちに、その残った左腕で、またまた五雲様がまえよりもいっそう名声のお高くなるような絵をいくつもいくつもお仕上げなさいましたのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかわいそうに、今度は残った五雲様のその左腕を、それも意地わるく筆をとるにたいせつな親指と人さし指を、またもむごたらしゅう切りとったのでござります」「そうか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま伊勢佐木町の通りに走りこもうとした慶一は、高志に左腕をつかまれた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはまえと違って、いかさま、江戸のお盆人気をひとりで占めているらしく、わんさわんさの大入り繁盛です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "するてえと、慾の皮のつっぱった連中がわんさわんさとおしかけて、十万円とふしぎな見世物の両方につられてどんどんはいる。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ、さわんなさんなよう、折れるから。",
              "citation": {
                "source": "百合",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、アメリカやヨーロッパのよくばり連中が、シャベルをかついで、さびしいいなかの港、サンフランシスコに、わんさわんさと出かけて行っては、砂金をほった。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
