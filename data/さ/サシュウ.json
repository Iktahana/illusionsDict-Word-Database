    "definitions": [
      {
        "index": 1,
        "gloss": "checking and receiving (an invoice, goods, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしてそれらのいわゆる心のなかの史跡や記念物のほうこそより急務の調査収集を要しなければならぬ問題である。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "封入の金子、貴殿俸給の内渡に有之候間御査収｜願上候　　　　　　　　　　　　　　　　　匆々　　つ　も　り印」　封入の札を数えてみると十円で七枚あった。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんとお写真をお飾りなすって、おやさしゅうござんすわね」　葉子はしんなりと立ち上がってその写真の前に行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご美男でござりまするか」「ええもう、それはそれは、お気高くて、やさしゅうて、絵からぬけ出たように美しい若上人さまでござります」　さらに光った。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "やさしゅうちいさな声で、ご免下さりませと訪のうた者がござりましたゆえ、出てまいりましたら、式台際に顔の真ッ白い――」「女か」「いいえ、女のような男でござります。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やさしゅうて、すなおで、かわゆらしゅうて、そのうえ主人思いの、なにひとつ非の打ちどころもない子でおじゃりますゆえ、春菜もいっそほんとうの妹にしたいと、口ぐせに申していたくらいでおじゃりました」　名人は聞き終わるとともに、じっと瞑目しながらうち考えたままでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「画から女が抜け出るより、あなたが画になる方が、やさしゅう御座んしょ」と女はまた髯にきく。",
              "citation": {
                "source": "一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "我まま云ってすみませんでした」　美くしい詩を作る人は親にもやさしゅうございました。",
              "citation": {
                "source": "無題（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やさしゅうしてすむことを、わざとむずかしくするのが、いかんのや。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おひさしゅうございますのね。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちいち心に触れて詠歎ひさしゅうしているといった感じである。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十兵衛、どこかに、今宵お使番の方が見えておるのか」「いや、さようなことは、表役人からもうけたまわりませぬが」「へんなこともあるものじゃ――まさしゅうこれは家康公のお手紙で、おまけに今夕のお日附となっている」「いかに早足なお使番でも、夕方からただいままでに、ここへ着くともうすのはふしぎなしだい。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるのは、心の故郷だけです」「でも、ばば殿も、今では其女にやさしゅうしてくれる様子。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京へは近うございますが、大阪へは廻り道で、山から山を音羽や笠取の里へとって、宇治の富乃荘へも出られると申します」「うむ、まさしゅうそれへさしてまいったに違いあるまい。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしゅう、ここでは釜は鍋に先を越されたわ。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "北条方とすれば、まさしゅう、天皇の詫び状なりと、鬼の首でも取ったように、見るであろうよ」「ま。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
