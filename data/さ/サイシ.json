  {
    "uuid": "94350a52-fe2c-5609-93ce-04d1481c2bd2",
    "entry": "祭祀",
    "reading": {
      "primary": "さいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
