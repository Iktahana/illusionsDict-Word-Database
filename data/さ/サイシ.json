[
  {
    "uuid": "41e7ac95-d9c3-5ba8-9a49-c2fe094494cd",
    "entry": "再思",
    "reading": {
      "primary": "さいし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "reconsideration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "再思三省すべきであらう。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに毘陵の趙再思という者が、偶然泰興を過ぎたので、知合であったから季因是の家をおとずれた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "毘陵は即ち唐家のあるところの地で、同じ毘陵の者であるから、趙再思も唐家に遊んだこともあって、彼の大名物の定鼎を見たこともあったのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙再思はただハイハイといっていると、季は重ねて、「唐家の定窯の方鼎は、君もかつて御覧になったことが御有りですか」といった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙再思は仕方なしに俟っていると、暮方になって漸く季は出て来て、余怒なお色にあるばかりで、「自分に方鼎を売付けた王廷珸という奴めは人を馬鹿にした憎い奴、南科の屈静源は自分が取立てたのですから、今書面を静源に遣わしました。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけても、その大根を拾ひあげるとき、私は何だかきまりが悪かつた、禅坊主らしくもない羞恥感である、古徳先聖の勝躅を再思三考せよ（巻煙草の吸殼を拾ふ場合は別である、それは恥ぢなければならない、恥づべき享楽のあらはれだから）。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巍至誠至心、直語して諱まず、尊厳を冒涜す、死を賜うも悔無し、願わくは大王今に於て再思したまえ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに毘陵の趙再思といふ者が、偶然泰興を過ぎたので、知合で有つたから季因是の家をおとづれた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "毘陵は即ち唐家の在るところの地で、同じ毘陵の者であるから、趙再思も唐家に遊んだことも有つて、彼の大名物の定鼎を見たことも有つたのである。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙再思はたゞハイ／＼と云つてゐると、季は重ねて、「唐家の定窯の方鼎は、君も曾て御覧になつたことが御有りですか」と云つた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙再思は仕方無しに俟つてゐると、暮方になつて漸く季は出て来て、余怒猶ほ色に在るばかりで、「自分に方鼎を売付けた王廷珸といふ奴めは人を馬鹿にした憎い奴、南科の屈静源は自分が取立てたのですから、今書面を静源に遣はしました。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢は正直だ、意識しない自分をさらけだして見せてくれる、再思三省。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで落合天童は時代のおのづから要求し落ちつくところを再思三考に及んで、彼の自宅の町内の天妙教支部を訪れた。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に『非命の死と罪悪』の一節は、正に本章の圧巻で、再思三考に値する。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢明なる先覚者の再思三慮すべき点はここにあるのである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばそれは小さいしかし恐ろしい猛獣がやけに檻にぶっつかるかと思うような音である。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいしょに、緑の蛙が目をさましました。",
              "citation": {
                "source": "二ひきの蛙",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "又三郎が昨日のことなど一言も云わずあんまりそらぞらしいもんですからそれに耕一に何も云われないように又日曜のことなどばかり云うもんですからじっさいしゃくにさわったのです。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町にきた、さいしょのころは、ひどくせまくるしい気がして、さびしい思いをしたものです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいしょきみの下に使われていたときも、わたしはきみに、おまえといわれると、やはりおなじ感じがして、いわば地面におしふせられるようにおもったものだ。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいしょの日は、こんなふうにしてすぎましたが、それからは、だんだんわるくなるばかりです。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかべのすぐそばに、春のさいしょの黄色い花が咲いていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、さいしょの日も、つぎの日も、ひとりとして、うまくやってのける者がない。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、さいしょの広間にはいりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずさいしょに、それを取り出さなければだめだね。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、さいしょの小鳥がさえずりはじめました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは、自分たちの名前の、さいしょの文字を、緑がかった、灰色のみきに、ほりつけました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りに集まる男の子たちの中で、いつもあのわる口の歌をうたっているよくない子は、いつか、いちばんさいしょにうたいはじめた、あの男の子でした。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、この子がいちばんさいしょにうたいだしたのですし、それに、いつもきまって、歌の仲間にはいっていたのですから。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、さいしょに歌をうたいはじめた、あのいじわるの、いたずらっ子には？",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
