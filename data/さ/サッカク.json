    },
    "definitions": [
      {
        "index": 1,
        "gloss": "illusion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは必ずしも彼の錯覚ではなかつた。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十年前の錯覚だらけの記憶をそのまま大事にそっとしておくのも悪くはないと思うのである。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今でも盆踊りというとその夜を思い出すが、不思議な錯覚から、その時踊っていた妖精のような人影の中に、死んだその人の影がいっしょに踊っていたのだというような気がしてしかたがない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "颱風もなければ烈震もない西欧の文明を継承することによって、同時に颱風も地震も消失するかのような錯覚に捕われたのではないかと思われるくらいに綺麗に颱風と地震に対する「相地術」を忘れてしまったのである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも何かの錯覚であるかどうか信用の出来る資料がないから不明である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋近来の流行が、一方には裾を短くしてほとんど膝まで出し、他方には肉色の靴下をはいて錯覚の効果を予期しているのに比して、「ちよいと手がるく褄をとり」というのは、遙かに媚態としての繊巧を示している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこの種の縞が「いき」と感ぜられるときがあるとすれば、放射性が覆われて平行線であるかのごとき錯覚を伴う場合である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしずっと年を取った後に、再びこうした規則正しく繰返される「試験」の峠を越そうとは予期しなかったが、そのおかげで若い日の学生時代の幻影のようなものを呼び返し、そうしてもう一度若返ったような錯覚を起こさせる機縁に際会するのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中が真暗くなったような錯覚を起こさせるのがジャーナリズムの狙い所ではあろうが、考えてみるとどこの世界にでも与太者のユーモレスクのない世界はないであろう。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお伽噺のような時代が今日までつづいているという錯覚がすべての間違いの舞台の旋転する軸となっている。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう場合でも、一方では音の方向知覚というものの本来不確実なために、また一方では劇場の複雑な反響のために、なおその上に、視像の暗示にだまされる錯覚のために、実際はたいした不都合は感じないかもしれない。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが音響の場合には、これに相当するような錯覚を起こすことはむつかしい。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをまた一面から云うと、甲の味いを感ずるのは何等かの錯覚に基きやしないかと疑うことも出来る。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台の奥から機関車のヘッドライトが突進して来るように見えるのは、ただ光力をだんだんに強くし、ランプの前の絞りを開いて行くだけでそういう錯覚を起こさせるのではないかと思われた。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "醒めての後にも、私はそのヴィジョンを記憶しており、しばしば現実の世界の中で、異様の錯覚を起したりした。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの魔法のような不思議の変化は、単に私が道に迷って、方位を錯覚したことにだけ原因している。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時私は、未知の錯覚した町の中で、或る商店の看板を眺めていた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この偶然の発見から、私は故意に方位を錯覚させて、しばしばこのミステリイの空間を旅行し廻った。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "錯覚された宇宙は、狐に化かされた人が見るのか。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は私の物語を冷笑して、詩人の病的な錯覚であり、愚にもつかない妄想の幻影だと言う。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "有限な語彙の限定は形式の限定と同様往々俳句というものの活動の天地を限定するかのような錯覚を起こさせる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろいろいろの無定形無季題短詩の試みがあるのは多くはこの錯覚によるのではないかと想像される。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の関係もないことであるにもかかわらず、ふとした錯覚で何かしら関係があるような気がしたのは、たしかに自分の頭の迷誤である。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、これも不思議な錯覚の一例として後日の参考のためについでに書添えておくこととする。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも不思議な事に、仮面の顔というものは、永く見ていると、それが色々に動き変わるような錯覚を生じるものだが、この場合でもやはりそれがある。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その事を云いだすと二人の子供も「オヤ、ほんとにそうだ」と云って同意したから、強ち自分だけの錯覚ではないらしい。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもマッチやライターが手近にある生活になれていたので、この絶海の孤島に漂着しても、そんなものすぐそばにあるようなさっかくをおこしたのだ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
