[
  {
    "uuid": "dee53383-4e8c-5caf-816f-f2fa2732cdf1",
    "entry": "錯覚",
    "reading": {
      "primary": "さっかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
