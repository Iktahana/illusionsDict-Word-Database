        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「それにこの森はすっかりおれの森なんだからさっきのように勝手にわらびなんぞ取ることは疾うに差し止めてあるんだぞ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝顔の絵をかいた団扇を暑中見舞に持って来たために、出入りを差し止められた商人もあるという。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に叔父の待合入りをピッタリと差し止めたので、私はその当時、八方の待合からかかって来る電話を聞かされてウンザリさせられたものであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが引っ張ってくるから、あなたからぐっと差し止めなせえよ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、あの野郎があなたの言うことを聞かなかったら、そのときゃあおれらが黙ってねえから」「それじゃ、とにかく差し止めてみよう」「それじゃ、みんなは厩舎の前へ行って、あそこで待っていてくれ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし命令ではこの三点のみが禁止され、販売の差し止めは指示されなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の宮の時には別にお差し止めの沙汰もなかったので、今度も大丈夫だろうと多寡をくくって持ち出して来たところが、右の次第で金銀だけは取りのけろと云うことになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこで、観世物の方はお差し止めか」「いいえ、相変らず木戸をあけています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く差し止めてしまえばいいのだ」「わたしは見ませんが、子分の亀吉は話の種に、地蔵の踊るのを見に行ったそうですから、あいつと相談して何とか致しましょう」　半七は請け合って帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろこの土地を人買いが立ち廻るというので、国守が旅人に宿を貸すことを差し止めた。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の館へ出入りを差し止めるとも言った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう制札であろうと、通行お差し止めと書いてあらば開門無用じゃッ」「ほほう、なかなか口賢しいこと申しおるな。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "松平伊豆守近藤右門へ」　意外にも吟味差し止めのいかめしやかなお書状でしたから、晴れたと見えたのもつかのま、この世の悲しみを一度に集めたごとく青々と面を青めると、力なく言い捨てました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この狂言差し止めたッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "神妙にせいッ」　不意をうたれて、当の三左衛門はいうまでもないこと、土間いっぱいの見物たちがわッともみ声あげながら騒ぎたったのを、「八丁堀の右門が不審のかどあって差し止めたのだッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがおやぢ、はじめそれをやらせられる時に、あまり名譽なことぢやないから誰にも言つちやならんぞと差し止められてゐたらしいんだ。",
              "citation": {
                "source": "女",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（後に出る変態性欲用具の項参照）　こうした上流の人士が民心の頽廃を嘆いて、吾が児の活動見物を差し止めるのかと思うと可笑しい。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は念のために八丁堀同心へその次第を申し立てると、不審の筋ありというので葬式はひとまず差し止められた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の出兵を差し止める道は、今夜中に成田頼母を倒すよりほか、道はないと存ずるが、方々の御意見は？",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家は箸を啣へた儘じつと考へ込んでゐたが、暫くすると、「いつぞや越前が早生の果物なぞは侈奢の沙汰だといふので、差し止めたやうには思ふが、若芽薑のやうなものまで布令を出さうとは思ひがけなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自殺かどうかがはっきり決定されるまで、記事を差し止めたのだ」　俊夫君は、しばらく考えておりましたが、「どうも、いま聞いただけでは、さっぱり見当がつきません。",
              "citation": {
                "source": "自殺か他殺か",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮人ちゅうのは一体に猜疑深い劣等民族ですから」「それは待った」と大村は手を上げて思い深げに差し止めた。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそのお芝居ばっかりは、お差し止めにならないと大変な事になります。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに何か不都合な障害があってそれを描くことが差し止められると神経衰弱的傾向を現し自狂的となりやすい。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、オフェリヤ殺し場は、遂に差し止められて、あの無残な夢を新たにしようとした、観客を失望させた。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も此興行は三日きりで差し止めにあつてゐる。",
              "citation": {
                "source": "由良助の成立",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは側ではらはらしましたが、三上はわたくしの口出しを差し止めました。",
              "citation": {
                "source": "死因の疑問",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、やがてその洋装娘が、宇利氏の前までやって来て切符を差出すと、受けとった宇利氏は、娘をやり過して置いて、いきなり手を前に出し、あとから神妙について来て、伝さんへ目で挨拶しながら通り抜けようとした案内人を、ピタリさしとめた。",
              "citation": {
                "source": "三の字旅行会",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてやるぞ」　と手をさしのばして、杉田の顔をつかみかかろうとするのを、ドクトルは横合からさしとめた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の放送局内の騒ぎについては、すぐ記事さしとめの命令がその筋から発せられたので、世間には洩れなかったが、実は局内ではたいへんな騒ぎで、局長以下、みんな真青になってしまい、その下にいる局員たちは、仕事もなにも、手につかなくなってしまったほどだった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
