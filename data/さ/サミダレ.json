    "definitions": [
      {
        "index": 1,
        "gloss": "early-summer rain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たちばなの昧爽時や古館　五月雨頃の、仄暗く陰湿な黄昏などに、水辺に建てられた古館があり、橘の花が侘しげに咲いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙燭して廊下通るや五月雨　降り続く梅雨季節。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨や御豆の小家の寝覚がち「五月雨や大河を前に家二軒」という句は、蕪村の名句として一般に定評されているけれども、この句はそれと類想して、もっとちがった情趣が深い。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に夏の部で評釈した句「五月雨や御豆の小家の寝醒めがち」も、どこか色っぽい人情を帯びてはいるが、詩情の本質においてやはりこれらの句と共通している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨や蚕わづらふ桑畑　暗澹とした空の下で、蚕が病んでいるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の道や葵かたむく五月雨　曇暗の雲にかくれて、太陽の光も見えない夏の昼に、向日葵はやはり日の道を追いながら、雨にしおれて傾いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに「春雨」「五月雨」「しぐれ」の適切な訳語を外国語に求めるとしたら相応な困惑を経験するであろうと思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日降りつづく五月雨もきょうは夕方からめずらしく小歇みになったが、星ひとつ見えない暗い夜に、牛込無量寺門前の小さい草履屋の門をたたく者があった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は古人の「五月雨の降り残してや光堂」の句を、日を距ててではありましたが、思い出しました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨も夕暮れも暮れゆく春もこの二人にはとりわけて悲しからずとりわけてうれしからぬようなり、ただおのが唄う声の調べのまにまにおのが魂を漂わせつ、人の上も世の事も絶えて知らざるなり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてモンスーンのないかの地にはほんとうの「春風」「秋風」がなく、またかの地には「野分」がなく「五月雨」がなく「しぐれ」がなく、「柿紅葉」がなく「霜柱」もない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは北海道にも珍らしく五月雨じみた長雨がじと／＼と薄ら寒く降り続いた六月半ばの事だつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨のしと／＼とする時分、家内が朝の間、掃除をする時、縁のあかりで氣が着くと、疊のへりを横縱にすツと一列に並んで、小さい雨垂に足の生えたやうなものの群り出たのを、黴にしては寸法が長し、と横に透すと、まあ、怪しからない、悉く茸であつた。",
              "citation": {
                "source": "くさびら",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――五月雨の陰氣な一夜、坂の上から飛蒐るやうなけたゝましい跫音がして、格子をがらりと突開けたと思ふと、神樂坂下の其の新宅の二階へ、いきなり飛上つて、一驚を吃した私の机の前でハタと顏を合はせたのは、知合のその男で……眞青に成つて居る。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」五月雨はじと／＼と降る、外は暗夜だ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月　五月雨の茅屋雫して、じと／＼と沙汰するは、山の上の古社、杉の森の下闇に、夜な／＼黒髮の影あり。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨の濁水滔々たる桂川の上流から、新しい長持に錠を卸して、上に白い御幣を置いたものが流れて来た。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあげく五月雨の降る或る夕方のこと、手に手に棒千切を持った十四五人が「金貸し後家」の家のまわりを取り囲むと、強がりの青年が三人代表となって中に這入って、後家さんに直接談判を開始した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨の景にしろ、月夜の景にしろ、その中の主要なる部分――といふよりは中心點を讀者に示して、それで非常に面白味があるといふやうに書くのは、文學者の手際であらうとおもふ。",
              "citation": {
                "source": "「自然を寫す文章」",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖の水まさりけり五月雨　去来の傑作である。",
              "citation": {
                "source": "天狗",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はもう幻影に過ぎなかった愛の世界を失って娑婆即ち忍苦の世界の者となったのみだ、其娑婆に在って又ふたたび幻影の世界を求めて、遅かれ速かれふたたび浅ましい物の香に接しようとも思わぬ、と取留めも無く、物を思うでもなく、思わぬでもなく、五月雨のしとしとと降る頃を、何か分らぬ時を過した。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度朝からしとしととした五月雨、それが一人旅の侘びしさを一しほ誘ふ。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ何だね、五月雨時分、夜中からあれた時だね。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "極性な朱でござったろう、ぶちまけた甕充満のが、時ならぬ曼珠沙華が咲いたように、山際に燃えていて、五月雨になって消えましたとな。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――五月雨の徒然に、踊を見よう。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは五月雨の降る比であった。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　五月雨の比は過ぎて世は七月の暑い世界となった。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さみだれが煙るように降る夕方、老妓は傘をさして、玄関横の柴折戸から庭へ入って来た。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さみだれの季節になると子供は都会の中の丘と谷合にそれ等の実の在所をそれらを啄みに来る烏のようによく知っていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……垣の卯の花、さみだれの、ふる屋の軒におとづれて、朝顏の苗や、夕顏の苗……　またうたに、……田舍づくりの、かご花活に、づツぷりぬれし水色の、たつたを活けし樂しさは、心の憂さもどこへやら……　小うたの寄せ本で讀んだだけでも一寸意氣だ、どうして惡くない。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
