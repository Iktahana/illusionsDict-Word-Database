        "index": 1,
        "gloss": "March Revolution (Austria and Germany, 1848)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
