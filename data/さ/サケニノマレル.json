    "definitions": [
      {
        "index": 1,
        "gloss": "to drink too much and lose self-control",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
