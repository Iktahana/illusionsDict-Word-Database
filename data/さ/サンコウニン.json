    "definitions": [
      {
        "index": 1,
        "gloss": "invited witness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "委員会は、事件の真相究明のため、数名の参考人を招致した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は事件の重要参考人として、警察から事情聴取を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国会での参考人質疑は、テレビで生中継された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その当夜、現場で被害者に出逢ったのは僕ひとりで、また一方には加害者を警察まで送って来た関係もあるので、僕は唯一の参考人として警察へも幾たびか呼び出された。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "下田夫婦や、林の細君や、安田も参考人としてたびたび取り調べを受けたけれども、ついに何らの手懸かりも得られなかった。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして決心したように立上ると、参考人と云う名目で、金剛と不二の二人を連行して、本署へ引挙げることにした。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村は、事件の参考人として、さきに帰って行った星尾、園部、川丘みどりの三人を、出来るだけ早く、この場へ召喚することが必要であると思った。",
              "citation": {
                "source": "麻雀殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点に関しては、藤枝、林田及び私は参考人の立場に立つて、いちいち説明し得べきことを立証した。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林田も、今日は私と共に警部に一応参考人として取り調べられる立場にいるので、これも多くを他の者に対してはきかなかつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ参考人となつて警察へよばれる経験もやつて見るさ」　と林田は笑いながらいう。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、参考人だし、いかに警部がああ云つても、どうしても普通の人に対するときとはちがうので、かなり鄭重に取り扱われた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、奥間巡査、その妹を参考人として訊問の必要があるから、君、その楼へ行って同行して来給へ。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日出所した古我判事は直に本事件の参考人として、被告の妻静子、証人として小林定次郎、神戸牧師の二人を喚問する事を書記に命じた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十九日支倉の妻静子は予審廷に召喚せられて、参考人として古我判事に訊問せられた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は更に四月六日静子の母を参考人として放火事件の取調を行い同日広島県下から召喚した貞の父を調べたが、いずれも今までに判明した事実を裏書きしたに過ぎなかった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に静子の母、中田かまを参考人として一回都合三十六回に渡って訊問を行なった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所からの照会は支倉の第三回訊問後彼の自殺を企てようとした事件の為参考人銀之助を取調べた直後出したものらしい。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に裁判長は被告に向って、今までの証人並に参考人の陳述につき、意見、弁明、反証等はないかと聞き質した所、被告支倉はなしと答えたので、その日は閉廷となり続行する事となった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海事工廠の造艦学泰斗ウイリアム・ホワイト卿、ロバアト・ステイル氏なども出廷して、参考人として意見を徴されている。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうか、では君は後から××署へ来い、参考人だぞ！",
              "citation": {
                "source": "地図にない街",
                "author": "橋本五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手をすると、自分は参考人か容疑者として警察へ引っぱられるかもしれん。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一応の取調べを受けに、二人の責任者が参考人として自動車に乗せられ、本署のある町まで同行を求められたときに、練吉は自分も乗う込まうとして加藤巡査にひきとめられた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰公の参考人として取調べられたのは申す迄も無い。",
              "citation": {
                "source": "越後獅子",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼柳丸には稚拙な笑い絵を描いては仲間に無料でくれてやる道楽があって、その一枚が警察の手へ入ったために大騒動、彼に絵をもらった落語家一同が参考人としてみんな呼び出されたという騒ぎもあった。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "次回公判にはその占師も参考人として登場することになつてこの日は閉廷となつた。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "参考人としてではなく、殺人嫌疑で訊問されていたのだった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でももしよかったら、今晩……、（すこし調子づいて）じつはね、さっき向うで相談したんですが、今晩、〈絲満南風太郎の参考人の会〉をやろうってことになったんです。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "西貝、古田、久我、葵、〈那覇〉のボーイ……、絲満事件の参考人や容疑者たちの写真である。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "中谷も参考人として喚ばれましたが、親しかった以前に引かえて、彼は冷然と私に不利な証言をしました。",
              "citation": {
                "source": "流転",
                "author": "山下利三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験の主な目的は、多くの参考人の言から綜合すると、人間は血液をどの程度に失えば死ぬのか、血液の代用として生理的食塩水をどれ程注入することができるか、どれだけ肺を切りとることが可能か、人脳の切開はどこまでいけるか、心臓の手術は如何、というようなことらしかった。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外の「手術」の内容は、前述した如く本人が米軍に逮捕されてから間もなく自殺したため、他の参考人たちの口供書から推察するよりほかに知る由がなかった。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、最も重要な参考人の証言は、法廷で朗読された――ロンドン塔の内で聴取されたものであって、いまは照合も査証もする由のない口供書だった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "教頭が出てきての説明では、片岡先生のは、ただ参考人というだけのことで、いま校長がもらいさげにいったから、すぐ帰ってくるだろうといった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
