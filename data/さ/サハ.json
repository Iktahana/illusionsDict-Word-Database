    },
    "definitions": [
      {
        "index": 1,
        "gloss": "left wing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は社会党の右派でも左派でもなければ、共産党員でもない。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "メイエルホリドは、彼の「再建設期のソヴェト劇場の任務」を、この左派｜同伴者詩人の作品で、どんな工合に実現して行ったろうか？",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由党のこの反共声明は社会党左派といわれていた同党内のより少い反動主義者のグループの一部のものに極めて注目すべき喜劇を演じさせた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "内閣の椅子を占めることに対して情熱を感じた左派のグループ中、加藤勘十と鈴木茂三郎等が中心となって外国記者団を引見し、社会党左派が共産党に接触を保ってきたのは、勤労大衆を同党の組合総同盟に獲得するためであった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この声明はただちに日本国内にも反映し、社会党左派の一部がとったその態度は保守的政党の嘲笑を買ったばかりでなく、社会党左派そのものの内部から激しい批判を受けた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『読売新聞』は一貫して犯罪性を強調し、この裏に共産党ありと、あすにも犯人があがりそうに不安な雰囲気をかきたててきたが、今日の『読売』をみると一役すんだのだろう、国鉄中闘委員会左派十四名免職をトップに、あとは野球、囲碁へと注意を流している。",
              "citation": {
                "source": "犯人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由｜之魁・圧制政府顛覆・一死報国のスローガンをかざして、明治十七年九月二十三日加波山に旗上げして一敗した自由党左派の加波山事件は、この村からいって山の反対側にあたる下館を基地として起こった。",
              "citation": {
                "source": "加波山",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "加波山事件までの左派自由党の社会的地盤は地方における「由緒ある門閥の家柄」――桜井君にきけば、当時の記録にそのようにあるよし――徳川時代から氏を称した郷士富農であって、幕府封建制に代った明治絶対主義政府との妥協を拒否しつつ、翌明治十八年の秩父事件ではついに働く農民貧民の大衆を動員するにいたった。",
              "citation": {
                "source": "加波山",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで肥後に会同した清河その他に、薩藩左派の抬頭を報じてやがて薩藩極左派と連絡できる素因をつくったのは長州竹崎の商人｜白石廉作である。",
              "citation": {
                "source": "新撰組",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "この導線こそ維新変革史を通じて一貫した「左派」の特質であった。",
              "citation": {
                "source": "新撰組",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "一片一片の要素としては「左派」浪士団に存在したすべてのものがここにもまた馳せ参じていた。",
              "citation": {
                "source": "新撰組",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の春、任期を満たした彼は、再び自由党候補を破って再任したが、彼が属する左派社会党のほかに、労農党と共産党の票が支持していたのである。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　社会党左派の、鈴木茂三郎委員長は、私にとっては、四十年前の新聞社の同僚であり、当代の政治家中では、最もなつかしい存在である。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次読む人読まぬ人――三人の政治家――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マツァは未来派は技師の世界から生れたもので汽罐車や速力やをとらえようとしていると云っているというので、それは技師の心となど云えないこと、未来派左派が詩で鍛冶派（マヤコフスキー）であった理由、未来派の手法は、新しいリアリズムにより動きをもたらさぬこと。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "西尾官房長官に不信任案が出たときも、党内の左派が同調の動きをみせたので、これをまとめて否決するのに苦労した。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煎じ詰めたところ、極端な破壊思想に対して、国家の伝統を守ろうとする立脚点に立っているわけだから、左派に属する人士の活動と正対して、なんらかの活動を致さなければならない筈である。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無政府主義者のような別種の急進左派もまたこの呼びかけを繰り返した。",
              "citation": {
                "source": "ファシズムとは何か",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、英国の左派知識人が本当にドイツや日本の戦勝を求めていたわけではなく、彼らの多くが、自国がおちょくられるのを見たくて仕方なかっただけであり、最後の勝利をもたらしたのが英国ではなく、ソ連か、もしかするとアメリカであると感じたかったのだ。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "平均的左派知識人が信じていたところによると、一九四〇年には我々は敗れていたし、一九四二年にはドイツがエジブトを突破していたし、日本が占領地から駆逐されることもなかったし、米英の爆撃はドイツに何らの影響も与えなかった。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌の色を問わずマルクス主義者その他左派の著者で、この条約の予言に近づけた者はいなかった。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "左派層に彼らが受けている隠れた理由は、二人とも陸軍省と不仲であるというものだ。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前、左派の一部の人の文字にも、そんなのを見たが、ずいぶん気をまわすものだと苦笑にたえない。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "造花造りの羽振のよさは、あゝ、滑稽なこつた滑稽なこつた。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（とまれ人は、読んで感得するだけ感得するのであり、聞いて感得するだけ感得するのであり、見て感得するだけ感得するのであり、たづさはつて感得するだけ感得するのである。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかこれは、ロマンチシズム開花する国で云ふにふさはしいことのやうだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生の芸術の貴重さは、彼が人間としての人格の貴重さから出発する。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその妻のごとき、純日本的な可憐な女を、彼のいわゆる『野蛮人』である西洋人の社会に、孤独で生活させることの痛ましさは、想像だけでも耐えがたい残忍事だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ彼の好んで使ふ「鬼」といふ言葉が、その雅號の上でも文學上でも、また人物の風采上でもふさはしいことを強く感じた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに絢爛たる面貌にくらべて、四肢の貧しさは、これまた驚くべきほどであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさは上天気ゆえ、家内と妹を連れて、武田神社へ、桜を見に行く。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
