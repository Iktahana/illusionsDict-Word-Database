  {
    "uuid": "eb4813de-3228-55ea-9c94-0df641b69744",
    "entry": "刪定",
    "reading": {
      "primary": "さんてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
