      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(computer) process",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、そういう方でも、たいていは足し算程度で、まだ掛け算にはなっていないように私には思われます。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに私が足し算程度というのは、物をあくまでも物と見て、その経済的利用価値だけを考えての使い方です。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ堂脇のお嬢さんていうのには、俺は全く憧憬してしまった。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その叔母さんていうのは、編集長さん、あなたのこのあいだの翻訳にあんなに大勢の予約者を集めてくれた人なんですよ――』『ああ、あの親切な婦人ね！",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階のお母さんていうのは雲月斎玉兎っていう奇麗な人だろう」「イイエ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "職人は庄さんていふんですが、さうなりや何でこんな唖なんぞう守つて居るもんですか、茶屋女を受け出してね、此は家へ暫くやつて置いて筑波向へ行つちまつたんでさ、それでも此はうつちやられたとは思はねえんですから……」　剃刀は顎を滑かにさうして徐ろに走る。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがね旦那、その亭主は庄さんていふんですが仲々いゝ男でね、一寸お世辭もいゝし、つきあつちや惡いことはまあ有りませんよ。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、今の大だんなの七郎兵衛さんと、ご沈落しなさっている兄の八郎兵衛さんと、このおふたりが成人なすったときにも、先代の親ごさんていうのがさっそく言い伝えどおり、それぞれむすこさんにお嫁をめとらしたんですがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "するてえと、ご運わるく兄の八郎兵衛さんには女のお子ども衆が生まれ、弟の七郎兵衛さんにはまたご運よくもあの陽吉さんていう男の子どもが生まれたんでね、代々の家憲どおり、七郎兵衛さんが兄をさしおいて、今の生島屋の何万両っていうご身代を、ぬれ手でつかみ取りにしちまったんですよ」「なるほど、わかったわかった。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつもひっぱりこもうと思ってるんだけどね」「あの人、浅井さんていうんでしょう？",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりひどいことをするとな、人間がゆるしても、神様が許さんていうてな。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩濱さんていふのは好人物だけれど消極的な人ですからね。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――権さんだけじゃあ分らない」「……ああ、じゃああの男が権さんていうのかい、こないだ蒲団を背負って行った出眼の男が」　ろくは、合点をした。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金ちゃんにきくと、アンポンタンが知る前に阪地へいった人なのだそうだ、曙山さんていうのだといった。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんていうたら何につけ彼につけ稚殿の事ばっかり……」「笑いなんな。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幹事さんていうものは、こういうときこそいるものなのよ」　皮肉そうにそう云ったのは、三輪である。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おつさんていふ人は、あれは此のうちの何をして居る人？",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「野呂さんていふんだ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のきいてるのはおりかさんていふんだ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今の人におりかさんて云つたら、そんな人はゐませんと云つたが、此處ではおちかさんていふのかい。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女の子のお父さんていうのが、恐い顔して、一言も口をきかずに見ているんですって。",
              "citation": {
                "source": "遺産",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「苗字はなんというんです」と押返して尋ねると、苗字は知らないが平五郎さんで、平五郎さんていえば近所じゅうどこでも知ってるから、苗字なんかなくっても、とどくのに違いないと保証する。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早く顔を洗っていらっしゃいな――小母さん、この人が鶴子さんていうんですの」　冬子は今度はお光の方に話しかけた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕の前でそんなことを云ったって構いませんが、鴨田君の前で云おうものなら、蟒を嗾しかけられますぜ」「鴨田さんていうと、爬虫館の方ですね」「そうです」と返事をしたが、西郷氏はすこし冗談を云いすぎたことを後悔した。",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧子　　より江さんていふ人の大胆なのには、あきれましたわ。",
              "citation": {
                "source": "温室の前",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧子　　ぢや、西原さんていふ方は、大学へいらしつてから、おとなしくおなりになつたのね。",
              "citation": {
                "source": "温室の前",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "福井　さっき斎藤さんていう人が来たんだ。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            },
            {
              "text": "京葉さんていうのよ。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、いよいよ塾長さんていふ方にお目にかかつて、あたくしびつくりしたんですよ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと　　今度来る三谷さんていふん奥さんば、写させて貰へばよかたい。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
