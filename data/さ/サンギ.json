[
  {
    "uuid": "66424fa4-7377-59a2-9ef5-3954aa08b061",
    "entry": "参議",
    "reading": {
      "primary": "さんぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "participation in government",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『東京がなんだ、参議がどうだ、東京は人間のはきだめよ。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの友のある者は参議になった、ある者は神に祭られた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日、参議雅経さまが少し恐縮の態で御ところへおいでになられましたが、その時も、将軍家はこころよくお逢ひになつて、種々御歓談の末、長明入道さまにも、まだまだ尋ねたい事もあるゆゑ遠慮なく御ところへ参るやうにとのお言伝さへございました御様子でした。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し検非違使でゞもあれば兎に角、検非違使の別当は参議以上であるから、無位無官の者が突然にそれを望むべくは無い。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度都では此時参議｜右衛門督藤原忠文を征東大将軍として、東征せしむることになつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "増賀は参議｜橘恒平の子で、四歳の時につきものがしたように、叡山に上って学問をしよう、と云ったとか伝えられ、十歳から山へ上せられて、慈慧に就いて仏道を学んだ。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "定基は大江｜斉光の子で、斉光は参議｜左大弁正三位までに至った人で、贈従二位大江｜維時の子であった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いふ意見が、よほど御思召に叶つたやうであり、同年末には、立憲政治に就いて、山県有朋、黒田清隆、山田｜顕義、伊藤博文、大隈重信などの各参議に対して、意見の提出をお求めになつて居られる。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪木寛至参議院議員の試みが多少なりとも効を奏するか否かは、この駄文の作成時点では知りえない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "また高官の部類へやっとはいれたくらいの家よりも、参議にならない四位の役人で、世間からも認められていて、もとの家柄もよく、富んでのんきな生活のできている所などはかえって朗らかなものですよ。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "参議が二人、それから左衛門督、右衛門督が左右の楽を監督した。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は中将から参議に上った。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在は参議になっていて、名門の公子でりっぱな人物であるから世間から信頼されていることも格別なのであるが、その人自身は今の社会の空気が気に入らないで、何かのおりごとに源氏が恋しくなるあまりに、そのことで罰を受けても自分は悔やまないと決心してにわかに源氏と逢うために京を出て来たのである。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼南が大隈参議と進退を侶にし、今の次官よりも重く見られた文部｜権大書記官の栄位を弊履の如く一蹴して野に下り、矢野文雄や小野梓と並んで改進党の三｜領袖として声望隆々とした頃の先夫人は才貌双絶の艶名を鳴らしたもんだった。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに吉田首相とその乾分は世界のブルジョア政治家も裏面でしかあらわさないような男としての醜態を参議院で演出してもう民自党に投票してくれないでもいいんだということを天下に声明しました。",
              "citation": {
                "source": "泉山問題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに頑張って、末は参議になってもらいたい」と、伊織はいった。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしは欧陽修がひどく蠅を嫌つたものだが、軍事参議官｜井口省吾大将も、欧陽修に劣らぬ蠅｜嫌ひで、唯｜異ふのは、蠅嫌ひの名文を書き残さない位のものである。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "風俗小説の範囲で現実を見るだけでも、女の社会的な動きの一方には、婦人の参議院議員からはじまって少女歌劇の女優、婦人作家をふくむ女重役というものがあらわれているし、兜町・堂島に、女の相場がはやって来ています。",
              "citation": {
                "source": "私の書きたい女性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高層建築が左右からそびえたって空も見えないレキシントン街を背景に、もんぺをぬいだ赤松常子参議員が、白足袋に草履の足もとも元気そうに、コート姿をはこんでいる。",
              "citation": {
                "source": "この三つのことば",
                "author": "――わたしたちは・平和を・欲している――",
                "note": "青空文庫"
              }
            },
            {
              "text": "参議院の会議では母子世帯という風によぶ案もあるそうですが。",
              "citation": {
                "source": "「未亡人の手記」選後評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "参議院の考査委員会は、永井隆氏を表彰しようという案を発表したが、六月十二日、七月三日（一九四九年）の週刊朝日は、カソリック教徒であるこのひとの四つの著書が、それぞれにちがった筆者であるというようにいっている。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "参議院には民主的教育者三名が全国区から当選、地方区で三名が当選している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四六年度の選挙ではこの点の批難がおおいかくせなかったほどであったが、第二回の選挙には少くとも参議院には民主的教育者が当選したことで、いくらか一般人の教育の将来に対する見通しを明るくしている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会内にもキリスト教徒の進出は積極的で衆議院、参議院に二九名の議員がある。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近死去した真山青果のほか、中村吉蔵、参議院議員となった山本有三などのほかには、若い戯曲家は、主として小劇場の舞台のために書いていた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "参議院の法務委員会と裁判所との間に、浦和充子の事件について、見解の相異があり、法務委員会の権限について論議されている。",
              "citation": {
                "source": "「委員会」のうつりかわり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "参議院の引揚援護委員会も吉村隊事件ではいかがわしい委員会の本質を、人々の前にむきだした。",
              "citation": {
                "source": "「委員会」のうつりかわり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の布告文に「連邦参議院の決定により全帝国を通じてすべての種類のパン用穀物及び穀粉はこれを差し押うることとす。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四年廃藩置県の業成りて後、内治派の巨擘たる岩倉公は欧米回覧の企てをなし、木戸、大久保、伊藤の諸官を率いて本国を去れり、ここにおいて廟堂は西郷大将をはじめ副島、江藤、後藤、板垣の諸参議を残し、ほとんど国権派の世となれり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "西南の役に当たり兵馬｜倥偬の際に、矯激の建白書を捧げ、平和の手段をもって暗に薩州の叛軍に応じたるかの土州民権論者は、大久保参議の薨去を見てふたたびその気焔を吐き、処々の有志者を促して国会開設の請願をなさしめたり、ついに国会期成同盟会なるものは成立せり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
