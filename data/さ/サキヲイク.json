    "definitions": [
      {
        "index": 1,
        "gloss": "to go ahead",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白痴の小僧は馬の腹をすばしこく潜りぬけ、荷を積み重ねた赤い自動車がその鼻先を行く。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と先を行く男が叫ぶ。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅れてきた帝国主義国家、ドイツ、イタリア、日本は、ファシズムを国家の機軸に据えて、先を行く帝国主義諸国の覇権を脅かしながら勢力の拡大を試みた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてソニーは、先を行くパーソナルコンピューターを追って台頭したこのワークステーション分野で、かろうじてコンピューターに食い込む手掛かりをつかんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが多民族の共存を前提として我々の百歩先を行くアメリカの苦悩を笑い、単一民族国家（嘘つけ！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもちろん電子化された「読む」行為は、電子化では一歩先を行く「書く」という行為と有機的に結び付く。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがマッキントッシュはその間に先を行く。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "手甲に黒い脚絆をはき、白い手拭ひを姉さん冠りにして、負臺を擔いでさつさと先を行く彼女は健氣な頼もしいものに見えた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩先を行くアメリカの状況を論じ、ＰＣ―８００１売り込みのシナリオを解説する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会が次のステージに移ろうとするとき不可避に起こる闘争が、実顕地外の社会よりも一歩先を行くこの場所で起こりつつあるのではないか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "順平の思惑は、いつも村に流れて来る時勢より三四年は先を行く塩梅になった。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の上の小川―玉川―にけぶるやうにうつゝて居た月の光りに、五六間先を行く者の姿を、朧ろながら、確かに見た。",
              "citation": {
                "source": "死者の書　續篇（草稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかには、もつと先を行く人物もあつていい。",
              "citation": {
                "source": "批評家・作家・劇場人",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、二、三軒先を行く里好にきいてみた。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は半町ばかり先を行く。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "うし紅珊瑚",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも腐儒の因循をわらい、鎖港論を空吹く風と聞き流し、率先して西洋事情の紹介や、医書、究理書の翻刻に力を入れ、長崎や横浜に仕入れの出店を持って手びろく舶載物を輸入する、時勢から二歩も三歩も先を行く開化の先覚者。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、先を行くのは常に二頭の大型犬だった。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "先を行く人たちの同意が得られるなら、青空文庫を拡充するために、すでにある成果をどんどん使わせてもらおうと思います。",
              "citation": {
                "source": "青空文庫の提案",
                "author": "青空文庫編",
                "note": "青空文庫"
              }
            },
            {
              "text": "お春は幸子の顔色が急に変ったのを看て取ると、自分もひどく真剣な表情をして、「は」と答えたきり俯向きながら歩いていたが、幸子は動悸を静めるために、一丁程先を行く貞之助と悦子の後影に眼を遣りながら、わざと歩調をゆるめつつ歩いた。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスの臨床医学は他の国より先を行くようになり医学の進歩を数十年にわたって導いた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が、大声して、手を振ったので、先を行く輿は、「何者？",
              "citation": {
                "source": "日本名婦伝",
                "author": "大楠公夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌にかかる豹そのままな腰を見せて、先を行く背へ、白刃の一｜颯をふくみかける。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "三〇四号室」　さきをいく奴が、ふりむかずにいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "とめどもなく枝を手足のようにのばし、枝のさきをいくつにもひろげて、こっちへおしよせてくるマングローブの木。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さきをいく連中についていくことしか、頭になかったからだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきをいく二台の大排気量のエグゾーストがかさなりあい、シャーンというような音になって、うしろへなびいてくる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミーヨの乗ったヤマハＲＤ２５０が、さきをいく。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
