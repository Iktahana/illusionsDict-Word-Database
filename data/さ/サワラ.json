    "definitions": [
      {
        "index": 1,
        "gloss": "sawara cypress (Chamaecyparis pisifera)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何処も彼処もぴかぴかと黒く光るなかへこればかりは新らしく容れられた縁の部厚な椹の風呂桶の生々しい肌の色が、白くほっかりと浮んで見えた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方あんまり所在ないから、新町まで出かけて焼酎一杯、ついでに酢も一合求める、それから椹野河原へいつて宵待草を一株ひきぬいてきて庵の前に植ゑる、句も二つ拾つた、樹明君から雑草も借りた、いや御苦労々々々。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "椹野川にそうて散歩した、月見草の花ざかりである、途上数句拾うた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ立つて山口へゆく、椹野川風景もわるくない、桜冬木、白梅紅梅、枯葦、枯草、ことに川ぞひの旧道は自動車が通らないのがうれしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁盤目の中には、十字に椹の籬が組まれた。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "檜木、椹、明檜、槇、※――それを木曾の方では五木といひまして、さういふ木の生えた森や林があの深い谷間に茂つて居るのです。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "茄子の支へ竹を拾ふべく椹野河原へまで出かける（近所にもあるけれど個人所有の山へはいるのはうるさいから）、月見草がうつくしく咲いてゐた、土手の葉桜もうつくしかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口の句会へ行く、椹野川づたひに歩いて行つた、春景色、そして私は沈欝であつた、いつ訪ねても周二居はしづかであたゝかである、湯田温泉も私のかたくなにむすぼれた身心をほぐしてくれた、おいしい夕飯をいたゞいて、若い人々と話して、終列車で戻つた、まことによい一日一夜であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "半日、椹野川堤で読書、一文なしでは湯田へ行けないから。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君に連れられて、椹野川尻で鮒釣見習。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "椹野川土手づたひにぼつり／＼と歩く、山の色も水の音もすべて秋。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、樹明君来庵、誘はれて椹野川へ出かける、魚は捕らないで飲み歩いた、そしてどろ／＼ぼろ／＼になつてしまつた、……それでも理髪して、道具は持つて帰つて寝床にはいつてゐたから妙だ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼飯を食べてから、ふと思ひ立つて湯田へ行く、椹野川を土手づたひに溯る、葦の花、瀬の音、こほろぎのうた、お地蔵さま、秋草のいろ／＼、……温泉で一浴して引き返す、徃復とも歩いたが（銭がないから）、近来のよい散歩だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、ともすれば滅入りこむ気分をひきたてて、秋晴三里の郊外を歩いて山口へ出かける、椹野川風景も悪くない、葦がよい、花も葉も、――いろ／＼買物をして、湯田で一浴して帰つた、机上のノートに書き残して置いやうに、間違なく暮れる前に！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は散歩、三時間あまり、新町から椹野川土手へ、途中、Ｓ老人の店で一杯借りる、月草を折つて戻る、昼顔は見つからなかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧の六月十七夜、椹野河原は人出が多からう、今年は煙火の催物はないが。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "早々眼覚めたけれど、朝寝の癖があるらしいから遠慮して九時過ぎ起きた、すぐ温泉へ出かけて一浴、そして一杯、朝飯を頂戴してお暇乞する、二人はさらに椹野川で泳いだ、河原の石ころがそれ／″＼のよさを具へてゐる事実に今更のやうに驚嘆したりした。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君から招待される、暮羊君から五十銭借りて理髪、煙草とグリコとを買ふ、椹野川で水浴する、そしてそれから訪ねたが、すこし早すぎた、やがて樹明君帰宅、よく飲みよく食べた、そしてそのあたりをぶらついて帰つて来た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月六日暁の雨は強かつた、明けても降つたり晴れたりで、とても椹野川へ鮒釣りに行けさうもないので、思ひ切つてお暇乞する、こゝでもまた樹明さんの厚意に涙ぐまされた、駅まで送つて貰つた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "身心が燃える（昨夜、脱線しなかつたせいかも知れない、脱線してもまた燃えるのであるが）、自分で自分を持てあます、どうしようもないから、椹野川へ飛び込んで泳ぎまはつた、よかつた、これでどうやらおちつけた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "椹野川の瀬音、土手のさくらんぼ。",
              "citation": {
                "source": "行乞記",
                "author": "北九州行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "メロンの包みを抱いて、くみ子が椹の垣根のそばにきまり惡さうに立つた待つてゐた。",
              "citation": {
                "source": "多摩川",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ早く三百円にお目にかかってあれもこれも……ねえ伸ちゃんといいたい気持ちで、寛子が振り返ると、啓吉も伸一郎も、裏の貧弱な椹の垣根の下で、盛んに泥をこねかえしている。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の下に長々と延びてゆく赤石東尾根、その蔭には人里｜椹島がある。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日中に椹島まで行きたい、行かねばならない。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その椹島がもう今は目の下にあるのだ。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三十分も行ったろうか、針葉樹の木立を抜け切ると、ついにそこは椹島であった。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは人間はおろか、猫の子一匹の気配さえない死の部落椹島であったのだ。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計をなくしたので時間ははっきり分らないが、大分寝過したようなので急いで椹島を出た。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曽の五木と称されている、杜松や羅漢柏や椹や落葉松や檜などが左右に茂っている。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
