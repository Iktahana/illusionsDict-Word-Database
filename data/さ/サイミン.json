  {
    "uuid": "20f0c48f-f3b6-57f5-92aa-9d986fa10312",
    "entry": "サイミン",
    "reading": {
      "primary": "サイミン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "saimin (Hawaiian noodle dish)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "魂の病人のサイミン薬です。",
              "citation": {
                "source": "余はベンメイす",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の分類に従って言うならば、大インテリとは、サイミン術にかかりにくい性質を持った人間だ。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、コンミューニズムの端からファシズムの端に至るあらゆる種類の政治的プリンシプルが、現実的にデスポティズムの形をとった場合には、すべてサイミン術になる。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、サイミン術や政治と闘う道具として、彼自身の、そして彼自身だけのエイ智以外には、なんにも持っていないし、持とうとしない。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで広津と志賀と武者小路についての一言ずつを、ひとまず終るが、終るにあたって思うことは、これほどまでにすぐれて、他からのサイミン術にかかりにくい人たちでも、自分が自分にかけるサイミン術だけは、避け得ないのだろうかという事だ。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎町のどこかで、父親とふたりでサイミンを食べた午後について、なんの脈絡もなしに僕は思い出す。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱いサイミンの入ったどんぶりを、両手にひとつずつ持っていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイミンのどんぶりの持ちかたは、太い親指の先をどっぷりとサイミンのスープのなかにひたす、というスタイルだった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が小屋に戻ってから、「ポリネシア親指スープのサイミンだよ」　と、父親が言った。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このスープは、ほら、たいへん熱いよ」「彼女に訊いてみればいいのに」「そうもいかないよ」「なぜ」「熱くないのかと訊ねたなら、親指をスープに入れずに持ってこいという意味になる」　よくできたサイミンだった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュディーのオカズ・サイミン。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
