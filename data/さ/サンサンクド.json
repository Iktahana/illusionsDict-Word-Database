    "definitions": [
      {
        "index": 1,
        "gloss": "three-times-three exchange of nuptial cups",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
