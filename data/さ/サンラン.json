[
  {
    "uuid": "e2302ad9-9e9c-5164-9b57-da7d07d0eaba",
    "entry": "散乱",
    "reading": {
      "primary": "さんらん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
