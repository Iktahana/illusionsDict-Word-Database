    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dispersion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり実生活は、散乱しきつてゐた。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "油紙の天幕には、チロチロと漣の刻むような光りがする、岩石の間に、先刻捨てた尻拭き紙までが、真赤にメラメラと燃えている、この窪地一帯に散乱する岩石の切れ屑は、柔らかく圭角を円められて、赤い天鵝絨色が潮しはじめた。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社の庭には天狗がおもちゃにするというまさかり、かま、太刀などが、散乱している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は冷気のために雪が岩石の膚肌に凝結し、昼はそばから蒸発して行くので、冷熱の変化から岩石を破壊し、山体を陶器の破片のように滅茶滅茶にして散乱させる。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそれは名状し難い速さで廻っているかと思うと急に花火の開いたようにパッと散乱してそのまた一つ一つの片が廻転しながら縦横に飛び違う。",
              "citation": {
                "source": "赤",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度ごとに采配が切断されてその白い紙片が吹雪のように散乱する。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず長さ二丈くらいの大きな櫓を作り、その天井と中段とに横木を並べて置く、そして天井の上に水道を引いてその口から噴き出す水を天井一面に散乱させる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に、口からはなした朝日の吸口を緑色｜羅紗の卓布に近づけて口から流れ出る真白い煙をしばらくたらしていると、煙が丸く拡がりはするが羅紗にへばり付いたようになって散乱しない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡麻塩頭をぼう／＼と散乱さしひげむじゃのまま、仕事に打ちこんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小間切を叩きつけたような肉片や、バラ／＼になった骨や肉魂がそこらに散乱していた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大興駅附近の丘陵や、塹壕には砲弾に見舞われた支那兵が、無数に野獣に喰い荒された肉塊のように散乱していた。",
              "citation": {
                "source": "チチハルまで",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯其の時は、爪一つ指の尖も、人目には漏れないで、水底に眠つたやうに、面影ばかり澄切つて居たのに、――こゝでは、散乱れた、三ひら、五ひらの卯の花が、凄く動く汽車の底に、ちら／＼ちらと揺れて、指の、震へるやうにさへ見らるゝ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして音の散乱、反射というようなものも、どうにか論じてある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビール罎の花も芋の切れ端も散乱して熊さんの蒲団は濡れしおたれている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらさらひらひら、と低く呟いてその形容を味わい楽しむみたいに眼を細めていらっしゃる、かと思うと急に、いや、まだ足りない、ああ、雪は鵝毛に似て飛んで散乱す、か。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理窟を考えよう考えようとしたが、自分の両足の下の藍色の絨緞と、その上に散乱した料理や皿の平面が、前後左右にユラリユラリと傾きまわるばっかりで、どうしても考えを纏めることが出来なかった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、見る時、葛木も面にはらはらと柳の雫が、押えあえず散乱るる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は此処でも後になり先になり、脚絆の足を入れ違いに、頭を組んで白波を被ぐばかり浪打際を歩行いたが、やがてその大きい方は、五、六尺｜渚を放れて、日影の如く散乱れた、かじめの中へ、草鞋を突出して休んだ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "アツレキ三十一年七月一日夜、表、アフリカ、コンゴオの林中の空地に於て故なくして擅に出現、舞踏中の土地人を恐怖散乱せしめたる件。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その方はアツレキ三十一年七月一日夜、アフリカ、コンゴオの林中空地に於て、故なくして擅に出現、折柄月明によって歌舞、歓をなせる所の一群を恐怖散乱せしめたことは、しかとその通りにちがいないか。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "担える籠は覆りて、紙屑、襤褸切、硝子の砕片など所狭く散乱して、脛は地を蹴り、手は空を掴みて、呻吟せり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずたずたになれる筵の上に、襤褸切、藁屑、椀、皿、鉢、口無き土瓶、蓋無き鍋、足の無き膳、手の無き十能、一切の道具｜什物は皆｜塵塚の産物なるが、点々散乱してその怪異いうべからず。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "袋の山毛欅は四方に散乱した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバルト色に深く澄み渡つた南の空に、大粒の宝玉のやうに燦々と光り輝く十字星は、天空一ぱいに散乱する群星を圧してゐた。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の附近の田畑数町歩一面に、激戦地の跡もかくやと思はせるほど、巨大の根株や、丸太が散乱してゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が暗さに慣れるにつれ、中に散乱した彫像、器具の類や、周囲の浮彫、壁画などが、ぼうっと眼前に浮上って来た。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　とか何とか、うろ覚えの独言を言ってね、お前さん、（それ、雪は鵝毛に似て飛んで散乱し、人は鶴※を着て立って徘徊すと言えり……か。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、日の光りやゝ弱く、衣のひた／＼と身に着く処に、薄い影が繊細くさして、散乱れた桜の花の、背に頸にかゝつたまゝ、美女は、手を額に当てゝ、双六盤に差俯向いて、ものゝ悩ましげな風情であつた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……其処には白金の日輪が小さくただ光つて廻るばかし、時折、微風が翼をかへして雪のやうに散乱する。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　囂々々々々々、轟々々々々々、　混雑、擾乱、圧搾、粉砕、散乱、微塵、芳香、光、光、光。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
