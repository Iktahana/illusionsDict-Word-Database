        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北国をめぐる旅人が、小百合火の夜燃ゆる神通川を後に、二人輓きの人車に揺られつつ富山の町を出て、竹藪の多い村里に白粉臭い女のさまよう上大久保を過ぎると、下大久保、笹津の寂しい村々の柴｜焚く烟が車の上に流れて来る。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「逢はましものを小百合葉の」という高砂の歌の終わりのところになって、中将は杯を源氏に勧めた。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目の小百合殺しは一向問題にならなかったが、二番目の角力と鳶の者の喧嘩は座方の宣伝が頗る効を奏して、どこでもその噂で持ち切っているという有様であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四には、はた巖根の小百合、あけぼのの香のささやきを。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手に　持ちしは、小百合を　三個、髮なる　きら星　數は　七つ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀の園『みだれてくらき深海の底にねむりし身もこよひ、』――眞珠小百合の唇にはじめてふれて、　　　『君を戀ふ』と。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "小百合は知るや、慕ひよる眼ざしは天にふさへども、胸にはゆらぐ海の音のうれひやいとど　　　『君を戀ふ』と。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あふれて月は雲に入り、雲は光にとくるとき、小百合の園の香に映えて影ゆめふかげ、　　　『君を戀ふ』と。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しんじゆの清き身ならずば小百合なにかはくちづけのあまきにほひもまじへじを、さてもせつなげ、　　　『君を戀ふ』と。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼沈みしも海のそこ、戀ふるも深きこころには、小百合なさけのくちづけもあさきやさらに、　　　『君を戀ふ』と。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "『※ながれて戀にゆき、おもひはもゆる身ぞこよひ、』――眞珠小百合の花びらの口にくちづけ、　　　『君を戀ふ』と。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分に向って、かざらしの小百合よ、と思うのよ、いまのまさかに、どんな顔して気持でいるのかよと思うのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに、春になると花粉を地べたに撒きちらした“谷間の小百合”がある雑木林じゃないか。",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレイバック、小百合と恋人の歌、山根寿子と土屋伍一の二人、そこへかけつけて――といふところ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の光に明日といふ黄花のさゆり透きみえて、月の光に手の影はひとり悲しくあらはれぬ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "二薫はたかきさゆりの花はかざしにさゝむ。",
              "citation": {
                "source": "さかほがひ",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫ほるさゆりの花片におくあけぼのゝ白露か緑色こき大空に照るくれなゐの夕づゝか。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "さゆりのゆどこ　かぐわしい一つ一つのゆたかな花でなくては、お似合いにはならないわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
