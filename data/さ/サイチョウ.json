[
  {
    "uuid": "4ec4a42e-262b-5aa5-aa6c-404c9165f321",
    "entry": "再調",
    "reading": {
      "primary": "さいちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
