          "literary": [
            {
              "text": "犀鳥は神方で蛇の頸を銜え持ち行くところへプレ神が来る。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから犀鳥が蛇を見れば必ず殺し虎を見れば必ず叫んで追い去らんとす。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に虎を射る場合に限り犀鳥の羽を矧いだ矢を用いてこれに厭勝つのだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで小さいちょうちんが木にいっぱいともされたようなぐあいでした。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ霜で枯れたままになっている、草株の上へ腰を下ろすと、黄色な小さいちょうが、風に吹かれて目の前を飛んでいきました。",
              "citation": {
                "source": "花の咲く前",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
