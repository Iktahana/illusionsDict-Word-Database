        "examples": {
          "standard": [
            {
              "text": "人間は、高度なサピエンスを持つ生物として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人工知能がサピエンスを持つ日は来るのだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "動物にも様々な程度のサピエンスがあることが、最近の研究で明らかになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わずかに人間学其の他というような狭い盆地で、ホモ・サピエンスとホモ・ファーベルとが並べられた程度にすぎない。",
              "citation": {
                "source": "生産を目標とする科学",
                "author": "――再三「科学と技術」とについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴリラとホモ・サピエンスとを連続させる環は現在生きていない。",
              "citation": {
                "source": "範疇の発生学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
