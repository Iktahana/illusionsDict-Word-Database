[
  {
    "uuid": "941d8cc4-e6a2-569f-b583-6942a142faaa",
    "entry": "山巓",
    "reading": {
      "primary": "さんてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
