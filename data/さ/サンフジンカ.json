    "definitions": [
      {
        "index": 1,
        "gloss": "maternity and gynaecology department (gynecology)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
