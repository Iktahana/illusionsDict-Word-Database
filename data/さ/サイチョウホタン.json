    "definitions": [
      {
        "index": 1,
        "gloss": "compensating for one's shortcomings by incorporating others' strong points",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
