    "definitions": [
      {
        "index": 1,
        "gloss": "even if that isn't the case",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
