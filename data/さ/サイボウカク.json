        "examples": {
          "standard": [
            {
              "text": "細胞核には、生物の設計図であるDNAが格納されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "細胞核の働きを阻害すると、細胞は正常に機能できなくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「先生、細胞核って、細胞の真ん中にある一番大事な部分ですか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "生殖質（＊ワイスマンの用語、核に存在する）は残って、しばしば自分がどの物体から来ていることさえを知らない男たちによって、真理の細胞核は受精される。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等の部屋は博物館――日本に於る最初の動物博物館――の細胞核である。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
