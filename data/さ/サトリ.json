[
  {
    "uuid": "8c3703ad-9295-5f42-b8d6-457d61576157",
    "entry": "悟り",
    "reading": {
      "primary": "さとり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
