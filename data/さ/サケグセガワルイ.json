    "definitions": [
      {
        "index": 1,
        "gloss": "being a bad drunk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
