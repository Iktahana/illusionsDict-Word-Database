          "literary": [
            {
              "text": "裁判記録によると彼は裁判長の訊問に答えなかったのである。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一問一答の裁判記録よりの、抜萃」と題する冊子ができあがったのである。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "主馬はいま、或る古い裁判記録を調べている。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、古い裁判記録を、その犯罪と、判決によって分類するという、極めて退屈なかび臭い仕事であった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――裁判記録を役所の外まで持ち出した、というお叱りさ。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
