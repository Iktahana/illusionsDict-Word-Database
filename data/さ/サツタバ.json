    "definitions": [
      {
        "index": 1,
        "gloss": "bundle of banknotes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
