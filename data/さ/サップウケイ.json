    "definitions": [
      {
        "index": 1,
        "gloss": "dreary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "上陸当初の日に一瞥して嘔吐を催し、現代日本の醜悪面を代表する都会と罵り、世界のどんな汚い俗悪の都市より、もっと殺風景で非芸術的な都市と評した東京は、彼が死んでも住みたくない所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、もう東京はいやだ、殺風景すぎる、僕は北京に行きたい、世界で一ばん古い都だ、あの都こそ、僕の性格に適しているのだ、なぜといえば、――と、れいの該博の知識の十分の七くらいを縷々と私に陳述して、そうして間もなく飄然と渡支した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景な下宿の庭に鬱陶しく生いくすぶった八つ手の葉蔭に、夕闇の蟇が出る頃にはますます悪くなるばかりである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐世保もただ殺風景な新開町であった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に夕顔棚ありて下に酒酌む自転車乗りの一隊、見るから殺風景なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景な病室の粗末な寝台の上で最期の息を引いた人の面影を忘れたのでもない、秋雨のふる日に焼場へ行った時の佗しい光景を思い起さぬでもないが、今の平一の心持にはそれが丁度覚めたばかりの宵の悪夢のように思われるのである。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景と云うよりはただ何となくそぞろに荒れ果てた景色である。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは毎日一日役所の殺風景な薄暗い部屋にのみ籠っているし、日曜と云っても余計な調べ物や内職の飜訳などに追われて、こんな事を考えた事も少ないが、病んで寝てみると、急に戸外のうららかな光が恋しくて胸をくすぐられるようである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞く大正池の眺めは思の外に殺風景に思はれた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞く大正池の眺めは思いのほかに殺風景に思われた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに、どうも座敷用または書卓用としては、あまりに殺風景なような気がした。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」太田ミサコは鉤形の鼻を鳴らして殺風景な部屋椅子に腰を下ろすと、埃のつんだ卓子に片ひじついて、「ほほ、それではバル・セロナ生れの伊達ものには見えないわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに殺風景な木造の建築がある。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景だと思っていたコンクリートの倉庫も見慣れると賤が伏屋とはまたちがった詩趣や俳味も見いだされる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある赤煉瓦の恐ろしく殺風景な建物の前に来たとき、案内者が「世界第一の煉瓦｜建築であります」と説明した。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は、どうも、他に話題も無いし、せっかくおいで下さったのになんのおかまいも出来ず、これでは余り殺風景ですから、窮した揚句の果に、こんなものを持ち出したのですから、そこのところは貧者一燈の心意気にめんじて、面白くもないだろうけれど見てやって下さい。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所も電気と瓦斯だけで片付けているに違いないのに、何の目的でコンナ殺風景なものをオッ立てたのであろう……なぞと考えれば考える程、私は不思議でたまらなくなって来た。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの音につれてスクリーンに現われる映像は、ただの殺風景な兵隊の行列である。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金気｜蕭条としてたちまち至る殺風景。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の下へ忍ばした勢だから、氣焔と、殺風景推して知るべしだ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らばと言つて、一寸蛙を、承りまする儀でと、一々町内の差配へ斷るのでは、木戸錢を拂つて時鳥を見るやうな殺風景に成る。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴の姿の消えたあとは、遣手の欠伸よりも殺風景である。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――はあはあと、私が感に入って驚くのを、おかしがって、何、牡丹のひたしものといった処で、一輪ずつ枝を折る殺風景には及ばない、いけ花の散ったのを集めても結構よろしい。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、いきなり殺風景な写真を見せつけられ、うむを言わさず、見合いに行けと言われて、はいと承知して、いいえ、承知させられて、――そして私がいそいそと――、あんまりだ。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景ななどと、男の人の使うような言葉をもちいたが、全くその写真を見たときの私の気持はそれより外に現わせない。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに午前六時の朝日会館など、まるで日曜日の教室――いや、それ以上に、ひっそりとして、味気なくて、殺風景でいたずらにがらんとして、凡そ無意味な風景であろう。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　信吉は「実行」という殺風景な言葉を使って、呟いた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に詩人の為すべきことは、人の無趣味とし、殺風景とし、俗悪とし、＊プロゼックとするものに就いてさえ、新しき詩美を発見し、詩の世界を豊富にして行くことに存するのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校の社會そのものが、彼には呪ふべき最惡であり、その殺風景なる建物は、彼を苦しめる牢獄の如く思はれた。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この成立学舎と云うのは、駿河台の今の曾我祐準さんの隣に在ったもので、校舎と云うのは、それは随分不潔な、殺風景｜極まるものであった。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
