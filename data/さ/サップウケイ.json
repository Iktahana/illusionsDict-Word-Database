[
  {
    "uuid": "fb21f7a0-a342-5d82-b97a-ef52c30e4eb5",
    "entry": "殺風景",
    "reading": {
      "primary": "さっぷうけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
