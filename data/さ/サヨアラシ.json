        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "嘗てあれほどわたくしの身にひし／＼と食い入った諸行無常の小夜嵐も松の音とのみ上の空に聴き澄まして通し過せるのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『小夜嵐』三に、ぶたのもしき坊主とあるは頼みにならぬ坊主で豕に関係なし。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし浮世の小夜嵐の習ひ、遂に不帰の客となられ、一家の悲痛まことに人を泣かせずには置きませんでした。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しがたまで見えた隣家の前栽も、蒼然たる夜色に偸まれて、そよ吹く小夜嵐に立樹の所在を知るほどの闇さ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よや、一座の山の上に、火焔を浴びた城一つ、落城と見えて女子供の泣き叫ぶ声の物凄く、その間も吹きつのる小夜嵐。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "轟ッ――と一わたり、小夜嵐が屋棟を鳴らして過ぎる。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただときどき家を鳴らして渡る小夜嵐が、遠くの潮騒のように余韻を引いて過ぎるばかり。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
