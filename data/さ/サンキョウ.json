[
  {
    "uuid": "a282284e-c9bc-5cbe-9747-fef741c4aab3",
    "entry": "三教",
    "reading": {
      "primary": "さんきょう",
      "alternatives": [
        "さんぎょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
