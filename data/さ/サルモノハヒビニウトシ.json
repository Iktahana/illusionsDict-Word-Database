        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父が亡くなって何年も経ち、去る者は日々に疎しという言葉を実感する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんなに大切な人でも、去る者は日々に疎し。それが人間の性なのだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悲しみは癒えても、去る者は日々に疎しとは言いたくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "去る者は日々に疎しといってなかなか死者に対する礼はつくされないものだ。",
              "citation": {
                "source": "墓",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "去る者は日々に疎しといつてなか／＼死者に対する礼はつくされないものだ。",
              "citation": {
                "source": "墓",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "去る者は日々に疎し、というか、二月、三月とすぎ、半年もすぎるとまるで思いださないというより、どんな犬であったか思いだせないくらいになっていた。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
