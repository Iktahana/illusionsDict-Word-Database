[
  {
    "uuid": "3474c628-deb1-569c-93d5-faeaea0f4449",
    "entry": "鞘当て",
    "reading": {
      "primary": "さやあて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
