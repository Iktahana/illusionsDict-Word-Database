    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rivalry in love",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "引くに引かれぬ鞘当てから、日本全国を潜行する無量無辺の不正ダイナマイトを正面に廻わして、アアリャジャンジャンと斬結ぶ事になった。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに悲劇の発端が生じたのだが、長く良人と別れていた彼女も、性的な淋しさや何かから、病的にサミイへ近づいて行って、そこに、アン・ルロイとの間に恋の鞘当てが始まったのだ。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると誰か叔父の刀にぴしりと鞘当てをしかけた者があつた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると誰か叔父の刀にぴしりと鞘当てをしかけた者があった。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く“心臓盗難男の恋の鞘当て”曰く“奇賊烏啼も登場の今様四角恋愛合戦”また曰く“無心臓男の恋の栄冠”と。",
              "citation": {
                "source": "心臓盗難",
                "author": "烏啼天駆シリーズ・２",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ場合はまゝあつたが、未来にどうといふ当のない身は磊落で鞘当ても起らない。",
              "citation": {
                "source": "決闘",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッキリ情婦となつてしまへば却つて鞘当てはないのだけれども、相手が処女、清純楚々たるタヲヤメであるとやゝこしくなる。",
              "citation": {
                "source": "決闘",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げた顛末は、私がよく存じておりますが、女同士の鞘当てというところがおかしいんで、両方でイガミ合っているうちに、肝腎の当人が、行方知れずになってしまったんでございますよ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「過日我らが組下の一人、諸戸新吾と申す者、貴殿の部下たる矢部藤十殿に、鞘当てのことより意趣となり、双方果し合い致したるところ、卑怯にも矢部殿には数人を語らい、諸戸新吾を打ち挫き、恥辱を、与えなされたため、諸戸は無念を書き残し、数日前に腹切ってござる。",
              "citation": {
                "source": "二人町奴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると浪人はつけあがり、「鞘当ていたして置きながら、失礼致したとは何んのことじゃ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ所存があったればこそ鞘当て致したに相違あるまい。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これは甚だ迷惑千万、鞘当てしたるは拙者ではなく、そう云う貴殿ではござらぬか」「何、某が鞘当てしたと？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞘当てしたはその方じゃ！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "播磨　や、それがいわゆる鞘当て。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "いささかの意趣遺恨でもあろうものなら、その鞘当てからいかなる騒ぎになろうも知れぬところを、見事、平らに捌いた両人の手並み、ちかごろ鮮やか、鮮やか、ははははは。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "両人　鞘当てとはどうも、ははははは、それがまた自らなる御座興となって、殿の御感を得るとは。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "座の一人　いや、文字どおりの鞘当てでござりましたて。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "悍馬のごとく逸って、こりゃ鞘当てもしかねますまいて。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞘を触れられた侍　一つ、その兼定に鞘当てされた某の刀も、御列座の高覧に預かりたいもので、ははははは。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "源三が生きていてこそ鞘当てだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には、元はと言えば、そのことから、戸部近江之介と鞘当てになって、こんにちこんなようなことになったほどの、伊豆屋の娘のお園、改名して園絵という、思い思われた妻があるのである。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "その円枝さんとは、武右衛門がおめえに色眼を使うんで、たびたび鞘当てがあったことだろうの。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "影人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして乞食の仲間に入ったか、生れは相当に良かったらしく、物越しも尋常、気風も娘らしい若々しさと、荒み切れない優しさを持って居りますから仲間では一番の人気者で、斯う言う私も、昨日までは何んかしら淡い恋心を寄せて、辻の六蔵と二、三度鞘当てめかしい事をやったものです。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも、金が目当てだったことは言う迄もありませんが、それでも、お園とお組が、掴み合いの大鞘当てをするだけあって、若旦那の金之助は、なか／＼の美男でもありました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "夕立の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　果して、吾妻屋永左衛門と、大井久我之助の鞘当ては、一応表向きは納まりましたが、二人の心持は執拗に深刻に、行くところまで行き着いてしまったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "毒酒薬酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵馬は、あまり不思議だから、非常中の非常手段ではあったが、ワザと近寄ってその武家にカチッと、自分から鞘当てを試みました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士として鞘当てを受けたのは、果し状をつけられたようなものであるにかかわらず、その武家は知らぬ顔に、人混みに紛れて逃げ去ろうとするのは歯痒い。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、おたがいたちのうちに鞘当ても起らないし、お代官そのものもいっこう悪い顔をしないのは、お人好しで全く気がつかないのか、或いは自分が相当の食わせ者であるだけに、気がついても、見て見ないふりをしているのか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ、来たぞ」　何が来たのだかわからないが、三人はそれを避けて通すと、すれすれに通行したが、鞘当てを演ずることもなく、しばらくすると、これも前の軽格と同様、音も姿も夜霧の中に消えてしまいます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道利権をめぐる米英公使のさやあてはしだいに激しくなってゆくのであるが、いまは筆をはぶく。",
              "citation": {
                "source": "明治の五十銭銀貨",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
