  {
    "uuid": "f4854048-3e8d-5503-86c0-beee8a6024c1",
    "entry": "三宝",
    "reading": {
      "primary": "さんぼう",
      "alternatives": [
        "さんぽう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the Three Jewels",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その間に父上は戸棚から三宝をいくつも取下ろして一々｜布巾で清めておられる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに黄ばんだしみのあるのも鼠のいたずらじゃないかしらんなど独語を云いながら我も手伝うておおかた三宝の清めも済む。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父上はこれに一々｜水引をかけ綺麗にはしを揃えて、さて一々青い紙と白い紙とをしいた三宝へのせる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番大きな下の壇へは色々な供物の三宝が並べられる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所に杯盤の音、戸口に見送りの人声、はや出立たんと吸物の前にすわれば床の間の三宝に枳殻飾りし親の情先ず有難く、この枳殻誤って足にかけたれば取りかえてよと云う人の情もうれし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業式三宝または水差しなど、　　たとへいくたび紅白の、甘き澱みに運ぶとも、　　　鐘鳴るまではカラぬるませじと、うなじに副へし半巾は、　　慈鎮｜和尚のごとくなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "側の三宝に貼紙がしてある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（どなた、）と納戸の方でいったのは女じゃから、南無三宝、この白い首には鱗が生えて、体は床を這って尾をずるずると引いて出ようと、また退った。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上は旧石神井村三宝寺の池なれば、正しくは石神井川といふべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こころざしは受けますが、三宝にのったものは、あとで、食べるのは、あなた方ではありませんか。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「南無三宝、はははは。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝、こりゃ加州まで行くことかと息切がして蒼くなりましたね。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝声がかかった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに背後に人の足音が聴こえたので、南無三宝！",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "部室の外にどやどやと跫音して、二三人が来れる様子に、南無三宝飛び退りて再び日蔽の影に潜みぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹五郎　南無三宝、堂の下で誓を忘れて、鐘の影を踏もうとした。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宝の利益、四方の大慶。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……南無三宝、赤蜻蛉は颯と外れた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と踏張って両方の握拳で押えつける者もあれば、いきなり三宝｜火箸でも火吹竹でも宙で振廻す人もある――まあ一人や二人は、きっとそれだけで縁から飛出して遁げて行きます。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このふっくりした白いものは、南無三宝仰向けに倒れた女の胸、膨らむ乳房の真中あたり、鳩尾を、土足で蹈んでいようでないか。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝、魔物の唾じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほい、」　と視めて、「南無三宝。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝、電光に幕あるのみ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は鈍感なのか、三宝柑をたべるのに夢中になっているのか、それに気が付かない様だった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて女は何程か知れぬが相当の金銀を奉書を敷いた塗三宝に載せて持て来て男の前に置き、「私｜軽忽より誤って御足を留め、まことに恐れ入りました。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝三十銭、支出する小遣がないから払ふ訳に往かない。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤蛙が化けたわ、化けたわと、親仁が呵々と笑ったですが、もう耳も聞えず真暗三宝。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面に衝立が立っていて、その前に三宝が置いてある、古めかしいきれいな広い玄関だった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、本堂へむくりと立った、大きな頭の真黒なのが、海坊主のように映って、上から三宝へ伸懸ると、手が燈明に映って、新しい蝋燭を取ろうとする。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母　　其創を見ましたが、此眼で見ましたが……南無さんぼう！",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
