[
  {
    "uuid": "92071e66-b708-5b1d-a87b-f1c8474c583f",
    "entry": "参謀",
    "reading": {
      "primary": "さんぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
