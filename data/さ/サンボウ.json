    },
    "definitions": [
      {
        "index": 1,
        "gloss": "staff officer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "如何に精密なる参謀本部の地図でも一木一草の位置までも写したものはない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論参謀本部の五万分一地図にはないほど新しい道路である。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「は、……」　自動車の傍の馬上の男も、参謀か、師長であるらしかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また二里ばかり大蛇の蜿るような坂を、山懐に突当って岩角を曲って、木の根を繞って参ったがここのことで余りの道じゃったから、参謀本部の絵図面を開いて見ました。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい二十世紀の文明国と名乗る国がらからすれば、内閣に一人や二人のしかるべき科学大臣がいてもよさそうであり、国防最高幹部にすぐれた科学者参謀の三四人がいても悪いことはなさそうに思えるのであるが、これも畢竟は世の中を知らぬ老学究の机上の空想に過ぎないのかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お濠をぐるっとめぐって、参謀本部のとこから、日比谷へ出て、それから新橋駅へ出て、赤羽は、その裏じゃないか。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸にこみ上げてくる喜びをじっと押し殺して、参謀の提出した方略を採用する指揮官のように、わざと落ちつき払いながら鉛筆を動かし始めた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宅坂の方面から参謀本部の下に沿って流れ落ちる大溝は、裁判所の横手から長州原の外部に続いていて、昔は河獺が出るとかいわれたそうであるが、その古い溝の石垣のあいだから鰻が釣れるので、うなぎ屋の印半纏を着た男が小さい岡持をたずさえて穴釣りをしているのをしばしば見受けた。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動山にいつて、参謀本部が作戦計画を立てはじめた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "参謀本部といふのは、徳一君と久助君と兵太郎君で、誰がきめたのでもなかつたが、しぜんにさういふことになつてゐたのである。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふことが上手だから、参謀本部の一人になるねうちはあると、兵太郎はじぶんで考へてゐたのである。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、参謀本部が、誰と誰を支那兵にし、誰を友軍の斥候にし、誰をタンクにするかといふやうなことをきめてゐたときのことだつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「参謀本部の翻訳をして、まだ学校なども独逸語を持っていますな――早瀬主税――と云う、あれは、貴娘の父様の弟子ですな。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勿論早瀬は、それがために、分けて規律の正しい、参謀本部の方は、この新聞が出ない先に辞職、免官に、なったです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、とんだ災難で、早瀬は参謀本部の訳官も辞した、と新聞には体裁よく出してあるが、考えて御覧なさい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの会のほとんど参謀長とも謂つべき本宅の大切な母親が、あいにく病気で、さしたる事ではないが、推してそういう場所へ出て、気配り心扱いをするのは、甚だ予後のために宜しからず、と医家だけに深く注意した処から、自分で進んだ次第ではなく、道子が出席することになった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　道学者の坂田（アバ大人）さんが、兄さんの媒口を利くのが癪に障るからって、（攫徒の手つだいをして、参謀本部も諭旨免官になりました。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る参謀将校は、この度のわが作戦は、敵の意表の外に出ず、と語った。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "参謀も新聞社も、ユウモアのつもりではなかったようだ。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此を隠謀の参謀本部として、豚汁をつついては密議を凝らし、夜更けて雨でも降れば、よく二人で同じ蒲団に雑魚寝をしたもの。",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "又二｜里ばかり大蛇の畝るやうな坂を、山懐に突当つて岩角を曲つて、木の根を繞つて参つたが此処のことで余りの道ぢやつたから、参謀本部の絵図面を開いて見ました。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母には、四谷の津の守で芸妓屋の参謀をしているふだんは音信不通の弟が一人ありますが、リョウマチで臥ているとかで、その妻と娘が来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、この海軍参謀、ちょんがらちょっぴりの小男でござい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "近衛局出仕を罷められ、参謀本部出仕にならせ給ふ。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "参謀本部出仕を罷められ、戸山学校次長に補せられさせ給ふ。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴かない許りでなく李如松は怒って之を斬ろうとさえしたが、参謀が惟敬をして行長を偽り油断させる策を説いたので命｜丈は助かった。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより陳曹操の不仁を悪み、次の宿でその熟睡に乗じ刺し殺さんとしたが思い直してこれを捨て去り、後日｜呂布の参謀となって曹操に殺されたとある。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者よ、試みに参謀本部五万分の一の地図「四万」の部を開いて見給え。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は初め参謀本部のものに拠らず他の府県別の簡単なものを開いて見てこの猿ヶ京村を見出し、サテも斯んな処に村があり、斯んな処にも歌を詠もうと志している人がいるのかと、少なからず驚嘆したのであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタズラの張本人は大杉君で、荒畑寒村君なども参謀の一人だったろう。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
