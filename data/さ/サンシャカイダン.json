        "examples": {
          "standard": [
            {
              "text": "離婚問題の解決に向けて、弁護士を交えた三者会談が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "紛争地域の和平実現のため、関係国の首脳による三者会談が急遽開かれることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "親子と担任教師による三者会談で、進路についてじっくり話し合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "が、ここではそれに触れる必要も余白もない、単直に三者会談を紹介するわけであるが、満信と山治との質問は、ひと口に云うと、「泰三を赴任させた真意はどこにあるか」ということであった。",
              "citation": {
                "source": "思い違い物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殿が金満家であられると、金満家で」「わけがわからん、金満家とはなんであろうか」　三者会談はこのようにして終った。",
              "citation": {
                "source": "思い違い物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬を連れて行ったので、フィールデン、ラッフル爺さん、マロウの三者会談は聞けなかった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
