        "examples": {
          "standard": [
            {
              "text": "サイバネティックスの概念は、人間と機械の相互作用を理解する上で不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このSF小説は、サイバネティックスが社会にもたらす影響を深く考察している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はサイバネティックスを専門とし、義肢の開発に尽力している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それはサイバネティックスと呼ばれる一連の機械論的還元主義だ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでデカルトが二次元座標を用いて幾何学を代数的に処理したように、サイバネティックスはこの四つの軸からなる座標を１と０の二進数で描写してしまう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが僕が言いたいのはこうしたサイバネティックスの思想が宇宙を蝕み始めた現代において、たった一つだけ人間を１と０から解放し、再び尊厳を持った人間を回復させる救済の可能性があるということだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイバネティックスは１と０で大宇宙を四次元的に描写する決定論だ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが呼吸をしていることも、気まぐれに首をかしげてみることも、サイバネティックスは１と０の膨大な配列で最初から予言してしまう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイバネティックスの１と０も数だ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
