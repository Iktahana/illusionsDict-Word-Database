          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "久しぶりに会った学生時代の友人は、すっかり変わっていた。「去る者日々に疎し」を感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "連絡を怠っていると、去る者日々に疎しになってしまうから気をつけよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "物理的な距離が離れても、心の距離まで去る者日々に疎しにはしたくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
