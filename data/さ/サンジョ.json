[
  {
    "uuid": "ba8bc45b-6c61-5a8b-9afe-3fd2a178b2e4",
    "entry": "三女",
    "reading": {
      "primary": "さんじょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
