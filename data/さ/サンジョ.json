  {
    "uuid": "cdd52da7-b9b0-5975-bcad-cf1d874c00b9",
    "entry": "芟除",
    "reading": {
      "primary": "さんじょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
