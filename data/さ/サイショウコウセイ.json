        "examples": {
          "standard": [
            {
              "text": "新しいサーバーを構築する際、まずは最小構成で起動確認を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このソフトウェアは、最小構成でも十分に動作するよう設計されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "システムトラブルの原因を特定するため、最小構成でのテストが有効だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "システム１００の価格は、最小構成で約三七〇万円。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "システム20／15の最小構成の価格は、一九九万八〇〇〇円とされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最小構成で七三万円、本格的に日本語を使うとなると一五〇万円を超える価格も、個人の道具の枠にはおさまっていなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最小構成では四ＫバイトのＲＡＭは、最大で四八Ｋバイトまで拡張できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロッピーディスクが常識となる時代を先取りして、六四〇Ｋバイトの五インチドライブを最小構成でも一台持たせると踏ん切ったパソピア16は、ＭＳ―ＤＯＳマシンとして立ち上がり、ＧＷベーシックもフロッピーディスクから読み込む形をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスクなしの最小構成で一四万五〇〇〇円。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
