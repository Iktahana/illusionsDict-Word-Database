          "literary": [
            {
              "text": "それに初陣の時拝領した兼光を差し添えた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は部屋の壁々に彼女の母の代りに新しい花を差し添えた。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、燃え口からはみ出すほど、後から後から新な薪を差し添えた。",
              "citation": {
                "source": "光のない朝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋詰には医者が附けられ、又土佐藩から看護人が差し添えられた。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　素早く団八の差し添えへ手をかけ、「可哀そうだねえ」「わーッ……わ、わ、わ、わッ」「もう一｜抉り！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ご存知の白須氏、桐島氏差し添え、これより直ちに駕籠をもって、冬次郎様お屋敷まで差し立てまする……つきましてはこれなる小箱一個、私より冬次郎様へのご進物、そなたの手よりお渡しくだされ、このようにご伝達くださりませ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……差し添えを抜いた逆賊の走狗の、その差し添えで御胸元を二太刀！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、南の奉行所から差し紙が来たので、一空さま差し添えで蒼い顔を見せていた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではもう一名、べつにしかるべき与力を差し添えてやろう。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……よって、なんじの身柄と、証拠物件一切を差し添え、関係者すべての者も、東平府の奉行所へさしまわし、そちらで判決を仰ぐことに相成ろうぞ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
