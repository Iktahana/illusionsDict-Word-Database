      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "soccer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伝統あるサッカー部が全国大会への出場を果たすと、当初は彼らの勝利を讃える原稿が載りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォークキャンプ実現に向けた呼びかけやサッカー部後援会への決算報告要求。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラグビー部やサッカー部の連中が大挙して入ったあとでは、泥風呂といわれるくらいに、湯が茶色くにごってしまう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝統的な校技としてのサッカー、毎年二〇人前後は卒業生を東京大学に送り込む学力レベルの高さ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに放課後のクラブ活動にはサッカーを選び、授業の終わった四時ごろから、毎日二時間ほどボールを追った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同室の人間とも、サッカー部の連中ともトラブルはなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その庭では野球やサッカーと一緒にゴルフもやれるようになっている。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミンナ黒人ノ俳優バカリ使ッテアルノ」「ソレガソンナニイヽノカネ」「ブレノ・メロッテノハサッカーノ選手上リデ、素人ナンデスッテ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト、ヤガテ彼女ハ行ケ／＼ノ戸口カラ現レタガ、今度ハ鮭色ピンクノサッカーノガウンヲ着テ、支那製ラシイ牡丹ノ刺繍ノアル繻子ノ室内履ヲ穿イテ来タ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例ノサッカーノガウンニ着換エテ立ッテイル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ出たとらは、ゆうゆうとあるいてゆく、彼は黒っぽい三毛猫で、躯もたっぷり肥えていて大きいし、顔もサッカーのボールくらい大きくてまるかった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろずう躰がすばらしく大きいし、サッカーのボールほどもある顔で、牙を剥き出しながら睨まれると、たいていの者がはいりそびれてしまう。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はしっこいビルマ人がサッカー場で私を蹴躓かせ、審判（これもまたビルマ人）があらぬ方を見ていた時、群衆は胸糞悪い哄笑でこれを歓迎した。",
              "citation": {
                "source": "象を撃つ",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
