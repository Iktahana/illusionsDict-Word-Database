        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "劣勢だったチームは、最後っ屁とばかりに猛攻を仕掛けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は不利な状況を打開するため、最後っ屁とも言える奇策に出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もう打つ手はないと思われたが、彼は最後っ屁を使った」と解説者が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
