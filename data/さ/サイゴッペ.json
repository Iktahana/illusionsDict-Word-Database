          "literary": [
            {
              "text": "三郎は嘘の最後っ屁の我慢できぬ悪臭をかいだような気がした。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタチの最後っ屁ということは聞いていたが、これをまともに嗅がされたには驚いた。",
              "citation": {
                "source": "猫先生の弁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが御めえいざってえ段になると奴め最後っ屁をこきゃがった。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やるなら、こうだ」　最後っ屁を発して、壇上から床へ飛び下りた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
