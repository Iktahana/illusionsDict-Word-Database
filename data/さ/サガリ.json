    "definitions": [
      {
        "index": 1,
        "gloss": "fall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "片側の大名邸の高い土堤の上に茂り重なる萩青芒の上から、芭蕉の広葉が大わらわに道へ差し出て、街燈の下まで垂れ下がり、風の夜は大きな黒い影が道一杯にゆれる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルマン教授は胡麻塩の長髪を後ろへ撫でつけていて、いつも七つ下がりのフロックを着ていたが、講義の言語はこの先生がいちばん分りやすくて楽であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水平に持って歩いていた網を前下がりに取り直し、少し中腰になったまま小刻みの駆け足で走り出した。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手水鉢を座敷のまん中で取り落として洪水を起こしたり、火燵のお下がりを入れて寝て蒲団から畳まで径一尺ほどの焼け穴をこしらえた事もあった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、海の面はどこでも一昼夜に二度ずつ上がり下がりをするもので、それを潮の満干と云います。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の海軟風（土佐ではマゼという）が衰えてやがて無風状態になると、気温は実際下がり始めていても人の感じる暑さは次第に増して来る。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "纒いしは袷一枚、裾は短かく襤褸下がり濡れしままわずかに脛を隠せり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい炭取りくらいの大きさの竹かごを棒切れの先に引っかけたのを肩にかついで、跛を引き歩きながら「丸葉柳は、山オコゼは」と、少し舌のもつれるような低音で尻下がりのアクセントで呼びありくのであった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元からすこしだらだら下がりになり萱が一面に生え、尾花の末が日に光っている、萱原の先きが畑で、畑の先に背の低い林が一｜叢繁り、その林の上に遠い杉の小杜が見え、地平線の上に淡々しい雲が集まっていて雲の色にまがいそうな連山がその間にすこしずつ見える。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにお立ちの方はありませんかとでも云ったようでしたが誰もしんとして答えるものがありませんでしたので次長は一寸礼をして引き下がりました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は――吹矢も、化ものと名のついたので、幽霊の廂合の幕から倒にぶら下がり、見越入道は誂えた穴からヌッと出る。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし引下がりて白き駒控へたる少女、わが目がねはしばしこれに留まりぬ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし引き下がりて白き駒控えたる少女、わが目がねはしばしこれにとどまりぬ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソクラテスが、籠にはいって吊り下がりながら、天界の事を考えた話を思い出した。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件当夜は、ロイロットさんは早くから寝室へ下がりましたが、おそらくお休みになったのではないと思います。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "言うことを聞いて、部屋に下がりたまえ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "活版印刷業者がじょじょに態勢を立て直すと、謄写版は再び、印刷業の裾野に引き下がります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "以降、この分野では、日本のメーカーがゼロックスに盛んに挑戦を仕掛け、競争を通じて値段が下がりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "枚数を増やせれば、単価はさらに大幅に下がります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "干潮に向かって波が引くように次第に熱が下がりはじめると、深い疲労の底から重苦しい胃袋が浮かんできました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計の針が突然止まってしまったような昼下がりの河原で、小澤家の人々が体験する一風変わった人たちの出会いが、飼い犬のロンの目から描かれていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "よかったらイーサネットでうちのマシンにぶら下がりませんか」と、藤井さんは切り出します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　それから二日目の七ツ下がり（午後四時過ぎ）に、善八と幸次郎が半七の長火鉢のまえに鼻をそろえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "利章は「はつ」と云つて、疊三枚程する／＼と下がり兩眼に涙を浮べて「難有き爲合せに存じ奉ります」と云つた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾つかの女御や更衣たちの御殿の廊を通い路にして帝がしばしばそこへおいでになり、宿直をする更衣が上がり下がりして行く桐壺であったから、始終ながめていねばならぬ御殿の住人たちの恨みが量んでいくのも道理と言わねばならない。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "加冠が終わって、いったん休息所に下がり、そこで源氏は服を変えて庭上の拝をした。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし綾衣の紋が下がり藤であるということだけは、確かに知っていた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "下がり藤の紋があざやかに見えた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　向う両国の観世物小屋でこんな不意の出来事が人を驚かしたのは、文化三年の江戸の秋ももう一日でちょうど最中の月を観ようという八月十四日の昼の七つ（四時）下がりであった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、急にけさほど――」「宿下がりいたしましたか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            }
          ]
        }
