    "definitions": [
      {
        "index": 1,
        "gloss": "do not pursue those who leave you",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
