        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから見ると、盛りのついた猫のあわて過ぎて板壁からころげ落ちる方が、まだしも活氣がある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者の診察室にはいると、患者は言われぬ先に自分から、十進法の目盛りのついた小型な秤の台座に立った。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪が長けりゃ女じゃ、と合点して、さかりのついた犬同然、珠を頂いた御恩なぞも、新屋の姉えに、藪の前で、牡丹餅半分分けてもろうた了簡じゃで、のう、食物も下されば、お情も下さりょうぐらいに思うて、こびりついたでござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷峰はその樣子をさかりのついた雌馬の樣だと思つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夜になると彼奴等の猛しい唸り声を聞いて、遠近のさかりのついた野良犬や、狂犬どもが盛んに吠え立てるのだ。",
              "citation": {
                "source": "犬舎",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかりのついた豚みたいだ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きらわれものの女白浪、それもお前というお人を一度見てからは、意馬心猿とやらが浅間しく乗り移った、さかりのついた雌犬同然さ――それで、悪いかえ？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかりのついた猫の鳴き声に耳を傾けました。",
              "citation": {
                "source": "未亡人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お綱の奴が急に二階へとんとん登つて行つた意味は一目瞭然であるから、さかりのついた猫の声と同様のけたたましい笑ひ声を耳にしては、腸のよぢれる思ひがしたことであらう。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お綱の奴が急に二階へとんとん登って行った意味は一目｜瞭然であるから、さかりのついた猫の声と同様のけたたましい笑い声を耳にしては腸のよじれる思いがしたことであろう。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかりのついた犬みたいに狂暴になった助手たちから自分を自由にしてくれということだったんだ。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでさかりのついた猫より下劣だ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
