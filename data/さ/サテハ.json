        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かなたにてきらめく川やさてはまた遠山の雪その枝にからすとまればざんざんと実はうちゆるゝこのときに教諭白藤灰いろのイムバネス着ていぶかしく五助をながめ粘土地をよこぎりてくる",
              "citation": {
                "source": "〔洪積の台のはてなる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてはＢ君、俺の金がツケメかな」とＡ君が試みに思ふとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本文学にしろ外国文学にしろ、その作品の「流れ」の諦視、「持続ぶり」「終始ぶり」の諦視、さてはフォルムに就いての理念、その涵養が今日我々の緊急事である。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "不十分に、さては断片的に、誌すことは出来るにしても、尠くもこの小論中に書くとしたら全くの無意味でさへある。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一重筵の上にして蒔繪の盆や草雙紙さては廚の煤鍋が入り亂れたる狂態を水干やれし古雛のこは狼藉ととがめずや。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔除鼠除けの呪文、さては唐竹割の術より小よりで箸を切る伝まで十銭のところ三銭までに勉強して教える男の武者修行めきたるなど。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芒の蓬々たるあれば萩の道に溢れんとする、さては芙蓉の白き紅なる、紫苑、女郎花、藤袴、釣鐘花、虎の尾、鶏頭、鳳仙花、水引の花さま／″＼に咲き乱れて、径その間に通じ、道傍に何々塚の立つなどあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては白湾子と共に名古屋に遊びし帰途伊勢を経て雪夜こゝに一夜を明かせし淋しさなどもさま／″＼偲ばる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては五十鈴の流れ二見の浜など昔の草枕にて居眠りの夢を結ばんとすれどもならず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎は、舟をゆはへ附けよと言はれて、さてはこの馬鹿も何か感づいたかな？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このすゞろなる物の音に　　希望はあらず、さてはまた、懺悔もあらず。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さては米代を飲んぢまやがつたな」　と腹の中で云つて、私は首をすくめた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "（引出しの分も拜借致し候　　　石之助）さては放蕩かと人々顏を見合せてお峯が詮議は無かりき、孝の餘徳は我れ知らず石之助の罪に成りしか、いや／＼知りて序に冠りし罪かも知れず、さらば石之助はお峯が守り本尊なるべし、後の事しりたや。",
              "citation": {
                "source": "大つごもり",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿、今もし此處におはしまして、例の辱けなき御詞の數々、さては恨みに憎みのそひて御聲あらく、さては勿躰なき御命いまを限りとの給ふとも、我れは此眼の動かんものか、此胸の騷がんものか、動くは逢見たき慾よりなり、騷ぐは下に戀しければなり。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（引出しの分も拝借致し候　　　　　石之助）　さては放蕩かと人々顔を見合せてお峯が詮議は無かりき、孝の余徳は我れ知らず石之助の罪に成りしか、いやいや知りて序に冠りし罪かも知れず、さらば石之助はお峯が守り本尊なるべし、後の事しりたや。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（引出しの分も拜借致し候　　　　　　　　石之助）　さては放蕩かと人々顏を見合せてお峰が詮議は無かりき、孝の餘徳は我れ知らず石之助の罪に成りしか、いや／＼知りて序に冠りし罪かも知れず、さらば石之助はお峰が守り本尊なるべし、後の事しりたや。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿、今もし此処におはしまして、例の辱けなき御詞の数々、さては恨みに憎くみのそひて御声あらく、さては勿躰なき御命いまを限りとの給ふとも、我れはこの眼の動かん物か、この胸の騒がんものか。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「変だ変だと思ったが……さては、父っつあん、お前お貸元に何か云ったな？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が、Ｔ「伝八つあんと仰しゃるんでしょう」　棚倉さてはと思って門弟に合図する。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "側の門弟の一人が、さては、と意味あり気な顔で見合わす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、Ｔ「さすれば　命だけは助けてやる」　と云われて典六「さては半次」と立ち上らんとするが、　大吉に刀突き付けられ、　仕方なく両手をついて詫びる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様が、Ｔ「さては　騙り者か」　と言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてはにはかに現はれて、　　ひたすらうしろすべりする、　黒き毛剃の庶務課長。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おふみが「あのね」Ｔ「どうぞ私の願いが叶いますようにッて」　アレッレッ、　と伝六驚いて、　さてはおふみちゃん、Ｔ「誰かに惚れたね」　「知らないわ」　伝六が、　「ハテ誰かな」Ｔ「誰に惚れたんだい」　「知らないッ」　おふみちゃん、ちょいと赧い顔して立ち上る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては緯度をとび越えたのか。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては今の時の暢気さは、この浪が立とうとする用意に、フイと静まった海らしい。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてはあつらえたまいしごとく家に送りたまうならむと推はかるのみ、わが胸の中はすべて見すかすばかり知りたまうようなれば、わかれの惜しきも、ことのいぶかしきも、取出でていわむは益なし。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
