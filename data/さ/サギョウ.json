    "definitions": [
      {
        "index": 1,
        "gloss": "the \"sa\" column of the Japanese syllabary table (sa, shi, su, se, so)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「全体どごさ行ぐのだべ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どごさ行ぐのだべ。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上さ行って好い草食え。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして引っ返そうとしましたら、「達二、どこさ行く。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お前さま今夜ほうのきさ仏さん拝みさ行ぐべ。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ふん見さ行ぐべさ。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれこれがら出掛げて峠さ行ぐまでに行ぎあって今夜の踊り見るべしてすすめるがらよ、なあにどごまで行がなぃやなぃようだなぃがけな。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして踊り済まってがら家さ連れで来ておれ実家さ行って泊って来るがらうなこっちで泣いて頼んでみなよ。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「山の方ぁい、い※とも学校さ行がれなぃもな。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんがそこで「何した、家さ行ぐだぐなったのが、何した。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家さ行ぐだぃぐなったべぁな。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上さ行げば平らだはんて。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（承知、承知、おお、嬢様どこさ行かっしゃる。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上さ行って好い草食へ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして引っ返さうとしましたら、「達二、どこさ行く。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんつ野原さ行ぐべすさ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんつぁんのとこさ行くと帰れ／＼といふべ、俺やけ糞になつて、何もしねえで町の中をごろつき歩いてゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんつぁんとこさ行つたらおんつぁんがいつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩俺はおんつぁんの作つてくれた風呂敷包を全部質において、料理屋さ行つてうつと飲んで女を買つたら、次ぐの朝払ひが足らなかつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしに牛太郎と一緒におやぢのとこさ行つたらお袋が危篤で俺らこと捜しぬいてるところだつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　二十四「後を頼むとって、お前様、どこさ行かっしゃる。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われさ行水するだら蛙飛込む古池というへ行けさ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の村さ行つたて、俺の酒呑んでゐねえ巡査一人だつて無えがら。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（承知、承知、おゝ、嬢様何処さ行かつしやる。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（何さ行つて見さつしやい御亭主は無事ぢや、いやなかなか私が手には口説落されなんだ、はゝゝゝはゝ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お城趾の方さ行つては成んねえだ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かあちやん、何處さ行ぐの」「町へさ」「なんに行ぐの」「此の荷物をもつてよ」「町つて、どこ」「いま行けばわかるがね。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、　町の　西門に　かまえた　ちいさな　お店の　まどぎわで、　さぎょう台の上に　あぐらを　かいて、　朝から　ばんまで　すわっていました。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぬいとりの　ぬのに　合わせて、　むだなく　ふくの　かたちを　たち切りましたから、　さぎょう台の上に　ちらかるのは、　ほんの少しの　切れはしだけ　――「はしきれすぎて、　どうにもならない　――　ネズミの　チョッキには　なるくらいだ。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぎょう台じゅうに、　さくらんぼ色の　切れはしが　とっちらかります。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
