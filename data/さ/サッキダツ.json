      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be seething (with anger)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死に目に会ふことも許されない寿枝と楢雄は香櫨園の家でソハソハしながら、不安な気持のまま何か殺気立つてゐた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と相手が殺気立つて拳固を突き出したから私も、「何でえ！",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かゞ、私が居酒屋の娘に怪しからぬ想ひを抱いてゐる、それで、せめてもそんな言ひがゝりをつけて抱擁の快を感じようとでもしてゐるに違ひない――などゝひやかすと、妻は幾分殺気立つて、「何といふ厭な奴だらう、失礼な。",
              "citation": {
                "source": "出発",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などとＡの口調を真似たかのやうに殺気立つて横柄に叫んだり、「それツ！",
              "citation": {
                "source": "雪景色",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は、内心唖然としたのであるが、眼付までも殺気立つてゐる気合ひに蹴落されて諾々としてしまつたのである。",
              "citation": {
                "source": "西瓜喰ふ人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」新庄は殺気立つた彼の目を見つめながら、その手を掴んだ。",
              "citation": {
                "source": "浪の音",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "にやにやと殺気立つ選択眼。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い空気がマグネシュームをたいてとられた写真の面に感じられるが、その雰囲気は率直に殺気立つものとは違った、寧ろ大変大人っぽい、謂わば相方とも腹のなかは心得きっている上での折衝と云う情景である。",
              "citation": {
                "source": "電車の見えない電車通り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝昼なしに混雑する宮島線の電車は、夕刻になると更に殺気立つ。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺気立つた中に、何ともいへぬ間の抜けたものも感じられる、奇怪な世界であつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈アサツテカヘル〉　僕には殺気立つた甥の顔が目に見えてくるやうだつた。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉庫の仕事は元来滅多にないようないい稼ぎ口なので、それに抜かれてあぶれてみれば憎悪と嫉妬の念に駆り立てられ殺気立つのも無理はなかった。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "』或日口笛を吹き鳴らし吹き鳴らし炭坑へ行くとあんなに静かだつた坑夫部屋の窓々が皆殺気立つて糸巻きのやうに空つぽのトロツコがレールに浮いてゐた。",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこのおそるべく厭な大蜘蛛が現われた時の、私の家庭はそれこそ殺気立つのだ、子供の時分は、さア早く来てくれ、蜘蛛や蜘蛛やと逃げ出せば、誰れかが処置をつけてくれたが、目下私が一番大人であるから、その体面上からいっても、退治るのは私の責任でまた退治るには、女中や妻君に任せておけないのだ。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に藤本鉄石の樹木は錆ナイフのやうに殺気立つてゐる。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかう云ふ殺気立つた光景を好まないので、室外へ出て汽車を待つてゐると、またいろいろの厭な事が耳に入つた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "この報一たび伝はるや、鉱毒地一帯が忽ち殺気立つた。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を尊敬するに地にぬかずくような気違い共だから、正しい理論は失われ、頑迷コローな片意地と、不自然な義理人情に身もだえて、電車は殺気立つ、一足外へでると、みんな死にもの狂いのていたらく、悲しい有様である。",
              "citation": {
                "source": "天皇陛下にさゝぐる言葉",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときはもう日本の負けることは明らかな時で、いづれ本土は戦場となり、私も死に、日本の男はあらまし死に、女だけが残つて、殺気立つた兵隊たちのオモチャになつて殺されたり可愛がられたりするのだらうと考へてゐたので、私は重荷を下したやうにホッとした気持があつた。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "市中は、これこそ殺気立つてゐると思はれたが、それも停車場附近で人力車夫が争つて客を呼ぶ声をさう取つたのは致し方もない。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "同乗の一将校は、その軍服が血の臭ひのするほど殺気立つてゐた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "月給千円、食事づきで雇ひたいと申しでると全員にわかに殺気立つて我も我もと申出るのを押しとゞめ一室をかりて一人づゝ口答試問を行ふ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は殺気立つと気違ひだつた。",
              "citation": {
                "source": "いづこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "父を裏切り一門を亡す奸賊であるといふので父と兄が刀の柄に手をかけ青ざめて殺気立つから、私の間違ひでありました、父上、兄上の御決意でありますなら私も違背は致しませぬ、と言つて一時をごまかした。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌舞伎踊はまだ劇の形式に整へられてゐなかつたが、とにかく、その人気は日本全国に及び、見物の群衆が殺気立つて刃傷沙汰まで惹き起したので、遂に、寛永の中頃、法令によつて厳禁されたといふ記録がある。",
              "citation": {
                "source": "演劇と政治",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりには急に殺気立つた空気が感じられた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、下方では殺気立つた空気が暗らがりの中に暗く、圧するやうに籠つてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに不当に殺気立つてゐたのであつた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は殺気立つと気違いだった。",
              "citation": {
                "source": "いずこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
