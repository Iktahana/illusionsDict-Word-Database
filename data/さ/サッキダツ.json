[
  {
    "uuid": "4c117466-03af-51cc-93cb-02b00828535e",
    "entry": "殺気立つ",
    "reading": {
      "primary": "さっきだつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Godan verb with 'tsu' ending",
