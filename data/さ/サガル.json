  {
    "uuid": "9a73015b-49a4-5d1a-8f6d-f80ed55d9932",
    "entry": "下ル",
    "reading": {
      "primary": "さがる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "below",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "以下ルクレチウスと私の呼ぶものは、必ずしもローマの詩人ルクレチウス・カールスをさすのではなくて、かの書に示された学説の代表者を抽象してそれをさすものである事を承知した上で以下の解説を読んでもらいたいと思うのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御申上なれバ、京師柳馬場三条下ル所、楢崎将作死後五年トナル。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十二月四日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時私ハ京都三条通河原町一丁下ル車道｜酢屋に宿申候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年六月二十四日　乙女、おやべあて",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　さて京都の屋敷は、高倉通り六角下ル和久屋町という所で、今まで居た岡本という京都留守居と交代して、ここに落着いた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大和行幸の洛中へ触れ出されたのを自分が知ったのは、柳馬場丸太町｜下ル所よりの来状を手にした時であった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺町今出川下町壱人、上立売下ル瓢箪之図子に壱人。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代にはお庭掃除は小法師と称して、もとは丹波の山国から出ておったが、中頃は三条余部村のエタ六人と、寺町今出川下ル町及び上立売下ル瓢箪図子から各一人、都合八人でこれを奉仕し、享保十二年以後は大和丹波市外六人のエタ村から出役し、さらに後には京都蓮台野からもこれを勤めておった。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（同巻ヲ倒ニシテ巻首ヨリノ中程ニ突然ト左ノ数行アリ）廿三日　将軍坂ニ下ル○廿三日ハ乙丑ノ九月ナリ校正者識廿四日夜　大坂ニ下ル。",
              "citation": {
                "source": "坂本龍馬手帳摘要",
                "author": "坂本龍馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿三日夜　伏水ニ下ル二時過ル頃―――廿四日朝　邸ニ入ル。",
              "citation": {
                "source": "坂本龍馬手帳摘要",
                "author": "坂本龍馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "森玉岡の著『両総｜吟嚢』という書に河野秀幹、字子貞、号克堂、俗称蔵、南東金ノ人〕として「秋日下墨水」〔秋日墨水ヲ下ル〕七絶一首が載っている。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶頂から東の方へ下り気味に四町｜許行った処は、『甲斐国志』に北方ハ本宮ヨリ奥ノ院薬師ヶ岳ヘ下ルコト一里許、此処甲信両州ノ界ニシテ、神領モ亦此ニ限ル、天正壬午ノ御朱印ニ所謂長子ノ番所是ナリト云。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹見泉石の記述「公事務ノ暇、雪ノ下ル毎ニ之ヲ審視スルコト、今春ニ至テ、幾ド二十年」というのによると、土井利位、或は泉石が初めて顕微鏡で雪華を観察したのは、一八一二年頃で、甫周が顕微鏡の用法を講述してから十年後くらいに当る。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな家も持てあましてきたので、西洞院七条下ル堀川の小さな家へ移った。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩一晩ダケデス、明日コノ川下ルト海ニ出マス、海ニ出ルトソノ黒船ガ待ッテイルデス。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長は、三好長慶から乞いうけた「管領家家人、東国ヘ下ル者」とある往来手形を、木戸へかかるたび、所領の役人へ出して示した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川放水路の水量を調節する近代科学的｜閘門の上を通って土手を数町川下へさがると右にクラブハウスがあり左にリンクが展開している。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "如斯ことはきょう始めてと云うではないが見る度に胸がふさがるべくおぼえ何と云うて慰さめんようもなく身も世もあらぬ思である。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "うるさがる様子にて。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし相手がはにかむ場合には園は黙って引きさがるほかはなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を隔てて眼の前にふさがるように切り立った高い崕の上に、やや黄味を帯びた青空が寒々と冴えて、ガラス板を張りつめたように平らに広がっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな抽象論で引きさがるかい。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが脚気を煩つて、二週間程の間に眼もふさがる位の水腫れがして、心臓麻痺で誰も知らないうちに亡くなつて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も村民はこの女王を真中に守護して、お練りをする時のやうにごたごたして居ながらも、此人の前に立ちふさがるやうなぶしつけをしようとするものはなかつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の袂にも、蘆の上にも、随所に、米つき虫は陽炎のごとくに舞って、むらむらむらと下へ巻き下っては、トンと上って、むらむらとまた舞いさがる。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前帯をしゃんとした細腰を、廂にぶらさがるようにして、綻びた脇の下から、狂人の嘉吉は、きょろりと一目。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯を食べながら、澄太さんから清水さんの話を聞く、聞けば聞くほど頭がさがる、そして自分の不甲斐なさを恥ぢる、是非一度は同朋園を訪ねたいと思ふ。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "これみな恬澹な名僧といわれた父親の世務をうるさがる性癖から来た結果だが、母親はどういうものか父を恨まなかった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし極めずは、四十より能はさがるべし。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "さる程に、あがるは三十四五までの比、さがるは四十以来なり。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "長兄の苦労のほどに頭さがる。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
