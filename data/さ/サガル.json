    "definitions": [
      {
        "index": 1,
        "gloss": "to come down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "風雪というものを知らない国があったとする、年中気温が摂氏二十五度を下がる事がなかったとする。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｄ君は現在教育制度の欠陥を論じて、日本人は小学から大学までただ満員電車にぶら下がる術を教わるばかりだと云った。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学位のねうちは下がるほど国家の慶事である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めにはいきなり酷く叱られて慄え上がるが、教えを受けて引下がるときは皆嬉々として引下がったという話である。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすっかり弱ってしまって、丁度｜悪戯をしてつかまった子供のような意気地のない心持になって、主人の云うがままになって引き下がる外はなかったのである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "足踏み辷らして崖へ落ちて木へブラ下がる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸につかえていたものが一時に下がるような気がした。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれに対して一つの心配することは、最高水準を下げると同時に最低水準も下がるというのは自然の変異の方則であるから、このユートピアンの努力の結果はつまり人間を次第に類人猿の方向に導くということになるかもしれないということである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "能を見て頭が下がるのは、かように生死以上の生死をあらわす「舞台＝戦場」の厳粛さに打たれるからではあるまいか。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは人間の祖先の猿が手で樹枝からぶら下がる時にその足で樹幹を押えようとした習性の遺伝であろうと言った学者があるくらいであるから、猫の足踏みと文明人のダンスとの間の関係を考えてみるのも一つの空想としては許されるべきものであろう。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひたといい出すお袋の事」と上がれば「よもすがら尼の持病を押えける」と下がるのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこれらのいっさいを一束にしても天秤は俳諧連句のほうへ下がるであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎしぎしと音がして、青黄色に膨れた、投機家が、豚を一匹、まるで吸った蛭のように、ずどうんと腰で摺り、欄干に、よれよれの兵児帯をしめつけたのを力綱に縋って、ぶら下がるように楫を取って下りて来る。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子はピンをさし終えるが早いか、突然いやに冷めたい手で私の両耳にぶら下がると、私の唇に接吻して、どんどん暗やみの方へ逃げて行ってしまったではないか。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺でもどうかすると、ひどく戦塵に汚れ窶れた傷病兵の出迎えがあり、乗客の目を傷ましめたが、均平もこの民族の発展的な戦争を考えるごとに、まず兵士の身のうえを考える方なので、それらの人たちを見ると、つい感傷的にならないわけに行かず、おのずと頭が下がるのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨此の毒飼の事が実に存したこととすれば、氏郷は宜いが政宗は甚く器量が下がる。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "白州を下がる子供らを見送って佐佐は太田と稲垣とに向いて、「生先の恐ろしいものでござりますな」と言った。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道中で商売をしている以上、それで素直に引下がる筈のないのは判り切っていた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気圧が急に下がるからだという。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ポケットはちょうど状差しのような具合に教室の中へ、窓の下の板壁に垂れ下がるのだった。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "では少し夜食をいただいて、部屋へ下がるとしましょう。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "火のついた蝋燭を手にして、自分の寝室へ下がる間際に、「ワトソン。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "金具からぶら下がる様子は、さらに激しく際だって、もはやどう見ても人間ではない。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも話したとおり、僕の注意はすぐさま通風口と寝台の上に垂れ下がる綱とに向けられた。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私が食い下がると、「そんなものがいったい何になる？",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と己が頭髪を掴んで、宙に下がるばかり突立った。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に砕けていて、ちっともみずからがらない女だけれど、どこか恐しく品があって、私なんざ時々我ながら頭の下がることがありますもの。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とまあ時には一歩も引かぬやり合いを演じる鶴岡マングース雄二とアスキー・ハブ出版局ではあるが、連中がぐるになって積み重ねてきた仕事には実際頭が下がる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川放水路の水量を調節する近代科学的｜閘門の上を通って土手を数町川下へさがると右にクラブハウスがあり左にリンクが展開している。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "如斯ことはきょう始めてと云うではないが見る度に胸がふさがるべくおぼえ何と云うて慰さめんようもなく身も世もあらぬ思である。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
