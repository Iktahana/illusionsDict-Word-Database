  {
    "uuid": "d0d71a14-59d7-55fd-9ba8-fb6735242b70",
    "entry": "莢",
    "reading": {
      "primary": "さや",
      "alternatives": [
        "サヤ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pod (e.g. a pea pod)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大根の花も莢になっている時分であった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めのうち、清三は夏休み中、池の水を汲むのを手伝ったり、畑へ小豆の莢を摘みに行ったりした。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これの実を指にて摘めば虫などの跳るやうに自ら動きて、莢破れ子飛ぶこと極めて速やかなり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は食卓に大きな笊をのせて青い莢隠元をむしっていた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ折々聞るものは豌豆の莢が熱い日に彈けて豆の飛ぶ音か、草間の泉の私語やうな音、それでなくば食ひ飽た鳥が繁茂の中で物疎さうに羽搏をする羽音ばかり。",
              "citation": {
                "source": "怠惰屋の弟子入り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "此菓子はまずオレンジの内莢で香をつけた牛乳四デシリットルの中に、玉子十個とフルーレットクレーム四デシリットルを混ぜる。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪垣なる藤豆の、莢も實も、午の影紫にして、谷を繞る流あり。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱とチーズを壺焼にしたスープ・ア・ロニオンとか、牛舌のハヤシライスだとか、莢隠元のベリグレット・ソースのサラダとか、彼がふだん好んだものを註文したので鼈四郎は慥え易かった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨のない時期に、鴨に似た若い家鴨を探したり、夏｜長けて莢は硬ばってしまった中からしなやかな莢隠元を求めたり鼈四郎は、走り廻った。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤棚の藤が莢になって朝風にゆらめくのを少し寝不足の眼で私がうっとりと眺めて入って居ると麻川氏は私のずっと後の薄暗い床脇に蹲居の恰好で坐り込んだ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶室＝＝小床にたつた一つ、古油壺に莢になりかけた菜の花。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番上りのものには、瑪瑙の莢に、紅宝玉の実を装った、あの造りものの吉祥果を遣る。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラスノヱンドウの莢等。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夜になると、父親は浴衣がけで、印度産の籐の握り太のステッキを携え、莢豆の棚の間や青薄の蔭に潜む若い男女を、川狩の魚のようにつゝき出した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "栖子は千代重が指図して行った蚕豆の莢を盆の上で不手際に剥ぎながら、眼はぼんやり花畑を眺めていた。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "栖子は指先を莢の豆に無意識に動かしながら、心を遠くうねり尖らして、横浜の園芸会社へ、オランダから到着した新種のカーネーションの種子を取りに行くといって出て行き、五日も帰らない尾佐の挙措を探り廻した。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "栖子の両手の指先きが、つやつやした豆莢の厚い皮をぺちゃんと圧し潰し、小さい鼻から目の醒めるような青い匂いを吸い込みながら、莢の裂け目へ右の指先を突き入れると、彼女の指先になまなましい柔かいものが触た。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって莢を抛り出した。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代重は傍へ来て、体を曲げて栖子が抛り出した豆の莢を拾った。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代重は豆の莢の内部を近眼鏡をかしげて覗き込み、それから左の手套の水気をブラウズの腰でこすり取って、竿を眼にうけさせ、莢の破り口を逆にしてとんとんとはたいた。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ、南瓜も飛び出せ、牛蒡も踊り出せ、枝豆、隠元、ささぎ豆、なた豆、落花生に胡麻の種、莢がはぢけた、赤ちやけた、化猫、雉猫、かま鼬、粟が尻尾を黄に垂れた。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小径は、いつか東村と来た時に黒い矢車型のげんげの莢でいつぱいだつた。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "東と南とに欄干は繞り、廂にはまた藤の棚がその葉の青い光線から、おなじくまだ青い実の莢を幾｜条も幾｜条も垂らしてはいるが、そうして昼間の岐阜｜提灯にもが、風はそよともしないのである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣　稟鴉は木に眠り豆は莢の中秋の日の眞實丘の畑きんいろ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣稟鴉は木に眠り豆は莢の中秋の日の眞實丘の畑きんいろ。",
              "citation": {
                "source": "聖三稜玻璃",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "莢の中の豆　莢の中には豆粒が五つありました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああふるさとの永日に少女子どものなつかしさたとしへもなきなつかしさやさしく指を眼にあててももいろの秋の夕日をすかしみるわが身の春は土にうもれて空しく草木の根をひたせる涙。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ゆがみつゝ月は出で〕宮沢賢治ゆがみつゝ月は出でうすぐもは淡くにほへり汽車のおとはかなく恋ごゝろ風のふくらしペンのさやうしなはれ山の稜白くひかれり汽車の音はるけくなみだゆゑ松いとくろしかれ草はさやぎてわが手帳たゞほのかなり",
              "citation": {
                "source": "〔ゆがみつゝ月は出で〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "看痾宮沢賢治七月はさやに来れど故しらに人はなほ疾み日過ぎ来し白雲の野はさびしくも掃き浄めらる",
              "citation": {
                "source": "看痾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲があたしを連れてくのです……さよなら地球よ、さやうなら！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
