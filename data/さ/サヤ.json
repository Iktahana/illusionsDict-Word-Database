    "definitions": [
      {
        "index": 1,
        "gloss": "scabbard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "傍にあつた刀をとり上げて鞘を払つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『武家義理物語』の三の一に「すこしの鞘とがめなどいひつのり、無用の喧嘩を取むすび、或は相手を切りふせ、首尾よく立のくを、侍の本意のやうに沙汰せしが、是ひとつと道ならず。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝三次の宅（夜である）　行燈の燈影で三四郎が大刀の鞘を払って凝視する。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎会心の笑を浮べて刀を鞘に収める。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次尚も、Ｔ「それから　其の黒羽二重に　朱鞘の長刀　落し差して　居る処……」　と云われて仲蔵、恐る恐る「それがどうか致しましたか？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌流大刀の鞘を払って、鞘を捨てた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、切り出すと彼は熱情を鞘におさめてから冷淡に私に答えるのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まるで酒場の醉ひどれのやうな兵士の集團は濕つた路上に重い靴を引き摺りながら、革具をぎゆつぎゆつ軋らせながら劍鞘を互にかち合せながら、折折寢言のやうな唸り聲を立てながら、まだ五六｜里先のＮ原まで歩かなければならなかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "指揮刀の鞘の銀色を闇の中に閃かしてゐる小隊長の大島少尉さへよろけながら歩いてゐるのが、五六｜歩先に見えた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、いきなり左の方でガチヤガチヤと劍鞘の鳴る音がした。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が剣鞘で尻を殴った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」剣鞘で老人の尻を叩いている男に、さきの一人が思い切った調子で云った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森林の利権を買って、それをまた会社へ鞘を取って売りつけた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーベルの鞘が鳴る。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手向うの小高い丘の上から、銃を片手に提げ、片手に剣鞘を握って、斥候が馳せ下りて来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着剣した、兵士の銃と銃、剣と剣が触れあって、がちゃがちゃ鳴ったり、床尾板がほかの者の剣鞘をはねあげたりした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数寄の光壁更たけて、　　　　千の鱗翅と鞘翅目、直翅の輩はきたれども、　　　公子訪へるはあらざりき。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、柔らかい蹠の、鞘のなかに隠された、鉤のように曲った、匕首のように鋭い爪！",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつくしき人はなかばのりいでたまいて、とある蒔絵ものの手箱のなかより、一口の守刀を取出しつつ鞘ながら引そばめ、雄々しき声にて、「何が来てももう恐くはない、安心してお寝よ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "這個髯斑に眼円にして面赤き辺塞の驍将に対して、爾き言を出さむには、当時流行の剣劇の朱鞘で不可、講談ものゝ鉄扇でも不可い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シロオテは藤兵衛の心をさとったと見えて、やがて刀を鞘ながら抜いて差し出し、また、あやしい言葉を叫ぶのであった。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方風の細折結に羽二重の紋服、天鵞絨裾の野袴、二方革のブッサキ羽織に、螺鈿鞘、白柄の大小、二枚重ねの麻裏まで五分も隙のない体構え。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りにこの両三日のうちにはキット下手人を探り出いてお眼にかけまする私の所存……何卒……何卒御容赦を……」　松倉十内は、何か思い直したように切柄をかけた白鞘の脇差から手を離した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初から試し斬りの切柄かけた白鞘の新身の脇差を引付けて、物を訊く法があるものか。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば塗下駄や、帯や、蛇の目傘や、刀の鞘や、茶托や塗り盆などの漆黒な斑点が、適当な位置に適当な輪郭をもって置かれる事によって画面のつりあいが取れるようになっている。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日も浅田という元｜孵化場で同僚だった鞘取のような男が札幌から来て、長いこと話していった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い華車な顔にはめこまれた、鼠の眼のやうな可愛らしい眼がすわつて来ると、勃凸の全身は鞘を払つた懐剣のやうに見えた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊鳶色の古刀の鞘よ、舌あまりの幼な友達、おまへの額は四角張つてた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は赤鞘の安兵衛てんです。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああふるさとの永日に少女子どものなつかしさたとしへもなきなつかしさやさしく指を眼にあててももいろの秋の夕日をすかしみるわが身の春は土にうもれて空しく草木の根をひたせる涙。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
