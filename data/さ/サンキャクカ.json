        "examples": {
          "standard": [
            {
              "text": "望遠鏡は安定した三脚架に据え付けられ、天体観測の準備が整った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "測量機器を正確に設置するため、堅固な三脚架が用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "三脚架の上にカメラをセットし、夜景の撮影を開始した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どの部屋にも、電燈は勿論、ランプや燭台らしいものもなく、その代りには、各部屋の例の薄絹を張った窓の外の廊下に、赤々と燃え上る、焔の鉢をのせた三脚架が据えられ、その古風な焔が窓の色とりどりな薄絹を通して、各部屋を、キラキラと照らしていた。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の前には三脚架にカンヴァスが立てかけてあり、彼の左手にはパレット、右手には絵筆が握られていた。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
