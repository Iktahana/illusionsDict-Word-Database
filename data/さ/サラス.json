    "definitions": [
      {
        "index": 1,
        "gloss": "to expose (to the sun, public, danger, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かれは彼等のなすままにおめおめ服従して、白昼諸人のまえに生き恥を晒すほかはなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼にはただ窓を明け崖路へ彼らの姿を晒すということばかりでもすでに新鮮な魅力であった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の行くかた　雲東に行けば車馬通じ、雲西に行けば馬泥を濺ぎ、雲南に行けば水潭に漲り、雲北に行けば麦を晒すに好し、と支那にては云ひならはしたるに、雲北に行けば雨ふるもののやう歌へる和歌のあるもをかし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が邦の俗書に、朝に西北の方に黒雲見ゆるは雨なり、といひ、青き雲北斗を蔽へば大雨なり、などいへるあるを見れば、おしなべて我が邦にては、麦を晒すに好しといひ、老鸛河を尋ねて哭すというやうなる事は、云ひ得ざるにや。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に此方は婚礼を眼の前に控えているから、それを附目に何かの面倒を持ち込まれては、吉岡家に対しても気の毒、自分達も世間に対して余計な恥を晒すようにもなる。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁隣が機業家なんです、高い山から谷底見れば小万可愛や布｜晒すなんぞと、工女の古い処を唄つて居るのを聞きながら、日あたりの可い机の傍で新版を一冊よみました。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "タツタ一人……タツタ一人の母様の御病気を治療し度いばつかりに、身を売りましたのが仇になつて……そこにお出でになる御役人｜衆のお言葉に靡きませなんだばつかりに……かやうに日の本の恥を、外つ国までも晒すやうな……不忠、不孝なわたくし……」　苦痛の為にかありけむ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、それが威張れば威張るほどツマラヌ奴に見えて来るし、栄耀をすればする程、自分の恥を晒すことになるものですが、不思議なことに、ドンナに身分不相応な事でも、天子様と、神様と、親様の御為にする事なら、決して恥かしくないことがわかりました。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなどこで俺の恥まで晒すより、東京さでも行けばいいじゃねえか？",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の使命は綛糸を解き、緋の糸をより分け、残らず白日の下に晒すことだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも武士らしい、華やかな勇ましい最期ともあることか、世に死に恥を晒すような見苦しい死にざまじゃ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一層のこと、警察へ訴えて、二人を取り押えてもらおうかしら、だがそんなことをするのは、自分の恥をも明るみへ晒すことだった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の戦いには、主従｜挙って鋒鏑に血を注ぎ、城下に尸を晒すばかりじゃ。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のは三つほどの内に越後獅子の布を晒す所ぢやといふのが一つあつた。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにするな」「悪逆無道の痴者として、三条河原へ晒すのよ」「おおそうか、面白いな」「蔵人！",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、鳥のように美しい姿だといいんだが、あさましい死体を晒す事を考えると侘しくなってくる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、さうした卑しめのなかに、身を晒すことはたまらないのだ。",
              "citation": {
                "source": "あひびき",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スカラカ、チャカポコ外聞晒す。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の日中に外聞｜晒す。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更となって……恥を晒すかッ……コン畜生コン畜生コン畜生ッ……」「アイタッ……アタッ……アタアタッ……サ……晒します晒しますッ。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜に限ってこの鏡の前で、そんな風に特別な素振をするのは、非常な危険に身を晒す事になるのだぞ。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺とクレハの一生涯の恥を晒すことになるんだ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の世間の実際に女子の不身持にして辱を晒す者なきに非ず、毎度聞く所なれども、斯く成果てたる其原因は、父母たる者、又夫たる者が、其女子を深く家の中に閉籠め置かざりしが故なりやと言うに、必ずしも然らず。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう事になって見ると、賭博をして勝ったところで一向｜得が行かず、かえって汚名を世上に晒す結果となるので、さしも盛んであった袁彦道の流行も、次第に衰えて、民皆その業を励むに至った。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でもこの木曾の開田村方面では実行されているとのことでございますが、かの麻布を晒すために、また、飯山地方ではあの紙の原料である楮の皮を晒すのにそこの雪を利用いたしております。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "市三は、さきの鉱車よりも、もっと這入り方が少ない今度のやつを役員の眼前にさらすのは、罪をあばかれるように辛かった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日繰り返される三原山型の記事にはとうの昔にかびがはえているが、たまに眼をさらす古典には千年を経ても常に新しいニュースを読者に提供するようなあるものがあるような気もする。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな人間はまず少ないであろうが、これとよく似た係蹄に我れとわが手にかかって人の虜になり生き恥をさらす人は実に数え切れないほど多数である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "防御のない急所を矢弾の雨にさらすようなものかもしれない。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七楽しからずや天の原　　そら照る星のさやけさに月の光の貴さに　　心をさらすその時のアー　是れ　是れ　是れ　　是れこそ楽しき極みなれ。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
