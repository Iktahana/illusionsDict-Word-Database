[
  {
    "uuid": "4eb87768-d8ab-5daf-9896-747d66f6e8c2",
    "entry": "酸欠",
    "reading": {
      "primary": "さんけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
