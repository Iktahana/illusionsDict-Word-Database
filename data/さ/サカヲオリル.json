    "definitions": [
      {
        "index": 1,
        "gloss": "to go downhill",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "坂を下りるにつれて星が雑木林の蔭へ隠れてゆく。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "………ですけれど、私達だつて矢張坂を下りるぢやありませんか？",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、坂を下りるのかと思うと、違った。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さし俯向いた頸のほんのり白い後姿で、捌く褄も揺ぐと見えない、もの静かな品の好さで、夜はただ黒し、花明り、土の筏に流るるように、満開の桜の咲蔽うその長坂を下りる姿が目に映った。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "新坂を下りると鍋焼うどんが居ました。",
              "citation": {
                "source": "夜の赤坂",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『風邪かも知れませんが、……先刻支廳から出て坂を下りる時も、妙に寒氣がしましてねす。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度目か四度目に市廳坂を下りる時、渠は辷るまいと大事を取つて運んで居た足を不圖留めて、廣々とした港内の夜色を見渡した。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『風邪かも知れませんが、……先刻支庁から出て坂を下りる時も、妙に悪寒がしましてねす。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度目か四度目に市庁坂を下りる時、渠は辷るまいと大事を取つて運んで居た足を不図留めて、広々とした港内の夜色を見渡した。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の土手から古榎が無遠慮に枝を突き出して日の目の通わぬほどに坂を蔽うているから、昼でもこの坂を下りる時は谷の底へ落ちると同様あまり善い心持ではない。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校へみちびく坂を下りると、新しくはいった平一郎をまるで知らない筈の人達がみな「お早う」と悦ばしげに礼をして行く。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六　宅の前のだらだら坂を下りると、一間ばかりの小川に渡した橋があって、その橋向うのすぐ左側に、小さな床屋が見える。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車を見捨てた所からだらだらと坂を下りると、すぐ目の下に河口湖が青く沈んで見えた。",
              "citation": {
                "source": "湖水めぐり",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくここまで来るうちに――家を出て五六軒の農家のならぶ往還を通り、畑地へ出て、沼岸へ坂を下りる頃落したのかも知れぬ。",
              "citation": {
                "source": "錦紗",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "また狭い坂を下りると間もなく、観音様の横手の門へ出ます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小諸新町の坂を下りると、浅い谷がある。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という号令が坂を下りるたびにひびき渡った。",
              "citation": {
                "source": "接吻",
                "author": "ПОЦЕЛУЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初さんと自分は真直に坂を下りる。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は父親がともすると頼りない足もとで、よろよろ坂を下りるのを今更らのように見戍った。",
              "citation": {
                "source": "みずうみ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "このベッドの足の方のネジクギが一本ぬけてガタクリしているのよ、三本足の驢馬にのって山坂を下りる夢でも見なければいいけれど。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その坂を下りる度に膝の間節がガタリガタリとがたついて、実に苦しかつたのを覚えてゐるのは、坂を下ることの楽易といふ観念を初めて破られたといふ理由によるものである。",
              "citation": {
                "source": "初旅の残像",
                "author": "安倍能成",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を下りると間もなく久子さんの家だった。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "急な坂を下りるので足がガク／″＼する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
