    "definitions": [
      {
        "index": 1,
        "gloss": "while out on a walk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今年は三日ばかり続けて散歩がてらに行ってみたが、いつもまだ早過ぎた。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その町に城山というのがあって、大木暗く茂った山で、あまり高くはないが、はなはだ風景に富んでいましたゆえ、私は散歩がてらいつもこの山に登りました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうも水の音に暮れてしまったので、電灯の下で夕飯をすませて、散歩がてら理髪店へゆく。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘だと思うなら、近々お天気のいい日にでも散歩がてらいらっして下さい。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの馬鹿｜女郎め、今ごろはどこに何をしているか、一つ探偵をしてやろうと、うちわを持ったまま、散歩がてら、僕はそとへ出た。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「久し振りに散歩がてら、Ｂを訪れて見よう。",
              "citation": {
                "source": "「或る日の運動」の続き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "快い宵でしたが私は退屈しましたので、散歩がてら家を出ました。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうも水の音に暮れてしまったので、電燈の下で夕飯をすませて、散歩がてら理髪店へゆく。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叱りつけてをいてやがてニヤリと白い歯を見せながら、「ところで今度俺は墓地を買ったよ、今日はまあその自慢に来たのだが一つ散歩がてら見に行かないか。",
              "citation": {
                "source": "馬頭観世音",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "食後の散歩がてら、蕗のとうを探して近在をぶらつく、出てゐた、出てゐた、去年も出たところに出てゐた、よい蕗のとうだ、よい香気だ、さつそく佃煮にする、句にする。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼御飯を食べてから散歩がてら、駅まで出迎へたが、失望々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、孤愁に堪へかねて四日ぶりに外出、散歩がてら駅まで行く、句集はまだ来てゐない、帰途Ｍ屋で一杯ひつかけ、折から昇る月を背負うて戻る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩がてらポストへ、――櫨紅葉が日にましうつくしうなる、野菊が咲きだした、龍膽も咲いてゐる、……秋は野に山にいつぱいだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩がてらポストへ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、Ｎさん来訪、無事を喜ぶ（意味深長な一句だ）、見送りがてら、散歩がてら、石油買ひがてらに新町まで同道する、折から展開される演習を観る（何十年ぶりかで）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、散歩がてらポストへ、途中、一杯ひつかけたいのをぐつと抑へて、その代りに四句拾うて戻つた！",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩がてらポストへ、そして……あゝ。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、また、散歩がてらポストへ、暮羊居に立ち寄つて、久しぶりに会食した、よばれた／＼、うまかつた／＼！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩がてら、学校のＩさんを訪ねて、四国霊場奉納経をあげる、彼の妻君は大のお大師信者だから。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――苦しい手紙を書いて、散歩がてらのポスト行がたうとう嘉川まで歩いた、ぼつ／＼稲刈がはじまり、路傍には私の好きな石蕗の花がちらほら咲いてゐた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口へ散歩がてら出かける、敬君を訪ふ、不在、Ｕ君を訪ふ、また不在（そのために嫌な頼みをいひださなくてすんだけれど）、帰途、Ｓ君の店に寄り、事情を話して白米一升快く貸して貰ふことが出来た、うれしかつた、ありがたかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩がてら図書館へ、途上で一句拾ふ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も散歩がてら図書館へ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩がてらポストまで出かけた、買物いろ／＼。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、散歩がてら貸本屋まで出かけて、婦人公論を借りて帰つた。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩がてらに、平岡の所へ行て見やうかと思ひ出したが、散歩が目的か、平岡が目的か、自分には判然たる区別がなかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断でもかなりな参詣人を呼んでいるそこの寺は、ちょうど東京の下町から老人や女の散歩がてら出かけて行くのに適当したような場所であった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度彼は散歩がてら自分の家を出て、節子の通って来る路の途中まで彼女を迎えに行ったことがあった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれがためにだろう、あとからついてきて、「散歩がてら送って行きます」と皆に言葉をかけた主人に対しても、いっそう敬意を払うことができた。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　札幌區立病院は、――義雄が有馬の家から散歩がてら出ると直ぐ横手に當るので、這入つて時々瞑想に眈つたことがある農科大學附屬博物館の、はびこつた牧草や、脊の高いアカダモや、ドロや、柳やの多い、その廣い構内の東南端に接して、――北一條七丁目の一廓の、廣く長く、まばらな鐵柵をめぐらした中に立つてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
