    },
    "definitions": [
      {
        "index": 1,
        "gloss": "funeral hall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "信一郎が、静子を伴って帰京した翌日に、青木家の葬儀は青山の斎場で、執り行われることになっていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎が、定刻の三時前に行ったときに、早くも十幾台の自動車と百台に近い俥が、斎場の前の広い道路に乗り捨てゝあった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、皆が静かになったかと思うと、戞々たる馬蹄の響がして、霊柩を載せた馬車が遺族達に守られて、斎場へ近づいて来るのだった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "式場の青山斎場では既に読経が始まっている頃であろう。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の日の斎場の光景は、まことに厳粛を極めたものだった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎場の正面のずっと高い石の壇上には、大熊老人の亡骸を安置しその下には、各名士から贈られた真榊や、花筒や、花環がギュウギュウ言うほど、おし並べられ、まるでアマゾン河畔の大森林を此処に移したかの感があった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎が、静子を伴つて帰京した翌日に、青木家の葬儀は青山の斎場で、執り行はれることになつてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎が、定刻の三時前に行つたときに、早くも十幾台の自動車と百台に近い俥が、斎場の前の広い道路に乗り捨てゝあつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、皆が静かになつたかと思ふと、戞々たる馬蹄の響がして、霊柩を載せた馬車が遺族達に守られて、斎場へ近づいて来るのだつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは聞得大君が任命されると間もなく、その領地たる知念へ始めて御下りになって霊地｜斎場御嶽に参詣されることで、昔は国王の冊封の儀式にも比すべき儀式でありました。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓は谷中斎場の向いの横町を西へ入って、北側の感応寺にある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "するといつか道を間違へ、青山斎場の前へ出てしまつた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "するといつか道を間違え、青山斎場の前へ出てしまった。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　翌日午後二時、青山斎場で二川重明の神式による葬儀がしめやかに行われた。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月十五日（水曜）晴　朝早く目ざめ、早めに青山斎場へ行く。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山の斎場へ行ったら、靄がまったく晴れて、葉のない桜のこずえにもう朝日がさしていた。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎場は、小学校の教室とお寺の本堂とを、一つにしたような建築である。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎場を出て、入口の休所へかえって来ると、もう森田さん、鈴木さん、安倍さん、などが、かんかん火を起した炉のまわりに集って、新聞を読んだり、駄弁をふるったりしていた。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者は皆、接待係の案内で、斎場の中へはいって行く。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして皆で、受付を閉じて、斎場へはいった。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも、斎場とどこかの家との間らしい。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "少したって、久米と斎場へ行ってみると、もう会葬者がおおかた出て行ったあとで、広い建物の中はどこを見ても、がらんとしている。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又夏目先生の御葬式の時、青山斎場の門前の天幕に、受附を勤めし事ありしが、霜降の外套に中折帽をかぶりし人、わが前へ名刺をさし出したり。",
              "citation": {
                "source": "森先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや、先生だったかと思いし時は、もう斎場へ入られし後なりき。",
              "citation": {
                "source": "森先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは、郊外の北野の斎場といふ処にあるその山を、大甞宮までひいて来るのです。",
              "citation": {
                "source": "日本美",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は運命を苦笑する人のごとく、絹帽などを被って、葬式の供に立つ、俥を駆って斎場へ駈けつける。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子登極の式には、必北野、荒見川の斎場から標山といふものを内裏まで牽いて来たので、其語原を探つて見れば、神々の天降りについて考へ得る処がある。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "島尻の斎場御嶽でも、近年までは、女装を学ばねば這入れぬ事になつてゐた。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の神・磯の神或はさいふあ（斎場御嶽の事か）神・にれえ神など言ふ風な名である。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "複式なるは、斎場において、群集の異性――群行神としての自覚において、祭時に其村の男性が来臨する形――に向ふもの、単式は、其巫女たる処女の家々に、個々に訪問する神々――なる男――に逢ひ又逢はぬ形で待遇するものである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
