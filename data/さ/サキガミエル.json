    "definitions": [
      {
        "index": 1,
        "gloss": "to envision how things will turn out (usu. unfortunate)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二一　勘次が走つて鬼怒川の岸に立つた時は霧が一｜杯に降りて、水は彼の足許から二三｜間先が見えるのみであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ねえや、このおじさんは行者じゃねえが、千里も万里も先が見える目玉が二つあるからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は花壇に綺麗な花が咲くが、まだ深い雪の中から、緑色の花壇の仕切りの先が見えるだけだ。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピムキンのボロ長靴の先が見える。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りの垣根越しに、暗い縁先が見える。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやんと、先が見えるのさ。",
              "citation": {
                "source": "秘密の代償",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムダム・ホールと山川総理の宅の間にはサムダム館の尖つた塔の先が見える。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い裳裾の下から覗き出した金色の靴の爪先が見える。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯並びのいい、例えば小粒の真珠のような歯の間から、ヒクヒクと動く小さな舌の先が見える。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それほど先が見えるなら、何だって格子の中へ入れてから、俺を呼出さなかったんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二本の脇差",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大層目先が見えるやうになつたんだね、八兄哥」「へツ、それほどでもねえ」「馬鹿なツ」　大舌打を一つ、この法外な自惚男をさげすむやうに、萬七と清吉は顏を見合せました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "濡れた千兩箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大層目先が見えるようになったんだね、八兄哥」「へッ、それほどでもねえ」「馬鹿なッ」　大舌打を一つ、この法外な自惚男をさげすむように、万七と清吉は顔を見合せました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "濡れた千両箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い広い裾の下に赤いスリッパアの先が見えるのなど、病院らしい美しさがなくもない。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの長衣の下に、ちょっと靴の先が見えるだけでも、私はもう自分をとり失ってしまう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを、横へ廻ると、書院の縁先が見える。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
