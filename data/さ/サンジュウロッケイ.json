    "definitions": [
      {
        "index": 1,
        "gloss": "the 36 (ancient Chinese military) strategies (of which the last resort was said to be beating a retreat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
