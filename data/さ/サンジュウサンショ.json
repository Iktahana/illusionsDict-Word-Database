    "definitions": [
      {
        "index": 1,
        "gloss": "thirty-three temples sacred to Kannon (Avalokitesvara)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "扨柳亭筆記に京順禮の始より萬治三年と寛文五年と二説ある由を示し、寛文四年の印本に、老婆物語と題する洛陽三十三所觀音の縁起を聚めし册子あれば、此事寛文の初より起り、寶永正徳の頃迄も有しなるべしとある。",
              "citation": {
                "source": "女順禮",
                "author": "並にサンヤレの事",
                "note": "青空文庫"
              }
            },
            {
              "text": "順禮が札を打つ事、後奈良帝の弘治頃成りし桂川地藏記に、御地藏へ所詣物萬般也、先有御所的之役人云々、或有三十三所順禮行者打簡とみゆ。",
              "citation": {
                "source": "女順禮",
                "author": "並にサンヤレの事",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎮西三十三所の第二十四番、田結の観音寺に詣でる、つまらないところだつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十三所の順礼歌の最後が「谷汲」であり、さんげ念仏の小栗転生物語の小萩の居たのは青墓であつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都府｜乙訓郡新神足村友岡）　美濃の谷汲の念仏池は、三十三所の観音の霊場である為に、はやくから有名でありました。",
              "citation": {
                "source": "日本の伝説",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
