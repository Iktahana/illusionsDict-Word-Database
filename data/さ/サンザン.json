[
  {
    "uuid": "a396f956-76a3-5b62-8c0f-a5770d27a8d3",
    "entry": "散々",
    "reading": {
      "primary": "さんざん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
