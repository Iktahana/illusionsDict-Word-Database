        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "パンに紅茶、ボイルド・エツグにサラダとお極りの朝食を濟ますと、ざつと新聞に眼を通し、すぐ洋服に着換へて三田四國町の久保田万太郎邸へ行く。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンの皮や、らっきょうや、サラダや、独活や、そんなものでも、音を立てて食うことに異常な幸福を感じる。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば「礼服を着ないでサラダを出した」といったような種類のものである。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもしい譬喩ではあるが、言わばビフテキのあとで良いサラダを食ったような感じがある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一皿と家鴨の股の肉にサラダをあしらった一皿を組ましたものが、この店の名物「家鴨のブレッセ」である。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "入らつしやいと云ひながら好く視ると、どの人も覚えのある顔で、半月ほど前にこゝらへ来て、測量をしたり杭を打ち込んだりして行つた復興局の人達でしたから、わたしも商売柄、先日はご苦労様でしたとか何とか挨拶をして、さてお誂へを訊くと、サラダか何かのあつさりしたもので、ビールを飲ませろと云ふんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "無いといふものを無理に出せとも云はれず、ましてまんざら識らない顔でもないんですから、わたしも素直に承知して、ビール廿一杯とハムサラダ三枚の勘定を貸して遣ることにすると、みんなも喜んで出て行きました。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり私の方ぢやあビール廿一杯とハムサラダ三枚の勘定の代りに、家の焼けるのを助かつたと思やあ好いんですから、差引きをすりやあ有難いわけだと云つてゐるんですよ。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩の御馳走は、蛙の焼串、小さい子供の指を詰めた蝮の皮、天狗茸と二十日鼠のしめった鼻と青虫の五臓とで作ったサラダ、飲み物は、沼の女の作った青みどろのお酒と、墓穴から出来る硝酸酒とでした。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちいち隣りの王子のほうを盗み見て、こっそりその手つきを真似て、どうやら口に入れる事が出来ても、青虫の五臓のサラダや蛆のつくだ煮などの婆さんのお料理ばかり食べつけているラプンツェルには、その王さまの最上級の御馳走も、何だか変な味で胸が悪くなるばかりでありました。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱とチーズを壺焼にしたスープ・ア・ロニオンとか、牛舌のハヤシライスだとか、莢隠元のベリグレット・ソースのサラダとか、彼がふだん好んだものを註文したので鼈四郎は慥え易かった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の膳のクキと鮒の煮浸し、馬鈴薯の味噌汁に添って先生がキャンプ料理風な鑵詰ものを使って慥えた塩肉のハンバーグステーキと、フルーツサラダは夜食の膳を相当に賑わしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとすいすいしたサラダと辛子だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い二つの皿には水っぽい新鮮なサラダの緑を、白い三つの皿にはやや薄黄のマイナスソースをかけた羊の蒸肉を盛ってあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラダも※ぎたてです。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "このサラダも万歳だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのサラダは全く地面から湧き出た滋味そのものの新鮮さと気品とを飜えしている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」俺はつくづく苦笑した、「それはサラダを絞りましたので。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、書信を数通したため、夕方近く台所に出て来て、晩餐の支度をしている妻の傍で冗談口をききながら、サラダを掻きまぜたりした。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにかおあつらへを、」「野菜サラダが出来るかね、」「出来ますわ、」「ぢや、それと、ナマを貰はうか、」「はい、ナマと野菜サラダでございますね、」　お幸ちやんはさう聞き直してから暖簾の口へ行つた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野菜サラダ一ちやう、」　それから片手で暖簾の垂れをあげて内へ入つて行つた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客はウイスキーと野菜サラダを注文した。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくさい脂がサラダのおもな味でした。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく、羅摩（ラーマ）はアヨジ国王ダサラダが正后カウサリアに生ませた子で、初め林中に瞿曇仙に師事した時、上に述べた通りこの仙人その妻アハリアの不貞を怒り、詛うて石に化しあったのを羅摩足で触れて本形に復せしめた。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "前出ハヌマン猴王の素性について異説あり、羅摩の父ダサラダ子なきを憂い神に牲すると、牲火より神現じ天食を王に授く。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このサラダは愛ねえさんがお醋とオリーブ油を間違って油をたくさんかけたからきっと油っこくってよ」　愛子はおだやかに貞世をにらむようにして、「貞ちゃんはひどい」　といった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厨房一同入寮晩餐会メニューチキンコンソメ　　アスパラガスのサラダマッシュポテト　　ヒラメのソテコールドミート　　パンデザートはバニラアイスクリーム　慶一は、「厨房」という字を、とりあえず「とうぼう」と読み、コックかなんかの意味だろうと考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、コールドビーフやハムサラダでビールを一杯飲むのもいい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客といふのは、ハム・サラダと貞女とが大の好物なのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
