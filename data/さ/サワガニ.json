    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese freshwater crab (Geothelphusa dehaani)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
