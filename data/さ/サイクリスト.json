        "examples": {
          "standard": [
            {
              "text": "早朝の公園には、たくさんのサイクリストが練習に励んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロのサイクリストは、厳しいトレーニングを毎日こなしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事故を起こさないよう、サイクリストはヘルメットを着用すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わたしも口をあわせて、下手なサイクリストを罵倒すると、老人はやがて又云い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "少年少女の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで草ッ原へ逃げ込む、果ては双方意地ずくでいがみ合いつつ、どうやらよたよた乗れることになり、桜田門まで遠征、それが途中三度も下りて休憩という始末、いやはや初期のサイクリストあんまり自慢にならぬ。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
