[
  {
    "uuid": "35e427c1-dbed-5a5c-8455-57b043898ede",
    "entry": "三秋",
    "reading": {
      "primary": "さんしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "three autumn months",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このあたりは河水東西に流れて両岸の地もまた幽寂空疎なれば、三秋月を賞するのところとして最も可なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の孝孺に賜うの書に、余一日見ざれば三秋の如き有りの語あり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日（火曜）晴　さすが三秋の風が吹く。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、盆祭りと習合せられた形で、其前は、満月の夜を、三秋の中に択んだのであらう。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴻業果たし收むべきその時天は貸さずして出師なかばに君病みぬ、三顧の遠きむかしより夢寐も忘れぬ君の恩答て盡すまごゝろを示すか吐ける紅血は、建興の十三秋なかば丞相病篤かりき。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
