[
  {
    "uuid": "1dd82a24-4277-5252-813d-2db6c472aaec",
    "entry": "逆巻く",
    "reading": {
      "primary": "さかまく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
