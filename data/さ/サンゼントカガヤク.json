    "definitions": [
      {
        "index": 1,
        "gloss": "to shine brilliantly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
