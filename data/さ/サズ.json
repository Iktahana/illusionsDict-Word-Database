  {
    "uuid": "1c6ca7ed-caab-51fc-a37f-3aa1535314a2",
    "entry": "サズ",
    "reading": {
      "primary": "サズ",
      "alternatives": [
        "サーズ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "saz (long-necked lute common in Turkish folk music)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此ノ權利ト此ノ義務トハ一切ノ條件ニ依リテ干犯サルルコトヲ許サズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ノ亞細亞ニ與ヘラレタル使命ハ英人ノ罪惡ヲ再ビスルヲ許サズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "――樹明君近来の口癖はブチコワスゾである、何カヲブチコワサズニハヰラレナイホド、君は悩み苦しみ焦立つてゐる、そこで、私が先づ茶碗をぶちこはす、樹明君喜んで皿を投げつける、ガチヤンガラガラ、どうやら胸がすいたらしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無量義経」によれば、「四十余ニハ未だ真実ヲ顕ハサズ」とある。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――君たちは葷酒山門ニ入ルヲ許サズということを、知っているか。",
              "citation": {
                "source": "祭りの夜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来文人韻士ノ之ニ居ル者鮮シトナサズ。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "然レドモ当初稿ヲ脱セシ時ヨリ既ニ半歳ヲ過ギ一時｜蒐集シタリシ資料ノ今｜蚤クモ座右ニ留メザルモノマタ鮮シトナサズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔腕力今ニ于テ猶健在ナリ／一タビ揮ヘバ千紙モ未ダ難シト為サズ〕との意気を示していた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔鎮年道途ヲ走キ／祭祀ヲ奉ズル暇無シ／地下｜若シ知有ラバ／豈｜謂ハンヤ克家ノ子ト／惟ダ詩癖ノ同ジキ有ルノミ／家声誓ツテ墜トサズ〕枕山はこの誓言にたがわず家声を墜すようなことはしなかった。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人ハ古器ヲ好ミ一人ハ新器ヲ好メバ則チ人ハイマダ古器ヲ好ムヲ以テ勝レリトナサズンバアラズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "適同人集ノ挙アリ遷延シテ果サズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヲ嗜ミ口ニ瓢杓ヲ離サズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "家事｜纒擾タルヲ以テ果サズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "倦メバ則アルイハ坐シ、アルイハ臥シ、劇談一｜餉、善ク戯謔シテシカモ虐ヲナサズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒モマタ両三｜罎ヲ過サズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "明の李時珍がその著『本草綱目』に「按ズルニ陸佃ガ※雅ニ云ク、蕉ハ葉ヲ落サズ一葉｜舒ルトキハ則チ一葉｜蕉ル、故ニ之レヲ蕉卜謂フ、俗ニ乾物ヲ謂テ巴ト為ス、巴モ亦蕉ノ意ナリ」と書いている。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の『桃洞遺筆』に引用されている『本朝食鑑』（小野必大の著、元禄十年1697出版）巻之四の文を仮名交りに書いてみれば、「上野州下野州ニ山栗アリ極メテ小ニシテ一年ニ三度、栗ヲ収ム故ニ三度栗ト号ス其味ヒ佳ナラズト為サズ此｜類ノ山栗ハ諸州ニ在レドモ亦極メテ小キナリ是レ古ヘノ※栗乎」である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "答　モシ私ノ云ッタ事ニ対シテ、清三ガ少シデモ耳ヲ傾ケテクレタラ、私ハ清三ヲ殺サズニスンダカモシレナイノデス。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三蓋ヲ煙草盆トシテ煙管ポンポンナドノ便アリ、第四舎営ノ夜半ニ筆ヲ揮フトキ蝋燭立トスベシ、第五ハ即チ枕ノ代理而シテ彼ノぴすとるニ至ツテハ、幸ニ吾常勝軍ニ従フニ依ツテ徒ニ行李ノ重量ヲ増スノミ、更ニ一分ノ用ヲモナサズ。",
              "citation": {
                "source": "小杉放庵",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女ハ頭ト骨ト尾トヲ皿ノ一方ニ片寄セテ、身ヲ一片モ残サズニ猫ガ舐メタヨウニ食ベル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（妻ハソレヲ口ニ出シタ※ハナイガ、ジェームス・スチュアートノ映画ダト缺カサズ見ニ行クラシイノデアル）モットモ妻ガ木村ニ接近スルノハ、僕ガ彼ヲ敏子ニ妻ワセテハドウカトイウ考エガアッテ、家庭ニ出入リサセルヨウニシ、妻ニソレトナク二人ノ様子ヲ見ルヨウニト命ジタカラナノデアル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女ノ理性ハ制御ヲ命ジタトシテモ、彼女ノ飽クナキ肉体ハ理性ノ言ニ耳ヲ貸サズ、僕ヲ破滅ニ追イ込ムマデモ満足ヲ求メテ已マナイデアロウ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレハ僕モ考エルガ、ソレヨリ先ニ彼ラガ考エ出サズニハ措カナイデアロウ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　サズキは物をのせる臺。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "こら智深、ここは山門だぞ、山門だぞよ」「なアるほど、文殊院五台山の山門らしい」「葷酒山門ニ入ルヲ許サズ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てまえも亡くなった父と東京見物に参ったさい、徐寧の家で見せて貰った薄ら覚えが残っていますが……なんでもそれは“鎗貫サズノ鎖小札ノ鎧”……とかいう物で、朱革ノ鎧櫃に入れ、いつも大事に、二階の天井裏に吊ッてある。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然ルニ　賄賂ニ毒セラレタル官コレヲ捕エテ　却ッテ淫婦奸夫ヲ殺サズ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　どこの寺でも、「葷酒山門ニ入ルヲ許サズ」は、法城の掟みたいになっているが、この天野山金剛寺では、坊舎で酒を醸酒っている。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――天下ヲ治ムル者ハ人ノ親ヲ殺サズ――と。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "書中言ヲツクサズ、旦暮河南ノ空ヲ望ンデ、来命ヲ待ツ。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
