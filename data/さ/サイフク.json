[
  {
    "uuid": "e8bbba3a-f79f-5b8a-b6f7-42968b8dba5a",
    "entry": "斎服",
    "reading": {
      "primary": "さいふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "priestly vestments, esp. white silk robes worn at festivals",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "年かっこう、べっぴんぶりもそっくりですよ」　いかさま年は二十七、八、髪はおすべらかしに、緋のはかまをはいて、紫｜綸子の斎服に行ないすました姿は、穏やかならぬ美人なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつアなんだ」　草香流片手締めで締めあげながら、ぱっと斎服をはぎとりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の白羽二重の斎服が、さやさや鳴り拡がり、部屋一杯になった。",
              "citation": {
                "source": "祖母のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗斎服保は号に栗字があるが、寛政十二年に歿してゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……太占をもって神意を問い、大嘗斎服の神殿を造り、触穢を忌み清浄を喜ぶ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すさのをの命が、斑馬の皮を斎服殿に投げ込まれた時に、気絶したのは、わかひるめの神であつた（日本紀一書）。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "身重な窪川いね子が小さいふくさ包をもって上落合の作家同盟の事務所の横にポンプ井戸がある、そのわきを歩いていた姿を思い浮べた。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時の経つのは恐ろしく長い、もう三十分も経ったろうと思って見ると、まだ、小さいふくらみのある蜂の剣のような針は、中央の６から五分ほか動いて居ない。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　マルコは小さいふくろを手に持ってボートから波止場に上陸して勇ましく都の方に向って歩きだしました。",
              "citation": {
                "source": "母を尋ねて三千里",
                "author": "アミーチス",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルコはただ「ありがとう、ありがとう」といって小さいふくろを持って外へ出ました。",
              "citation": {
                "source": "母を尋ねて三千里",
                "author": "アミーチス",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろ子は、トラックの上で小さいふくさを出し、髪の毛が吹きちらされる頭を結えた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
