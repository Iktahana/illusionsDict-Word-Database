[
  {
    "uuid": "7cce8f18-8f84-5c0a-9a47-f7a669b058c6",
    "entry": "産気",
    "reading": {
      "primary": "さんけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
