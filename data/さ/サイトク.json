    "definitions": [
      {
        "index": 1,
        "gloss": "intelligence and virtue",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
