          "literary": [
            {
              "text": "こゝは、安房の最東端也。",
              "citation": {
                "source": "房州の一夏",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺を出でて、間もなく、狹山の最東端にとりつく。",
              "citation": {
                "source": "狹山紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十九島は寛政四年に東雲仙火山群最東端の眉山が爆発し、山体の東半部が海中にけし飛び、出来上った島々で、成立後百三十余年に過ぎぬ新島嶼である。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペルナンブコ港は人口十九万人を有し、南米の最東端にあり、その市街は小舟にて来往するを得るをもって、西半球のベニスの称ありという。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "最東端のここでは、まだ火山は生きている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
