    "definitions": [
      {
        "index": 1,
        "gloss": "sweet potato (Ipomoea batatas)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつもは、赤いさつま芋みたいな元気のいい顔が、きょうは何だかしおれていました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦乞食は霙の降る中を寒さに赤さつま芋色になった手をつなぎ合って、町の表通りから溝の橋を渡って遊郭へ入って行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これが評判のさつま芋というものか。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根、桜島、蕪菜、朝鮮芋（さつま芋）、荒苧（里芋）、豌豆、唐豆（そら豆）、あずき、ささげ、大豆、なた豆、何でもあった。",
              "citation": {
                "source": "私の父",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自家の畑で採れたさつま芋をリュックに一杯つめていて、ひどく疲れている様子だ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の一番隅っこの暗い部屋を借りている大工さんの子供が、さつま芋を醤油で炊いたのを持って来てくれた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になつて、ゆき子は此の家の人からさつま芋を分けて貰つて、一緒にふかして貰つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつま芋の賽の目に切ったものが、菜味としてふんだんに入っている。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛名山の西の腰から流れ出す烏川の冷たい流れを渡り、板鼻町へ入ったとき、さつま芋を五銭ほど買って、三人で分けて食べた。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、きょうの昼飯は、さつま芋の蒸したのを五銭買って三人で分けて食べただけだ、というようなことを遠まわしに話した。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうも長倉村でさつま芋を五銭買って分けて食べた。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪もよいの空は、さつま芋を分けて食べた頃から模様が変わって、いまでは降るような星空になっている。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつま芋の賽の目に切つたものが、菜味としてふんだんに入つてゐる。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつま芋も一緒に、こんがりと焼けている。",
              "citation": {
                "source": "牛の丸焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには閉口したらしいが、勇猛心をふるって、無事任務を終えて、そのあとは皆で鶏をむしりながら、さつま芋を食う。",
              "citation": {
                "source": "牛の丸焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下の大きい穴の中で、まるのままの牛と、さつま芋と、とうもろこしと、南瓜とを一緒にして、芭蕉の葉でつつんで、蒸し焼にする。",
              "citation": {
                "source": "牛の丸焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちのおやつは、季節毎にちがっていて、秋になればさつま芋、冬になると、このこうばく蟹であった。",
              "citation": {
                "source": "母性愛の蟹",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、さつま芋の蔓も食べたし、アメリカの料理も食べさせられた。",
              "citation": {
                "source": "母性愛の蟹",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この淵に毎日、さつま芋を細かにしてまいておいて、三日目ぐらいにそのさつま芋を餌にしてウキなしで釣るのだが、針素は八毛という用心深さで、尺二寸五分、尺五寸の大バヤを十尾釣りあげた。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「芋女ォって、どなるか」「芋女でなかったら、どうする」「芋女に、きまっとると思うがな」　口ぐちに芋女芋女といっているのは、この地方がさつま芋の本場であり、その芋畑のまん中にある女学校なので、こんないたずらな呼びかたも生まれたわけだ。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのそばに母親らしいやはり色の黒い女が、野天でさつま芋を切っている。",
              "citation": {
                "source": "一つ身の着物",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人も家も、大人も子供も、俎板もさつま芋も、どす黒い煙にいぶされたような色だった。",
              "citation": {
                "source": "一つ身の着物",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かに少量の干うどんとさつま芋とが手に入ったきりであった。",
              "citation": {
                "source": "地異印象記",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか南瓜やさつま芋などが好きだった。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になって帰ろうとすると、徳富氏は、「あなた方にさつまいもを進ぜましょう。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って、縁の下から小犬のような大きさのさつまいもを、幾つも幾つも掘り出して、それを風呂敷に包もうとした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、今日世界の大部分がひどい食料制限をして、私たちはさつまいもを買うのにも苦心している。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今私たちはパンも馬鈴薯もさつまいもも買えずにいるから、米を副食としてときくと、では主食品はどんな風に手に入れられるのだろうという、ぼんやりした当惑も感じるのである。",
              "citation": {
                "source": "「うどんくい」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其品は　いも　なすび　ふぢ豆の類なににてもよし　かいわり菜（備後方言まびき菜）　外名をしらず　きらひもの　たうなす　さつまいも　ぼうふら（南瓜）　太中。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちの級の畑には、馬鈴薯とさつまいもと、ふだん草と、とうもろこしが植えてあります。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
