    "definitions": [
      {
        "index": 1,
        "gloss": "sum",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうしてサムボリスムなる名称のきまるまで、その一派は「デカダン派」を以て自称してゐることを思い合せて貰はう。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "富永は、彼が希望したやうに、サムボリストとして詩を書いて死んだ。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の健康の行詰まりには此度の伊香保がサム・シングであつたのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の行詰まりを救ふサム・シングを世界中の爲政者や思想家やが試みてゐるが、此の利目は未だわからないやうである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京踊なども矢張り此のサム・シングの一つではあるかも知れない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "挟箱や鳥毛の槍を押し立てて舞踊しながら練り歩く百年前の姿をした「サムライ日本」の行進のために「モダーン日本」の自由主義を代表する自動車の流れが堰き留められてしまったのである。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "露語の zima は霜（シモ）や寒（サム）や梵語の hima（雪）やラテンの hiems（冬）やギリシアの cheimon（冬）やまたペルシア語の sarmai（寒い）にも似ている。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲランは、ここでは、サムゴッドといふ名のもとに、その素ばらしさをかなり誇張せられて、姿をあらはしてゐる。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後にサムナー・テーンターやグラハム・ベルらの研究によって錫箔の代わりに蝋管を使うようになり、さらにベルリナーの発明などがあって今日のグラモフォーンすなわち平円盤蓄音機ができ、今ではこれが世界のすみずみまで行き渡っている。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムソンというんだ」　綺麗な疳高い、少し野趣を帯びた笑声が弾けるように響いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は何であったかよく覚えていませんが、僕はたしかサムライの服装をして行きました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこで彼は、記念にと云って僕の着ていたサムライの衣裳を所望したのです。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡同様、無慙にも顔面の皮膚を剥ぎそられ何処の者とも判明せざれど年齢二十三四歳位にて、サムライの仮装着を着けたるところより多分前夜何処かの仮装舞踏会に出席したる日本人にあらざるかと推測さる。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "『それで、君はそこでもその郁と云う支那人がつまり、君からサムライの衣裳を貰ったばっかりに君の身代りに立ったと云うのですね。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゴカキ新美南吉　ツキヨノ　マツナミキノ　ミチデ　一リノ　サムライガ、ウシロカラ　ハシツテ　キタ　カラノ　カゴニ　ノセテ　モラヒマシタ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゴノ　中ノ　サムライガ　ナンダラウト　オモツテルト、コンドハ、「タヽキコロサウカ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中ノ　サムライハ　マツサヲニ　ナツテ　フルヒダシマシタ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "オクビヨウナ　サムライハ　モウ　ハノ　ネガ　アヒマセン。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムライハ　コシカラ　カタナヲ　サヤグルミ　ヌイテ　下ニ　オキ、キモノノ　スソヲ　ハシヨリマシタ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムライハ　一シヨウケンメイ　ニゲマシタガ　イキガ　キレタノデ、ミチバタヘ　バツタリ　スワツテ　シマヒマシタ。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ト、サムライハ　マダ　フルツテ　ヰマス。",
              "citation": {
                "source": "カゴカキ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルト　サムライ新美南吉　五ニンノ　サムライガ　タビヲ　シテ　アル　ヒ　ヤマミチヲ　トホリカヽルト、木ノ　下ニ　一ピキノ　サルガ　ヰマシタ。",
              "citation": {
                "source": "サルト　サムライ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビヨウキノ　サルヲ　キツテモ　シカタナイト　イフノデ、五人ノ　サムライハ、ソノ　サルヲ　ツレテ　ユキマシタ。",
              "citation": {
                "source": "サルト　サムライ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤガテ　サルハ、ビヨウキモ　ナホツテ　五人ノ　サムライニ　ヨク　ナレマシタ。",
              "citation": {
                "source": "サルト　サムライ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　五ニンノ　サムライハ　サルヲ　キラナクテ　ヨカツタ　コトヲ、メニ　ナミダヲ　タメテ　ヨロコビマシタ。",
              "citation": {
                "source": "サルト　サムライ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナガレボシ新美南吉　フユノ　サムイ　サムイ　ヨフケ、ヒユーン　ヒユーント　コガラシノ　フク　オソラノ　上ノ　ハウデ　三ツ　ナランダ　コドモノ　ホシガ、ケンクワヲ　シマシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イツモハ　ナカヨシダツタノデスケレド、アンマリ　マンナカノ　ホシガ　サムイ　サムイト　イフノデ　ホカノ　二ツノ　ホシニ　イジメラレタノデシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
