    "definitions": [
      {
        "index": 1,
        "gloss": "General Staff Headquarters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
