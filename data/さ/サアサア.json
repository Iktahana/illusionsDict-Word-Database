          "literary": [
            {
              "text": "水がさあさあ云っている。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさあ団子たべろ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさあ、こいづも食べろ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　婦人は言下に打解けて、（さあさあ汚うございますが早くこちらへ、お寛ぎなさいまし、そうしてお洗足を上げましょうかえ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさあおなかにおはいりください。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がさあさあ云ってゐる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさあみんな団子たべろ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあさあ、こちらへおいで下さい。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあさあ、太郎、起きろ起きろ」　と今度はお父さんの声がしました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋の硯を仮寝の床に、路の記の端に書き入れて、一寸御見に入れたりしを、正綴にした今度の新版、さあさあかわりました双六と、だませば小児衆も合点せず。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "禰宜　さあさあ、これ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今灯を点けたばかり、油煙も揚らず、かんてらの火も新しい、店の茣蓙の端に、汚れた風呂敷を敷いて坐り込んで、物｜馴れた軽口で、「召しませぬか、さあさあ、これは阿蘭陀トッピイ産の銀流し、何方もお煙管なり、お簪なり、真鍮、銅、お試しなさい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあさあ召して下さい、召して下さいよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といってちょいと句切り、煙管を手にして、莨を捻りながら、動静を伺って、「さあさあ、誰方でもどうでござんす。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさあ、どうぞお入り下さい。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあさあおなかにおはひりください。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の内二枚半に筆太に、書附けたる広告の見ゆる四辻へ、侠な扮装の車夫一人、左へ曲りて鮫ヶ橋谷町の表通、軒並の門札を軒別に覗きて、「黒瀬ぬい、と、ええ、黒瀬と、さっぱり知れねえぞ、こっちは土方職、次は車力、引越荷車｜仕候か、お次は何だ、鋳掛屋かい、差替りまして蝙蝠傘直、さあさあ解らねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お動きなすって御成敗がなさり悪くば、縛りましょう、釣上げましょう、さあさあ、どうとも御望み次第。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙を払って）さあさあ、親類というお言葉なんだ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さあさあ、お寝室ごしらえをしておきましょう。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「さあさあ看板に無い処は木曾もあるよ、木曾街道もあるよ。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、時々……「さあさあ看板に無い処は木曾もあるよ、木曾街道もあるよ。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かで蛙が鳴き出したかと思うと、雨はさあさあと降って来た。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
