          "literary": [
            {
              "text": "こういう風に研究が進んで来ると、化学変化もこの現象に関係があると言い出し、過酸化水素の分解が生物線で促進されるとか、酸とアルカリとの中和でも生物線と同じような放射線が出るとか、色々な実験結果が出て来た。",
              "citation": {
                "source": "千里眼その他",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "体内にも酸とアルカリが存在する。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような変化による最終産物は酸とアルカリであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸とアルカリの釣り合いが正しく保たれると個体は健康であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
