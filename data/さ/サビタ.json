    "definitions": [
      {
        "index": 1,
        "gloss": "panicled hydrangea (Hydrangea paniculata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
