        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "＊ＩＢＭ産業スパイ事件を体験していたら、池田敏雄さんは次に何をやろうと言い出したろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八二年のＩＢＭ産業スパイ事件は、見ることなく終わった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂村さんの舞台は、ＩＢＭ産業スパイ事件の後に回ってきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のコンピューター界に現われた鬼才二人は、コンピューターのメディアへの変質とＩＢＭ産業スパイ事件という歴史の転換をはさんで、標準と独創を百八十度入れ替えて対置した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭ産業スパイ事件以降、我々はこの問いに答えよと迫られている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとするとこの男はライバル会社の産業スパイかも知れない。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
