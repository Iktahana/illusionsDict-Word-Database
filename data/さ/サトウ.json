[
  {
    "uuid": "0b09d33e-3f25-5a41-ae47-4b7b748e71f9",
    "entry": "左党",
    "reading": {
      "primary": "さとう",
      "alternatives": [
        "ひだりとう"
      ],
      "is_heteronym": false
    },
    "grammar": {
