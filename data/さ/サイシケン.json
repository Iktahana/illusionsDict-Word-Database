          "literary": [
            {
              "text": "悪い学科が一科目きりですから、従来の慣例に従えば再試験を受けられます。",
              "citation": {
                "source": "首席と末席",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその足で再びジョーンズ博士を訪れて再試験のことを頼み入った。",
              "citation": {
                "source": "首席と末席",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には翌日寺島君は真の形式丈けの再試験を受けて即座に卒業した。",
              "citation": {
                "source": "首席と末席",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何」「再試験をして貰う」「いつ？",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の休暇が終って新学年が始まると間もなく、赤羽君と吉田君が再試験を受けて卒業した。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
