[
  {
    "uuid": "18b4bfc7-d05e-5403-97d4-a2f5847b37c8",
    "entry": "鎖状",
    "reading": {
      "primary": "さじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chainlike",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "葡萄状球菌、連鎖状球菌に因る諸疾患にも卓效を奏するといふことだつたので、私は、それを、はじめて二錠服用したときから、既に恢復の一歩を踏み出したやうな爽快を覺えました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君達は、あのフィラリヤって言う寄生虫のために淋巴管が閉塞がれて、淋巴の欝積を来した場合だとか、或は又、一寸した傷口から連鎖状球菌の浸入に依って、浮腫性の病後に続発的に現れる象皮病――って奴を知ってるかい？",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち被封鎖状態が彼らの科学を進歩せしめた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊の御紋の周囲に王冠と獅子頭が互いちがいに鎖状をなしている金の装飾、おそれ多くも下にこう書かれてあった。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事情はたださえ長年の封鎖状態におかれた日本の文化と民主化のために重大な遺憾事である。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "球菌は２つ、４つ、房、または連鎖状、をしている。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "産褥熱その他の連鎖状球菌による致死的な感染も間もなく過去の病気と考えられるようになるであろう。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "溶血性連鎖状球菌は今日と同じように恐ろしいものであった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は腸チフスまたは亜急性連鎖状球菌症に罹ったのであろう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は２日後に死亡し足指の爪が食い込んだことによる悪性の連鎖状球菌によって死亡したことは間違いないであろう。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
