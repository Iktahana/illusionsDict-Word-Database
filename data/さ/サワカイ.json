        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その日、沢田の為に送別茶話会を寄宿舎で開くことになつてゐた。",
              "citation": {
                "source": "喜びと悲しみの熱涙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶話会は夕方の五時頃に終つた。",
              "citation": {
                "source": "喜びと悲しみの熱涙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "庚戌会と言えば謹厳な学術の報告会、兼、茶話会みたようなものと思ったが、なかなかどうしてエライ景気だわい。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の路上茶話会がここに開かれて、諸家の見舞人が続々もたらしてくる各種の報告に耳をかたむけていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶話会の群れのうちから若い人はひとり起ち、ふたり起って、番町方面の状況を偵察に出かけた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　誰が云ったのか知らないが、その声に気がついて、わたしはすぐに自分の家へ駈けて帰ると、横町の人たちももう危険の迫って来たのを覚ったらしく、路上の茶話会はいつか解散して、どこの家でも俄かに荷ごしらえを始め出した。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大君のめでたい誕生日は、茶話会では収まらなかった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の路上茶話会がここに開かれて、諸家の見舞人が続々｜齎らしてくる各種の報告に耳をかたむけていた。",
              "citation": {
                "source": "火に追われて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶話会の群のうちから若い人は一人起ち、ふたり起って、番町方面の状況を偵察に出かけた。",
              "citation": {
                "source": "火に追われて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　誰がいったのか知らないが、その声に気がついて、わたしはすぐに自分の家へ駆けて帰ると、横町の人たちももう危険の迫って来たのを覚ったらしく、路上の茶話会はいつか解散して、どこの家でも俄に荷ごしらえを始め出した。",
              "citation": {
                "source": "火に追われて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "合宿では月々一夜を選んで選手の休養かた／″＼、彼等の父兄や友達を招いで茶話会を催すのが例だつたが、この二三回この方日報社にとゞく戦争の実写映画と幻灯とを映写した。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が初めて山中に会つたのは、たしか『都新聞』の小林氏の主催にかかる茶話会の席上であつた。",
              "citation": {
                "source": "人間山中貞雄",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねての約束の如く、山口詩選出版記念茶話会へ招待されたので出かける、一時のバスで湯田へ。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "出征兵士の相当ある地方では、出征兵士の家族の若い婦人たちを茶話会、或いはその他の形であつめ、ブルジョアのバラまく戦争へのアジ、例えば桜井忠温の「銃剣は耕す」などという軍事通信の曝露をやり、次第にサークルへ組織して行くようなことも考えられる。",
              "citation": {
                "source": "国際無産婦人デーに際して",
                "author": "――作家同盟各支部に婦人委員会をつくれ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の或ものは家族を加えた茶話会に彼を招待した。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "形式ばった茶話会がくずれてから、多喜子はヴェランダのところで煙草をすっている桃子のそばへよって行った。",
              "citation": {
                "source": "二人いるとき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ですっかりロシアの仕事を終り、茶話会をしてしまうと云うのである。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　音楽会が終った後で、俊助はとうとう大井と藤沢とに引きとめられて、『城』同人の茶話会に出席しなければならなくなった。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻に至つて南部氏と本城夫人の配慮で、在留婦人の一部の茶話会が大和ホテルで催され、私は短時間ながら其等の婦人達にお目に掛ることの出来たのを喜んだ。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "山県乃ち自由党の首脳星亨を招きて宣言書を交附し、三十日、首相邸に於て茶話会を開く。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の或ものは家族を加へた茶話会に彼を招待した。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "角館中学校の校歌の話になつたとき、『つまり茶話会などの時に歌ふのもあつていいですね。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三学期全寮茶話会の夜、私はあなたの演説を聞いた。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全寮茶話会の夜は無事に済んでよかったが、あなたはこれに類する、他人の思想を僭するような危険な地位にこれまで幾度も立たれはしなかったろうか。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの茶話会の演説は私の予期したごとくモラーリッシュなものであった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、ポリテクニシヤンの家庭の茶話会はどうか。",
              "citation": {
                "source": "世界人情覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二百三十八　茶話会　中川の去りて後小山は独りお登和嬢と対座せしが嬢の様子の引立たぬを見て心の愁を想い遣り「お登和さん、さぞ御心配でしょう。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の関係している雑誌社で毎土曜日に社員の茶話会を開きます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日の御馳走は一切その当番の人の趣向に任せるとしたところ、以前は最下等の鰻の丼位で済ませたものが俄に種々の趣向が出て、或は鮎の鮨に茶菓子が出る事もあり、中には自分の家から手打蕎麦を拵えて来る事もあり、天麩羅飯も出来れば五目鮨も出来るというような訳で茶話会の傍ら食物の共進会が始まった様な訳です。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶話会のお弁当に二十銭もお掛けなされば西洋風の気の利いた御馳走が出来ます」と得意になって語り出しぬ。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
