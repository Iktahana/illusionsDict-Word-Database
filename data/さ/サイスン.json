          "literary": [
            {
              "text": "彼らは、きちんと採寸して、そのお父さんにぴったりのサイズの、ことのほか美しい出来ばえのシャツを、作ってあげます。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんども丁寧に採寸し、見事なシャツを、半蔵と幸江は作るのです。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これでいっさいすんだとおもってはいけません。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでいっさいすんでしまったのです。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
