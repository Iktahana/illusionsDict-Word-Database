        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゲーテのライネケフックスの訳本を読んで聞かせてくれたり、十歳未満の自分にミルの経済論、ルソーの民約論を教授してくれるという予告だけでもしてくれた楠さんは、たしかにその時代の新人であり、少なくも自分にとっては、来るべき「約束の国」の先触れをする天使の役をつとめてくれたように思われる。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ十歳未満の筆者が、座ったまま翁と応待していると、祖父が背後からイキナリ筆者の頸筋を掴まえて鼻の頭と額をギュウと畳にコスリ付けた事があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、まだ世の中を見る眼、それから人生に対する考え、そんなものが、ハッキリと定まっていない、独特のものを持っていない、二十五歳未満の青少年が、小説を書いても、それは無意味だし、また、しようがないのである。",
              "citation": {
                "source": "小説家たらんとする青年に与う",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとくすること幾春秋――なんて大仰だが、闘牛は牛齢五歳未満をもって一条件とする。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱山に働く婦人の数が、男子一五パーセント増に対して女子は一七パーセント増して約二百万人もおり、しかも坑内作業が多くて二十歳未満の女の子がふえているという事を、人は無関心に聞くであろうか。",
              "citation": {
                "source": "女性の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働時間は大人八時間、七時間で十八歳未満の青年労働者は平均六時間だ。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六歳未満は四時間労働制だ。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百六十四名、主に少女工（十五歳未満）剣劇ファン○職工と女工と別の出入口をもっているところもある。",
              "citation": {
                "source": "工場労働者の生活について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同月八日此間出生仕候娘病気之処、養生不相叶申上刻死去仕候、七歳未満に付、御定式之通、三日之遠慮引仕候段御達申上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三月廿六日末女病気之処養生不相叶今暁丑中刻病死仕候処、七歳未満に付三日之遠慮引仕候旨、合御触流を以及御達候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "統計のなかにも、二十歳未満の少女に強盗と云うのが一人ありました。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八歳未満が、窃盗二人、嬰児殺し一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十歳未満が、窃盗二人、強盗一人、放火二人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五歳未満が、窃盗四人、詐欺二人、殺人一人、嬰児殺し二人、放火四人、治安維持法違反一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十歳未満では、窃盗十一人、詐欺四人、殺人四人、放火五人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五歳未満は、窃盗四人、詐欺二人、傷害一人、殺人六人、嬰児殺し三人、放火五人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十歳未満では、窃盗八人、詐欺二人、殺人一人、嬰児殺し三人、放火六人、治安維持法違反一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十歳未満、窃盗十八人、詐欺五人、殺人四人、嬰児殺し五人、放火十人、賭博一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十歳未満は、窃盗十五人、詐欺一人、殺人六人、嬰児殺し三人、堕胎一人、放火九人、贓物収受一人、文書偽造一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十歳未満では、窃盗四人、殺人一人、嬰児殺し一人、放火三人、賭博一人、兌換券偽造一人。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦国の孤独人、そういう感懐が、三十歳未満の私の精神に却って媚びた。",
              "citation": {
                "source": "祭りの夜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂュリエットは十四歳未満の娘の筈だが、西洋の娘がいかほど早熟てゐるにしても、よしんば恋がミネル※の神力を与へたにしても、十三や十四の娘に斯んな気のきいた、綺麗な、そして胸をつく言葉がペラ／＼と喋りまくられやうとは思へない。",
              "citation": {
                "source": "文章その他",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジュリエットは十四歳未満の娘の筈だが、西洋の娘がいかほど早熟ているにしても、よしんば恋がミネル※の神力を与えたにしても、十三や十四の娘に斯んな気のきいた、綺麗な、そして胸をつく言葉がペラペラと喋りまくられようとは思えない。",
              "citation": {
                "source": "文章その他",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、学生の徴兵猶予の撤廃、十七等種の就業に四十歳未満の男子を禁止、官庁人員の整理、官庁と家屋店舗の整理など、かなり思い切ったものだ。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの問題に関する一般の計算では、青年は二十歳未満でも兵役に堪えるものと考えられている。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一八歳未満の青年の極めて多数が、徴兵忌避の目的をもって、尚早にして結婚生活に入ったことは、周知のことに属する。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、児童虐待防止法　この十月一日から児童虐待防止法が実施され、十四歳未満の児童を、家庭内に於ける虐待・種々なる職業に於ける虐使其他から護ることになった。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "人というなかに、三〇歳未満の青年たちがふくまれないというはずはない。",
              "citation": {
                "source": "現実の必要",
                "author": "――総選挙に際して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも婦人と青年とがより悪条件で働かされて来たこれまでのしきたりから言えば、三十歳未満の青年は、つまりは女なみだということだろうか。",
              "citation": {
                "source": "青年の生きる道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十歳未満だから、どんな愛人も満足するだろう。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
