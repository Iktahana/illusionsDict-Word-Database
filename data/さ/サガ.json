  {
    "uuid": "fa8b96dc-8f83-532d-9d11-6a0c10e19e76",
    "entry": "サガ",
    "reading": {
      "primary": "サガ",
      "alternatives": [
        "サーガ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "saga",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "肥えて居た方はことに衰へて、あのはち切れさうだつた血色のいゝ皮膚が、今はもうタブタブして居て、ガサガサした感じさへ与へて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井がガサガサガサガサ云います。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どんな小さな瀕死人でもがその市立病院に一直線にはひつて行かうと思ひつめさへしたら、サガン公爵ですら、その行列を止まらさない訣には行かない。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鈴薯は大抵倒れたりガサガサに枯れたりしてゐた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の物干しの暗い隅でガサガサという音が聞こえる。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ハラガヘッテハ、イクサガデキヌ。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井がガサガサガサガサ云ひます。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなガサガサガサガサさがしましたが、どうしてもそんなものはありません。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはガサガサガサガサやりますけれどもどうもなかなか見つかりません。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっかさんの手はそんなにガサガサしているのでしょう。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井がガサガサガサガサ言います。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平たい庭石の上に用意して在った炭俵の上にガサガサと土下座をすると、頬冠を取った目明の良助は、その側から少し離れて、型の如く爪先立ちに跼まった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い鼻の頭を今一度、念入りにコスリ上げると、炭俵の上からガサガサと一膝進み出た。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その事は無論時田も江藤も知っていたので、江藤もよく考えたら森の奥のガサガサする音は必ずそれと気の付くはずなんだ。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "動いたと見えて、ガサガサと新聞包が揺れたろうではないか。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきの茶いろの毛のガサガサした先生の教室なのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヰルナラサガス」此れなら、局待の二字分がきちんと入る、うまいでせう。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二ツノ　ホシハ、ソノ　ヨルモ、オシダマツテ　アツチコツチト　ナクナツタ　ホシヲ　メデ　サガシテ　ヰマシタ。",
              "citation": {
                "source": "ナガレボシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヌスビトト　コヒツヂ新美南吉　ヤワラカイ　クサガ　ミドリノ　モウフノヤウニ　ハヱテ　ヰル　ヒロツパニ　タクサンノ　ヒツジガ　メイメイト　ナキナガラ　アソンデ　ヰマシタ。",
              "citation": {
                "source": "ヌスビトト　コヒツヂ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムスコハ、イロイロ　サガシタガ、アマリ　ヨイ　キカイガ　ナイノデ、ラツパヲ　カツテ、「コレヲ　サカサマニ　シテ　ミミニ　ツケテ、ラツパノ　シリカラ　キキナサイ。",
              "citation": {
                "source": "ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
