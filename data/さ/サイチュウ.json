[
  {
    "uuid": "70c41a62-7ce3-5daa-bb18-9fea1bfda1f0",
    "entry": "再注",
    "reading": {
      "primary": "さいちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "repeat order",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さては、百万の大軍がいま戦争さいちゅうの曠野。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この僧侶は祈っているようすでしたが、そのお祈りのさいちゅうに何か物思いにしずんでいるようでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そこでは、おそろしいさわぎの起っている、まっさいちゅうでした。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩さいちゅうに誤って足をすべらし小川へ転落した場合のことを考慮したのであった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日分くらいの食料を持参して来たのだが、何せ夏の暑いさいちゅうなので、にぎりめしが皆くさりかけて、めし粒が納豆のように糸をひいて、口にいれてもにちゃにちゃしてとても嚥下することが出来ぬ。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥一の義母しづ、庭の物干竿より、たくさんの洗濯物を取り込みのさいちゅう。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そのよろこびのまっさいちゅうに、ヘンデル先生は、ふとした不注意から、ばいきんが目にはいり、それがもとで、死んでしまいました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ除夜の鐘のさいちゅうだ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、君、日本はいま国運を賭して、北方の強大国と戦争のまっさいちゅうだ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑魚寝のさいちゅうに血なんか吐いたら、いい見世物ですわよ。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇后はそれに答えて、「あの御子は、ちょうどとりでが火をかけられて焼けるさいちゅうに、その火の中でお生まれになったのでございますから、本牟智別王とお呼び申したらよろしゅうございましょう」とおっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そのいそがしいまっさいちゅうに、ランプがふっと消えてしまいました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "（もう来ているだろうか、この試験さいちゅうに）　彼は神中が試験にいそがしいことを知っていて、己かってな処へ呼ぶのが腹だたしくなって来た。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはそれをとりまいて、幕のあくのを待つさいちゅうでした。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語りさいちゅうの作者も、また読者も、実にとまどい困惑するばかりである。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大戦争のまっさいちゅうなのに。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の起こりましたのは山王権現、俗に山王さんといわれているあのお祭りのさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろはがるたを地でいって粂五郎は、土に頭をもぐらせんばかりにしながら、必死とちぢこまりつつがたがたとやっていたさいちゅうなのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご承知のごとく、昔は太陰暦でございますから、現今とはちょうどひと月おくれで、だから七月といえば、まさに炎熱のまっさいちゅうです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫かごにはまだ少し早いが、そのかわり軒端の先には涼しい回りとうろうがつるされて、いずこの縁台も今を繁盛に浮き世話のさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "興照寺より届けいでこれあり候とあったその永代橋へたどりついてみると、名人の出馬いまかいまかとかたずをのんで、寺社奉行ご支配の小者たちが群がり集まる群衆を制しつつ、その到着を待ちあぐんでいるさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お番所からはまだだれも出馬しないとみえて、自身番の小者たちにしかられながら、物見高い群衆が押しつ押されつ、わいわいとうち騒いでいるさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月十五日、冬のまっさいちゅうに決まっているじゃねえですかよ」「江戸は降らねえが、さだめし加賀あたりは大雪だろうね」「なにをべらぼうなこというんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどなくなった騒ぎのさいちゅうおみえになりましたが、何をおあわてか目いろを変えてこの奥へ駆けこんでいったきり、あのかたの姿が消えてなくなりましたゆえ、なおさら気味わるく思っていたところでござります」「よしよし。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までもしばしば申し上げたように、当今とは一カ月おくれの太陰暦ですから、師走は師走であっても、ずっと寒気がきびしくて、朝夕はへそまでが凍りそうな寒のさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きついてみると、なるほど熊仲和尚の報告どおり、南部名物くまの手踊りはいまし興行のさいちゅうでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その拍手のまっさいちゅうです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお盆のさいちゅうに、またうすっ気味のわるいいたずらするやつがあったものだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょっぴいてきた若者をお白州へ引きすえて、大得意の敬四郎がぴしぴしと痛み吟味をかけているさいちゅうへ、その配下の者がまろび込むように駆け込んできながら、歯の根も合わずに新しい事実を敬四郎に報告したからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "道中つつがのうございまして、祝着至極にござります」　まことにどうもこの、豆州か、というような鷹揚で、威厳があって、それでいてじゅうぶんに親しみのある呼び方なぞというものは、お三家のかたででもなくては、なかなかこんなふうに板にはつかないものですが、しかるに、そのごあいさつのさいちゅうです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
