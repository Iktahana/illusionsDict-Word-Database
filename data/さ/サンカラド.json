        "examples": {
          "standard": [
            {
              "text": "古い日本家屋の座敷には、趣のある桟唐戸がはめ込まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寺院建築において、桟唐戸は格式と美しさを兼ね備えた重要な要素だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "職人が丹精込めて作った桟唐戸の彫刻は、見事なものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「母親さんからどういう手紙が行くものですか、それは解りませんが――」と正太はその話を継いで、「阿爺の手紙は、豊世が受取って、それから母親さんの方へ取次いでいます。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでお前もあいつに会うのは厭だろうと云うんだ」「じゃあなたはあたしが小林さんからどんな事を聴いたか知っていらっしゃるの」「そりゃ知らないよ。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい時から母さんや私が、お父さんからどんなひどい目に会ったか！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
