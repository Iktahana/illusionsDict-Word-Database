    "definitions": [
      {
        "index": 1,
        "gloss": "day laborer (in construction, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
