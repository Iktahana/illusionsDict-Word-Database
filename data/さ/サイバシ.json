        "examples": {
          "standard": [
            {
              "text": "菜箸を使って鍋の具材をかき混ぜる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "熱い料理を取り分ける際は、菜箸が便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本の家庭料理には欠かせない調理器具の一つが菜箸だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（二見、菜箸をもつたまゝ現れる）駄目ですよ、静かにしなくつちや……。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おくめは、菜箸を片手に持ったまま、戸口へ下りて行って、懐しそうに娘の風を見た。",
              "citation": {
                "source": "黄昏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいであすこいらの小家がみんなかびたもちで目に見えない大きなさいばしがそれをあみの上にのせてあっちにやったりこっちにやったりして居るように思われる。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
