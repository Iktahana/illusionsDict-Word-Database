      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "site",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "資料の宝庫といった、充実したサイトがみつかり、そこからさらに関連のページにたくさんのリンクが伸びていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方木津田さんはサイバーブックセンターへの道案内に加え、電子出版物のオンライン流通を論じる中で、テーマとして取り上げたさまざまな関連のサイトにリンクを張っていたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際に当たりはじめると、次から次へと興味深いサイトが見つかりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロソフトのサイトにも、創立二十周年を記念するページがありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀之内さんのページからたどって、ＢＢＡのサイトを開くと、「弱視者を含めた視覚障碍者全般の読書を支援するために点訳・音訳・拡大訳の３分野の活動を全て統合的に推進しています。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面に表示できる文字数に合わせて、ファイルを小分けして用意したサイトがある。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンナツマラナイ素描帳ヲ見テクダサイト言ウノハタイヘンツライノデス。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵小説は読者に驚異を与える、恐怖を与える、何らかの強烈なエキサイトメントを与えるということを第一の主眼としなければならぬ。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場ノ人ガクルト、クサイクサイト云ウノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "樽野は鴎丸の漁屋で、雨の日には夫々天に向つて舌を鳴らしながら酒宴を催しに集つて来る老若の、七郎丸、大々丸、鱗丸、三郎兵衛丸、潮吹丸、づくにゆう丸、鯖子丸、般若丸、サイトウ丸、源太郎兵衛丸などといふ連中と相知つたが、その酒宴の騒々しいことと云つたら素晴しい！",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（４）種蒔きどきに歌う唄、すなわち畠蒔き唄というのは当方では、ただ、ヤイトヤアラ、サイトヤア……という意味をなさぬような調子である。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日あたりから、朝鮮人が来ると云う噂が立ち、センセンキョーキョー、地震のとき、春江ちゃんの行って居たサイトウさんのところでは、奥さんが死なれその良人、子供二人、姉妹たち、皆一緒に居る。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この教練に從つて造化の意匠が分つて來ると、高尚な情緒が起つて、僕等を擴張して呉れる、この自個擴張はインサイト、洞察に由らなければならない。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど少なくともインターネットに接続できる人に対しては、openURL で、陳述の掲載されているサイトにリンクを張れる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "両市長の陳述を掲載した広島と長崎のホームページに加えて、翻訳作業中に見つけた核兵器をテーマにしたサイトにも、リンクを張った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "openURL を仕込んだそのサイトからは、「核兵器の本質を見極めよう」とする志のリンクが、さらに夥しいホームページに向かって伸びていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると今度は、関連のサイトを軒並み調べてみたくなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに各種の検索エンジンで調べてリンクをたどっていくと、興味深いサイトがいくつも見つかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが個人のサイトでも、アップル※の克明な歩みや、コンピューターの総合年表といったものをカバーした、力の入ったものがある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の持ち物である『パソコン創世記』から、インターネットのさまざまな関連サイトにリンクを張るつもりではじめた作業だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまなサイトへのリンク付けの作業は、この環境なしではとてもやり通せなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋと云ふ小説家のことを、彼の買つたブル・ドツグのことを、リウイサイトと云ふ毒瓦斯のことを。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋと云う小説家のことを、彼の買ったブル・ドッグのことを、リウイサイトと云う毒｜瓦斯のことを。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "母様も、妙にエキサイトして、種々な小さい問題で、現代の物質的な生活、――貧困になりそうな者と見れば、親友の誓をしたものまで、利害関係によって離れると云って被居っしゃる。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月七日　水　昨夜、眠る前に、国男さんの事で少し、エキサイトした故か、安眠が出来なかった。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
