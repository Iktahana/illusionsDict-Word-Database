  {
    "uuid": "52fd52d6-6a4a-53f2-8a20-9e8ff3bf9120",
    "entry": "産駒",
    "reading": {
      "primary": "さんく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "horse offspring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼らは私たちの「逆廻り」を、うさんくさそうな傍目を使って、あわれむが如き素振りでゆき過ぎた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石を敷いた狭いゴミだらけの通りを、え体の知れない支那人が、犬のようにうさんくさく行ったり来たりする。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（何にしても貴僧には叔母さんくらいな年紀ですよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だって、おぬいさんくらい美しく生れついて、銀行の重役の家に育って、いい加減から貧乏になってみろ、俺だって今ごろは神様になっているんだ……神様もけだものもあるかい。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日の晩方になって、森がもう黒く見えるころ、おかあさんはにわかに立って、炉に榾をたくさんくべて家じゅうすっかり明るくしました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの無限者のうちへはおいでなさい、なか／＼の善根家で、たくさんくれますよと教へて下さつた深切な人もあつた。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、きょうは、この人形の誕生日だしするから、贈り物も、きっと、うんとたくさんくるよ」「うん、それなら、ぼくもよく知ってるよ」と、ヤルマールは言いました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいで私が下敷で叩きおとしたら姉さんくやしがつたわね。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし相手は、うさんくささうに、わしをじろじろと見てゐて、首を横に振りました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家も、津田さんくらいになると、やっぱり違ったところがあると思った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪の子、というと、へんに牧師さんくさくなって、いけませんが、なんといったらいいのかなあ、おれは悪い事を、いつかやらかした、おれは、汚ねえ奴だという意識ですね。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐろりや、はとり、えひりおゑぬ、ぴりてゆい、さんくと。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、抗議すると、「だって、美和子の覚えているパパは、前川さんくらいだわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、随分探したんだけど、結局南條さんくらい、いい人ないと思うんですもの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お前は何人だ、）　養父はうさんくささうに云つて眼を光らした。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名僧の、智識の、僧正の、何のッても、今時の御出家に、女でこそあれ、山の清心さんくらいの方はありやしない。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに時重さんくらいと思ったときもあったに、いまは時重と自分とのあいだに、よほどな距離があることを思わないわけにいかなかった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家も貧乏で、ちょうどお前さんくらいの妹がある。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて美禰子さんくらいのなら我慢すると言っている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "わきざしでなし、短刀でなし、まさしく小柄で突いた突き傷だな」　ずばりとホシをさしておくと、気味のわるい町方役人が来たものじゃな、というように、じろじろとうさんくさげに見ながめているあるじのほうへ、いんぎんに一礼していいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、皆さん、そこらへ席をとってください」　北見博士は、うさんくさそうに、総監についてきた一同の顔を見まわした。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "機屋の窓助さん助さん　　　この助さん東に花妻　　　真中に川端柳の　　　木の枕助さん助さん　　　この助さんくぐもり小浜の　　　海の音は機屋の窓まで　　　響くぞへ。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はうさんくさそうにじろじろみていたが、「どこでよ。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンナは、何だか旧教くさく、尼さんくさいからと云うので。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
