[
  {
    "uuid": "dc7c553f-3aa5-5907-90cc-a0563a897479",
    "entry": "惨苦",
    "reading": {
      "primary": "さんく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
