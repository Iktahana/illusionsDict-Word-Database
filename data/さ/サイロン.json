[
  {
    "uuid": "51da3c6a-b4b1-5fe7-b3ad-c9a5a5f92019",
    "entry": "細論",
    "reading": {
      "primary": "さいろん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
