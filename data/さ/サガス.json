        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何しろ文学的素質がないのだ、そこでアラを探すにも彼らしくアラを探すことになる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼に妻子がなかったら、日本に幻滅した最初の日に、再度また『まだ知らぬ新しい国』を探すために、あてのない漂泊の旅に出発したにちがいなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで大抵の人がその凡そ何かを探すのだ。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとからボーイにカバンを持たせて、彼のゐる所を探すやうにやつて来る。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に牝狐の方では胸が清々してきて、もう一度牡兎を探す気になつてゐた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "山寄りの道を行く方が山の岳神を探すに便利は多いようなものの、それ等の山は多く未開の山で、ちょっと人に訊いただけでも、山の主は、百足であるとか、猿であるとか、鷲であるとか、気の利いた山の神ではなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく虚々実々、無言にして、天体の日月星辰を運行る中に、新生の惑星が新しく軌道を探すと同じ叡智が二人の中に駈け廻った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂美食に飽きた食通がうまいものを探すのは中流の料理屋に於てである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その旅人と云っても、馬を扱う人の外は、薬屋か林務官、化石を探す学生、測量師など、ほんの僅かなものでした。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝奥の部屋　源兵衛、来て押し入れ等を探す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯く服をいじりて窓の処まで行き暫く外を見て、急に向き返り、部屋の内を、何か探すように、歩き廻る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その内娘は左手の箪笥を開け探す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（娘、ブラシを探す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「道を探すだけでなしに、パルチザンがいやしないか、家があるか、鉄道が見えるか、よく気をつけてやるんだぞ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石油を撒き、石油ランプをともし、子供が脛まで、くさった水苔くさい田の中へ脚をずりこまして、葉裏の卵を探す代りに。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その旅人と云っても、馬を扱ふ人の外は、薬屋か林務官、化石を探す学生、測量師など、ほんの僅かなものでした。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "重要な手がかりを探す手がかりが全く絶えた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は逆に、無駄なことばかりしてやろう」　青年はそう決心はつきましたものの、さて、その決心に添うような無駄事を探す段になって、はたと行き詰りました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが積極的誤解となると、手を尽すか探すかすれば、正解に達し得られるものをいい加減にして置くか、感情に左右されて軽忽に実情を覆う誤解であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この行方を探すには、私が巡礼に出なければならないんだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何を探すっていうの。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう夜になっては探せないから、今日はどこかに野宿して、明朝早く探すことにしようじゃないか。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかにこの十年ばかり前までは、うら枯の秋から、冬の時雨の夜へかけて、――迷児の迷児の何とかやーい――と鐘をたたいて、魔に捉られたものを探す声を、毎晩のように聞いて、何とも早や首を縮めたものでござります、……と昨夜の宿で按摩が饒舌った。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と膝行歩きて、燧火か、附木か、探す様子。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合、そんな詮議をするよりも、まずその二人のゆくえを探す方が近道ですから、五、六人の若い衆が提灯を照らして裏と表へ駈け出しました。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その行方を探す小説を書くかな。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "失敗た、とあの人は約束の時間におくれたことに改めて思いあたり、そして京都の夜の町をかけずりまわって、その友達を探すのである。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く横になれるところをと焦っても、旅館はおろか貸間を探すにも先ず安いところをという、そんな情ない境遇を悲しんでごたごたした裏通りを野良猫のように身を縮めて、身を寄せて、さまよい続けていたのだった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チケットを落したんですが……」　と、小沢はもう探すことは諦めて、係員に言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあもうきっと僕は僕のために、僕のお母さんのために、カムパネルラのためにみんなのためにほんたうのほんたうの幸福をさがすぞ。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
