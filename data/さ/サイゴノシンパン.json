[
  {
    "uuid": "24957c5f-381a-5554-8532-b8411855ae53",
    "entry": "最後の審判",
    "reading": {
      "primary": "さいごのしんぱん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Last Judgment (judgment of mankind to take place when the world ends, according to various religious traditions)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、それは、私たち二人にとって、最後の審判の日の※よりも怖ろしい響で御座いました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして恐ろしい最後の審判の日はじりじりと近づくのである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の審判の喇叭でも待つように、ささやきもせず立ち連なった黄葉の林。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が最後の審判の台に立たされた時、たった一つ、「けれども私は、私と附き合った人をひとりも堕落させませんでした。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、「最後の審判」の写真版を畳んで、つぎの部屋へ引き上げ、机に向った。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時分の二葉亭の議論の最後の審判官は何時でもモーズレーであって、何かにつけてはモーズレーを引合に出した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、最後の審判の日が来つたところで誰一人罪せられる者はゐないであらう。",
              "citation": {
                "source": "神童の死",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が死の淵にかがやく星にみいつてゐるとき、　いつも浮んでくるのはその幻だ　広島の惨劇は最後の審判の絵か何かのやうにおもはれたが、そこから避れ出た私は死神の眼光から見のがされたのではなかつた。",
              "citation": {
                "source": "死について",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "大袈裟にいえば、最後の審判の日が来たのかと思われる程であった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は堪えがたい恐懼と煩悶とにひと月あまりをかさねた末に、彼は更に最後の審判をうけるべく怖ろしい決心を固めた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスマイル教徒に言わせると、この復活並びに最後の審判に関するゾロアスター教の教えは、単に宇宙系における周期的変転を表現する影像にすぎないというのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は哲学的判断の最後の依拠を常識に置くものであり、而も一定の既成判断内容としての常識的直観を最後の審判者とするのである。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街の果ての平原に煙幕のような蒙古風が巻き立ったかと思うと、視界はもう人類最後の審判の日のように、赤く暗く霞んで、色の附いた空気があらゆる隙間から、室内へ、机の上へ、寝台へ、そして私たちの鼻口へ、おそらくは肺の底へまで音を立てて侵入してくるのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "その信徒等は彼等の感激に於て固より全く新しく明ける日の微風に包まれてゐるのを信じたが、然しそれは同時にこの世界の過ぎ去る最後の審判の日であるべきであつたのである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は實にソレルにおいて最後の審判、かの終末觀（eschatologie）の觀念を見る＊＊。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後の審判の絵のように川岸は悶死者の群で埋められたのだが……）　僕はあのとき、あの静かな川岸で睡って行ったなら、どんな夢をみたのだろうか。",
              "citation": {
                "source": "夢と人生",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、細君の眼には、僕が最後の審判からのがれて来た不吉な人間のやうに見えるのかもしれない。",
              "citation": {
                "source": "飢ゑ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等の主人公がどんなに激昂して、彼等を悪党だの、泥坊だの、旅人を苦しめる追剥ぎだのと罵り、果ては最後の審判の怖ろしさまで引合いに出して脅してみても、いっかな、鍛冶屋たちをへこますことは出来なかった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "つひぞあん畜生が一月分だつて月給の前借をさせた例しがあるかい――それよりやあ、最後の審判の來るのを待つた方がましなくらゐだ。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の審判の日は近づきましたよ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲエテはミケル・アンジエロの「最後の審判」に嘆服した時も、ヴアテイカンのラフアエルを軽蔑するのに躊躇するだけの余裕があつた。",
              "citation": {
                "source": "芸術その他",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "では「さまよえる猶太人」とは何かと云うと、これはイエス・クリストの呪を負って、最後の審判の来る日を待ちながら、永久に漂浪を続けている猶太人の事である。",
              "citation": {
                "source": "さまよえる猶太人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはミケル・アンジェロの「最後の審判」の壁画よりも遥かに六十何歳かのレムブラントの自画像を愛している。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の審判「はッははは、だいぶ驚いたようじゃね、無理もない、突然君にこんなことまでいってもとても飲込めんじゃろうからネ……しかしまあわしの仕事がぼんやりでもわかってくれたら手伝ってくれたまえよ。",
              "citation": {
                "source": "白金神経の少女",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その筈じゃよ、これはあの有名なシスティーン礼拝堂の大壁画『最後の審判』と同じなんじゃ。",
              "citation": {
                "source": "白金神経の少女",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女がある爲めに、此の世の中は、僅かに最後の審判を免れてゐるのだとさへ考へられた。",
              "citation": {
                "source": "貝殼追放",
                "author": "女人崇拜",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはミケル・アンヂエロの「最後の審判」の壁画よりも遥かに六十何歳かのレムブラントの自画像を愛してゐる。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらは最大いなる體を出でゝ、純なる光の天に來れり　三七―三九この光は智の光にて愛これに滿ち、この愛は眞の幸の愛にて悦びこれに滿ち、この悦び一切の樂しみにまさる　四〇―四二汝はこゝにて天堂の二隊の軍をともに見るべし、而してその一隊をば最後の審判の時汝に現はるゝその姿にて見む。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいに最後の審判者たる彼の父の意見を必要と認めたものか、まだ寝ている叔父をとうとう呼び起した。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミケランヂェロの「最後の審判」の肉體の堆積。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
