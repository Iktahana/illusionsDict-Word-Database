    "definitions": [
      {
        "index": 1,
        "gloss": "bleaching",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "晒しでもねえ、木綿の官品のズボンじゃねえか。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでたちまち箱を割って拵えた小さな白い杭もでき　ほうたいをとった残りの晒しの縁のまっ白な毬も出て来た。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大へんわかりきった事で恐縮ですが、僕なぞ時々此のわかりきった事を失念してとんだ恥を晒します。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚一枚に眼を晒し終つて後、さてあまりに尋常な周圍を見廻すときのあの變にそぐはない氣持を、私は以前には好んで味つてゐたものであつた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸上の生活力を一度死に晒し、実際の影響力を鞣してしまい、幻に溶かしている世界だった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿な奴だな、若けえ者のくせに飛んだ業晒しだ」「これからどうするんですね」と、半七は訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は斯うしてここに半日晒しものにした上で、棒しばりにして広小路は勿論、馬道から花川戸のあたりまで、引き廻してあるくのであると彼等は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬られた頸は三つも四つも並べて路傍の電柱にぶらさげられ、晒し首にされた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら晒し首にしたところで、彼等の悪業のむくいとしてはやり足らぬかもしれなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は開け放った窓のなかで半裸体の身体を晒しながら、そうした内湾のように賑やかな溪の空を眺めている。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚一枚に眼を晒し終わって後、さてあまりに尋常な周囲を見廻すときのあの変にそぐわない気持を、私は以前には好んで味わっていたものであった。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併せて先輩を晒し物にして批判した罪も謹しんで負う。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づきてとくと視れば、浅葱地に白く七宝｜繋ぎの洗い晒したる浴衣の片袖にぞありける。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに今や白昼に其の怪しき形骸を晒したのである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が書く事はすべて、自分の耻晒しであり世上の物笑いである。",
              "citation": {
                "source": "砕けた瓦",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "真綿は繭を曹達でくたくた煮て緒を撈り、水に晒して蛹を取り棄てたものを、板に熨して拡げるのだったが、彼女は唄一つ歌わず青春の甘い夢もなく、脇目もふらず働いているうちに、野山に幾度かの春が来たり秋がおとずれて、やがて二十三にもなった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は三十前なのに大分老い晒した人のような身体つきや動作になっていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水天髣髴の間に毛筋ほどの長堤を横たえ、その上に、家五六軒だけしか対岸に見せない利根川の佐原の宿、干瓢を干すその晒した色と、その晒した匂いとが、寂しい眠りを誘う宇都宮の田川の宿――その他川の名は忘れても川の性格ばかりは、意識に織り込まれているものが次々と思い泛べられて来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや風が吹き出して、河の天地は晒し木綿の滝津瀬のように、白瀾濁化し、ときどき硝子障子の一所へ向けて吹雪の塊りを投げつける。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの水を貯へた甕は夕方から庭に持ち出して蓋をとり、紗帛で甕の口を覆ひ、夜天に晒した。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しなやかに細い多くの線をなして麗はしく輝やかしく落下る美しさは、恰も纖く裂いた絖を風に晒して聚散させたを觀るやうな感じである。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれば唯河原の布晒し位のものだ。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和智君は痩せて背のひょろ長い体に洗い晒した浴衣を着ていた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このくらい手近かにある現品の吟味を、今更、表に晒して野暮な実物｜看貫も出来ないじゃござんせんか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六七年も、洋服を着て暖かい日向を選み／＼坊ちゃん嬢ちゃんの草花いじりの相手をして鈍ってしまったこの身体が、どうして再びあの吹き晒しと凍て土の世界へ、苦痛に噛まれに戻れよう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽に晒した毛のまばらな生剥ぎの皮を見るような寂しく焦々しい感じを起させます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沼の三分の一ほどの湖ですが、まわりは直ぐ山が匍い立ち、鉛色の水の面に白樺の老い晒した幹が白く抜けて、蛇骨のように見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜというのに、いま私は私の身や心として意識しているこのちり／″＼ばら／＼の髑髏、背骨、肋骨、腰骨、肢骨は、ちり／″＼ばら／＼ではありながら、どれもみな水晶のように透き通り、万更、そこらに朽ち果てた野晒しとも違うようです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、僕に死を禁ずるその同じ詭弁家が時には僕を死の前にさらしたり、死に赴かせたりするのだ。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は掛合い万歳は好きでない」「君は自分の手塩にかけた作品を市場にさらしたあとの突き刺されるような悲しみを知らないようだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
