        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北から帰って来たという小鳥たちは身籠る季節まえのまだ見ぬ雄を慕うて、囀りを立てている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたるところで小鳥らの囀りがする。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにもかも喧しい、だが小鳥らの囀りではない。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、チチチと何處からとなく聞えてくる朝の雀の囀りに耳を傾けながら、今日誰が見舞ひに來てくれるだらう――などと云ふ事を、樂しみながら考へたりした。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀の群が灌木の間をにぎやかに囀り、嬉々としてとびまわった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれが出て行くとそこらを片着け多勢の手で夕飯の餉台とともにお櫃や皿小鉢がこてこて並べられ、ベちゃくちゃ囀りながら食事が始まった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれが出て行くとそこらを片着け多勢の手で夕飯の餉台とともにお櫃や皿小鉢がこてこて並べられ、べちゃくちゃ囀りながら食事が始まった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の前の麦の中から、雲雀がとび出して、少しあがつていつたかと思ふと、囀りはじめた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三味線を弾いて聞かせると、音に競って軒で高囀りする。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い朝ゆゑ、それは冷めたい囀りだ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋の縁先で何匹かのカナリヤがやっきに囀り合っている。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側に飼鳥を売る店があって、いろいろな鳥の賑やかな囀りが聞える。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "エボナイトのような弾力と光沢を持った、あらゆる樹木の梢に群がる木の芽は、ずんずんと日｜毎にふくらんで行き、いろいろの小鳥は思い思いの音色で木の枝に囀り廻っていた。",
              "citation": {
                "source": "緑の芽",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはその狐の如く、ハツバス・ダアダアに聞きたるダンテの難を囀り出し、その代にはいたくペトラルカを讚め稱へき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後におもなる女優又來りて、それの詞の韻脚は囀りにくし、あの韻をば是非とも阿のこゑにして賜はれといふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして部屋の中にも軒端にもいつぱいに眼白籠が懸けてあり、とり／″＼に囀り交してゐた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "神女達の纏ふ羅は、両岸の此処彼処から囀り渡る小鳥の声にも、ヒラ／＼とたなびいて緑なる春の河を静かに昇つて行つた。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由よ、お前の正体は何か自由と言ひ、自由の束縛と言ひ町のヤマガラよ、お前はその正体を知つてゐるか、お前はそれを具体的に語ることができるか、をそらく、それはお前には出来ないだらう、ただ自由に囀り、自由に飛び廻るものが、これらのすべてを知り、これらのすべてを語るだらう。",
              "citation": {
                "source": "小熊秀雄全集",
                "author": "―３―",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだしその本隊は牝猴と事馴れぬ牡と少弱輩より成り、母は児を背負う、先達猴の威容堂々と進むに打って変り、本隊の猴ども不規律甚だしく、千鳥足で囀り散らし何の考えもなくただただ斥候の用心深きを憑んで行くものと見ゆ、若猴数疋果を採らんとて後るれば殿士来って追い進ましむ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに書き洩らしたが加藤雀庵の『囀り草』の虫の夢の巻に、千住の飛鳥の社頭で毎年四月八日に疫癘を禳う符というを出すに、桃の木で作れり、支那に倣うたのだろうとある。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうちに湧きたつやうな行々子の囀りと共に白々夜があけた。",
              "citation": {
                "source": "老苦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "一羽の鶯が其處らに巣でもあると見えて、遠くへは暫しも行かず、松の葉かげに斷えず囀り續けてゐた。",
              "citation": {
                "source": "比叡山",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は囀り、歌い、そして妻子を連れて枝から枝へと飛び移った。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥も囀りに倦き、風もまどろむおやつの時にも、母様はなおやめずに針を動かしておいでだった。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜毎に彼處の柘榴へ來て、あのやうに囀りをる。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿の真紅な花が燃えてゐて、陽は初夏のやうに豊かに降り注ぎ、何の鳥だか、頻りに人を恍惚とさす囀りが、あたりの空気を顫はせてゐた。",
              "citation": {
                "source": "馬頭観世音",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボール凾から木の箱へ移すと、二三度飛び廻ったかとおもうと、咽喉をふるわせて囀りだした。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "一羽の雛はもう囀りを覚えはじめ、わけても愛らしく頼もしかった。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳はまだあの囀りのあとを追い、その眼は無限のなかに彷徨っているようで、絶え入るばかりの烈しいものが、妻の貌に疼いていた。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした研究の結果いかんによっては、ほととぎすの声を「テッペンカケタカ」と聞いたり、ほおじろのさえずりを「一筆啓上仕候」と聞いたりすることが、うっかりは非科学的だと言って笑われないことになるかもしれない。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
