    "definitions": [
      {
        "index": 1,
        "gloss": "to hold out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "タンポポの花一輪の贈りものでも、決して恥じずに差し出すのが、最も勇気ある、男らしい態度であると信じます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は、龍宮の階段まで見送りに出て、默つて小さい貝殼を差し出す。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳が、Ｔ「娘をこの雲霧主膳に呉れぬその時は」　と云って、Ｔ「此の連判状を奉行所へ差し出すぞ」　エッと源兵衛顔色蒼白となる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳が、Ｔ「連判状を老中へ差し出すなぞ、野暮は申さぬ」　と言って、Ｔ「その代り」　と詰め寄る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍が、Ｔ「先生　只今御病気中に　御座れば」　ナニッ病気、と団九郎、　取次の侍、紙包を取り出して、Ｔ「誠に軽少に　御座るが　ホンの草鞋銭」　と団九郎の前に差し出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで次に皿を差し出す檀那は誰様だらうと思案したが、これはカロリイネ様の御亭主でペエテル様だと極めた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にはただ弔詞を包紙に包んだままで柩の前に差し出すのも沢山にあった。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "松公慌てて手を差し出す。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人に優しい見舞いの言葉をかけ、そうしてお金をそっと差し出す。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "店を出るとき家鴨の番号を記入したカードをマネージャーが恭しく客に差し出す。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と手でつまんで差し出す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはただ手を差し出すだけです。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘、恥かしそうに阿難の顔に見入り乍ら手を差し出す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋燭を差し出す父の手がすこしく顫えているからであった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校、毎年三月の修業式のときには必ず右総代として校長から賞品をいただくのであるが、その賞品を壇上の校長から手渡してもらおうと、壇の下から両手を差し出す。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際、この子は何よりも、自分の差し出す両腕の恰好に、おのれの注意力の全部を集めているのです。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は、竜宮の階段まで見送りに出て、黙つて小さい貝殻を差し出す。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野中教師、右手を差し出す。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "節子、無言で野中に寄り添い、あたりを見廻し、それから白い角封筒をそっと野中に差し出す。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "小使銭を支給されたその日に、勝治はぬっと節子に右手を差し出す。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、やけくそになって、味でも体裁でも、めちゃめちゃに、投げとばして、ばたばたやってしまって、じつに不機嫌な顔して、お客に差し出す。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "髭の男に扮している立派な役者は、わかいお弟子の差し出す鏡に向い、その髭の先にめしつぶをくっつけようとあせるのだが、めしつぶは冷え切っていて粘着力を失っているので、なかなか附かない。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯行こうと叔父が差し出す盃を順平はかしこまって戴き、呑み乾して返えす。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸村山伏の犬おどしにて、お目にかけるものにてはなしと云って、差し出す。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前は、同心ともう一度差し出すべきかどうかを相談した。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もう一度差し出す事は、将軍の不注意を、とがめ立てするようにも当るのである。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯行こうと叔父の差し出す盃を順平はかしこまって戴き、呑み乾して返えす。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥大した男の恋愛のつづきを受理する女のように頑健な裸な腕を寝床からさしだすと、受話器を整形された小さな耳にあてた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋のおばさんが花束をさしだす。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この薬籠をお前さんが持って往くが好い、お前さんは私の弟子のつもりでおるが好い」　と、薬籠をさしだすので、甚内はそれを受けとって肩にした。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
