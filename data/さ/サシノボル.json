    "definitions": [
      {
        "index": 1,
        "gloss": "to rise (e.g. sun, moon)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海を越えたる百萬の大御軍の雄叫びは旗雲高くさしのぼる日にこそ勇めまのあたり。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹹涸川堰の下の葦むらに行々子鳴きて鳰はお堀に水路舟行二十日、再び沖端に帰りて、人々と共に楽しむと柳河まで小舟に棹さしのぼる。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてさしのぼるに東のかたに山のよこをれるを見て人に問へば「八幡の宮」といふ。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間生活への思意が複雑明瞭になって来る度につれて、さながらしずかにさしのぼる月の運行に準じてあたりの山野が美しい光に溢れて来るように、人間の美しい精神の輝きとしての責任の感情もひろく、深く、大きいものとなってゆくのである。",
              "citation": {
                "source": "女の歴史",
                "author": "――そこにある判断と責任の姿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しずしずとさしのぼる旭は、霊峰富士の頂に、金色の光を放っているではないか。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕　風おちぬ　しづもる屋根に白白と　雪おもしろく月さしのぼる。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "青山という名のいわれは、夏山の峰の緑の木の間から、有明の月のさしのぼるすがたをいう。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしのぼる明るさや響や波動が内部に感じられるようでしょう？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に挙げた淀川両岸の絵本に出ている橋本の図を見ると月が男山のうしろの空にかかっていてをとこやま峰さしのぼる月かげにあらはれわたるよどの川舟という景樹の歌と、新月やいつをむかしの男山という其角の句とが添えてある。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "めざすは八塩の温泉を越えて秩父路へ、そして江戸へ、日輪のさしのぼる東へ、東へ。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の出る朝には、岡崎の草庵を二人の輦が出た、夕月のさしのぼる黄昏れには、二人の輦が、吉水から帰った。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな月のさしのぼるのを見ながら、「親不孝ばかりした」　驕慢児の眼にも、真実の涙が光った。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "綸言豈疑義あらんやと人はみな耀く目を以て答え、血のさしのぼる面をもって決意をあらわしていた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ久しぶりな身心地」　と、彼は浴後のからだを、縁の柱にもたせて、折ふしさしのぼる夏の夜の新月がこぼすソヨ風にしばし虚心を吹かせていた。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに陽がさしのぼる。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
