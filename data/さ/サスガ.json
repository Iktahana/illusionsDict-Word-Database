  {
    "uuid": "119a6617-8b0d-5bda-975a-932a149e6cf1",
    "entry": "刺刀",
    "reading": {
      "primary": "さすが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dagger",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私の聽覺は刺刀のやうに冴えた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の仕事がありませんと、もっとユックリ頂戴したかったのですが、残念です」　と止刺刀を刺した。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚き周章てゝ押破らむとする和尚の背後より跳りかゝり、左の肩より大袈裟がけに切りなぐり、板の間に引き倒ふして止刺刀を刺す。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等男女こそ覿面の因果応報、思ひ知らずやと云ひも終らず、馬十の脳天を唐竹割にし、奈美女の死骸を打重ねて止刺刀を刺し、その上より部屋の中の珍宝、奇具を片端より覆へして打重ねたるまゝ本堂の下を潜りて外に出で、血刀と衣服を前なる谷川に洗ひ浄めて、悠々と方丈に帰り来りぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしくこの機会に、ご城内において刺刀を加え、二度と中国へ帰ることなきように計らっていただきたい――　という旨が認められていたのである。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると、仇討というものは――　仇を討たんとして、怨霊のごとく、狙けまわしている間が、切実なる復讐の間で、斃して、仇の喉三寸に刺刀を貫くことは、仇の罪業をゆるし、同時に彼を救ってやることになる。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの悲しい宿命者も、さすがに日本に渡ってからは、多少の平和と幸福を経験した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆あなたのためです』と、さすがにヘルンも夫人に愚痴をこぼしている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした貞淑の妻にかしずかれて、日本での晩年を平和に暮した詩人ヘルンは、さすがに自らその寂しい幸福を自覚していた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、彼もさすがにてれくさそうにして眼を激しくしばたたかせながら、そうして、おしまいにはほとんど不機嫌になってしまって語って聞かせたこんなふうの手柄話を、あんまり信じる気になれないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに大隅君も心細くなった様子で、おい、この家でモオニングか何か貸してくれないものかね、と怒ったような口調で私に言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とれいの鷹揚ぶった態度で首肯いたが、さすがに、感佩したものがあった様子であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は出際にお客さんがありはしたし……明日立つたら……」　母が「甘い」とよく彼が言ふので、また言はれはしまいかと思つて、遠慮深さうにさう言つた時、彼はさすがに「甘い」とはいはれなかつた、却つて自分の方が「甘い」だつたのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏町によく見る風物で、何の奇もない市中風景の一角だが、そこを捉えて春夜の生ぬるく霞んだ空気を、市中の空一体に感触させる技巧は、さすがに妙手と言うべきである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに蕪村は、芭蕉俳句の本質を理解しており、その「風流」とその「情緒」とを、完全に表現し得たのであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅津の君も今は物もいはで彳めるを、玉枝の君と妾とは目見合せてをり、さすがに恐しからぬにもあらず。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがにワルキリーの国だと思われたりした。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "引上げてゲッチンゲンへ移るときはさすがに名残惜しい気がするのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽笛の吼ゆるごとき叫ぶがごとき深夜の寂寞と云う事知らぬ港ながら帆柱にゆらぐ星の光はさすがに静かなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道の並木の松さすがに昔の名残を止むれども道脇の茶店いたずらにあれて鳥毛挟箱の行列見るに由なく、僅かに馬士歌の哀れを止むるのみなるも改まる御代に余命つなぎ得し白髪の媼が囲炉裏のそばに水洟すゝりながら孫｜玄孫への語り草なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした茫漠たる冬田の中に一羽くらい鴫が居るのを見付け出すということは到底｜素人には出来ない芸当であったが、さすが専門家の要太の眼には、不思議なフィルター・スクリーンでもあるかのように、実に敏感に迅速にそれを発見するのである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くとさすがに都会の人の冷淡さと薄情さはサッパリしていて気持ちがいい。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにはさすがの両親も持て余したと云う。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めての他郷の空で、某病院の二階のゴワゴワする寝台に寝ながら窓の桜の朧月を見た時はさすがに心細いと思った。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蘭人はさすがに狼狽した。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに、實家のポストには投入しかねた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんの瘤が一夜のうちに消失してゐるのを見てとつて、さすがの聖人も、内心すこしく驚いたのであるが、しかし、父母の容貌に就いてとやかくの批評がましい事を言ふのは、聖人の道にそむくと思ひ、氣附かぬ振りして默つて別れたのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はじめて氣がついたのであるが、乙姫の背後には、めだかよりも、もつと小さい金色の魚が無數にかたまつてぴらぴら泳いで、乙姫が歩けばそのとほりに從つて移動し、そのさまは金色の雨がたえず乙姫の身邊に降り注いでゐるやうにも見えて、さすがにこの世のものならぬ貴い氣配が感ぜられた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの御想像は、まあドンヂヤンドンヂヤンの大騷ぎで、大きなお皿に鯛のさしみやら鮪のさしみ、赤い着物を着た娘つ子の手踊り、さうしてやたらに金銀珊瑚綾錦のたぐひが、――」「まさか、」と浦島もさすがに少し不愉快さうな顏になり、「私はそれほど卑俗な男ではありません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとしきり、そのやうに凄じくあばれて、さすがにもうだめだ、といふやうな疲れ切つた顏つきをして鎌を投げ捨て、「これ、見ろ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
