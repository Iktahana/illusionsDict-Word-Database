    "definitions": [
      {
        "index": 1,
        "gloss": "coldness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "実際あの頃の政府は、馬鹿な悪い親で、大ばくちの尻ぬぐいに女房子供の着物を持ち出し、箪笥はからっぽ、それでもまだ、ばくちをよさずにヤケ酒なんか飲んで女房子供は飢えと寒さにひいひい泣けば、うるさい！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、いかな人情も、寒さにはかなはない。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は東北生れの癖に、寒さに弱く、ごほん、ごほん變な咳さへ出て來て、たうとう下山を決意した。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖簾をかけた質屋の店も、既に戸を閉めてしまったので、万象｜寂として声なく、冬の寂寞とした闇の中で、孤独の寒さにふるえながら、小さな家々が眠っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "易水に根深流るる寒さ哉「根深」は葱の異名。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河豚汁の宿赤々と灯しけり　と、冬の街路に炉辺の燈灯を恋うる蕪村は、裏街を流れる下水を見て易水に根深流るる寒さかな　と、沁々として人生のうら寒いノスタルジアを思うのだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白晝はベツトに寢ねて寒さに悲しみ、夜は遲く起きて徘徊す。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れを厭ふ隣家寒夜に鍋を鳴らす葱買ひて枯木の中を帰りけり易水に根深流るる寒さかな古寺やほうろく棄つる藪の中月天心貧しき町を通りけり　此等の俳句に現はれる、抒情味の本質は何だらうか。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱田の八剣森陰より伏し拝みてセメント会社の煙突に白湾子と焼芋かじりながらこのあたりを徘徊せし当時を思い浮べては宮川行の夜船の寒さ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもあらばあれ、御三人、ちかごろの寒さにつけても、おからだお大切のこと、第一におねがひいたします。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になって空に星はあったが、電光が白い柱を、谷の中に投げては、夜営の人々をおどろかした、夜半には、秋雨が音なく注いだ、川縁に転がっている流材を焚火にして、寒さを凌いだ、針葉樹の切崖で囲んだ、瓶のように窄い谷底からは、天も谷川ほどの細さで流れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬の山と幾分か軽く視て、雪中の登山服装というほどの準備もしていなかったため、幾重の衣も徹されて、腹から股にかけ、薊で撫で廻されるような疼痛を感じ初めた、唇はピリッとして、亀裂するかと惑われ、その寒さにわなわなと骨髄から震動した。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "やり切れねえなあ、嬶は又腹を膨らかしやがったし、……」彼はウヨウヨしている子供のことや、又此寒さを目がけて産れる子供のことや、滅茶苦茶に産む嬶の事を考えると、全くがっかりしてしまった。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺なんざあ、三十年も銅や岩ばっかり噛って来たが、それでも歯が一本も欠けねえ」「岩は、俺たちの米のおまんまだ」　と云う程、慣れ切った仕事であったのに、それでもその一瞬間は、たとい夏であっても体のどこかに、寒さに似たものを感じるのであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は暮れ、雨さへも降り出したので、寒さは又増した。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "衰えた身体を九十度の暑さに持て余したのはつい数日前の事のように思われたのに、もう血液の不充分な手足の末端は、障子や火鉢くらいで防ぎ切れない寒さに凍えるような冬が来た。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そして只今、この大地は、四度目に来た冷い時期の、そのまた中に幾たてもこまかく冷温のきざみのある、ちょうどその二つ目の寒さの峠を下り降った根方の陽気の続いている時期にあるのでございます」　まめ桜はひと年の五月に一度咲き、同じその頃、三光鳥はこの裾野の麓へ来て鳴く。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈悲深い男は、家外の寒さを思い遣り乍ら室内のストーヴの火に暖を採り、椅子にふかふかと身を埋めて静に読書して居りました。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、家外の吹雪の中に一人のヴァイオリン弾きの老爺の乞食が立ち、やがてそれは寒さのために縮んで主人の室の硝子扉に貼りつくように体を寄せました。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さにいきはむねに白く凍りました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さや霜がまるで剣のようによだかを刺しました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氷山の流れる北のはての海で、小さな船に乗って、風や凍りつく潮水や、烈しい寒さとたたかって、たれかゞ一生けんめいはたらいてゐる。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「素足も、野暮な足袋ほしき、寒さもつらや」といいながら、江戸芸者は冬も素足を習とした。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の茎冬のさむさに、ほそき毛をもてつつまれし、草の茎をみよや、あをらみ茎はさみしげなれども、いちめんにうすき毛をもてつつまれし、草の茎をみよや。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに、みんな捜し出されて、ぞろぞろ西洋間へひきあげて、「おさむさんは、まだだよ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば露計りも愛矜なく、しかも身もちむさむさしたる出女の、油垢に汚れ朽ばみしゆふべの寝まきながら、発出でたる心地ぞする。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "さむさ、きびしく、あしを、いたむ。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――けれど、それもほんのわずかのあいだで、やがてカイは、すっかり、きもちがよくなって、もう身のまわりのさむさなど、いっこう気にならなくなりました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲルダはさむさに、ひどくやられていて、口をきくことができませんでした。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに、ゲルダは身をきるようなさむさをかんじました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
