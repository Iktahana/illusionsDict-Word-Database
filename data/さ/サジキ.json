    "definitions": [
      {
        "index": 1,
        "gloss": "dress circle (of a theatre)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
