    "definitions": [
      {
        "index": 1,
        "gloss": "to go upstream",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "満身の力を足に集注して大谷川の沿岸を遡る。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪速の潮なし遡ると、我が行かば何はばむ、長髄彦。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪速の潮なし遡ると、我が行かば何はばむ、長髓彦。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は南国の大きい水禽のように碧流を遡るのだ。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫紺の水禽は、遡る。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の問題を解く際、大事なのは過去へ遡る推理ができることだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "この能力こそ遡る推理、僕が分析推理と口にしたときに意図していることだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れの中には岩の姿が、遡るに伴れてあちこちに現れ、鶺鴒が飛び交はしてゐたりしたが、勾配が増して行くに随つて水勢は滝のやうな音をたてて、花々しい水煙りを挙げてゐた。",
              "citation": {
                "source": "繰舟で往く家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　尼瀧郡中第一と稱せられたる尼瀧へとて、あくる日、宿の主人を導者に頼みて、河内川を遡る。",
              "citation": {
                "source": "足柄の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "轉じて、路を左に取りて、一支溪を遡る。",
              "citation": {
                "source": "足柄の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日導者を雇ひ、一家擧つて阿武隈の本溪を遡る。",
              "citation": {
                "source": "阿武隈川水源の仙境",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "六鹽釜まで戻り、鹽涌橋を渡りて、鹿股川を遡る。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はまだ暮れ切れなかったが、水の光は漸次に褪めて、薄ら寒い夕靄の色が川下の方から遡るように拡がって来た。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊野川の谷を遡る時も、瀞八町の渓に船を泛べる時も、玉置山に大塔の宮の遺跡を偲ぶ時も、柔かな細い雨が常に私の旅の衣を沾して居た。",
              "citation": {
                "source": "春雨にぬれた旅",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒月の放胆｜無礙な画風は先人椿岳の衣鉢を承けたので、寒月の画を鑑賞するものは更に椿岳に遡るべきである。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は南国の大きい水禽のやうに碧流を遡るのだ。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫紺の水禽は遡る、遡る。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "船はいい加減のところまで下ったので、さらに方向を転じて上流の方へ遡ることになりました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は好加減のところまで下ったので、更に方向を転じて上流の方へ遡ることになりました。",
              "citation": {
                "source": "栗の花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古い／＼歴史を遡るには、こんな春の陽を浴びながらでは、呼べば直ちに応へる――といふ風には、何事も返答出来なからうぢやないか。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くこの植物の歴史に遡ると、大昔のヘブライ人が「デーン」と称して居たものと同じであつてヤコブの時代には非常に尊ばれた「創成」の歴史によると、リユーベンが野に於てこの植物を見つけ、其の母のリエーに与へた。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は少し以前に遡るが、私は帝国主義の感化を受けたと同時に、儒教の感化をも余程蒙った。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年ほど遡る、余がワルシャワに長期滞在したときのこと。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルデア人が最古の規則正しい天文観察を行ったのは耶蘇紀元前四〇〇〇年ないし五〇〇〇年前に遡るものと推測される。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは古代の大陸との交通を想像させるばかりでなく、もつと古い神話にまで遡るなら、天地創造の初發の光景にまで、人の空想を誘ふやうなところだ。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "この救世軍の仕事は、社会生活の根本へ遡ることをしないで、さうした現象に対して到るところの抱へ主に個人的な私刑を課するやうなものだつた。",
              "citation": {
                "source": "チビの魂",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "話はヨーロッパ大戦当時にまで遡る。",
              "citation": {
                "source": "くちなし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句の季題と称するものは俳諧の父なる連歌を通して歴史的にその来歴を追究して行くと枕草子や源氏物語から万葉の昔にまでもさかのぼることができるものが多数にあるようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの祖先を千年前にさかのぼると、今の自分というのはその昔の二千万人の血を受け継いでいる勘定だそうである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "建築や演劇でも、いずれもかなりな灰色の昔にまでその発達の径路をさかのぼる事ができるであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
