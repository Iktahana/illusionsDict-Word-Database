  {
    "uuid": "24d8ae33-c6b4-5588-9df2-c1c3fa757191",
    "entry": "歳代",
    "reading": {
      "primary": "さいだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
      ],
      "ctype": null,
