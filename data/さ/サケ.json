    },
    "definitions": [
      {
        "index": 1,
        "gloss": "alcohol",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蜂の尾と、ラム酒とに、世界は分解されしなり。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "草野君は酒を飲んで酔ふと殆んどそのたびに眠る。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒場であらうと屋台であらうと、その場に眠つてしまふ。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすやみ萩原朔太郎うすやみに光れる皿あり皿の底に蟲かくれ居て啜り鳴く晝はさびしく居間にひそみて鉛筆の心をけづるに疲れ夜は酒場の椅子にもたれて想ひにひたせる我が身の上こそ悲しけれ",
              "citation": {
                "source": "うすやみ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し淫酒のせゐである。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその淫酒は、氏の詩人としての孤独のせゐである。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝負事でも始めるか酒でも飲むしか仕方はない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "まづ、酒場へでも赴くといふことになる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚黙りつゞけるとしても、Ａは兎も角女給なり、従つて酒場の空気なりと交流が始まる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕と節野とは、教室で可なり口をきき合つたのであり、一緒に酒場なぞにも行つた男であるが、それでも彼の昼間通つてゐる日本大学の同級生が其の場に来合せたりすると、その方が主になるのである。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、月曜日には飲み過ごしの後、銀座の酒場で、乱暴を致し、その翌日は心佗しく、独りでゐるに絶えられず、而もその銀座の酒場に一緒に行つた、津濃といふ友人の所へどうも行つてゐたく、勝手なこととは承知しながら、出掛けて行つて、ぐづぐづしてゐた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処らでの高級酒場たる酒場の中はひつそりして、客がゐないので小さな窓はみんな開放つてある。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、俺のこの宿酔の頭では、一杯ひつかけてから行かなければ、とても相談にはのられやしないぞ」といふやうなわけで私はまたも其処に入り、どうせこんな所の日本酒はまづいからと思つたのでビールを註文。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒屋の御用聞きが現れて、何なりと御手伝ひしませうと云ふと、有難いが「あれを何処これを何処と、片附けるのは却々自分でないと分らないから」と、それをニコ／＼しながら、長々とやるのでその御用聞きはしまひには僕の顔を見て笑つてゐた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――「よき住居よき酒、香りよき煙草・紅茶。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事も米の飯に味噌汁、野菜の漬物や煮魚を食い、夜は二三合の日本酒を晩酌にたしなんだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日二三合の米の飯と、少しばかりの副食物と、二三合の日本酒とさえあれば、それで私の生活は充分であると、その訪問客に語っているヘルンは、実際に学者風の簡易生活をしていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐の時、ヘルンはいつも二三本の日本酒を盃で傾けながら、甚だ上機嫌に朗かだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が日本酒を飲むので、妻が酌をしてくれる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに丁度、酒に醉つた者が醉はない人々の中にゐて、意地惡く狂態を觀察されるやうな、一種不愉快な自覺が生ずる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ態度が、職業的に習性となつてるその小説家的態度が、ある冷酷な――酒に醉はない――觀察本能を、我々ちがつた世界の人間に印象させるにすぎないのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は土産に上等のシャンパン酒を置いて歸つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（今から考へると、このシャンパン酒は彼の生前の形見だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿の或る居酒屋で、商人たちの話を聞いて悲しくなつた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は妙に悲しくなつて、酒も飮まずに出てしまつた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒川弥太郎、酒井米子、花井蘭子などの芝居であった。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いノオトのちりを吹き払って、カントやヘエゲルやマルクスを、もういちど読み直して、それから、酒をつつしんで新しい本も買いたい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も記者が簡単に云へるものと考へてゐるとは思はないけれど、それを一般世間が可なりオーム返しに信じたりする風景は、なさけなく思はれるのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ十字疾行する街路のうへそのするどさに日輪もさけびくるめき群集をこえて落しきたるを感じいのり齒をくひしめ受難の日のひくれがたわれつひに蛇のごとくなりて絶息す。",
              "citation": {
                "source": "受難日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
