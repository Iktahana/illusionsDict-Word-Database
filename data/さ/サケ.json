[
  {
    "uuid": "16e465ee-71a9-5f75-9bc5-be632ce5403d",
    "entry": "酒",
    "reading": {
      "primary": "さけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
