        "examples": {
          "standard": [
            {
              "text": "幼い頃、いつも遊んでいた再従弟が、最近海外から帰ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "私の父の従妹の息子は、私の再従弟にあたります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "来週、再従弟の結婚式に参列するために、実家に帰省する予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私の再従弟に増田宗太部と云う男があります。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "密使の津田藤三郎信勝は、織田家の血につながる一人で、北畠信雄とは、再従弟にあたっている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
