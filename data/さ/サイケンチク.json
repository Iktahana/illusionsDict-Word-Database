        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私たちはかなり潤いと勇気とを取戻した頃、東側の喫茶店の再建築の足場の頂上に西日が射して路面はたそがれ、ネオンがちらほら煌めき出して来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時余輩は現存の法隆寺金堂・塔婆・中門等の古建築物に関して、該寺が天智天皇九年庚午四月三十日夜半の大火に一旦焼失し、その後いつの頃からか再建築に着手して、奈良朝の初め頃までにはほぼ完成を見るに至ったものであることの前提の下に、所謂非再建論に対して素人の無鉄砲なる駁論を発表したのであった。",
              "citation": {
                "source": "法隆寺再建非再建論の回顧",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃東京帝室博物館の再建築が大規模な計画で進められた。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再建築は、意外に早かった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
