  {
    "uuid": "d154b4ae-e62a-5ac9-9b0b-79412cdef0d1",
    "entry": "ＳＡＬ",
    "reading": {
      "primary": "サル",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
