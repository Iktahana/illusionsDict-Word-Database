  {
    "uuid": "361a8ee7-706c-5233-95b7-8e6a6505f43b",
    "entry": "申",
    "reading": {
      "primary": "さる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the Monkey (ninth sign of the Chinese zodiac)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今は多くを申しません。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "全集が弘く読まれる事を希望しつつ、広告の一助にもと一寸一言申述べます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "※ルモオルは却々しつかりした男で、彼女はその妻として実に申し分のない妻だつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "セザンヌが謂ふ「空と樹木」が、申すまでもなく都より豊富だからです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の書中の諸詩篇を、年代順に配列し直して読むならば、詩毎に、彼が駆廻つた短い道程、彼の旅行、彼の恋、彼の悲しい肉体を、熾な芸術家の申し分ない歎賞を以て、繰返す思ひがするのである。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨク来タト申シタイアナタノ可愛イ手紙、今朝参リマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "また時々は夫人に芝居見物をすすめて、『歌舞伎座に団十郎、たいそう面白いと新聞申します。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きょうは、あなたにおわびを申し上げます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おわびを申し上げます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうこれから先方へ、申込みに行こうと思っているのですが、あなたのところに大隅さんの最近の写真がありませんか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいま友人、大隅忠太郎君から、結納ならびに華燭の典の次第に就き電報を以て至急の依頼を受けましたが、ただちに貴門を訪れ御相談申上げたく、ついては御都合よろしき日時、ならびに貴門に至る道筋の略図などをお示し下さらば幸甚に存じます、と私も異様に緊張して書き送ってやったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、持参の結納の品々を白木の台に載せて差し出し、「このたびは、まことに、――」と礼法全書で習いおぼえた口上を述べ、「幾久しゅうお願い申上げます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「は、幾久しゅうお願い申上げます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方八方に、幾久しゅう、幾久しゅうとばかり言うのも、まがぬけているような気がして、こんどは、「末永くお願い申します。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいにくどうも、お相手を申上げる者がいないので。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸衣裳の用意も無い事はないのだが、それも一週間ほど前から申込んでいただかないと困るのです、という返事であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の新人諸君に対して、責任を感じましたので、一言申し開きを致します。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時彼は代議士の選挙運動事務所に学校の道場を使ふが好いかと校長に申出た。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こよや、お孃樣にお禮申し上げよ、とて輕く頭をおしやりたるもをかし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も縁側へ出て新しく水を入れた手水鉢で手洗い口すすいで霊前にぬかずき、わが名を申上げて拍手を打つと花瓶の檜扇の花びらが落ちて葡萄の上にとまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の大名それの君、すれちがいし船の早さに驚いてあれは何船と問い給えば御附きの人々かしこまりて、あれはちがい船なればかく早くこそと御答え申せば、さらばそのちがい船を造れと仰せられし勿体なさと父上の話に皆々またどっと笑う間に船は新田堤にかかる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の事は覚えていないがただ一事はっきり覚えているのは、この子が自分にときどき梟をやろうとか時鳥をやろうとかまた鷹をやろうとかいう申し出しをしたことである。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はどういう訳かその鷹がひどく欲しかったので、彼の申込みに応じて品は忘れたが彼の要求するものを引渡した。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度二十五周年記念号を出すので何か書くようとの懇篤な御すすめがありましたので何かと考えてみましたが右様の次第でありますからほとんど何も申上げる材料はないのでありますが、せっかくの御すすめでありますから、ただほんの少しばかり思い付いたことを申上げたいと思います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことは、貴誌の方々には珍しくも何でもないことと思いますが、ただ平生から思っていることでありますから、これだけのことを申上げて、御懇ろな御手紙に対する御返事に代えることと致したいと思います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "島木さんの事について何か書くようにとの御手紙を頂きましたので、考えてはみましたが、私は同氏から稀に御手紙は頂戴しておりましたものの、御目にかかったのは前後にただ一度だけ、それも宴会の席上でちょっと御挨拶をしたばかりでありまして、同氏の追憶と云っては別段に申上げるほどの資格も御座いません。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ何か強いて申上げようとすれば次のような事で御座います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな取止めもない事では雑誌に載せて頂くのは如何かと存じますが御返事までに申上げます、どうか悪しからず願います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは端書で「今朝ハ失敬、今日午後四時頃夏目来訪只今（九時）帰申候。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかすがにのぞみのみにて、拱きて、そがのぞみに圧倒さるる。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
