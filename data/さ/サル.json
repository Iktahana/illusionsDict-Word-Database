    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Surface Air Lifted (postal service)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――パラドクサルな人生よ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルオガセの垂れる針葉樹の間からも、同じように起る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "根曲り竹も、楊の根も、樅の肌も、はた長くしな垂れるサルオガセも、その柔嫩の手に、一旦は、撫でられぬものはない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば（サル）（ワ）（カー）（マ）（サ）（ムリ）（ダ）（シア）（アシユ）（ワ）（メ）（ダ）（シア）（ヤト）（フア）（ラム）。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんはユニヴァーサルに国境を超越した存在だと思う。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天界ホテルのサルーンへ這入ると、有名な五十に近い小柄な舞踏の師匠を取巻いて、コムミニストだというマルクス派の作家らしい男達がひどく酔って女達に愛想をつかされていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お六が南京刈の男と再びサルーンにでてきた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "広東人の用心深さが麻雀、私から一千｜弗をサルーンから投出してしまった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから孟買の港に船遊びする富限者船の燈が明滅するのを眺めながらサルーンから響いてくる音楽と歓談の声を聞いた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が夜会服に替えてサルーンに設けられた席に着くと、金モールの事務長の植民地通いの海員らしい頑丈な腕がさしのべられて関西｜訛のある社交的なバスが、ようこそ、Ｙさん。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルーンでは数人の英国人が別れの唄を合唱している。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから私は彼女を連れて、白首女の蝟集する裏町へ行って、チョップ・ハウスのサルーンで、一夜そこの踊子たちの仲間入を彼女にさせました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、班長のサル又や襦袢の洗濯をさせられたり、銃の使い方や、機関銃や、野砲の撃ち方を習う。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようよう馬丁の爺さんが、うやうやしげな腰つきで、新らしいサル又を持ってはいった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "莫大ナル出兵費ハ誰カラ出ルカ、諸君ガ一本ノ煙草ヲ喫ンデモ、半斤ノ砂糖ヲ使ッテモ、一足ノサル又ヲ買ッテモ、必ズ間接ニ徴収セラレル税金カラ出テイルノダ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "サル又と襦袢だけの者。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アンドレア・デル・サルトの、……」　ばかに大きな声で、突然そんなことを言い出した人があるので、笠井さんは、うしろを振りむいた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンドレア・デル・サルト。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンドレア・デル・サルトとは、再び相見ることは無い。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな名前が、なんの聯関もなく、ひょいひょい胸に浮んで、乱れて、泳ぎ、けれども笠井さんには、そのたくさんの名前の実体を一つとして、鮮明に思い出すことができず、いまは、アンドレア・デル・サルトと、アンリ・ベックの二つの名前の騒ぎではない。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンリ・ベックを知らなくても、アンドレア・デル・サルトを思い出せなくっても、笠井さんは、あの三角に尖った銀色の、そうしていま夕日を受けてバラ色に光っているあの山の名前だけは、知っている。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンリ・ベックだの、アンドレア・デル・サルトだの、生意気なこと言っていても、駒が岳を見て、やあ八が岳だ、荘厳ねなんて言ってやがる。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろのアンドレア・デル・サルトたちが降りてしまったので、笠井さんも、やれやれと肩の荷を下ろしたよう、下駄を脱いで、両脚をぐいとのばし、前の客席に足を載せかけ、ふところから一巻の書物を取り出した。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "登場者は活動写真の俳優として知られているヘンリー・ウォルサルやフランクリン・ホールの人たちで、それに大学の学生たちが加わっているのです。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のおどろいたのは、主人公の松王を勤めたヘンリー・ウォルサルの立派なことです。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の文学は結局生活の総決算の文学であり、人間を描いても、結局心境のありのままを描くだけですが、ジャン・ポール・サルトルのこの「水いらず」という小説は人間の可能性を描いております。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、サルトルの提唱しているエグジスタンシアリスム――つまり実存主義は、戦後の混乱と不安の中にあるフランスの一つの思想的必然であります。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような文学こそ、新しい近代小説への道に努力せんとしている僕らのジェネレーションを刺戟するもので、よしんば僕らがもっている日本的な文学教養は志賀さんや秋声の文学の方をサルトルよりも気品高しとするにせよ、僕はやはりサルトルをみなさんにすすめたい。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
