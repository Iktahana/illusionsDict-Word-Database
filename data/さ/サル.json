[
  {
    "uuid": "eda6099d-d070-509d-99df-4c3864e095aa",
    "entry": "猿",
    "reading": {
      "primary": "さる",
      "alternatives": [
        "サル"
      ],
      "is_heteronym": false
    },
    "grammar": {
