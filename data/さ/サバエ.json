    "definitions": [
      {
        "index": 1,
        "gloss": "flies swarming at the beginning of summer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "肉親は五月蠅い、と思はず、何時もながら痛感した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "開けさせたくはないが開けて貰へば少しでも五月蠅さが減るだらう。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺の感傷が俺を五月蠅くするのだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は「五月蠅」と書いて「うるさい」と読み、昼寝の顔をせせるいたずらもの、ないしは臭いものへの道しるべと考えられていた。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも五月蠅そうにそれをやるのである。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは吉田が「そこまで言ってしまってはまたどんな五月蠅いことになるかもしれない」ということを急に自覚したのにもよるが、それと同時にそこまで退引きのならぬように追求して来る執拗な女の態度が急に重苦しい圧迫を吉田に感じさせたからだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は五月蠅と書いてうるさいと読み昼寝の顔をせせるいたずらものないしは臭いものへの道しるべと考えられていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼さんは世間から名士扱いにされるのを五月蠅がって、宿がえ蓮月と云われるほど宿がえを致した位だからその名士見物の素振りをちらっとも見せてはならんぞ。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何が、この頃の旱で、やれ雨が欲しい、それ水をくれろ、と百姓どもが、姫様のお住居、夜叉ヶ池のほとりへ五月蠅きほどに集って来せる。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目に付くと五月蠅からね」　と何気なく云い棄てて露っぽい小径の笹の間を蹴分け蹴分け急いで行った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり五月蠅ので或るとき、「……叔父さん。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の安心が左様手易くは出来ぬわい、と五月蠅云ふ。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "恁※日にお前みたいな垢臭い婆さんが行くと、如来様も昼寝が出来ねえで五月蠅がるだあ。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "山に住み世に離るとも、全く世を厭ふにあらず、五月蠅やと、切に思へど、人来ねばたづきも知らず、妻と我、二人居れども、かくてあれども、時をりはただ寂しくて、眼を見合せぬ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "山に住み世に離るとも、全く世を厭ふにあらず、五月蠅やと切に思へど、人来ねばたづきも知らず、妻と我、二人居れども、かくてあれども、時をりはただ寂しくて眼を見合せぬ。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "又野の処へ改めて話を聞きに来る者もチョイチョイ出て来たが、又野は五月蠅がって何も話さなかった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、私の袖を引きますので五月蠅しい奴と思うて振向きますと、大惣の奴、熱で黒くなった舌を甜めずりまわしております。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこでもええから貴様の好きな聯隊に入れてやる」　中学を出て福岡の市役所に出頭し、徴兵検査を早く受けたいと願ったら、吏員から五月蠅がられたので、母等と共に上京して鎌倉に居住し、麻布聯隊区に籍を移し、たしか乙種で不合格となったのを志願して無理にパスした。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、その翌日から三日も続けて、上本町六丁目から小橋西之町への舗道を豹一に尾行られると、半分は五月蠅いという気持から、「何か用ですの」いきなり振り向いて、きめつけてやる気になった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　清次郎はこう五月蠅そうに言い捨てて行ってしまった。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "醫者は一｜應見なければ分らぬといつて五月蠅い勘次に返辭しなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月蠅がつて邪險に叱つて見ても與吉は甘えて笑つて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「癖になつから、みつしら懲りらかした方がえゝ、俺方は畑が五月蠅くつて本當に仕やうねえ」「見せしめに行つ時にや、こつぴどく行んなくつちやえかねえよ」「村落の内ようく見せえすりや直に分らな、蜀黍なんぞ何處へ隱せるもんぢやねえ」抔と近い畑同士は呶鳴り合つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも僅に桑の木へ絡んだ晝顏の花に一｜杯の量を注いでは慌てゝ疾驅しつゝからりと熱した空が拭はれることも有るのであるが、驟雨は後から後からと驅つて來るので曉の白まぬうちから麥を搗いて庭一｜杯に筵を干た百姓をどうかすると五月蠅く苛めた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとつゝあ聾だから聞えねんだ、おとつゝあ呉ろうつと俺れ見てえに呶鳴つて見ろ、そんでなけれ耳引張てやれ」「そんだつて厭だあ俺ら、おとつゝあに打つ飛ばされつから」「えゝから行けはあ、汝等見てえな餓鬼奴等ごや／＼來ちや五月蠅くつて仕やうねえから」與吉は悄々と立つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯平は暇を惜しがる勘次が唐鍬を執て出た時朝餉の後の口を五月蠅く鳴らしながら火鉢の前にどつかりと坐つて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻から茶碗でも茶菓子でも一杯になつて甞めずりまはつて居た蠅が五月蠅く顏をはひまはる。",
              "citation": {
                "source": "旅の日記",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の軍醫等は五月蠅がつて碌々取り合はぬので遂僕の處へばかり來るやうになつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の卷煙草の灰が自分の顏へ五月蠅くかゝる。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに世間はかく安楽でいつまでも続かず、一日婦女どもが食物を摺り調える処へ上帝来り立ち留まって観るを五月蠅がり、あっちへ行けといえど去らず、婦女ども怒って擂木で上帝を打ったから、上帝倉皇天に登り復と地上へ降らず、世は永く精物に司配さる。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
