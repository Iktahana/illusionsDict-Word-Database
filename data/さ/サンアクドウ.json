    "definitions": [
      {
        "index": 1,
        "gloss": "the world of hungry spirits and the world of animals",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
