        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "虫っけらの眼から贅沢水を流す様な事をして居やがって、憚りながら口幅ってえ事が云える義理かい。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯山と枯野と、ところどころの沢水と、いまだに深くはぬくもらぬが、なにかに酔はせるものがある。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸侯の別業で、一器、六方石の、その光沢水晶にして、天然に簫の形をしたのがある。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢水に、鴨ぞ啼くなる。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼のなく声する　夜の窓※春水満四沢道の辺の桑の立ち木も、沢水の中になりたり。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪溶けの沢水の中には、のそのそと歩きまわる※蛄。",
              "citation": {
                "source": "葡萄蔓の束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "座句沢　在砺砥沢北而隔山沢水西流合片品川。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震つて春の沢水｜溢れけり　　　　青々　地震のために急に水が吹き出したり、また水が涸れたりすることは随分よくあることであるが、しかしこの春水は必ずしもその地震が原因というわけでもあるまい。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その乱岩の間にところどころ、白煙をあげて硫気を吐き、沢水は怪しく白黄濁して、地獄めいた凄気を漂わせている。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢水は、むろん凍結して、懸け樋に水は通わないから、万事氷を溶かして弁じるのだ。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
