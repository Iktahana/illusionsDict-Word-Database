          "standard": [
            {
              "text": "「さしあたって」は、このプロジェクトを成功させることに集中します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さしあたって」の目標は、期日までに全てのタスクを完了することだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さしあたって」の懸念事項は、予算の制約についてです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その足跡は里犬よりも大きく、糞は毛と骨で――雨晒しになったのを農夫が熱の薬に用いる。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「埋もれた青春」、その一つ一つに特別な感じと思いをうける、私にはそんなにはなされないほどのものではないけれ共一番始めにある埋れた春の幼い二人の子供の気持には落椿のはかなさといぬはりこの色の様に平凡なものでありながらはなれがたいなつかしみをうけた。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            }
          ]
