        "examples": {
          "standard": [
            {
              "text": "学園祭の準備をめぐって、実行委員、生徒会、教師の三者対立が起こった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "選挙戦では、三者対立の構図が鮮明になり、激しい論戦が繰り広げられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "複雑な利害が絡み合い、三者対立の解決は困難を極めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それからミドル級の勝ち抜き戦になり、終りのヘビー級となると一対一か、せいぜい三者対立くらいで勝敗を争うことになる。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
