    "definitions": [
      {
        "index": 1,
        "gloss": "soda pop (esp. fruit-flavored)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
