        "examples": {
          "standard": [
            {
              "text": "最上級生として、学校行事の企画運営に積極的に参加しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "卒業を間近に控えた最上級生たちは、感謝の気持ちを込めて校長先生に挨拶をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "私たちのクラスの最上級生は、後輩たちの模範となるような行動を心がけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "割合によい成績で進級し最上級生になった私は、初めて一しょの級になった首席を通している女の子に好意を持ちはじめた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は最上級生になり、緊張感を新しくした。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子が日本にいたころの和一郎は、美術学校の最上級生だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最上級生全部に起立して眞直に壁の方を向けと云つて下さい。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を命じられたか合點が行くと、最上級生はおとなしく從つた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は五年生を受持ったが、これが分校の最上級生で、男女混合の七十名ぐらいの組であるが、どうも本校で手に負えないのを分校へ押しつけていたのではないかと思う。",
              "citation": {
                "source": "風と光と二十の私と",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
