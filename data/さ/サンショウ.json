  {
    "uuid": "1c5ea044-5190-58e1-8513-b6c6d725395f",
    "entry": "三省",
    "reading": {
      "primary": "さんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "three ministries (under the ritsuryō system: Ministries of Civil Services, Health and War)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "再思三省すべきであらう。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者は、土地も、家も、家畜も売り払って、東三省へ移住した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうにこれは、君の三思三省すべきところだ。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、この事たる、究極よりこれを見るに「黄人の相｜食み相闘ふもの」に他ならず、「たとひ我が日本甘んじて白人の牛後となり、二三省の地を割き二三万方里の土地四五千万の人民を得るも、何ぞ黄人の衰滅に補あらん。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年十二月、渋柿）曙町より（十二）　今日神田の三省堂へ立ち寄って、ひやかしているうちに、「性的犯罪考」という本が見当たったので、気まぐれの好奇心から一本を求めた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子爵は奥さんに三省堂の世界地図を一枚買って渡して、電報や手紙が来る度に、鉛筆で点を打ったり線を引いたりして、秀麿はここに著いたのだ、ここを通っているのだと言って聞かせた。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "であれば、先生の門下に在って、才器は必ずしも人に勝ってはいないが、儒教の系統を正しく継いだことで後人に尊崇されている曾子のような人も、「吾、日に吾が身を三省する、人の為に謀って忠ならざるか、朋友と交わって信あらざるか、伝えて習わざるか」『論語（学而四）』と日々｜徳の精進に実工夫を洩らされている。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾子の三省の一条に、「伝えて習わざるか」とあるのは、先生が「学びて時に之を習う、また説ばしからず乎」と言われたのと表裏をなしている。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三省の言からも曽子の学問の様子が覗い知られるが、第一に「人の為に謀って忠ならざるか」とある。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は歳暮大売出しと大きな門をつくった内の三省堂に本をかいによった。",
              "citation": {
                "source": "心配",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢は正直だ、意識しない自分をさらけだして見せてくれる、再思三省。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "デカルトは「第三省察」において神の存在を論じた。",
              "citation": {
                "source": "デカルト哲学について",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞には三千五百円の句集ということが話題にされているけれども、この間の晩、三省堂の店頭に据えられたマイクは、あんなに書籍払底を訴えていた。",
              "citation": {
                "source": "豪華版",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖北・安徽・江蘇三省の地は、その大部は江北に在るけれども、勿論南支那の範圍に屬すべきものである。",
              "citation": {
                "source": "晉室の南渡と南方の開發",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "但この三省の北部殊に淮北の地は、むしろ北支那の色彩を帶びて居る事實を否定することが出來ぬ。",
              "citation": {
                "source": "晉室の南渡と南方の開發",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "東漢時代から兩晉時代にかけて、天子を稱して國家ともいふ（『資治通鑑』晉紀十七、咸康三年の條の、元初の胡三省の註參看）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "元初の胡三省は、自唐太宗後。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三省堂の喫茶部へ入った。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三省堂で語学の本など買ったのですが、どうかしら。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田では三省堂を出てから夜店の古本を見て十銭でエジソン伝など掘出し、あすこの不二家へよってコーヒーとお菓子をたべ、バスで高田の馬場までかえりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後から本を買いに出かけ中西屋で Wisdom and Destiny と Longfellow's Poem works ヲ買イ、三省堂で The story of the world と「徒然草」の講義を買い文房堂からノートと鉛筆を買って来る。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遼東」の古意は「遼東文献徴略」の著者の研究に拠ると、後世のやうに狭いもので無く、渝関（山海関）以東、今の東三省全部と熱河東部に亘る広大な地域の総称であつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "張作霖が近年阿片の栽培を東三省の農民に強制し、それから重税を搾取してゐるのも同じ理由からである。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟は張作霖の東三省統一の犠牲となつて民国八年（大正七年）に身を亡したので、この記念塔の除幕式は行はれずにしまつた相である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後、三省堂の外来語辞典が出たのを見ると、鳥居龍蔵氏が、はたの語原を、蒙古のはた即幣束に関係あるものとして居られた。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "淮河は、河南、安徽、江蘇の三省にまたがる大河であって、二千年間に約千回もの大※濫を起している。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は貴殿の容姿に就ては明らさまの批判を避けたい意向であるが、三思三省せられんことを希望する。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "論ずるだけがヤボであり、さういふ文学以前の問題にかゝづらつて一席弁じるサルトル先生も情ない先生だが、作家に向ひ弁明などと注文せられる向きの編輯者諸先生は先づ以て三思三省せらるべし。",
              "citation": {
                "source": "余はベンメイす",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三省堂で、コンサイズ和英二冊買って光子さん夫婦に送る。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の衆議院議長中島信行といふ人を始め、江口三省、直原守次郎などいふ急進的自由主義者が屡※來訪し、後には信州飯田事件の首謀者櫻井平吉氏も同居者となり、ほとんど毎晩、社會問題の議論が沸騰しました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
