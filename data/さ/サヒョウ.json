        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "◯今全巻四十二章を左表の如く分類することが出来る。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに英、仏、独、米の四個国について富の分配のありさまを見るに、実に左表のごとくである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "左表を參考されたい。",
              "citation": {
                "source": "支那史上の偉人（孔子と孔明）",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "明代の『圖書編』や『續文獻通考』に據ると、天下の總戸數に對する南支那の戸數は、略左表の如き割合で増加して居る。",
              "citation": {
                "source": "歴史上より觀たる南支那の開發",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち左表に揚ぐる計算はやや精細を得たるものなり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もし各国万般の製造事業のありさまを見んと欲せば左表のごとし。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "今試みに文化民族の成文神話に就て、其成分を分析するときは、略左表に示す如きものを得可し。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天然現象を説明するものの中にも亦た、多くの区別あり、即ち左表の如し。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夢の種類を分析するに、左表のごとき結果を得たり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに、その夢を夢中見るところの場所について分析するに、左表のごとき結果を得るなり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、これを時間について分析するときは、左表のごとき結果を得るなり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、英国中にあるものを統計するに左表のごとし。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、西洋にて東洋学研究の流行せる景況の一斑を示さんため、その冊子中より右に関する書類の部数を挙ぐること、左表のごとし。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "左表：いとこ同士結婚で生まれた子供たちの家族（観察者氏名：アルカプトン尿者の数）。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
