        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は三悪趣に苦しむ衆生を救済するため、修行に励んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "三悪趣から解脱するには、善行を積むことが不可欠だと教えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の夢の中には、三悪趣の恐ろしい光景が何度も現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、口で「、十方世界諸仏、世界一切の菩薩、智火に不祥を焼き、浄瑠璃の光を放ち、諸悪鬼神を摧滅して、一切の三悪趣苦悩を除き、六道四生、皆富貴延命を獲させ給え、得させ給え」　と、誦した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
