[
  {
    "uuid": "ac54b3b9-8d92-55af-8b3e-a592772dff95",
    "entry": "幸先",
    "reading": {
      "primary": "さいさき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
