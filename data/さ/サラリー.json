        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "サラリーメンの洪水のために死骸のような建物の堰が破られて、空にそびえる高楼の窓が花のようにひらくと、女事務員の青と赤の色彩が花粉の媒介の役目をした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍で飲んでいたサラリーマン風の男と非常な親友になって、スッカリ肝胆照してしまった。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、客は、「そや、昔の友達や」　――と知られて女の手前はばかるようなそんな安サラリーマンではない。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の上に置かれた帽子は、安サラリーマンのカンカン帽以上に豪華にも見えなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六人取り交ぜたブルジョアの坊ちゃんで、若いサラリーマンや大学生達だとの事、それから藤棚の方はと聞いた時、「麻川荘之介さん、あの文士の。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等には独身もののサラリーマンらしい可憐な経済観念があった。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒロポン代だけでサラリーが……」　飛んじゃいますわと、こぼしていたが、到頭逃げてしまったらしい。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ私の背後に立止まって凝っと覗いているサラリーマンらしい中年紳士の肩越しに、銀座の往来の断面が三分の二ほど映っている。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地を離れ、都会に定住し、柔弱な側用人や腰元などに取りまかれてゐたのでは、知行取りで、今の高級サラリーマンと同じで、もう武士ではないのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "安二郎に渡す必要がなければ、おめおめ日割勘定のサラリーを貰いに行かないだろうと、思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計へ出頭して、先月の中頃に退社したものだが、半月だけはたしかに出勤した故、もしや規程でその日割勘定でもらえることになっているのだったら、いま受け取りたいのだがと、半泣きの顔で早口に言うと、会計係は名前をきいて、「あ、君のサラリーまだだったね。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛利豹一殿と殿をつけて表に書いてあるのを、なにか不思議なくらい鄭重に扱われた気持で気持よく見ながら、玄関を出てから、封を切ってみると、一月分のサラリーがそっくりそのままはいっていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小店員は自転車を止め、若きサラリーマンは靴ひもの解けたのも忘れ、魂は飛行機に乗って青山の空をかけっているのであった。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし東京に呼び戻されると、所詮サラリーマンとの思いがわいて、さっさと辞表を出してしまいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰宅を急ぐサラリーマンが、慶一に突き当たった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生風でも、サラリーマン風でも、成るべくその家の人々が案内を知らぬ方面で、その令嬢が好きそうな風采をして接近する。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりこの妻を連れたサラリーマンは四五日前忘年会の二次会で、一友と語り合って、僕達は到頭男になったね、と頻りに男らしい感慨に耽ったものだが、今夜も彼は自分が男であることを自覚してそれはとてもいい気持になってゐた。",
              "citation": {
                "source": "飯田橋駅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのサラリーなども、女学校の教諭時代に比べると、みじめなものだった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ夕刻のこととて、ハマダ撞球場は学生やサラリーマンで七台ある球台が、どれもこれも一杯だった。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "難儀はあつても、都會のサラリーマンよりは厭な思ひせずと、食うて行くことは出來よう。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "專門學校を出たての若いサラリーマンといふところであらう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山本有三氏は、この根幹をなす生涯のテーマから出立して、更にその人間としてなすべきことの内容と経過とその帰結とを小工場主、小学校、中学校、大学等の教師、下級中級サラリーマン、勤労婦人の日常葛藤の裡に究求し描き出そうとする。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後、社会の事情の変遷につれ、中間層、下級サラリーマン、インテリゲンツィアの生活条件の変化によって大衆という内容はひろくなった。",
              "citation": {
                "source": "今日の文学に求められているヒューマニズム",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿泊人はいずれも朝の勤めの早いサラリーマンなので、こんな遅くに電話のかかって来るはずもなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラリーマンの妻としての暮しにおいても、サラリー・ウーマンとしての暮しにおいても。",
              "citation": {
                "source": "現実の道",
                "author": "――女も仕事をもて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "互にまともな結婚もなかなかできない下級サラリーマンとウーマンとが、自分たちのゆがめられしぼられている小さい恋の花束を眺めて、野暮に憤る代りに、肩をすくめ、目交ぜし合い、やがて口笛を吹いてゆくような新らしげな受動性。",
              "citation": {
                "source": "新しい一夫一婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いサラリーマンである従弟の話の中に、この頃の若い女のひとで結婚はしたくないが子供だけは欲しいって云うのが随分あるねということがあった。",
              "citation": {
                "source": "未開の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草・砂糖・織物すべてが高価になり、若いサラリーマンの日常は些細なところまで逼迫してきている。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地道な若い下級サラリーマンや、職業婦人の間に、今日はこんな世の中だからよい恋愛や結婚は望んでも駄目だという一種の絶望に似た気分があるのも事実だと思う。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
