    "definitions": [
      {
        "index": 1,
        "gloss": "gold dust",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小初は砂金のように濃かく汗の玉の吹き出た薫の上半身へ頭を靠れ薫の手をとった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ゼーヤから掘りだしてきた砂金を代りにポケットへしのばして、また、河を渡り、国外へ持ち去った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "快活らしい元気な表情の中には、ただ、ゼーヤから拾ってきた砂金を掴み取り、肌の白い豊満な肉体を持っているバルシニヤを快楽する、そのことばかりでいっぱいだった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "没薬、丹、朱、香、玉、砂金の類ではない。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま此処に来てこの経を視るに、毛越寺の彼はあたかも砂金を捧ぐるが如く、これは月光を仰ぐようであった。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ　烈日の丘に燃ゆる瞳孔ありおん手に魚あれども泳がせたまはず聖者めんめんと涙をたれはてしなき砂金の道を踏み行きたまふ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、まぼろしのかもめどり、渚はとほく砂丘はさんらん、十字の上に耶蘇はさんらん、女の胴は砂金に研がれ、その陰部もさんらん、光り光りてあきらかに眞珠をはらむ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の寺のなかでも古いこの寺の鐘は、水へ砂金を流し込むやうに大気の底を底をと慕つて響いた。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、全部忘れてしまっても、その勉強の訓練の底に一つかみの砂金が残っているものだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの村の籬落はまばらな灯の点在だけになり、大梁と思われる地平線の一抹の黒みの中には砂金のような灯が混っている。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、きくと、実は砂金の鉱区が売物に出ているという。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして砂金の鉱区を買ったが……。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "写していて、よくもまあ、お前という人間のいやらしさにうってつけの文章だと、あきれるくらいだが、さて、そうやって砂金の鉱区を買ったものの、ここでも未だ運は向かなかったらしい。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いうちに軍事探偵を廃業して、ここに砂金を採りに行くのだと云って、満洲の地図に赤い印を附けてみせたものである。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく砂金採掘の用意をして渡満した父は、哈爾賓の市外で、露人に誘拐されて満洲里に連れて行かれる途中、列車の中で射殺されて鉄橋の下に投棄てられていたという事実が報道されている。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして私たち兄弟に、僅か千円ばかりの葬式の費用を投与えたきり、砂金の採掘権を支那人に売渡して、印度に行ってしまった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その頃まで北海道の砂金といったらカリフォルニヤの向う張る勢いで、しかも夕張川の上流の各支流の源泉附近は到る処、砂金ならざるなしという評判で、全国の成金病患者がワンワンと押しかけていたものだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところが不思議な事に、その砂金が、本流の夕張川の下流に在る名前は忘れたが一つの大きな滝を段階として、その下流には一粒の砂金も見当らない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまるところ、その滝壺の底にはイザナギ、イザナミの尊以来、沈澱している砂金が、計算してみると四百億円ぐらいは在るらしい……というのだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりその滝の横に運河を掘ってその滝の上流を堰き止めて、滝壺の水を掻き干して、底の方に溜まっている四百億円の砂金をスコップで貨車へ積み込もうという曠古の大事業だ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃雇っていた抱え俥の車夫に、もしこの事業に成功した暁には、貴様に米俵一杯の砂金を遣ると云ったもんだから、真に受けた俥夫の奴め真夏の炎天をキチガイのように走りまわったものだが、一方にこの話が玄洋社の連中に伝わった時の壮士連の活気付きようと来たら、それこそ前代未聞の壮観だったね。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸福感というものは、悲哀の川の底に沈んで、幽かに光っている砂金のようなものではなかろうか。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手といつたら猫の手でも借りたい砂金掘りだに――。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原に着いたら餓鬼共の、頭、河に突込んで腹、さけるほど水のませろ、ヘド吐いたら、砂金飛び出すべよ。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "『近江輿地誌略』三九、秀郷竜宮将来の十宝の内に、砂金袋とあるもこの属だろう。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "豐年祭のころに、砂金の波の光を漂はせて、豪勢な景氣だつた日光は今どこに隱れてゐる。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「温泉へ五町、砂金採取所へ八町」と札が目についた。",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "イルクウツク――砂金。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "こころの中にひろがっている「空虚」が画面を支配し、近代的都会、機械時代、集団主義的意識に対して、個人と個性を守らんとする意識が、はるかに時代にさきんじて、空虚と畏れをもって脅えているのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国が、百五十年さきんじ、フランスが五十年さきんじて、ドイツを北海と地中海に残して大西洋の利潤を享楽したのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
