        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昨年、山陰地方で行われたという、××君の手紙である。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれの流行して來たのは東京あたりでもまだ昨日のことのやうにしか思はれないのに、今日はもうこんな勢で山陰地方にまでゆきわたつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陰地方に名高い出雲浦を一※りして見るといふ樂しみもあつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陰地方を旅するものが、陸から隱岐の島を望まうとするのも、その燈臺附近の位置からであらう。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鳥城はこの山陰地方で天守閣を保存する唯一の城址である。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かかう大きなものをつかんで、非常な力でそれを壓搾してあるやうに見えますが――」　かうした大谷君の言葉を聞くにつけても、私は行く先で逢ふ山陰地方の人達が、それ／″＼住慣れた土地にあるものをよく見てゐるのに感心した。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はその夜の空氣に包まれながら、山陰地方から離れて行つた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "小泉八雲といふ先生は、この人も寢ることにかけてはわれらの友達仲間であつたと見え、いつぞや山陰地方へ旅し先生の遺跡を訪ねた折に、その故家に先生遺愛の古い枕を見出した。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾て山陰地方への旅をして、城崎に近い瀬戸の日和山からも、香住の岡見公園からも、浦富、出雲浦等の海岸からも、あるひは石見の高角山からも日本海を望み見た。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、それで安心して道行をきめ込み、一旦、山陰地方の乗合会社に身を潜めたが、二千円の金を費い果すと大胆にも、昨、昭和八年の夏、又もや東京へ舞い戻って来て、小梅に同棲し、姦夫の戸若は三徳材木店専属のトラックの運転手となっていた。",
              "citation": {
                "source": "衝突心理",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "広幅ものの輸出羽二重や人絹を織っていたこの山陰地方の町の機屋は、直接アメリカの恐慌の打撃を蒙ったのであった。",
              "citation": {
                "source": "だるまや百貨店",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海北道主貴は、宗像三女神の総称となっているが、同じ神と考えられてきた丹波の比沼神に仕える丹波道主貴は、東山陰地方最高の巫女なる神人の家のかばねであった。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "海北道主貴は、宗像三女神の総称となつてゐるが、同じ神と考へられて来た丹波の比沼神に仕へる丹波道主貴は、東山陰地方最高の巫女なる神人の家のかばねであつた。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳田君の御説はそれから見れば大いに進んだもので、本誌七巻三号の倉光君の報告せられた「蒲とクグ」（五九頁）によると、今でも山陰地方では、山子・木挽・石屋等に限って、叺様の藁縄製の袋を携帯しているが、旧皮屋部落の青年が、それを蒲で作ったものを持っておったとあるのも思い合される。",
              "citation": {
                "source": "くぐつ名義考",
                "author": "古代社会組織の研究",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも後世には山間にも耕地が開けて、住民は農業片手間に炭を焼くという風の地方が多いが、それでもなお山陰地方では、今も炭焼を「山子」と云い、山村の農民が山へ炭を焼きに行く事を、「山子に行く」などという地方もある。",
              "citation": {
                "source": "炭焼長者譚",
                "author": "系図の仮托と民族の改良",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　間人とハチヤ　山陰地方にはかつてハチまたはハチヤと呼ばれた一種の階級の民衆があった。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "産所すなわち山陰地方でいうハチヤ或いはハチと同類で、越中でトウナイというのもつまりは「十無い」で、「八」ということを避けた隠し言葉でありましょう。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陰地方に鉢屋と呼ばれたものもやはりハチで、土師の義であると解せられる。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然もわが篠山は、近畿と山陰地方とに跨がる、丹波、丹後、但馬の三丹地方中での、盆地に拓けた都市、旧城下町で、京都が王城であった頃の、王城に近い都市でさえあった。",
              "citation": {
                "source": "丹波篠山",
                "author": "平野零児",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち山陰地方の○○○という小さな町の娘さんから手紙で、ぜひ店において商売を見習わしてくれと懇願して来ました。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊の明り　秋の亥の子とは別に、山陰地方から北陸、東北にかけて、亥の月でも何でもない三月ごろに春亥の子というのがある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツツミジヒラ　山陰地方で弘く用ゐられる正月肴の一つ。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツツミジイラ　山陰地方で弘く用いられる正月肴の一つ。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふゆの両親が死絶えたので、親類ともいつか疎遠になった小関の一家は、暫く山陰地方にある国へも帰らなかった。",
              "citation": {
                "source": "午市",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "複雑ないまの情勢下にあっては、ここの開戦はまた忽ち播州にもひびき、大坂表にも動揺を与え、なお丹波、山陰地方にまで、一波万波を生ずるの様相をあらわして来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これからは鳥取も、羽柴筑前守様の治下になる」　と聞えると、驚かれるばかり、この城下の様相は一変して、山陰地方の離民を吸収した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陰地方は一帯に、この食事をハシマと謂って通ずる。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　そう考えても許さるるかと思う傍証の一つは、これも山陰地方でならば得られる資料で、出雲大社を始めとして、遠方の神々へお詣りに行った者が、居村に還って来てから執り行う儀式に、ドウブルイという名が今でも関西には広く分布している。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "中部地方から東の各県、北陸一帯、または山陰地方も但馬から西の方では、この晩だけは二十三夜とは言わずに、大師講といいまたはその大師の昔話によって、跡隠しとか擂木隠しとか、その他いろいろの珍しい名を以て呼んでいる。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陰地方に行くと是がクマになり、正月｜忌詞のイネツムを、大グマを積むなどという例もある。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
