[
  {
    "uuid": "95fce71c-46b5-5aa5-ad02-6166c2f318b8",
    "entry": "騒がす",
    "reading": {
      "primary": "さわがす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
