  {
    "uuid": "12d0f0b7-c518-5bdd-a524-d252d316054d",
    "entry": "さる事ながら",
    "reading": {
      "primary": "さることながら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
