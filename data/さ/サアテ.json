        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さあて弱った」　大山は、頭の中が熱くなった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあてね」と天草時行、皮肉に顔をゆがめたが、「お高く買ってくださるはよい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さあてところでお京様」　こういうと富士見の将右衛門、駕籠に乗っているお京の方へ、ヒョイと顔を振り向けた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年はどうやら事なくてすんだが、さあて、今年はどうだやら。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さあて、象がもし卵で生まれるとしたら、その卵の殻はよっぽど分厚に出来ていることじゃろうな。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "叩鉦の音が揃って、声自慢の男女が集ると、有転輪廻の車より、三毒五慾の糸をだし生死のかせわのひまいらぬさあてもとうとき、おんあぼきゃ、べいろしゃの、なかもふだらに、はんどく、じんばら、はらはりたや、うん――じんばら、はらはりたや、うんが面白くて、いい気になって高音にうたった。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるものは静かに水色のはげちょろけたルバーシカのポケットから粉煙草を出し、膝へ肱をつき熊手みたいな大きい指先でそれを巻きながら、ニキータの方は見ず、　――へえ……さあてね。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあて――まだまだお早うござりますゆえ、かく、お銭の集まりましたる上からは、一つ、黒船おっ払いの、お呪いとして、南玉一世一代の踊を、御覧に入れます。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでお供いたしましょう」「そうさなあ、どこへ行こう」「どこへでもお供いたします」「さあてどこへ行ったものか、これ女馬子、どこへ行ったらよいな？",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあてね」と小一郎は、わざと困ったような顔をしたが、「女王殿下が許しましょうかしら？",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さあてこれからどうしたものだ」考えがグルグル渦を巻く。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあてこれからどうしたものだ。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはいけない」　と旗二郎、ポンと飛び返ると闇の中――以前隠れていた建物の角へ、ピッタリ背中を食っつけたが、「さあて、これからどうしたものだ」　突嗟の間に思案した。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあて何んな応待で其奴の本性見破ろうかな？",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さあて、これからどうしたものだ？",
              "citation": {
                "source": "染吉の朱盆",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さあてそれから、さあてそれから？",
              "citation": {
                "source": "染吉の朱盆",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあてどの辺りにあるんだろう？",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあてどっちへ逃げたものだ。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして警戒線にぶつかると、アイウエオやいろははおろか、逆に、すせもひゑしみめゆきさあてえ……。",
              "citation": {
                "source": "傷痕の背景",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあてな、そうしましょうか。",
              "citation": {
                "source": "庶民生活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然評判を落すといふことも起るかな」　道平はそのまゝ夕食を招ばれて、ゆつくり腰を落ちつけてゐたが、夜ふけ近い頃になつて、ひよつこり「さあて、帰るかな」　と云つた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「外から這入って来た奴が、あると云いなさるのか」「さあてな。",
              "citation": {
                "source": "乳を刺す",
                "author": "黒門町伝七捕物帳",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寒い寒い、ヤケに寒い」　チンと一つ鼻をかみ、「さあて、どっちへ行ったものかな」　あてなしにブラブラ歩き出した。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さあて生酔いの俺様だが、飛天夜叉殿の美しさには、ほとほと参っているのでな。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小父さん諾いてくださるでしょうか」「さあて私にお願いとは？",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあて、どうしたものだろう？",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあてどのへんから切り込んで行こう」　またも聞こえる水調子。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあてね、どこへ行こう」「それでは宛てがございませんので？",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあて　アイロンがけも　おしまい。",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
