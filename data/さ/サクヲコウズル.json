[
  {
    "uuid": "b18c8afe-85d5-5e91-bf93-722e32d22914",
    "entry": "策を講ずる",
    "reading": {
      "primary": "さくをこうずる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
