        "examples": {
          "standard": [
            {
              "text": "横綱は得意の鯖折りで相手力士を土俵に沈めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あんなに体格差があるのに、鯖折りで勝つなんて見事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鯖折りは、相手の体勢を崩して一気に押し倒す相撲の技だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そのままいけば鯖折りという手になりそうだった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯖折りというのは、よくは知らないが、反けざまに躯を二つに折られるのらしい。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
