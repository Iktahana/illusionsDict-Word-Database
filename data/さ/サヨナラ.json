        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いろいろお世話になりました　　いろいろお世話になりましたねえ　　いろいろお世話になりましたさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに良いお天気の日に　　お別れしてゆくのかと思ふとほんとに辛い　　こんなに良いお天気の日にさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、午睡の夢から覚めてみると　　みなさん家を空けておいでだつた　　あの時を妙に思ひ出しますさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして明日の今頃は　　長の年月見馴れてる　　故郷の土をば見てゐるのですさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはそんなにパラソルを振る　　僕にはあんまり眩しいのです　　あなたはそんなにパラソルを振るさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私この家に、朝さよならします。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はさよならを云つて、冷えた靴を穿いた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えなくならうとする前に彼は一寸振向いて、「お嬢さんさよなら」と、高い声で巫戯けて云つた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲があたしを連れてくのです……さよなら地球よ、さやうなら！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ももう、とほくはないのかもしれない……２『それではさよならといつて、めうに真鍮の光沢かなんぞのやうな笑を湛へて彼奴は、あのドアの所を立ち去つたのだつたあね。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さよなら、おっかさん。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さよなら、おっかさん。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北風がわらって、「ことしもこれでまずさよならさよならっていうわけだ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さよなら……」　荒荒しく女の腕を振りほどいて、さう叫び殘すと、私は振り向きもせずに扉の外へ飛び出した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あゝではさよなら。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよなら、北上山地、北上川、岩手県の夜の風、今武田先生が廻ってみんなの席の工合や何かを見て行った。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さよならみな様。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さよなら、どうか空の王様によろしく。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さよなら、さよなら。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜巻は二人をおろして「さよなら、ごきげんよろしゅう」と云いながら風のように海に帰って行きました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよなら、えい、畜生、その骨汁は、空虚だったのか。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
