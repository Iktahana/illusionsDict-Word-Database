        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お祖母ちやんには、この柿の樹と、塀とに渡してある重さうな干物竿が却々持扱へなかつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉と眉との間に皺を寄せたり伸ばしたりしながら、竿のあちらの端とこちらの端をかはるがはるに見てゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、もう三十余年前にただ一度実見したきりなので記憶がはなはだたしかでないが、網を張った叉手の二等辺三角形の両辺の長さが少なくも九尺くらいあり、柄竿の長さもほぼそのくらいあるかと思われ、とにかくずいぶん大きなものであるので、それを自由に操作するには相当の腕力を要するものであったように思う。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "網の竿をのばしたと思うと急に足を早めて網を投げた。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "艫の処を見ると定さんが旗竿へもたれて浜の方を見ながら口笛を吹いているからそこへいって話しかける。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の方が、釣り竿を堤防の石垣の穴にさし込んどいて、「かうして屋根を葺くんだよ」　と云つて、堤の上に乾してあつた乾草を胡桃の枝に渡して、屋根を葺いてやつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の持つてゐる釣竿は未だ見えた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣竿を寄せ、竿頭からテグスを掴むと、私は力まかせに引つ張つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "テグスは竿頭から三分の一位の処で切れたことが、手さぐりで分つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はカジカンだ手で竿を畳み、子供たちの方へ堤の上を歩いて行つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「竿はどこへやつた？",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、分つた、分つた」　私は子供の竿を抜きにかかつたが、元の方の二本が固くて抜けなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "出征を祝す、の征旗も、旗を取り込んで、てつぺんに葉を少し残した旗竿だけが、淋しく軒先きに立つてゐる。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "分らぬ事として竿の先に吊しておくのは慎重ではあろうが忠実とは云われまい。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊は一｜列になって、崖をななめに下り、中にはさきに黒い鉤のついた長い竿を持った人もありました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顧みると町の旅館の旗が竿頭に白く動いて居る。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十｜近い、背は低いが骨太の老人で矢張釣竿を持て居る。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど一人が竿を出し得る丈の場處だからボズさんは唯見物をして居た。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『病氣に良くない、』『雨が降りさうですから』など宿の者がとめるのも聞かず、僕は竿を持て出掛けた。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ竿竹や竿竹」というのをひと月ほど前に聞いたのは珍しかった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井から竹竿で突張った鉋のようなものでごしりごしりと刻んでいるのが往来から見えていた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカシヤの樹の下には、カギをつけた長い竹竿で、子供達が、白い藤のような花を薄暗い街燈にすかして、もぎ取ろうと肩が凝るほど首を上に向けきっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "剥げ落ちた朱門の上で、細長い竿の青天白日旗が、大きく風をはらんでいる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "醒めたるまゝを封介の、　　　　憤りほのかに立ちいでて、けじろき水のちりあくた、　　　もだして馬の指竿とりぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄工所の人は小さなランチへ波の凌ぎに長い竹竿を用意して荒天のなかを救助に向かった。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉取竿を持った子供があちこちする。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫籠を持たされた児は、時どき立ち留まっては籠の中を見、また竿の方を見ては小走りに随いてゆく。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　いのちの孤獨、われより出でて徘徊し、歩道に種を蒔きてゆく、種を蒔くひと、みづを撒くひと、光るしやつぽのひと、そのこども、しぬびあるきのたそがれに、眼もおよばぬ東京の、いはんかたなきはるけさおぼえ、ぎたる彈く、ぎたる彈く。",
              "citation": {
                "source": "ぎたる彈くひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "源次が起って南向きの雨戸をあけると、もう六ツ（午前六時）すぎの朝の光りは、庭から一度にさっと流れ込んで、まだ新しい蚊帳の波をまっさおに照らした、死んだ女の顔はいよいよ蒼く映って物凄くみえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵の横にある大きな柿の木の大枝小枝がまっさおな南国の空いっぱいに広がっている。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
