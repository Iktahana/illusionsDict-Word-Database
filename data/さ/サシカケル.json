    "definitions": [
      {
        "index": 1,
        "gloss": "to hold (umbrella) over",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
