          "literary": [
            {
              "text": "※３　複六方錐＝六辺の三角錐が上下に合わさったもの。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊７　正義標　三角錐形の置物で、頂上に帝室の紋章をつけ、三つの面に各々ペテロ一世の勅令を彫みつけたもので、役所のテーブルの上に必らず備えつけられていたもの。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔は凸凹がはげしくて岩を見るようで、鼻が三角錐のようにとがって前へとびだしている。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
