[
  {
    "uuid": "f4ddcfa3-b62c-5c4c-9c33-64d65e0ad122",
    "entry": "再勤",
    "reading": {
      "primary": "さいきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
