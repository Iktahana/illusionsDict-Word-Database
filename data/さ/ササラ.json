    "definitions": [
      {
        "index": 1,
        "gloss": "bamboo whisk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
