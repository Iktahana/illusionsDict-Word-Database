[
  {
    "uuid": "53f69a1c-9155-57c7-81f7-492be0968aea",
    "entry": "西国",
    "reading": {
      "primary": "さいごく",
      "alternatives": [
        "さいこく"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
