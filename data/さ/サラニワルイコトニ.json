        "examples": {
          "standard": [
            {
              "text": "プレゼン中にパソコンがフリーズした。さらに悪いことに、バックアップも取っていなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "約束の時間に遅れた。さらに悪いことに、相手の誕生日を忘れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雨が降り出した。さらに悪いことに、傘を家に忘れてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さらに悪いことには、子供は時計を落して壊した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれを憎悪の的とするような者に、あるいは（さらに悪いことには）われわれを眼中に置かないような者に、一｜生涯われわれを結びつける、この結婚という習慣の連鎖に比ぶれば、自分の寂寞もさほど悲しくないように彼には思われた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
