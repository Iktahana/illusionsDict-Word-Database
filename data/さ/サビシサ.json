[
  {
    "uuid": "0b10eac7-71f3-5dd8-aeef-935254c6dac2",
    "entry": "寂しさ",
    "reading": {
      "primary": "さびしさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
