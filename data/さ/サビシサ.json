    "definitions": [
      {
        "index": 1,
        "gloss": "(feeling of) loneliness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが彼が帰化を決心し、日本の土となることを覚悟した時、言い知れぬ寂しさとやるせなさが、心の底にうずつき迫るのを感じたであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした時の寂しさとやるせなさを紛らすために、詩人はわざと煙草の火を消し、ボオボオという寂しい貝を吹いたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の方でも、同じやうな感想を抱いて居たので、突然自殺の報告に接した時は、裏切られたやうな怒と寂しさを感じた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした春の日の光の下で、人間の心に湧いて来るこの不思議な悩み、あこがれ、寂しさ、捉えようもない孤独感は何だろうか。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩春の日の弱い日だまりを感じさせるような、或る荒寥とした、心の隅の寂しさを感じさせる句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の句と同じく、或る荒寥とした、心の隅の寂しさを感じさせる句であるが、その「寂しさ」は、勿論｜厭世の寂しさではなく、また芭蕉の寂びしさともちがっている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま行路に逢う知人の顔にも、生活の寂しさが暗く漂っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「侘び」とは、前にも他の句解で述べた通り、人間生活の寂しさや悲しさを、主観の心境の底で噛みしめながら、これを対照の自然に映して、そこに或る沁々とした心の家郷を見出すことである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に評釈した「飛弾山の質屋閉しぬ夜半の冬」と同想であり、荒寥とした寂しさの中に、或る人恋しさの郷愁を感じさせる俳句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕭条たる秋風の音は、それ自ら芭蕉の心霊の声であり、よるべもなく救いもない、虚無の寂しさを引き裂くところの叫である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦はその同じ虚無の寂しさから、森林に入って出家し、遂に人類救済の悟道に入った。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凩に匂ひやつけし帰り花　冬の北風が吹きすさんで庭の隅に、侘しい枯木の枝に咲いてる帰り花を見て、心のよるべない果敢なさと寂しさとを、しみじみ哀傷深く感じたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しさや華のあたりのあすならふ「あすは檜の木とかや、谷の老木のいへることあり。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物園にて灼きつく如く寂しさ迫りひとり來りて園内の木立を行けば枯葉みな地に落ち猛獸は檻の中に憂ひ眠れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一群の人たちは、遅塚麗水、大町桂月、江見水蔭、田山花袋、久保天随、坪谷水哉などであるが、花袋が紀行文家と言われた時分は、自然派文学勃興以前のことで、文章に感傷癖はあったが、淡泊清新、ことに武蔵野あたりの原野や雑木林の寂しさを、淡彩的に点描するのに巧みであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しさは、人の心の空虚を占領した。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ意味からいって彼女の芸は巴里の哀れさ寂しさをしみじみ秘めた小さいもろけた小屋ほど適する。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "選まれたということの孤独の寂しさ、また晴れがましさ、責任の重苦しさと権利の娯しさ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の祖神の翁に、噎返るような怒りと愛惜の念、また、不如意の口惜しさ、老いて取残されるものの寂しさがこもごも胸に突き上げて来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は真昼の寂しさ以外、何も意識していない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうやって自分を真昼の寂しさに憩わしている、そのことさえも意識していない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮のない相手に向って放つその声には自分が世話をしている青年の手前勝手を詰る激しい鋭さが、発声口から聴話器を握っている自分の手に伝わるまでに響いたが、彼女の心の中は不安な脅えがやや情緒的に醗酵して寂しさの微醺のようなものになって、精神を活溌にしていた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "満目｜粛殺の気に充ちて旅のうら寂しさが骨身に徹る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありたけの魂をすっかり投げ出して、どうでもして下さいと言いたくなるような寂しさですね」「この底に、ある力強いものがあるんだが、まあ君は女だからね」　小唄に残っている間の土山へひょっこり出る。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈愛深ければこそ、白髪をかかえて吾児を旅に手離して寂しさを守って居るのである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人が訪ねて來ると、時々その笛をポーポーと鳴らしながら、「こいつを吹いとると、人生の寂しさを忘れるわえ。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの西行のやうな牧水氏が、遠いところから訪ねて來て追ひ歸され、孤影悄然として門を出て行く姿を考へ、名状できない寂しさと、氣のすまない思ひで一杯になつた。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今迄、故意にそれを言はないやうに、寂しさから眼をそらした。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田だけは、江戸時代から、郡内の甲斐絹の本場を控えて、旅人の交通が繁かっただけあって、山の坊のさびしさが漂うと共に、宿場の賑わいをも兼ねて見られる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主頭め、山山は集ひて青き原をなすさてその上の丘のさびしさ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
