  {
    "uuid": "23cda603-a763-5575-b351-7f13a8f7b4b2",
    "entry": "三々",
    "reading": {
      "primary": "さんさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
