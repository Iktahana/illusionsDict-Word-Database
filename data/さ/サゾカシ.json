        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そなたと永劫離れぬ双生像に鋳られるなら、娘も嘸かし本望でござろう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事に柔順な翁は、この諫止に従ったらしいが嘸かし残念であったろうと思う。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘸かしビックリなすったでしょう。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のつまりませぬくり言を長々と書きつけまして嘸かしお倦きになったことで御座いましょう。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御病気の折柄をも構いませず、女心のせつなさに、こんなに長々とした事を御眼にかけまして嘸かしお読みづらくてお疲れの事と存じます。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来の日本には独身の男女が嘸かし殖えることであろう。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのみじめな残骸を見てまわると、吾が日本の「地震鯰」も嘸かし溜飲が下ったろうと思われる痛快さである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い間雪に包まれた人たちにとつては嘸かしこの見榮えのせぬさびしい花に心を惹かるゝことであらう。",
              "citation": {
                "source": "花二三",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な御縁によってあなたの許に嫁ぎ、新婚の一夜を過して、その翌日、実家へ戻って、そのまま、御そばに伺わぬ私の行いを、あなたは嘸かしお怒りで御座いましょう。",
              "citation": {
                "source": "秘密の相似",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れには反して、世に落人の見る影もなき今の我身、草葉の蔭より先君の嘸かし腑甲斐なき者と思ひ給はん。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私が春のインバネスを羽織つてゐたことを修一から別れた妻が聞いたら、「おや／＼、そないなお洒落をしとつたの、イヨウ／＼」と、嘸かし笑ふであらう。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰らぬと思つて居る所へ不意に帰つて行つたら、嘸かし皆が吃驚するであらう。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘸かしビックリなすった事で御座んしょう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御苦労さん」なぞいう挨拶がましいことを云ったことは一度もなかったのだから、金鵄勲章の配達手君にとっては嘸かし傲慢な、生意気な青二才に見えたであろう。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから考えるとこの時の私の眼は、嘸かし鋭い光りを放っていたであろうと思う。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者は嘸かし自烈たいであろう。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは嘸かし面白いでしょう。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、介抱が巧く行かなかった当の責任者の副院長が、嘸かし狼狽しているだろうと想像した、嘲りの意味の微笑も交っていたように思う。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は嘸かしわしを恨んでいるだろう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘸かし立派に撮れた事と思ってゐます。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第によつたならば、少々位の狐肉は送つてくれるかも知れないと、気がついたからすぐ浅間山麓へ手紙をだし、千円の皮を残す銀狐は嘸かし肉もおいしからうとたよりしたのであつた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘸かしまた聞かせられることだらうなあ。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "人夫が自分たちの用にあてる天幕を忘れて持って来なかったので、お荷物にかける携帯天幕を人夫用にお貸下げになって、お荷物は皆天幕の中に入れた為に、嘸かしお窮屈でいらせられた御事と恐懼に堪えない。",
              "citation": {
                "source": "秩父宮殿下に侍して槍ヶ岳へ",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月には伊勢殿の御勘気も解けて、上洛御免のお沙汰がありましたとやら、またそのうち嘸かし色々と怪しげな物ごとが出来いたすことでございましょう。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月には伊勢殿の御勘気も解けて、上洛御免のお沙汰がありましたとやら、またそのうち嘸かし色々と怪しげな物ごとが出来いたすことでございませう。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「仲の町は嘸かし賑うこってげしょう。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ皆朝顔のおかげといたく愛して翌年の夏に至りけるに、去年の花より多くの種残りて、さりとは数多生ひ出で、蔓の頃はさぞかしと思ひやらる。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽先生ども、さぞかしガヤガヤと非難することだろうッて。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そいつはさぞかし愉快だろうな！",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頭から水をかぶったり、水の底のほうまでもぐっていったりするのは、とっても楽しいんですもの」「ふん、さぞかし、楽しいでしょうよ」と、ニワトリの奥さんは、言いました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
