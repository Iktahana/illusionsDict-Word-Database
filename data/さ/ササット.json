          "literary": [
            {
              "text": "ささっ、ささっと大粒の雨が合間々々に一息しながら降り続いた。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さささっと　ねこぬこタムに　かけよって　何が何だか　わからないうちに　――　みぐるみ　はがされ　まるめられて、　ひもで　ぎゅうぎゅう　ぐるぐるまきに　しばられて。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、ささっと廊下を急ぐ足音がして、シュッとマッチを擦る音がして、燃え殻をガタゴト落とす音がした。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が入室すると、文具類をささっと脇にどけた。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
