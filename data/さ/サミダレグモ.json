        "examples": {
          "standard": [
            {
              "text": "五月雨雲が空を覆い、今にも雨が降り出しそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんよりとした五月雨雲が、梅雨の訪れを告げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "五月雨雲の隙間から、わずかに青空が見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "五月雨雲の間に見え隠れする白馬連峯を物色するうち、やがて見覚えの代馬が所在を示した。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は陣小屋にかくれて、鬱陶しい五月雨雲を廂の外にみながら、だいぶ晴々しくない顔をしていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
