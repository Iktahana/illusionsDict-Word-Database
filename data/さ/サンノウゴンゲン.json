        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『厳神鈔』に山王権現第一の使者に猿、第二の使者鹿なり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の起こりましたのは山王権現、俗に山王さんといわれているあのお祭りのさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくするうちにも、山王権現のおみこしは、総江戸八十八カ町の山車引き物、屋台を従えながら、しずしずと、いや初かつおのごとく威勢よく竹橋ご門外に向かって、お矢倉さきにさしかかってまいりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "山王権現の祟りも恐れ給はずや」ト、様々にいひ紛らし、間隙を見て逃げんと構ふるにぞ。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、山王権現に対するおほやまくひの神の本体が、もつとはつきりせぬ間は、生得の使はしめかどうかは、疑ひの余地がある。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大僧正が聞いて、愛護を山王権現と斎うた。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "川村杳樹氏（実は柳田国男先生）が提供せられた沢山の難題問答（郷土研究四の七）の例の中、陸前赤沼長老阪で、西行に舌を捲かした松下童子が、山王権現の化身であつたと言ふ話も、多少根本の山王に痕跡のあつたものとすれば、まへの関係は一層深くなるのだが、数点の類似だけでは、愛護・皇慶の交渉はむつかしい。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "比叡山の地主神｜大山咋神は、最澄によって山王権現として祭られている。",
              "citation": {
                "source": "憑き物系統に関する民族的研究",
                "author": "その一例として飛騨の牛蒡種",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷川明神山王権現また芝の山内はいずれもわが家を去ること遠くはない。",
              "citation": {
                "source": "写況雑記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原を過ぎて大川、山王権現の森を左に望むころから、一人の若い女が後になり前になり自分を尾けているのに、与惣次は気が付いたのである。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "槍祭夏の夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月十四、十五日は永田馬場、日吉山王権現の御祭礼。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "山王権現は徳川家の産土神。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには先ず、山王権現のお力を借りる以外に手がない。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　激昂していた大衆は、すっかり溜飲を下げて、「頭を下げ、手をついて、降伏した者を、この上、踏みにじってもしかたがあるまい」と、「念仏｜停止」の奏請運動は、せっかく、山王権現の神輿まで磨いたところであったが、（沙汰止み――）ということになってしまった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
