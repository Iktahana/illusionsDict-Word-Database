    "definitions": [
      {
        "index": 1,
        "gloss": "deity enshrined at Hie Shrine (in Shiga and Tokyo)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
