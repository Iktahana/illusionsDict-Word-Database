    "definitions": [
      {
        "index": 1,
        "gloss": "three sun (ca. 9.1 cm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "思いがけなく頭の上が、二、三寸ほど、大根卸しでも注いだように、白くなっている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の藤二がどこからか健吉が使い古した古独楽を探し出して来て、左右の掌の間に三寸釘の頭をひしゃいで通した心棒を挾んでまわした。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "独楽に磨きをかけ、買った時には、細い針金のような心棒だったのを三寸釘に挿しかえた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本箱の上に釘を二本立ててその間にわずかに三寸四角ぐらいの紙を張ったのがスクリーンである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず初めは、浴槽の水を掻き廻さないで、水面二、三寸のところへ寒暖計の球をさしこんで、所定の温度に達した頃に報知して来るのだから、かき廻さないで飛び込めば上の方は適温だが、底の方はまだ水である。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな面の皮の厚さが、二寸も三寸もありそうなゴツイ彼等も、自分自身の悪業のため、満洲がいにくゝなる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一分間ばかりたつと、その戸口へよく肥った、頬の肉が垂れ、眉毛が三寸くらいに長く伸びている老人がチャンチャンコを着て出てきた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不気味で投出そうとするとずるずると辷って指の尖へ吸ついてぶらりと下った、その放れた指の尖から真赤な美しい血が垂々と出たから、吃驚して目の下へ指をつけてじっと見ると、今折曲げた肱の処へつるりと垂懸っているのは同形をした、幅が五分、丈が三寸ばかりの山海鼠。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにも、かれ、蚊帳吊るため部屋の四隅に打ちこまれてある三寸くぎ抜かばやと、もともと四尺八寸の小女、高所の釘と背のびしながらの悪戦苦闘、ちらと拝見したこともございました。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この川に三寸厚サの一枚板で橋が懸かっている。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番前の両脚と、一番後ろの両脚とをかたみがわりに拝むようにすり合せて、それで頭を撫でたり、羽根をつくろったりする動作を根気よく続けては、何んの必要があってか、素早くその位置を二三寸ずつ上の方に移した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イフヒムの奴も太腐れて居やがる癖に、胸三寸と来ちゃからっきし乳臭なんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子は、自分ながら、どうしたことかと下唇を痛いほど噛んで笑いを止め、五尺三寸の娘の身体を、寝床から軽く滑り下ろした。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隔の襖は裏表、両方の肩で圧されて、すらすらと三寸ばかり、暗き柳と、曇れる花、淋しく顔を見合せた、トタンに跫音、続いて跫音、夫人は衝と退いて小さな咳。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "目ばかり黒い、けばけばしく真赤な禅入を、木兎引の木兎、で三寸ばかりの天目台、すくすくとある上へ、大は小児の握拳、小さいのは団栗ぐらいな処まで、ずらりと乗せたのを、その俯目に、ト狙いながら、件の吹矢筒で、フッ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　城下の果に霧を展いて、銀線の揺れつつ光る海の上に、紅日、山の端の松を沈むこと二三寸。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と乳の下三寸に銃口を向ければ、「それじゃ行こうか。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、厚さは雜と塀の上から二階家の大屋根の空と見て、幅の廣さは何のくらゐまで漲つて居るか、殆ど見當が附かない、と言ふうちにも、幾干ともなく、急ぎもせず、後れもせず、遮るものを避けながら、一つ一つがおなじやうに、二三寸づゝ、縱横に間をおいて、悠然として流れて通る。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手首の白さ更に可三寸。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不浄よけの金襴の切にくるんだ、たけ三寸ばかり、黒塗の小さな御厨子を捧げ出して、袈裟を机に折り、その上へ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "石抱きは十露盤板と称する三角形の板をならべた台のうえに罪人を坐らせて、その膝のうえに石の板を積むので、石は伊豆石にかぎられ、長さ三尺、厚さ三寸、目方は一枚十三貫である。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣り責は青細引で罪人の両手をうしろに縛って、地上より三寸六分の高さまで釣りあげるのである。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "背丈が、五尺三寸あった。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の暮れかたからちらちらしはじめ間もなくおおきい牡丹雪にかわり三寸くらい積ったころ、宿場の六個の半鐘が一時に鳴った。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛は卓をとんとたたいて卓のうえにさしわたし三寸くらい深さ一寸くらいのくぼみをこしらえてから答えた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村氏が五百円の賞金と直径三寸大の賞牌に相当するのに、他の学者はただの一銭の賞金にも直径一分の賞牌にも値せぬように俗衆に思わせるのは、木村氏の功績を表するがために、他の学者に屈辱を与えたと同じ事に帰着する。",
              "citation": {
                "source": "学者と名誉",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "脊丈が、五尺三寸あった。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
