      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cops",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "言ひ得てゐない所もあるかと思ふが、何分締切間際の事故、何分の御察しを願ふ。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "云へばいふ程、相手は心理的観察の対象を、益々得るといふわけだし、云ふ方は、益々話の内容自体の中に突き進むといつたわけだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのためには、人の心理を洞察する聡明な智慧と、絶えず同化しようと努めるところの、献身的な意志と努力が必要である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等と交はることは、私にとつてちがつた宇宙への觀察だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに小説家は、常に何事に對しても客觀的で、冷靜な觀察眼をはなつてゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのちがつた空氣は、意地の惡い觀察の眼をもつて、じろじろと自分の醉態を眺めてゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに丁度、酒に醉つた者が醉はない人々の中にゐて、意地惡く狂態を觀察されるやうな、一種不愉快な自覺が生ずる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川君に對する時、いつも自分はさうした不快さ――觀察されるものの不快さ――を、本能の微妙な隅に直感した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもこれは、小説家について全く知らない私が、一般の習性となつてる小説家的本能（觀察本能）を、たまたま初見の谷崎君や芥川君について邪解したものにすぎなかつたのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は決して、そんな意地惡き觀察をしてゐるのでない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ態度が、職業的に習性となつてるその小説家的態度が、ある冷酷な――酒に醉はない――觀察本能を、我々ちがつた世界の人間に印象させるにすぎないのだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場にはこのまちが始めてのようであったが、べつだん驚きもせずゆったりした歩調で私と少しはなれて歩きながら、両側の小窓小窓の女の顔をひとつひとつ熟察していた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹はすぐに察知したらしく、「ペリカンをかいているのです」とひくく私に言って聞かせながら、ペリカンの様様の姿態をおそろしく乱暴な線でさっさと写しとっていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまつたね、話がないんだ、と言つて笑ふと、娘さんは、私の窮屈がつてゐるのを察して、男は無口なはうがいい、と言ひ置いてさつさと部屋から出て行つて呉れた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（下）　甲府偵察のこと　きらきら光るＧペンを、たくさん財布にいれて、それを懷に抱いて歩いてゐると、何だか自分が清潔で、若々しくて、氣持のいいものである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、御推察を願います。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを察してやらなければいけない。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の推察するに、私の所から逃げた当分は、新しき男とその友人の家などに行つた場合、男を変へたことを少々誇りげにし、その理由として男が自分に教へた理智的な目的を語つたり、もつと気紛れな場合には、私について人に分り易い欠点――そのために彼の女が私を嫌つたのではない欠点を語つたらしいのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚痴つぽい観察が不可ないんだ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡り廊下に近い一棟の病室の者達が、最早その赤坊の苦しげな絶え／＼の泣き声のために「急病人あり」と知つて、縁側に出て見えもせぬ診察室の方に首を伸してゐた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "せきを一つして診察所のドアを開けた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し認識しようと観察しようと結構だ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ応用科学が、何かの目的の下に認識したり観察したりする様に認識したり観察したりするのは無駄だ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "認識が面白い限りに於て認識され、観察が面白い限りに観察されるのは結構なことだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "訝かつても自分に殆んどない要素である故遂に推察出来ず、疑心悪鬼を生じ、芸術家を憎むに到る。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日社長の宅へ行つたといふのはつまり御機嫌伺ひ方々その真否の偵察に出掛けたのであつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶の舌ゼンマイに似る暑さかな暖かや蕊に臘ぬる造り花臘梅や雪うち透かす枝のたけ「蝶の舌」の句は、ゼンマイに似ているといふ目付け所が山であり、比喩の奇警にして観察の細かいところに作者の味噌があるのだらうが、結果はそれだけの機智であつて、本質的に何の俳味も詩情もない、単なる才気だけの作品である。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の二つの句もやはり同じやうに観察の細かさと技巧の凝り性を衒つた句で、末梢神経的な先鋭さはあるとしても、ポエヂイとしての真実な本質性がなく、やはり頭脳と才気と工夫だけで造花的に作つた句である。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊林宮沢賢治エレキに魚をとるのみか鳥さへ犯すしれをのこ捕らでやまんと駐在の戸田巡査こそいかめしきまこと楊に磁の乗りて小鳥は鉄のたぐひかやひとむれさつと落ち入りてしらむ梢ぞあやしけれ",
              "citation": {
                "source": "楊林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れる時その話のことで「明日かあさつては是非訪ねるから」と三田村自身云つたのだが未だに来ない。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
