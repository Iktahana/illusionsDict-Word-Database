[
  {
    "uuid": "a325bf76-002d-5195-b210-70d8d69dffdb",
    "entry": "察",
    "reading": {
      "primary": "さつ",
      "alternatives": [
        "サツ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
