        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "土蔵の横を曲ったお媼さんの俥が、邸をめぐった長い珊瑚樹の生垣に添って走り尽すと、やがて、茫としてつきる処が見えぬほど、広く続いた耕地の中心を一直線に専断した平坦な県道に、敏捷な、軽快な姿を現わすのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "武帝其の舅に力を添へて、まけるなとて、珊瑚樹の高さ二尺なるを賜ふ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心は次第々々に其中に引き込まれて、遂に「珊瑚樹の根付」迄行って全くあなたの為に擒にされて仕舞ったのです。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "派手に美しき声す）月の灘の桃色の枝珊瑚樹、対の一株、丈八尺、周囲三抱の分。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……桃色の枝珊瑚樹、丈八尺、周囲三抱の分までにござった。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "珊瑚樹の青い葉が窓から覗いていて、一枚一枚の葉が、電燈の光を受けて、強く輝いている。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百舌が鳴く、くゐい、くゐい、くゐい、りりり……まん円い真赤な太陽が、今、蜒つて上つた段々畑の珊瑚樹にくわつと燃えあがる、――海には帆が光る、光る、光る。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は光る珊瑚樹と照りかへる村の間に見ゆ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の行きとまりに低い珊瑚樹の生垣、中ほどに形ばかりの枝折戸、枝折戸の外は三尺ばかりの流れに一枚板の小橋を渡して広い田圃を見晴らすのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　珊瑚樹垣の根には蕗の薹が無邪気に伸びて花を咲きかけている。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の高い珊瑚樹の生垣の外は、桑畑が繁りきって、背戸の木戸口も見えないほどである。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉妹を先にして予は桑畑の中を通って珊瑚樹垣の下をくぐった。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "整骨醫の家はがら竹の垣根に珊瑚樹の大木が掩ひかぶさつて陰氣に見えて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次は一｜度整骨醫の門を潜つてからは、世間には這※に怪我人の數が有るものだらうかと絶えず驚愕と恐怖との念に壓せられて居たが、珊瑚樹の繁茂した木蔭から竹の垣根を往來へ出た時彼は身も心も俄に輕くなつたことを感じた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は其處に何物をも得ないで遁るやうに珊瑚樹の木蔭を出た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、枝珊瑚樹を台にして、それに黒奴が大勢遊んでいるようなものを拵える。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "脂土や石膏に心を惹かれたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は以前蔵前の師匠の家にいた当時、あの珊瑚樹に黒奴のとまっている仕事をたのまれた関係で、旧知の人でありますから、久しぶり対面しますと、「一つ木彫りをお願いしたい」ということである。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "牙彫りを排し木彫りに固執したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい古い欅の樹と松の樹とが蔽い冠さって、左の隅に珊瑚樹の大きいのが繁っていた。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雄はいかにしても苦しいので、突如その珊瑚樹の蔭に身を躱して、その根本の地上に身を横えた。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿、珊瑚樹、柚子、八ツ手など皆そうだ。",
              "citation": {
                "source": "新茶のかおり",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "垣の隅には椿と珊瑚樹との厚い緑の葉が日を受けていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "珊瑚樹の垣は茂って、はっきりと中は見えないが、それでも白壁の土蔵と棟の高い家屋とはわかった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三も一緒に縁におりて、珊瑚樹の垣根や、隣りの松や槻のような木の梢を下から見あげていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "明の宦官王振の家産を沒收した時、金庫銀庫併せて六十餘棟に及び、珊瑚樹の高さ六七尺のもののみにても、二十餘株あつたといふ。",
              "citation": {
                "source": "支那の宦官",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "沙室屋の珊瑚樹を詐ったのも甚内です。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "呂宋助左衛門の手代だったのも、備前宰相の伽羅を切ったのも、利休居士の友だちになったのも、沙室屋の珊瑚樹を詐ったのも、伏見の城の金蔵を破ったのも、八人の参河侍を斬り倒したのも、――ありとあらゆる甚内の名誉は、ことごとくわたしに奪われるのです。",
              "citation": {
                "source": "報恩記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "川瀬の音がすぐ真下に聞かれる庭園の梅の樹や杏の樹や珊瑚樹の古木を、彼はどんなに愛したか知れない。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝ってほしい誕生日ではないが、祝ってくれた父や母や伯母も、いまは墓石になって、わたしの植えた珊瑚樹の葉擦れの音を聞きながら、青山の墓地に眠っている――　と、伊東はその晩の日記に書くことであろう。",
              "citation": {
                "source": "暴風雨に終わった一日",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の問答から察すると、女の男にくれと逼ったのは珊瑚樹の珠か何からしい。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ松本について見ても、この間の晩神田の洋食屋で、田口の娘を相手にして珊瑚樹の珠がどうしたとかこうしたとか云っていた時の方が、よっぽど活きて動いていた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
