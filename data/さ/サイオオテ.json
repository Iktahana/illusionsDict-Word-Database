        "examples": {
          "standard": [
            {
              "text": "社長の最終的な裁可を得て、このプロジェクトは正式に始動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "法案は国会で可決されたが、政府の裁可を待ってから施行される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の提案は、会議で多くの賛同を得たが、最終的な裁可は保留された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "大型コンピューター用パッケージ・ソフトの販売とサポートで独立系ソフトハウスの最大手の地位を築いてきたアシストが、パーソナルコンピューター用に九千七百円の優しい文房具シリーズをぶつけるに至った経緯にはすでに触れた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、時代を画する新世代機が間もなく最大手のメーカーから出荷されるとの情報は、他社の追撃を抑えるうえで大きな威力を発揮した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "クレードルストンのお抱え株屋は業界の最大手。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
