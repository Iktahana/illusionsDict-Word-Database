    "definitions": [
      {
        "index": 1,
        "gloss": "fine split (e.g. in wood)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "試しに杖をあげて見るとささくれまでがはっきりと写った。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「確です、（信女――）尤も、ささくれてはいましたが。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅梅は花が散ってしまっていて青青した葉をひろげ、百日紅は枝々の股からささくれのようなひょろひょろした若葉を生やしていた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋銀の皿しげる草むらをたづねつつなにをほしさに呼ばへるわれぞゆくゆく葉うらにささくれて指も眞紅にぬれぬれぬ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もその方を見ると、靴の底の横の方が、ベタルのために軽くささくれ立っていた。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴底の横側が踏板の縁にこすれて軽くささくれ立っているのが、私にも見て取れた。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄濁った形のくずれたのが、狂うようにささくれだって、澄み切った青空のここかしこに屯していた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストを恋い恋うて、夜も昼もやみがたく、十字架を編み込んだ美しい帯を作って献げようと一心に、日課も何もそっちのけにして、指の先がささくれるまで編み針を動かした可憐な少女も、その幻想の中に現われ出た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ささくれて、赤くかわいた口びるからもれ出るあの囈言……それがどうかすると近々と耳に聞こえたり、ぼんやりと目を開いたりするその顔が浮き出して見えたりした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは吹き散らされながら、塊まって、白く柔かな針を集めたように、ささくれだつ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒も呑めず弟子もいない庸三は、しばらくいるうちにすっかり孤独に陥って、酔って悪く絡まってくる友達を防禦するのに骨が折れ、神経がささくれ立ったように疲れて来たものだったが、今考えるとそれも過去の惨めな彼の姿であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "摺り減った当り棒、縁のささくれ立った目笊、絵具の赤々した丼などもあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在おかれている有様は受け身の警戒の形なのだが、その犬の心としては主張するところをもっていて、犬の身になってみれば何となしそれが尤もでありそうな、そういう表情が、毛のささくれた穢れた体に漲っている。",
              "citation": {
                "source": "犬三態",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸が開いて居るので、庭へ廻り、ささくれた廊下や、赤土で、かさかさな庭を見、此が自分の家になるのかと、怪しいような心持さえした。",
              "citation": {
                "source": "小さき家の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "指にたつた、ささくれを針のさきで、ほぐしてくれた母……。",
              "citation": {
                "source": "心願の国",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "使い古してささくれたのは削ってまた共衿の縫目へ差しておく。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の着物も、ささくれて来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして年をとっているし、ささくれた身なりのままで、父の国へやりたくないけれど、二人共絶体絶命のどんづまり故、沈黙って汽車に乗るより仕方がない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢山の本も今はもう二三冊になってしまって、ビール箱には、善蔵の「子を連れて」だの、「労働者セイリョフ」、直哉の「和解」がささくれているきりなり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかそんな可憐な子供達のささくれた白粉の濃い顔を見ていると、たまらない程、私も誰かにすがりつきたくなる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ささくれた角帯に、クリップで小さい万年筆の頭がのぞいている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞼には深い影がさして、あのように誇っていた長い睫も、抜けたようにささくれて、見るかげもない。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間ばかり前に裁判所へ行って貰っておいた接見許可証は、四つに畳んだ端がささくれたようになって入っている。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それは、ささくれた神経の方で、許さない。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗い階段を螺旋まきに駈けあがり天井を抜けると、ささくれ立ったコンクリートの屋上に出る。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがては冬來り、葉は落ち、枝はささくれ立ち、あの險しくも白眼をした雪もよひの空、寒い雨、地凍る霜の夜明け、君の呻きは細枝をふるはし、低い空を嘯かう。",
              "citation": {
                "source": "展望",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ私によく腑におちなかったのは、近頃彼女がひどく身体を大事にしてることで、酒をつつしみ、食物に気をつけ、指先のささくれにも手当をしていた。",
              "citation": {
                "source": "死ね！",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ジャケツの上に背広をひっかけてる相手の男は、日焼けした顔に善良そうな笑みを浮かべ、指の節々が太く爪先がささくれてる頑丈な手で、用心深く猪口を口元に運びながら、煙草はやめたが、酒はなかなかやめられず、今日も女房に内緒でちょっとやってるんで、と変に淋しいことを云い出した。",
              "citation": {
                "source": "霧の中",
                "author": "――「正夫の世界」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻毛と指先のささくれ、これが何より禁物である。",
              "citation": {
                "source": "塩花",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
