[
  {
    "uuid": "2905253e-23fc-5668-87fe-ed711a3fe2ea",
    "entry": "参考になる",
    "reading": {
      "primary": "さんこうになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
