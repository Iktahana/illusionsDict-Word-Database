    "definitions": [
      {
        "index": 1,
        "gloss": "talent and accomplishments",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
