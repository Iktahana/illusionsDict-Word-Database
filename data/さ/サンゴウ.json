[
  {
    "uuid": "f317cd21-6c00-5de6-be2a-d6c1dcc01d58",
    "entry": "山号",
    "reading": {
      "primary": "さんごう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "honorific mountain name prefixed to a temple's name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神護寺と云う名の寺は山城の高雄山にもあって、寺として珍らしいものでは無いが、雷山にかつて神護院があって、境内に香合石のあることを思うと、ここの石城山神護寺も、もとは「コウゴジ」と読んで、所謂石城たる神籠石を山号寺号に因んだものかもしれない。",
              "citation": {
                "source": "周防石城山神籠石探検記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "当夕九時、英船仏山号に移りてカントンに向かう。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏山号の着せし岸は植民州と名づけ、外国人の寄留地にして洋館並立す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "山号は確かだが寺名はあやしい。",
              "citation": {
                "source": "初旅の残像",
                "author": "安倍能成",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰勝寺の山号はいうまでもなく、細川家の中祖細川｜藤孝（幽斎）の泰勝院徹宗玄旨の法名から取ったものであるが、その細川幽斎と妙心寺禅林とのあいだがらは、ずいぶん密接なものだったらしい。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、観心寺には、檜ノ尾山の山号もある。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
