[
  {
    "uuid": "33f39832-0c7e-5938-8c8a-d6ff34ea2600",
    "entry": "肴",
    "reading": {
      "primary": "さかな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
