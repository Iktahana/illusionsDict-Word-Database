  {
    "uuid": "9983f553-e6b1-5597-bf10-3ad11d33a946",
    "entry": "酒断ち",
    "reading": {
      "primary": "さかだち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "swearing off liquor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どんなうつくしいけしきも、この鏡にうつすと、煮くたらしたほうれんそうのように見え、どんなにりっぱなひとたちも、いやなかっこうになるか、どうたいのない、あたまだけで、さかだちするかしました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき出がけには、まだ二、三日お頼みしなくちゃなるまいかとも思ったものだから、寝言でもさかだちでもご随意のように願っておきましてたっけが、お聞きのとおりの仕儀でござんすからな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、他力本願がさかだちしたタンカもきられている。",
              "citation": {
                "source": "しようがない、だろうか？",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが一九四七年の春以来日本民主化の第三の段階に入ってから、とくに、一九四八年に入ってから、猛烈な戦争挑発と並行して、日本の内外で民主的という表現が、そろりそろりとさかだちした意味で使用されはじめた。",
              "citation": {
                "source": "三年たった今日",
                "author": "――日本の文化のまもり――",
                "note": "青空文庫"
              }
            },
            {
              "text": "千貢の詩集を出してくれれば、私は裸になってさかだちをしてみせてもいい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかだちをして、足で五色の輪をつかひわける者がゐました。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうなると、わたしもこまりましたが、なに、やつつけてやれといふ気になつて、できるなら、さかだちをして、僕ときやうさうしてみろ、といつてやりました。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、外に出て、線を引いて、わたしがかたはしに立つと、三人の男がさかだちをしてわたしにならびました。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、いくらさかだちがじやうずでも、わたしは足で走るんですから、勝負はわかつてゐます。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の男がさかだちをしてかけるところは、じつにみごとでしたが、子供でもわたしの方は足で走るんです、わけなく勝ちました。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかだちをした男が、足をばたばたうごかして向つてくるのを、わたしはぐるぐるまはつてよけながら、すきをみて、一本の足をとらへて、ぐつと引きたふしてやりました。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくらさかだちがじやうずでも、子供の僕にかなはないぢやないか。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人たちにさかだちをさせて、さんざんからかつたり、銅貨と金貨とをとりかへさしたりして、みどころがある。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなひゞきがして、船底にめりめりと音がして、船はさかだちになりました。",
              "citation": {
                "source": "スミトラ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに甘酒に中毒してさかだちしても駄目だ。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "太――いや、リーロフ大佐」　アメリカの艦艇が、さかだちとなって、ゆらゆらと水中に、しずみはじめるごとに、司令官ケレンコは、太刀川にむかいほこらしげにいった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩句をよりゆたかにする筈の插画は、シャガールがさかだちしたって、一つのより弱い説明でしかないのですものね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうあんなのさかだちしたってないことよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "如才ない富公は　お嬢さん　お嬢さん　と機嫌をとつて、さかだちをしたり、筋斗がいりをしたり、いろんな芸当をやつてみせる。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "押えこみ、はねかえし、もつれ合ってゴロゴロところげまわり、二本の足がさかだちをして相手の顔をはさみ、しめつけ、ふりほどき、上になり、下になり、横転し、逆転し、そのたびごとに、二つの肉団のあらゆる部分が、筋張り、ふるえ、躍動した。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の下には、床板がなくて、そこしれぬ深さの中に、やっぱり何千人という一つ目小僧どもが、まっすぐに立ったり、さかだちをしたりして、ウジャウジャと、むらがっているではありませんか。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこも、無限の空にまで、つづいて、やはり何千人という一つ目小僧が、顔を下に向けて、さかだちしたり、まっすぐに立ったりして、見通しのきかぬ上の方まで、むらがっているではありませんか。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、かわいらしい幼虫は、やっぱりあの細い糸にぶら下って、頭を下にさかだちをして、壺の底にかさなり合っている青虫の一匹を、小さなくちばしで、つついていた。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかだっているまゆが、いっそうさかだち、ほそい目が、リンのようにかがやき、赤いくちびるをひきしめて、ぎりぎりと、歯がみをしているのです。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして舌尖に血をながし、直ちに血判して、「もし、この都の内で、曹操に対し、あなたが大事を決行する日が来たら、それがしは必ず西涼の遠きより烽火をあげて、今日の約にお応え申さん」　云ううちにも馬騰はまなじりを裂き、髪さかだち、すでに風雲に嘯く日のすがたをおもわせるほどだった。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
