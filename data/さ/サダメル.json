    "definitions": [
      {
        "index": 1,
        "gloss": "to decide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼等の考え出すいろいろな革新は僕の周囲に死の機会を増し、彼等の説くところは僕を死に導き、または彼等の定める法律は僕に死を与えるのだ。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説の稿料に準じて、詩の稿料を定めるのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "船も丁度あると来たので帰る事と定める。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去を定めるものは現在であって、現在を定めるものが未来ではあるまいか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際重力加速度ｇを定めるにはこのような直接の方法によらず、却って間接に振子の週期と長さから定め、空気の抵抗の影響は必要に応じて理論から計算した補正で除去する事が出来るのである。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからこのＸを定めるという方法だ」と云って聞かせた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸素と水素の比重を定めた次の仕事は当然窒素の比重を定めることであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその区々な表現の価値を定めるものも科学の場合とは無論一様でない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような時代に当って「完成の度」に代って作品の価値を定めるものは何であろう。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇藝術の眞價を定めるものは、何といつても「時」である。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは二三度肩を聳かして、そして心配らしい、物を聞き定めるやうな顔をした。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "質量は物体に含まるる実体の量だというように考えたは昔の事で、後にむしろ力の概念が先になって、物体に力が働いた時に受ける加速度を定める係数というふうに解釈した実証論者もある。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余談はしばらくおいて、ＡＢ、ＡＣ、ＡＤ……の関係、なお念のために比較の主客を置換してＢＡ、ＣＡ、ＤＡ……の関係の濃度に対するだいたいの比較的の数値を定める事ができたとすれば、少なくもここにＡＢという一つの「鎖の輪」が、従来よりはやや科学的な根拠の上に仮設される。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その波の量子エネルギーを定める振動数はある意味での量子の「形」とも見られるのではあるまいか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち彼は形の変化は、形を定める「部分」の錯列によって生ずると考える。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果から、「左側通行」の規則が、どの程度まで市民の頭にしみ込んでいるかを判断する一つの目安を定めることも可能である。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも、この種の研究を充分に進めた上で、消防署の配置や消火栓の分布を定めるのでなければ決して合理的とは言えないであろうと思われる。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳めしい鉄門の鉄柵越しに門前の様子を見定めると、電光の様に小潜りを出た。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするためには経営維持に必要な費用は租税などと類似の方法で一般から集め、記者や編集員らも適当に組織された選挙制度によって定めるべきであろう。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その穴に爆薬を仕掛けて一度に倒壊させるのであったが、倒れる方向を定めるために、その倒そうとする方向の側面に穴の数を多くしていた。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが出来ないことが判って見ると今度は積極的に慧鶴を未来の夫と思い定めることによって良心を宥めた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから室子は結局のところは男に敵わないと思っていたが、この青年は抜群の腕と見えて、彼女の左舷の方に漕ぎ出ると、オールへ水の引掛け方も従容と、室子の艇の、左舷の四分の一の辺へ、艇頭を定めると、ほとんど半メートルの差もなく漕ぎ連れて来る。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の特長は他人とくらべてどういうところにあるか、それを自覚し見定めることの確実さ、不確実さによってその人の一生には無駄がなく、随って有意義に一生を使い得ると思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから智の方の知識経験も疎かには出来ませんが、その根本方針を定めるのはどうしても慧の直覚に拠らなければなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは怪み、中は驚いて、果はその顔を見定めると、幼立に覚えのある、裏長屋の悪戯小憎、かつてその黒い目で睨んでおいた少年の懐しさに、取った手を放さないでいたのであったが。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく全島が山と、森と、谷とで蔽はれて居つては、今更何處へと方向を定める事も出來ぬのである、之からあんな深山幽谷に進入するのは、却て危險を招くやうなものだから、島の探險は一先づ中止して、兎も角も再び海岸に皈らんと踵を廻らす途端、日出雄少年は急に歩を停めて『あら、あの音は？",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、何方でも、早く橄欖島に到着した方は、向ふ一週間の間、其島の附近で待合はせ、一週間※て後も他の一方が見えぬ時には、最早運命の盡と覺悟を定める筈であつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　波頭、雲の層、累る蓮華か、象徴った台座の巌を見定める隙もなしに、声とともに羽織の襟を払って、ずかと銅像の足の爪を、烏の嘴のごとく上から覗かせて、真背向に腰を掛けた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟と瞳を定めると、其處に此處に、それ彼處に、其の數の夥しさ、下に立つたものは、赤蜻蛉の隧道を潛るのである。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちで彼の顔を見さだめるよりも、相手の眼は捷かった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
