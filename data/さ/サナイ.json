    "definitions": [
      {
        "index": 1,
        "gloss": "suona (Chinese shawm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "脳貧血を起さないまでも、一層がつかりしますから。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに、ああした魔力ある彼の言葉は、彼の不思議な天賦の性情から、自然と湧き出づる人格のリズムであつて、断じて彼以外の者の追蹤を許さない秘密であらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど『美しいシャボン玉』を壊さないように、注意に注意して気をつけましたと、未亡人となった夫人が後で言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）君、一緒に本を出さないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋にそなへつけの机のまへに坐つて、右の引き出しには、書きあげた原稿を、左の引き出しには、まだ汚さない原稿用紙を。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく思い出さないようにしているのですけれど。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍはお前の成績の悪いことをおつ父さんに話さないのだらうか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍが話さないでもおつ父さんが訊く。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り蕪村がこの点で独歩であり、多くの秀れた句を書いているのは、彼の気質が若々しく、枯淡や洒脱を本領とする一般俳人の中にあって、範疇を逸する青春性を持っていたのと、かつ卑俗に堕さない精神のロマネスクとを品性に支持していたためである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧家の奥深く、影のささないひっそりした部屋。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」早く殺さないと肉が落ちると云うので要太郎が鳥の脇腹をつまむと首がぐたりとなった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば雨のふる日に傘をささないで往来を歩きたいと思ったとしても、なかなかそうはさせてくれない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう手紙を寄こさないで下さい。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰問袋も寄こさないで下さい。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく思ひ出さないやうにしてゐるのですけれど。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕口を言はず、駄洒落を飛ばさないから、Ｋ君をユーモリストだと誰も思はないけれど、挨拶をさせたり、序文を書かせたりしたら、Ｋ君のものは天下一品だ。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、その前の頁には、Ｔ・Ｉといふ人が、「變な言ひかたかも知れないが、Ｋさんは、ほんとの聲を出す人であつた、さうしてほんとの聲しか、出さない人であつた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足を踏みはづさないやうに氣をつけて下さいよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかげで明治三十七年二月の『太陽』に掲載せられたのはいいが、どうしたものか、博文館から原稿料を送ってよこさない。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "痕を残さない、濃さと淡さの碧が、谷から舞い上る霧のほむらに、ぬらりと光る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "西に向いて、また一峰を超え、やや下ってまた北に向って上る、霧の中で目標にする山もないから、手に磁石を放さない、何でも北へ向けばいいのだ、北へ、北へと歩む。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "随って厳格に言えば、初雪という語は意義を成さないのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし氷河を欠いた日本アルプスには、それほど雪の働きを示さないから、岩石は鋭い山稜や、尖った峰となって、粗硬な形態を示している。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、君といふ肉体は、一つの遺言も残さないで死ねば、それつ切りだ。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに俺に食ってかかったって、仕方がないじゃないか、な、ちゃんと嘆願さえすれば、船長だって涙金位寄越さないものでもないんだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が七輪の炭火の上に倒れても、よう起さないで泣き出してしまう老人に、――畜生！",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "又いくら廣くても其の面積は吾々の下駄ばきの足を容れる事を許さない爲に、なんとなく行き詰まつた窮屈な感じを與へるが、畑地ならば實際何處でも歩いて行けば行かれると思ふだけでも自由な舒びやかな氣がする。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋に火がついて燃えているので巡査が張番していて人を通さない。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "処々どっしりした旧独逸の高級品屋が在り、柵を引しめる棒柱のように見えるので、下品には決して墜さないで、あとは軒並みの戦後独逸の安物屋、街のかみさんや、あんちゃん、ねえちゃんといった処へ、時々素晴らしい毛皮の令嬢奥様も交った調和が、かえって淋しく品の好い高級品屋の店頭より綺麗なのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の神が神としていちばん大事な修業をする間、少しでも娘の気を散らさないよう、爪の垢ほどの穢れを持来さしめぬよう心懸けて呉れるのがほんとの親子の情だといった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
