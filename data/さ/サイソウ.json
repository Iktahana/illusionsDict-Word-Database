  {
    "uuid": "2b9ea423-d377-58eb-8278-4535ba9e8a7f",
    "entry": "洒掃",
    "reading": {
      "primary": "さいそう",
      "alternatives": [
        "せいそう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
