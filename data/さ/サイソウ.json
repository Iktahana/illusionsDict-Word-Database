      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "scrubbing (with water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "村の処女会の人々がにぎやかに神社の境内を洒掃してゐる、辻々には演習兵歓迎の日の丸がへんぽんとひるがへつてゐる、これもまたわるくない風景だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "前庭の洒掃浄らかにして一草一石を止めず。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "左衞門『何事ぞ』と問へば、『斯かる事、我口より申すは如何なものなれども、二十を越えてはや三歳にもなりたれば、家に洒掃の妻なくては萬に事缺けて快からず、幸ひ時頼｜見定め置きし女子有れば、父上より改めて婚禮を御取計らひ下されたく、願ひと言ふは此事に候』。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども星遷り世變り、之が洒掃の勞を取るの人なく、雨雪之れを碎き、風露之れを破り、今や塊然として土芥に委するも人絶えて之を顧みず、先人の功名得て而して傳ふべきなし。",
              "citation": {
                "source": "人生終に奈何",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の顔色はなお家の門戸のごとし、広く人に交わりて客来を自由にせんには、まず門戸を開きて入口を洒掃し、とにかくに寄りつきを好くするこそ緊要なれ。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……朱子の学説を要約すれば、洒掃応待の礼よりはじめ、恭敬いやしくも事をなさず、かつ心を静止して、読書して事物を究め、聖賢の域に入れよとある。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まれびとを迎へる爲の洒掃と考へるのは、まれびとの本義をとり違へて居る。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生叱りつけたり、口を聞かなかったり、身上の苦労をさせたり、小供の世話をさせたりするばかりで何一つ洒掃薪水の労に酬いた事はない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れて来ると、観客の笑い声だけでなく、囁き声やら、赤ん坊の泣き声まで、はっきり聞えて来て、かえってうるさいそうである。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これといって教育はないでしょうが、今晩はいっさいそういうことは問わないことにしましょう。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にゆうべも宵からどこへか出て行って、夜の明けないうちに戻って来て、あさ飯には小さいそうだ鰹一尾を食って、その骨を庭さきへ投げ出して置いて、物置へはいって寝てしまったとのことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう先生だから、いっこう知りません、何か間違いでしょう、偉大なる暗闇という論文は雑誌に出ましたが、匿名です、先生の崇拝者が書いたものですから御安心なさいくらいに言っておけば、そうかで、すぐ済んでしまうわけだが、このさいそうはいかん。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジプシイ――悪いことはすべて彼らの所為となっていて、またじっさいそうかも知れないが、毒々しい色布と人ずれとに身を固め、職業的勇敢さをもってどこにでも出現し、どこまでも肉迫してくる乞食民族の旅行隊――かれらの皺の一つにも諸大陸の味がこまかく刻み込まれている。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさいそう思った。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間というものは、自分が奇妙な性質をもっているのだと常に言いきかされていると、じっさいそういう性質になってしまいがちである。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさいそうだから、そういうよりほかないじゃないか。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさいそういう例は数えきれないほどあるのです。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、彼がわたしの生活にああいう役廻りを演じたからではなく、要するに、彼がじっさいそういう人間だったからです。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            }
          ]
        }
