    "definitions": [
      {
        "index": 1,
        "gloss": "colour picture (color)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
