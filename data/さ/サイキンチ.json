        "examples": {
          "standard": [
            {
              "text": "この山脈の奥地には、かつて大規模な採金地があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "採金地を目指して、多くの人々が夢と希望を胸に旅立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い地図には、隠された採金地の場所が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あの方は毎週二三度はロンドンに出ますが、何でも南アフリカの採金地の株に、非常に興味を持っているようでございますわ」「それではスミスさん、いずれこの上にも変ったことがありましたら、また入らして下さい。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、君の左の人差し指と拇指の間の皮膚の筋を見て、君が採金地の株を買わなかったと云うことが、あまり首をひねりまわさない中に解ったと云うわけさ」「どうも僕には何の事か解らないね」「いや誠に御もっとも至極――しかしこれはごく手短に説明することが出来るんだ。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            }
          ]
        }
