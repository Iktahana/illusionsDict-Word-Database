    "definitions": [
      {
        "index": 1,
        "gloss": "Sakurada Gate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
