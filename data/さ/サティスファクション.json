        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「さてさて、今日はどんな面白い話が聞けるかな？」と、老人は孫に期待を込めて尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さてさて、これで目的は達せられたわけだ。」と、彼は満足げに頷いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さてさて、困ったことになったぞ！」と、探偵は事件の意外な展開に頭を抱えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ローリング・ストーンズは、慶一にとっては、デイヴ・クラーク・ファイヴより落ちる、三流のバンドだが、〈サティスファクション〉よりは、こっちのほうが好みではある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、〈サティスファクション〉で聴かれる、この時代に、こんなものが存在するのが信じられない、ばかげたドラム・ブレイクにくらべれば、〈ゲット・オフ・オヴ・マイ・クラウド〉のイントロのドラムは、はるかにパワーがある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「〈サティスファクション〉でも、やるわけ？",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファズを手にした人間は、どうしても〈サティスファクション〉のリフを弾かずにはいられない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
